# Ephemeral per-cell runner image for hive-bench.
#
# Used for two phases with DIFFERENT network postures:
#   - generation (U3): the candidate agent edits a restored repo. It needs
#     egress to its model API, so this runs with an egress ALLOWLIST (the model
#     endpoint only) — never the host network unrestricted. Agent CLIs + auth
#     are mounted read-only at run time; they are NEVER baked into an image
#     layer (auth must not ship in a public image).
#   - gate (U4): apply the candidate diff and run the repo's tests with
#     --network none. No agent, no model, no egress.
#
# Ruby base because the v1 corpus is Ruby/CLI-weighted; per-repo toolchains are
# layered on as the corpus widens (see corpus curation, U8).
FROM ruby:3.4-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends git ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# Non-root: the candidate's code and the gate's tests run unprivileged.
RUN useradd --create-home --shell /bin/bash runner
USER runner
WORKDIR /work

# Agent CLIs (claude/codex/pi) and their auth are bind-mounted at run time by
# harness/lib/isolation.sh, not installed here.
ENTRYPOINT ["/bin/bash", "-lc"]
