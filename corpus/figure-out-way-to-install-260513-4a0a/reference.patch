diff --git a/packaging/aur/PKGBUILD.template b/packaging/aur/PKGBUILD.template
new file mode 100644
index 00000000..a31a9448
--- /dev/null
+++ b/packaging/aur/PKGBUILD.template
@@ -0,0 +1,38 @@
+# Maintainer: Hive maintainers <maintainers@users.noreply.github.com>
+pkgname=hive-bin
+pkgver=<%= version %>
+pkgrel=1
+pkgdesc='Folder-as-agent pipeline for autonomous software tasks'
+arch=('x86_64' 'aarch64')
+url='https://github.com/ivankuznetsov/hive'
+license=('MIT')
+# `provides=('hive')` + `conflicts=('hive')` is INTENTIONAL and not a
+# self-conflict. We provide the virtual `hive` capability so consumers
+# can `pacman -S hive`, and conflict with the unrelated `apache-hive`
+# AUR package name `hive` (the SQL-on-Hadoop tool) so pacman blocks
+# the collision before our symlink fallback is needed.
+provides=('hive')
+conflicts=('hive' 'apache-hive')
+install=hive.install
+source_x86_64=("https://github.com/ivankuznetsov/hive/releases/download/v${pkgver}/hive-${pkgver}-linux-x86_64-gnu.tar.gz")
+source_aarch64=("https://github.com/ivankuznetsov/hive/releases/download/v${pkgver}/hive-${pkgver}-linux-aarch64-gnu.tar.gz")
+sha256sums_x86_64=('<%= sha256_linux_x86_64_gnu %>')
+sha256sums_aarch64=('<%= sha256_linux_aarch64_gnu %>')
+
+package() {
+  local target
+  case "${CARCH}" in
+    x86_64) target="linux-x86_64-gnu" ;;
+    aarch64) target="linux-aarch64-gnu" ;;
+    *) echo "unsupported architecture: ${CARCH}" >&2; exit 1 ;;
+  esac
+
+  install -Dm755 "${srcdir}/hive-${pkgver}-${target}/bin/hive" "${pkgdir}/usr/bin/hive"
+  install -Dm644 "${srcdir}/hive-${pkgver}-${target}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
+  install -dm755 "${pkgdir}/usr/share/hive"
+  cp -R --no-preserve=mode "${srcdir}/hive-${pkgver}-${target}/share/hive/." "${pkgdir}/usr/share/hive/"
+  find "${pkgdir}/usr/share/hive" -type d -exec chmod 755 {} +
+  find "${pkgdir}/usr/share/hive" -type f -exec chmod 644 {} +
+
+  printf 'aur\n' > "${pkgdir}/usr/share/hive/install-channel"
+}
