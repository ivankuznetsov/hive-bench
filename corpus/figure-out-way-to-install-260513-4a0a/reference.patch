+#!/usr/bin/env bash
+set -euo pipefail
+
+# `hv` is the fallback launcher when Apache Hive shadows our binary
+# earlier on PATH. We refuse to `exec hive` via `command -v`, because
+# on the exact collision this script exists to solve, `command -v
+# hive` resolves to Apache Hive. Instead, probe known install
+# locations in priority order.
+
+self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
+
+candidates=(
+  "${HIVE_BIN_OVERRIDE:-}"
+  "${XDG_BIN_HOME:-${HOME}/.local/bin}/hive"
+  "${HOMEBREW_PREFIX:-/opt/homebrew}/bin/hive"
+  "/usr/local/bin/hive"
+  "/usr/bin/hive"
+  "/opt/hive/bin/hive"
+)
+
+for candidate in "${candidates[@]}"; do
+  [[ -n "$candidate" ]] || continue
+  [[ -x "$candidate" ]] || continue
+
+  resolved="$(readlink -f "$candidate" 2>/dev/null || echo "$candidate")"
+  # Guard against `hv -> hv` chains: never exec into our own script.
+  [[ "$resolved" != "$self" ]] || continue
+
+  exec "$candidate" "$@"
+done
+
+echo "hv: hive binary not found in ${XDG_BIN_HOME:-${HOME}/.local/bin}, ${HOMEBREW_PREFIX:-/opt/homebrew}/bin, /usr/local/bin, /usr/bin, or /opt/hive/bin" >&2
+echo "hv: set HIVE_BIN_OVERRIDE=<path> to point at a custom install location" >&2
+echo "hv: install with 'brew install ivankuznetsov/hive/hive', 'yay -S hive-bin', or the pinned install.sh from install.md" >&2
+exit 127
