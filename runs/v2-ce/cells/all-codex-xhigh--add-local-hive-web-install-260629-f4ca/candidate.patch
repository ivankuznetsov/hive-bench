diff --git a/lib/hive/commands/setup/qmd_installer.rb b/lib/hive/commands/setup/qmd_installer.rb
new file mode 100644
index 00000000..5061c696
--- /dev/null
+++ b/lib/hive/commands/setup/qmd_installer.rb
@@ -0,0 +1,131 @@
+require "fileutils"
+require "open3"
+require "shellwords"
+require "hive/paths"
+
+module Hive
+  module Commands
+    class Setup
+      # Installs Hive's managed qmd CLI under XDG_DATA_HOME without touching
+      # the operator's global npm prefix.
+      class QmdInstaller
+        Result = Data.define(:status, :message, :path, :fix_command) do
+          def ok?
+            status == "ok"
+          end
+        end
+
+        NPM_PACKAGE = "@tobilu/qmd".freeze
+
+        def initialize(runner: nil, which: nil, data_home: nil, bin_home: nil, package: NPM_PACKAGE)
+          @runner = runner || ->(*argv) { Open3.capture3(*argv) }
+          @which = which || method(:which_on_path)
+          @data_home = data_home || Hive::Paths.data_home
+          @bin_home = bin_home || ENV["XDG_BIN_HOME"] || File.expand_path("~/.local/bin")
+          @package = package
+        end
+
+        def ensure!
+          if (existing = find_qmd)
+            return Result.new(status: "ok", message: "qmd found at #{existing}", path: existing, fix_command: nil)
+          end
+
+          unless @which.call("npm")
+            return Result.new(
+              status: "missing",
+              message: "qmd is not installed and npm is not available",
+              path: nil,
+              fix_command: install_command
+            )
+          end
+
+          FileUtils.mkdir_p(qmd_home)
+          _out, err, status = run("npm", "install", "--global", "--prefix", qmd_home,
+                                  "--no-audit", "--no-fund", @package)
+          unless status.success?
+            return Result.new(status: "failed", message: "qmd install failed: #{first_line(err)}",
+                              path: nil, fix_command: install_command)
+          end
+
+          run("npm", "rebuild", "--global", "--prefix", qmd_home, "better-sqlite3")
+          link_managed_binary
+
+          if File.executable?(qmd_bin)
+            Result.new(status: "ok", message: "qmd installed at #{qmd_bin}", path: qmd_bin, fix_command: nil)
+          else
+            Result.new(status: "failed", message: "qmd install completed but no executable was found at #{qmd_bin}",
+                       path: nil, fix_command: install_command)
+          end
+        rescue SystemCallError => e
+          Result.new(status: "failed", message: "qmd install failed: #{e.class}: #{e.message}",
+                     path: nil, fix_command: install_command)
+        end
+
+        def find_qmd
+          env_qmd = ENV["HIVE_QMD_BIN"].to_s
+          return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+          path_qmd = @which.call("qmd")
+          return path_qmd if path_qmd
+
+          candidates = [
+            qmd_bin,
+            File.expand_path("~/.local/share/hive/qmd/bin/qmd")
+          ]
+          install_prefix = install_prefix_path
+          candidates << File.join(install_prefix, "hive", "qmd", "bin", "qmd") if install_prefix
+          candidates.find { |candidate| File.file?(candidate) && File.executable?(candidate) }
+        end
+
+        def install_command
+          "npm install --global --prefix #{Shellwords.escape(qmd_home)} #{@package}"
+        end
+
+        private
+
+        def qmd_home
+          File.join(@data_home, "qmd")
+        end
+
+        def qmd_bin
+          File.join(qmd_home, "bin", "qmd")
+        end
+
+        def install_prefix_path
+          path = File.join(@data_home, "install-prefix")
+          return nil unless File.readable?(path)
+
+          File.read(path).lines.first.to_s.strip.then { |value| value.empty? ? nil : value }
+        end
+
+        def link_managed_binary
+          return unless File.executable?(qmd_bin)
+
+          FileUtils.mkdir_p(@bin_home)
+          link = File.join(@bin_home, "qmd")
+          return if File.exist?(link) && !File.symlink?(link)
+
+          FileUtils.ln_sf(qmd_bin, link)
+        rescue SystemCallError
+          nil
+        end
+
+        def run(*argv)
+          @runner.call(*argv)
+        end
+
+        def which_on_path(name)
+          ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+            path = File.join(dir, name)
+            return path if File.file?(path) && File.executable?(path)
+          end
+          nil
+        end
+
+        def first_line(text)
+          text.to_s.lines.map(&:strip).find { |line| !line.empty? }.to_s
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/setup/web_bundle.rb b/lib/hive/commands/setup/web_bundle.rb
new file mode 100644
index 00000000..fd75c5b7
--- /dev/null
+++ b/lib/hive/commands/setup/web_bundle.rb
@@ -0,0 +1,78 @@
+require "fileutils"
+require "open3"
+require "shellwords"
+require "hive/paths"
+require "hive/commands/web"
+
+module Hive
+  module Commands
+    class Setup
+      # Prepares the packaged/source Rails app bundle and its state-home
+      # SQLite storage for local foreground or service-managed web runs.
+      class WebBundle
+        Result = Data.define(:status, :message, :app_dir, :storage_dir, :fix_command) do
+          def ok?
+            status == "ok"
+          end
+        end
+
+        def initialize(app_dir: nil, storage_dir: nil, runner: nil)
+          @app_dir = app_dir
+          @storage_dir = storage_dir || File.join(Hive::Paths.state_home, "web-storage")
+          @runner = runner || ->(*argv, chdir: nil, env: {}) { Open3.capture3(env, *argv, chdir: chdir) }
+        end
+
+        def ensure!
+          app_dir = @app_dir || Hive::Commands::Web.rails_app_dir
+          unless app_dir
+            return Result.new(status: "missing", message: "Rails web app was not found",
+                              app_dir: nil, storage_dir: @storage_dir,
+                              fix_command: "Install a Hive package that includes web/, or set HIVEBOX_WEB_APP_DIR.")
+          end
+
+          FileUtils.mkdir_p(@storage_dir)
+          env = { "BUNDLE_GEMFILE" => File.join(app_dir, "Gemfile"), "HIVEBOX_STORAGE_DIR" => @storage_dir }
+          unless bundle_check?(app_dir, env)
+            _out, err, status = run("bundle", "install", chdir: app_dir, env: env)
+            unless status.success?
+              return Result.new(status: "failed", message: "web bundle install failed: #{first_line(err)}",
+                                app_dir: app_dir, storage_dir: @storage_dir, fix_command: bundle_fix(app_dir))
+            end
+          end
+
+          _out, err, status = run("bin/rails", "db:prepare", chdir: app_dir, env: env)
+          unless status.success?
+            return Result.new(status: "failed", message: "web db:prepare failed: #{first_line(err)}",
+                              app_dir: app_dir, storage_dir: @storage_dir,
+                              fix_command: "Ensure #{@storage_dir} is writable, then run #{bundle_fix(app_dir)} && bin/rails db:prepare")
+          end
+
+          Result.new(status: "ok", message: "web bundle ready at #{app_dir}",
+                     app_dir: app_dir, storage_dir: @storage_dir, fix_command: nil)
+        rescue SystemCallError => e
+          Result.new(status: "failed", message: "web bundle setup failed: #{e.class}: #{e.message}",
+                     app_dir: @app_dir, storage_dir: @storage_dir, fix_command: @app_dir ? bundle_fix(@app_dir) : nil)
+        end
+
+        private
+
+        def bundle_check?(app_dir, env)
+          _out, _err, status = run("bundle", "check", chdir: app_dir, env: env)
+          status.success?
+        end
+
+        def run(*argv, chdir:, env:)
+          @runner.call(*argv, chdir: chdir, env: env)
+        end
+
+        def bundle_fix(app_dir)
+          "cd #{Shellwords.escape(app_dir)} && bundle install"
+        end
+
+        def first_line(text)
+          text.to_s.lines.map(&:strip).find { |line| !line.empty? }.to_s
+        end
+      end
+    end
+  end
+end
