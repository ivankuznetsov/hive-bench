+# Sample systemd-user unit for `hive web` (Linux).
+#
+# This unit runs Rails in the foreground. systemd is the supervisor.
+
+[Unit]
+Description=Hive Rails web UI
+After=default.target
+StartLimitBurst=3
+StartLimitIntervalSec=300
+
+[Service]
+Type=simple
+Environment=HIVE_BIN=%h/.local/bin/hive
+Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
+ExecStart=%h/.local/bin/hive web
+Restart=on-failure
+RestartSec=10s
+KillMode=mixed
+TimeoutStopSec=60
+
+[Install]
+WantedBy=default.target
