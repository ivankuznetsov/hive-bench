index 00000000..aabe8581
--- /dev/null
+++ b/lib/hive/commands/setup/dependency_check.rb
@@ -0,0 +1,166 @@
+require "open3"
+require "rbconfig"
+require "rubygems"
+require "hive/agent_profiles"
+
+module Hive
+  module Commands
+    class Setup
+      # Host preflight for `hive setup`. External tools are diagnosed with
+      # operator-facing fix commands; setup never installs or authenticates them.
+      class DependencyCheck
+        Check = Data.define(:name, :status, :message, :fix_command, :fatal) do
+          def ok?
+            status == "ok"
+          end
+        end
+
+        REQUIRED_RUBY = Gem::Version.new("3.4.0")
+        EXTERNAL_COMMANDS = {
+          "git" => "Install git: https://git-scm.com/downloads",
+          "tmux" => "Install tmux (macOS: `brew install tmux`; Ubuntu/Debian: `sudo apt-get install tmux`)",
+          "gh" => "Install GitHub CLI: https://cli.github.com/",
+          "node" => "Install Node.js/npm: https://nodejs.org/",
+          "npm" => "Install Node.js/npm: https://nodejs.org/"
+        }.freeze
+
+        attr_reader :checks
+
+        def initialize(backends:, runner: nil, which: nil, home: Dir.home, host_os: RbConfig::CONFIG["host_os"])
+          @backends = Array(backends).map(&:to_s)
+          @runner = runner || ->(*argv) { Open3.capture3(*argv) }
+          @which = which || method(:which_on_path)
+          @home = home
+          @host_os = host_os
+          @checks = []
+        end
+
+        def call
+          @checks = []
+          check_platform
+          check_ruby
+          EXTERNAL_COMMANDS.each_key { |name| check_command(name) }
+          check_gh_auth if command_available?("gh")
+          check_agent_auth
+          @checks
+        end
+
+        def ok?
+          @checks.none? { |check| check.fatal && !check.ok? }
+        end
+
+        private
+
+        def add(name, status:, message:, fix_command: nil, fatal: true)
+          @checks << Check.new(
+            name: name,
+            status: status.to_s,
+            message: message,
+            fix_command: fix_command,
+            fatal: fatal
+          )
+        end
+
+        def check_platform
+          case @host_os
+          when /darwin|linux/i
+            add("platform", status: :ok, message: "supported #{@host_os}")
+          else
+            add(
+              "platform",
+              status: :missing,
+              message: "local services are supported on Linux and macOS; got #{@host_os}",
+              fix_command: "Run Hive local web on Linux/macOS, or use the Docker hivebox path."
+            )
+          end
+        end
+
+        def check_ruby
+          current = Gem::Version.new(RUBY_VERSION)
+          if current >= REQUIRED_RUBY
+            add("ruby", status: :ok, message: "Ruby #{RUBY_VERSION}")
+          else
+            add(
+              "ruby",
+              status: :missing,
+              message: "Ruby #{REQUIRED_RUBY} or newer is required; current Ruby is #{RUBY_VERSION}",
+              fix_command: "Install Ruby 3.4+ (for example `mise install ruby@3.4 && mise use ruby@3.4`)."
+            )
+          end
+        end
+
+        def check_command(name)
+          if command_available?(name)
+            add(name, status: :ok, message: "#{name} found at #{@which.call(name)}")
+          else
+            add(name, status: :missing, message: "#{name} is not installed or not on PATH",
+                      fix_command: EXTERNAL_COMMANDS.fetch(name))
+          end
+        end
+
+        def check_gh_auth
+          _out, err, status = run("gh", "auth", "status")
+          if status.success?
+            add("gh-auth", status: :ok, message: "gh is authenticated")
+          else
+            detail = first_line(err)
+            add(
+              "gh-auth",
+              status: :missing,
+              message: [ "gh is installed but not authenticated", detail ].reject(&:empty?).join(": "),
+              fix_command: "Run `gh auth login --hostname github.com --git-protocol https --web`."
+            )
+          end
+        rescue SystemCallError => e
+          add("gh-auth", status: :missing, message: "gh auth status could not run: #{e.message}",
+                         fix_command: "Install and authenticate GitHub CLI with `gh auth login`.")
+        end
+
+        def check_agent_auth
+          @backends.each do |name|
+            next unless %w[claude codex].include?(name)
+
+            if Hive::AgentProfiles.logged_in?(name, home: @home)
+              add("#{name}-auth", status: :ok, message: "#{name} credentials found")
+            else
+              add(
+                "#{name}-auth",
+                status: :missing,
+                message: "#{name} is not authenticated",
+                fix_command: agent_auth_command(name)
+              )
+            end
+          end
+        end
+
+        def agent_auth_command(name)
