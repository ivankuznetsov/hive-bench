diff --git a/test/e2e/scenarios/local_web_setup.yml b/test/e2e/scenarios/local_web_setup.yml
new file mode 100644
index 00000000..8446af0b
--- /dev/null
+++ b/test/e2e/scenarios/local_web_setup.yml
@@ -0,0 +1,156 @@
+name: local_web_setup
+description: Local setup, loopback web foreground, bind guardrail, and shared status smoke.
+tags: [local-web]
+steps:
+  - kind: ruby_block
+    description: Create fake external CLIs, service managers, credentials, and a tiny Rails-compatible app.
+    block: |
+      require "fileutils"
+      fakebin = File.join(run_home, "fakebin")
+      home = File.join(run_home, "home")
+      app = File.join(run_home, "fake-web")
+      FileUtils.mkdir_p([fakebin, home, File.join(app, "config"), File.join(app, "bin")])
+
+      write_exec = lambda do |path, body|
+        File.write(path, body)
+        FileUtils.chmod(0o755, path)
+      end
+
+      {
+        "gh" => "#!/usr/bin/env bash\n[ \"$1\" = auth ] && [ \"$2\" = status ] && exit 0\nexit 0\n",
+        "tmux" => "#!/usr/bin/env bash\n[ \"$1\" = -V ] && echo 'tmux 3.4'\nexit 0\n",
+        "node" => "#!/usr/bin/env bash\necho 'v20.0.0'\n",
+        "npm" => "#!/usr/bin/env bash\nexit 0\n",
+        "claude" => "#!/usr/bin/env bash\nexit 0\n",
+        "codex" => "#!/usr/bin/env bash\nexit 0\n",
+        "qmd" => "#!/usr/bin/env bash\nexit 0\n",
+        "bundle" => "#!/usr/bin/env bash\nexit 0\n",
+        "systemctl" => "#!/usr/bin/env bash\nexit 0\n",
+        "launchctl" => "#!/usr/bin/env bash\nexit 0\n"
+      }.each { |name, body| write_exec.call(File.join(fakebin, name), body) }
+      FileUtils.ln_sf(Hive::E2E::Paths.hive_bin, File.join(fakebin, "hive"))
+
+      FileUtils.mkdir_p(File.join(home, ".claude"))
+      FileUtils.mkdir_p(File.join(home, ".codex"))
+      File.write(File.join(home, ".claude", ".credentials.json"), '{"token":"fake"}')
+      File.write(File.join(home, ".codex", "auth.json"), '{"token":"fake"}')
+
+      File.write(File.join(app, "Gemfile"), "source 'https://rubygems.org'\n")
+      File.write(File.join(app, "config", "application.rb"), "# fake rails app marker\n")
+      write_exec.call(File.join(app, "bin", "rails"), <<~'RUBY')
+        #!/usr/bin/env ruby
+        if ARGV.first == "db:prepare"
+          exit 0
+        end
+        if ARGV.first == "server"
+          require "socket"
+          bind = "127.0.0.1"
+          port = 4567
+          ARGV.each_with_index do |arg, idx|
+            bind = ARGV[idx + 1] if arg == "-b"
+            port = ARGV[idx + 1].to_i if arg == "-p"
+          end
+          server = TCPServer.new(bind, port)
+          Signal.trap("TERM") { server.close; exit 0 }
+          loop do
+            client = server.accept
+            request = client.gets.to_s
+            while (line = client.gets)
+              break if line == "\r\n"
+            end
+            body = request.include?("/health") ? "OK\n" : "Hive local test\n"
+            client.write "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nContent-Length: #{body.bytesize}\r\nConnection: close\r\n\r\n#{body}"
+            client.close
+          end
+        end
+        exit 0
+      RUBY
+  - kind: cli
+    description: Run setup with fake host dependencies and service managers.
+    args: [setup]
+    env:
+      PATH: "{run_home}/fakebin:/usr/local/bin:/usr/bin:/bin"
+      HOME: "{run_home}/home"
+      HIVE_INVOKED_BIN: "{run_home}/fakebin/hive"
+      HIVEBOX_WEB_APP_DIR: "{run_home}/fake-web"
+    timeout: 60
+  - kind: state_assert
+    description: Setup enrolled the project for daemon dispatch.
+    path: "{sandbox}/.hive-state/config.yml"
+    match: "daemon:\\n  enabled: true"
+  - kind: spawn_background
+    description: Start foreground web on loopback with the fake Rails app.
+    id: web
+    args: [web, --bind, 127.0.0.1, --port, 4597]
+    env:
+      PATH: "{run_home}/fakebin:/usr/local/bin:/usr/bin:/bin"
+      HOME: "{run_home}/home"
+      HIVE_INVOKED_BIN: "{run_home}/fakebin/hive"
+      HIVEBOX_WEB_APP_DIR: "{run_home}/fake-web"
+  - kind: ruby_block
+    description: Confirm loopback /health is reachable without login.
+    block: |
+      require "net/http"
+      uri = URI("http://127.0.0.1:4597/health")
+      deadline = Time.now + 10
+      last_error = nil
+      until Time.now > deadline
+        begin
+          response = Net::HTTP.get_response(uri)
+          raise "unexpected health response #{response.code} #{response.body.inspect}" unless response.code == "200" && response.body.include?("OK")
+          break
+        rescue StandardError => e
+          last_error = e
+          sleep 0.2
+        end
+      end
+      raise "health check never passed: #{last_error&.message}" if Time.now > deadline
+  - kind: stop_process
+    id: web
+  - kind: ruby_block
+    description: Force global config to no-auth so non-loopback bind must be rejected.
+    block: |
+      require "yaml"
+      config_path = File.join(run_home, "config.yml")
+      data = YAML.safe_load_file(config_path) || {}
+      data["web"] ||= {}
+      data["web"]["auth_mode"] = "none"
+      data["web"]["unsafe_no_auth"] = false
+      File.write(config_path, data.to_yaml)
+  - kind: cli
+    description: Refuse unsafe non-loopback no-auth startup before Rails boots.
+    args: [web, --bind, 0.0.0.0, --port, 4598]
+    expect_exit: 64
+    expect_stderr_match: "refusing unauthenticated non-loopback"
+    env:
+      PATH: "{run_home}/fakebin:/usr/local/bin:/usr/bin:/bin"
+      HOME: "{run_home}/home"
+      HIVE_INVOKED_BIN: "{run_home}/fakebin/hive"
+      HIVEBOX_WEB_APP_DIR: "{run_home}/fake-web"
+  - kind: cli
+    description: Create a task through the CLI surface.
+    args: [new, "{project}", "local web smoke task"]
+  - kind: ruby_block
+    description: Confirm the web status feed sees the CLI-created task.
+    block: |
+      old_home = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = run_home
+      begin
+        require "hive/web/status_feed"
+        payload = Hive::Web::StatusFeed.new.snapshot
+        tasks = payload.fetch("projects").flat_map { |project| project.fetch("tasks", []) }
+        raise "StatusFeed did not include CLI-created task" unless tasks.any? { |task| task["slug"] == slug }
+      ensure
+        old_home.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old_home
+      end
+  - kind: json_assert
+    description: Daemon status reports the current unit binary without drift.
+    args: [daemon, status, --json]
+    schema: hive-daemon-status
+    expect_exit: 1
+    env:
+      PATH: "{run_home}/fakebin:/usr/local/bin:/usr/bin:/bin"
+      HOME: "{run_home}/home"
+      HIVE_INVOKED_BIN: "{run_home}/fakebin/hive"
+    pick: [binary_matches_cli]
+    equals: true
