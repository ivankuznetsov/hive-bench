new file mode 100644
index 00000000..a05feed8
--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,182 @@
+require "json"
+require "stringio"
+require "hive/config"
+require "hive/commands/init"
+require "hive/commands/daemon"
+require "hive/commands/setup/backend_prompt"
+require "hive/commands/setup/dependency_check"
+require "hive/commands/setup/qmd_installer"
+require "hive/commands/setup/web_bundle"
+
+module Hive
+  module Commands
+    # First-class local setup for running the CLI/TUI and Rails web UI against
+    # the same XDG/Hive state.
+    class Setup
+      Summary = Data.define(:ok, :checks, :qmd, :web_bundle, :project, :daemon, :web)
+
+      def initialize(project_path = Dir.pwd, json: false, start_web: true, web_service: true,
+                     dependency_check: nil, qmd_installer: nil, web_bundle: nil,
+                     output: $stdout, error: $stderr)
+        @project_path = File.expand_path(project_path || Dir.pwd)
+        @json = json
+        @start_web = start_web
+        @web_service = web_service
+        @dependency_check = dependency_check
+        @qmd_installer = qmd_installer
+        @web_bundle = web_bundle
+        @output = output
+        @error = error
+      end
+
+      def call
+        backends = collect_backends
+        Hive::Config.write_global_agents!(backends)
+
+        dependency_check = @dependency_check || DependencyCheck.new(backends: backends)
+        checks = dependency_check.call
+        render_checks(checks)
+
+        qmd = (@qmd_installer || QmdInstaller.new).ensure!
+        render_result("qmd", qmd)
+        web_bundle = (@web_bundle || WebBundle.new).ensure!
+        render_result("web bundle", web_bundle)
+
+        project = ensure_project_enrolled
+        daemon = ensure_daemon_service
+        web = ensure_web_service if @web_service || @start_web
+
+        ok = dependency_check.ok? && qmd.ok? && web_bundle.ok? && daemon.fetch("ok") && (web.nil? || web.fetch("ok"))
+        summary = Summary.new(ok: ok, checks: checks, qmd: qmd, web_bundle: web_bundle,
+                              project: project, daemon: daemon, web: web)
+        @json ? emit_json(summary) : emit_summary(summary)
+        raise Hive::Error, "hive setup found dependency issues; see fix commands above" unless ok
+
+        summary
+      rescue BackendPrompt::Aborted => e
+        warn_line("hive setup: aborted (#{e.message})")
+        exit Hive::ExitCodes::USAGE
+      end
+
+      private
+
+      def collect_backends
+        BackendPrompt.new(input: $stdin, output: @error, summary_io: @output).collect
+      end
+
+      def ensure_project_enrolled
+        unless File.file?(File.join(@project_path, ".hive-state", "config.yml"))
+          capture_command_output { Hive::Commands::Init.new(@project_path, force: false, json: false).call }
+        end
+        name = File.basename(@project_path)
+        Hive::Config.register_project(name: name, path: @project_path)
+        capture_command_output { Hive::Commands::Daemon.new("enable", name, json: false).call }
+        { "name" => name, "path" => @project_path, "enrolled" => true }
+      rescue Hive::AlreadyInitialized
+        name = File.basename(@project_path)
+        Hive::Config.register_project(name: name, path: @project_path)
+        capture_command_output { Hive::Commands::Daemon.new("enable", name, json: false).call }
+        { "name" => name, "path" => @project_path, "enrolled" => true }
+      end
+
+      def ensure_daemon_service
+        capture_command_output { Hive::Commands::Daemon.new("repair", json: false).call }
+        { "ok" => true, "command" => "hive daemon repair" }
+      rescue Hive::Error => e
+        warn_line("hive setup: daemon service repair failed: #{e.message}")
+        { "ok" => false, "command" => "hive daemon repair", "message" => e.message }
+      end
+
+      def ensure_web_service
+        require "hive/commands/web"
+        commands = []
+        if @web_service
+          capture_command_output { Hive::Commands::Web.new(subcommand: "install", force: true).call }
+          commands << "hive web install"
+        end
+        if @start_web
+          begin
+            capture_command_output { Hive::Commands::Web.new(subcommand: "start").call }
+            commands << "hive web start"
+          rescue Hive::Error => e
+            raise unless service_manager_unavailable?(e)
+
+            warn_line("hive setup: web service start skipped: #{e.message}")
+            return {
+              "ok" => true,
+              "command" => commands.join(" && "),
+              "message" => e.message,
+              "manual_command" => "hive web"
+            }
+          end
+        end
+        { "ok" => true, "command" => commands.join(" && ") }
+      rescue Hive::Error => e
+        command = commands&.last || "hive web install"
+        warn_line("hive setup: #{command} failed: #{e.message}")
+        { "ok" => false, "command" => command, "message" => e.message }
+      end
+
+      def service_manager_unavailable?(error)
+        error.message.include?("systemd-user is not available") ||
+          error.message.include?("launchctl is not available") ||
+          error.message.include?("services are not supported on this platform")
+      end
+
+      def capture_command_output
+        original_stdout = $stdout
+        original_stderr = $stderr
+        $stdout = StringIO.new
+        $stderr = StringIO.new
+        yield
+      ensure
+        $stdout = original_stdout if original_stdout
+        $stderr = original_stderr if original_stderr
+      end
+
+      def render_checks(checks)
+        checks.each do |check|
+          next if check.ok?
+
+          warn_line("hive setup: #{check.name}: #{check.message}")
+          warn_line("  fix: #{check.fix_command}") if check.fix_command
+        end
+      end
+
+      def render_result(label, result)
+        return if result.ok?
+
+        warn_line("hive setup: #{label}: #{result.message}")
+        warn_line("  fix: #{result.fix_command}") if result.fix_command
+      end
+
+      def emit_summary(summary)
+        @output.puts "hive setup: #{summary.ok ? 'ready' : 'needs attention'}"
+        @output.puts "  project: #{summary.project.fetch('name')} (daemon enabled)"
+        @output.puts "  web: http://127.0.0.1:4567"
+      rescue Errno::EPIPE
+        nil
+      end
+
+      def emit_json(summary)
+        @output.puts JSON.generate(
+          "schema" => "hive-setup",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-setup"),
+          "ok" => summary.ok,
+          "checks" => summary.checks.map { |check| check.to_h.transform_keys(&:to_s) },
+          "qmd" => summary.qmd.to_h.transform_keys(&:to_s),
+          "web_bundle" => summary.web_bundle.to_h.transform_keys(&:to_s),
+          "project" => summary.project,
+          "daemon" => summary.daemon,
+          "web" => summary.web
+        )
+      end
+
+      def warn_line(line)
+        @error.puts line
+      rescue Errno::EPIPE
+        nil
+      end
+    end
+  end
+end
