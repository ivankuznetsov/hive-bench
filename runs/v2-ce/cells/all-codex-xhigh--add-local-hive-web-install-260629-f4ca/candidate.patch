+require "test_helper"
+require "hive/commands/setup/qmd_installer"
+
+class SetupQmdInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  Status = Struct.new(:success?)
+
+  def test_existing_qmd_noops
+    with_tmp_dir do |dir|
+      qmd = File.join(dir, "qmd")
+      File.write(qmd, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, qmd)
+
+      result = Hive::Commands::Setup::QmdInstaller.new(which: ->(name) { name == "qmd" ? qmd : nil }).ensure!
+
+      assert result.ok?
+      assert_equal qmd, result.path
+    end
+  end
+
+  def test_missing_npm_reports_managed_install_command
+    with_tmp_dir do |dir|
+      result = Hive::Commands::Setup::QmdInstaller.new(
+        which: ->(_name) { nil },
+        data_home: dir
+      ).ensure!
+
+      refute result.ok?
+      assert_match(/npm install --global --prefix/, result.fix_command)
+    end
+  end
+
+  def test_installs_with_npm_when_available
+    with_tmp_dir do |dir|
+      commands = []
+      runner = lambda do |*argv|
+        commands << argv
+        if argv.include?("install")
+          qmd = File.join(dir, "qmd", "bin", "qmd")
+          FileUtils.mkdir_p(File.dirname(qmd))
+          File.write(qmd, "#!/bin/sh\n")
+          FileUtils.chmod(0o755, qmd)
+        end
+        [ "", "", Status.new(true) ]
+      end
+
+      result = Hive::Commands::Setup::QmdInstaller.new(
+        which: ->(name) { name == "npm" ? "/bin/npm" : nil },
+        runner: runner,
+        data_home: dir,
+        bin_home: File.join(dir, "bin")
+      ).ensure!
+
+      assert result.ok?
+      assert commands.any? { |argv| argv[0, 4] == %w[npm install --global --prefix] }
+    end
+  end
+end
