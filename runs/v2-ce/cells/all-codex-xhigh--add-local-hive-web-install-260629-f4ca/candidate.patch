+require "test_helper"
+require "hive/commands/setup/web_bundle"
+
+class SetupWebBundleTest < Minitest::Test
+  include HiveTestHelper
+
+  Status = Struct.new(:success?)
+
+  def stub_app
+    dir = Dir.mktmpdir("hive-web-bundle")
+    FileUtils.mkdir_p(File.join(dir, "config"))
+    File.write(File.join(dir, "config", "application.rb"), "# app")
+    File.write(File.join(dir, "Gemfile"), "source 'https://rubygems.org'\n")
+    FileUtils.mkdir_p(File.join(dir, "bin"))
+    File.write(File.join(dir, "bin", "rails"), "#!/bin/sh\n")
+    FileUtils.chmod(0o755, File.join(dir, "bin", "rails"))
+    yield dir
+  ensure
+    FileUtils.rm_rf(dir) if dir
+  end
+
+  def test_bundle_check_pass_noops_install_and_prepares_db
+    stub_app do |app|
+      commands = []
+      runner = ->(*argv, chdir:, env:) { commands << [ argv, chdir, env ]; [ "", "", Status.new(true) ] }
+
+      result = Hive::Commands::Setup::WebBundle.new(app_dir: app, runner: runner).ensure!
+
+      assert result.ok?
+      assert commands.any? { |entry| entry.first == [ "bundle", "check" ] }
+      assert commands.any? { |entry| entry.first == [ "bin/rails", "db:prepare" ] }
+      refute commands.any? { |entry| entry.first == [ "bundle", "install" ] }
+    end
+  end
+
+  def test_bundle_install_failure_reports_cd_bundle_install
+    stub_app do |app|
+      runner = lambda do |*argv, chdir:, env:|
+        status = argv == [ "bundle", "install" ] ? Status.new(false) : Status.new(argv != [ "bundle", "check" ])
+        [ "", "bundle failed\n", status ]
+      end
+
+      result = Hive::Commands::Setup::WebBundle.new(app_dir: app, runner: runner).ensure!
+
+      refute result.ok?
+      assert_match(/cd .*bundle install/, result.fix_command)
+    end
+  end
+end
