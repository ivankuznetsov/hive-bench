+require "hive/web/daemon_health"
+
+class DaemonController < ApplicationController
+  def repair
+    result = daemon_health.repair!
+    redirect_to root_path, notice: "Daemon service repaired (#{result.wire_outcome})."
+  rescue Hive::Error => e
+    redirect_to root_path, alert: "Daemon repair failed: #{e.message}"
+  end
+
+  def restart
+    daemon_health.restart!
+    redirect_to root_path, notice: "Daemon restart requested."
+  rescue Hive::Error => e
+    redirect_to root_path, alert: "Daemon restart failed: #{e.message}"
+  end
+
+  private
+
+  def daemon_health
+    @daemon_health ||= Hive::Web::DaemonHealth.new
+  end
+end
