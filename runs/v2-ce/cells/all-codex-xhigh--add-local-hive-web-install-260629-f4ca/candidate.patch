@@ -0,0 +1,59 @@
+require "test_helper"
+require "hive/commands/setup/dependency_check"
+
+class SetupDependencyCheckTest < Minitest::Test
+  include HiveTestHelper
+
+  Status = Struct.new(:success?)
+
+  def test_successful_checks_include_agent_auth
+    with_tmp_dir do |home|
+      FileUtils.mkdir_p(File.join(home, ".claude"))
+      File.write(File.join(home, ".claude", ".credentials.json"), '{"ok":true}')
+      FileUtils.mkdir_p(File.join(home, ".codex"))
+      File.write(File.join(home, ".codex", "auth.json"), '{"ok":true}')
+      which = ->(name) { "/bin/#{name}" }
+      runner = ->(*_argv) { [ "", "", Status.new(true) ] }
+
+      checks = Hive::Commands::Setup::DependencyCheck.new(
+        backends: %w[claude codex],
+        which: which,
+        runner: runner,
+        home: home,
+        host_os: "linux"
+      ).call
+
+      assert checks.all?(&:ok?), checks.map(&:to_h).inspect
+    end
+  end
+
+  def test_missing_external_cli_reports_fix_command
+    check = Hive::Commands::Setup::DependencyCheck.new(
+      backends: [],
+      which: ->(name) { name == "git" ? "/bin/git" : nil },
+      runner: ->(*_argv) { [ "", "", Status.new(false) ] },
+      host_os: "linux"
+    )
+
+    checks = check.call
+    npm = checks.find { |row| row.name == "npm" }
+    refute npm.ok?
+    assert_match(/Node\.js/, npm.fix_command)
+    refute check.ok?
+  end
+
+  def test_gh_auth_failure_reports_login_command
+    checks = Hive::Commands::Setup::DependencyCheck.new(
+      backends: [],
+      which: ->(_name) { "/bin/tool" },
+      runner: ->(*argv) {
+        argv == [ "gh", "auth", "status" ] ? [ "", "not logged in\n", Status.new(false) ] : [ "", "", Status.new(true) ]
+      },
+      host_os: "linux"
+    ).call
+
+    gh = checks.find { |row| row.name == "gh-auth" }
+    refute gh.ok?
+    assert_match(/gh auth login/, gh.fix_command)
+  end
+end
