+require "test_helper"
+require "hive/commands/setup"
+
+class SetupCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  Check = Hive::Commands::Setup::DependencyCheck::Check
+  Result = Data.define(:status, :message, :path, :fix_command) do
+    def ok?
+      status == "ok"
+    end
+  end
+
+  FakeDependencyCheck = Struct.new(:checks) do
+    def call
+      checks
+    end
+
+    def ok?
+      checks.all?(&:ok?)
+    end
+  end
+
+  FakeProvisioner = Struct.new(:result) do
+    def ensure!
+      result
+    end
+  end
+
+  def test_setup_writes_backends_and_runs_ordered_side_effects
+    with_tmp_global_config do
+      calls = []
+      check = FakeDependencyCheck.new([
+        Check.new(name: "git", status: "ok", message: "git ok", fix_command: nil, fatal: true)
+      ])
+      ok = Result.new(status: "ok", message: "ok", path: "/tmp/tool", fix_command: nil)
+      command = Hive::Commands::Setup.new(
+        Dir.pwd,
+        dependency_check: check,
+        qmd_installer: FakeProvisioner.new(ok),
+        web_bundle: FakeProvisioner.new(ok),
+        start_web: true,
+        output: StringIO.new,
+        error: StringIO.new
+      )
+      command.define_singleton_method(:ensure_project_enrolled) do
+        calls << :project
+        { "name" => "repo", "path" => Dir.pwd, "enrolled" => true }
+      end
+      command.define_singleton_method(:ensure_daemon_service) do
+        calls << :daemon
+        { "ok" => true, "command" => "hive daemon repair" }
+      end
+      command.define_singleton_method(:ensure_web_service) do
+        calls << :web
+        { "ok" => true, "command" => "hive web start" }
+      end
+
+      command.call
+
+      assert_equal %w[claude codex], Hive::Config.load_global_agents
+      assert_equal [ :project, :daemon, :web ], calls
+    end
+  end
+
+  def test_setup_fails_when_dependency_check_has_fatal_issue
+    with_tmp_global_config do
+      check = FakeDependencyCheck.new([
+        Check.new(name: "gh-auth", status: "missing", message: "login required",
+                  fix_command: "gh auth login", fatal: true)
+      ])
+      ok = Result.new(status: "ok", message: "ok", path: nil, fix_command: nil)
+      err = StringIO.new
+      command = Hive::Commands::Setup.new(
+        Dir.pwd,
+        dependency_check: check,
+        qmd_installer: FakeProvisioner.new(ok),
+        web_bundle: FakeProvisioner.new(ok),
+        start_web: false,
+        output: StringIO.new,
+        error: err
+      )
+      command.define_singleton_method(:ensure_project_enrolled) { { "name" => "repo", "path" => Dir.pwd, "enrolled" => true } }
+      command.define_singleton_method(:ensure_daemon_service) { { "ok" => true, "command" => "hive daemon repair" } }
+
+      error = assert_raises(Hive::Error) { command.call }
+
+      assert_match(/dependency issues/, error.message)
+      assert_match(/gh auth login/, err.string)
+    end
+  end
+end
