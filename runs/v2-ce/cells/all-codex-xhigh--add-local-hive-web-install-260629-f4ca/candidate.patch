diff --git a/test/integration/setup_command_test.rb b/test/integration/setup_command_test.rb
new file mode 100644
index 00000000..686f7beb
--- /dev/null
+++ b/test/integration/setup_command_test.rb
@@ -0,0 +1,54 @@
+require "test_helper"
+require "hive/commands/setup"
+
+class SetupCommandIntegrationTest < Minitest::Test
+  include HiveTestHelper
+
+  Result = Data.define(:status, :message, :path, :fix_command) do
+    def ok?
+      status == "ok"
+    end
+  end
+
+  FakeDependencyCheck = Struct.new(:checks) do
+    def call
+      checks
+    end
+
+    def ok?
+      true
+    end
+  end
+
+  def test_setup_enrolls_existing_initialized_project
+    with_tmp_global_config do
+      with_tmp_git_repo do |repo|
+        capture_io { Hive::Commands::Init.new(repo, force: true).call }
+        cfg_path = File.join(repo, ".hive-state", "config.yml")
+        cfg = YAML.safe_load_file(cfg_path)
+        cfg["daemon"] ||= {}
+        cfg["daemon"]["enabled"] = false
+        File.write(cfg_path, cfg.to_yaml)
+
+        ok = Result.new(status: "ok", message: "ok", path: nil, fix_command: nil)
+        command = Hive::Commands::Setup.new(
+          repo,
+          dependency_check: FakeDependencyCheck.new([]),
+          qmd_installer: Struct.new(:result) { def ensure! = result }.new(ok),
+          web_bundle: Struct.new(:result) { def ensure! = result }.new(ok),
+          start_web: false,
+          output: StringIO.new,
+          error: StringIO.new
+        )
+        command.define_singleton_method(:ensure_daemon_service) { { "ok" => true, "command" => "hive daemon repair" } }
+
+        command.call
+
+        reloaded = YAML.safe_load_file(cfg_path)
+        assert_equal true, reloaded.dig("daemon", "enabled")
+        registered = Hive::Config.registered_projects.find { |entry| entry["path"] == File.expand_path(repo) }
+        refute_nil registered
+      end
+    end
+  end
+end
