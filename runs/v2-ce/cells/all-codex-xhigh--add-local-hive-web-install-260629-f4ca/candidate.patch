+require "hive/commands/daemon/service_installer"
+require "hive/pid_file"
+require "hive/paths"
+
+module Hive
+  module Web
+    # Read/write daemon health adapter for the Rails surface. It is deliberately
+    # scoped to the per-user daemon unit; web and daemon services remain separate.
+    class DaemonHealth
+      include Hive::PidFile
+
+      def pid_file
+        File.join(Hive::Paths.state_home, ".daemon.pid")
+      end
+
+      def snapshot
+        pid = read_live_pid
+        service = installer.service_state
+        {
+          "running" => !pid.nil?,
+          "pid" => pid,
+          "pid_file" => pid_file
+        }.merge(service)
+      rescue StandardError => e
+        {
+          "running" => false,
+          "pid" => nil,
+          "pid_file" => pid_file,
+          "service_installed" => nil,
+          "service_enabled" => nil,
+          "unit_path" => nil,
+          "binary_matches_cli" => nil,
+          "unit_drift" => "unknown",
+          "repair_recommended" => false,
+          "error" => "#{e.class}: #{e.message}"
+        }
+      end
+
+      def repair!
+        result = installer.install!(autostart: true, force: true)
+        raise Hive::Error, "daemon repair failed while writing #{installer.target_path}" if result.failed? || result.drifted?
+
+        result
+      end
+
+      def restart!
+        installer.restart!
+      end
+
+      private
+
+      def installer
+        @installer ||= Hive::Commands::Daemon::ServiceInstaller.new
+      end
+    end
+  end
+end
