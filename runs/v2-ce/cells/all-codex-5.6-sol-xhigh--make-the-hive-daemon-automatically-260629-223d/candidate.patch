+++ b/lib/hive/daemon/recoverable_marker_retry.rb
@@ -0,0 +1,484 @@
+require "open3"
+require "digest"
+require "json"
+require "securerandom"
+require "hive/config"
+require "hive/events"
+require "hive/markers"
+require "hive/recovery_command"
+require "hive/task"
+require "hive/task_action"
+require "hive/daemon/auto_retry_health"
+require "hive/daemon/auto_retry_state"
+require "hive/daemon/dispatch_request_queue"
+
+module Hive
+  module Daemon
+    # Fail-closed classifier and safety guard for the deliberately tiny v1
+    # dependency-recovery allowlist. This object does not probe dependencies,
+    # mutate markers, or enqueue work; those responsibilities are layered on
+    # by AutoRetryHealth, AutoRetryState, and the dispatcher coordinator.
+    class RecoverableMarkerRetry
+      Decision = Struct.new(
+        :eligible, :classification, :probe_family, :rationale, :task,
+        :marker, :evidence, :config, :project_root, keyword_init: true
+      ) do
+        def eligible?
+          eligible == true
+        end
+      end
+
+      CLAUDE_EXCEPTION_CLASSES = %w[
+        Hive::AgentError
+        Hive::TmuxRunner::ExecutableMissing
+        Hive::TmuxRunner::NoServerRunning
+        Hive::TmuxRunner::CommandFailed
+        Hive::TmuxRunner::CommandTimedOut
+      ].freeze
+
+      # Every accepted family has a matching non-destructive dynamic probe in
+      # AutoRetryHealth. Keep this table closed: a near-match is parked.
+      CLAUDE_SIGNATURES = [
+        [ :claude_session, :session_absence, /\btmux session .+ already exists\b/i ],
+        [ :claude_session, :session_absence, /\btmux session .+ did not start\b/i ],
+        [ :claude_session, :session_absence, /\bclaude tmux session .+ terminated before becoming ready\b/i ],
+        [ :claude_session, :session_absence, /\bsession no longer exists\b/i ],
+        [ :claude_session, :session_absence, /\bcould not inspect claude tmux session\b/i ],
+        [ :claude_handshake, :wrapper_handshake, /\bclaude interactive prompt did not become ready\b/i ],
+        [ :claude_runtime, :runtime, /\bclaude binary not runnable\b/i ],
+        [ :claude_runtime, :runtime, /\bcould not parse claude .+ output\b/i ],
+        [ :claude_runtime, :runtime, /\bclaude \d+(?:\.\d+)+ below minimum\b/i ],
+        [ :claude_runtime, :runtime, /\bclaude version check timed out\b/i ]
+      ].freeze
+
+      def initialize(controller: nil, config_loader: Hive::Config.method(:load),
+                     task_loader: Hive::Task.method(:new), git_status: nil,
+                     health: nil, state: nil, request_queue: Hive::Daemon::DispatchRequestQueue,
+                     logger: nil, events: Hive::Events, enabled: true,
+                     request_state_home: nil)
+        @controller = controller
+        @config_loader = config_loader
+        @task_loader = task_loader
+        @git_status = git_status || method(:default_git_status)
+        @health = health
+        @state = state
+        @request_queue = request_queue
+        @logger = logger
+        @events = events
+        @enabled = enabled == true
+        @request_state_home = request_state_home
+      end
+
+      def configure(enabled:)
+        @enabled = enabled == true
+        self
+      end
+
+      def evaluate(row, legacy_layout_projects: {})
+        return reject("not_error_marker") unless row.marker.to_s == "error"
+        return reject("legacy_project_layout") if legacy_layout_projects.include?(row.project)
+        return reject("live_task_lock") if row.live_task_lock == true
+        if @controller&.running_task?(project: row.project, slug: row.slug)
+          return reject("controller_owned_run")
+        end
+
+        task = load_task(row)
+        marker = read_matching_marker(row, task)
+        return reject("marker_changed", task: task) unless marker
+
+        cfg = @config_loader.call(project_root(task, row))
+        return reject("project_daemon_disabled", task: task, marker: marker) if cfg.dig("daemon", "enabled") == false
+
+        evidence = current_evidence(row, marker)
+        classification = classify(row, cfg, marker, evidence)
+        return reject(classification.fetch(:rationale), task: task, marker: marker, evidence: evidence) unless classification[:eligible]
+
+        safety_rationale = safety_failure(task, row, marker)
+        return reject(safety_rationale, task: task, marker: marker, evidence: evidence) if safety_rationale
+
+        Decision.new(
+          eligible: true,
+          classification: classification.fetch(:classification),
+          probe_family: classification.fetch(:probe_family),
+          rationale: "eligible",
+          task: task,
+          marker: marker,
+          evidence: evidence,
+          config: cfg,
+          project_root: project_root(task, row)
+        )
+      rescue Hive::InvalidTaskPath, Hive::ConfigError, SystemCallError, IOError,
+             Psych::Exception, KeyError, TypeError => e
+        reject("state_unreadable:#{e.class.name}")
+      end
+
+      # Coordinator entry point. It intentionally prefilters only the two v1
+      # reasons, rotates by the durable cursor, and admits at most one new
+      # project/classification probe group per full tick.
+      def scan(rows, now: Time.now, legacy_layout_projects: {})
+        return [] unless @enabled
+        return [] unless @health && @state && @state.available?
+
+        @health.begin_tick!
+        candidates = Array(rows).select do |row|
+          row.marker.to_s == "error" &&
+            %w[implementer_failed claude_launch_failed].include?(row.marker_attrs.to_h["reason"].to_s)
+        end
+        keyed = candidates.to_h { |row| [ candidate_cursor_key(row), row ] }
+        ordered_keys = @state.rotate_candidates(keyed.keys.sort)
+        actions = []
+        probe_group = nil
+
+        ordered_keys.each do |cursor_key|
+          row = keyed.fetch(cursor_key)
+          decision = evaluate(row, legacy_layout_projects: legacy_layout_projects)
+          unless decision.eligible?
+            audit_negative(row, decision, fingerprint: "", probes: [], now: now)
+            next
+          end
+
+          identity = identity_for(row, decision)
+          epoch = @state.recovery_epoch(**identity)
+          cheap = @health.cheap_fingerprint(
+            classification: decision.classification,
+            config: decision.config,
+            project_root: decision.project_root,
+            recovery_epoch: epoch
+          )
+          cached = @state.cached_health(**identity, cheap_fingerprint: cheap)
+          due = @state.probe_due?(**identity, cheap_fingerprint: cheap, now: now)
+          group = [ row.project.to_s, decision.classification.to_s, decision.probe_family.to_s, cheap,
+                    decision.probe_family.to_sym == :session_absence ? row.slug.to_s : nil ]
+
+          if due || cached.nil?
+            if probe_group && probe_group != group
+              actions << { action: :deferred, project: row.project, slug: row.slug }
+              next
+            end
+            probe_group ||= group
+            bundle = @health.probe(
+              decision: decision, config: decision.config,
+              project_root: decision.project_root,
+              recovery_epoch: epoch
+            )
+            cached = {
+              "healthy" => bundle.healthy?, "fingerprint" => bundle.fingerprint,
+              "probes" => bundle.probes.map(&:to_h)
+            }
+            @state.record_health!(
+              **identity, cheap_fingerprint: cheap,
+              health_fingerprint: bundle.fingerprint, healthy: bundle.healthy?,
+              probes: cached.fetch("probes"), now: now
+            )
+            @state.advance_cursor!(cursor_key)
+          end
+
+          evaluation = @state.observe(
+            **identity, stage: row.stage, marker_id: decision.marker.attrs.fetch("marker_id"),
+            marker_attrs: decision.marker.attrs,
+            health_fingerprint: cached.fetch("fingerprint"),
+            healthy: cached.fetch("healthy"), safe: true, now: now
+          )
+          if evaluation.action == :schedule
+            scheduled = schedule(row, decision, identity, evaluation,
+                                 cached: cached, now: now)
+            actions << scheduled if scheduled
+          else
+            rationale = evaluation.rationale || evaluation.action.to_s
+            audit_negative(row, decision, fingerprint: cached.fetch("fingerprint"),
+                           probes: cached.fetch("probes"), now: now,
+                           rationale: rationale, attempt: evaluation.attempt)
+            actions << { action: evaluation.action, project: row.project, slug: row.slug }
+          end
+        end
+        actions
+      rescue StandardError => e
+        @logger&.event(:fatal,
+                       message: "recoverable_marker_retry raised: #{e.class}: #{e.message}",
+                       keeping_previous: true)
+        []
+      end
+
+      # Exposed for the tokenized child, which must repeat the exact safety
+      # decision while it owns the ordinary task lock.
+      def revalidate_safety(task:, row:, marker:)
+        safety_failure(task, row, marker)
+      rescue SystemCallError, IOError, TypeError
+        "state_unreadable"
+      end
+
+      private
+
+      def schedule(row, decision, identity, evaluation, cached:, now:)
+        request_id = @request_queue.generate_request_id
+        token = SecureRandom.hex(24)
+        argv = Hive::RecoveryCommand.retry_argv(
+          project: row.project, slug: row.slug, stage: row.stage,
+          workflow: row.workflow, auto_retry_token: token
+        )
+        return audit_negative(row, decision, fingerprint: cached.fetch("fingerprint"),
+                              probes: cached.fetch("probes"), now: now,
+                              rationale: "retry_verb_unavailable", attempt: evaluation.attempt) unless argv
+
+        reservation = @state.reserve!(
+          **identity, request_id: request_id, token: token,
+          attempt: evaluation.attempt, marker_id: decision.marker.attrs.fetch("marker_id"),
+          marker_attrs: decision.marker.attrs, stage: row.stage,
+          health_fingerprint: cached.fetch("fingerprint"), now: now
+        )
+        return nil unless reservation
+
+        payload = decision_payload(
+          row, decision, action: "scheduled", rationale: evaluation.rationale,
+          fingerprint: cached.fetch("fingerprint"), probes: cached.fetch("probes"),
+          attempt: evaluation.attempt, request_id: request_id, now: now
+        )
+        unless emit_task_decision(row, payload)
+          @state.release!(token: token, reason: "task_audit_failed", now: now)
+          @logger&.event(:auto_retry_queue_failed, **symbolize(payload), reason: "task_audit_failed")
+          return { action: :audit_failed, project: row.project, slug: row.slug }
+        end
+
+        begin
+          kwargs = {
+            project: row.project, slug: row.slug, argv: argv,
+            requestor: "healer", trigger: "auto_retry:#{identity.fetch(:reason)}:#{evaluation.attempt}",
+            request_id: request_id, now: now
