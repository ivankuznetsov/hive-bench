diff --git a/test/unit/daemon/auto_retry_health_test.rb b/test/unit/daemon/auto_retry_health_test.rb
new file mode 100644
index 00000000..0026f057
--- /dev/null
+++ b/test/unit/daemon/auto_retry_health_test.rb
@@ -0,0 +1,180 @@
+require "test_helper"
+require "rbconfig"
+require "hive/daemon/auto_retry_health"
+
+class HiveDaemonAutoRetryHealthTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeDecision = Struct.new(:classification, :probe_family, :evidence, :task, keyword_init: true)
+  FakeTask = Struct.new(:slug, keyword_init: true)
+
+  class FakeRunner
+    attr_reader :calls
+
+    def initialize(results)
+      @results = results
+      @calls = []
+    end
+
+    def run(argv, **options)
+      @calls << [ argv, options ]
+      result = @results.fetch(argv.first == "codex" && argv[1..2] == [ "login", "status" ] ? :login :
+                              argv.first == "codex" && argv[1] == "exec" ? :smoke :
+                              argv.last == "--version" ? argv.first.to_sym : :other)
+      result.respond_to?(:call) ? result.call(argv, options) : result
+    end
+  end
+
+  def test_codex_requires_login_and_smoke_and_reuses_bundle_within_tick
+    runner = FakeRunner.new(
+      login: result("codex login status", stdout: "Logged in"),
+      smoke: result("codex smoke", stdout: "HIVE_AUTO_RETRY_OK"),
+      codex: result("codex version", stdout: "codex 0.125.0"),
+      hive: result("hive version", stdout: "hive 0.3.2")
+    )
+    health = health_for(runner)
+
+    first = health.probe(
+      decision: decision(:codex_auth), config: codex_config,
+      project_root: "/tmp/project", recovery_epoch: 0
+    )
+    second = health.probe(
+      decision: decision(:codex_auth), config: codex_config,
+      project_root: "/tmp/project", recovery_epoch: 0
+    )
+
+    assert first.healthy?
+    assert_equal first.fingerprint, second.fingerprint
+    assert_equal 1, runner.calls.count { |argv, _| argv[0, 3] == [ "codex", "login", "status" ] }
+    assert_equal 1, runner.calls.count { |argv, _| argv[0, 2] == [ "codex", "exec" ] }
+    smoke_options = runner.calls.find { |argv, _| argv[0, 2] == [ "codex", "exec" ] }.last
+    refute_equal "/tmp/project", smoke_options.fetch(:cwd)
+  end
+
+  def test_codex_login_failure_prevents_smoke
+    runner = FakeRunner.new(
+      login: result("login", status: :failed, stderr: "not logged in"),
+      codex: result("codex version", stdout: "codex 0.125.0"),
+      hive: result("hive version", stdout: "hive 0.3.2")
+    )
+    bundle = health_for(runner).probe(
+      decision: decision(:codex_auth), config: codex_config,
+      project_root: "/tmp/project", recovery_epoch: 0
+    )
+
+    refute bundle.healthy?
+    refute runner.calls.any? { |argv, _| argv[0, 2] == [ "codex", "exec" ] }
+  end
+
+  def test_fingerprint_changes_only_for_relevant_signals
+    runner = FakeRunner.new(
+      login: result("login", stdout: "Logged in"),
+      smoke: result("smoke", stdout: "HIVE_AUTO_RETRY_OK"),
+      codex: result("codex", stdout: "codex 0.125.0"),
+      hive: result("hive", stdout: "hive 0.3.2")
+    )
+    health = health_for(runner)
+    one = health.signal_fingerprint(
+      classification: :codex_auth, config: codex_config,
+      project_root: "/tmp/project", recovery_epoch: 1
+    )
+    two = health.signal_fingerprint(
+      classification: :codex_auth, config: codex_config.merge("unrelated" => "secret"),
+      project_root: "/tmp/project", recovery_epoch: 1
+    )
+    three = health.signal_fingerprint(
+      classification: :codex_auth, config: codex_config,
+      project_root: "/tmp/project", recovery_epoch: 2
+    )
+
+    assert_equal one, two
+    refute_equal one, three
+  end
+
+  def test_command_runner_redacts_and_times_out_process_group
+    runner = Hive::Daemon::AutoRetryHealth::CommandRunner.new
+    secret = "sk-#{'a' * 24}"
+    redacted = runner.run(
+      [ RbConfig.ruby, "-e", "STDOUT.write(ARGV.fetch(0))", secret ],
+      timeout: 10, env: {}, cwd: Dir.tmpdir
+    )
+    timeout = runner.run(
+      [ RbConfig.ruby, "-e", "sleep 5" ],
+      timeout: 0.05, env: {}, cwd: Dir.tmpdir
+    )
+
+    assert redacted.ok?
+    refute_includes redacted.stdout, secret
+    assert_includes redacted.stdout, "[REDACTED:openai_api_key]"
+    assert_equal :timeout, timeout.status
+  end
+
+  def test_claude_requires_static_checks_doctor_and_family_probe
+    with_tmp_dir do |dir|
+      wrapper = File.join(dir, "interactive_claude_wrapper.sh")
+      File.write(wrapper, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, wrapper)
+      runner = FakeRunner.new(
+        hive: result("hive", stdout: "hive 0.3.2"),
+        claude: result("claude", stdout: "2.1.200")
+      )
+      dynamic_calls = []
+      health = health_for(
+        runner,
+        wrapper_path: wrapper,
+        ready_self_check: -> { true },
+        dynamic_probe: ->(**kwargs) { dynamic_calls << kwargs; result("dynamic") }
+      )
+      bundle = health.probe(
+        decision: decision(:claude_session, probe_family: :session_absence),
+        config: claude_config, project_root: dir, recovery_epoch: 0
+      )
+
+      assert bundle.healthy?
+      assert_equal :session_absence, dynamic_calls.first.fetch(:family)
+      assert bundle.probes.any? { |probe| probe.name == "ready_detector" }
+      assert bundle.probes.any? { |probe| probe.name == "doctor" }
+    end
+  end
+
+  private
+
+  def result(name, status: :ok, stdout: "", stderr: "")
+    Hive::Daemon::AutoRetryHealth::ProbeResult.new(
+      name: name, status: status, duration_ms: 1,
+      stdout: stdout, stderr: stderr, classification: status == :ok ? nil : status.to_s
+    )
+  end
+
+  def decision(classification, probe_family: classification)
+    FakeDecision.new(
+      classification: classification, probe_family: probe_family,
+      evidence: "tmux session hive-demo already exists", task: FakeTask.new(slug: "demo")
+    )
+  end
+
+  def health_for(runner, **options)
+    Hive::Daemon::AutoRetryHealth.new(
+      command_runner: runner,
+      env: { "PATH" => ENV.fetch("PATH", "") },
+      doctor: ->(**_kwargs) { [ { status: "present", skill: "/ce-plan" } ] },
+      invoked_binary: -> { "hive" },
+      binary_resolver: ->(name, _env) { name },
+      **options
+    )
+  end
+
+  def codex_config
+    {
+      "execute" => { "agent" => "codex" },
+      "agents" => { "codex" => { "bin" => "codex", "min_version" => "0.125.0" } }
+    }
+  end
+
+  def claude_config
+    {
+      "claude" => { "mode" => "tmux" },
+      "agents" => { "claude" => { "bin" => "claude", "min_version" => "2.1.118" } }
+    }
+  end
+end
