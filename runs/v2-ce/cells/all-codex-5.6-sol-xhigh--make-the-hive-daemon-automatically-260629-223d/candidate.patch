diff --git a/test/unit/daemon/recoverable_marker_retry_test.rb b/test/unit/daemon/recoverable_marker_retry_test.rb
new file mode 100644
index 00000000..5afceb4b
--- /dev/null
+++ b/test/unit/daemon/recoverable_marker_retry_test.rb
@@ -0,0 +1,300 @@
+require "test_helper"
+require "hive/daemon/recoverable_marker_retry"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonRecoverableMarkerRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  Row = Hive::Daemon::StatusConsumer::Row
+
+  FakeTask = Struct.new(:folder, :state_file, :worktree_path, :stage_name, :slug, :id, keyword_init: true)
+
+  class FakeHealth
+    attr_reader :probe_calls
+    def initialize(healthy: true)
+      @healthy = healthy
+      @probe_calls = 0
+    end
+    def begin_tick! = nil
+    def cheap_fingerprint(**_kwargs) = "cheap-fingerprint"
+    def signal_fingerprint(**_kwargs) = "health-fingerprint"
+    def probe(**_kwargs)
+      @probe_calls += 1
+      probe = Hive::Daemon::AutoRetryHealth::ProbeResult.new(
+        name: "doctor", status: @healthy ? :ok : :failed,
+        duration_ms: 1, stdout: "ok", stderr: "", classification: nil
+      )
+      Hive::Daemon::AutoRetryHealth::Bundle.new(
+        healthy: @healthy, fingerprint: "health-fingerprint",
+        probes: [ probe ], signals: {}
+      )
+    end
+  end
+
+  class FakeQueue
+    attr_reader :requests
+    def initialize = @requests = []
+    def generate_request_id = "request-1"
+    def write_request!(**kwargs)
+      @requests << kwargs
+      kwargs.fetch(:request_id)
+    end
+    def remove(*_args, **_kwargs) = true
+  end
+
+  class FakeEvents
+    attr_reader :records
+    def initialize(succeed: true)
+      @succeed = succeed
+      @records = []
+    end
+    def emit(**kwargs)
+      @records << kwargs
+      @succeed ? kwargs : nil
+    end
+  end
+
+  class FakeLogger
+    attr_reader :events
+    def initialize = @events = []
+    def event(name, **attrs) = @events << [ name, attrs ]
+  end
+
+  def setup
+    @controller = Object.new
+    @controller.define_singleton_method(:running_task?) { |project:, slug:| false }
+    @configs = {}
+    @tasks = {}
+    @retry = Hive::Daemon::RecoverableMarkerRetry.new(
+      controller: @controller,
+      config_loader: ->(root) { @configs.fetch(root) },
+      task_loader: ->(folder) { @tasks.fetch(folder) },
+      git_status: ->(path) { [ "", "", true ] }
+    )
+  end
+
+  def test_accepts_only_codex_execute_401_missing_auth_signature
+    with_candidate(reason: "implementer_failed", message: "HTTP 401: Missing bearer or basic authentication") do |row, root|
+      @configs[root] = { "execute" => { "agent" => "codex" }, "daemon" => { "enabled" => true } }
+
+      decision = @retry.evaluate(row)
+
+      assert decision.eligible?
+      assert_equal :codex_auth, decision.classification
+
+      @configs[root]["execute"]["agent"] = "claude"
+      refute @retry.evaluate(row).eligible?
+    end
+  end
+
+  def test_rejects_bare_401_and_stale_diagnostic_evidence
+    with_candidate(reason: "implementer_failed", message: "HTTP 401") do |row, root|
+      @configs[root] = { "execute" => { "agent" => "codex" }, "daemon" => { "enabled" => true } }
+      row.diagnostic = {
+        "marker_signature" => "stale",
+        "detail" => "401 missing bearer or basic auth"
+      }
+
+      decision = @retry.evaluate(row)
+
+      refute decision.eligible?
+      assert_equal "unrecognized_implementer_failure", decision.rationale
+    end
+  end
+
+  def test_accepts_fixed_claude_launcher_family_and_rejects_unknown_class
+    with_candidate(
+      reason: "claude_launch_failed",
+      message: "tmux session hive-4-execute-demo already exists",
+      exception_class: "Hive::AgentError"
+    ) do |row, root|
+      @configs[root] = { "execute" => { "agent" => "claude" }, "daemon" => { "enabled" => true } }
+
+      decision = @retry.evaluate(row)
+      assert decision.eligible?
+      assert_equal :claude_session, decision.classification
+      assert_equal :session_absence, decision.probe_family
+
+      Hive::Markers.set(
+        row.state_file, :error,
+        reason: "claude_launch_failed",
+        message: "tmux session hive-4-execute-demo already exists",
+        exception_class: "RuntimeError"
+      )
+      row.marker_attrs = Hive::Markers.current(row.state_file).attrs.dup
+      decision = @retry.evaluate(row)
+      refute decision.eligible?
+      assert_equal "unrecognized_launcher_exception", decision.rationale
+    end
+  end
+
+  def test_accepts_concrete_tmux_no_server_error_with_inspection_signature
+    with_candidate(
+      reason: "claude_launch_failed",
+      message: "could not inspect claude tmux session hive-demo: no server running",
+      exception_class: "Hive::TmuxRunner::NoServerRunning"
+    ) do |row, root|
+      @configs[root] = { "execute" => { "agent" => "claude" }, "daemon" => { "enabled" => true } }
+
+      assert @retry.evaluate(row).eligible?
+    end
+  end
+
+  def test_execute_safety_fails_closed_on_dirty_or_unreadable_worktree
+    with_candidate(reason: "implementer_failed", message: "401 missing bearer auth") do |row, root|
+      @configs[root] = { "execute" => { "agent" => "codex" }, "daemon" => { "enabled" => true } }
+      dirty = Hive::Daemon::RecoverableMarkerRetry.new(
+        controller: @controller,
+        config_loader: ->(_path) { @configs.fetch(root) },
+        task_loader: ->(folder) { @tasks.fetch(folder) },
+        git_status: ->(_path) { [ " M lib/example.rb\n", "", true ] }
+      )
+      failed = Hive::Daemon::RecoverableMarkerRetry.new(
+        controller: @controller,
+        config_loader: ->(_path) { @configs.fetch(root) },
+        task_loader: ->(folder) { @tasks.fetch(folder) },
+        git_status: ->(_path) { [ "", "fatal", false ] }
+      )
+
+      assert_equal "dirty_worktree", dirty.evaluate(row).rationale
+      assert_equal "worktree_status_failed", failed.evaluate(row).rationale
+    end
+  end
+
+  def test_live_owner_rotated_marker_and_disabled_or_legacy_project_are_unsafe
+    with_candidate(reason: "implementer_failed", message: "401 missing basic auth") do |row, root|
+      @configs[root] = { "execute" => { "agent" => "codex" }, "daemon" => { "enabled" => true } }
+      row.live_task_lock = true
+      assert_equal "live_task_lock", @retry.evaluate(row).rationale
+      row.live_task_lock = false
+
+      @configs[root]["daemon"]["enabled"] = false
+      assert_equal "project_daemon_disabled", @retry.evaluate(row).rationale
+      @configs[root]["daemon"]["enabled"] = true
+
+      assert_equal "legacy_project_layout", @retry.evaluate(row, legacy_layout_projects: { "demo" => true }).rationale
+
+      Hive::Markers.set(row.state_file, :error, reason: "implementer_failed", message: "401 missing basic auth")
+      assert_equal "marker_changed", @retry.evaluate(row).rationale
+    end
+  end
+
+  def test_planning_stage_allows_only_marker_only_artifact
+    with_candidate(
+      stage: "3-plan", reason: "claude_launch_failed",
+      message: "claude interactive prompt did not become ready in tmux session hive-demo",
+      exception_class: "Hive::AgentError"
+    ) do |row, root|
+      @configs[root] = { "plan" => { "agent" => "claude" }, "daemon" => { "enabled" => true } }
+
+      assert @retry.evaluate(row).eligible?
+
+      File.write(row.state_file, "## Overview\nUser-authored plan\n\n#{Hive::Markers.current(row.state_file).raw}\n")
+      assert_equal "planning_content_present", @retry.evaluate(row).rationale
+    end
+  end
+
+  def test_coordinator_reserves_audits_and_writes_tokenized_same_stage_request
+    with_candidate(reason: "implementer_failed", message: "401 missing bearer auth") do |row, root|
+      @configs[root] = { "execute" => { "agent" => "codex" }, "daemon" => { "enabled" => true } }
+      health = FakeHealth.new
+      queue = FakeQueue.new
+      events = FakeEvents.new
+      logger = FakeLogger.new
+      state_path = File.join(root, "auto-retry.json")
+      state = Hive::Daemon::AutoRetryState.new(path: state_path, logger: logger)
