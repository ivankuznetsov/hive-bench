+          kwargs[:state_home] = @request_state_home if @request_state_home
+          @request_queue.write_request!(**kwargs)
+          @state.mark_queued!(token: token, now: now) or raise "could not mark auto-retry request queued"
+          @logger&.event(:auto_retry_scheduled, **symbolize(payload))
+          { action: :scheduled, project: row.project, slug: row.slug,
+            request_id: request_id, token: token, argv: argv }
+        rescue StandardError => e
+          remove_request(request_id)
+          @state.release!(token: token, reason: "queue_failure", now: now)
+          failure = payload.merge("action" => "queue_failed", "rationale" => "#{e.class}: #{e.message}")
+          emit_task_decision(row, failure)
+          @logger&.event(:auto_retry_queue_failed, **symbolize(failure))
+          { action: :queue_failed, project: row.project, slug: row.slug }
+        end
+      end
+
+      def audit_negative(row, decision, fingerprint:, probes:, now:, rationale: nil, attempt: nil)
+        rationale ||= decision.rationale
+        identity = decision.task ? identity_for(row, decision) : {
+          project: row.project, task_id: nil, slug: row.slug,
+          reason: row.marker_attrs.to_h["reason"].to_s
+        }
+        epoch = @state.recovery_epoch(**identity)
+        marker_id = row.marker_attrs.to_h["marker_id"].to_s
+        return nil unless @state.negative_audit_due?(
+          **identity, rationale: rationale, fingerprint: fingerprint,
+          marker_id: marker_id, recovery_epoch: epoch, now: now
+        )
+
+        action = rationale.to_s.include?("exhausted") ? "exhausted" : "parked"
+        payload = decision_payload(row, decision, action: action, rationale: rationale,
+                                   fingerprint: fingerprint, probes: probes,
+                                   attempt: attempt, request_id: nil, now: now)
+        emit_task_decision(row, payload) if File.directory?(row.folder.to_s)
+        event = action == "exhausted" ? :auto_retry_exhausted : :auto_retry_evaluated
+        @logger&.event(event, **symbolize(payload))
+        @state.record_negative_audit!(
+          **identity, rationale: rationale, fingerprint: fingerprint,
+          marker_id: marker_id, recovery_epoch: epoch, now: now
+        )
+        { action: action.to_sym, project: row.project, slug: row.slug }
+      end
+
+      def decision_payload(row, decision, action:, rationale:, fingerprint:, probes:, attempt:, request_id:, now:)
+        marker_attrs = decision.marker&.attrs || row.marker_attrs.to_h
+        {
+          "decision_id" => ::Digest::SHA256.hexdigest(JSON.generate([
+            row.project, row.slug, marker_attrs["marker_id"], action, request_id, now.utc.iso8601(6)
+          ]))[0, 24],
+          "project" => row.project.to_s,
+          "task_id" => decision.task&.id,
+          "slug" => row.slug.to_s,
+          "stage" => row.stage.to_s,
+          "marker" => row.marker.to_s,
+          "marker_id" => marker_attrs["marker_id"].to_s,
+          "reason" => marker_attrs["reason"].to_s,
+          "classification" => decision.classification&.to_s,
+          "probes" => Array(probes),
+          "health_fingerprint" => fingerprint.to_s,
+          "attempt" => attempt,
+          "max_attempts" => Hive::Daemon::AutoRetryState::MAX_ATTEMPTS,
+          "action" => action.to_s,
+          "request_id" => request_id,
+          "rationale" => rationale.to_s,
+          "timestamp" => now.utc.iso8601(6)
+        }
+      end
+
+      def emit_task_decision(row, payload)
+        !@events.emit(
+          task_folder: row.folder, slug: row.slug, stage: row.stage,
+          event_type: :auto_retry_decision,
+          message: "#{payload.fetch('action')}: #{payload.fetch('rationale')}",
+          details: payload
+        ).nil?
+      end
+
+      def identity_for(row, decision)
+        {
+          project: row.project, task_id: decision.task.id,
+          slug: row.slug, reason: decision.marker.attrs.fetch("reason").to_s
+        }
+      end
+
+      def recovery_epoch(decision)
+        decision.marker&.attrs&.fetch("recovery_epoch", 0).to_i
+      end
+
+      def candidate_cursor_key(row)
+        [ row.project, row.marker_attrs.to_h["reason"], row.slug ].join("\0")
+      end
+
+      def remove_request(request_id)
+        kwargs = { state_home: @request_state_home } if @request_state_home
+        @request_queue.remove(request_id, **(kwargs || {}))
+      rescue StandardError
+        nil
+      end
+
+      def symbolize(hash)
+        hash.to_h.transform_keys(&:to_sym)
+      end
+
+      def classify(row, cfg, marker, evidence)
+        reason = marker.attrs.fetch("reason", "").to_s
+        case reason
+        when "implementer_failed"
+          classify_codex(row, cfg, evidence)
+        when "claude_launch_failed"
+          classify_claude(marker, evidence)
+        else
+          { eligible: false, rationale: "reason_not_allowlisted" }
+        end
+      end
+
+      def classify_codex(row, cfg, evidence)
+        return { eligible: false, rationale: "codex_auth_wrong_stage" } unless row.stage.to_s == "4-execute" # coding-scoped: v1 Codex recovery allowlist
+        return { eligible: false, rationale: "execute_profile_not_codex" } unless cfg.dig("execute", "agent").to_s == "codex"
+
+        auth_signature = evidence.match?(/\b401\b/i) &&
+          evidence.match?(/missing\s+(?:bearer(?:\s+token)?|basic(?:\s+auth(?:entication)?)?)/i)
+        return { eligible: false, rationale: "unrecognized_implementer_failure" } unless auth_signature
+
+        { eligible: true, classification: :codex_auth, probe_family: :codex_auth }
+      end
+
+      def classify_claude(marker, evidence)
+        exception_class = marker.attrs.fetch("exception_class", "").to_s
+        unless CLAUDE_EXCEPTION_CLASSES.include?(exception_class)
+          return { eligible: false, rationale: "unrecognized_launcher_exception" }
+        end
+
+        family = CLAUDE_SIGNATURES.find { |_classification, _probe, pattern| evidence.match?(pattern) }
+        return { eligible: false, rationale: "unrecognized_launcher_signature" } unless family
+
+        { eligible: true, classification: family[0], probe_family: family[1] }
+      end
+
+      def load_task(row)
+        raise Hive::InvalidTaskPath, "task folder missing" unless File.directory?(row.folder.to_s)
+
+        @task_loader.call(row.folder)
+      end
+
+      def read_matching_marker(row, task)
+        return nil unless File.file?(task.state_file)
+        return nil unless File.readable?(task.state_file)
+
+        marker = Hive::Markers.current(task.state_file)
+        return nil unless marker.name == :error
+
+        expected_id = row.marker_attrs.to_h.fetch("marker_id", "").to_s
+        return nil if expected_id.empty?
+        return nil unless marker.attrs.fetch("marker_id", "").to_s == expected_id
+        expected_attrs = row.marker_attrs.to_h.transform_keys(&:to_s).transform_values(&:to_s)
+        return nil unless marker.attrs.transform_values(&:to_s) == expected_attrs
+
+        marker
+      end
+
+      def current_evidence(row, marker)
+        parts = [ marker.attrs["message"] ]
+        diagnostic = row.diagnostic
+        if diagnostic.is_a?(Hash) && diagnostic["marker_signature"].to_s == Hive::TaskAction.marker_signature(marker)
+          parts.concat([ diagnostic["summary"], diagnostic["detail"] ])
+        end
+        parts.compact.map(&:to_s).join("\n")
+      end
+
+      def safety_failure(task, row, marker)
+        body = File.read(task.state_file, encoding: "UTF-8")
+        without_current = body.sub(marker.raw.to_s, "")
+        return "terminal_success_present" if without_current.match?(/<!--\s*(?:COMPLETE|EXECUTE_COMPLETE|REVIEW_COMPLETE)\b/)
+
+        if worktree_owning_stage?(row, task)
+          path = task.worktree_path
+          return "worktree_missing" if path.to_s.empty? || !File.directory?(path)
+
+          stdout, _stderr, success = @git_status.call(path)
+          return "worktree_status_failed" unless success
+          return "dirty_worktree" unless stdout.to_s.empty?
+        elsif planning_stage?(row)
+          return "planning_content_present" unless planning_scaffold_only?(without_current)
+        else
+          # A launcher failure in an agent-backed custom stage with no
+          # worktree can only be retried when the state artifact is marker-only.
+          return "ambiguous_stage_content" unless without_current.strip.empty?
+        end
+        nil
+      end
+
+      def worktree_owning_stage?(row, task)
+        index = row.stage.to_s[/\A(\d+)-/, 1]&.to_i
+        return index.between?(4, 8) if index
+
+        !task.worktree_path.to_s.empty?
+      end
+
+      def planning_stage?(row)
+        %w[2-brainstorm 3-plan].include?(row.stage.to_s) # coding-scoped: planning-content safety policy
+      end
+
+      def planning_scaffold_only?(body)
+        # In current coding workflows these files do not exist before the
+        # launcher writes them. Permit only whitespace and empty headings so
+        # future harmless scaffolds do not strand recovery; any prose, Q/A,
+        # feedback, frontmatter, list item, or completed artifact parks.
+        body.each_line.all? do |line|
+          stripped = line.strip
+          stripped.empty? || stripped.match?(/\A\#{1,6}\s+[A-Za-z0-9 _-]+\z/)
+        end
+      end
+
+      def project_root(task, row)
+        return task.project_root if task.respond_to?(:project_root) && task.project_root
+
+        folder = File.expand_path(row.folder)
+        marker = "#{File::SEPARATOR}.hive-state#{File::SEPARATOR}"
+        folder.split(marker, 2).first
+      end
+
+      def default_git_status(path)
+        out, err, status = Open3.capture3("git", "-C", path, "status", "--porcelain")
+        [ out, err, status.success? ]
+      rescue SystemCallError => e
+        [ "", e.message, false ]
+      end
+
+      def reject(rationale, task: nil, marker: nil, evidence: nil)
+        Decision.new(
+          eligible: false, classification: nil, probe_family: nil,
+          rationale: rationale, task: task, marker: marker, evidence: evidence
+        )
+      end
+    end
+  end
+end
