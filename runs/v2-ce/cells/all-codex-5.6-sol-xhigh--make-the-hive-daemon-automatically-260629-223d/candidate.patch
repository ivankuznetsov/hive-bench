diff --git a/lib/hive/recovery_command.rb b/lib/hive/recovery_command.rb
new file mode 100644
index 00000000..59a360d6
--- /dev/null
+++ b/lib/hive/recovery_command.rb
@@ -0,0 +1,58 @@
+require "hive/config"
+require "hive/workflows"
+require "hive/workflows/project"
+
+module Hive
+  module RecoveryCommand
+    module_function
+
+    def retry_verb_for_stage(stage, workflow: nil, project: nil)
+      stage = stage.to_s
+      unless Hive::Workflows.coding_id?(workflow)
+        return nil if generic_terminal_stage?(stage, workflow, project: project)
+        return nil if generic_non_agent_stage?(stage, workflow, project: project)
+        return "run"
+      end
+      return nil if stage == "9-done" # coding-scoped: terminal coding stage
+
+      Hive::Workflows.verb_arriving_at(stage) || { "5-review" => "review", "6-pr" => "pr" }[stage] # coding-scoped: legacy coding verbs
+    end
+
+    def retry_argv(project:, slug:, stage:, workflow: nil, auto_retry_token: nil, json: true)
+      verb = retry_verb_for_stage(stage, workflow: workflow, project: project)
+      return nil unless verb
+
+      stage_flag = verb == "run" ? "--stage" : "--from"
+      argv = [ "hive", verb, slug, stage_flag, stage, "--project", project ]
+      argv.concat([ "--auto-retry-token", auto_retry_token.to_s ]) unless auto_retry_token.to_s.empty?
+      argv << "--json" if json
+      argv
+    end
+
+    def generic_terminal_stage?(stage, workflow, project: nil)
+      last = resolve_descriptor(workflow, project: project)&.stages&.last
+      !last.nil? && last.dir == stage
+    end
+
+    def generic_non_agent_stage?(stage, workflow, project: nil)
+      found = resolve_descriptor(workflow, project: project)&.stage_for_dir(stage)
+      !found.nil? && found.kind != :agent
+    end
+
+    def resolve_descriptor(workflow, project: nil)
+      Hive::Workflows::Project.synchronize do
+        load_project_overlay(project)
+        Hive::Workflows::Registry.fetch(workflow.to_s.to_sym)
+      end
+    rescue Hive::Workflows::UnknownWorkflow
+      nil
+    end
+
+    def load_project_overlay(project_name)
+      return if project_name.nil? || project_name.to_s.empty?
+
+      match = Hive::Config.registered_projects.find { |entry| entry["name"] == project_name.to_s }
+      Hive::Workflows::Project.load!(match["path"]) if match
+    end
+  end
+end
diff --git a/test/integration/daemon_recoverable_marker_retry_test.rb b/test/integration/daemon_recoverable_marker_retry_test.rb
new file mode 100644
index 00000000..a40de30c
--- /dev/null
+++ b/test/integration/daemon_recoverable_marker_retry_test.rb
@@ -0,0 +1,299 @@
+require "test_helper"
+require "shellwords"
+require "hive/commands/run"
+require "hive/daemon/dispatcher"
+require "hive/daemon/recoverable_marker_retry"
+
+class DaemonRecoverableMarkerRetryIntegrationTest < Minitest::Test
+  include HiveTestHelper
+
+  NOW = Time.now
+  Row = Hive::Daemon::StatusConsumer::Row
+
+  class FakeHealth
+    attr_accessor :fingerprint, :healthy
+
+    def initialize(fingerprint: "dependency-v1", healthy: true)
+      @fingerprint = fingerprint
+      @healthy = healthy
+    end
+
+    def begin_tick! = nil
+    def cheap_fingerprint(**_kwargs) = "cheap-#{fingerprint}"
+    def signal_fingerprint(**_kwargs) = fingerprint
+
+    def probe(**_kwargs)
+      result = Hive::Daemon::AutoRetryHealth::ProbeResult.new(
+        name: "fake_dependency", status: healthy ? :ok : :failed,
+        duration_ms: 1, stdout: healthy ? "healthy" : "unhealthy",
+        stderr: "", classification: healthy ? nil : "fixture_failure"
+      )
+      Hive::Daemon::AutoRetryHealth::Bundle.new(
+        healthy: healthy, fingerprint: fingerprint,
+        probes: [ result ], signals: {}
+      )
+    end
+  end
+
+  class FakeLogger
+    attr_reader :events
+    def initialize = @events = []
+    def event(name, **attrs) = @events << [ name, attrs ]
+  end
+
+  class FakeStatus
+    def initialize(result) = @result = result
+    def fetch = @result
+  end
+
+  class FakeSupervisor
+    attr_reader :spawned
+    def initialize = @spawned = []
+    def spawn(**kwargs)
+      @spawned << kwargs
+      900 + @spawned.length
+    end
+    def reap_all(now:) = []
+    def reap_dry_run(now:) = []
+    def enforce_timeouts(now:) = []
+    def in_flight_count = @spawned.length
+    def update_timeouts(**_kwargs) = nil
+    def terminate_all(grace_sec:) = nil
+  end
+
+  class LockedIntegrationRun < Hive::Commands::Run
+    attr_reader :runner_called
+
+    def perform_rebase(_task, _cfg)
+      Struct.new(:attempted, :reason).new(false, :test)
+    end
+
+    def pick_runner(_task)
+      lambda do |task, _cfg|
+        @runner_called = true
+        Hive::Markers.set(task.state_file, :execute_complete)
+        { status: :ok, commit: nil }
+      end
+    end
+
+    def commit_after(_task, _result) = nil
+    def report(_task, _result) = nil
+  end
+
+  def test_codex_401_flows_from_daemon_tick_through_locked_same_stage_runner
+    with_tmp_global_config do |state_home|
+      project, folder, worktree, state_file = build_execute_task(state_home)
+      Hive::Config.register_project(name: "demo", path: project)
+      marker = Hive::Markers.current(state_file)
+      row = status_row(folder, state_file, marker)
+      result = Hive::Daemon::StatusConsumer::Result.new(
+        ok: true, rows: [ row ],
+        projects: [ Hive::Daemon::StatusConsumer::ProjectInfo.new(name: "demo", legacy_stage_dirs: []) ],
+        error: nil
+      )
+      logger = FakeLogger.new
+      controller = Hive::Daemon::ConcurrencyController.new(
+        max_concurrent_runs: 3, max_concurrent_per_project: 3,
+        max_runs_per_day_per_project: 50
+      )
+      health = FakeHealth.new
+      ledger = Hive::Daemon::AutoRetryState.new(
+        path: File.join(state_home, "ledger.json"), logger: logger
+      )
+      coordinator = Hive::Daemon::RecoverableMarkerRetry.new(
+        controller: controller, health: health, state: ledger,
+        logger: logger, request_state_home: state_home
+      )
+      supervisor = FakeSupervisor.new
+      dispatcher = Hive::Daemon::Dispatcher.new(
+        config: { "daemon" => Hive::Config.load_global_daemon },
+        controller: controller, supervisor: supervisor,
+        status_consumer: FakeStatus.new(result), logger: logger,
+        dispatch_request_state_home: state_home,
+        dispatch_result_state_home: state_home,
+        auto_retry_state: ledger, auto_retry_health: health,
+        auto_retry_coordinator: coordinator
+      )
+
+      dispatcher.tick(now: NOW)
+
+      assert_equal 1, supervisor.spawned.length, logger.events.inspect
+      argv = Shellwords.split(supervisor.spawned.first.fetch(:command_string))
+      assert_equal [ "hive", "develop", "task-58", "--from", "4-execute" ], argv.first(5)
+      token = argv.fetch(argv.index("--auto-retry-token") + 1)
+      assert_equal :claimed,
+                   Hive::Daemon::DispatchRequestQueue.status(
+                     supervisor.spawned.first.fetch(:request_id), state_home: state_home
+                   )
+
+      run = LockedIntegrationRun.new(
+        folder, auto_retry_token: token,
+        auto_retry_state: ledger, auto_retry_health: health
+      )
+      run.call
+
+      assert run.runner_called
+      assert_equal :execute_complete, Hive::Markers.current(state_file).name
+      entry = ledger.entry(project: "demo", task_id: 58, slug: "task-58", reason: "implementer_failed")
+      assert_equal 1, entry.fetch("attempts")
+      events = File.readlines(File.join(folder, "events.jsonl")).map { |line| JSON.parse(line) }
+      decisions = events.select { |event| event["event_type"] == "auto_retry_decision" }
+      assert_equal %w[scheduled started], decisions.map { |event| event.dig("details", "action") }
+      assert logger.events.any? { |name, _| name == :auto_retry_scheduled }
+      assert_equal "", `git -C #{Shellwords.escape(worktree)} status --porcelain`
+    end
+  end
+
+  def test_claude_launcher_marker_queues_exact_plan_retry_only_after_green_bundle
+    with_tmp_global_config do |state_home|
+      project = File.join(state_home, "project")
+      folder = File.join(project, ".hive-state", "stages", "3-plan", "task-287")
+      FileUtils.mkdir_p(folder)
+      File.write(File.join(project, ".hive-state", "config.yml"), {
+        "daemon" => { "enabled" => true }, "plan" => { "agent" => "claude" }
+      }.to_yaml)
+      File.write(File.join(folder, "meta.yml"), { "id" => 287, "display_name" => "Launcher" }.to_yaml)
+      state_file = File.join(folder, "plan.md")
+      Hive::Markers.set(
+        state_file, :error, reason: "claude_launch_failed",
+        exception_class: "Hive::AgentError",
+        message: "claude interactive prompt did not become ready in tmux session hive-task-287"
+      )
+      marker = Hive::Markers.current(state_file)
+      row = Row.new(
+        project: "demo", slug: "task-287", stage: "3-plan", workflow: "coding",
+        marker: "error", marker_attrs: marker.attrs, folder: folder,
+        state_file: state_file, state_file_mtime: File.mtime(state_file),
+        action: "error", live_task_lock: false, diagnostic: nil
+      )
+      logger = FakeLogger.new
+      health = FakeHealth.new(healthy: false)
+      ledger = Hive::Daemon::AutoRetryState.new(path: File.join(state_home, "claude-ledger.json"))
+      coordinator = Hive::Daemon::RecoverableMarkerRetry.new(
+        health: health, state: ledger, logger: logger,
+        request_state_home: state_home
+      )
+
+      assert_empty coordinator.scan([ row ], now: NOW).select { |action| action[:action] == :scheduled }
+      assert_empty Hive::Daemon::DispatchRequestQueue.pending(state_home: state_home)
+
+      health.healthy = true
+      health.fingerprint = "dependency-v2"
+      coordinator.scan([ row ], now: NOW + 1)
+      pending = Hive::Daemon::DispatchRequestQueue.pending(state_home: state_home)
+      assert_equal 1, pending.length, logger.events.inspect
+      request = pending.fetch(0)
+      assert_equal [ "hive", "plan", "task-287", "--from", "3-plan" ], request.argv.first(5)
+    end
+  end
+
+  def test_second_retry_needs_changed_health_and_backoff_then_exhausts_across_restart
+    with_tmp_dir do |root|
+      _project, folder, _worktree, state_file = build_execute_task(root)
+      marker = Hive::Markers.current(state_file)
+      row = status_row(folder, state_file, marker)
+      logger = FakeLogger.new
+      health = FakeHealth.new(fingerprint: "dependency-v1")
+      ledger_path = File.join(root, "ledger.json")
+      ledger = Hive::Daemon::AutoRetryState.new(path: ledger_path)
+      coordinator = Hive::Daemon::RecoverableMarkerRetry.new(
+        health: health, state: ledger, logger: logger,
+        request_state_home: root
+      )
+
+      first = coordinator.scan([ row ], now: NOW).find { |action| action[:action] == :scheduled }
+      refute_nil first
+      token = first.fetch(:token)
+      ledger.claim!(token: token, marker_id: marker.attrs.fetch("marker_id"),
+                    health_fingerprint: "dependency-v1", now: NOW)
+      ledger.start!(token: token, now: NOW)
+      Hive::Daemon::DispatchRequestQueue.remove(first.fetch(:request_id), state_home: root)
+      Hive::Markers.clear_current(state_file, expected_name: :error,
+                                  match_attrs: { "marker_id" => marker.attrs.fetch("marker_id") })
+      Hive::Markers.set(state_file, :error, reason: "implementer_failed",
+                        message: "401 missing bearer auth")
+      row.marker_attrs = Hive::Markers.current(state_file).attrs
+
+      restarted = Hive::Daemon::AutoRetryState.new(path: ledger_path)
+      coordinator = Hive::Daemon::RecoverableMarkerRetry.new(
+        health: health, state: restarted, logger: logger,
+        request_state_home: root
+      )
+      assert_empty coordinator.scan([ row ], now: NOW + 60).select { |action| action[:action] == :scheduled }
+      assert_empty coordinator.scan([ row ], now: NOW + 1900).select { |action| action[:action] == :scheduled }
+
+      health.fingerprint = "dependency-v2"
+      second = coordinator.scan([ row ], now: NOW + 1901).find { |action| action[:action] == :scheduled }
+      refute_nil second
+      current = Hive::Markers.current(state_file)
+      restarted.claim!(token: second.fetch(:token), marker_id: current.attrs.fetch("marker_id"),
+                       health_fingerprint: "dependency-v2", now: NOW + 1901)
+      started = restarted.start!(token: second.fetch(:token), now: NOW + 1901)
+      assert_equal 2, started.fetch("attempts")
+      assert started.fetch("exhausted")
+      Hive::Daemon::DispatchRequestQueue.remove(second.fetch(:request_id), state_home: root)
+      Hive::Markers.clear_current(state_file, expected_name: :error,
+                                  match_attrs: { "marker_id" => current.attrs.fetch("marker_id") })
+      Hive::Markers.set(state_file, :error, reason: "implementer_failed",
+                        message: "401 missing bearer auth")
+      row.marker_attrs = Hive::Markers.current(state_file).attrs
+
+      final_state = Hive::Daemon::AutoRetryState.new(path: ledger_path)
+      final = Hive::Daemon::RecoverableMarkerRetry.new(
+        health: FakeHealth.new(fingerprint: "dependency-v3"),
+        state: final_state, logger: logger, request_state_home: root
+      )
+      assert_empty final.scan([ row ], now: NOW + 4000).select { |action| action[:action] == :scheduled }
+      assert_equal 2, final_state.entry(project: "demo", task_id: 58, slug: "task-58",
+                                        reason: "implementer_failed").fetch("attempts")
+
+      # Manual fallback remains a plain marker clear and does not re-arm the
+      # lifetime automatic budget.
+      exhausted_marker = Hive::Markers.current(state_file)
+      assert Hive::Markers.clear_current(
+        state_file, expected_name: :error,
+        match_attrs: { "marker_id" => exhausted_marker.attrs.fetch("marker_id") }
+      )
+      assert_equal 2, final_state.entry(project: "demo", task_id: 58, slug: "task-58",
+                                        reason: "implementer_failed").fetch("attempts")
+    end
+  end
+
+  private
+
+  def build_execute_task(root)
+    project = File.join(root, "project")
+    folder = File.join(project, ".hive-state", "stages", "4-execute", "task-58")
+    worktree = File.join(root, "worktree")
+    FileUtils.mkdir_p(folder)
+    File.write(File.join(project, ".hive-state", "config.yml"), {
+      "daemon" => { "enabled" => true },
+      "execute" => { "agent" => "codex" },
+      "worktree_root" => File.dirname(worktree)
+    }.to_yaml)
+    File.write(File.join(folder, "meta.yml"), { "id" => 58, "display_name" => "Auth recovery" }.to_yaml)
+    File.write(File.join(folder, "worktree.yml"), { "path" => worktree }.to_yaml)
+    FileUtils.mkdir_p(worktree)
+    run!("git", "-C", worktree, "init", "-b", "task-58", "--quiet")
+    run!("git", "-C", worktree, "config", "user.email", "test@example.com")
+    run!("git", "-C", worktree, "config", "user.name", "Test")
+    File.write(File.join(worktree, "README.md"), "clean\n")
+    run!("git", "-C", worktree, "add", "README.md")
+    run!("git", "-C", worktree, "commit", "-m", "initial", "--quiet")
+    state_file = File.join(folder, "task.md")
+    Hive::Markers.set(
+      state_file, :error, reason: "implementer_failed",
+      message: "HTTP 401: missing bearer or basic authentication"
+    )
+    [ project, folder, worktree, state_file ]
+  end
+
+  def status_row(folder, state_file, marker)
+    Row.new(
+      project: "demo", slug: "task-58", stage: "4-execute", workflow: "coding",
+      marker: "error", marker_attrs: marker.attrs, folder: folder,
+      state_file: state_file, state_file_mtime: File.mtime(state_file),
+      action: "error", live_task_lock: false, diagnostic: nil
+    )
+  end
+end
