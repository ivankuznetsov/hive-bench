index 00000000..72ae5926
--- /dev/null
+++ b/test/unit/daemon/auto_retry_state_test.rb
@@ -0,0 +1,185 @@
+require "test_helper"
+require "json"
+require "time"
+require "hive/daemon/auto_retry_state"
+
+class HiveDaemonAutoRetryStateTest < Minitest::Test
+  include HiveTestHelper
+
+  NOW = Time.utc(2026, 7, 11, 12, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+    def initialize = @events = []
+    def event(name, **attrs) = @events << [ name, attrs ]
+  end
+
+  def setup
+    @dir = Dir.mktmpdir("hive-auto-retry-state")
+    @path = File.join(@dir, "state", "auto-retry.json")
+    @logger = FakeLogger.new
+    @state = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+    @identity = { project: "demo", task_id: 58, slug: "task-58", reason: "implementer_failed" }
+  end
+
+  def teardown
+    FileUtils.rm_rf(@dir)
+  end
+
+  def test_first_healthy_observation_reserves_without_consuming_attempt
+    decision = observe(marker_id: "m1", fingerprint: "healthy-1", healthy: true)
+    assert_equal :schedule, decision.action
+    assert_equal 1, decision.attempt
+
+    @state.reserve!(**@identity, request_id: "r1", token: "t1", attempt: 1,
+                    marker_id: "m1", marker_attrs: { "reason" => "implementer_failed" },
+                    stage: "4-execute", health_fingerprint: "healthy-1", now: NOW)
+    assert_equal 0, @state.entry(**@identity).fetch("attempts")
+    assert_equal "reserved", @state.entry(**@identity).fetch("phase")
+
+    @state.mark_queued!(token: "t1", now: NOW)
+    started = @state.start!(token: "t1", now: NOW)
+    assert_equal 1, started.fetch("attempts")
+    refute started.fetch("exhausted")
+  end
+
+  def test_second_attempt_requires_changed_health_and_thirty_minutes
+    start_attempt(marker_id: "m1", fingerprint: "health-1", request: 1, now: NOW)
+    failed_at = NOW + 60
+
+    assert_equal :backoff, observe(marker_id: "m2", fingerprint: "health-2", healthy: true, now: failed_at).action
+    assert_equal :health_unchanged,
+                 observe(marker_id: "m2", fingerprint: "health-1", healthy: true, now: failed_at + 1900).action
+    ready = observe(marker_id: "m2", fingerprint: "health-2", healthy: true, now: failed_at + 1800)
+    assert_equal :schedule, ready.action
+    assert_equal 2, ready.attempt
+
+    @state.reserve!(**@identity, request_id: "r2", token: "t2", attempt: 2,
+                    marker_id: "m2", marker_attrs: {}, stage: "5-open-pr",
+                    health_fingerprint: "health-2", now: failed_at + 1800)
+    @state.mark_queued!(token: "t2", now: failed_at + 1800)
+    started = @state.start!(token: "t2", now: failed_at + 1800)
+    assert_equal 2, started.fetch("attempts")
+    assert started.fetch("exhausted")
+    assert_equal :exhausted,
+                 observe(marker_id: "m3", fingerprint: "health-3", healthy: true, now: failed_at + 4000).action
+  end
+
+  def test_budget_survives_reconstruction_and_stage_moves
+    start_attempt(marker_id: "m1", fingerprint: "health-1", request: 1, now: NOW)
+    reconstructed = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+
+    entry = reconstructed.entry(**@identity)
+    assert_equal 1, entry.fetch("attempts")
+    assert_equal "4-execute", entry.fetch("stage")
+    reconstructed.observe(**@identity, stage: "6-review", marker_id: "m2", marker_attrs: {},
+                          health_fingerprint: "health-2", healthy: true, safe: true, now: NOW + 60)
+    assert_equal 1, reconstructed.entry(**@identity).fetch("attempts")
+    assert_equal "6-review", reconstructed.entry(**@identity).fetch("stage")
+  end
+
+  def test_releasing_unstarted_reservation_does_not_consume_budget
+    observe(marker_id: "m1", fingerprint: "health-1", healthy: true)
+    @state.reserve!(**@identity, request_id: "r1", token: "t1", attempt: 1,
+                    marker_id: "m1", marker_attrs: {}, stage: "4-execute",
+                    health_fingerprint: "health-1", now: NOW)
+    assert @state.release!(token: "t1", reason: "expired", now: NOW + 10)
+    entry = @state.entry(**@identity)
+    assert_equal 0, entry.fetch("attempts")
+    assert_nil entry["phase"]
+  end
+
+  def test_token_claim_is_one_use_and_snapshot_bound
+    observe(marker_id: "m1", fingerprint: "health-1", healthy: true)
+    @state.reserve!(**@identity, request_id: "r1", token: "t1", attempt: 1,
+                    marker_id: "m1", marker_attrs: {}, stage: "4-execute",
+                    health_fingerprint: "health-1", now: NOW)
+    @state.mark_queued!(token: "t1", now: NOW)
+
+    assert_nil @state.claim!(token: "t1", marker_id: "newer", health_fingerprint: "health-1", now: NOW)
+    claim = @state.claim!(token: "t1", marker_id: "m1", health_fingerprint: "health-1", now: NOW)
+    assert_equal "claimed", claim.fetch("phase")
+    assert_nil @state.claim!(token: "t1", marker_id: "m1", health_fingerprint: "health-1", now: NOW)
+  end
+
+  def test_corrupt_and_newer_schema_files_fail_closed
+    FileUtils.mkdir_p(File.dirname(@path))
+    File.write(@path, "{")
+    corrupt = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+    refute corrupt.available?
+    assert_equal :unavailable, corrupt.observe(**@identity, stage: "4-execute", marker_id: "m1",
+                                                marker_attrs: {}, health_fingerprint: "h",
+                                                healthy: true, safe: true, now: NOW).action
+
+    File.write(@path, JSON.generate("schema_version" => 99, "entries" => {}, "cursor" => nil))
+    newer = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+    refute newer.available?
+
+    File.write(@path, JSON.generate("schema_version" => 1, "entries" => { "x" => { "attempts" => 0 } }))
+    partial = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+    refute partial.available?
+  end
+
+  def test_negative_audits_are_throttled_but_changes_emit_immediately
+    assert @state.negative_audit_due?(**@identity, rationale: "unhealthy", fingerprint: "f1",
+                                      marker_id: "m1", recovery_epoch: 0, now: NOW)
+    @state.record_negative_audit!(**@identity, rationale: "unhealthy", fingerprint: "f1",
+                                  marker_id: "m1", recovery_epoch: 0, now: NOW)
+    refute @state.negative_audit_due?(**@identity, rationale: "unhealthy", fingerprint: "f1",
+                                     marker_id: "m1", recovery_epoch: 0, now: NOW + 120)
+    assert @state.negative_audit_due?(**@identity, rationale: "safe_now", fingerprint: "f1",
+                                      marker_id: "m1", recovery_epoch: 0, now: NOW + 120)
+    assert @state.negative_audit_due?(**@identity, rationale: "unhealthy", fingerprint: "f1",
+                                      marker_id: "m1", recovery_epoch: 0, now: NOW + 1800)
+  end
+
+  def test_fair_cursor_rotates_and_persists
+    candidates = %w[a b c]
+    assert_equal candidates, @state.rotate_candidates(candidates)
+    @state.advance_cursor!("a")
+    assert_equal %w[b c a], @state.rotate_candidates(candidates)
+
+    reconstructed = Hive::Daemon::AutoRetryState.new(path: @path, logger: @logger)
+    assert_equal %w[b c a], reconstructed.rotate_candidates(candidates)
+  end
+
+  def test_state_and_parent_are_owner_only
+    observe(marker_id: "m1", fingerprint: "health-1", healthy: false)
+    assert_equal 0o600, File.stat(@path).mode & 0o777
+    assert_equal 0o700, File.stat(File.dirname(@path)).mode & 0o777
+  end
+
+  def test_reservation_and_queue_transition_are_idempotent
+    observe(marker_id: "m1", fingerprint: "health-1", healthy: true)
+    args = {
+      **@identity, request_id: "r1", token: "t1", attempt: 1,
+      marker_id: "m1", marker_attrs: {}, stage: "4-execute",
+      health_fingerprint: "health-1", now: NOW
+    }
+    assert @state.reserve!(**args)
+    assert @state.reserve!(**args)
+    assert @state.mark_queued!(token: "t1", now: NOW)
+    assert @state.mark_queued!(token: "t1", now: NOW)
+    assert_equal 0, @state.entry(**@identity).fetch("attempts")
+  end
+
+  private
+
+  def observe(marker_id:, fingerprint:, healthy:, safe: true, now: NOW)
+    @state.observe(
+      **@identity, stage: "4-execute", marker_id: marker_id,
+      marker_attrs: { "marker_id" => marker_id, "reason" => @identity[:reason] },
+      health_fingerprint: fingerprint, healthy: healthy, safe: safe, now: now
+    )
+  end
+
+  def start_attempt(marker_id:, fingerprint:, request:, now:)
+    assert_equal :schedule, observe(marker_id: marker_id, fingerprint: fingerprint, healthy: true, now: now).action
+    token = "t#{request}"
+    @state.reserve!(**@identity, request_id: "r#{request}", token: token, attempt: request,
+                    marker_id: marker_id, marker_attrs: {}, stage: "4-execute",
+                    health_fingerprint: fingerprint, now: now)
+    @state.mark_queued!(token: token, now: now)
+    @state.start!(token: token, now: now)
+  end
+end
