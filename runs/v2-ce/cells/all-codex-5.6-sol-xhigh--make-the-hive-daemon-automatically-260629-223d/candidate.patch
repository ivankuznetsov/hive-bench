+require "digest"
+require "fileutils"
+require "json"
+require "securerandom"
+require "time"
+require "hive/paths"
+
+module Hive
+  module Daemon
+    # Durable retry ledger shared by the daemon coordinator and tokenized
+    # child. All read-modify-write operations hold a cross-process flock and
+    # land through fsync+rename with owner-only permissions.
+    class AutoRetryState
+      SCHEMA_VERSION = 1
+      MAX_ATTEMPTS = 2
+      SECOND_ATTEMPT_BACKOFF_SEC = 30 * 60
+      FALLBACK_INTERVAL_SEC = 30 * 60
+      TOKEN_TTL_SEC = 10 * 60
+      STALE_TMP_SEC = 60
+
+      Evaluation = Struct.new(:action, :attempt, :rationale, :eligible_after, keyword_init: true)
+
+      def self.default_path
+        Hive::Paths.auto_retry_state_path
+      end
+
+      def initialize(path: self.class.default_path, logger: nil)
+        @path = path && File.expand_path(path)
+        @logger = logger
+        @available = !@path.nil?
+        clean_orphaned_tmp_files!
+        validate_initial_document!
+      end
+
+      def available?
+        @available == true
+      end
+
+      def entry(project:, task_id: nil, slug:, reason:)
+        return nil unless available?
+
+        with_document do |doc|
+          value = doc.fetch("entries", {})[identity_key(project: project, task_id: task_id, slug: slug, reason: reason)]
+          deep_copy(value)
+        end
+      end
+
+      def entry_for_token(token)
+        return nil if token.to_s.empty? || !available?
+
+        with_document do |doc|
+          found = doc.fetch("entries", {}).values.find { |value| value["token"].to_s == token.to_s }
+          deep_copy(found)
+        end
+      end
+
+      def started_entries
+        return [] unless available?
+
+        with_document do |doc|
+          doc.fetch("entries", {}).values
+             .select { |value| value["phase"] == "started" }
+             .map { |value| deep_copy(value) }
+        end || []
+      end
+
+      def observe(project:, task_id: nil, slug:, reason:, stage:, marker_id:,
+                  marker_attrs:, health_fingerprint:, healthy:, safe:, now: Time.now)
+        return Evaluation.new(action: :unavailable, rationale: "state_unavailable") unless available?
+
+        result = nil
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          value["stage"] = stage.to_s
+          value["last_observed_marker_id"] = marker_id.to_s
+          value["last_observed_fingerprint"] = health_fingerprint.to_s
+          value["last_observed_at"] = iso(now)
+          value["last_marker_attrs"] = stringify_hash(marker_attrs)
+
+          result = evaluate_entry(value, marker_id: marker_id, health_fingerprint: health_fingerprint,
+                                  healthy: healthy, safe: safe, now: now)
+        end
+        result || Evaluation.new(action: :unavailable, rationale: "state_write_failed")
+      end
+
+      def reserve!(project:, task_id: nil, slug:, reason:, request_id:, token:, attempt:,
+                   marker_id:, marker_attrs:, stage:, health_fingerprint:, now: Time.now)
+        return nil unless available?
+
+        reserved = nil
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          if value["token"].to_s == token.to_s && value["request_id"].to_s == request_id.to_s
+            reserved = deep_copy(value)
+            next
+          end
+          next if find_token(doc, token)
+          expected_attempt = value.fetch("attempts", 0).to_i + 1
+          next unless value["phase"].to_s.empty?
+          next unless attempt.to_i == expected_attempt && attempt.to_i <= MAX_ATTEMPTS
+          next if value["exhausted"] == true
+
+          value.merge!(
+            "phase" => "reserved",
+            "request_id" => request_id.to_s,
+            "token" => token.to_s,
+            "reserved_attempt" => attempt.to_i,
+            "reserved_at" => iso(now),
+            "expires_at" => iso(now + TOKEN_TTL_SEC),
+            "stage" => stage.to_s,
+            "marker_id" => marker_id.to_s,
+            "original_marker_attrs" => stringify_hash(marker_attrs),
+            "approved_health_fingerprint" => health_fingerprint.to_s
+          )
+          reserved = deep_copy(value)
+        end
+        reserved
+      end
+
+      def mark_queued!(token:, now: Time.now)
+        transition_token(token, from: %w[reserved queued], to: "queued", now: now)
+      end
+
+      def claim!(token:, marker_id:, health_fingerprint:, now: Time.now)
+        claimed = nil
+        mutate do |doc|
+          value = find_token(doc, token)
+          next unless value && value["phase"] == "queued"
+          next if expired?(value, now)
+          next unless value["marker_id"].to_s == marker_id.to_s
+          next unless value["approved_health_fingerprint"].to_s == health_fingerprint.to_s
+
+          value["phase"] = "claimed"
+          value["claimed_at"] = iso(now)
+          claimed = deep_copy(value)
+        end
+        claimed
+      end
+
+      # The budget commit point. It must be called immediately before the
+      # guarded marker clear/runner entry, after mandatory task audit succeeds.
+      def start!(token:, now: Time.now)
+        started = nil
+        mutate do |doc|
+          value = find_token(doc, token)
+          next unless value && %w[queued claimed].include?(value["phase"])
+          next if expired?(value, now)
+
+          attempt = value["reserved_attempt"].to_i
+          next unless attempt == value.fetch("attempts", 0).to_i + 1
+          next if attempt > MAX_ATTEMPTS
+
+          value["phase"] = "started"
+          value["attempts"] = attempt
+          value["started_at"] = iso(now)
+          value["last_attempted_health_fingerprint"] = value["approved_health_fingerprint"].to_s
+          value["last_attempted_marker_id"] = value["marker_id"].to_s
+          value["exhausted"] = true if attempt >= MAX_ATTEMPTS
+          started = deep_copy(value)
+        end
+        started
+      end
+
+      def release!(token:, reason:, now: Time.now)
+        released = false
+        mutate do |doc|
+          value = find_token(doc, token)
+          next unless value && %w[reserved queued claimed].include?(value["phase"])
+
+          value["last_release_reason"] = reason.to_s
+          value["last_released_at"] = iso(now)
+          clear_reservation(value)
+          released = true
+        end
+        released
+      end
+
+      # Conservative reconciliation hook used on boot/ticks. The queue lookup
+      # returns :pending, :claimed, :missing, or :ambiguous for request ids.
+      # Pre-start missing requests are released; a started entry remains spent.
+      def reconcile!(queue_status:, now: Time.now)
+        actions = []
+        mutate do |doc|
+          doc.fetch("entries", {}).each_value do |value|
+            phase = value["phase"].to_s
+            next if phase.empty? || phase == "started"
+
+            status = queue_status.call(value["request_id"].to_s)
+            if status == :missing
+              actions << { "action" => "released", "token" => value["token"], "request_id" => value["request_id"] }
+              value["last_release_reason"] = "reconciled_missing_request"
+              value["last_released_at"] = iso(now)
+              clear_reservation(value)
+            elsif status == :ambiguous
+              # A claimed child may have crossed the start boundary before a
+              # crash made correlation impossible. Count conservatively.
+              next unless phase == "claimed"
+
+              attempt = value["reserved_attempt"].to_i
+              value["phase"] = "started"
+              value["attempts"] = [ value.fetch("attempts", 0).to_i, attempt ].max
+              value["started_at"] ||= iso(now)
+              value["last_attempted_health_fingerprint"] = value["approved_health_fingerprint"].to_s
+              value["exhausted"] = true if value["attempts"] >= MAX_ATTEMPTS
+              actions << { "action" => "counted_ambiguous", "token" => value["token"], "request_id" => value["request_id"] }
+            end
+          end
+        end
+        actions
+      end
+
+      def negative_audit_due?(project:, task_id: nil, slug:, reason:, rationale:,
+                              fingerprint:, marker_id:, recovery_epoch:, now: Time.now)
+        value = entry(project: project, task_id: task_id, slug: slug, reason: reason)
+        return true unless value
+
+        signature = audit_signature(rationale, fingerprint, marker_id, recovery_epoch)
+        return true unless value["last_negative_audit_signature"] == signature
+
+        last = parse_time(value["last_negative_audit_at"])
+        last.nil? || now - last >= FALLBACK_INTERVAL_SEC
+      end
+
+      def record_negative_audit!(project:, task_id: nil, slug:, reason:, rationale:,
+                                 fingerprint:, marker_id:, recovery_epoch:, now: Time.now)
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          value["last_negative_audit_signature"] = audit_signature(rationale, fingerprint, marker_id, recovery_epoch)
+          value["last_negative_audit_at"] = iso(now)
+        end
+      end
+
+      def probe_due?(project:, task_id: nil, slug:, reason:, cheap_fingerprint:, now: Time.now)
+        value = entry(project: project, task_id: task_id, slug: slug, reason: reason)
+        return true unless value
+        return true unless value["last_evaluated_cheap_fingerprint"].to_s == cheap_fingerprint.to_s
+
+        last = parse_time(value["last_evaluated_at"])
+        last.nil? || now - last >= FALLBACK_INTERVAL_SEC
+      end
+
+      def record_evaluation!(project:, task_id: nil, slug:, reason:, cheap_fingerprint:, now: Time.now)
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          value["last_evaluated_cheap_fingerprint"] = cheap_fingerprint.to_s
+          value["last_evaluated_at"] = iso(now)
+        end
+      end
+
+      def cached_health(project:, task_id: nil, slug:, reason:, cheap_fingerprint:)
+        value = entry(project: project, task_id: task_id, slug: slug, reason: reason)
+        return nil unless value
+        return nil unless value["last_probe_cheap_fingerprint"].to_s == cheap_fingerprint.to_s
+
+        {
+          "healthy" => value["last_probe_healthy"] == true,
+          "fingerprint" => value["last_probe_health_fingerprint"].to_s,
+          "probes" => Array(value["last_probe_results"])
+        }
+      end
+
+      def record_health!(project:, task_id: nil, slug:, reason:, cheap_fingerprint:,
+                         health_fingerprint:, healthy:, probes:, now: Time.now)
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          value["last_probe_cheap_fingerprint"] = cheap_fingerprint.to_s
+          value["last_probe_health_fingerprint"] = health_fingerprint.to_s
+          value["last_probe_healthy"] = healthy == true
+          value["last_probe_results"] = Array(probes).first(20)
+          value["last_probe_at"] = iso(now)
+          value["last_evaluated_cheap_fingerprint"] = cheap_fingerprint.to_s
+          value["last_evaluated_at"] = iso(now)
+        end
+      end
+
+      def rotate_candidates(candidates)
+        values = Array(candidates)
+        return values if values.empty? || !available?
+
+        cursor = with_document { |doc| doc["cursor"] }
+        index = values.index(cursor)
+        return values unless index
+
+        values.rotate(index + 1)
+      end
+
+      def advance_cursor!(candidate)
+        mutate { |doc| doc["cursor"] = candidate }
+      end
+
+      # Drop only low-value cadence/audit fields for tasks absent from the
+      # current status snapshot. Attempt history and exhaustion are permanent.
+      def prune_cadence!(active_identity_keys:)
+        active = Array(active_identity_keys).map(&:to_s)
+        mutate do |doc|
+          doc.fetch("entries", {}).each do |key, value|
+            next if active.include?(key)
+
+            %w[last_negative_audit_signature last_negative_audit_at
+               last_evaluated_cheap_fingerprint last_evaluated_at
+               last_observed_fingerprint last_observed_at].each { |field| value.delete(field) }
+          end
+        end
+      end
+
+      def key_for(project:, task_id: nil, slug:, reason:)
+        identity_key(project: project, task_id: task_id, slug: slug, reason: reason)
+      end
+
+      def recovery_epoch(project:, task_id: nil, slug:, reason:)
+        entry(project: project, task_id: task_id, slug: slug, reason: reason)&.fetch("recovery_epoch", 0).to_i
+      end
+
+      def record_recovery_activity!(project:, task_id: nil, slug:, reason:, now: Time.now)
+        mutate do |doc|
+          value = fetch_entry!(doc, project: project, task_id: task_id, slug: slug, reason: reason)
+          value["recovery_epoch"] = value.fetch("recovery_epoch", 0).to_i + 1
+          value["last_recovery_activity_at"] = iso(now)
+        end
+      end
+
+      private
+
+      def evaluate_entry(value, marker_id:, health_fingerprint:, healthy:, safe:, now:)
+        attempts = value.fetch("attempts", 0).to_i
+        return Evaluation.new(action: :exhausted, attempt: attempts, rationale: "attempt_budget_exhausted") if value["exhausted"] || attempts >= MAX_ATTEMPTS
+        # A parked ERROR observed after a child crossed `started` is the
+        # durable proof that run ended back at the recoverable reason. Retire
+        # the one-use token before evaluating attempt two.
+        clear_reservation(value) if value["phase"] == "started"
+        return Evaluation.new(action: :reserved, attempt: attempts + 1, rationale: "request_already_reserved") unless value["phase"].to_s.empty? || value["phase"] == "started"
+        return Evaluation.new(action: :unsafe, attempt: attempts + 1, rationale: "retry_safety_failed") unless safe
+        return Evaluation.new(action: :unhealthy, attempt: attempts + 1, rationale: "dependency_unhealthy") unless healthy
+
+        if attempts.zero?
+          return Evaluation.new(action: :schedule, attempt: 1, rationale: "first_healthy_observation")
+        end
+
+        # Seeing a parked marker after attempt one proves that automatic run
+        # failed. Record the observation once per episode; marker rotation
+        # triggers evaluation but is never itself a changed health signal.
+        if value["failure_marker_id"].to_s != marker_id.to_s
+          value["failure_marker_id"] = marker_id.to_s
+          value["failed_attempt_observed_at"] = iso(now)
+          value["eligible_after"] = iso(now + SECOND_ATTEMPT_BACKOFF_SEC)
+        end
+
+        eligible_after = parse_time(value["eligible_after"])
+        if eligible_after && now < eligible_after
+          return Evaluation.new(action: :backoff, attempt: 2, rationale: "second_attempt_backoff",
+                                eligible_after: eligible_after)
+        end
+        if value["last_attempted_health_fingerprint"].to_s == health_fingerprint.to_s
+          return Evaluation.new(action: :health_unchanged, attempt: 2, rationale: "dependency_signal_unchanged",
+                                eligible_after: eligible_after)
+        end
+
+        Evaluation.new(action: :schedule, attempt: 2, rationale: "changed_health_after_backoff",
+                       eligible_after: eligible_after)
+      end
+
+      def fetch_entry!(doc, project:, task_id:, slug:, reason:)
+        key = identity_key(project: project, task_id: task_id, slug: slug, reason: reason)
+        doc["entries"][key] ||= {
+          "project" => project.to_s,
+          "task_id" => task_id.nil? ? nil : task_id.to_s,
+          "slug" => slug.to_s,
+          "reason" => reason.to_s,
+          "attempts" => 0,
+          "exhausted" => false,
+          "phase" => nil
+        }
+      end
+
+      def identity_key(project:, task_id:, slug:, reason:)
+        stable_task = task_id.nil? || task_id.to_s.empty? ? "slug:#{slug}" : "id:#{task_id}"
+        ::Digest::SHA256.hexdigest(JSON.generate([ project.to_s, stable_task, reason.to_s ]))
+      end
+
+      def find_token(doc, token)
+        return nil if token.to_s.empty?
+
+        doc.fetch("entries", {}).values.find { |value| value["token"].to_s == token.to_s }
+      end
+
+      def transition_token(token, from:, to:, now:)
+        transitioned = nil
+        mutate do |doc|
+          value = find_token(doc, token)
+          next unless value && from.include?(value["phase"])
+          next if expired?(value, now)
+
+          value["phase"] = to
+          value["#{to}_at"] = iso(now)
+          transitioned = deep_copy(value)
+        end
+        transitioned
+      end
+
+      def clear_reservation(value)
+        %w[phase request_id token reserved_attempt reserved_at queued_at claimed_at expires_at
+           marker_id original_marker_attrs approved_health_fingerprint].each { |key| value[key] = nil }
+      end
+
+      def expired?(value, now)
+        expiry = parse_time(value["expires_at"])
+        expiry.nil? || now > expiry
+      end
+
+      def audit_signature(rationale, fingerprint, marker_id, recovery_epoch)
+        ::Digest::SHA256.hexdigest(JSON.generate([
+          rationale.to_s, fingerprint.to_s, marker_id.to_s, recovery_epoch.to_i
+        ]))
+      end
+
+      def validate_initial_document!
+        return unless @path && File.exist?(@path)
+        raise InvalidDocument, "state path is not a regular file" if !File.file?(@path) || File.symlink?(@path)
+
+        with_lock do
+          doc = read_document
+          validate_document!(doc)
+        end
+      rescue NewerSchema => e
+        @available = false
+        log(:auto_retry_state_newer_schema, path: @path, message: e.message)
+      rescue JSON::ParserError, InvalidDocument, SystemCallError, IOError, TypeError => e
+        @available = false
+        log(:auto_retry_state_corrupt, path: @path, error_class: e.class.name, message: e.message)
+      end
+
+      def with_document
+        return nil unless available?
+
+        with_lock do
+          doc = File.exist?(@path) ? read_document : empty_document
+          validate_document!(doc)
+          yield doc
+        end
+      rescue NewerSchema => e
+        suspend!(:auto_retry_state_newer_schema, e)
+        nil
+      rescue JSON::ParserError, InvalidDocument, SystemCallError, IOError, TypeError => e
+        suspend!(:auto_retry_state_corrupt, e)
+        nil
+      end
+
+      def mutate
+        return nil unless available?
+
+        with_lock do
+          doc = File.exist?(@path) ? read_document : empty_document
+          validate_document!(doc)
+          yield doc
+          persist!(doc)
+        end
+      rescue NewerSchema => e
+        suspend!(:auto_retry_state_newer_schema, e)
+        nil
+      rescue JSON::ParserError, InvalidDocument, SystemCallError, IOError, TypeError => e
+        suspend!(:auto_retry_state_write_error, e)
+        nil
+      end
+
+      def with_lock
+        ensure_parent!
+        File.open("#{@path}.lock", File::RDWR | File::CREAT, 0o600) do |file|
+          File.chmod(0o600, file.path)
+          file.flock(File::LOCK_EX)
+          yield
+        end
+      rescue SystemCallError, IOError => e
+        suspend!(:auto_retry_state_lock_error, e)
+        nil
+      end
+
+      def read_document
+        JSON.parse(File.read(@path, encoding: "UTF-8"))
+      end
+
+      def validate_document!(doc)
+        raise InvalidDocument, "root must be a Hash" unless doc.is_a?(Hash)
+        version = doc["schema_version"]
+        raise InvalidDocument, "schema_version must be an Integer" unless version.is_a?(Integer)
+        raise NewerSchema, "on-disk schema v#{version} is newer than v#{SCHEMA_VERSION}" if version > SCHEMA_VERSION
+        raise InvalidDocument, "entries must be a Hash" unless doc["entries"].is_a?(Hash)
+
+        doc["entries"].each_value do |value|
+          raise InvalidDocument, "entry must be a Hash" unless value.is_a?(Hash)
+          %w[project slug reason].each do |field|
+            raise InvalidDocument, "entry #{field} invalid" unless value[field].is_a?(String) && !value[field].empty?
+          end
+          raise InvalidDocument, "entry attempts invalid" unless value["attempts"].is_a?(Integer) && value["attempts"].between?(0, MAX_ATTEMPTS)
+          raise InvalidDocument, "entry exhausted invalid" unless value["exhausted"] == true || value["exhausted"] == false
+          valid_phases = [ nil, "reserved", "queued", "claimed", "started" ]
+          raise InvalidDocument, "entry phase invalid" unless valid_phases.include?(value["phase"])
+        end
+        true
+      end
+
+      def empty_document
+        { "schema_version" => SCHEMA_VERSION, "cursor" => nil, "entries" => {} }
+      end
+
+      def persist!(doc)
+        ensure_parent!
+        tmp = File.join(File.dirname(@path), ".#{File.basename(@path)}.#{Process.pid}.#{SecureRandom.hex(4)}.tmp")
+        File.open(tmp, File::WRONLY | File::CREAT | File::TRUNC, 0o600) do |file|
+          file.write(JSON.generate(doc))
+          file.flush
+          file.fsync
+        end
+        File.chmod(0o600, tmp)
+        File.rename(tmp, @path)
+        File.chmod(0o600, @path)
+        fsync_parent!
+      ensure
+        FileUtils.rm_f(tmp) if tmp
+      end
+
+      def ensure_parent!
+        dir = File.dirname(@path)
+        FileUtils.mkdir_p(dir, mode: 0o700)
+        File.chmod(0o700, dir)
+      end
+
+      def fsync_parent!
+        File.open(File.dirname(@path), File::RDONLY) { |file| file.fsync }
+      rescue Errno::EINVAL, Errno::ENOSYS, NotImplementedError
+        nil
+      end
+
+      def clean_orphaned_tmp_files!
+        return unless @path
+
+        dir = File.dirname(@path)
+        return unless File.directory?(dir)
+
+        pattern = File.join(dir, ".#{File.basename(@path)}.*.tmp")
+        Dir.glob(pattern).each do |tmp|
+          FileUtils.rm_f(tmp) if Time.now - File.mtime(tmp) >= STALE_TMP_SEC
+        end
+      rescue SystemCallError, IOError => e
+        log(:auto_retry_state_tmp_sweep_error, path: @path, error_class: e.class.name, message: e.message)
+      end
+
+      def suspend!(event, error)
+        @available = false
+        log(event, path: @path, error_class: error.class.name, message: error.message)
+      end
+
+      def log(event, **attrs)
+        @logger&.event(event, **attrs)
+      rescue ArgumentError
+        # An injected legacy logger may not know the new closed enum yet; state
+        # still fails closed. The production logger enum is updated with this
+        # component, so this is only compatibility for narrow test doubles.
+        nil
+      end
+
+      def stringify_hash(value)
+        value.to_h.transform_keys(&:to_s).transform_values(&:to_s)
+      end
+
+      def iso(time)
+        time.utc.iso8601(6)
+      end
+
+      def parse_time(value)
+        return nil if value.to_s.empty?
+
+        Time.iso8601(value.to_s)
+      rescue ArgumentError
+        nil
+      end
+
+      def deep_copy(value)
+        value && JSON.parse(JSON.generate(value))
+      end
+
+      class InvalidDocument < StandardError; end
+      class NewerSchema < StandardError; end
+    end
+  end
+end
