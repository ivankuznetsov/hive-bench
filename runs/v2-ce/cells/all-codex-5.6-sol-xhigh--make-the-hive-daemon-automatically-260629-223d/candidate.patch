new file mode 100644
index 00000000..431dc656
--- /dev/null
+++ b/lib/hive/daemon/auto_retry_health.rb
@@ -0,0 +1,554 @@
+require "digest"
+require "fileutils"
+require "json"
+require "open3"
+require "securerandom"
+require "tmpdir"
+require "timeout"
+require "hive"
+require "hive/agent_profiles"
+require "hive/claude_launcher"
+require "hive/commands/doctor"
+require "hive/invoked_binary"
+require "hive/secret_patterns"
+require "hive/tmux_runner"
+
+module Hive
+  module Daemon
+    # Bounded dependency probes and deterministic, non-secret health signals
+    # for recoverable marker retries. A new instance may live for the daemon's
+    # lifetime; #begin_tick! clears only tick-local command/result caches.
+    class AutoRetryHealth
+      OUTPUT_MAX_BYTES = 4_096
+      VERSION_TIMEOUT_SEC = 10
+      LOGIN_TIMEOUT_SEC = 10
+      DOCTOR_TIMEOUT_SEC = 15
+      SMOKE_TIMEOUT_SEC = 30
+      HANDSHAKE_TIMEOUT_SEC = 30
+
+      ProbeResult = Struct.new(
+        :name, :status, :duration_ms, :stdout, :stderr, :classification,
+        keyword_init: true
+      ) do
+        def ok?
+          status.to_sym == :ok
+        end
+
+        def to_h
+          {
+            "name" => name.to_s,
+            "status" => status.to_s,
+            "duration_ms" => duration_ms.to_i,
+            "stdout" => stdout.to_s,
+            "stderr" => stderr.to_s,
+            "classification" => classification
+          }
+        end
+      end
+
+      Bundle = Struct.new(:healthy, :fingerprint, :probes, :signals, keyword_init: true) do
+        def healthy?
+          healthy == true
+        end
+      end
+
+      # Array-argv subprocess runner with explicit cwd/env, monotonic timing,
+      # process-group timeout termination, and bounded/redacted capture.
+      class CommandRunner
+        def run(argv, cwd:, env:, timeout:)
+          raise ArgumentError, "argv must be a non-empty Array" unless argv.is_a?(Array) && !argv.empty?
+
+          started = monotonic
+          stdout = ""
+          stderr = ""
+          status = nil
+          pid = nil
+          Open3.popen3(env.to_h, *argv.map(&:to_s), chdir: cwd, pgroup: true) do |stdin, out, err, wait|
+            pid = wait.pid
+            stdin.close
+            out_reader = Thread.new { out.read.to_s }
+            err_reader = Thread.new { err.read.to_s }
+            begin
+              Timeout.timeout(timeout) { status = wait.value }
+            rescue Timeout::Error
+              terminate_group(pid)
+              stdout = out_reader.value
+              stderr = err_reader.value
+              return result(argv, :timeout, started, stdout, stderr, "timeout")
+            ensure
+              out.close unless out.closed?
+              err.close unless err.closed?
+            end
+            stdout = out_reader.value
+            stderr = err_reader.value
+          end
+
+          if status&.success?
+            result(argv, :ok, started, stdout, stderr, nil)
+          elsif status&.signaled?
+            result(argv, :signal, started, stdout, stderr, "signal_#{status.termsig}")
+          else
+            result(argv, :failed, started, stdout, stderr, "exit_#{status&.exitstatus || 'unknown'}")
+          end
+        rescue Errno::ENOENT, Errno::EACCES, Errno::ENOEXEC, IOError => e
+          result(argv, :error, started || monotonic, stdout, "#{stderr} #{e.message}", e.class.name)
+        end
+
+        private
+
+        def terminate_group(pid)
+          Process.kill("TERM", -pid)
+          deadline = monotonic + 1.0
+          while monotonic < deadline
+            begin
+              Process.kill(0, pid)
+              sleep 0.02
+            rescue Errno::ESRCH
+              return
+            end
+          end
+          Process.kill("KILL", -pid)
+        rescue Errno::ESRCH, Errno::EPERM
+          nil
+        end
+
+        def result(argv, status, started, stdout, stderr, classification)
+          ProbeResult.new(
+            name: File.basename(argv.first.to_s), status: status,
+            duration_ms: ((monotonic - started) * 1000).round,
+            stdout: AutoRetryHealth.sanitize_output(stdout),
+            stderr: AutoRetryHealth.sanitize_output(stderr),
+            classification: classification
+          )
+        end
+
+        def monotonic
+          Process.clock_gettime(Process::CLOCK_MONOTONIC)
+        end
+      end
+
+      class << self
+        def sanitize_output(value)
+          text = value.to_s.encode("UTF-8", invalid: :replace, undef: :replace, replace: "?")
+          text = text.gsub(/[\u0000-\u0008\u000B\u000C\u000E-\u001F\u007F]/, "?")
+          text = text.gsub(/\b(bearer|basic|token)\s+[A-Za-z0-9._+\/=\-]{6,}/i, '\1 [REDACTED]')
+          text = text.gsub(/\b(access_token|refresh_token|api_token)\s*[:=]\s*\S+/i, '\1=[REDACTED]')
+          text = Hive::SecretPatterns.redact(text)
+          return text if text.bytesize <= OUTPUT_MAX_BYTES
+
+          truncated = text.byteslice(0, OUTPUT_MAX_BYTES - 16).to_s.scrub("")
+          "#{truncated}…[truncated]"
+        end
+      end
+
+      def initialize(command_runner: CommandRunner.new, env: ENV.to_h, doctor: nil,
+                     invoked_binary: Hive::InvokedBinary.method(:path),
+                     binary_resolver: nil,
+                     wrapper_path: File.expand_path("../scripts/interactive_claude_wrapper.sh", __dir__),
+                     ready_self_check: Hive::ClaudeLauncher.method(:ready_detector_self_check),
+                     dynamic_probe: nil)
+        @command_runner = command_runner
+        @env = env.to_h.transform_keys(&:to_s).transform_values(&:to_s).freeze
+        @doctor = doctor || method(:default_doctor)
+        @invoked_binary = invoked_binary
+        @binary_resolver = binary_resolver || method(:resolve_binary)
+        @wrapper_path = wrapper_path
+        @ready_self_check = ready_self_check
+        @dynamic_probe = dynamic_probe || method(:default_dynamic_probe)
+        begin_tick!
+      end
+
+      def begin_tick!
+        @bundle_cache = {}
+        @doctor_cache = {}
+        @login_cache = {}
+        @version_cache = {}
+      end
+
+      def probe(decision:, config:, project_root:, recovery_epoch: 0)
+        signals = signal_snapshot(
+          classification: decision.classification, config: config,
+          project_root: project_root, recovery_epoch: recovery_epoch
+        )
+        fingerprint = digest(signals)
+        cache_key = [ File.expand_path(project_root), decision.classification.to_s,
+                      decision.probe_family.to_s, fingerprint,
+                      decision.probe_family.to_sym == :session_absence ? ::Digest::SHA256.hexdigest(decision.evidence.to_s) : nil ]
+        return @bundle_cache.fetch(cache_key) if @bundle_cache.key?(cache_key)
+
+        probes = decision.classification == :codex_auth ?
+          codex_probes(config, project_root) : claude_probes(decision, config, project_root)
+        bundle = Bundle.new(
+          healthy: probes.all?(&:ok?), fingerprint: fingerprint,
+          probes: probes.freeze, signals: signals.freeze
+        )
+        @bundle_cache[cache_key] = bundle
+      end
+
+      # Cheap fingerprint used by cadence/state code before deciding whether a
+      # full expensive bundle is due. Values are normalized/digested and never
+      # contain credentials or raw environment values.
+      def signal_fingerprint(classification:, config:, project_root:, recovery_epoch: 0)
+        digest(signal_snapshot(
+          classification: classification, config: config,
+          project_root: project_root, recovery_epoch: recovery_epoch
+        ))
+      end
+
+      def cheap_fingerprint(classification:, config:, project_root:, recovery_epoch: 0)
+        agent = classification.to_sym == :codex_auth ? "codex" : "claude"
+        binary = configured_binary(config, agent)
+        snapshot = {
+          "agent" => agent,
+          "binary" => file_signal(binary),
+          "config" => relevant_config(config, agent),
+          "env" => relevant_env_digest(agent),
+          "recovery_epoch" => recovery_epoch.to_i
+        }
+        if agent == "claude"
+          snapshot["wrapper"] = file_signal(@wrapper_path)
+          snapshot["hive"] = file_signal(@invoked_binary.call)
+        else
+          login = login_probe(binary, project_root)
+          snapshot["login"] = login.ok? && login.stdout.match?(/logged\s+in/i) ? "logged_in" : "not_logged_in"
+        end
+        digest(snapshot)
+      end
+
+      private
+
+      def codex_probes(config, project_root)
+        binary = configured_binary(config, "codex")
+        probes = [ doctor_probe(config, project_root), version_probe(binary, "codex", config) ]
+        login = login_probe(binary, project_root)
+        probes << login
+        return probes unless login.ok? && login.stdout.match?(/logged\s+in/i)
+
+        Dir.mktmpdir("hive-auto-retry-codex") do |cwd|
+          raw = @command_runner.run(
+            [ binary, "exec", "-c", 'approval_policy="never"', "--sandbox", "read-only",
+              "--ephemeral", "--skip-git-repo-check", "--json",
+              "Reply with exactly HIVE_AUTO_RETRY_OK" ],
+            cwd: cwd, env: @env, timeout: SMOKE_TIMEOUT_SEC
+          )
+          probes << named_result(raw, "codex_smoke",
+                                 require_output: /\bHIVE_AUTO_RETRY_OK\b/)
+        end
+        probes
+      end
+
+      def claude_probes(decision, config, project_root)
+        probes = [ doctor_probe(config, project_root) ]
+        probes << wrapper_probe
+        probes << ready_detector_probe
+        probes << invoked_hive_probe(project_root)
+        probes << version_probe(configured_binary(config, "claude"), "claude", config)
+        if probes.all?(&:ok?)
+          raw = @dynamic_probe.call(
+            family: decision.probe_family, decision: decision,
+            config: config, project_root: project_root, env: @env
+          )
+          probes << named_result(raw, "claude_#{decision.probe_family}")
+        end
+        probes
+      end
+
+      def signal_snapshot(classification:, config:, project_root:, recovery_epoch:)
+        agent = classification.to_sym == :codex_auth ? "codex" : "claude"
+        binary = configured_binary(config, agent)
+        doctor = doctor_rows(config, project_root).map do |row|
+          row.to_h.transform_keys(&:to_s).slice("kind", "stage", "name", "agent", "skill", "status")
+        end.sort_by { |row| row.values_at("kind", "stage", "name", "agent", "skill").join("\0") }
+        snapshot = {
+          "agent" => agent,
+          "binary" => file_signal(binary),
+          "version" => probe_signal(version_probe(binary, agent, config)),
+          "doctor" => doctor,
+          "config" => relevant_config(config, agent),
+          "env" => relevant_env_digest(agent),
+          "recovery_epoch" => recovery_epoch.to_i
+        }
+        if agent == "codex"
+          login = login_probe(binary, project_root)
+          snapshot["login"] = login.ok? && login.stdout.match?(/logged\s+in/i) ? "logged_in" : "not_logged_in"
+        else
+          snapshot["wrapper"] = file_signal(@wrapper_path)
+          snapshot["hive"] = file_signal(@invoked_binary.call)
+          snapshot["hive_version"] = probe_signal(invoked_hive_probe(project_root))
+        end
+        snapshot
+      end
+
+      def doctor_probe(config, project_root)
+        rows = doctor_rows(config, project_root)
+        failed = rows.any? { |row| %w[missing version_too_old].include?(row_status(row)) }
+        ProbeResult.new(
+          name: "doctor", status: failed ? :failed : :ok, duration_ms: 0,
+          stdout: self.class.sanitize_output(JSON.generate(rows)), stderr: "",
+          classification: failed ? "required_check_failed" : nil
+        )
+      rescue StandardError => e
+        ProbeResult.new(name: "doctor", status: :error, duration_ms: 0,
+                        stdout: "", stderr: self.class.sanitize_output(e.message),
+                        classification: e.class.name)
+      end
+
+      def doctor_rows(config, project_root)
+        key = [ File.expand_path(project_root), digest(relevant_config(config, "doctor")) ]
+        @doctor_cache[key] ||= Array(@doctor.call(config: config, project_root: project_root))
+      end
+
+      def default_doctor(config:, project_root:)
+        Hive::Commands::Doctor.check(config: config, project_root: project_root).rows
+      end
+
+      def row_status(row)
+        row.respond_to?(:[]) ? (row[:status] || row["status"]).to_s : "missing"
+      end
+
+      def login_probe(binary, project_root)
+        key = [ binary, File.expand_path(project_root) ]
+        @login_cache[key] ||= named_result(
+          @command_runner.run([ binary, "login", "status" ], cwd: project_root,
+                              env: @env, timeout: LOGIN_TIMEOUT_SEC),
+          "codex_login", require_output: /logged\s+in/i
+        )
+      end
+
+      def version_probe(binary, agent, config)
+        key = [ binary, agent, config.dig("agents", agent, "min_version").to_s ]
+        @version_cache[key] ||= begin
+          raw = @command_runner.run([ binary, "--version" ], cwd: Dir.tmpdir,
+                                    env: @env, timeout: VERSION_TIMEOUT_SEC)
+          result = named_result(raw, "#{agent}_version", require_output: /\d+\.\d+\.\d+/)
+          validate_minimum_version(result, config.dig("agents", agent, "min_version"))
+        end
+      end
+
+      def validate_minimum_version(result, minimum)
+        return result unless result.ok? && !minimum.to_s.empty?
+
+        version = result.stdout[/\d+\.\d+\.\d+/]
+        return failed_copy(result, "malformed_version") unless version
+        return result unless (version_tuple(version) <=> version_tuple(minimum.to_s)).negative?
+
+        failed_copy(result, "version_too_old")
+      end
+
+      def wrapper_probe
+        healthy = File.file?(@wrapper_path) && File.readable?(@wrapper_path) && File.executable?(@wrapper_path)
+        ProbeResult.new(
+          name: "claude_wrapper", status: healthy ? :ok : :failed, duration_ms: 0,
+          stdout: healthy ? File.expand_path(@wrapper_path) : "", stderr: "",
+          classification: healthy ? nil : "wrapper_missing_or_invalid"
+        )
+      rescue SystemCallError => e
+        ProbeResult.new(name: "claude_wrapper", status: :error, duration_ms: 0,
+                        stdout: "", stderr: self.class.sanitize_output(e.message),
+                        classification: e.class.name)
+      end
+
+      def ready_detector_probe
+        healthy = @ready_self_check.call == true
+        ProbeResult.new(name: "ready_detector", status: healthy ? :ok : :failed,
+                        duration_ms: 0, stdout: "", stderr: "",
+                        classification: healthy ? nil : "self_check_failed")
+      rescue StandardError => e
+        ProbeResult.new(name: "ready_detector", status: :error, duration_ms: 0,
+                        stdout: "", stderr: self.class.sanitize_output(e.message),
+                        classification: e.class.name)
+      end
+
+      def invoked_hive_probe(project_root)
+        binary = @invoked_binary.call
+        return missing_probe("hive_binary", "invoked_binary_missing") if binary.to_s.empty?
+
+        raw = @command_runner.run([ binary, "--version" ], cwd: project_root,
+                                  env: @env, timeout: VERSION_TIMEOUT_SEC)
+        named_result(raw, "hive_binary", require_output: /\b#{Regexp.escape(Hive::VERSION)}\b/)
+      end
+
+      def default_dynamic_probe(family:, decision:, config:, project_root:, env:)
+        case family.to_sym
+        when :runtime
+          ProbeResult.new(name: "claude_runtime", status: :ok, duration_ms: 0,
+                          stdout: "runtime version verified", stderr: "", classification: nil)
+        when :session_absence
+          session = decision.evidence.to_s[/\b(?:claude )?tmux session ([A-Za-z0-9_.-]+)/i, 1]
+          return missing_probe("claude_session_absence", "session_name_missing") unless session
+
+          raw = @command_runner.run(
+            [ ENV.fetch("HIVE_TMUX_BIN", "tmux"), "has-session", "-t", session ],
+            cwd: project_root, env: env, timeout: VERSION_TIMEOUT_SEC
+          )
+          # has-session nonzero means the exact blocker is absent. Timeouts,
+          # signals and spawn errors are not accepted as proof of absence.
+          status = raw.status.to_sym == :failed ? :ok : :failed
+          ProbeResult.new(name: "claude_session_absence", status: status,
+                          duration_ms: raw.duration_ms, stdout: raw.stdout,
+                          stderr: raw.stderr,
+                          classification: status == :ok ? nil : "session_still_present_or_uninspectable")
+        when :wrapper_handshake
+          wrapper_handshake_probe(config: config, env: env)
+        else
+          missing_probe("claude_dynamic", "unknown_probe_family")
+        end
+      end
+
+      def wrapper_handshake_probe(config:, env:)
+        started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
+        session = "hive-auto-retry-#{Process.pid}-#{SecureRandom.hex(4)}"
+        cleanup_ok = true
+        Dir.mktmpdir("hive-auto-retry-claude") do |cwd|
+          profile = Hive::AgentProfiles.lookup(:claude, cfg: config)
+          runner = Hive::TmuxRunner.new(name: session, cwd: cwd, env: env,
+                                        tmux_bin: env.fetch("HIVE_TMUX_BIN", "tmux"),
+                                        socket_name: env["HIVE_TMUX_SOCKET"])
+          command = Hive::ClaudeLauncher.wrapper_command(
+            cwd: cwd, add_dirs: [], profile: profile,
+            permission_mode: Hive::Config.claude_permission_mode(config),
+            allowed_tools: "Read"
+          )
+          runner.start_detached(command: command)
+          deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + HANDSHAKE_TIMEOUT_SEC
+          ready = false
+          until Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline
+            ready = Hive::ClaudeLauncher.ready_prompt?(runner.capture_pane_tail(bytes: 8192))
+            break if ready
+            sleep 0.25
+          end
+          cleanup_ok = runner.kill_session != false
+          return ProbeResult.new(
+            name: "claude_wrapper_handshake", status: ready && cleanup_ok ? :ok : :failed,
+            duration_ms: ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).round,
+            stdout: "", stderr: "",
+            classification: ready ? (cleanup_ok ? nil : "cleanup_failed") : "readiness_timeout"
+          )
+        ensure
+          begin
+            runner&.kill_session
+          rescue StandardError
+            cleanup_ok = false
+          end
+        end
+      rescue StandardError => e
+        ProbeResult.new(name: "claude_wrapper_handshake", status: :error,
+                        duration_ms: ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).round,
+                        stdout: "", stderr: self.class.sanitize_output(e.message),
+                        classification: e.class.name)
+      end
+
+      def named_result(raw, name, require_output: nil)
+        result = ProbeResult.new(
+          name: name, status: raw.status, duration_ms: raw.duration_ms,
+          stdout: self.class.sanitize_output(raw.stdout),
+          stderr: self.class.sanitize_output(raw.stderr),
+          classification: raw.classification
+        )
+        return result unless result.ok? && require_output
+        return result if result.stdout.match?(require_output) || result.stderr.match?(require_output)
+
+        failed_copy(result, "required_evidence_missing")
+      end
+
+      def failed_copy(result, classification)
+        ProbeResult.new(name: result.name, status: :failed, duration_ms: result.duration_ms,
+                        stdout: result.stdout, stderr: result.stderr,
+                        classification: classification)
+      end
+
+      def missing_probe(name, classification)
+        ProbeResult.new(name: name, status: :failed, duration_ms: 0,
+                        stdout: "", stderr: "", classification: classification)
+      end
+
+      def configured_binary(config, agent)
+        configured = config.dig("agents", agent, "bin").to_s
+        configured = agent if configured.empty?
+        override_key = config.dig("agents", agent, "env_override").to_s
+        raw = override_key.empty? ? configured : @env.fetch(override_key, configured)
+        @binary_resolver.call(raw, @env) || raw
+      end
+
+      def resolve_binary(name, env)
+        return File.expand_path(name) if name.include?(File::SEPARATOR)
+
+        env.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, name)
+          return File.expand_path(path) if File.file?(path) && File.executable?(path)
+        end
+        name
+      end
+
+      def file_signal(path)
+        return { "path" => nil, "status" => "missing" } if path.to_s.empty?
+
+        expanded = File.expand_path(path)
+        stat = File.stat(expanded)
+        return { "path" => expanded, "status" => "not_file" } unless stat.file?
+
+        {
+          "path" => expanded,
+          "size" => stat.size,
+          "mtime_ns" => (stat.mtime.to_r * 1_000_000_000).to_i,
+          "sha256" => ::Digest::SHA256.file(expanded).hexdigest
+        }
+      rescue SystemCallError
+        { "path" => path.to_s, "status" => "missing" }
+      end
+
+      def relevant_config(config, agent)
+        selected = {}
+        %w[claude execute brainstorm plan].each do |key|
+          selected[key] = config[key] if config.key?(key)
+        end
+        if config.dig("review", "reviewers")
+          selected["review"] = { "reviewers" => config.dig("review", "reviewers") }
+        end
+        # Keep only the active profile under agents; other profile edits do not
+        # represent recovery of this dependency.
+        selected["agents"] = { agent => config.dig("agents", agent) } if agent != "doctor" && config.dig("agents", agent)
+        selected
+      end
+
+      def probe_signal(probe)
+        {
+          "status" => probe.status.to_s,
+          "stdout" => probe.stdout.to_s,
+          "classification" => probe.classification.to_s
+        }
+      end
+
+      def relevant_env_digest(agent)
+        keys = [ "PATH", "HIVE_INVOKED_BIN", "HIVE_TMUX_BIN", "HIVE_TMUX_SOCKET",
+                 agent == "codex" ? "HIVE_CODEX_BIN" : "HIVE_CLAUDE_BIN" ]
+        keys.to_h do |key|
+          value = @env[key]
+          [ key, value.nil? ? "absent" : ::Digest::SHA256.hexdigest(value) ]
+        end
+      end
+
+      def version_tuple(value)
+        value.to_s.split(".").map(&:to_i)
+      end
+
+      def digest(value)
+        ::Digest::SHA256.hexdigest(JSON.generate(canonical(value)))
+      end
+
+      def canonical(value)
+        case value
+        when Hash
+          value.keys.map(&:to_s).sort.to_h do |key|
+            child = value.key?(key) ? value[key] : value[key.to_sym]
+            [ key, canonical(child) ]
+          end
+        when Array
+          value.map { |item| canonical(item) }
+        else
+          value
+        end
+      end
+    end
+  end
+end
