--- a/test/unit/daemon/logger_test.rb
+++ b/test/unit/daemon/logger_test.rb
@@ -164,6 +164,25 @@ class HiveDaemonLoggerTest < Minitest::Test
     end
   end
 
+  def test_log_and_rotations_are_owner_only_under_permissive_umask
+    with_tmp_dir do |dir|
+      path = File.join(dir, "logs", "daemon.log")
+      old_umask = File.umask(0)
+      logger = Hive::Daemon::Logger.new(path: path, max_bytes: 1, max_files: 2)
+      logger.event(:tick_begin)
+      logger.event(:tick_end)
+      logger.close
+
+      assert_equal 0o700, File.stat(File.dirname(path)).mode & 0o777
+      ([ path ] + Dir.glob("#{path}.*")).each do |candidate|
+        assert_equal 0o600, File.stat(candidate).mode & 0o777
+      end
+    ensure
+      File.umask(old_umask) if old_umask
+      logger&.close
+    end
+  end
+
