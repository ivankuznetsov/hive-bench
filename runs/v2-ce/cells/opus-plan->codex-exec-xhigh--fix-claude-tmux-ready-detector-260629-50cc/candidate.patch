+require "test_helper"
+require "rubygems/package"
+
+class BuiltGemScriptsTest < Minitest::Test
+  PROJECT_ROOT = File.expand_path("../../..", __dir__)
+  GEMSPEC_PATH = File.join(PROJECT_ROOT, "hive.gemspec")
+  # Deliberate, pinned scope: the plan mandated scanning these two launcher
+  # modules "at minimum" for shipped `scripts/*.sh` references. This is an
+  # explicit allowlist, not a glob of lib/hive/**/*.rb; a future module that
+  # references a new packaged script must be added here so its scripts are
+  # covered too.
+  SCRIPT_REFERENCE_SOURCES = %w[
+    lib/hive/claude_launcher.rb
+    lib/hive/stop_hook_installer.rb
+  ].freeze
+  SCRIPT_REFERENCE_PATTERN = %r{scripts/[\w.-]+\.sh}.freeze
+  # Gem build failures that mean the build environment/tooling is unavailable
+  # (so we degrade to verifying Gem::Specification#files) rather than a real
+  # bug in this test, which must propagate instead of being downgraded to a
+  # skip. `Gem::InvalidSpecificationException` is a `Gem::Exception` but signals
+  # a genuine packaging fault (e.g. a declared `spec.files` entry missing on
+  # disk), so it is re-raised inside the rescue rather than skipped. The errno
+  # list is scoped to the specific tmpdir/tooling failures a sandboxed build
+  # raises; a broader `SystemCallError` could mask a real file-level packaging
+  # fault as a skip.
+  GEM_BUILD_UNAVAILABLE_ERRORS = [
+    Gem::Exception,
+    Errno::ENOENT,  # gem/build tooling or tmpdir path missing
+    Errno::EACCES,  # sandboxed tmpdir not writable
+    Errno::EROFS,   # read-only build sandbox
+    Errno::ENOSPC   # no space to stage the built .gem
+  ].freeze
+
+  def test_built_gem_contains_launcher_referenced_scripts
+    references = launcher_referenced_script_paths
+
+    refute_empty references, "launcher script reference scanner must not pass vacuously"
+
+    contents = built_gem_contents
+    missing = references - contents
+
+    assert_empty missing,
+                 "built gem is missing launcher-referenced scripts: #{missing.join(", ")}"
+
+    # Assertions run first so real coverage is validated even in degraded mode.
+    # If the gem could not actually be built, built_gem_contents fell back to
+    # Gem::Specification#files and recorded a message; surface that as a visible
+    # skip AFTER the assertions so the run reports "validated files, but did not
+    # exercise a real build" rather than silently passing as full coverage.
+    skip @gem_build_error_message if @gem_build_error_message
+  end
+
+  private
+
+  def launcher_referenced_script_paths
+    SCRIPT_REFERENCE_SOURCES.flat_map do |source|
+      source_path = File.join(PROJECT_ROOT, source)
+
+      File.read(source_path).scan(SCRIPT_REFERENCE_PATTERN).map do |script_ref|
+        referenced_path = File.join(File.dirname(source), script_ref)
+        full_path = File.join(PROJECT_ROOT, referenced_path)
+
+        assert File.file?(full_path),
+               "script reference #{script_ref.inspect} in #{source} does not resolve to a source file"
+
+        referenced_path
+      end
+    end.uniq.sort
+  end
+
+  def built_gem_contents
+    spec = Gem::Specification.load(GEMSPEC_PATH)
+
+    Dir.mktmpdir("hive-built-gem") do |dir|
+      gem_path = File.join(dir, "#{spec.full_name}.gem")
+      built_path = nil
+
+      begin
+        Dir.chdir(PROJECT_ROOT) do
+          capture_io do
+            built_path = Gem::Package.build(spec, false, false, gem_path)
+          end
+        end
+
+        return Gem::Package.new(built_path).contents.sort
+      rescue *GEM_BUILD_UNAVAILABLE_ERRORS => e
+        # An invalid gemspec (e.g. a declared-but-missing `spec.files` entry) is
+        # a real packaging fault, not an unavailable build environment — surface
+        # it instead of masking it as a skip via the spec.files fallback.
+        raise if e.is_a?(Gem::InvalidSpecificationException)
+
+        # Only a genuine build-environment/tooling failure degrades to the
+        # spec.files fallback. Any other error class is re-raised (not rescued)
+        # so a real packaging fault is never mislabeled as a skip.
+        @gem_build_error_message =
+          "gem build unavailable (#{e.class}: #{e.message}); verified Gem::Specification#files only"
+        return spec.files.sort
+      end
+    end
+  end
+end
