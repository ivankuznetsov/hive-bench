+
+  def test_charm_tui_i_opens_info_panel_and_close_keys_return_to_grid
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+        project = File.basename(dir)
+        capture_io { Hive::Commands::New.new(project, "smoke probe").call }
+        project_prefix = project[0, 12]
+
+        env = { "TERM" => "xterm-256color", "HIVE_TUI_BACKEND" => "charm" }
+        PTY.spawn(env, "ruby", "-I", HIVE_LIB, HIVE_BIN, "tui") do |reader, writer, pid|
+          reader.winsize = [ 30, 120 ]
+
+          first = read_until(reader, deadline_seconds: 10.0) do |buf|
+            buf.include?(project_prefix) && buf.include?("[?] help  [i] info  [q] quit")
+          end
+          assert_includes first, "[?] help  [i] info  [q] quit"
+
+          writer.write("i")
+          writer.flush
+          info = read_until(reader, deadline_seconds: 5.0) do |buf|
+            buf.include?("INFO") && buf.include?("Original idea") && buf.include?("smoke probe")
+          end
+          assert_includes info, "INFO"
+          assert_includes info, "created_at:"
+          assert_includes info, "smoke probe"
+
+          close_and_reopen_card_info_with(reader, writer, pid, "q")
+          close_and_reopen_card_info_with(reader, writer, pid, "\e")
+          close_and_reopen_card_info_with(reader, writer, pid, "i")
+          writer.write("i")
+          writer.flush
+          assert_nil wait_for_pid_exit(pid, deadline_seconds: 0.5),
+                     "`i` from card info must close to grid, not quit"
+
+          writer.write("q")
+          writer.flush
+          status = wait_for_pid_exit(pid, deadline_seconds: 3.0)
+          refute_nil status, "charm TUI must exit within 3s of pressing 'q' from grid"
+          assert_equal 0, status.exitstatus, "clean quit exits 0"
+        end
+      end
+    end
+  rescue Errno::EIO
+    raise unless $!.message.include?("Input/output error")
+  end
+
+  def close_and_reopen_card_info_with(reader, writer, pid, key)
+    writer.write(key)
+    writer.flush
+    assert_nil wait_for_pid_exit(pid, deadline_seconds: 0.5),
+               "#{key.inspect} from card info must return to grid, not quit"
+
+    sleep 0.1
+    writer.write("i")
+    writer.flush
+    info = read_until(reader, deadline_seconds: 5.0) { |buf| buf.include?("INFO") }
+    assert_includes info, "INFO", "#{key.inspect} must return to grid so `i` can reopen card info"
+  end
 end
