new file mode 100644
index 00000000..fc3db8a9
--- /dev/null
+++ b/lib/hive/tui/views/card_info.rb
@@ -0,0 +1,179 @@
+require "lipgloss"
+require "hive/stages"
+require "hive/tui/log_tail"
+require "hive/tui/styles"
+require "hive/tui/text"
+require "hive/tui/views/format"
+
+module Hive
+  module Tui
+    module Views
+      # Full-screen read-only task detail panel. The TUI has no markdown
+      # renderer; stage files are sanitized and wrapped as plain text,
+      # matching the TUI's other text-only read surfaces.
+      module CardInfo
+        FOOTER = "[q]/[Esc]/[i] close".freeze
+        # Canonical execute stage dir (`4-execute`) from the single source
+        # of truth so the log-tail gate never drifts from the pipeline.
+        EXECUTE_STAGE_DIR = Hive::Stages::SHORT_TO_FULL.fetch("execute").freeze
+
+        module_function
+
+        def render(model)
+          state = model.card_info_state
+          return "" if state.nil?
+
+          header_width = [ model.cols.to_i - 1, 1 ].max
+          outer_width = [ model.cols.to_i - 2, 1 ].max
+          bordered = model.cols.to_i >= 40
+          inner_width = bordered ? [ outer_width - 2, 1 ].max : outer_width
+          body_height = [ model.rows.to_i - 5, 1 ].max
+          content_height = [ body_height - 2, 1 ].max
+
+          body_lines = truncate_overflow(content_lines(state, inner_width), content_height, inner_width)
+          body_lines << ""
+          body_lines << Styles::HINT.render(truncate(FOOTER, inner_width))
+          body = Lipgloss.join_vertical(Lipgloss::TOP, *body_lines)
+          panel = bordered ? Styles::PANE_FOCUSED_BORDER.width(inner_width).render(body) : body
+
+          Lipgloss.join_vertical(Lipgloss::TOP, header_bar(state, header_width), panel)
+        end
+
+        def content_lines(state, width)
+          # The outer header bar (`INFO · slug · stage`) already names the
+          # slug, and `field_lines` repeats it as `slug: …`, so there is no
+          # third "Task info · slug" title line here — it only duplicated
+          # the slug near the top.
+          lines = []
+          lines.concat(field_lines(state, width))
+          lines.concat(original_text_lines(state, width))
+          lines.concat(extra_lines(state, width))
+          lines
+        end
+
+        def field_lines(state, width)
+          [
+            "slug: #{safe(state.row.slug)}",
+            "stage: #{safe(state.row.stage)}",
+            "created_at: #{present_or_dash(state.created_at)}",
+            "working_dir: #{present_or_dash(state.working_dir)}",
+            "latest_log: #{present_or_dash(state.log_path)}"
+          ].map { |line| truncate(line, width) }
+        end
+
+        def original_text_lines(state, width)
+          text = state.original_text.to_s.strip
+          return [] if text.empty?
+
+          [ "", Styles::HEADER.render(truncate("Original idea", width)), *wrapped(text, width) ]
+        end
+
+        def extra_lines(state, width)
+          if prefer_log_tail?(state) && Array(state.log_tail_lines).any?
+            return log_tail_lines(state, width)
+          end
+          body = state.stage_file_body.to_s.strip
+          return [] if body.empty?
+
+          title = "Stage file · #{File.basename(state.stage_file_path.to_s)}"
+          [ "", Styles::HEADER.render(truncate(title, width)), *wrapped(body, width) ]
+        end
+
+        # The log tail is the execute/running extra only (plan Unit-3, A3);
+        # every other stage renders its canonical state file inline (A2),
+        # even when a prior agent run left logs under the task folder. Gate
+        # on the row's stage/status so a brainstorm/plan card with stale
+        # logs still shows `brainstorm.md`/`plan.md` rather than the tail.
+        def prefer_log_tail?(state)
+          prefer_log_tail_for_row?(state.row)
+        end
+
+        # Row-level split of `prefer_log_tail?` so the model layer
+        # (BubbleModel#open_card_info) can gate its tail-line read to the
+        # same execute/running rows the view renders it for, without
+        # duplicating the stage/status predicate and risking drift.
+        def prefer_log_tail_for_row?(row)
+          row.stage.to_s == EXECUTE_STAGE_DIR || row.action_key.to_s == "agent_running"
+        end
+
+        def log_tail_lines(state, width)
+          title = "Latest log tail · #{File.basename(state.log_path.to_s)}"
+          lines = Array(state.log_tail_lines).map do |line|
+            truncate(safe(Hive::Tui::LogTail::Formatter.format(line)), width)
+          end
+          [ "", Styles::HEADER.render(truncate(title, width)), *lines ]
+        end
+
+        def truncate_overflow(lines, height, width)
+          return lines if lines.length <= height
+
+          visible = lines.first(height)
+          visible[-1] = overflow_line(visible[-1], width)
+          visible
+        end
+
+        def overflow_line(line, width)
+          return "" if width.to_i <= 0
+          return "…" if width.to_i == 1
+
+          # Strip ANSI/control bytes before slicing: the last visible line
+          # can be a Lipgloss-styled header, and a raw byte cut at
+          # `width - 1` would split an escape sequence mid-stream on a real
+          # tty (the test env strips ANSI, so it never surfaces there).
+          # Sanitising first guarantees the slice lands on a plain-text
+          # boundary.
+          "#{safe(line)[0, width.to_i - 1]}…"
+        end
+
+        def header_bar(state, width)
+          row = state.row
+          text = "INFO · #{safe(row.slug)} · #{safe(row.stage)}"
+          Styles::HEADER.render(truncate(text, width))
+        end
+
+        def wrapped(text, width)
+          # Split on real newlines FIRST, then sanitize each line: sanitising
+          # the whole blob up front would map every 0x0A to `?` (see
+          # Text.sanitize) and collapse multi-line markdown like
+          # "# Plan\n\nDo work" into "# Plan??Do work" instead of readable
+          # per-line plain text.
+          text.to_s.lines.flat_map { |line| wrap_line(safe(line.chomp), width) }
+        end
+
+        def wrap_line(line, width)
+          return [ "" ] if line.empty?
+          return [ truncate(line, width) ] if width <= 8
+
+          words = line.split(/\s+/)
+          rows = []
+          current = +""
+          words.each do |word|
+            if current.empty?
+              current = word
+            elsif "#{current} #{word}".length <= width
+              current << " " << word
+            else
+              rows << truncate(current, width)
+              current = word
+            end
+          end
+          rows << truncate(current, width) unless current.empty?
+          rows
+        end
+
+        def present_or_dash(value)
+          text = safe(value).strip
+          text.empty? ? "-" : text
+        end
+
+        def safe(value)
+          Hive::Tui::Text.sanitize(value.to_s)
+        end
+
+        def truncate(string, width)
+          Views::Format.truncate(string, width)
+        end
+      end
+    end
+  end
+end
