diff --git a/test/unit/tui/views/card_info_test.rb b/test/unit/tui/views/card_info_test.rb
new file mode 100644
index 00000000..7bb2da89
--- /dev/null
+++ b/test/unit/tui/views/card_info_test.rb
@@ -0,0 +1,139 @@
+require "test_helper"
+require "hive/tui/model"
+require "hive/tui/snapshot"
+require "hive/tui/views/card_info"
+
+class HiveTuiViewsCardInfoTest < Minitest::Test
+  def row(stage: "2-brainstorm", slug: "info-card", worktree_path: "/tmp/info-card-worktree")
+    folder = "/tmp/demo/.hive-state/stages/#{stage}/#{slug}"
+    Hive::Tui::Snapshot::Row.new(
+      project_name: "demo",
+      stage: stage,
+      slug: slug,
+      folder: folder,
+      worktree_path: worktree_path,
+      state_file: File.join(folder, "brainstorm.md"),
+      marker: "waiting",
+      attrs: {},
+      mtime: nil,
+      age_seconds: 0,
+      claude_pid: nil,
+      claude_pid_alive: nil,
+      action_key: "needs_input",
+      action_label: "Needs input",
+      suggested_command: nil,
+      next_action: nil,
+      diagnostic: nil
+    )
+  end
+
+  def model_for(state, cols: 100, rows: 24)
+    Hive::Tui::Model.initial.with(mode: :card_info, card_info_state: state, cols: cols, rows: rows)
+  end
+
+  def state_for(**overrides)
+    defaults = {
+      row: row,
+      created_at: "2026-05-20T00:00:00Z",
+      original_text: "Build a task info panel for the TUI.",
+      working_dir: "/tmp/info-card-worktree",
+      log_path: "/tmp/demo/.hive-state/logs/info-card/execute.log",
+      stage_file_path: "/tmp/demo/.hive-state/stages/2-brainstorm/info-card/brainstorm.md",
+      stage_file_body: "# Brainstorm\n\nRequirements and constraints.",
+      log_tail_lines: []
+    }
+    Hive::Tui::Model::CardInfoState.new(**defaults.merge(overrides))
+  end
+
+  def test_renders_common_fields_and_stage_file_body
+    output = Hive::Tui::Views::CardInfo.render(model_for(state_for))
+
+    assert_includes output, "INFO · info-card · 2-brainstorm"
+    assert_includes output, "slug: info-card"
+    assert_includes output, "stage: 2-brainstorm"
+    assert_includes output, "created_at: 2026-05-20T00:00:00Z"
+    assert_includes output, "working_dir: /tmp/info-card-worktree"
+    assert_includes output, "latest_log: /tmp/demo/.hive-state/logs/info-card/execute.log"
+    assert_includes output, "Original idea"
+    assert_includes output, "Build a task info panel"
+    assert_includes output, "Stage file · brainstorm.md"
+    assert_includes output, "Requirements and constraints."
+    assert_includes output, "[q]/[Esc]/[i] close"
+  end
+
+  def test_log_tail_takes_precedence_over_stage_file_body_for_execute_rows
+    state = state_for(row: row(stage: "4-execute"), log_tail_lines: [ "line-1", "line-2" ])
+    output = Hive::Tui::Views::CardInfo.render(model_for(state))
+
+    assert_includes output, "Latest log tail · execute.log"
+    assert_includes output, "line-1"
+    assert_includes output, "line-2"
+    refute_includes output, "Stage file · brainstorm.md"
+  end
+
+  def test_log_tail_takes_precedence_for_running_rows
+    running = row(stage: "2-brainstorm")
+    running = Hive::Tui::Snapshot::Row.new(**running.to_h.merge(action_key: "agent_running"))
+    state = state_for(row: running, log_tail_lines: [ "line-1", "line-2" ])
+    output = Hive::Tui::Views::CardInfo.render(model_for(state))
+
+    assert_includes output, "Latest log tail · execute.log"
+    refute_includes output, "Stage file · brainstorm.md"
+  end
+
+  # Regression: a non-execute, non-running card (brainstorm/plan) whose
+  # stage agent already ran has logs on disk, but `i` must still render
+  # its canonical stage file inline (acceptance A2), NOT the log tail.
+  def test_non_execute_row_with_logs_still_renders_stage_file
+    state = state_for(log_tail_lines: [ "line-1", "line-2" ])
+    output = Hive::Tui::Views::CardInfo.render(model_for(state))
+
+    assert_includes output, "Stage file · brainstorm.md"
+    assert_includes output, "Requirements and constraints."
+    refute_includes output, "Latest log tail"
+  end
+
+  # Regression: multi-line stage/idea bodies must wrap as separate visible
+  # lines, not collapse newlines into `?` (Text.sanitize maps 0x0A→`?`).
+  def test_multiline_stage_body_preserves_line_breaks
+    state = state_for(stage_file_body: "# Plan\n\nDo work")
+    output = Hive::Tui::Views::CardInfo.render(model_for(state))
+
+    refute_includes output, "# Plan??Do work"
+    assert_includes output, "# Plan"
+    assert_includes output, "Do work"
+    assert output.lines.any? { |line| line.include?("# Plan") && !line.include?("Do work") },
+           "the heading and body must render on separate lines"
+  end
+
+  def test_inbox_state_omits_extras_section_when_body_is_nil
+    state = state_for(
+      row: row(stage: "1-inbox"),
+      stage_file_path: "/tmp/demo/.hive-state/stages/1-inbox/info-card/idea.md",
+      stage_file_body: nil,
+      log_tail_lines: []
+    )
+    output = Hive::Tui::Views::CardInfo.render(model_for(state))
+
+    refute_includes output, "Stage file"
+    refute_includes output, "Latest log tail"
+    assert_includes output, "Original idea"
+  end
+
+  def test_narrow_terminal_renders_without_border
+    output = Hive::Tui::Views::CardInfo.render(model_for(state_for, cols: 36, rows: 12))
+
+    assert_includes output, "INFO · info-card"
+    assert_includes output, "slug: info-card"
+    refute_match(/[╭╮╰╯]/, output)
+  end
+
+  def test_overlong_content_is_truncated_with_ellipsis
+    long_body = (1..40).map { |i| "section line #{i}" }.join("\n")
+    state = state_for(stage_file_body: long_body, original_text: "short")
+    output = Hive::Tui::Views::CardInfo.render(model_for(state, cols: 80, rows: 12))
+
+    assert output.lines.any? { |line| line.chomp.delete("│").rstrip.end_with?("…") },
+           "overflowing card info content must end a visible line with an ellipsis"
+  end
+end
