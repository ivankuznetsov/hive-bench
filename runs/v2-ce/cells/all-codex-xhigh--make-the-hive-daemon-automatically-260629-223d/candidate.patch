@@ -0,0 +1,483 @@
+require "test_helper"
+require "fileutils"
+require "json"
+require "shellwords"
+require "tmpdir"
+require "hive/daemon/auto_retry"
+require "hive/daemon/dispatcher"
+require "hive/daemon/concurrency_controller"
+require "hive/daemon/dispatch_request_queue"
+require "hive/daemon/logger"
+
+class DaemonAutoRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  Row = Hive::Daemon::StatusConsumer::Row
+  ProjectInfo = Hive::Daemon::StatusConsumer::ProjectInfo
+  ChildExit = Hive::Daemon::ChildSupervisor::ChildExit
+  T0 = Time.utc(2026, 7, 1, 12, 0, 0)
+
+  class FakeStatusConsumer
+    attr_accessor :rows
+
+    def initialize(project:)
+      @project = project
+      @rows = []
+    end
+
+    def fetch
+      Hive::Daemon::StatusConsumer::Result.new(
+        ok: true,
+        rows: @rows,
+        projects: [ ProjectInfo.new(name: @project, legacy_stage_dirs: []) ],
+        error: nil
+      )
+    end
+  end
+
+  class FakeSupervisor
+    attr_reader :spawned
+    attr_accessor :reap_queue
+
+    def initialize
+      @spawned = []
+      @reap_queue = []
+      @next_pid = 2000
+    end
+
+    def spawn(command_string:, project:, slug:, stage:,
+              hive_state_path: nil, state_file_path: nil, dry_run: nil, request_id: nil)
+      pid = @next_pid
+      @next_pid += 1
+      @spawned << {
+        pid: pid,
+        command: command_string,
+        project: project,
+        slug: slug,
+        stage: stage,
+        request_id: request_id,
+        state_file_path: state_file_path
+      }
+      pid
+    end
+
+    def reap_all(now: Time.now)
+      out = @reap_queue
+      @reap_queue = []
+      out
+    end
+
+    def reap_dry_run(now: Time.now) = []
+    def terminate_all(grace_sec: 600); end
+    def update_timeouts(**); end
+    def enforce_timeouts(now:) = []
+    def in_flight_count = @spawned.size
+  end
+
+  class FakeLogger
+    attr_reader :events
+
+    def initialize
+      @events = []
+    end
+
+    def event(name, **attrs)
+      unless Hive::Daemon::Logger::EVENTS.include?(name)
+        raise ArgumentError, "unknown daemon log event in test: #{name.inspect}"
+      end
+
+      @events << [ name, attrs ]
+    end
+
+    def close; end
+  end
+
+  class FakeProbeCache
+    attr_reader :calls
+
+    def initialize(sets)
+      @sets = sets
+      @calls = []
+    end
+
+    def probe(recovery_type)
+      @calls << recovery_type
+      @sets.fetch(recovery_type)
+    end
+  end
+
+  class FakeSafetyGuard
+    attr_reader :calls
+
+    def initialize(result)
+      @result = result
+      @calls = 0
+    end
+
+    def safe?(_row)
+      @calls += 1
+      @result
+    end
+  end
+
+  def setup
+    @root = Dir.mktmpdir("hive-auto-retry-project")
+    @state_home = Dir.mktmpdir("hive-auto-retry-state")
+    @project = "proj"
+    @hive_state = File.join(@root, ".hive-state")
+    FileUtils.mkdir_p(File.join(@hive_state, "stages"))
+    @status = FakeStatusConsumer.new(project: @project)
+    @supervisor = FakeSupervisor.new
+    @logger = FakeLogger.new
+    @controller = Hive::Daemon::ConcurrencyController.new(
+      max_concurrent_runs: 5,
+      max_concurrent_per_project: 5,
+      max_runs_per_day_per_project: 100
+    )
+    @original_find_project = Hive::Config.method(:find_project)
+    root = @root
+    hive_state = @hive_state
+    project = @project
+    Hive::Config.define_singleton_method(:find_project) do |name|
+      next nil unless name == project
+
+      { "name" => project, "path" => root, "hive_state_path" => hive_state }
+    end
+  end
+
+  def teardown
+    Hive::Config.define_singleton_method(:find_project, @original_find_project) if @original_find_project
+    FileUtils.remove_entry(@root) if @root && File.exist?(@root)
+    FileUtils.remove_entry(@state_home) if @state_home && File.exist?(@state_home)
+  end
+
+  def test_codex_auth_marker_clears_then_requeues_same_stage
+    slug = "codex-auth-260701-abcd"
+    row = task_row(
+      slug: slug,
+      stage: "4-execute",
+      state_filename: "task.md",
+      reason: "implementer_failed",
+      marker_id: "err-codex",
+      diagnostic: "Codex request failed: HTTP 401 missing bearer auth"
+    )
+    dispatcher = dispatcher_with_engine(
+      probe_cache: probe_cache("codex_auth_recovery" => healthy_probe_set("fp-codex", "codex_auth_recovery"))
+    )
+    @status.rows = [ row ]
+
+    dispatcher.tick(now: T0)
+
+    assert_equal 1, @supervisor.spawned.size
+    clear_spawn = @supervisor.spawned.first
+    assert_equal Shellwords.join([
+      "hive", "markers", "clear", slug,
+      "--name", "ERROR", "--project", @project, "--json",
+      "--match-attr", "marker_id=err-codex,reason=implementer_failed"
+    ]),
+                 clear_spawn.fetch(:command)
+    assert_auto_retry_event(slug, "retry_enqueued", "codex_auth_recovery")
+
+    @status.rows = []
+    @supervisor.reap_queue = [
+      child_exit(clear_spawn, exit_code: 0, command: clear_spawn.fetch(:command))
+    ]
+    dispatcher.tick(now: T0 + 60)
+
+    assert_equal 2, @supervisor.spawned.size
+    assert_equal "hive run #{slug} --project #{@project} --stage 4-execute --json",
+                 @supervisor.spawned.last.fetch(:command)
+  end
+
+  def test_claude_launcher_marker_clears_then_requeues_same_stage
+    slug = "claude-launch-260701-abcd"
+    row = task_row(
+      slug: slug,
+      stage: "3-plan",
+      state_filename: "plan.md",
+      reason: "claude_launch_failed",
+      marker_id: "err-claude",
+      diagnostic: "interactive prompt did not become ready; readiness detector timed out"
+    )
+    dispatcher = dispatcher_with_engine(
+      probe_cache: probe_cache(
+        "claude_launcher_recovery" => healthy_probe_set("fp-claude", "claude_launcher_recovery")
+      )
+    )
+    @status.rows = [ row ]
+
+    dispatcher.tick(now: T0)
+
+    clear_spawn = @supervisor.spawned.first
+    assert_equal Shellwords.join([
+      "hive", "markers", "clear", slug,
+      "--name", "ERROR", "--project", @project, "--json",
+      "--match-attr", "marker_id=err-claude,reason=claude_launch_failed"
+    ]),
+                 clear_spawn.fetch(:command)
+    assert_auto_retry_event(slug, "retry_enqueued", "claude_launcher_recovery")
+
+    @status.rows = []
+    @supervisor.reap_queue = [
+      child_exit(clear_spawn, exit_code: 0, command: clear_spawn.fetch(:command))
+    ]
+    dispatcher.tick(now: T0 + 60)
+
+    assert_equal "hive run #{slug} --project #{@project} --stage 3-plan --json",
+                 @supervisor.spawned.last.fetch(:command)
+  end
+
+  def test_unknown_and_excluded_failures_remain_parked
+    slug = "unknown-failure-260701-abcd"
+    row = task_row(
+      slug: slug,
+      stage: "4-execute",
+      state_filename: "task.md",
+      reason: "implementer_failed",
+      marker_id: "err-unknown",
+      diagnostic: "tests failed with exit_code=1"
+    )
+    probes = probe_cache("codex_auth_recovery" => healthy_probe_set("fp-unused", "codex_auth_recovery"))
+    dispatcher = dispatcher_with_engine(probe_cache: probes)
+    @status.rows = [ row ]
+
+    dispatcher.tick(now: T0)
+
+    assert_empty @supervisor.spawned
+    assert_empty probes.calls
+    assert_auto_retry_event(slug, "not_retried", nil)
+  end
+
+  def test_safety_or_probe_failure_keeps_marker_parked
+    unsafe_slug = "unsafe-260701-abcd"
+    unsafe_row = task_row(
+      slug: unsafe_slug,
+      stage: "4-execute",
+      state_filename: "task.md",
+      reason: "implementer_failed",
+      marker_id: "err-unsafe",
+      diagnostic: "Codex request failed: HTTP 401 missing bearer auth"
+    )
+    unsafe_dispatcher = dispatcher_with_engine(
+      probe_cache: probe_cache("codex_auth_recovery" => healthy_probe_set("fp-safe", "codex_auth_recovery")),
+      safety_guard: FakeSafetyGuard.new(safety_result(false, "dirty worktree"))
+    )
+    @status.rows = [ unsafe_row ]
+
+    unsafe_dispatcher.tick(now: T0)
+
+    assert_empty @supervisor.spawned
+    assert_auto_retry_event(unsafe_slug, "not_retried", "codex_auth_recovery")
+
+    probe_slug = "probe-fail-260701-abcd"
+    @status.rows = [
+      task_row(
+        slug: probe_slug,
+        stage: "4-execute",
+        state_filename: "task.md",
+        reason: "implementer_failed",
+        marker_id: "err-probe",
+        diagnostic: "Codex request failed: HTTP 401 missing bearer auth"
+      )
+    ]
+    dispatcher = dispatcher_with_engine(
+      probe_cache: probe_cache("codex_auth_recovery" => failed_probe_set("fp-red", "doctor red"))
+    )
+
+    dispatcher.tick(now: T0 + 60)
+
+    assert_empty @supervisor.spawned
+    assert_auto_retry_event(probe_slug, "not_retried", "codex_auth_recovery")
+  end
+
+  def test_retry_controls_and_kill_switch_keep_marker_parked
+    exhausted_slug = "exhausted-260701-abcd"
+    row = task_row(
+      slug: exhausted_slug,
+      stage: "4-execute",
+      state_filename: "task.md",
+      reason: "implementer_failed",
+      marker_id: "err-exhausted",
+      diagnostic: "Codex request failed: HTTP 401 missing bearer auth"
+    )
+    2.times do |index|
+      Hive::Events.emit(
+        task_folder: row.folder,
+        slug: exhausted_slug,
+        stage: "4-execute",
+        event_type: :auto_retry_decision,
+        message: "retry",
+        details: {
+          "timestamp" => (T0 - 3600 + index).utc.iso8601,
+          "action" => "retry_enqueued",
+          "stage" => "4-execute",
+          "reason" => "implementer_failed",
+          "health_fingerprint" => "fp-#{index}"
+        }
+      )
+    end
+    probes = probe_cache("codex_auth_recovery" => healthy_probe_set("fp-new", "codex_auth_recovery"))
+    dispatcher = dispatcher_with_engine(probe_cache: probes)
+    @status.rows = [ row ]
+
+    dispatcher.tick(now: T0)
+
+    assert_empty @supervisor.spawned
+    assert_empty probes.calls
+    assert_auto_retry_event(exhausted_slug, "not_retried", "codex_auth_recovery")
+
+    kill_slug = "kill-switch-260701-abcd"
+    kill_row = task_row(
+      slug: kill_slug,
+      stage: "4-execute",
+      state_filename: "task.md",
+      reason: "implementer_failed",
+      marker_id: "err-kill",
+      diagnostic: "Codex request failed: HTTP 401 missing bearer auth"
+    )
+    kill_probes = probe_cache("codex_auth_recovery" => healthy_probe_set("fp-kill", "codex_auth_recovery"))
+    kill_dispatcher = dispatcher_with_engine(
+      probe_cache: kill_probes,
+      daemon_cfg: { "auto_retry" => { "enabled" => false } }
+    )
+    @status.rows = [ kill_row ]
+
+    kill_dispatcher.tick(now: T0 + 60)
+
+    assert_empty @supervisor.spawned
+    assert_empty kill_probes.calls
+    assert_empty auto_retry_events(kill_row.folder)
+  end
+
+  private
+
+  def dispatcher_with_engine(probe_cache:, safety_guard: FakeSafetyGuard.new(safety_result(true, "safe")),
+                             daemon_cfg: {})
+    engine = Hive::Daemon::AutoRetry::DecisionEngine.new(
+      probe_cache: probe_cache,
+      safety_guard: safety_guard,
+      request_queue: Hive::Daemon::DispatchRequestQueue,
+      state_home: @state_home,
+      logger: @logger,
+      controller: @controller
+    )
+    Hive::Daemon::Dispatcher.new(
+      config: {
+        "daemon" => {
+          "edit_debounce_sec" => 30,
+          "poll_interval_sec" => 30,
+          "shutdown_grace_sec" => 60
+        }.merge(daemon_cfg)
+      },
+      controller: @controller,
+      supervisor: @supervisor,
+      status_consumer: @status,
+      logger: @logger,
+      dispatch_request_state_home: @state_home,
+      auto_retry_engine: engine
+    ).tap do |dispatcher|
+      dispatcher.define_singleton_method(:project_enabled?) { |_| true }
+    end
+  end
+
+  def task_row(slug:, stage:, state_filename:, reason:, marker_id:, diagnostic:)
+    folder = File.join(@hive_state, "stages", stage, slug)
+    FileUtils.mkdir_p(folder)
+    state_file = File.join(folder, state_filename)
+    File.write(state_file, "# #{slug}\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} -->\n")
+    Row.new(
+      project: @project,
+      slug: slug,
+      stage: stage,
+      marker: "error",
+      marker_attrs: {
+        "reason" => reason,
+        "marker_id" => marker_id,
+        "message" => diagnostic
+      },
+      folder: folder,
+      state_file: state_file,
+      state_file_mtime: File.mtime(state_file),
+      action: "error",
+      suggested_command: "hive run #{slug}",
+      claude_pid_alive: nil,
+      live_task_lock: false,
+      diagnostic: {
+        "summary" => diagnostic,
+        "detail" => diagnostic
+      }
+    )
+  end
+
+  def child_exit(spawn, exit_code:, command:)
+    ChildExit.new(
+      pid: spawn.fetch(:pid),
+      exit_code: exit_code,
+      project: spawn.fetch(:project),
+      slug: spawn.fetch(:slug),
+      stage: nil,
+      command: command,
+      state_file_path: spawn[:state_file_path],
+      started_at: T0,
+      finished_at: T0 + 1,
+      json_envelope: nil,
+      request_id: spawn.fetch(:request_id)
+    )
+  end
+
+  def probe_cache(sets)
+    FakeProbeCache.new(sets)
+  end
+
+  def healthy_probe_set(fingerprint, recovery_type)
+    Hive::Daemon::AutoRetry::ProbeSet.new(
+      recovery_type: recovery_type,
+      probes: [
+        Hive::Daemon::AutoRetry::ProbeResult.new(
+          name: "hive_doctor",
+          status: "pass",
+          rationale: "doctor green"
+        )
+      ],
+      health_fingerprint: fingerprint
+    )
+  end
+
+  def failed_probe_set(fingerprint, rationale)
+    Hive::Daemon::AutoRetry::ProbeSet.new(
+      recovery_type: "codex_auth_recovery",
+      probes: [
+        Hive::Daemon::AutoRetry::ProbeResult.new(
+          name: "hive_doctor",
+          status: "fail",
+          rationale: rationale
+        )
+      ],
+      health_fingerprint: fingerprint
+    )
+  end
+
+  def safety_result(safe, rationale)
+    Hive::Daemon::AutoRetry::SafetyResult.new(safe: safe, rationale: rationale, details: {})
+  end
+
+  def auto_retry_events(folder)
+    path = File.join(folder, "events.jsonl")
+    return [] unless File.exist?(path)
+
+    File.readlines(path, chomp: true).map { |line| JSON.parse(line) }
+        .select { |event| event["event_type"] == "auto_retry_decision" }
+  end
+
+  def assert_auto_retry_event(slug, action, recovery_type)
+    event = @logger.events.find do |name, attrs|
+      name == :auto_retry_decision && attrs[:slug] == slug && attrs[:action] == action
+    end
+    refute_nil event, "expected auto_retry_decision #{action} for #{slug}, got #{@logger.events.inspect}"
+    if recovery_type.nil?
+      assert_nil event[1][:recovery_type]
+    else
+      assert_equal recovery_type, event[1][:recovery_type]
+    end
+  end
+end
