@@ -0,0 +1,1263 @@
+require "digest"
+require "json"
+require "open3"
+require "stringio"
+require "timeout"
+require "time"
+require "hive/agent_profiles"
+require "hive/claude_launcher"
+require "hive/config"
+require "hive/commands/doctor"
+require "hive/daemon/dispatch_request_queue"
+require "hive/events"
+require "hive/invoked_binary"
+require "hive/markers"
+require "hive/task"
+require "hive/worktree"
+
+module Hive
+  module Daemon
+    # Conservative daemon-side retry helper for parked terminal markers.
+    # The decision engine is built in small pieces in this module so the
+    # safety-relevant logic stays unit-testable without forking the daemon.
+    module AutoRetry
+      MAX_ATTEMPTS = 2
+      SECOND_RETRY_BACKOFF_SEC = 30 * 60
+
+      AUTO_RETRY_EVENT_TYPE = "auto_retry_decision".freeze
+      RETRY_ENQUEUED_ACTION = "retry_enqueued".freeze
+
+      SECRET_KEY_RE = /(authorization|bearer|token|secret|password|credential|api[_-]?key|access[_-]?key)/i.freeze
+      SECRET_VALUE_RES = [
+        /\bBearer\s+[A-Za-z0-9._~+\/=-]+/i,
+        /\bBasic\s+[A-Za-z0-9._~+\/=-]+/i,
+        /\b(?:sk|gh[opsu]?)_[A-Za-z0-9_=-]{12,}/i
+      ].freeze
+      REDACTED = "[REDACTED]".freeze
+
+      EXCLUDED_FAILURE_PATTERNS = [
+        /test(s)?\s+fail/i,
+        /failing\s+test/i,
+        /business[\s-]?logic/i,
+        /review\s+finding/i,
+        /merge\s+conflict/i,
+        /dirty\s+worktree/i,
+        /exit_code\s*=?\s*1/i
+      ].freeze
+
+      CODEX_AUTH_401_RE = /\b(?:http\s*)?401\b/i.freeze
+      CODEX_AUTH_DETAIL_RE = /
+        missing\s+(?:bearer|basic)(?:\s+auth(?:entication)?)?|
+        bearer\s+auth|
+        basic\s+auth
+      /ix.freeze
+      CLAUDE_LAUNCH_RE = /
+        launcher|
+        wrapper|
+        readiness|
+        ready\s+detector|
+        interactive\s+prompt\s+did\s+not\s+become\s+ready|
+        active\s+(?:daemon\s+)?binary\s+mismatch|
+        HIVE_CLAUDE_BIN|
+        NoServerRunning
+      /ix.freeze
+
+      Classification = Struct.new(:recovery_type, :rationale, keyword_init: true) do
+        def recoverable?
+          !recovery_type.nil?
+        end
+      end
+
+      CommandResult = Struct.new(
+        :exitstatus,
+        :stdout,
+        :stderr,
+        :duration,
+        :timed_out,
+        :error,
+        keyword_init: true
+      ) do
+        def success?
+          !timed_out && error.nil? && exitstatus == 0
+        end
+      end
+
+      ProbeResult = Struct.new(
+        :name,
+        :status,
+        :duration,
+        :stdout,
+        :stderr,
+        :rationale,
+        :metadata,
+        keyword_init: true
+      ) do
+        def pass?
+          status.to_s == "pass"
+        end
+
+        def to_h
+          {
+            "name" => name,
+            "status" => status,
+            "duration" => duration,
+            "stdout" => stdout,
+            "stderr" => stderr,
+            "rationale" => rationale,
+            "metadata" => metadata || {}
+          }
+        end
+      end
+
+      ProbeSet = Struct.new(:recovery_type, :probes, :health_fingerprint, keyword_init: true) do
+        def healthy?
+          Array(probes).all?(&:pass?)
+        end
+
+        def to_h
+          {
+            "recovery_type" => recovery_type,
+            "healthy" => healthy?,
+            "health_fingerprint" => health_fingerprint,
+            "probes" => Array(probes).map(&:to_h)
+          }
+        end
+      end
+
+      SafetyResult = Struct.new(:safe, :rationale, :details, keyword_init: true) do
+        def safe?
+          safe == true
+        end
+
+        def to_h
+          {
+            "safe" => safe?,
+            "rationale" => rationale,
+            "details" => details || {}
+          }
+        end
+      end
+
+      DecisionResult = Struct.new(
+        :task,
+        :stage,
+        :marker_id,
+        :reason,
+        :recovery_type,
+        :action,
+        :rationale,
+        :attempt_count,
+        :health_fingerprint,
+        :classification,
+        :probe_set,
+        :safety,
+        :request_id,
+        :details,
+        keyword_init: true
+      ) do
+        def retry_enqueued?
+          action.to_s == RETRY_ENQUEUED_ACTION
+        end
+      end
+
+      GitStatus = Struct.new(:ok, :porcelain, :merge_state, :error, keyword_init: true) do
+        def ok?
+          ok == true
+        end
+      end
+
+      class ShellCommandRunner
+        def run(argv, timeout:, env: {})
+          start = Time.now
+          stdout = +""
+          stderr = +""
+          wait_thread = nil
+          out_thread = nil
+          err_thread = nil
+
+          Open3.popen3(env, *argv) do |stdin, out, err, wait|
+            wait_thread = wait
+            stdin.close
+            out_thread = Thread.new { out.read.to_s }
+            err_thread = Thread.new { err.read.to_s }
+
+            unless wait.join(timeout)
+              terminate_process(wait.pid)
+              stdout = join_reader(out_thread)
+              stderr = join_reader(err_thread)
+              return CommandResult.new(
+                exitstatus: nil,
+                stdout: stdout,
+                stderr: stderr,
+                duration: Time.now - start,
+                timed_out: true,
+                error: nil
+              )
+            end
+
+            stdout = join_reader(out_thread)
+            stderr = join_reader(err_thread)
+            CommandResult.new(
+              exitstatus: wait.value.exitstatus,
+              stdout: stdout,
+              stderr: stderr,
+              duration: Time.now - start,
+              timed_out: false,
+              error: nil
+            )
+          end
+        rescue SystemCallError => e
+          CommandResult.new(
+            exitstatus: nil,
+            stdout: stdout.to_s,
+            stderr: stderr.to_s,
+            duration: Time.now - start,
+            timed_out: false,
+            error: "#{e.class}: #{e.message}"
+          )
+        ensure
+          out_thread&.kill if out_thread&.alive?
+          err_thread&.kill if err_thread&.alive?
+          wait_thread&.kill if wait_thread&.alive?
+        end
+
+        private
+
+        def terminate_process(pid)
+          Process.kill("TERM", pid)
+          sleep 0.2
+          Process.kill("KILL", pid)
+        rescue Errno::ESRCH, Errno::EPERM
+          nil
+        end
+
+        def join_reader(thread)
+          thread.join(1)
+          thread.value.to_s
+        rescue StandardError
+          ""
+        end
+      end
+
+      class ProbeCache
+        def initialize(runner)
+          @runner = runner
+          @cache = {}
+        end
+
+        def probe(recovery_type)
+          @cache[recovery_type.to_s] ||= @runner.probe(recovery_type.to_s)
+        end
+      end
+
+      class ProbeRunner
+        CODEX_LOGIN_TIMEOUT_SEC = 10
+        CODEX_SMOKE_TIMEOUT_SEC = 30
+        HIVE_VERSION_TIMEOUT_SEC = 10
+        OUTPUT_SNIPPET_BYTES = 2 * 1024
+
+        def initialize(project_root:, cfg: {}, command_runner: ShellCommandRunner.new,
+                       hive_bin: ENV.fetch("HIVE_BIN", "hive"), env: ENV.to_h,
+                       doctor_probe: nil, tmux_probe: nil, active_binary_probe: nil,
+                       wrapper_path: nil)
+          @project_root = project_root
+          @cfg = cfg || {}
+          @command_runner = command_runner
+          @hive_bin = hive_bin
+          @env = env || {}
+          @doctor_probe = doctor_probe
+          @tmux_probe = tmux_probe
+          @active_binary_probe = active_binary_probe
+          @wrapper_path = wrapper_path || File.expand_path("../scripts/interactive_claude_wrapper.sh", __dir__)
+          @universal_result = nil
+        end
+
+        def probe(recovery_type)
+          case recovery_type.to_s
+          when "codex_auth_recovery"
+            codex_auth_probe_set
+          when "claude_launcher_recovery"
+            claude_launcher_probe_set
+          else
+            probes = [ probe_result("auto_retry_recovery_type", "fail", rationale: "unknown recovery type") ]
+            build_probe_set(recovery_type.to_s, probes, {})
+          end
+        end
+
+        private
+
+        def codex_auth_probe_set
+          probes = [ universal_doctor_probe ]
+          unless probes.first.pass?
+            return build_probe_set("codex_auth_recovery", probes, "doctor" => probes.first.to_h)
+          end
+
+          login = command_probe(
+            "codex_login_status",
+            [ agent_bin("codex"), "login", "status" ],
+            timeout: CODEX_LOGIN_TIMEOUT_SEC
+          )
+          smoke = if login.pass?
+                    command_probe(
+                      "codex_exec_smoke",
+                      [ agent_bin("codex"), "exec", "--skip-git-repo-check", "echo hive-auto-retry-smoke" ],
+                      timeout: CODEX_SMOKE_TIMEOUT_SEC
+                    )
+          else
+                    probe_result("codex_exec_smoke", "fail", rationale: "skipped because codex login status failed")
+          end
+          probes.concat([ login, smoke ])
+          build_probe_set(
+            "codex_auth_recovery",
+            probes,
+            "doctor" => probes.first.to_h,
+            "codex_login" => login.to_h,
+            "codex_smoke" => smoke.to_h
+          )
+        end
+
+        def claude_launcher_probe_set
+          probes = [ universal_doctor_probe ]
+          unless probes.first.pass?
+            return build_probe_set("claude_launcher_recovery", probes, "doctor" => probes.first.to_h)
+          end
+
+          wrapper = wrapper_probe
+          ready = ready_detector_probe
+          binary = active_binary_version_probe
+          probes.concat([ wrapper, ready, binary ])
+          build_probe_set(
+            "claude_launcher_recovery",
+            probes,
+            "doctor" => probes.first.to_h,
+            "wrapper" => wrapper.to_h,
+            "ready_detector" => ready.to_h,
+            "active_binary" => binary.to_h
+          )
+        end
+
+        def universal_doctor_probe
+          @universal_result ||= begin
+            if @doctor_probe
+              normalize_probe("hive_doctor", @doctor_probe.call)
+            else
+              out = StringIO.new
+              start = Time.now
+              exit_code = Hive::Commands::Doctor.new(
+                config: @cfg,
+                project_root: @project_root,
+                json: true,
+                output: out
+              ).call
+              status = exit_code.zero? ? "pass" : "fail"
+              probe_result("hive_doctor", status,
+                           duration: Time.now - start,
+                           stdout: out.string,
+                           rationale: exit_code.zero? ? "doctor passed" : "doctor exited #{exit_code}")
+            end
+          rescue StandardError => e
+            probe_result("hive_doctor", "error", rationale: "#{e.class}: #{e.message}")
+          end
+        end
+
+        def wrapper_probe
+          unless File.file?(@wrapper_path) && File.executable?(@wrapper_path)
+            return probe_result(
+              "claude_wrapper",
+              "fail",
+              rationale: "wrapper missing or not executable",
+              metadata: { "path" => @wrapper_path }
+            )
+          end
+
+          stat = File.stat(@wrapper_path)
+          probe_result(
+            "claude_wrapper",
+            "pass",
+            rationale: "wrapper is executable",
+            metadata: { "path" => @wrapper_path, "mtime" => stat.mtime.utc.iso8601, "size" => stat.size }
+          )
+        rescue SystemCallError => e
+          probe_result("claude_wrapper", "error", rationale: "#{e.class}: #{e.message}",
+                                               metadata: { "path" => @wrapper_path })
+        end
+
+        def ready_detector_probe
+          if @tmux_probe
+            return normalize_probe("claude_ready_detector", @tmux_probe.call)
+          end
+
+          start = Time.now
+          status, message = Hive::ClaudeLauncher.tmux_status
+          probe_result(
+            "claude_ready_detector",
+            status.to_s == "present" ? "pass" : "fail",
+            duration: Time.now - start,
+            rationale: message
+          )
+        rescue StandardError => e
+          probe_result("claude_ready_detector", "error", rationale: "#{e.class}: #{e.message}")
+        end
+
+        def active_binary_version_probe
+          if @active_binary_probe
+            return normalize_probe("active_hive_binary", @active_binary_probe.call)
+          end
+
+          result = @command_runner.run([ @hive_bin, "--version" ], timeout: HIVE_VERSION_TIMEOUT_SEC, env: @env)
+          probe_from_command(
+            "active_hive_binary",
+            result,
+            expected_stdout: Hive::VERSION,
+            command: [ @hive_bin, "--version" ]
+          )
+        end
+
+        def command_probe(name, argv, timeout:)
+          result = @command_runner.run(argv, timeout: timeout, env: @env)
+          probe_from_command(name, result, command: argv)
+        end
+
+        def probe_from_command(name, result, command:, expected_stdout: nil)
+          status = command_status(result)
+          rationale = command_rationale(result)
+          if status == "pass" && expected_stdout
+            actual = result.stdout.to_s.strip
+            unless actual == expected_stdout.to_s
+              status = "fail"
+              rationale = "expected #{expected_stdout.inspect}, got #{actual.inspect}"
+            end
+          end
+
+          probe_result(
+            name,
+            status,
+            duration: result.duration,
+            stdout: result.stdout,
+            stderr: result.stderr,
+            rationale: rationale,
+            metadata: { "command" => AutoRetry.redact_secrets(command) }
+          )
+        end
+
+        def command_status(result)
+          return "timeout" if result.timed_out
+          return "error" if result.error
+
+          result.exitstatus.to_i.zero? ? "pass" : "fail"
+        end
+
+        def command_rationale(result)
+          return "timed out" if result.timed_out
+          return result.error if result.error
+          return "exit 0" if result.exitstatus.to_i.zero?
+
+          "exit #{result.exitstatus}"
+        end
+
+        def normalize_probe(name, value)
+          return value if value.is_a?(ProbeResult)
+
+          if value.is_a?(Hash)
+            status = value["status"] || value[:status] || (value["healthy"] || value[:healthy] ? "pass" : "fail")
+            return probe_result(
+              value["name"] || value[:name] || name,
+              status.to_s,
+              duration: value["duration"] || value[:duration],
+              stdout: value["stdout"] || value[:stdout],
+              stderr: value["stderr"] || value[:stderr],
+              rationale: value["rationale"] || value[:rationale],
+              metadata: value["metadata"] || value[:metadata] || {}
+            )
+          end
+
+          probe_result(name, value ? "pass" : "fail", rationale: value ? "probe passed" : "probe failed")
+        end
+
+        def probe_result(name, status, duration: nil, stdout: nil, stderr: nil, rationale: nil, metadata: {})
+          ProbeResult.new(
+            name: name,
+            status: status.to_s,
+            duration: duration && duration.round(3),
+            stdout: safe_output(stdout),
+            stderr: safe_output(stderr),
+            rationale: safe_output(rationale),
+            metadata: AutoRetry.redact_secrets(metadata || {})
+          )
+        end
+
+        def build_probe_set(recovery_type, probes, signal_payload)
+          payload = base_fingerprint_payload.merge(
+            "recovery_type" => recovery_type,
+            "signals" => signal_payload
+          )
+          ProbeSet.new(
+            recovery_type: recovery_type,
+            probes: probes,
+            health_fingerprint: AutoRetry.hash_fingerprint(payload)
+          )
+        end
+
+        def base_fingerprint_payload
+          {
+            "daemon" => {
+              "hive_bin" => @hive_bin,
+              "invoked_binary" => Hive::InvokedBinary.path(env: @env),
+              "version" => Hive::VERSION
+            },
+            "env" => @env.slice(
+              "PATH", "HIVE_BIN", "HIVE_CODEX_BIN", "HIVE_CLAUDE_BIN", "HIVE_TMUX_BIN",
+              "GEM_HOME", "BUNDLE_GEMFILE"
+            ),
+            "agent_profiles" => Hive::AgentProfiles.registered_names.map(&:to_s).sort
+          }
+        end
+
+        def agent_bin(name)
+          overrides = @cfg.dig("agents", name.to_s)
+          env_key = overrides.is_a?(Hash) ? overrides["env_override"] : nil
+          env_key ||= "HIVE_#{name.to_s.upcase}_BIN"
+          override = @env[env_key].to_s
+          return override unless override.empty?
+
+          configured = overrides.is_a?(Hash) ? overrides["bin"] : nil
+          configured || name.to_s
+        end
+
+        def bound_output(value)
+          text = value.to_s
+          return nil if text.empty?
+          return text if text.bytesize <= OUTPUT_SNIPPET_BYTES
+
+          trimmed = text.byteslice(0, OUTPUT_SNIPPET_BYTES).to_s
+          trimmed.scrub!("")
+          "#{trimmed}...[truncated]"
+        end
+
+        def safe_output(value)
+          text = value.to_s
+          return nil if text.empty?
+
+          bound_output(AutoRetry.redact_secrets(text))
+        end
+      end
+
+      class DecisionEngine
+        NOT_RETRIED_ACTION = "not_retried".freeze
+        AUTO_RETRY_REQUESTOR = "daemon".freeze
+        AUTO_RETRY_TRIGGER = "auto_retry".freeze
+
+        def initialize(probe_cache: nil, safety_guard: SafetyGuard.new,
+                       request_queue: Hive::Daemon::DispatchRequestQueue,
+                       state_home: Hive::Paths.state_home, logger: nil,
+                       controller: nil, probe_cache_factory: nil,
+                       audit_throttle: AuditThrottle.new)
+          @probe_cache = probe_cache
+          @safety_guard = safety_guard
+          @request_queue = request_queue
+          @state_home = state_home
+          @logger = logger
+          @controller = controller
+          @probe_cache_factory = probe_cache_factory
+          @audit_throttle = audit_throttle
+          @project_probe_caches = {}
+        end
+
+        def evaluate(rows, now: Time.now)
+          Array(rows).filter_map { |row| evaluate_row(row, now: now) }
+        end
+
+        def evaluate_row(row, now: Time.now)
+          context = row_context(row)
+          if live_task?(row)
+            return decision(context, NOT_RETRIED_ACTION,
+                            "task is currently locked by a live runner", now: now)
+          end
+          if in_flight?(context)
+            return decision(context, NOT_RETRIED_ACTION,
+                            "task already has a daemon dispatch in flight", now: now)
+          end
+
+          classification = AutoRetry.classify_marker(row)
+          context[:classification] = classification
+          context[:recovery_type] = classification.recovery_type
+          unless classification.recoverable?
+            return decision(context, NOT_RETRIED_ACTION, classification.rationale, now: now)
+          end
+
+          history = AutoRetry.retry_history(
+            task_folder: context[:task_folder],
+            stage: context[:stage],
+            reason: context[:reason]
+          )
+          context[:history] = history
+          unless history.readable?
+            return decision(context, NOT_RETRIED_ACTION,
+                            "retry history unreadable: #{history.read_error}", now: now)
+          end
+          if history.attempt_count >= MAX_ATTEMPTS
+            return decision(context, NOT_RETRIED_ACTION,
+                            "auto-retry attempts exhausted", now: now)
+          end
+
+          probe_set = probe_cache_for(row).probe(classification.recovery_type)
+          context[:probe_set] = probe_set
+          context[:health_fingerprint] = probe_set.health_fingerprint
+          unless probe_set.healthy?
+            return decision(context, NOT_RETRIED_ACTION,
+                            "health probes are not green", now: now)
+          end
+
+          blocked = retry_control_blocker(history, probe_set, now)
+          return decision(context, NOT_RETRIED_ACTION, blocked, now: now) if blocked
+
+          safety = @safety_guard.safe?(row)
+          context[:safety] = safety
+          return decision(context, NOT_RETRIED_ACTION, safety.rationale, now: now) unless safety.safe?
+
+          final_safety = @safety_guard.safe?(row)
+          context[:safety] = final_safety
+          return decision(context, NOT_RETRIED_ACTION, final_safety.rationale, now: now) unless final_safety.safe?
+
+          if duplicate_pending_request?(context)
+            return decision(context, NOT_RETRIED_ACTION,
+                            "auto-retry request is already pending", now: now)
+          end
+
+          enqueue_retry!(row, context, now)
+          decision(
+            context,
+            RETRY_ENQUEUED_ACTION,
+            "cleared marker via dispatch queue and re-enqueued #{context[:stage]}",
+            request_id: context[:request_id],
+            attempt_count: history.attempt_count + 1,
+            now: now
+          )
+        rescue StandardError => e
+          context ||= row_context(row)
+          decision(context, NOT_RETRIED_ACTION,
+                   "auto-retry decision error: #{e.class}: #{e.message}", now: now)
+        end
+
+        private
+
+        def row_context(row)
+          attrs = AutoRetry.marker_attrs(row)
+          {
+            row: row,
+            project: AutoRetry.row_value(row, :project).to_s,
+            slug: AutoRetry.row_value(row, :slug).to_s,
+            stage: AutoRetry.row_value(row, :stage).to_s,
+            task_folder: AutoRetry.row_value(row, :folder).to_s,
+            state_file: AutoRetry.row_value(row, :state_file).to_s,
+            marker_id: attrs["marker_id"].to_s,
+            reason: AutoRetry.marker_reason(row)
+          }
+        end
+
+        def live_task?(row)
+          AutoRetry.row_value(row, :live_task_lock) == true
+        end
+
+        def in_flight?(context)
+          return false unless @controller.respond_to?(:running_task?)
+
+          @controller.running_task?(project: context[:project], slug: context[:slug])
+        end
+
+        def retry_control_blocker(history, probe_set, now)
+          return nil if history.attempt_count.zero?
+
+          if history.last_health_fingerprint.to_s == probe_set.health_fingerprint.to_s
+            return "health signal has not changed since last auto-retry"
+          end
+
+          if history.last_retry_at && (now - history.last_retry_at) < SECOND_RETRY_BACKOFF_SEC
+            return "second auto-retry backoff has not elapsed"
+          end
+
+          nil
+        end
+
+        def enqueue_retry!(row, context, now)
+          request_id = @request_queue.generate_request_id
+          @request_queue.write_sequence!(
+            request_id,
+            remaining_argvs: [ retry_argv(context) ],
+            state_home: @state_home
+          )
+          @request_queue.write_request!(
+            project: context[:project],
+            slug: context[:slug],
+            argv: clear_marker_argv(row, context),
+            requestor: AUTO_RETRY_REQUESTOR,
+            trigger: AUTO_RETRY_TRIGGER,
+            request_id: request_id,
+            state_home: @state_home,
+            now: now
+          )
+          context[:request_id] = request_id
+        rescue StandardError
+          @request_queue.discard_sequence(request_id, state_home: @state_home) if request_id
+          raise
+        end
+
+        def clear_marker_argv(row, context)
+          argv = [
+            "hive", "markers", "clear", context[:slug],
+            "--name", AutoRetry.row_value(row, :marker).to_s.upcase,
+            "--project", context[:project],
+            "--json"
+          ]
+          match_attr = Hive::Markers.error_recovery_match_attr(AutoRetry.marker_attrs(row))
+          argv.concat([ "--match-attr", match_attr ]) if match_attr
+          argv
+        end
+
+        def retry_argv(context)
+          [
+            "hive", "run", context[:slug],
+            "--project", context[:project],
+            "--stage", context[:stage],
+            "--json"
+          ]
+        end
+
+        def duplicate_pending_request?(context)
+          return false unless @request_queue.respond_to?(:pending)
+
+          @request_queue.pending(state_home: @state_home).any? do |request|
+            request.project.to_s == context[:project] &&
+              request.slug.to_s == context[:slug] &&
+              request.trigger.to_s == AUTO_RETRY_TRIGGER
+          end
+        rescue StandardError
+          true
+        end
+
+        def probe_cache_for(row)
+          return @probe_cache if @probe_cache
+          return @probe_cache_factory.call(row) if @probe_cache_factory
+
+          project_root = project_root_for(row)
+          @project_probe_caches[project_root] ||= begin
+            cfg = Hive::Config.load(project_root)
+            ProbeCache.new(ProbeRunner.new(project_root: project_root, cfg: cfg))
+          end
+        end
+
+        def project_root_for(row)
+          folder = AutoRetry.row_value(row, :folder).to_s
+          return Hive::Task.new(folder).project_root unless folder.empty?
+
+          raise ArgumentError, "row task folder is missing"
+        end
+
+        def decision(context, action, rationale, request_id: nil, attempt_count: nil, now: Time.now)
+          history = context[:history]
+          result = DecisionResult.new(
+            task: context[:slug],
+            stage: context[:stage],
+            marker_id: context[:marker_id],
+            reason: context[:reason],
+            recovery_type: context[:recovery_type],
+            action: action,
+            rationale: rationale,
+            attempt_count: attempt_count || history&.attempt_count || 0,
+            health_fingerprint: context[:health_fingerprint],
+            classification: context[:classification],
+            probe_set: context[:probe_set],
+            safety: context[:safety],
+            request_id: request_id,
+            details: {
+              "project" => context[:project],
+              "slug" => context[:slug],
+              "task_folder" => context[:task_folder]
+            }
+          )
+          audit_decision!(context, result, now)
+          result
+        end
+
+        def decision_details(context, action, rationale, now, request_id: nil, attempt_count: nil)
+          {
+            "timestamp" => now.utc.iso8601,
+            "task" => context[:slug],
+            "project" => context[:project],
+            "stage" => context[:stage],
+            "marker_id" => context[:marker_id],
+            "reason" => context[:reason],
+            "recovery_type" => context[:recovery_type],
+            "probes" => context[:probe_set]&.to_h,
+            "health_fingerprint" => context[:health_fingerprint],
+            "attempt_count" => attempt_count || (context[:history]&.attempt_count || 0),
+            "action" => action,
+            "rationale" => rationale,
+            "request_id" => request_id,
+            "safety" => context[:safety]&.to_h
+          }.compact
+        end
+
+        def audit_decision!(context, result, now)
+          return unless result.retry_enqueued? || auditable_negative?(context, result)
+
+          details = AutoRetry.redact_secrets(decision_details(
+            context,
+            result.action,
+            result.rationale,
+            now,
+            request_id: result.request_id,
+            attempt_count: result.attempt_count
+          ))
+          return unless result.retry_enqueued? || @audit_throttle.allow?(throttle_key(details), now: now)
+
+          write_task_event(context, result, details)
+          write_daemon_log(details)
+        end
+
+        def auditable_negative?(context, result)
+          return false if result.retry_enqueued?
+          return false unless AutoRetry.row_value(context[:row], :marker).to_s == "error"
+
+          true
+        end
+
+        def write_task_event(context, result, details)
+          return if context[:task_folder].to_s.empty?
+
+          Hive::Events.emit(
+            task_folder: context[:task_folder],
+            slug: context[:slug],
+            stage: context[:stage],
+            event_type: :auto_retry_decision,
+            message: "#{result.action}: #{result.rationale}",
+            details: details
+          )
+        end
+
+        def write_daemon_log(details)
+          @logger&.event(
+            :auto_retry_decision,
+            project: details["project"],
+            slug: details["task"],
+            stage: details["stage"],
+            marker_id: details["marker_id"],
+            reason: details["reason"],
+            recovery_type: details["recovery_type"],
+            action: details["action"],
+            rationale: details["rationale"],
+            attempt_count: details["attempt_count"],
+            health_fingerprint: details["health_fingerprint"],
+            request_id: details["request_id"],
+            probes: details["probes"],
+            safety: details["safety"]
+          )
+        end
+
+        def throttle_key(details)
+          [
+            details["project"],
+            details["task"],
+            details["stage"],
+            details["reason"],
+            details["rationale"],
+            details["health_fingerprint"]
+          ].join("\0")
+        end
+      end
+
+      class AuditThrottle
+        DEFAULT_TTL_SEC = 30 * 60
+
+        def initialize(ttl_sec: DEFAULT_TTL_SEC)
+          @ttl_sec = ttl_sec
+          @last_emitted_at = {}
+        end
+
+        def allow?(key, now:)
+          last = @last_emitted_at[key]
+          return false if last && (now - last) < @ttl_sec
+
+          @last_emitted_at[key] = now
+          true
+        end
+      end
+
+      class SafetyGuard
+        TERMINAL_SUCCESS_MARKERS = %i[complete execute_complete review_complete].freeze
+        WORKTREE_STAGES = %w[4-execute 6-review 8-finalize].freeze # coding-scoped: v1 safety predicates
+        CONTENT_ONLY_STAGES = %w[2-brainstorm 3-plan].freeze # coding-scoped: v1 safety predicates
+        SAFE_GENERATED_PATH_PREFIXES = [
+          ".hive/auto-retry/",
+          ".hive-auto-retry/"
+        ].freeze
+
+        def initialize(git_status_runner: nil, marker_reader: nil, worktree_resolver: nil)
+          @git_status_runner = git_status_runner
+          @marker_reader = marker_reader
+          @worktree_resolver = worktree_resolver
+        end
+
+        def safe?(row)
+          success = terminal_success_marker(row)
+          return unsafe("terminal success marker is present", marker: success) if success
+
+          stage = AutoRetry.row_value(row, :stage).to_s
+          if WORKTREE_STAGES.include?(stage)
+            return worktree_safe?(row, stage)
+          end
+
+          if CONTENT_ONLY_STAGES.include?(stage)
+            return content_stage_safe?(row, stage)
+          end
+
+          unsafe("stage #{stage.empty? ? '(missing)' : stage} has no v1 auto-retry safety predicate")
+        rescue StandardError => e
+          unsafe("safety guard error: #{e.class}: #{e.message}")
+        end
+
+        private
+
+        def terminal_success_marker(row)
+          marker = read_current_marker(row)
+          return nil unless marker
+          return marker.name.to_s if TERMINAL_SUCCESS_MARKERS.include?(marker.name)
+
+          nil
+        end
+
+        def read_current_marker(row)
+          if @marker_reader
+            return @marker_reader.call(row)
+          end
+
+          state_file = AutoRetry.row_value(row, :state_file).to_s
+          return nil if state_file.empty?
+
+          Hive::Markers.current(state_file)
+        end
+
+        def worktree_safe?(row, stage)
+          path = worktree_path(row)
+          return unsafe("worktree pointer missing or unreadable") if path.to_s.empty?
+          return unsafe("worktree path does not exist", "path" => path) unless File.directory?(path)
+
+          status = git_status(path)
+          return unsafe("worktree status unreadable", "error" => status.error) unless status.ok?
+          return unsafe("worktree has merge state", "path" => path) if status.merge_state
+
+          unsafe_lines = unsafe_porcelain_lines(status.porcelain)
+          unless unsafe_lines.empty?
+            return unsafe(
+              "worktree has uncommitted or ambiguous files",
+              "path" => path,
+              "status" => unsafe_lines
+            )
+          end
+
+          safe("clean #{stage} worktree", "path" => path)
+        end
+
+        def content_stage_safe?(row, stage)
+          state_file = AutoRetry.row_value(row, :state_file).to_s
+          return unsafe("state file missing") if state_file.empty? || !File.file?(state_file)
+
+          content = File.read(state_file)
+          stripped = strip_markers_and_frontmatter(content)
+          if substantive_content?(stripped)
+            return unsafe("#{stage} contains user or generated content that could be overwritten")
+          end
+
+          safe("#{stage} has no substantive content")
+        rescue SystemCallError => e
+          unsafe("state file unreadable: #{e.class}: #{e.message}")
+        end
+
+        def worktree_path(row)
+          return @worktree_resolver.call(row) if @worktree_resolver
+
+          folder = AutoRetry.row_value(row, :folder).to_s
+          return nil if folder.empty?
+
+          pointer = Hive::Worktree.read_pointer(folder)
+          pointer && pointer["path"]
+        rescue StandardError
+          nil
+        end
+
+        def git_status(path)
+          return normalize_git_status(@git_status_runner.call(path)) if @git_status_runner
+
+          out, err, status = Open3.capture3("git", "-C", path, "status", "--porcelain=v1")
+          return GitStatus.new(ok: false, porcelain: "", merge_state: false, error: err.strip) unless status.success?
+
+          merge_path, _merge_err, merge_status = Open3.capture3("git", "-C", path, "rev-parse", "--git-path", "MERGE_HEAD")
+          merge_head = merge_path.strip
+          merge_head = File.join(path, merge_head) unless File.absolute_path?(merge_head)
+          merge_state = merge_status.success? && File.exist?(merge_head)
+          GitStatus.new(ok: true, porcelain: out, merge_state: merge_state, error: nil)
+        rescue SystemCallError => e
+          GitStatus.new(ok: false, porcelain: "", merge_state: false, error: "#{e.class}: #{e.message}")
+        end
+
+        def normalize_git_status(value)
+          return value if value.is_a?(GitStatus)
+
+          if value.is_a?(Hash)
+            return GitStatus.new(
+              ok: value.fetch(:ok, value.fetch("ok", true)),
+              porcelain: value[:porcelain] || value["porcelain"] || "",
+              merge_state: value[:merge_state] || value["merge_state"] || false,
+              error: value[:error] || value["error"]
+            )
+          end
+
+          GitStatus.new(ok: true, porcelain: value.to_s, merge_state: false, error: nil)
+        end
+
+        def unsafe_porcelain_lines(porcelain)
+          porcelain.to_s.lines.map(&:chomp).reject do |line|
+            line.strip.empty? || safe_generated_status_line?(line)
+          end
+        end
+
+        def safe_generated_status_line?(line)
+          path = line[3..].to_s
+          SAFE_GENERATED_PATH_PREFIXES.any? { |prefix| path.start_with?(prefix) }
+        end
+
+        def strip_markers_and_frontmatter(content)
+          text = content.gsub(Hive::Markers::MARKER_RE, "")
+          text = text.sub(/\A---\s*\n.*?\n---\s*\n/m, "")
+          text
+        end
+
+        def substantive_content?(text)
+          text.lines.any? do |line|
+            stripped = line.strip
+            next false if stripped.empty?
+            next false if stripped.start_with?("#")
+
+            true
+          end
+        end
+
+        def safe(rationale, details = {})
+          SafetyResult.new(safe: true, rationale: rationale, details: details)
+        end
+
+        def unsafe(rationale, details = {})
+          SafetyResult.new(safe: false, rationale: rationale, details: details)
+        end
+      end
+
+      RetryHistory = Struct.new(
+        :attempt_count,
+        :last_retry_at,
+        :last_health_fingerprint,
+        :read_error,
+        keyword_init: true
+      ) do
+        def readable?
+          read_error.nil?
+        end
+      end
+
+      module_function
+
+      def enabled?(daemon_cfg)
+        daemon_cfg.dig("auto_retry", "enabled") != false
+      end
+
+      def classify_marker(row)
+        marker = row_value(row, :marker).to_s
+        reason = marker_reason(row)
+        text = diagnostic_text(row)
+
+        return not_recoverable("marker is not terminal ERROR") unless marker == "error"
+        return not_recoverable("missing diagnostics") if text.strip.empty?
+
+        if excluded_failure_text?(text)
+          return not_recoverable("diagnostics describe an excluded failure class")
+        end
+
+        case reason
+        when "implementer_failed"
+          classify_implementer_failed(text)
+        when "claude_launch_failed"
+          classify_claude_launch_failed(text)
+        else
+          not_recoverable("marker reason #{reason.empty? ? '(missing)' : reason.inspect} is not v1 recoverable")
+        end
+      end
+
+      def retry_history(task_folder:, stage:, reason:)
+        events = read_task_events(task_folder)
+        return unreadable_history("events.jsonl unreadable") if events.nil?
+
+        attempts = 0
+        last_retry_at = nil
+        last_health_fingerprint = nil
+
+        events.each do |event|
+          next unless event.is_a?(Hash)
+          next unless event["event_type"].to_s == AUTO_RETRY_EVENT_TYPE
+
+          details = event["details"].is_a?(Hash) ? event["details"] : {}
+          event_stage = details["stage"] || event["stage"]
+          event_reason = details["reason"] || details["marker_reason"]
+          next unless event_stage.to_s == stage.to_s
+          next unless event_reason.to_s == reason.to_s
+          next unless details["action"].to_s == RETRY_ENQUEUED_ACTION
+
+          attempts += 1
+          parsed_time = parse_time(details["timestamp"] || event["ts"])
+          last_retry_at = parsed_time if parsed_time
+          last_health_fingerprint = details["health_fingerprint"] if details.key?("health_fingerprint")
+        end
+
+        RetryHistory.new(
+          attempt_count: attempts,
+          last_retry_at: last_retry_at,
+          last_health_fingerprint: last_health_fingerprint,
+          read_error: nil
+        )
+      rescue JSON::ParserError, SystemCallError, IOError => e
+        unreadable_history("#{e.class}: #{e.message}")
+      end
+
+      def hash_fingerprint(payload)
+        redacted = redact_secrets(payload)
+        ::Digest::SHA256.hexdigest(JSON.generate(canonicalize(redacted)))
+      end
+
+      def redact_secrets(value, key_hint = nil)
+        case value
+        when Hash
+          value.each_with_object({}) do |(key, child), out|
+            key_string = key.to_s
+            out[key_string] = if key_string.match?(SECRET_KEY_RE)
+                                REDACTED
+                              else
+                                redact_secrets(child, key_string)
+                              end
+          end
+        when Array
+          value.map { |child| redact_secrets(child, key_hint) }
+        when String
+          redacted = value.dup
+          SECRET_VALUE_RES.each { |pattern| redacted.gsub!(pattern, REDACTED) }
+          key_hint.to_s.match?(SECRET_KEY_RE) ? REDACTED : redacted
+        else
+          value
+        end
+      end
+
+      def canonicalize(value)
+        case value
+        when Hash
+          value.keys.sort.each_with_object({}) do |key, out|
+            out[key] = canonicalize(value[key])
+          end
+        when Array
+          value.map { |child| canonicalize(child) }
+        else
+          value
+        end
+      end
+
+      def read_task_events(task_folder)
+        path = File.join(task_folder.to_s, "events.jsonl")
+        return [] unless File.exist?(path)
+
+        File.readlines(path, chomp: true).filter_map do |line|
+          next if line.strip.empty?
+
+          JSON.parse(line)
+        end
+      end
+
+      def unreadable_history(message)
+        RetryHistory.new(
+          attempt_count: 0,
+          last_retry_at: nil,
+          last_health_fingerprint: nil,
+          read_error: message
+        )
+      end
+
+      def parse_time(value)
+        return nil if value.to_s.empty?
+
+        Time.parse(value.to_s)
+      rescue ArgumentError
+        nil
+      end
+
+      def classify_implementer_failed(text)
+        if text.match?(CODEX_AUTH_401_RE) && text.match?(CODEX_AUTH_DETAIL_RE)
+          return Classification.new(
+            recovery_type: "codex_auth_recovery",
+            rationale: "implementer_failed contains Codex HTTP 401 missing bearer/basic auth diagnostics"
+          )
+        end
+
+        not_recoverable("implementer_failed diagnostics do not match Codex auth recovery")
+      end
+
+      def classify_claude_launch_failed(text)
+        if text.match?(CLAUDE_LAUNCH_RE)
+          return Classification.new(
+            recovery_type: "claude_launcher_recovery",
+            rationale: "claude_launch_failed contains launcher/wrapper/readiness/binary diagnostics"
+          )
+        end
+
+        not_recoverable("claude_launch_failed diagnostics do not match launcher recovery")
+      end
+
+      def not_recoverable(rationale)
+        Classification.new(recovery_type: nil, rationale: rationale)
+      end
+
+      def excluded_failure_text?(text)
+        EXCLUDED_FAILURE_PATTERNS.any? { |pattern| text.match?(pattern) }
+      end
+
+      def marker_reason(row)
+        attrs = marker_attrs(row)
+        attrs["reason"].to_s
+      end
+
+      def marker_attrs(row)
+        value = row_value(row, :marker_attrs)
+        value.is_a?(Hash) ? value : {}
+      end
+
+      def diagnostic_text(row)
+        attrs = marker_attrs(row)
+        diagnostic = row_value(row, :diagnostic)
+        parts = []
+        %w[status message error_message detail exception_class exception_message].each do |key|
+          parts << attrs[key]
+        end
+        if diagnostic.is_a?(Hash)
+          %w[summary detail source source_path generated_by].each do |key|
+            parts << diagnostic[key]
+          end
+        elsif !diagnostic.nil?
+          parts << diagnostic
+        end
+        parts.compact.join("\n")
+      end
+
+      def row_value(row, key)
+        return row.public_send(key) if row.respond_to?(key)
+        return row[key.to_s] if row.is_a?(Hash) && row.key?(key.to_s)
+        return row[key] if row.is_a?(Hash) && row.key?(key)
+
+        nil
+      end
+    end
+  end
+end
