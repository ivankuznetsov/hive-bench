@@ -0,0 +1,940 @@
+require "test_helper"
+require "hive/daemon/auto_retry"
+require "hive/events"
+
+class HiveDaemonAutoRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  Row = Struct.new(
+    :project,
+    :slug,
+    :marker,
+    :marker_attrs,
+    :diagnostic,
+    :stage,
+    :folder,
+    :state_file,
+    :live_task_lock,
+    keyword_init: true
+  )
+
+  class FakeCommandRunner
+    attr_reader :calls
+
+    def initialize(results)
+      @results = results.dup
+      @calls = []
+    end
+
+    def run(argv, timeout:, env:)
+      @calls << { argv: argv, timeout: timeout, env: env }
+      @results.shift || command_result(exitstatus: 0)
+    end
+
+    private
+
+    def command_result(**kwargs)
+      HiveDaemonAutoRetryTest.command_result(**kwargs)
+    end
+  end
+
+  class FakeQueue
+    attr_reader :requests, :sequences, :discarded
+    attr_accessor :pending_requests
+
+    def initialize
+      @requests = []
+      @sequences = []
+      @discarded = []
+      @pending_requests = []
+      @next_id = 1
+    end
+
+    def generate_request_id
+      "auto-#{@next_id}".tap { @next_id += 1 }
+    end
+
+    def write_sequence!(request_id, remaining_argvs:, state_home:)
+      @sequences << { request_id: request_id, remaining_argvs: remaining_argvs, state_home: state_home }
+      true
+    end
+
+    def write_request!(project:, slug:, argv:, requestor:, trigger:, request_id:, state_home:, now:)
+      @requests << {
+        project: project,
+        slug: slug,
+        argv: argv,
+        requestor: requestor,
+        trigger: trigger,
+        request_id: request_id,
+        state_home: state_home,
+        now: now
+      }
+      request_id
+    end
+
+    def discard_sequence(request_id, state_home:)
+      @discarded << { request_id: request_id, state_home: state_home }
+      true
+    end
+
+    def pending(state_home:)
+      @pending_requests
+    end
+  end
