+  class FakeProbeCache
+    attr_reader :calls
+
+    def initialize(set)
+      @set = set
+      @calls = []
+    end
+
+    def probe(recovery_type)
+      @calls << recovery_type
+      @set
+    end
+  end
+
+  class FakeSafetyGuard
+    attr_reader :calls
+
+    def initialize(*results)
+      @results = results
+      @calls = 0
+    end
+
+    def safe?(_row)
+      @calls += 1
+      @results[@calls - 1] || @results.last || safety_result(true, "safe")
+    end
+  end
