+    def evaluate_completion_fallback(task:, runner:, log_label:, verifier:, context:)
+      reason = completion_fallback_precondition_failure(task, runner, context)
+      return completion_timeout_result(reason) if reason
+
+      pid = completion_candidate_pid(runner)
+      runner.send_prompt("/quit")
+      deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + completion_fallback_grace
+      loop do
+        if File.exist?(done_path(task))
+          result_state, status = read_result_json_completion(task)
+          if result_state == :valid && (status.nil? || status == :ok)
+            return { status: :ok, log_label: log_label }
+          end
+          return completion_timeout_result("late stop result #{result_state == :valid ? status : result_state}")
+        end
+
+        exit_status = read_wrapper_exit_status(task)
+        if exit_status
+          return completion_timeout_result("wrapper exit status #{exit_status}") unless exit_status.zero?
+
+          candidate = CompletionCandidate.new(
+            phase: context[:phase] || context["phase"],
+            pass: context[:pass] || context["pass"],
+            log_label: log_label,
+            task_slug: task_slug(task),
+            pid: pid,
+            session: runner.respond_to?(:name) ? runner.name : nil,
+            expected_sentinel: done_path(task),
+            result_path: result_path(task),
+            exit_status_path: exit_status_path(task),
+            missing_signal_reason: STOP_SIGNAL_MISSING_MESSAGE,
+            exit_status: exit_status
+          )
+          return verify_completion_candidate(task, candidate, verifier)
+        end
+
+        break if Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline
+
+        sleep [ poll_interval, deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC) ].min
+      end
