@@ -0,0 +1,161 @@
+require "test_helper"
+require "json"
+require "hive/stages/review"
+
+class ReviewFixCompletionTest < Minitest::Test
+  include HiveTestHelper
+
+  TaskStub = Struct.new(:slug, :folder)
+
+  def context(root, pass: 1, task_folder: File.join(root, "task"))
+    folder = task_folder
+    FileUtils.mkdir_p(File.join(folder, "reviews"))
+    Hive::Stages::Review::Context.new(
+      worktree_path: root,
+      task_folder: folder,
+      default_branch: "main",
+      pass: pass
+    )
+  end
+
+  def write_outcome(ctx, **overrides)
+    data = {
+      "task_slug" => "task-slug",
+      "pass" => ctx.pass,
+      "outcome" => "no_change",
+      "resolved_findings" => 2,
+      "resolution" => "No code changes were needed; the accepted findings were already resolved."
+    }.merge(overrides.transform_keys(&:to_s))
+    File.write(Hive::Stages::Review.fix_outcome_path(ctx), JSON.generate(data))
+  end
+
+  def test_parse_fix_outcome_accepts_strict_bound_no_change_evidence
+    with_tmp_dir do |dir|
+      ctx = context(dir)
+      write_outcome(ctx)
+
+      outcome, error = Hive::Stages::Review.parse_fix_outcome(
+        TaskStub.new("task-slug", ctx.task_folder), ctx, expected_findings: 2
+      )
+
+      assert_nil error
+      assert_equal "no_change", outcome.fetch("outcome")
+    end
+  end
+
+  def test_parse_fix_outcome_rejects_malformed_stale_vague_and_unknown_shapes
+    with_tmp_dir do |dir|
+      ctx = context(dir)
+      task = TaskStub.new("task-slug", ctx.task_folder)
+
+      File.write(Hive::Stages::Review.fix_outcome_path(ctx), "{")
+      assert_match(/malformed/, Hive::Stages::Review.parse_fix_outcome(task, ctx, expected_findings: 2).last)
+
+      write_outcome(ctx, pass: 2)
+      assert_match(/pass does not match/, Hive::Stages::Review.parse_fix_outcome(task, ctx, expected_findings: 2).last)
+
+      write_outcome(ctx, resolution: "nothing to do")
+      assert_match(/explicitly say/, Hive::Stages::Review.parse_fix_outcome(task, ctx, expected_findings: 2).last)
+
+      write_outcome(ctx, extra: true)
+      assert_match(/keys must be exactly/, Hive::Stages::Review.parse_fix_outcome(task, ctx, expected_findings: 2).last)
+    end
+  end
+
+  def test_verify_fix_artifacts_requires_reviewer_escalations_and_no_error_marker
+    with_tmp_dir do |dir|
+      ctx = context(dir)
+      reviews = File.join(ctx.task_folder, "reviews")
+      File.write(File.join(reviews, "reviewer-01.md"), "# Review\n- [x] fixed\n")
+      File.write(File.join(reviews, "escalations-01.md"), "# Escalations\n\n_All answered._\n")
+
+      ok, checked, error = Hive::Stages::Review.verify_fix_artifacts(ctx)
+      assert ok, error
+      assert_equal %w[reviewer-01.md escalations-01.md], checked
+
+      File.write(File.join(reviews, "errors-01.md"), "missing output")
+      ok, _checked, error = Hive::Stages::Review.verify_fix_artifacts(ctx)
+      refute ok
+      assert_match(/missing-output\/error artifact/, error)
+    end
+  end
+
+  def test_fix_result_is_excluded_from_reviewer_discovery
+    with_tmp_dir do |dir|
+      ctx = context(dir)
+      write_outcome(ctx)
+
+      assert_empty Hive::Stages::Review::Triage.discover_reviewer_files(ctx)
+      refute Hive::Stages::Review.reviewer_file?("fix-result-01.json")
+    end
+  end
+
+
+  def test_verify_fix_completion_rejects_changed_without_head_advance
+    with_tmp_dir do |dir|
+      worktree = File.join(dir, "worktree")
+      FileUtils.mkdir_p(worktree)
+      run!("git", "-C", worktree, "init", "-b", "main", "--quiet")
+      run!("git", "-C", worktree, "config", "user.email", "test@example.com")
+      run!("git", "-C", worktree, "config", "user.name", "Test")
+      File.write(File.join(worktree, "README.md"), "initial\n")
+      run!("git", "-C", worktree, "add", ".")
+      run!("git", "-C", worktree, "commit", "-m", "initial", "--quiet")
+      ctx = context(worktree, task_folder: File.join(dir, "task"))
+      task = TaskStub.new("task-slug", ctx.task_folder)
+      reviews = File.join(ctx.task_folder, "reviews")
+      File.write(File.join(reviews, "reviewer-01.md"), "- [x] accepted finding\n")
+      File.write(File.join(reviews, "escalations-01.md"), "# Escalations\n\n_All answered._\n")
+      write_outcome(ctx, outcome: "changed", resolved_findings: 1,
+                    resolution: "Applied the accepted finding.")
+      accepted = Hive::Stages::Review.collect_accepted_findings_with_count(ctx)
+      head = `git -C #{worktree} rev-parse HEAD`.strip
+      snapshot = Hive::ProtectedFiles.snapshot(
+        task.folder, Hive::Stages::Review.fix_protected_files(ctx.pass)
+      )
+
+      completion = Hive::Stages::Review.verify_fix_completion(
+        task, { "review" => {} }, ctx, accepted,
+        before_fix_sha: snapshot, before_fix_head: head
+      )
+
+      assert_equal :invalid_outcome, completion.status
+      assert_match(/requires HEAD to advance/, completion.message)
+    end
+  end
+
+  def test_verify_fix_completion_rejects_no_change_with_advanced_head
+    with_tmp_dir do |dir|
+      worktree = File.join(dir, "worktree")
+      FileUtils.mkdir_p(worktree)
+      run!("git", "-C", worktree, "init", "-b", "main", "--quiet")
+      run!("git", "-C", worktree, "config", "user.email", "test@example.com")
+      run!("git", "-C", worktree, "config", "user.name", "Test")
+      File.write(File.join(worktree, "README.md"), "initial\n")
+      run!("git", "-C", worktree, "add", ".")
+      run!("git", "-C", worktree, "commit", "-m", "initial", "--quiet")
+      before_head = `git -C #{worktree} rev-parse HEAD`.strip
+      ctx = context(worktree, task_folder: File.join(dir, "task"))
+      task = TaskStub.new("task-slug", ctx.task_folder)
+      reviews = File.join(ctx.task_folder, "reviews")
+      File.write(File.join(reviews, "reviewer-01.md"), "- [x] accepted finding\n")
+      File.write(File.join(reviews, "escalations-01.md"), "# Escalations\n\n_All answered._\n")
+      write_outcome(ctx, resolved_findings: 1)
+      accepted = Hive::Stages::Review.collect_accepted_findings_with_count(ctx)
+      snapshot = Hive::ProtectedFiles.snapshot(
+        task.folder, Hive::Stages::Review.fix_protected_files(ctx.pass)
+      )
+      File.write(File.join(worktree, "README.md"), "changed\n")
+      run!("git", "-C", worktree, "add", "README.md")
+      run!("git", "-C", worktree, "commit", "-m", "changed", "--quiet")
+
+      completion = Hive::Stages::Review.verify_fix_completion(
+        task, { "review" => {} }, ctx, accepted,
+        before_fix_sha: snapshot, before_fix_head: before_head
+      )
+
+      assert_equal :invalid_outcome, completion.status
+      assert_match(/requires HEAD to remain unchanged/, completion.message)
+    end
+  end
+end
