+      return "claude pane was not at a finished prompt" unless claude_ready_prompt?(pane)
+
+      nil
+    rescue Hive::TmuxError => e
+      "tmux_pane_unreadable: #{e.message}"
+    end
+
+    def verify_completion_candidate(task, candidate, verifier)
+      verification = verifier.call(candidate)
+      unless verification.is_a?(Hash) && verification[:accepted] == true
+        reason = verification.is_a?(Hash) ? verification[:reason] : "verifier returned no structured acceptance"
+        return completion_timeout_result(reason || "verifier rejected candidate")
+      end
+
+      payload = candidate.to_h.merge(
+        artifacts_checked: Array(verification[:artifacts_checked]),
+        evidence: verification[:evidence]
+      )
+      event = Hive::Events.emit(
+        task_folder: task.folder,
+        slug: task_slug(task),
+        stage: candidate.phase || "claude",
