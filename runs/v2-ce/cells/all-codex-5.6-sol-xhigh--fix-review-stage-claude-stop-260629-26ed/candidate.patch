+        File.write(fake, "#!/bin/sh\nexit #{exit_status}\n")
+        File.chmod(0o755, fake)
+
+        _out, err, status = Open3.capture3(
+          { "HIVE_TASK_STAGE_DIR" => dir },
+          wrapper, "--cwd", dir, "--bin", fake
+        )
+
+        assert_equal exit_status, status.exitstatus, err
+        assert_equal "#{exit_status}\n", File.read(File.join(dir, "claude-exit-status"))
+        assert_empty Dir.glob(File.join(dir, "claude-exit-status.tmp.*"))
+      end
     end
   end
 
