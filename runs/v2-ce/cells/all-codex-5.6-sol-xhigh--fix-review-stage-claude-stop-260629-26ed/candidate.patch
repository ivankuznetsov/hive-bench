+    rescue Hive::TmuxError => e
+      completion_timeout_result("tmux_pane_unreadable: #{e.message}")
+    rescue StandardError => e
+      completion_timeout_result("completion verifier raised #{e.class}: #{e.message}")
+    end
+
+    def completion_fallback_precondition_failure(task, runner, context)
+      return "tmux session unavailable" unless runner
+      if runner.respond_to?(:session_exists?) && !runner.session_exists?
+        return "tmux session terminated"
+      end
+
+      marker = Hive::Markers.current(task.state_file)
+      if %i[error review_error].include?(marker.name)
+        return "preexisting #{marker.name} marker"
+      end
+      blockers = Array(context[:blocking_paths] || context["blocking_paths"])
+      existing_blocker = blockers.find { |path| File.exist?(path.to_s) }
+      return "preexisting blocking output #{File.basename(existing_blocker)}" if existing_blocker
