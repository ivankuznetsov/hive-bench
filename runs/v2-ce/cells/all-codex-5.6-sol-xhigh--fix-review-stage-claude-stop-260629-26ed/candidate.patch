+require "test_helper"
+
+class ClaudeTmuxDocsTest < Minitest::Test
+  ROOT = File.expand_path("../..", __dir__)
+
+  def test_mode_policy_and_audit_event_are_documented
+    note = File.read(File.join(ROOT, "docs", "notes", "claude-tmux-launch-mode.md"))
+
+    assert_includes note, "mode: headless"
+    assert_includes note, "claude_completion_fallback"
+    assert_includes note, "safe to re-enable"
+    assert_includes note, "never changes this setting automatically"
+    assert_includes note, "result.json.tmp.<pid>"
+    assert_includes note, "claude-exit-status"
+  end
+
+  def test_known_incident_recovery_commands_are_exact_and_audit_gated
+    recipes = File.read(File.join(ROOT, "docs", "recipes.md"))
+    mappings = {
+      "Task 58 / PR #622" => "add-local-hive-web-install-260629-f4ca",
+      "Task 287 / PR #623" => "fix-claude-tmux-ready-detector-260629-50cc",
+      "Task 288 / PR #624" => "make-the-hive-daemon-automatically-260629-223d"
+    }
+
+    mappings.each do |label, slug|
+      assert_includes recipes, label
+      assert_includes recipes, "hive markers clear #{slug} --name REVIEW_ERROR"
+      assert_includes recipes, "hive run #{slug}"
+    end
+    assert_includes recipes, "OK for v1"
+    assert_match(/cannot safely re-evaluate\s+or clear them automatically/, recipes)
+    assert_includes recipes, "Never place unconditional `REVIEW_ERROR` clearing"
+  end
+end
