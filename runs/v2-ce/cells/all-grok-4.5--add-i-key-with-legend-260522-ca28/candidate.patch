+require "hive/tui/styles"
+require "hive/tui/text"
+require "hive/tui/views/format"
+
+module Hive
+  module Tui
+    module Views
+      # Full-screen read-only info panel for a focused task card.
+      # KeyMap routes only q / Esc / i → BACK in `:info` mode; this
+      # view only renders the captured `Model::InfoState` fields.
+      # No scrolling this iteration — overflow is truncated with `…`.
+      # All operator-/log-derived strings go through `Text.sanitize`
+      # (same contract as `Views::RedStatusDetail`) so CSI/control
+      # bytes in idea text, paths, or execute log extras cannot
+      # hijack the cursor or corrupt width math.
+      module InfoPanel
+        DISMISS_HINT = "q/Esc/i close".freeze
+        EMPTY_PLACEHOLDER = "—".freeze
+        ELLIPSIS = "…".freeze
+
+        module_function
+
+        def render(model)
+          state = model.info_state
+          return "" if state.nil?
+
+          width = [ model.cols.to_i, 1 ].max
+          height = [ model.rows.to_i, 1 ].max
+          body_budget = [ height - 1, 1 ].max # reserve one line for dismiss hint
+
+          lines = content_lines(state, width)
+          visible = fit_lines(lines, body_budget, width)
+          visible << Styles::HINT.render(truncate(DISMISS_HINT, width))
+          visible.join("\n")
+        end
+
+        # @api private — exposed for tests.
+        def content_lines(state, width)
+          lines = []
+          lines << Styles::HEADER.render(truncate("Info · #{safe(state.slug)}", width))
+          lines << ""
+          lines.concat(field_lines("Slug", state.slug, width))
+          lines.concat(field_lines("Stage", state.stage, width))
+          lines.concat(field_lines("Created", state.created_at, width))
+          lines.concat(field_lines("Working dir", state.working_dir, width))
+          lines.concat(field_lines("Latest log", state.latest_log_path, width))
+          lines << ""
+          lines << Styles::HEADER.render(truncate("Idea", width))
+          lines.concat(body_block(state.original_text, width))
+
+          if state.extras_label.to_s != "" && !state.extras_body.nil?
+            lines << ""
+            lines << Styles::HEADER.render(truncate(safe(state.extras_label), width))
+            lines.concat(body_block(state.extras_body, width))
+          end
+
+          lines
+        end
+
+        def field_lines(label, value, width)
+          display = Hive::Tui::Text.sanitize(value.to_s).strip
+          display = EMPTY_PLACEHOLDER if display.empty?
+          wrapped("#{label}: #{display}", width)
+        end
+
+        def body_block(text, width)
+          display = Hive::Tui::Text.sanitize(text.to_s)
+          display = EMPTY_PLACEHOLDER if display.strip.empty?
+          wrapped(display, width)
+        end
+
+        def fit_lines(lines, budget, width)
+          budget = [ budget.to_i, 1 ].max
+          return lines if lines.length <= budget
+
+          # Keep budget-1 content lines, then a truncation marker.
+          kept = lines.first([ budget - 1, 0 ].max)
+          kept << truncate(ELLIPSIS, width)
+          kept
+        end
+
+        def wrap_text(text, width)
+          capacity = [ width.to_i, 1 ].max
+          text.each_line(chomp: true).flat_map do |line|
+            chunk_buffer(line, capacity)
+          end
+        end
+
+        def wrapped(text, width)
+          wrap_text(text.to_s, width).map { |line| truncate(line, width) }
+        end
+
+        def chunk_buffer(buffer, capacity)
+          return [ "" ] if buffer.empty?
+
+          chunks = []
+          offset = 0
+          while offset < buffer.length
+            chunks << buffer[offset, capacity].to_s
+            offset += capacity
+          end
+          chunks
+        end
+
+        def truncate(line, width)
+          Views::Format.truncate(line.to_s, width.to_i)
+        end
+
+        def safe(value)
+          text = Hive::Tui::Text.sanitize(value.to_s)
+          text.empty? ? EMPTY_PLACEHOLDER : text
+        end
+      end
+    end
+  end
+end
