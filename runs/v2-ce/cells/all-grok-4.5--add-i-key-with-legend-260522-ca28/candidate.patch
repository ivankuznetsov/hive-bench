new file mode 100644
index 00000000..7dceedcf
--- /dev/null
+++ b/test/unit/tui/views/info_panel_test.rb
@@ -0,0 +1,137 @@
+require "test_helper"
+require "hive/tui/model"
+require "hive/tui/views/info_panel"
+
+class HiveTuiViewsInfoPanelTest < Minitest::Test
+  include HiveTestHelper
+
+  def info_state(**overrides)
+    defaults = {
+      slug: "some-slug",
+      stage: "1-inbox",
+      created_at: "2026-05-20T00:00:00Z",
+      original_text: "Original idea",
+      working_dir: "/tmp/project/.hive-state/stages/1-inbox/some-slug",
+      latest_log_path: nil,
+      extras_label: nil,
+      extras_body: nil
+    }
+    Hive::Tui::Model::InfoState.new(**defaults, **overrides)
+  end
+
+  def model_with(cols: 80, rows: 24, **state_overrides)
+    Hive::Tui::Model.initial.with(
+      mode: :info,
+      info_state: info_state(**state_overrides),
+      cols: cols,
+      rows: rows
+    )
+  end
+
+  def render_out(**kwargs)
+    Hive::Tui::Views::InfoPanel.render(model_with(**kwargs))
+  end
+
+  def render_lines(**kwargs)
+    render_out(**kwargs).lines(chomp: true)
+  end
+
+  def test_renders_title_with_slug
+    out = render_out(slug: "preview-me")
+    assert_includes out, "Info · preview-me"
+  end
+
+  def test_renders_common_fields
+    out = render_out(
+      slug: "card-a",
+      stage: "1-inbox",
+      created_at: "2026-05-20T00:00:00Z",
+      original_text: "Ship the thing",
+      working_dir: "/abs/path/to/card-a",
+      latest_log_path: "/abs/path/logs/card-a/run.log"
+    )
+
+    assert_includes out, "Slug: card-a"
+    assert_includes out, "Stage: 1-inbox"
+    assert_includes out, "Created: 2026-05-20T00:00:00Z"
+    assert_includes out, "Working dir: /abs/path/to/card-a"
+    assert_includes out, "Latest log: /abs/path/logs/card-a/run.log"
+    assert_includes out, "Ship the thing"
+  end
+
+  def test_inbox_has_no_extras_section
+    out = render_out(stage: "1-inbox", extras_label: nil, extras_body: nil)
+    refute_includes out, "brainstorm.md"
+    refute_includes out, "plan.md"
+    refute_includes out, "Latest log\n", "extras header must not appear for inbox"
+  end
+
+  def test_brainstorm_extras_body_appears
+    out = render_out(
+      stage: "2-brainstorm",
+      extras_label: "brainstorm.md",
+      extras_body: "Q1: What is the goal?"
+    )
+    assert_includes out, "brainstorm.md"
+    assert_includes out, "Q1: What is the goal?"
+  end
+
+  def test_missing_optional_fields_use_placeholders
+    out = render_out(created_at: nil, latest_log_path: nil, original_text: "")
+    assert_includes out, "Created: —"
+    assert_includes out, "Latest log: —"
+    assert_includes out, "—"
+  end
+
+  def test_renders_dismiss_hint
+    out = render_out
+    assert out.end_with?(Hive::Tui::Views::InfoPanel::DISMISS_HINT),
+           "dismiss hint must be the final rendered line"
+  end
+
+  def test_truncates_long_lines_to_width
+    lines = render_lines(
+      original_text: "x" * 80,
+      working_dir: "/very/long/path/" + ("seg/" * 20),
+      cols: 20,
+      rows: 40
+    )
+
+    assert lines.all? { |line| line.length <= 20 },
+           "all rendered lines must fit width: #{lines.inspect}"
+  end
+
+  def test_oversized_body_truncates_to_rows_with_ellipsis
+    text = (1..40).map { |i| "line #{i}" }.join("\n")
+    lines = render_lines(original_text: text, cols: 40, rows: 10)
+
+    assert_operator lines.length, :<=, 10
+    assert_includes lines.join("\n"), "…"
+  end
+
+  def test_nil_info_state_renders_empty
+    model = Hive::Tui::Model.initial.with(mode: :info, info_state: nil, cols: 80, rows: 24)
+    assert_equal "", Hive::Tui::Views::InfoPanel.render(model)
+  end
+
+  def test_sanitizes_ansi_and_control_bytes_from_body_and_fields
+    out = render_out(
+      slug: "card-\e[31mred\e[0m",
+      original_text: "idea\e[2J\x07body",
+      working_dir: "/tmp/\e[1mpath",
+      latest_log_path: "/tmp/logs/\x1brun.log",
+      extras_label: "plan.md",
+      extras_body: "step\e[0m one\nline\x08two",
+      cols: 100,
+      rows: 40
+    )
+
+    refute_match(/\e\[/, out, "ANSI CSI must be stripped from info panel output")
+    refute_includes out, "\x07"
+    refute_includes out, "\x08"
+    assert_includes out, "idea"
+    assert_includes out, "body"
+    assert_includes out, "step"
+    assert_includes out, "one"
+  end
+end
