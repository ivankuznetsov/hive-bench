-exec "$bin" "$@"
+"$bin" "$@" &
+child_pid=$!
+
+if [ -n "${HIVE_TASK_STAGE_DIR:-}" ]; then
+  mkdir -p "$HIVE_TASK_STAGE_DIR"
+  printf '%s\n' "$child_pid" > "${HIVE_TASK_STAGE_DIR}/claude-child.pid"
+fi
+
+forward_signal() {
+  signal=$1
+  if kill -0 "$child_pid" 2>/dev/null; then
+    kill "-$signal" "$child_pid" 2>/dev/null || true
+  fi
+}
+
+trap 'forward_signal TERM' TERM
+trap 'forward_signal INT' INT
+trap 'forward_signal HUP' HUP
+
+set +e
+wait "$child_pid"
+status=$?
+set -e
+trap - TERM INT HUP
+
+if [ -n "${HIVE_TASK_STAGE_DIR:-}" ]; then
+  status_path="${HIVE_TASK_STAGE_DIR}/claude-exit-status.json"
+  tmp_status_path="${status_path}.$$"
+  completed_at=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
+  printf '{"pid":%s,"exit_code":%s,"completed_at":"%s"}\n' \
+    "$child_pid" "$status" "$completed_at" > "$tmp_status_path"
+  mv "$tmp_status_path" "$status_path"
+fi
+
+exit "$status"
