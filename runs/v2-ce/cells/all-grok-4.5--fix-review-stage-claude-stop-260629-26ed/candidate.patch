@@ -0,0 +1,300 @@
+# frozen_string_literal: true
+
+require_relative "../../../test_helper"
+require "hive/stages/review"
+require "hive/events"
+
+class ReviewFixCompletionFallbackTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_stop_hook_timeout_result_predicate
+    assert Hive::Stages::Review.send(
+      :stop_hook_timeout_result?,
+      status: :timeout,
+      error_message: "claude stop hook did not signal completion"
+    )
+    refute Hive::Stages::Review.send(
+      :stop_hook_timeout_result?,
+      status: :timeout,
+      error_message: "something else"
+    )
+    refute Hive::Stages::Review.send(
+      :stop_hook_timeout_result?,
+      status: :error,
+      error_message: "claude stop hook did not signal completion"
+    )
+  end
+
+  def test_review_fix_evidence_requires_escalations_and_commit_or_dirty
+    with_tmp_dir do |root|
+      task_folder = File.join(root, "task")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(File.join(task_folder, "reviews"))
+      FileUtils.mkdir_p(worktree)
+      task = Struct.new(:folder, :slug).new(task_folder, "slug-test")
+      ctx = Struct.new(:task_folder, :worktree_path, :pass).new(task_folder, worktree, 1)
+
+      # No escalations → false
+      refute Hive::Stages::Review.send(
+        :review_fix_completion_evidence?,
+        task, ctx, before_fix_head: "aaa", after_fix_head: "bbb"
+      )
+
+      File.write(File.join(task_folder, "reviews", "escalations-01.md"), "# esc\n- [x] done\n")
+
+      # Head changed + escalations → true (stub worktree_status :clean)
+      with_replaced_singleton_method(
+        Hive::Stages::Review, :worktree_status, ->(_path) { :clean }
+      ) do
+        assert Hive::Stages::Review.send(
+          :review_fix_completion_evidence?,
+          task, ctx, before_fix_head: "aaa", after_fix_head: "bbb"
+        )
+      end
+    end
+  end
+
+  def test_review_fix_evidence_rejects_hard_failures
+    with_tmp_dir do |root|
+      task_folder = File.join(root, "task")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(File.join(task_folder, "reviews"))
+      FileUtils.mkdir_p(worktree)
+      File.write(File.join(task_folder, "reviews", "escalations-01.md"), "- [x] ok\n")
+      task = Struct.new(:folder, :slug).new(task_folder, "slug-test")
+      ctx = Struct.new(:task_folder, :worktree_path, :pass).new(task_folder, worktree, 1)
+
+      with_replaced_singleton_method(
+        Hive::Stages::Review, :worktree_status, ->(_path) { :clean }
+      ) do
+        refute Hive::Stages::Review.send(
+          :review_fix_completion_evidence?,
