diff --git a/test/integration/daemon_recoverable_marker_retry_test.rb b/test/integration/daemon_recoverable_marker_retry_test.rb
new file mode 100644
index 00000000..ff04e228
--- /dev/null
+++ b/test/integration/daemon_recoverable_marker_retry_test.rb
@@ -0,0 +1,204 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/commands/init"
+require "hive/markers"
+require "hive/daemon/recoverable_marker_retry"
+require "hive/daemon/status_consumer"
+require "hive/daemon/logger"
+require "hive/daemon/concurrency_controller"
+
+# Integration: real on-disk ERROR markers + status-shaped rows through
+# RecoverableMarkerRetry with injected green probes (no live Codex/Claude).
+class DaemonRecoverableMarkerRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  AUTH_MSG = "HTTP 401: Missing bearer/basic auth".freeze
+  LAUNCH_MSG = "claude interactive prompt did not become ready".freeze
+  NOW = Time.utc(2026, 7, 10, 15, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+
+    def initialize
+      @events = []
+    end
+
+    def event(name, **attrs)
+      unless Hive::Daemon::Logger::EVENTS.include?(name)
+        raise ArgumentError, "FakeLogger rejected event #{name.inspect}"
+      end
+
+      @events << [ name, attrs ]
+    end
+  end
+
+  def setup
+    @logger = FakeLogger.new
+    @controller = Hive::Daemon::ConcurrencyController.new(
+      max_concurrent_runs: 4,
+      max_concurrent_per_project: 2,
+      max_runs_per_day_per_project: 50
+    )
+  end
+
+  def green_factory
+    lambda { |cache|
+      Hive::Daemon::RecoverableMarkerRetry::Probes.new(
+        cache: cache,
+        runner: lambda { |cmd, _t|
+          st = Struct.new(:exitstatus) do
+            def success? = exitstatus.zero?
+          end.new(0)
+          cmd[1] == "login" ? [ "Logged in", "", st ] : [ "ok", "", st ]
+        },
+        agent_health_check: -> { [ true, "ok" ] },
+        wrapper_path_resolver: lambda {
+          path = File.join(Dir.tmpdir, "hive-it-wrapper-#{Process.pid}")
+          File.write(path, "#!/bin/sh\n") unless File.exist?(path)
+          File.chmod(0o755, path)
+          path
+        },
+        binary_match_check: -> { [ true, "ok" ] },
+        doctor_check: -> { [ true, "ok" ] },
+        ready_detector_check: -> { [ true, "ok" ] }
+      )
+    }
+  end
+
+  def make_retry(**opts)
+    Hive::Daemon::RecoverableMarkerRetry.new(
+      controller: @controller,
+      logger: @logger,
+      enabled: true,
+      probes_factory: green_factory,
+      fingerprint_inputs: { wrapper_mtime: "it-1", daemon_version: "t" },
+      git_status_proc: ->(_p) { false },
+      worktree_path_resolver: ->(_r) { nil },
+      **opts
+    )
+  end
+
+  def status_row(dir, folder, state_file, slug, stage, marker_attrs)
+    Hive::Daemon::StatusConsumer::Row.new(
+      project: File.basename(dir),
+      slug: slug,
+      stage: stage,
+      workflow: "coding",
+      marker: "error",
+      marker_attrs: marker_attrs,
+      folder: folder,
+      state_file: state_file,
+      state_file_mtime: File.mtime(state_file),
+      action: "error",
+      suggested_command: nil,
+      claude_pid_alive: nil,
+      live_task_lock: false,
+      diagnostic: nil
+    )
+  end
+
+  def test_a1_codex_auth_clears_real_marker_file
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+        slug = "retry-auth-260710-aaaa"
+        folder = File.join(dir, ".hive-state", "stages", "4-execute", slug)
+        FileUtils.mkdir_p(folder)
+        state_file = File.join(folder, "task.md")
+        Hive::Markers.set(state_file, :error,
+                          reason: "implementer_failed",
+                          marker_id: "it-auth-1",
+                          message: AUTH_MSG)
+
+        attrs = Hive::Markers.current(state_file).attrs
+        row = status_row(dir, folder, state_file, slug, "4-execute", attrs)
+        make_retry.evaluate([ row ], now: NOW)
+
+        assert_equal :none, Hive::Markers.current(state_file).name
+        assert(@logger.events.any? { |n, _| n == :auto_retry_cleared })
+        state = Hive::Daemon::RecoverableMarkerRetry::StateStore.new(folder)
+                                                                .reason_state("implementer_failed")
+        assert_equal 1, state.attempts
+      end
+    end
+  end
+
+  def test_a2_claude_launch_clears_real_marker_file
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+        slug = "retry-launch-260710-bbbb"
+        folder = File.join(dir, ".hive-state", "stages", "2-brainstorm", slug)
+        FileUtils.mkdir_p(folder)
+        state_file = File.join(folder, "brainstorm.md")
+        File.write(state_file, "# Brainstorm\n\n")
+        Hive::Markers.set(state_file, :error,
+                          reason: "claude_launch_failed",
+                          marker_id: "it-launch-1",
+                          message: LAUNCH_MSG)
+
+        attrs = Hive::Markers.current(state_file).attrs
+        row = status_row(dir, folder, state_file, slug, "2-brainstorm", attrs)
+        make_retry.evaluate([ row ], now: NOW)
+
+        assert_equal :none, Hive::Markers.current(state_file).name
+        cleared = @logger.events.find { |n, _| n == :auto_retry_cleared }
+        assert cleared
+        assert_equal "claude_launcher", cleared[1][:recovery_kind]
+      end
+    end
+  end
+
+  def test_a3_unsigned_implementer_failed_stays_parked
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+        slug = "retry-unsigned-260710-cccc"
+        folder = File.join(dir, ".hive-state", "stages", "4-execute", slug)
+        FileUtils.mkdir_p(folder)
+        state_file = File.join(folder, "task.md")
+        Hive::Markers.set(state_file, :error,
+                          reason: "implementer_failed",
+                          marker_id: "it-u-1",
+                          message: "tests failed: 2 errors")
+
+        attrs = Hive::Markers.current(state_file).attrs
+        row = status_row(dir, folder, state_file, slug, "4-execute", attrs)
+        make_retry.evaluate([ row ], now: NOW)
+
+        assert_equal :error, Hive::Markers.current(state_file).name
+        refute(@logger.events.any? { |n, _| n == :auto_retry_cleared })
+      end
+    end
+  end
+
+  def test_a8_kill_switch_disables_path
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+        slug = "retry-kill-260710-dddd"
+        folder = File.join(dir, ".hive-state", "stages", "4-execute", slug)
+        FileUtils.mkdir_p(folder)
+        state_file = File.join(folder, "task.md")
+        Hive::Markers.set(state_file, :error,
+                          reason: "implementer_failed",
+                          marker_id: "it-k-1",
+                          message: AUTH_MSG)
+
+        attrs = Hive::Markers.current(state_file).attrs
+        row = status_row(dir, folder, state_file, slug, "4-execute", attrs)
+        disabled = Hive::Daemon::RecoverableMarkerRetry.new(
+          controller: @controller,
+          logger: @logger,
+          enabled: false,
+          probes_factory: green_factory
+        )
+        disabled.evaluate([ row ], now: NOW)
+
+        assert_equal :error, Hive::Markers.current(state_file).name
+        assert_empty @logger.events
+      end
+    end
+  end
+end
