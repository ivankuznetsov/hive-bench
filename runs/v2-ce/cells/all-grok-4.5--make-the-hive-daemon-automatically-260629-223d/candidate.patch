diff --git a/lib/hive/daemon/recoverable_marker_retry.rb b/lib/hive/daemon/recoverable_marker_retry.rb
new file mode 100644
index 00000000..3a24d37f
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry.rb
@@ -0,0 +1,502 @@
+# frozen_string_literal: true
+
+require "time"
+
+require "hive/config"
+require "hive/events"
+require "hive/markers"
+require "hive/workflows"
+require "hive/daemon/dispatch_request_queue"
+require "hive/daemon/recoverable_marker_retry/classifier"
+require "hive/daemon/recoverable_marker_retry/probe_cache"
+require "hive/daemon/recoverable_marker_retry/probes"
+require "hive/daemon/recoverable_marker_retry/health_signal"
+require "hive/daemon/recoverable_marker_retry/state_store"
+require "hive/daemon/recoverable_marker_retry/safety"
+
+module Hive
+  module Daemon
+    # Probe-gated auto-retry for a fixed allowlist of parked terminal ERROR
+    # markers (Codex auth 401 / Claude launcher failures). Separate from
+    # StaleAgentHealer: durable per-task budgets, health probes, and
+    # work-area safety guards.
+    #
+    # Pipeline position: after StaleAgentHealer#heal, before per-row
+    # policy dispatch. Clear mechanics match manual `hive markers clear`
+    # + same-stage re-run (including 3-plan DispatchRequestQueue requeue).
+    class RecoverableMarkerRetry
+      MAX_ATTEMPTS = 2
+      SKIP_LOG_THROTTLE_SEC = 300 # throttle negative audits per fingerprint
+
+      attr_reader :enabled, :controller, :logger, :request_queue
+
+      def initialize(controller:, logger:, enabled: true,
+                     request_queue: Hive::Daemon::DispatchRequestQueue,
+                     probes_factory: nil,
+                     fingerprint_inputs: nil,
+                     git_status_proc: nil,
+                     worktree_path_resolver: nil,
+                     events: Hive::Events,
+                     config: nil,
+                     project_root: nil)
+        @controller = controller
+        @logger = logger
+        @enabled = enabled
+        @request_queue = request_queue
+        @config = config
+        @project_root = project_root
+        # nil = production default (build Probes with resolved live config).
+        # Tests inject a custom |cache| factory and keep that contract.
+        @probes_factory = probes_factory
+        @fingerprint_inputs = fingerprint_inputs
+        @git_status_proc = git_status_proc
+        @worktree_path_resolver = worktree_path_resolver
+        @events = events
+      end
+
+      # Walk parked ERROR rows and auto-clear recoverable ones when probes
+      # and safety allow. `now:` freezes the tick clock like every other
+      # daemon collaborator.
+      def evaluate(rows, now: Time.now, legacy_layout_projects: {})
+        return unless @enabled
+
+        rows = Array(rows)
+        # Skip fingerprint FS work (skill digest + auth sample) when the
+        # fleet has no parked ERROR candidates this tick.
+        return unless rows.any? { |row| row.marker.to_s == "error" }
+
+        cfg, root = resolve_config_context(rows)
+        cache = ProbeCache.new
+        probes =
+          if @probes_factory
+            @probes_factory.call(cache)
+          else
+            Probes.new(cache: cache, config: cfg, project_root: root)
+          end
+        fp_inputs = @fingerprint_inputs || HealthSignal.collect_inputs(
+          config: cfg,
+          project_root: root
+        )
+        fingerprint = HealthSignal.fingerprint(fp_inputs)
+
+        rows.each do |row|
+          evaluate_row(
+            row,
+            now: now,
+            legacy_layout_projects: legacy_layout_projects,
+            probes: probes,
+            fingerprint: fingerprint
+          )
+        end
+      end
+
+      # Reset durable state after a successful manual `hive markers clear`
+      # of an ERROR marker. No-op when reason is missing — plan IU4 resets
+      # per cleared reason only (non-ERROR clears must not wipe budget).
+      def self.reset_state_for_clear!(task_folder, reason: nil)
+        return if reason.nil? || reason.to_s.empty?
+
+        StateStore.new(task_folder).reset_reason!(reason)
+      end
+
+      private
+
+      # Prefer explicit project_root / injected config; otherwise load the
+      # first ERROR row's project config so skill inventory + agent_health
+      # see live overrides (not bare DEFAULTS). Falls back to DEFAULTS when
+      # the daemon only holds global daemon/update blocks without stage keys.
+      def resolve_config_context(rows)
+        if @project_root && !@project_root.to_s.empty?
+          loaded = load_project_config(@project_root)
+          return [ loaded, @project_root ] if loaded
+          return [ injected_or_defaults_config, @project_root ]
+        end
+
+        error_row = rows.find { |row| row.marker.to_s == "error" }
+        if error_row
+          path = project_path_for(error_row.project)
+          if path
+            loaded = load_project_config(path)
+            return [ loaded, path ] if loaded
+          end
+        end
+
+        [ injected_or_defaults_config, nil ]
+      end
+
+      def load_project_config(path)
+        Hive::Config.load(path)
+      rescue Hive::ConfigError, SystemCallError, ArgumentError
+        nil
+      end
+
+      def injected_or_defaults_config
+        cfg = @config
+        return cfg if cfg.is_a?(Hash) && stage_config_present?(cfg)
+
+        Hive::Config::DEFAULTS
+      end
+
+      def project_path_for(project_name)
+        entry =
+          begin
+            Hive::Config.find_project(project_name)
+          rescue StandardError
+            nil
+          end
+        return nil unless entry.is_a?(Hash)
+
+        path = entry["path"].to_s
+        return nil if path.empty? || !File.directory?(path)
+
+        path
+      end
+
+      def stage_config_present?(cfg)
+        cfg.key?("agents") || cfg.key?("brainstorm") || cfg.key?("plan") || cfg.key?("review")
+      end
+
+      def evaluate_row(row, now:, legacy_layout_projects:, probes:, fingerprint:)
+        return if legacy_layout_projects.include?(row.project)
+        return unless row.marker.to_s == "error"
+        return if row.live_task_lock == true
+        return if @controller.running_task?(project: row.project, slug: row.slug)
+        return if row.state_file_mtime.nil?
+        return if row.folder.to_s.empty?
+
+        classification = Classifier.classify(row)
+        reason = classification.reason.to_s
+
+        unless classification.eligible
+          # Throttled negative audit only for explicit non-allowlist on
+          # error markers that look like they might have been candidates
+          # (implementer_failed without signature). Unknown reasons stay quiet.
+          if reason == "implementer_failed"
+            maybe_log_skip(row, reason: reason, recovery_kind: nil,
+                                fingerprint: fingerprint, now: now,
+                                rationale: classification.deny_rationale || "not retried: unknown reason",
+                                action: "skipped")
+          end
+          return
+        end
+
+        store = StateStore.new(row.folder)
+        loaded = store.load
+        unless loaded[:ok]
+          log_decision(
+            :auto_retry_skipped, row,
+            recovery_kind: classification.recovery_kind,
+            marker_reason: reason,
+            fingerprint: fingerprint,
+            attempts: 0,
+            action: "skipped",
+            rationale: "not retried: corrupt auto_retry state (#{loaded[:error]})"
+          )
+          return
+        end
+
+        state = loaded[:by_reason][reason]
+        attempts = state&.attempts.to_i
+
+        if state&.exhausted || attempts >= MAX_ATTEMPTS
+          store.record_exhausted!(
+            reason,
+            fingerprint: fingerprint,
+            now: now,
+            rationale: "not retried: budget exhausted",
+            recovery_kind: classification.recovery_kind
+          ) unless state&.exhausted
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: "not retried: budget exhausted",
+            action: "exhausted",
+            attempts: attempts,
+            event: :auto_retry_exhausted
+          )
+          return
+        end
+
+        last_attempt_at = parse_time(state&.last_attempt_at)
+        gate = HealthSignal.retry_allowed?(
+          attempts: attempts,
+          last_attempt_at: last_attempt_at,
+          last_attempt_fingerprint: state&.last_attempt_fingerprint,
+          current_fingerprint: fingerprint,
+          now: now
+        )
+        case gate
+        when :exhausted
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: "not retried: budget exhausted",
+            action: "exhausted",
+            attempts: attempts,
+            event: :auto_retry_exhausted
+          )
+          return
+        when :blocked_same_signal
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: "not retried: health signal unchanged since last attempt",
+            action: "skipped",
+            attempts: attempts
+          )
+          return
+        when :blocked_backoff
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: "not retried: backoff not elapsed",
+            action: "skipped",
+            attempts: attempts
+          )
+          return
+        end
+
+        # R8 / IU3: throttle expensive probe suites per task/reason.
+        # Re-probe only when never probed, fingerprint changed, or the
+        # periodic floor (PERIODIC_REPROBE_SEC) has elapsed. Durable
+        # last_probe_* is the source of truth across daemon restarts.
+        last_probe_at = parse_time(state&.last_probe_at)
+        unless HealthSignal.should_reprobe?(
+          last_probe_at: last_probe_at,
+          last_probe_fingerprint: state&.last_probe_fingerprint,
+          current_fingerprint: fingerprint,
+          now: now
+        )
+          return
+        end
+
+        # Retry gate already enforced signal-change / backoff. Run the
+        # probe suite now; the tick-scoped ProbeCache keeps shell-outs
+        # cheap when many rows share the same env fingerprint.
+        suite = probes.run_suite(classification.recovery_kind, fingerprint_slice: fingerprint)
+        store.record_probe!(
+          reason,
+          fingerprint: fingerprint,
+          now: now,
+          recovery_kind: classification.recovery_kind
+        )
+
+        unless suite.ok
+          failed = suite.failed_probe || "probe"
+          rationale = "not retried: #{failed} failed"
+          # maybe_log_skip records durable skip state; do not pre-write
+          # last_skip_* or the throttle would suppress this tick's audit.
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: rationale,
+            action: "skipped",
+            attempts: attempts,
+            probe_results: probe_summary(suite)
+          )
+          return
+        end
+
+        safety = Safety.check(
+          row,
+          git_status_proc: @git_status_proc,
+          worktree_path_resolver: @worktree_path_resolver
+        )
+        unless safety.safe
+          maybe_log_skip(
+            row, reason: reason, recovery_kind: classification.recovery_kind,
+            fingerprint: fingerprint, now: now,
+            rationale: safety.rationale,
+            action: "skipped",
+            attempts: attempts,
+            probe_results: probe_summary(suite)
+          )
+          return
+        end
+
+        match_attrs = clear_match_attrs(row, reason: reason)
+        cleared = Hive::Markers.clear_current(
+          row.state_file,
+          expected_name: :error,
+          match_attrs: match_attrs
+        )
+        # Race / marker_id mismatch: silent no-op, do not burn budget.
+        return unless cleared
+
+        observe_pre_clear_mtime(row)
+        store.record_attempt!(
+          reason,
+          recovery_kind: classification.recovery_kind,
+          fingerprint: fingerprint,
+          now: now,
+          decision: "retried",
+          rationale: "retried: #{classification.recovery_kind} probes green"
+        )
+        new_attempts = attempts + 1
+
+        log_decision(
+          :auto_retry_cleared, row,
+          recovery_kind: classification.recovery_kind,
+          marker_reason: reason,
+          fingerprint: fingerprint,
+          attempts: new_attempts,
+          action: "cleared",
+          rationale: "retried: #{classification.recovery_kind} probes green",
+          probe_results: probe_summary(suite),
+          signature_matched: classification.signature_matched
+        )
+        emit_task_event(
+          row,
+          message: "auto_retry cleared reason=#{reason} kind=#{classification.recovery_kind} " \
+                   "attempts=#{new_attempts}/#{MAX_ATTEMPTS}"
+        )
+
+        requeue_plan_rerun(row) if coding_plan_row?(row)
+      rescue StandardError => e
+        @logger.event(
+          :auto_retry_skipped,
+          project: row.project,
+          slug: row.slug,
+          stage: row.stage,
+          action: "skipped",
+          rationale: "not retried: internal error",
+          error: "#{e.class}: #{e.message}"
+        )
+      end
+
+      def clear_match_attrs(row, reason:)
+        attrs = (row.marker_attrs || {}).to_h.transform_keys(&:to_s)
+        marker_id = attrs["marker_id"].to_s
+        match_attrs = { "reason" => reason }
+        match_attrs["marker_id"] = marker_id.empty? ? nil : marker_id
+        match_attrs
+      end
+
+      def observe_pre_clear_mtime(row)
+        return unless @controller.respond_to?(:observe_state_file_mtime)
+
+        @controller.observe_state_file_mtime(
+          project: row.project,
+          slug: row.slug,
+          mtime: row.state_file_mtime
+        )
+      end
+
+      def coding_plan_row?(row)
+        Hive::Workflows.coding_row?(row) && row.stage.to_s == "3-plan"
+      end
+
+      def requeue_plan_rerun(row)
+        request_id = @request_queue.write_request!(
+          project: row.project,
+          slug: row.slug,
+          argv: [ "hive", "plan", row.slug, "--project", row.project, "--from", "3-plan" ],
+          requestor: "healer",
+          trigger: "auto_retry_claude_launcher"
+        )
+        @logger.event(
+          :heal_requeued,
+          project: row.project,
+          slug: row.slug,
+          stage: row.stage,
+          request_id: request_id,
+          source: "recoverable_marker_retry"
+        )
+      rescue StandardError => e
+        @logger.event(
+          :heal_requeue_failed,
+          project: row.project,
+          slug: row.slug,
+          stage: row.stage,
+          error: "#{e.class}: #{e.message}",
+          remediation: "hive plan #{row.slug} --project #{row.project} --from 3-plan",
+          source: "recoverable_marker_retry"
+        )
+      end
+
+      def maybe_log_skip(row, reason:, recovery_kind:, fingerprint:, now:, rationale:,
+                        action:, attempts: 0, probe_results: nil, event: :auto_retry_skipped)
+        store = StateStore.new(row.folder)
+        state = store.reason_state(reason)
+        last_skip_at = parse_time(state&.last_skip_at)
+        last_fp = state&.last_skip_fingerprint.to_s
+        if last_skip_at && last_fp == fingerprint.to_s && (now - last_skip_at) < SKIP_LOG_THROTTLE_SEC
+          return
+        end
+
+        store.record_skip!(
+          reason,
+          fingerprint: fingerprint,
+          now: now,
+          rationale: rationale,
+          recovery_kind: recovery_kind
+        ) if action == "skipped" || action == "exhausted"
+
+        log_decision(
+          event, row,
+          recovery_kind: recovery_kind,
+          marker_reason: reason,
+          fingerprint: fingerprint,
+          attempts: attempts,
+          action: action,
+          rationale: rationale,
+          probe_results: probe_results
+        )
+        emit_task_event(row, message: "auto_retry #{action}: #{rationale}")
+      end
+
+      def log_decision(event, row, recovery_kind:, marker_reason:, fingerprint:, attempts:,
+                       action:, rationale:, probe_results: nil, signature_matched: nil)
+        attrs = {
+          project: row.project,
+          slug: row.slug,
+          stage: row.stage,
+          marker_id: marker_id_for(row),
+          marker_reason: marker_reason,
+          recovery_kind: recovery_kind&.to_s,
+          health_signal_fingerprint: fingerprint,
+          attempts: attempts,
+          max_attempts: MAX_ATTEMPTS,
+          action: action,
+          rationale: rationale
+        }
+        attrs[:probe_results] = probe_results if probe_results
+        attrs[:signature_matched] = signature_matched if signature_matched
+        @logger.event(event, **attrs)
+      end
+
+      def emit_task_event(row, message:)
+        @events.emit(
+          task_folder: row.folder,
+          slug: row.slug,
+          stage: row.stage,
+          event_type: :auto_retry,
+          agent: "daemon",
+          message: message
+        )
+      rescue StandardError
+        nil
+      end
+
+      def marker_id_for(row)
+        attrs = (row.marker_attrs || {}).to_h.transform_keys(&:to_s)
+        attrs["marker_id"]
+      end
+
+      def probe_summary(suite)
+        Array(suite.probes).each_with_object({}) do |probe, acc|
+          acc[probe.name.to_s] = probe.ok
+        end
+      end
+
+      def parse_time(value)
+        return nil if value.nil? || value.to_s.empty?
+        return value if value.is_a?(Time)
+
+        Time.parse(value.to_s)
+      rescue ArgumentError, TypeError
+        nil
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/classifier.rb b/lib/hive/daemon/recoverable_marker_retry/classifier.rb
new file mode 100644
index 00000000..61bdbe61
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/classifier.rb
@@ -0,0 +1,190 @@
+# frozen_string_literal: true
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Pure classifier: given a status row's marker attrs (and optional
+      # diagnostic text already captured on the marker), decide whether the
+      # parked ERROR is a v1 auto-retry candidate — before expensive probes.
+      #
+      # Deny-by-default: only the fixed allowlist of reasons with recognized
+      # diagnostic signatures are eligible. Callers must still enforce
+      # live-lock / running-task preconditions (documented below).
+      #
+      # Precondition (caller enforces): `row.live_task_lock` is not true and
+      # the concurrency controller does not report the task as running.
+      module Classifier
+        Result = Struct.new(
+          :eligible,
+          :recovery_kind,
+          :reason,
+          :signature_matched,
+          :deny_rationale,
+          keyword_init: true
+        )
+
+        # Multi-pattern Codex auth failure matcher. Prefer several explicit
+        # case-insensitive substrings over a single fragile regex so we do
+        # not auto-retry generic implementer failures.
+        CODEX_AUTH_HTTP_PATTERNS = [
+          /\b401\b/,
+          /unauthorized/i,
+          /http\s*401/i
+        ].freeze
+
+        # Strong Codex-auth wording: eligible alone (no HTTP code required).
+        CODEX_AUTH_SPECIFIC_PATTERNS = [
+          /missing\s+bearer(?:\s*\/\s*|\s+or\s+|\/)basic\s+auth/i,
+          /missing\s+bearer/i,
+          /missing\s+basic\s+auth/i,
+          /bearer\s+token/i,
+          /not\s+logged\s+in/i,
+          /authentication\s+required/i,
+          /login\s+required/i
+        ].freeze
+
+        # Generic auth wording: only eligible with HTTP 401 or Codex context.
+        CODEX_AUTH_GENERIC_PATTERNS = [
+          /auth(?:entication)?\s+failed/i,
+          /invalid\s+(?:api\s+)?key/i
+        ].freeze
+
+        # Codex / OpenAI surface tokens that disambiguate generic auth text
+        # from business-logic implementer failures.
+        CODEX_CONTEXT_PATTERNS = [
+          /\bcodex\b/i,
+          /\bopenai\b/i,
+          /missing\s+bearer/i,
+          /bearer\s+token/i,
+          /basic\s+auth/i
+        ].freeze
+
+        module_function
+
+        def classify(row)
+          marker = row.marker.to_s
+          unless marker == "error"
+            return deny("not retried: not an error marker", reason: nil)
+          end
+
+          attrs = marker_attrs(row)
+          reason = attrs["reason"].to_s
+          if reason.empty?
+            return deny("not retried: missing marker reason", reason: reason)
+          end
+
+          message = diagnostic_text(attrs, row)
+
+          case reason
+          when "implementer_failed"
+            classify_implementer_failed(reason, message)
+          when "claude_launch_failed"
+            classify_claude_launch_failed(reason, message)
+          else
+            deny("not retried: unknown reason", reason: reason)
+          end
+        end
+
+        def classify_implementer_failed(reason, message)
+          if message.to_s.strip.empty?
+            return deny("not retried: empty implementer_failed message", reason: reason)
+          end
+
+          signature = codex_auth_signature(message)
+          unless signature
+            return deny("not retried: implementer_failed without codex auth signature",
+                        reason: reason)
+          end
+
+          Result.new(
+            eligible: true,
+            recovery_kind: :codex_auth,
+            reason: reason,
+            signature_matched: signature,
+            deny_rationale: nil
+          )
+        end
+        private_class_method :classify_implementer_failed
+
+        def classify_claude_launch_failed(reason, message)
+          if message.to_s.strip.empty?
+            return deny("not retried: empty claude_launch_failed message", reason: reason)
+          end
+
+          Result.new(
+            eligible: true,
+            recovery_kind: :claude_launcher,
+            reason: reason,
+            signature_matched: "claude_launch_failed",
+            deny_rationale: nil
+          )
+        end
+        private_class_method :classify_claude_launch_failed
+
+        def codex_auth_signature(message)
+          text = message.to_s
+          has_http = CODEX_AUTH_HTTP_PATTERNS.any? { |re| re.match?(text) }
+          has_specific = CODEX_AUTH_SPECIFIC_PATTERNS.any? { |re| re.match?(text) }
+          has_generic = CODEX_AUTH_GENERIC_PATTERNS.any? { |re| re.match?(text) }
+          has_auth = has_specific || has_generic
+          has_codex_context = CODEX_CONTEXT_PATTERNS.any? { |re| re.match?(text) } || has_specific
+          return nil unless has_http || has_auth
+
+          # Prefer the stronger joint signal when both sides match (R1/IU1).
+          if has_http && has_auth
+            "codex_auth_401"
+          elsif has_http
+            # Alone, a bare 401 is not enough — many non-auth failures echo
+            # status codes. Require auth wording for eligibility.
+            nil
+          elsif has_specific || (has_generic && has_codex_context)
+            # Specific Codex login / bearer wording, or generic auth text
+            # only when Codex/OpenAI context is also present.
+            "codex_auth_message"
+          else
+            # Generic "authentication failed" / "invalid api key" without
+            # Codex context must not auto-retry business-logic failures.
+            nil
+          end
+        end
+        private_class_method :codex_auth_signature
+
+        def marker_attrs(row)
+          attrs = row.respond_to?(:marker_attrs) ? row.marker_attrs : nil
+          (attrs || {}).to_h.transform_keys(&:to_s)
+        end
+        private_class_method :marker_attrs
+
+        def diagnostic_text(attrs, row)
+          parts = []
+          %w[message error_message diagnostic detail].each do |key|
+            value = attrs[key]
+            parts << value.to_s unless value.nil? || value.to_s.empty?
+          end
+          if row.respond_to?(:diagnostic) && row.diagnostic
+            diag = row.diagnostic
+            if diag.is_a?(Hash)
+              parts << diag["message"].to_s if diag["message"]
+              parts << diag["summary"].to_s if diag["summary"]
+            else
+              parts << diag.to_s
+            end
+          end
+          parts.join("\n")
+        end
+        private_class_method :diagnostic_text
+
+        def deny(rationale, reason:)
+          Result.new(
+            eligible: false,
+            recovery_kind: nil,
+            reason: reason,
+            signature_matched: nil,
+            deny_rationale: rationale
+          )
+        end
+        private_class_method :deny
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/health_signal.rb b/lib/hive/daemon/recoverable_marker_retry/health_signal.rb
new file mode 100644
index 00000000..e7c04b8a
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/health_signal.rb
@@ -0,0 +1,250 @@
+# frozen_string_literal: true
+
+require "digest"
+require "hive/invoked_binary"
+require "hive/agent_profiles"
+require "hive/config"
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Builds a stable health-signal fingerprint and decides when to
+      # re-run probes / allow another auto-retry attempt.
+      #
+      # After a failed auto-retry attempt, a fingerprint *change* is
+      # required before another attempt (R9). Periodic re-probe may
+      # refresh probe cache/audit but must not clear the marker without
+      # that signal change.
+      module HealthSignal
+        PERIODIC_REPROBE_SEC = 600 # 10 minutes
+        SECOND_ATTEMPT_BACKOFF_SEC = 30 * 60 # 30 minutes
+        # Doctor-aligned stage keys used for skill-inventory digest /
+        # universal agent_health (brainstorm + plan carry configured skills).
+        SKILL_STAGES = %w[brainstorm plan].freeze
+
+        module_function
+
+        # Build fingerprint from injectable inputs (frozen clocks / env in tests).
+        def fingerprint(inputs = {})
+          pieces = [
+            inputs[:daemon_binary_path].to_s,
+            inputs[:daemon_version].to_s,
+            inputs[:hive_codex_bin].to_s,
+            inputs[:codex_home].to_s,
+            inputs[:hive_claude_bin].to_s,
+            inputs[:hive_invoked_bin].to_s,
+            inputs[:codex_bin_config].to_s,
+            inputs[:claude_bin_config].to_s,
+            inputs[:skill_inventory_digest].to_s,
+            inputs[:codex_login_state].to_s,
+            inputs[:wrapper_path].to_s,
+            inputs[:wrapper_mtime].to_s,
+            inputs[:manual_clear_generation].to_s
+          ]
+          ::Digest::SHA256.hexdigest(pieces.join("|"))[0, 32]
+        end
+
+        # Collect fingerprint inputs from the live process / env / config.
+        # `skill_inventory_digest` and `codex_login_state` default to cheap
+        # in-process samples so operator fixes (codex login, skill install)
+        # change the fingerprint without waiting for shell probe results.
+        def collect_inputs(env: ENV, version: Hive::VERSION, wrapper_path: nil, skill_inventory_digest: nil,
+                           codex_login_state: nil, manual_clear_generation: nil, config: nil,
+                           project_root: nil, home: nil)
+          wrapper = wrapper_path || Hive::InvokedBinary.path(env: env)
+          wrapper_mtime =
+            begin
+              wrapper && File.exist?(wrapper) ? File.mtime(wrapper).to_f : ""
+            rescue SystemCallError
+              ""
+            end
+
+          cfg = config || Hive::Config::DEFAULTS
+          agents = cfg["agents"].is_a?(Hash) ? cfg["agents"] : Hive::Config::DEFAULTS["agents"]
+          home_dir = home || env["HOME"] || Dir.home
+
+          {
+            daemon_binary_path: wrapper.to_s,
+            daemon_version: version.to_s,
+            hive_codex_bin: env["HIVE_CODEX_BIN"].to_s,
+            codex_home: env["CODEX_HOME"].to_s,
+            hive_claude_bin: env["HIVE_CLAUDE_BIN"].to_s,
+            hive_invoked_bin: env["HIVE_INVOKED_BIN"].to_s,
+            codex_bin_config: agents.dig("codex", "bin").to_s,
+            claude_bin_config: agents.dig("claude", "bin").to_s,
+            skill_inventory_digest: (skill_inventory_digest || skill_inventory_digest_for(cfg, project_root: project_root)).to_s,
+            codex_login_state: (codex_login_state || codex_login_state_for(home: home_dir, env: env)).to_s,
+            wrapper_path: wrapper.to_s,
+            wrapper_mtime: wrapper_mtime.to_s,
+            manual_clear_generation: manual_clear_generation.to_s
+          }
+        end
+
+        # Cheap codex login signal for fingerprinting (R9 / IU3): credential
+        # presence + auth-file mtime/size/content prefix so `codex login`
+        # without wrapper/env changes still rotates the fingerprint.
+        # Resolve auth tree the same way codex children do: CODEX_HOME when
+        # set, otherwise ~/.codex under `home`.
+        def codex_login_state_for(home: Dir.home, env: ENV, codex_home: nil)
+          base = codex_home.to_s
+          base = env["CODEX_HOME"].to_s if base.empty?
+          base = File.join(home.to_s, ".codex") if base.empty?
+          path = File.join(base, "auth.json")
+          logged_in = Hive::AgentProfiles.credential_present?(path)
+          prefix = logged_in ? "ok" : "fail"
+          return "#{prefix}:missing" unless File.file?(path)
+
+          mtime =
+            begin
+              File.mtime(path).to_f
+            rescue SystemCallError
+              0
+            end
+          size =
+            begin
+              File.size(path)
+            rescue SystemCallError
+              0
+            end
+          content_hash =
+            begin
+              ::Digest::SHA256.hexdigest(File.read(path, 512).to_s)[0, 12]
+            rescue SystemCallError, Errno::EISDIR
+              "unreadable"
+            end
+          "#{prefix}:#{mtime}:#{size}:#{content_hash}"
+        rescue StandardError
+          "unknown"
+        end
+
+        # In-process doctor-subset skill inventory digest (paths + status).
+        # Used as a fingerprint input so installing/updating skills rotates
+        # the signal without shelling `hive doctor`.
+        def skill_inventory_digest_for(config = nil, project_root: nil)
+          cfg = config || Hive::Config::DEFAULTS
+          pieces = skill_check_rows(cfg, project_root: project_root).map do |row|
+            [
+              row[:kind],
+              row[:stage],
+              row[:agent],
+              row[:skill],
+              row[:status],
+              row[:message]
+            ].join("|")
+          end
+          ::Digest::SHA256.hexdigest(pieces.join(";"))[0, 32]
+        rescue StandardError => e
+          "error:#{e.class}"
+        end
+
+        # Shared doctor-subset rows for fingerprint digest + agent_health.
+        # Returns array of hashes with :kind :stage :agent :skill :status :message.
+        def skill_check_rows(config = nil, project_root: nil)
+          cfg = config || Hive::Config::DEFAULTS
+          rows = []
+
+          SKILL_STAGES.each do |stage|
+            agent_name = (cfg.dig(stage, "agent") || "claude").to_s
+            skill =
+              begin
+                Hive::Config.stage_skill(cfg, stage)
+              rescue StandardError
+                cfg.dig(stage, "skill")
+              end
+            next if skill.nil? || skill.to_s.empty?
+
+            rows << skill_row_for(
+              kind: "stage",
+              stage: stage,
+              agent_name: agent_name,
+              skill: skill,
+              project_root: project_root
+            )
+          end
+
+          Array(cfg.dig("review", "reviewers")).each do |spec|
+            next unless spec.is_a?(Hash)
+
+            kind = (spec["kind"] || "agent").to_s
+            next unless kind == "agent"
+
+            agent_name = spec["agent"].to_s
+            bare = spec["skill"].to_s
+            next if agent_name.empty? || bare.empty?
+
+            rows << skill_row_for(
+              kind: "reviewer",
+              stage: "6-review",
+              agent_name: agent_name,
+              skill: bare,
+              project_root: project_root,
+              label: spec["name"].to_s
+            )
+          end
+
+          rows
+        end
+
+        def skill_row_for(kind:, stage:, agent_name:, skill:, project_root:, label: nil)
+          profile = Hive::AgentProfiles.lookup(agent_name.to_sym)
+          invocation = profile.format_skill_invocation(skill)
+          status, message = profile.verify_skill(invocation, project_root: project_root)
+          {
+            kind: kind,
+            stage: stage,
+            label: label || stage,
+            agent: agent_name,
+            skill: invocation,
+            status: status.to_s,
+            message: message.to_s
+          }
+        rescue StandardError => e
+          {
+            kind: kind,
+            stage: stage,
+            label: label || stage,
+            agent: agent_name,
+            skill: skill.to_s,
+            status: "missing",
+            message: "#{e.class}: #{e.message}"
+          }
+        end
+        private_class_method :skill_row_for
+
+        # Should we re-run probes this tick?
+        # true when: never probed, fingerprint changed, or periodic floor elapsed.
+        def should_reprobe?(last_probe_at:, last_probe_fingerprint:, current_fingerprint:, now:,
+                            periodic_sec: PERIODIC_REPROBE_SEC)
+          return true if last_probe_at.nil?
+          return true if last_probe_fingerprint.to_s.empty?
+          return true if last_probe_fingerprint.to_s != current_fingerprint.to_s
+
+          elapsed = now - last_probe_at
+          elapsed >= periodic_sec
+        end
+
+        # After a failed attempt, require fingerprint change before retry.
+        # Attempt 1: allowed immediately when probes green + signal ready.
+        # Attempt 2: needs 30m backoff AND fingerprint change.
+        def retry_allowed?(attempts:, last_attempt_at:, last_attempt_fingerprint:,
+                           current_fingerprint:, now:, max_attempts: RecoverableMarkerRetry::MAX_ATTEMPTS,
+                           backoff_sec: SECOND_ATTEMPT_BACKOFF_SEC)
+          attempts = attempts.to_i
+          return :exhausted if attempts >= max_attempts
+          return :allowed if attempts.zero?
+
+          # Subsequent attempts require signal change.
+          if last_attempt_fingerprint.to_s == current_fingerprint.to_s
+            return :blocked_same_signal
+          end
+
+          if last_attempt_at && (now - last_attempt_at) < backoff_sec
+            return :blocked_backoff
+          end
+
+          :allowed
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/probe_cache.rb b/lib/hive/daemon/recoverable_marker_retry/probe_cache.rb
new file mode 100644
index 00000000..8836cb3a
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/probe_cache.rb
@@ -0,0 +1,41 @@
+# frozen_string_literal: true
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Tick-scoped cache for probe results. Created at the start of a
+      # dispatcher evaluate pass and discarded after. Keyed by
+      # (probe_name, fingerprint_slice) so reason-level suites reuse the
+      # universal agent_health result and do not re-run codex smoke for
+      # every parked task when the env fingerprint is unchanged.
+      class ProbeCache
+        def initialize
+          @store = {}
+        end
+
+        def fetch(name, fingerprint_slice)
+          key = cache_key(name, fingerprint_slice)
+          return @store[key] if @store.key?(key)
+
+          result = yield
+          @store[key] = result
+          result
+        end
+
+        def size
+          @store.size
+        end
+
+        def clear!
+          @store.clear
+        end
+
+        private
+
+        def cache_key(name, fingerprint_slice)
+          [ name.to_s, fingerprint_slice.to_s ]
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/probes.rb b/lib/hive/daemon/recoverable_marker_retry/probes.rb
new file mode 100644
index 00000000..0fe56365
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/probes.rb
@@ -0,0 +1,427 @@
+# frozen_string_literal: true
+
+require "digest"
+require "open3"
+
+require "hive/agent_profiles"
+require "hive/invoked_binary"
+require "hive/claude_launcher"
+require "hive/config"
+require "hive/daemon/recoverable_marker_retry/health_signal"
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Probe suite for recoverable-marker auto-retry. Mixes in-process Hive
+      # checks with shell-outs for external CLIs. Every probe returns a
+      # result hash; timeouts / spawn errors / non-zero exits become
+      # `ok: false` without raising out of the tick.
+      class Probes
+        OUTPUT_TRUNCATE_BYTES = 4 * 1024
+        AGENT_HEALTH_TIMEOUT_SEC = 15
+        CODEX_LOGIN_TIMEOUT_SEC = 15
+        CODEX_SMOKE_TIMEOUT_SEC = 30
+        CLAUDE_READY_TIMEOUT_SEC = 10
+        HIVE_DOCTOR_TIMEOUT_SEC = 30
+        # Short drain budget after child exit before Thread#kill on pipe
+        # readers (mirrors DiagnosisAgent; tighter than its 5s grace).
+        READER_DRAIN_SEC = 0.5
+
+        CODEX_SMOKE_PROMPT = "Reply with the single word ok and nothing else.".freeze
+
+        CODEX_LOGGED_IN_PATTERNS = [
+          /logged\s+in/i,
+          /login\s+status:\s*logged/i,
+          /auth(?:entication)?\s*(?:ok|valid|success)/i
+        ].freeze
+
+        CODEX_NOT_LOGGED_IN_PATTERNS = [
+          /not\s+logged\s+in/i,
+          /logged\s+out/i,
+          /login\s+required/i,
+          /unauthenticated/i
+        ].freeze
+
+        Result = Struct.new(
+          :name, :ok, :duration_ms, :stdout, :stderr, :error,
+          keyword_init: true
+        ) do
+          def to_h
+            {
+              name: name,
+              ok: ok,
+              duration_ms: duration_ms,
+              stdout: stdout,
+              stderr: stderr,
+              error: error
+            }
+          end
+        end
+
+        SuiteResult = Struct.new(:ok, :probes, :failed_probe, keyword_init: true)
+
+        def initialize(cache: nil, runner: nil, env: ENV, clock: -> { Process.clock_gettime(Process::CLOCK_MONOTONIC) },
+                       agent_health_check: nil, wrapper_path_resolver: nil,
+                       binary_match_check: nil, doctor_check: nil,
+                       ready_detector_check: nil, config: nil, project_root: nil)
+          @cache = cache || ProbeCache.new
+          @runner = runner || method(:default_runner)
+          @env = env
+          @clock = clock
+          @config = config
+          @project_root = project_root
+          @agent_health_check = agent_health_check || method(:default_agent_health)
+          @wrapper_path_resolver = wrapper_path_resolver || method(:default_wrapper_path)
+          @binary_match_check = binary_match_check || method(:default_binary_match)
+          @doctor_check = doctor_check || method(:default_doctor_check)
+          @ready_detector_check = ready_detector_check || method(:default_ready_detector)
+        end
+
+        attr_reader :cache
+
+        def run_suite(recovery_kind, fingerprint_slice: "")
+          probes = []
+          universal = cached_probe("agent_health", fingerprint_slice) { agent_health }
+          probes << universal
+          return suite_fail(probes, universal) unless universal.ok
+
+          case recovery_kind.to_sym
+          when :codex_auth
+            login = cached_probe("codex_login_status", fingerprint_slice) { codex_login_status }
+            probes << login
+            return suite_fail(probes, login) unless login.ok
+
+            smoke = cached_probe("codex_exec_smoke", fingerprint_slice) { codex_exec_smoke }
+            probes << smoke
+            return suite_fail(probes, smoke) unless smoke.ok
+          when :claude_launcher
+            wrapper = cached_probe("claude_wrapper_present", fingerprint_slice) { claude_wrapper_present }
+            probes << wrapper
+            return suite_fail(probes, wrapper) unless wrapper.ok
+
+            ready = cached_probe("claude_ready_detector", fingerprint_slice) { claude_ready_detector }
+            probes << ready
+            return suite_fail(probes, ready) unless ready.ok
+
+            binary = cached_probe("daemon_binary_match", fingerprint_slice) { daemon_binary_match }
+            probes << binary
+            return suite_fail(probes, binary) unless binary.ok
+
+            doctor = cached_probe("hive_doctor_green", fingerprint_slice) { hive_doctor_green }
+            probes << doctor
+            return suite_fail(probes, doctor) unless doctor.ok
+          else
+            return SuiteResult.new(
+              ok: false,
+              probes: probes,
+              failed_probe: "unknown_recovery_kind"
+            )
+          end
+
+          SuiteResult.new(ok: true, probes: probes, failed_probe: nil)
+        end
+
+        def agent_health
+          timed("agent_health") do
+            ok, detail = @agent_health_check.call
+            [ ok, detail.to_s, "" ]
+          end
+        end
+
+        def codex_login_status
+          timed("codex_login_status") do
+            bin = codex_bin
+            out, err, status = @runner.call([ bin, "login", "status" ], CODEX_LOGIN_TIMEOUT_SEC)
+            combined = "#{out}\n#{err}"
+            if !status
+              [ false, out, err.empty? ? "timeout or spawn error" : err ]
+            elsif CODEX_NOT_LOGGED_IN_PATTERNS.any? { |re| re.match?(combined) }
+              [ false, out, err.empty? ? "not logged in" : err ]
+            elsif status.respond_to?(:success?) ? status.success? : status.to_i.zero?
+              # R4: require a positive logged-in indication. Empty/ambiguous
+              # exit-0 output must not false-green the gate before smoke.
+              logged_in = CODEX_LOGGED_IN_PATTERNS.any? { |re| re.match?(combined) }
+              [ logged_in, out, err.empty? ? (logged_in ? "" : "login status unclear") : err ]
+            else
+              [ false, out, err.empty? ? "exit #{status_code(status)}" : err ]
+            end
+          end
+        end
+
+        def codex_exec_smoke
+          timed("codex_exec_smoke") do
+            bin = codex_bin
+            cmd = [
+              bin, "exec",
+              "--dangerously-bypass-approvals-and-sandbox",
+              "--json",
+              CODEX_SMOKE_PROMPT
+            ]
+            out, err, status = @runner.call(cmd, CODEX_SMOKE_TIMEOUT_SEC)
+            ok = status && (status.respond_to?(:success?) ? status.success? : status.to_i.zero?)
+            [ ok, out, err.empty? ? (ok ? "" : "codex exec smoke failed") : err ]
+          end
+        end
+
+        def claude_wrapper_present
+          timed("claude_wrapper_present") do
+            path = @wrapper_path_resolver.call
+            if path && File.file?(path) && File.executable?(path)
+              [ true, path, "" ]
+            else
+              [ false, path.to_s, "wrapper missing or not executable" ]
+            end
+          end
+        end
+
+        def claude_ready_detector
+          timed("claude_ready_detector") do
+            ok, detail = @ready_detector_check.call
+            [ ok, detail.to_s, ok ? "" : detail.to_s ]
+          end
+        end
+
+        def daemon_binary_match
+          timed("daemon_binary_match") do
+            ok, detail = @binary_match_check.call
+            [ ok, detail.to_s, ok ? "" : detail.to_s ]
+          end
+        end
+
+        def hive_doctor_green
+          timed("hive_doctor_green") do
+            ok, detail = @doctor_check.call
+            [ ok, detail.to_s, ok ? "" : detail.to_s ]
+          end
+        end
+
+        private
+
+        def cached_probe(name, fingerprint_slice, &block)
+          @cache.fetch(name, fingerprint_slice, &block)
+        end
+
+        def suite_fail(probes, failed)
+          SuiteResult.new(ok: false, probes: probes, failed_probe: failed.name)
+        end
+
+        def timed(name)
+          started = @clock.call
+          ok = false
+          stdout = ""
+          stderr = ""
+          error = nil
+          begin
+            ok, stdout, stderr = yield
+            ok = !!ok
+          rescue StandardError => e
+            ok = false
+            error = "#{e.class}: #{e.message}"
+            stderr = error
+          end
+          duration_ms = ((@clock.call - started) * 1000).round
+          Result.new(
+            name: name,
+            ok: ok,
+            duration_ms: duration_ms,
+            stdout: truncate_output(stdout),
+            stderr: truncate_output(stderr),
+            error: error
+          )
+        end
+
+        def truncate_output(text)
+          s = text.to_s
+          return s if s.bytesize <= OUTPUT_TRUNCATE_BYTES
+
+          # Keep the trailing window (most useful for CLI failure tails).
+          s.byteslice(-OUTPUT_TRUNCATE_BYTES, OUTPUT_TRUNCATE_BYTES).to_s.scrub("")
+        end
+
+        def codex_bin
+          override = @env["HIVE_CODEX_BIN"].to_s
+          return override unless override.empty?
+
+          Hive::AgentProfiles.lookup(:codex).bin
+        rescue StandardError
+          "codex"
+        end
+
+        def status_code(status)
+          return status.exitstatus if status.respond_to?(:exitstatus)
+
+          status.to_i
+        end
+
+        # Default shell runner: popen3 in its own process group with
+        # SIGTERM/SIGKILL on timeout. Returns [stdout, stderr, status_or_nil].
+        # status is nil on timeout/spawn error. Mirrors DiagnosisAgent /
+        # Tui::Subprocess#bounded_capture3 so hung codex/claude children are
+        # not orphaned when the timer fires (Timeout.timeout alone unwinds
+        # without signalling the child).
+        def default_runner(cmd, timeout_sec)
+          started = @clock.call
+          Open3.popen3(@env.to_h, *Array(cmd), pgroup: true) do |stdin, stdout, stderr, wait_thr|
+            begin
+              stdin.close
+            rescue StandardError
+              nil
+            end
+            out_reader = Thread.new { read_probe_stream(stdout) }
+            err_reader = Thread.new { read_probe_stream(stderr) }
+            loop do
+              if wait_thr.join(0.05)
+                return [
+                  safe_thread_value(out_reader),
+                  safe_thread_value(err_reader),
+                  wait_thr.value
+                ]
+              end
+
+              elapsed = @clock.call - started
+              next if elapsed < timeout_sec.to_f
+
+              terminate_probe_process_group(wait_thr.pid)
+              # Give the child a short moment to exit so we can reap it;
+              # status stays nil to signal timeout to callers.
+              wait_thr.join(0.5)
+              return [ "", "timeout after #{timeout_sec}s", nil ]
+            end
+          end
+        rescue SystemCallError, ArgumentError => e
+          [ "", "#{e.class}: #{e.message}", nil ]
+        end
+
+        def read_probe_stream(stream)
+          stream.read
+        rescue IOError
+          ""
+        end
+
+        def safe_thread_value(thread)
+          # Drain briefly after child exit so a slow flush of
+          # `codex login status` is not truncated by immediate Thread#kill.
+          thread.join(READER_DRAIN_SEC) if thread.alive?
+          thread.kill if thread.alive?
+          thread.value.to_s
+        rescue StandardError
+          ""
+        end
+
+        def terminate_probe_process_group(pid)
+          return unless pid.is_a?(Integer) && pid > 1
+
+          begin
+            Process.kill("TERM", -pid)
+          rescue Errno::ESRCH, Errno::EPERM
+            nil
+          end
+          sleep 0.1
+          begin
+            Process.kill("KILL", -pid)
+          rescue Errno::ESRCH, Errno::EPERM
+            nil
+          end
+        end
+
+        # Universal agent-health (R3 / IU2): profile bins resolve AND the
+        # lightweight doctor skill subset has no missing / version_too_old
+        # rows. Applies to both codex_auth and claude_launcher paths so a
+        # missing stage skill cannot auto-clear either recovery kind.
+        def default_agent_health
+          issues = []
+          cfg = @config || Hive::Config::DEFAULTS
+
+          %i[claude codex].each do |name|
+            profile =
+              begin
+                Hive::AgentProfiles.lookup(name, cfg: cfg)
+              rescue StandardError
+                Hive::AgentProfiles.lookup(name)
+              end
+            bin = profile.bin
+            unless bin && !bin.to_s.empty?
+              issues << "#{name}: no bin"
+              next
+            end
+            # PATH-relative bins are acceptable; only fail hard absolute
+            # paths that clearly do not exist.
+            if bin.include?(File::SEPARATOR) && !(File.file?(bin) && File.executable?(bin))
+              issues << "#{name}: #{bin} missing"
+            end
+          rescue StandardError => e
+            issues << "#{name}: #{e.class}"
+          end
+
+          HealthSignal.skill_check_rows(cfg, project_root: @project_root).each do |row|
+            status = row[:status].to_s
+            next unless status == "missing" || status == "version_too_old"
+
+            issues << "#{row[:label] || row[:stage]}: #{status} (#{row[:skill]})"
+          end
+
+          [ issues.empty?, issues.empty? ? "ok" : issues.join("; ") ]
+        end
+
+        def default_wrapper_path
+          Hive::InvokedBinary.path(env: @env) ||
+            Hive::InvokedBinary.wrapper_path(@env)
+        end
+
+        def default_binary_match
+          wrapper = default_wrapper_path
+          resolved = Hive::InvokedBinary.path(env: @env)
+          if wrapper.nil? && resolved.nil?
+            # No wrapper env in this process (common in unit tests / bare
+            # ruby). Treat as match — binary identity is only meaningful
+            # when the daemon was launched via the install wrapper.
+            return [ true, "no_wrapper_env" ]
+          end
+
+          return [ false, "wrapper missing" ] if wrapper.nil?
+          return [ false, "resolved binary missing" ] if resolved.nil?
+
+          begin
+            same = File.expand_path(wrapper) == File.expand_path(resolved)
+            same ||= File.identical?(wrapper, resolved)
+          rescue SystemCallError
+            same = false
+          end
+          [ same, "wrapper=#{wrapper} resolved=#{resolved}" ]
+        end
+
+        def default_doctor_check
+          # In-process preference: verify claude/codex bins + version flags
+          # without shelling `hive doctor` (slow, needs project root).
+          issues = []
+          %i[claude codex].each do |name|
+            profile = Hive::AgentProfiles.lookup(name)
+            profile.check_version!
+          rescue Hive::AgentError => e
+            issues << "#{name}: #{e.message}"
+          rescue StandardError => e
+            issues << "#{name}: #{e.class}: #{e.message}"
+          end
+          [ issues.empty?, issues.empty? ? "ok" : issues.join("; ") ]
+        end
+
+        def default_ready_detector
+          # Exercise the pure readiness classifier against a fixture pane
+          # that mirrors a healthy Claude Code ready prompt. Does not
+          # spawn a full agent session.
+          fixture = <<~PANE
+            Claude Code
+            v2.1.179
+
+            ❯
+            for agents
+          PANE
+          ok = Hive::ClaudeLauncher.claude_ready_prompt?(fixture)
+          [ ok, ok ? "detector accepts ready prompt" : "detector rejected fixture ready prompt" ]
+        rescue StandardError => e
+          [ false, "#{e.class}: #{e.message}" ]
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/safety.rb b/lib/hive/daemon/recoverable_marker_retry/safety.rb
new file mode 100644
index 00000000..fb77081c
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/safety.rb
@@ -0,0 +1,212 @@
+# frozen_string_literal: true
+
+require "yaml"
+
+require "hive/brainstorm_parser"
+require "hive/git_ops"
+require "hive/markers"
+require "hive/task"
+require "hive/worktree"
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Refuse auto-retry when retry might overwrite user edits or
+      # partial answered content. Uncertain ⇒ unsafe (fail closed).
+      module Safety
+        TERMINAL_SUCCESS_MARKERS = %w[
+          execute_complete
+          review_complete
+          complete
+          plan_complete
+          brainstorm_complete
+        ].freeze
+
+        # Known terminal-success HTML comments that may appear without a
+        # Markers.current match (e.g. mid-file COMPLETE stamp).
+        TERMINAL_SUCCESS_PATTERNS = [
+          /<!--\s*EXECUTE_COMPLETE\b/i,
+          /<!--\s*REVIEW_COMPLETE\b/i,
+          /<!--\s*COMPLETE\b/i,
+          /<!--\s*PLAN_COMPLETE\b/i
+        ].freeze
+
+        Result = Struct.new(:safe, :rationale, keyword_init: true)
+
+        module_function
+
+        def check(row, git_status_proc: nil, worktree_path_resolver: nil)
+          if row.respond_to?(:live_task_lock) && row.live_task_lock == true
+            return unsafe("not retried: live task lock")
+          end
+
+          state_file = row.state_file.to_s
+          if state_file.empty? || !File.exist?(state_file)
+            return unsafe("not retried: missing state file")
+          end
+
+          if terminal_success?(state_file)
+            return unsafe("not retried: terminal success output present")
+          end
+
+          stage = row.stage.to_s
+          case stage
+          when "4-execute"
+            check_execute(row, git_status_proc: git_status_proc,
+                               worktree_path_resolver: worktree_path_resolver)
+          when "2-brainstorm"
+            check_brainstorm(row)
+          when "3-plan"
+            check_plan(row)
+          else
+            # Other stages with claude_launch_failed: only safe when the
+            # state file is essentially empty of stage body content.
+            check_generic_launch(row)
+          end
+        end
+
+        def check_execute(row, git_status_proc: nil, worktree_path_resolver: nil)
+          path = if worktree_path_resolver
+                   worktree_path_resolver.call(row)
+                 else
+                   resolve_worktree_path(row)
+                 end
+
+          # Missing worktree is safe — execute recreates it on re-entry.
+          return safe_result if path.nil? || !File.directory?(path)
+
+          dirty = if git_status_proc
+                    git_status_proc.call(path)
+                  else
+                    worktree_dirty?(path)
+                  end
+
+          return unsafe("not retried: dirty worktree") if dirty
+
+          safe_result
+        rescue StandardError => e
+          unsafe("not retried: safety check error (#{e.class})")
+        end
+        private_class_method :check_execute
+
+        def check_brainstorm(row)
+          folder = row.folder.to_s
+          path = File.join(folder, "brainstorm.md")
+          return safe_result unless File.exist?(path)
+
+          body = File.read(path, encoding: "UTF-8").to_s.scrub
+          questions = Hive::BrainstormParser.parse_text(body)
+          if questions.any?(&:answered?)
+            return unsafe("not retried: brainstorm has answered rounds")
+          end
+
+          # Non-trivial body without a clean unanswered-only structure is
+          # ambiguous — fail closed.
+          stripped = strip_markers_and_headers(body)
+          if stripped.bytesize > 200 && questions.empty?
+            return unsafe("not retried: ambiguous brainstorm content")
+          end
+
+          safe_result
+        rescue StandardError => e
+          unsafe("not retried: safety check error (#{e.class})")
+        end
+        private_class_method :check_brainstorm
+
+        def check_plan(row)
+          state_file = row.state_file.to_s
+          body = File.read(state_file, encoding: "UTF-8").to_s.scrub
+
+          if body.match?(/<!--\s*COMPLETE\b/i)
+            return unsafe("not retried: plan has COMPLETE stamp")
+          end
+
+          stripped = strip_markers_and_headers(body)
+          # Empty / AGENT_WORKING-only / minimal plan is safe to re-run.
+          return safe_result if stripped.strip.empty?
+          return safe_result if stripped.bytesize < 80
+
+          # Substantial plan body after a launch failure is ambiguous —
+          # re-running from scratch could clobber partial agent writes
+          # that an operator may want to keep.
+          unsafe("not retried: ambiguous plan content")
+        rescue StandardError => e
+          unsafe("not retried: safety check error (#{e.class})")
+        end
+        private_class_method :check_plan
+
+        def check_generic_launch(row)
+          body = File.read(row.state_file, encoding: "UTF-8").to_s.scrub
+          stripped = strip_markers_and_headers(body)
+          return safe_result if stripped.strip.empty? || stripped.bytesize < 80
+
+          unsafe("not retried: ambiguous stage content")
+        rescue StandardError => e
+          unsafe("not retried: safety check error (#{e.class})")
+        end
+        private_class_method :check_generic_launch
+
+        def terminal_success?(state_file)
+          marker = Hive::Markers.current(state_file)
+          name = marker.name.to_s.downcase
+          return true if TERMINAL_SUCCESS_MARKERS.include?(name)
+
+          body = File.read(state_file, encoding: "UTF-8").to_s
+          TERMINAL_SUCCESS_PATTERNS.any? { |re| re.match?(body) }
+        rescue StandardError
+          # Fail closed on unreadable state.
+          true
+        end
+        private_class_method :terminal_success?
+
+        def resolve_worktree_path(row)
+          folder = row.folder.to_s
+          return nil if folder.empty?
+
+          task = Hive::Task.new(folder)
+          path = task.worktree_path
+          path && !path.to_s.empty? ? path : nil
+        rescue StandardError
+          # Fall back to worktree.yml pointer if Task construction fails.
+          pointer = File.join(folder, "worktree.yml")
+          return nil unless File.exist?(pointer)
+
+          data = YAML.safe_load(File.read(pointer)) || {}
+          data["path"]
+        rescue StandardError
+          nil
+        end
+        private_class_method :resolve_worktree_path
+
+        def worktree_dirty?(path)
+          git = Hive::GitOps.new(path)
+          git.dirty?
+        rescue StandardError
+          # Uncertain dirty state ⇒ unsafe.
+          true
+        end
+        private_class_method :worktree_dirty?
+
+        def strip_markers_and_headers(body)
+          body.each_line.reject do |line|
+            line.match?(/\A\s*<!--/) ||
+              line.match?(/\A\s*#/) ||
+              line.match?(/\A\s*---\s*\z/) ||
+              line.strip.empty?
+          end.join
+        end
+        private_class_method :strip_markers_and_headers
+
+        def safe_result
+          Result.new(safe: true, rationale: nil)
+        end
+        private_class_method :safe_result
+
+        def unsafe(rationale)
+          Result.new(safe: false, rationale: rationale)
+        end
+        private_class_method :unsafe
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/recoverable_marker_retry/state_store.rb b/lib/hive/daemon/recoverable_marker_retry/state_store.rb
new file mode 100644
index 00000000..1644ab10
--- /dev/null
+++ b/lib/hive/daemon/recoverable_marker_retry/state_store.rb
@@ -0,0 +1,254 @@
+# frozen_string_literal: true
+
+require "fileutils"
+require "json"
+require "securerandom"
+require "time"
+
+module Hive
+  module Daemon
+    class RecoverableMarkerRetry
+      # Durable per-task auto-retry budget under the task folder.
+      # Survives daemon restart (unlike StaleAgentHealer in-memory maps).
+      #
+      # Atomic write (tmp + rename). Unreadable / corrupt state is
+      # fail-closed: callers must not auto-retry.
+      class StateStore
+        SCHEMA = "hive-auto-retry-state.v1".freeze
+        FILENAME = "auto_retry_state.json".freeze
+
+        ReasonState = Struct.new(
+          :recovery_kind,
+          :attempts,
+          :last_attempt_at,
+          :last_attempt_fingerprint,
+          :last_probe_at,
+          :last_probe_fingerprint,
+          :last_decision,
+          :last_rationale,
+          :exhausted,
+          :last_skip_at,
+          :last_skip_fingerprint,
+          keyword_init: true
+        ) do
+          def to_h
+            {
+              "recovery_kind" => recovery_kind,
+              "attempts" => attempts.to_i,
+              "last_attempt_at" => last_attempt_at,
+              "last_attempt_fingerprint" => last_attempt_fingerprint,
+              "last_probe_at" => last_probe_at,
+              "last_probe_fingerprint" => last_probe_fingerprint,
+              "last_decision" => last_decision,
+              "last_rationale" => last_rationale,
+              "exhausted" => !!exhausted,
+              "last_skip_at" => last_skip_at,
+              "last_skip_fingerprint" => last_skip_fingerprint
+            }
+          end
+        end
+
+        def self.path_for(task_folder)
+          File.join(task_folder.to_s, FILENAME)
+        end
+
+        def initialize(task_folder)
+          @task_folder = task_folder.to_s
+          @path = self.class.path_for(@task_folder)
+        end
+
+        attr_reader :path, :task_folder
+
+        # Returns { ok: bool, by_reason: Hash{String => ReasonState}, error: String? }
+        def load
+          return { ok: true, by_reason: {}, error: nil } unless File.exist?(@path)
+
+          raw = File.read(@path, encoding: "UTF-8")
+          data = JSON.parse(raw)
+          unless data.is_a?(Hash) && data["schema"] == SCHEMA
+            return { ok: false, by_reason: {}, error: "unrecognized schema" }
+          end
+
+          by_reason = {}
+          (data["by_reason"] || {}).each do |reason, payload|
+            next unless payload.is_a?(Hash)
+
+            by_reason[reason.to_s] = reason_state_from_hash(payload)
+          end
+          { ok: true, by_reason: by_reason, error: nil }
+        rescue JSON::ParserError, EncodingError, SystemCallError => e
+          { ok: false, by_reason: {}, error: "#{e.class}: #{e.message}" }
+        end
+
+        def reason_state(reason)
+          result = load
+          return nil unless result[:ok]
+
+          result[:by_reason][reason.to_s]
+        end
+
+        def update_reason!(reason, **attrs)
+          result = load
+          return false unless result[:ok]
+
+          by_reason = result[:by_reason]
+          current = by_reason[reason.to_s] || ReasonState.new(
+            recovery_kind: nil,
+            attempts: 0,
+            last_attempt_at: nil,
+            last_attempt_fingerprint: nil,
+            last_probe_at: nil,
+            last_probe_fingerprint: nil,
+            last_decision: nil,
+            last_rationale: nil,
+            exhausted: false,
+            last_skip_at: nil,
+            last_skip_fingerprint: nil
+          )
+
+          attrs.each do |key, value|
+            setter = "#{key}="
+            current.public_send(setter, value) if current.respond_to?(setter)
+          end
+          by_reason[reason.to_s] = current
+          write!(by_reason)
+        end
+
+        def record_attempt!(reason, recovery_kind:, fingerprint:, now:, decision: "retried",
+                            rationale: nil, max_attempts: RecoverableMarkerRetry::MAX_ATTEMPTS)
+          result = load
+          return false unless result[:ok]
+
+          current = result[:by_reason][reason.to_s]
+          attempts = (current&.attempts || 0) + 1
+          exhausted = attempts >= max_attempts
+          update_reason!(
+            reason,
+            recovery_kind: recovery_kind.to_s,
+            attempts: attempts,
+            last_attempt_at: iso(now),
+            last_attempt_fingerprint: fingerprint.to_s,
+            last_probe_at: iso(now),
+            last_probe_fingerprint: fingerprint.to_s,
+            last_decision: decision,
+            last_rationale: rationale,
+            exhausted: exhausted
+          )
+        end
+
+        def record_probe!(reason, fingerprint:, now:, decision: nil, rationale: nil, recovery_kind: nil)
+          attrs = {
+            last_probe_at: iso(now),
+            last_probe_fingerprint: fingerprint.to_s
+          }
+          attrs[:last_decision] = decision if decision
+          attrs[:last_rationale] = rationale if rationale
+          attrs[:recovery_kind] = recovery_kind.to_s if recovery_kind
+          update_reason!(reason, **attrs)
+        end
+
+        def record_skip!(reason, fingerprint:, now:, rationale:, recovery_kind: nil)
+          attrs = {
+            last_decision: "skipped",
+            last_rationale: rationale,
+            last_skip_at: iso(now),
+            last_skip_fingerprint: fingerprint.to_s,
+            last_probe_at: iso(now),
+            last_probe_fingerprint: fingerprint.to_s
+          }
+          attrs[:recovery_kind] = recovery_kind.to_s if recovery_kind
+          update_reason!(reason, **attrs)
+        end
+
+        def record_exhausted!(reason, fingerprint:, now:, rationale:, recovery_kind: nil)
+          attrs = {
+            exhausted: true,
+            last_decision: "exhausted",
+            last_rationale: rationale,
+            last_probe_at: iso(now),
+            last_probe_fingerprint: fingerprint.to_s
+          }
+          attrs[:recovery_kind] = recovery_kind.to_s if recovery_kind
+          update_reason!(reason, **attrs)
+        end
+
+        # Manual `hive markers clear` escape hatch: drop the reason budget
+        # so a future failure can auto-retry again.
+        def reset_reason!(reason)
+          result = load
+          return false unless result[:ok]
+
+          by_reason = result[:by_reason]
+          by_reason.delete(reason.to_s)
+          write!(by_reason)
+        end
+
+        def reset_all!
+          return true unless File.exist?(@path)
+
+          File.delete(@path)
+          true
+        rescue Errno::ENOENT
+          true
+        rescue SystemCallError
+          false
+        end
+
+        private
+
+        def reason_state_from_hash(payload)
+          ReasonState.new(
+            recovery_kind: payload["recovery_kind"],
+            attempts: payload["attempts"].to_i,
+            last_attempt_at: payload["last_attempt_at"],
+            last_attempt_fingerprint: payload["last_attempt_fingerprint"],
+            last_probe_at: payload["last_probe_at"],
+            last_probe_fingerprint: payload["last_probe_fingerprint"],
+            last_decision: payload["last_decision"],
+            last_rationale: payload["last_rationale"],
+            exhausted: payload["exhausted"] == true,
+            last_skip_at: payload["last_skip_at"],
+            last_skip_fingerprint: payload["last_skip_fingerprint"]
+          )
+        end
+
+        def write!(by_reason)
+          FileUtils.mkdir_p(@task_folder)
+          payload = {
+            "schema" => SCHEMA,
+            "by_reason" => by_reason.transform_values(&:to_h)
+          }
+          dir = @task_folder
+          tmp = File.join(
+            dir,
+            ".#{FILENAME}.tmp.#{Process.pid}.#{Thread.current.object_id}.#{SecureRandom.hex(4)}"
+          )
+          File.open(tmp, File::WRONLY | File::CREAT | File::TRUNC, 0o644, encoding: "UTF-8") do |file|
+            file.write(JSON.pretty_generate(payload))
+            file.flush
+            begin
+              file.fsync
+            rescue Errno::EINVAL, Errno::ENOSYS, IOError
+              nil
+            end
+          end
+          File.rename(tmp, @path)
+          true
+        rescue SystemCallError
+          begin
+            File.delete(tmp) if tmp && File.exist?(tmp)
+          rescue Errno::ENOENT, SystemCallError
+            nil
+          end
+          false
+        end
+
+        def iso(time)
+          time = Time.now if time.nil?
+          time = Time.at(time) if time.is_a?(Numeric)
+          time.respond_to?(:utc) ? time.utc.iso8601 : time.to_s
+        end
+      end
+    end
+  end
+end
