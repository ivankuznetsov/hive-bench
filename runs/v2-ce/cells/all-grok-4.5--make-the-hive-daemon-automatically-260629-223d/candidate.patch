+++ b/test/unit/daemon/recoverable_marker_retry/classifier_test.rb
@@ -0,0 +1,135 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/daemon/recoverable_marker_retry"
+require "hive/daemon/status_consumer"
+
+class RecoverableMarkerRetryClassifierTest < Minitest::Test
+  include HiveTestHelper
+
+  Row = Hive::Daemon::StatusConsumer::Row
+  Classifier = Hive::Daemon::RecoverableMarkerRetry::Classifier
+
+  def make_row(marker: "error", marker_attrs: {}, diagnostic: nil, stage: "4-execute")
+    Row.new(
+      project: "p", slug: "s", stage: stage, workflow: "coding",
+      marker: marker, marker_attrs: marker_attrs, folder: "/tmp/x",
+      state_file: "/tmp/x/task.md", state_file_mtime: Time.now,
+      action: "error", suggested_command: nil,
+      claude_pid_alive: nil, live_task_lock: nil, diagnostic: diagnostic
+    )
+  end
+
+  def test_implementer_failed_with_401_bearer_is_codex_auth
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "HTTP 401: Missing bearer/basic auth"
+    })
+    result = Classifier.classify(row)
+    assert result.eligible
+    assert_equal :codex_auth, result.recovery_kind
+    assert_equal "implementer_failed", result.reason
+    assert_equal "codex_auth_401", result.signature_matched
+  end
+
+  def test_implementer_failed_with_auth_wording_only
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "codex: not logged in — run codex login"
+    })
+    result = Classifier.classify(row)
+    assert result.eligible
+    assert_equal :codex_auth, result.recovery_kind
+    assert_equal "codex_auth_message", result.signature_matched
+  end
+
+  def test_implementer_failed_bare_auth_failed_without_codex_context_not_eligible
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "authentication failed while applying patch"
+    })
+    result = Classifier.classify(row)
+    refute result.eligible
+    assert_match(/without codex auth signature/, result.deny_rationale)
+  end
+
+  def test_implementer_failed_invalid_api_key_with_codex_context_eligible
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "codex: invalid api key"
+    })
+    result = Classifier.classify(row)
+    assert result.eligible
+    assert_equal :codex_auth, result.recovery_kind
+    assert_equal "codex_auth_message", result.signature_matched
+  end
+
+  def test_implementer_failed_generic_tests_failed_not_eligible
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "tests failed: 3 failures in suite"
+    })
+    result = Classifier.classify(row)
+    refute result.eligible
+    assert_nil result.recovery_kind
+    assert_match(/without codex auth signature/, result.deny_rationale)
+  end
+
+  def test_implementer_failed_empty_message_not_eligible
+    row = make_row(marker_attrs: { "reason" => "implementer_failed", "message" => "" })
+    result = Classifier.classify(row)
+    refute result.eligible
+    assert_match(/empty/, result.deny_rationale)
+  end
+
+  def test_implementer_failed_bare_401_without_auth_wording_not_eligible
+    row = make_row(marker_attrs: {
+      "reason" => "implementer_failed",
+      "message" => "upstream returned 401"
+    })
+    result = Classifier.classify(row)
+    refute result.eligible
+  end
+
+  def test_claude_launch_failed_with_message_is_eligible
+    row = make_row(
+      stage: "2-brainstorm",
+      marker_attrs: {
+        "reason" => "claude_launch_failed",
+        "message" => "claude interactive prompt did not become ready"
+      }
+    )
+    result = Classifier.classify(row)
+    assert result.eligible
+    assert_equal :claude_launcher, result.recovery_kind
+    assert_equal "claude_launch_failed", result.signature_matched
+  end
+
+  def test_claude_launch_failed_empty_message_not_eligible
+    row = make_row(marker_attrs: { "reason" => "claude_launch_failed" })
+    result = Classifier.classify(row)
+    refute result.eligible
+  end
+
+  def test_other_reasons_never_eligible
+    %w[limits_reached unpushed_commits tmux_session_terminated agent_orphaned
+       timeout dirty_worktree ensure_clean_on_exit_failed].each do |reason|
+      row = make_row(marker_attrs: { "reason" => reason, "message" => "anything" })
+      result = Classifier.classify(row)
+      refute result.eligible, "expected #{reason} not eligible"
+      assert_match(/unknown reason/, result.deny_rationale)
+    end
+  end
+
+  def test_non_error_marker_not_eligible
+    row = make_row(marker: "agent_working", marker_attrs: { "reason" => "implementer_failed" })
+    result = Classifier.classify(row)
+    refute result.eligible
+  end
+
+  def test_missing_reason_not_eligible
+    row = make_row(marker_attrs: { "message" => "HTTP 401 Missing bearer" })
+    result = Classifier.classify(row)
+    refute result.eligible
+  end
+end
