+# frozen_string_literal: true
+
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/recoverable_marker_retry"
+
+class RecoverableMarkerRetryHealthSignalTest < Minitest::Test
+  include HiveTestHelper
+
+  HS = Hive::Daemon::RecoverableMarkerRetry::HealthSignal
+  NOW = Time.utc(2026, 7, 10, 12, 0, 0)
+
+  def base_inputs(overrides = {})
+    {
+      daemon_binary_path: "/usr/bin/hive",
+      daemon_version: "0.3.2",
+      hive_codex_bin: "",
+      codex_home: "",
+      hive_claude_bin: "",
+      hive_invoked_bin: "/usr/bin/hive",
+      codex_bin_config: "",
+      claude_bin_config: "",
+      skill_inventory_digest: "abc",
+      codex_login_state: "ok:deadbeef",
+      wrapper_path: "/usr/bin/hive",
+      wrapper_mtime: "1000.0",
+      manual_clear_generation: ""
+    }.merge(overrides)
+  end
+
+  def test_fingerprint_stable_for_same_inputs
+    a = HS.fingerprint(base_inputs)
+    b = HS.fingerprint(base_inputs)
+    assert_equal a, b
+    assert_equal 32, a.length
+  end
+
+  def test_wrapper_mtime_change_changes_fingerprint
+    a = HS.fingerprint(base_inputs(wrapper_mtime: "1000.0"))
+    b = HS.fingerprint(base_inputs(wrapper_mtime: "2000.0"))
+    refute_equal a, b
+  end
+
+  def test_unchanged_fingerprint_within_periodic_window_skips_reprobe
+    fp = HS.fingerprint(base_inputs)
+    refute HS.should_reprobe?(
+      last_probe_at: NOW - 60,
+      last_probe_fingerprint: fp,
+      current_fingerprint: fp,
+      now: NOW,
+      periodic_sec: 600
+    )
+  end
+
+  def test_periodic_floor_allows_reprobe
+    fp = HS.fingerprint(base_inputs)
+    assert HS.should_reprobe?(
+      last_probe_at: NOW - 601,
+      last_probe_fingerprint: fp,
+      current_fingerprint: fp,
+      now: NOW,
+      periodic_sec: 600
+    )
+  end
+
+  def test_fingerprint_change_allows_reprobe
+    assert HS.should_reprobe?(
+      last_probe_at: NOW - 10,
+      last_probe_fingerprint: "old",
+      current_fingerprint: "new",
+      now: NOW
+    )
+  end
+
+  def test_never_probed_allows_reprobe
+    assert HS.should_reprobe?(
+      last_probe_at: nil,
+      last_probe_fingerprint: nil,
+      current_fingerprint: "fp",
+      now: NOW
+    )
+  end
+
+  def test_after_failed_attempt_same_fingerprint_blocks_retry
+    gate = HS.retry_allowed?(
+      attempts: 1,
+      last_attempt_at: NOW - 3600,
+      last_attempt_fingerprint: "same",
+      current_fingerprint: "same",
+      now: NOW
+    )
+    assert_equal :blocked_same_signal, gate
+  end
+
+  def test_after_failed_attempt_fingerprint_change_and_backoff_allows
+    gate = HS.retry_allowed?(
+      attempts: 1,
+      last_attempt_at: NOW - (30 * 60) - 1,
+      last_attempt_fingerprint: "old",
+      current_fingerprint: "new",
+      now: NOW
+    )
+    assert_equal :allowed, gate
+  end
+
+  def test_second_attempt_before_backoff_blocked
+    gate = HS.retry_allowed?(
+      attempts: 1,
+      last_attempt_at: NOW - 60,
+      last_attempt_fingerprint: "old",
+      current_fingerprint: "new",
+      now: NOW
+    )
+    assert_equal :blocked_backoff, gate
+  end
+
+  def test_first_attempt_allowed_immediately
+    gate = HS.retry_allowed?(
+      attempts: 0,
+      last_attempt_at: nil,
+      last_attempt_fingerprint: nil,
+      current_fingerprint: "fp",
+      now: NOW
+    )
+    assert_equal :allowed, gate
+  end
+
+  def test_exhausted_at_max_attempts
+    gate = HS.retry_allowed?(
+      attempts: 2,
+      last_attempt_at: NOW - 10_000,
+      last_attempt_fingerprint: "old",
+      current_fingerprint: "new",
+      now: NOW
+    )
+    assert_equal :exhausted, gate
+  end
+
+  def test_collect_inputs_populates_config_bins_and_live_signals
+    Dir.mktmpdir do |home|
+      codex_dir = File.join(home, ".codex")
+      FileUtils.mkdir_p(codex_dir)
+      auth = File.join(codex_dir, "auth.json")
+      File.write(auth, '{"tokens":{"access":"x"}}')
+
+      inputs = HS.collect_inputs(
+        env: { "HOME" => home, "HIVE_CODEX_BIN" => "/opt/codex" },
+        version: "9.9.9",
+        wrapper_path: nil,
+        home: home,
+        config: {
+          "agents" => {
+            "codex" => { "bin" => "/cfg/codex" },
+            "claude" => { "bin" => "/cfg/claude" }
+          },
+          "brainstorm" => { "agent" => "claude", "skill" => "/ce-brainstorm" },
+          "plan" => { "agent" => "claude", "skill" => "/plan" },
+          "review" => { "reviewers" => [] }
+        }
+      )
+
+      assert_equal "/cfg/codex", inputs[:codex_bin_config]
+      assert_equal "/cfg/claude", inputs[:claude_bin_config]
+      assert_equal "/opt/codex", inputs[:hive_codex_bin]
+      refute_empty inputs[:skill_inventory_digest]
+      assert_match(/\Aok:/, inputs[:codex_login_state])
+    end
+  end
+
+  def test_codex_login_state_changes_when_auth_file_changes
+    Dir.mktmpdir do |home|
+      codex_dir = File.join(home, ".codex")
+      FileUtils.mkdir_p(codex_dir)
+      auth = File.join(codex_dir, "auth.json")
+      File.write(auth, '{"tokens":{"access":"a"}}')
+      a = HS.codex_login_state_for(home: home)
+      File.write(auth, '{"tokens":{"access":"b-different"}}')
+      b = HS.codex_login_state_for(home: home)
+      refute_equal a, b
+    end
+  end
+
+  def test_codex_login_state_samples_auth_under_codex_home
+    Dir.mktmpdir do |base|
+      home = File.join(base, "home")
+      codex_home = File.join(base, "custom-codex")
+      FileUtils.mkdir_p(File.join(home, ".codex"))
+      FileUtils.mkdir_p(codex_home)
+      # Stale default tree must not be sampled when CODEX_HOME is set.
+      File.write(File.join(home, ".codex", "auth.json"), '{"tokens":{"access":"stale-default"}}')
+      auth = File.join(codex_home, "auth.json")
+      File.write(auth, '{"tokens":{"access":"live-under-codex-home"}}')
+
+      state = HS.codex_login_state_for(
+        home: home,
+        env: { "CODEX_HOME" => codex_home, "HOME" => home }
+      )
+      assert_match(/\Aok:/, state)
+
+      File.write(auth, '{"tokens":{"access":"rotated-under-codex-home"}}')
+      rotated = HS.codex_login_state_for(
+        home: home,
+        env: { "CODEX_HOME" => codex_home, "HOME" => home }
+      )
+      refute_equal state, rotated,
+                   "auth changes under CODEX_HOME must rotate the login signal"
+    end
+  end
+
+  def test_collect_inputs_skill_digest_uses_injected_config_not_defaults_only
+    custom = {
+      "agents" => {
+        "codex" => { "bin" => "/custom/codex" },
+        "claude" => { "bin" => "/custom/claude" }
+      },
+      "brainstorm" => { "agent" => "claude", "skill" => "/custom-brainstorm-skill" },
+      "plan" => { "agent" => "claude", "skill" => "/custom-plan-skill" },
+      "review" => {
+        "reviewers" => [
+          { "kind" => "agent", "agent" => "claude", "skill" => "custom-reviewer", "name" => "custom" }
+        ]
+      }
+    }
+    with_custom = HS.collect_inputs(
+      env: { "HOME" => Dir.home },
+      version: "1.0.0",
+      wrapper_path: nil,
+      config: custom,
+      codex_login_state: "ok:test"
+    )
+    with_defaults = HS.collect_inputs(
+      env: { "HOME" => Dir.home },
+      version: "1.0.0",
+      wrapper_path: nil,
+      config: Hive::Config::DEFAULTS,
+      codex_login_state: "ok:test"
+    )
+    refute_equal with_custom[:skill_inventory_digest], with_defaults[:skill_inventory_digest],
+                 "live config skill overrides must change the skill-inventory digest"
+    assert_equal "/custom/codex", with_custom[:codex_bin_config]
+  end
+end
diff --git a/test/unit/daemon/recoverable_marker_retry/probes_test.rb b/test/unit/daemon/recoverable_marker_retry/probes_test.rb
new file mode 100644
index 00000000..ffea13b6
--- /dev/null
+++ b/test/unit/daemon/recoverable_marker_retry/probes_test.rb
@@ -0,0 +1,162 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/daemon/recoverable_marker_retry"
+
+class RecoverableMarkerRetryProbesTest < Minitest::Test
+  include HiveTestHelper
+
+  Probes = Hive::Daemon::RecoverableMarkerRetry::Probes
+  ProbeCache = Hive::Daemon::RecoverableMarkerRetry::ProbeCache
+
+  def setup
+    @shell_calls = []
+  end
+
+  def green_probes(**overrides)
+    Probes.new(
+      cache: ProbeCache.new,
+      runner: method(:recording_runner),
+      agent_health_check: -> { [ true, "ok" ] },
+      wrapper_path_resolver: -> {
+        path = File.join(Dir.tmpdir, "hive-test-wrapper-#{Process.pid}")
+        File.write(path, "#!/bin/sh\n") unless File.exist?(path)
+        File.chmod(0o755, path)
+        path
+      },
+      binary_match_check: -> { [ true, "match" ] },
+      doctor_check: -> { [ true, "ok" ] },
+      ready_detector_check: -> { [ true, "ready" ] },
+      **overrides
+    )
+  end
+
+  def recording_runner(cmd, timeout_sec)
+    @shell_calls << { cmd: cmd, timeout: timeout_sec }
+    case cmd[1]
+    when "login"
+      [ "Logged in", "", fake_status(0) ]
+    when "exec"
+      [ "ok", "", fake_status(0) ]
+    else
+      [ "", "unknown", fake_status(1) ]
+    end
+  end
+
+  def fake_status(code)
+    Struct.new(:exitstatus) do
+      def success?
+        exitstatus.zero?
+      end
+    end.new(code)
+  end
+
+  def test_universal_fail_skips_codex_smoke
+    probes = green_probes(agent_health_check: -> { [ false, "missing skill" ] })
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp1")
+    refute suite.ok
+    assert_equal "agent_health", suite.failed_probe
+    assert_empty @shell_calls, "must not shell out when universal probe fails"
+  end
+
+  def test_codex_login_fail
+    runner = lambda { |cmd, _t|
+      @shell_calls << cmd
+      if cmd[1] == "login"
+        [ "Not logged in", "", fake_status(1) ]
+      else
+        flunk "should not run smoke after login fail"
+      end
+    }
+    probes = green_probes(runner: runner)
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "codex_login_status", suite.failed_probe
+  end
+
+  def test_codex_login_empty_exit_zero_fails_closed
+    runner = lambda { |cmd, _t|
+      @shell_calls << cmd
+      if cmd[1] == "login"
+        [ "", "", fake_status(0) ]
+      else
+        flunk "should not run smoke when login status is ambiguous"
+      end
+    }
+    probes = green_probes(runner: runner)
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "codex_login_status", suite.failed_probe
+    login = suite.probes.find { |p| p.name == "codex_login_status" }
+    assert login
+    refute login.ok
+  end
+
+  def test_codex_login_pass_smoke_fail
+    runner = lambda { |cmd, _t|
+      @shell_calls << cmd
+      if cmd[1] == "login"
+        [ "Logged in as user", "", fake_status(0) ]
+      else
+        [ "", "auth error", fake_status(1) ]
+      end
+    }
+    probes = green_probes(runner: runner)
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "codex_exec_smoke", suite.failed_probe
+  end
+
+  def test_codex_both_pass
+    probes = green_probes
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp")
+    assert suite.ok, suite.probes.map(&:to_h).inspect
+    assert_equal 2, @shell_calls.size
+  end
+
+  def test_claude_wrapper_missing
+    probes = green_probes(wrapper_path_resolver: -> { nil })
+    suite = probes.run_suite(:claude_launcher, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "claude_wrapper_present", suite.failed_probe
+  end
+
+  def test_claude_binary_mismatch
+    probes = green_probes(binary_match_check: -> { [ false, "mismatch" ] })
+    suite = probes.run_suite(:claude_launcher, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "daemon_binary_match", suite.failed_probe
+  end
+
+  def test_claude_doctor_red
+    probes = green_probes(doctor_check: -> { [ false, "skill missing" ] })
+    suite = probes.run_suite(:claude_launcher, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "hive_doctor_green", suite.failed_probe
+  end
+
+  def test_claude_all_green
+    probes = green_probes
+    suite = probes.run_suite(:claude_launcher, fingerprint_slice: "fp")
+    assert suite.ok, suite.probes.map(&:to_h).inspect
+  end
+
+  def test_probe_timeout_is_not_ok_and_does_not_raise
+    runner = lambda { |_cmd, _t|
+      [ "", "timeout after 1s", nil ]
+    }
+    probes = green_probes(runner: runner)
+    suite = probes.run_suite(:codex_auth, fingerprint_slice: "fp")
+    refute suite.ok
+    assert_equal "codex_login_status", suite.failed_probe
+  end
+
+  def test_cache_reuses_shell_within_tick
+    probes = green_probes
+    suite1 = probes.run_suite(:codex_auth, fingerprint_slice: "same")
+    suite2 = probes.run_suite(:codex_auth, fingerprint_slice: "same")
+    assert suite1.ok
+    assert suite2.ok
+    assert_equal 2, @shell_calls.size, "second suite must not re-invoke shell"
+  end
+end
