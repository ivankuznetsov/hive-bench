@@ -0,0 +1,525 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "time"
+require "hive/markers"
+require "hive/daemon/recoverable_marker_retry"
+require "hive/daemon/status_consumer"
+require "hive/daemon/logger"
+require "hive/events"
+
+class RecoverableMarkerRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  Row = Hive::Daemon::StatusConsumer::Row
+  RMR = Hive::Daemon::RecoverableMarkerRetry
+  NOW = Time.utc(2026, 7, 10, 12, 0, 0)
+  AUTH_MSG = "HTTP 401: Missing bearer/basic auth".freeze
+  LAUNCH_MSG = "claude interactive prompt did not become ready".freeze
+
+  class FakeController
+    attr_reader :observed_mtimes, :running
+
+    def initialize(running_pairs: [])
+      @running = running_pairs
+      @observed_mtimes = []
+    end
+
+    def running_task?(project:, slug:)
+      @running.include?([ project, slug ])
+    end
+
+    def observe_state_file_mtime(project:, slug:, mtime:)
+      @observed_mtimes << { project: project, slug: slug, mtime: mtime }
+    end
+  end
+
+  class FakeLogger
+    attr_reader :events
+
+    def initialize
+      @events = []
+    end
+
+    def event(name, **attrs)
+      unless Hive::Daemon::Logger::EVENTS.include?(name)
+        raise ArgumentError, "unknown event #{name.inspect}"
+      end
+
+      @events << [ name, attrs ]
+    end
+  end
+
+  class FakeRequestQueue
+    attr_reader :requests
+
+    def initialize
+      @requests = []
+    end
+
+    def write_request!(**kwargs)
+      @requests << kwargs
+      "req-#{@requests.size}"
+    end
+  end
+
+  class FakeEvents
+    attr_reader :emits
+
+    def initialize
+      @emits = []
+    end
+
+    def emit(**kwargs)
+      @emits << kwargs
+      kwargs
+    end
+  end
+
+  def setup
+    @logger = FakeLogger.new
+    @controller = FakeController.new
+    @request_queue = FakeRequestQueue.new
+    @events = FakeEvents.new
+    @fingerprint = "fp-stable-1"
+  end
+
+  def green_probes_factory
+    lambda { |cache|
+      RMR::Probes.new(
+        cache: cache,
+        runner: lambda { |cmd, _t|
+          if cmd[1] == "login"
+            [ "Logged in", "", status0 ]
+          else
+            [ "ok", "", status0 ]
+          end
+        },
+        agent_health_check: -> { [ true, "ok" ] },
+        wrapper_path_resolver: method(:temp_wrapper),
+        binary_match_check: -> { [ true, "match" ] },
+        doctor_check: -> { [ true, "ok" ] },
+        ready_detector_check: -> { [ true, "ready" ] }
+      )
+    }
+  end
+
+  def failing_probes_factory
+    lambda { |cache|
+      RMR::Probes.new(
+        cache: cache,
+        runner: lambda { |_cmd, _t| [ "", "fail", status1 ] },
+        agent_health_check: -> { [ true, "ok" ] },
+        wrapper_path_resolver: method(:temp_wrapper),
+        binary_match_check: -> { [ true, "match" ] },
+        doctor_check: -> { [ true, "ok" ] },
+        ready_detector_check: -> { [ true, "ready" ] }
+      )
+    }
+  end
+
+  def status0
+    Struct.new(:exitstatus) do
+      def success? = exitstatus.zero?
+    end.new(0)
+  end
+
+  def status1
+    Struct.new(:exitstatus) do
+      def success? = exitstatus.zero?
+    end.new(1)
+  end
+
+  def temp_wrapper
+    @wrapper_path ||= begin
+      path = File.join(Dir.tmpdir, "hive-rmr-wrapper-#{Process.pid}")
+      File.write(path, "#!/bin/sh\n") unless File.exist?(path)
+      File.chmod(0o755, path)
+      path
+    end
+  end
+
+  def make_orchestrator(enabled: true, probes_factory: nil, git_dirty: false)
+    RMR.new(
+      controller: @controller,
+      logger: @logger,
+      enabled: enabled,
+      request_queue: @request_queue,
+      probes_factory: probes_factory || green_probes_factory,
+      fingerprint_inputs: { daemon_binary_path: "hive", daemon_version: "t",
+                            wrapper_mtime: @fingerprint },
+      git_status_proc: ->(_path) { git_dirty },
+      worktree_path_resolver: ->(_row) { nil },
+      events: @events
+    )
+  end
+
+  def with_error_task(reason:, message:, stage: "4-execute", marker_id: "mid1")
+    Dir.mktmpdir do |dir|
+      basename = stage == "3-plan" ? "plan.md" : (stage == "2-brainstorm" ? "brainstorm.md" : "task.md")
+      state_file = File.join(dir, basename)
+      File.write(
+        state_file,
+        "# task\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} message=\"#{message}\" -->\n"
+      )
+      row = Row.new(
+        project: "p", slug: "s", stage: stage, workflow: "coding",
+        marker: "error",
+        marker_attrs: {
+          "reason" => reason,
+          "marker_id" => marker_id,
+          "message" => message
+        },
+        folder: dir, state_file: state_file,
+        state_file_mtime: NOW - 10,
+        action: "error", suggested_command: nil,
+        claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil
+      )
+      yield row, dir, state_file
+    end
+  end
+
+  def marker_on_disk(state_file)
+    Hive::Markers.current(state_file).name.to_s
+  end
+
+  # ── A1: Task-58 codex auth recovery ──────────────────────────────────
+
+  def test_a1_codex_auth_clears_when_probes_green
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, dir, state_file|
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+
+      assert_equal "none", marker_on_disk(state_file)
+      assert @logger.events.any? { |n, _| n == :auto_retry_cleared },
+             @logger.events.inspect
+      state = RMR::StateStore.new(dir).reason_state("implementer_failed")
+      assert_equal 1, state.attempts
+      assert_equal 1, @controller.observed_mtimes.size
+      assert @events.emits.any? { |e| e[:event_type] == :auto_retry }
+    end
+  end
+
+  # ── A2: Task-287 claude launcher recovery ────────────────────────────
+
+  def test_a2_claude_launch_clears_when_probes_green
+    with_error_task(reason: "claude_launch_failed", message: LAUNCH_MSG,
+                    stage: "2-brainstorm") do |row, dir, state_file|
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+
+      assert_equal "none", marker_on_disk(state_file)
+      cleared = @logger.events.find { |n, _| n == :auto_retry_cleared }
+      assert cleared
+      assert_equal "claude_launcher", cleared[1][:recovery_kind]
+      state = RMR::StateStore.new(dir).reason_state("claude_launch_failed")
+      assert_equal 1, state.attempts
+    end
+  end
+
+  # ── A3: implementer_failed without auth signature ────────────────────
+
+  def test_a3_unsigned_implementer_failed_stays_parked
+    with_error_task(reason: "implementer_failed", message: "tests failed") do |row, _dir, state_file|
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      refute @logger.events.any? { |n, _| n == :auto_retry_cleared }
+    end
+  end
+
+  # ── A4: probes fail ──────────────────────────────────────────────────
+
+  def test_a4_probe_failure_does_not_clear
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, _dir, state_file|
+      orch = make_orchestrator(probes_factory: failing_probes_factory)
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      assert @logger.events.any? { |n, a| n == :auto_retry_skipped && a[:rationale]&.include?("failed") }
+    end
+  end
+
+  # ── A5: exhausted budget ─────────────────────────────────────────────
+
+  def test_a5_exhausted_budget_no_clear
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, dir, state_file|
+      store = RMR::StateStore.new(dir)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "a", now: NOW - 10_000)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "b", now: NOW - 5000)
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      assert @logger.events.any? { |n, _| n == :auto_retry_exhausted }
+    end
+  end
+
+  # ── A6: second attempt before 30m / same fingerprint ─────────────────
+
+  def test_a6_second_attempt_same_fingerprint_blocked
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, dir, state_file|
+      # First clear succeeds.
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "none", marker_on_disk(state_file)
+
+      # Re-stamp the same error (simulating re-failure after re-run).
+      File.write(state_file,
+                 "# task\n\n<!-- ERROR reason=implementer_failed marker_id=mid2 " \
+                 "message=\"#{AUTH_MSG}\" -->\n")
+      row2 = Row.new(
+        project: row.project, slug: row.slug, stage: row.stage, workflow: "coding",
+        marker: "error",
+        marker_attrs: { "reason" => "implementer_failed", "marker_id" => "mid2",
+                        "message" => AUTH_MSG },
+        folder: dir, state_file: state_file, state_file_mtime: NOW,
+        action: "error", suggested_command: nil,
+        claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil
+      )
+      @logger.events.clear
+      # Same fingerprint inputs → blocked_same_signal even after 30m.
+      orch.evaluate([ row2 ], now: NOW + (31 * 60))
+      assert_equal "error", marker_on_disk(state_file)
+      refute @logger.events.any? { |n, _| n == :auto_retry_cleared }
+    end
+  end
+
+  # ── R9: second attempt after fingerprint change + 30m backoff ────────
+
+  def test_r9_second_attempt_succeeds_when_fingerprint_changes_after_backoff
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, dir, state_file|
+      # Attempt 1 with fingerprint A.
+      orch_a = RMR.new(
+        controller: @controller,
+        logger: @logger,
+        enabled: true,
+        request_queue: @request_queue,
+        probes_factory: green_probes_factory,
+        fingerprint_inputs: { wrapper_mtime: "fp-attempt-1", daemon_version: "t" },
+        git_status_proc: ->(_path) { false },
+        worktree_path_resolver: ->(_r) { nil },
+        events: @events
+      )
+      orch_a.evaluate([ row ], now: NOW)
+      assert_equal "none", marker_on_disk(state_file)
+      state = RMR::StateStore.new(dir).reason_state("implementer_failed")
+      assert_equal 1, state.attempts
+
+      # Re-park the same ERROR (task re-failed after re-run).
+      File.write(state_file,
+                 "# task\n\n<!-- ERROR reason=implementer_failed marker_id=mid2 " \
+                 "message=\"#{AUTH_MSG}\" -->\n")
+      row2 = Row.new(
+        project: row.project, slug: row.slug, stage: row.stage, workflow: "coding",
+        marker: "error",
+        marker_attrs: { "reason" => "implementer_failed", "marker_id" => "mid2",
+                        "message" => AUTH_MSG },
+        folder: dir, state_file: state_file, state_file_mtime: NOW + (31 * 60),
+        action: "error", suggested_command: nil,
+        claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil
+      )
+      @logger.events.clear
+
+      # Attempt 2: distinct fingerprint + 30m+ elapsed → clear again.
+      orch_b = RMR.new(
+        controller: @controller,
+        logger: @logger,
+        enabled: true,
+        request_queue: @request_queue,
+        probes_factory: green_probes_factory,
+        fingerprint_inputs: { wrapper_mtime: "fp-attempt-2-changed", daemon_version: "t" },
+        git_status_proc: ->(_path) { false },
+        worktree_path_resolver: ->(_r) { nil },
+        events: @events
+      )
+      orch_b.evaluate([ row2 ], now: NOW + (31 * 60))
+      assert_equal "none", marker_on_disk(state_file),
+                   "second attempt must clear after fingerprint change + backoff"
+      assert @logger.events.any? { |n, _| n == :auto_retry_cleared },
+             @logger.events.inspect
+      state = RMR::StateStore.new(dir).reason_state("implementer_failed")
+      assert_equal 2, state.attempts
+      assert state.exhausted, "max attempts reached after second clear"
+    end
+  end
+
+  # ── A7: dirty worktree ───────────────────────────────────────────────
+
+  def test_a7_dirty_worktree_no_clear
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, _dir, state_file|
+      orch = make_orchestrator(git_dirty: true)
+      # Need a worktree path so dirty check runs.
+      orch = RMR.new(
+        controller: @controller,
+        logger: @logger,
+        enabled: true,
+        request_queue: @request_queue,
+        probes_factory: green_probes_factory,
+        fingerprint_inputs: { wrapper_mtime: @fingerprint },
+        git_status_proc: ->(_path) { true },
+        worktree_path_resolver: ->(_r) { Dir.tmpdir },
+        events: @events
+      )
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      assert @logger.events.any? { |n, a|
+        n == :auto_retry_skipped && a[:rationale]&.include?("dirty worktree")
+      }
+    end
+  end
+
+  # ── A8: kill-switch ──────────────────────────────────────────────────
+
+  def test_a8_kill_switch_off_no_clear
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, _dir, state_file|
+      orch = make_orchestrator(enabled: false)
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      assert_empty @logger.events
+    end
+  end
+
+  # ── A9: live task lock ───────────────────────────────────────────────
+
+  def test_a9_live_task_lock_no_clear
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, _dir, state_file|
+      locked = Row.new(**row.to_h.merge(live_task_lock: true))
+      orch = make_orchestrator
+      orch.evaluate([ locked ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      refute @logger.events.any? { |n, _| n == :auto_retry_cleared }
+    end
+  end
+
+  # ── A10: unknown reason ──────────────────────────────────────────────
+
+  def test_a10_unknown_reason_no_clear
+    with_error_task(reason: "something_weird", message: "boom") do |row, _dir, state_file|
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      refute @logger.events.any? { |n, _| n == :auto_retry_cleared }
+    end
+  end
+
+  # ── Clear race does not burn budget ──────────────────────────────────
+
+  def test_clear_race_does_not_increment_attempts
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG,
+                    marker_id: "mid-old") do |row, dir, state_file|
+      # Status row has old marker_id; on-disk marker already rotated.
+      File.write(state_file,
+                 "# task\n\n<!-- ERROR reason=implementer_failed marker_id=mid-new " \
+                 "message=\"#{AUTH_MSG}\" -->\n")
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      state = RMR::StateStore.new(dir).reason_state("implementer_failed")
+      assert state.nil? || state.attempts.zero?
+    end
+  end
+
+  # ── Manual clear resets durable state ────────────────────────────────
+
+  def test_reset_state_for_clear_allows_future_retry
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |_row, dir, _state|
+      store = RMR::StateStore.new(dir)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "a", now: NOW)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "b", now: NOW + 1)
+      assert store.reason_state("implementer_failed").exhausted
+
+      RMR.reset_state_for_clear!(dir, reason: "implementer_failed")
+      assert_nil store.reason_state("implementer_failed")
+    end
+  end
+
+  # ── 3-plan requeue ───────────────────────────────────────────────────
+
+  def test_plan_stage_requeues_after_clear
+    with_error_task(reason: "claude_launch_failed", message: LAUNCH_MSG,
+                    stage: "3-plan") do |row, _dir, state_file|
+      orch = make_orchestrator
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "none", marker_on_disk(state_file)
+      assert_equal 1, @request_queue.requests.size
+      req = @request_queue.requests.first
+      assert_equal "healer", req[:requestor]
+      assert_includes req[:argv], "3-plan"
+    end
+  end
+
+  # ── R8: orchestrator-level probe throttle ────────────────────────────
+
+  def test_r8_second_evaluate_within_periodic_window_does_not_reinvoke_shell
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, dir, state_file|
+      shell_calls = []
+      factory = lambda { |cache|
+        RMR::Probes.new(
+          cache: cache,
+          runner: lambda { |cmd, _t|
+            shell_calls << cmd
+            [ "", "still broken", status1 ]
+          },
+          agent_health_check: -> { [ true, "ok" ] },
+          wrapper_path_resolver: method(:temp_wrapper),
+          binary_match_check: -> { [ true, "match" ] },
+          doctor_check: -> { [ true, "ok" ] },
+          ready_detector_check: -> { [ true, "ready" ] }
+        )
+      }
+      orch = make_orchestrator(probes_factory: factory)
+
+      orch.evaluate([ row ], now: NOW)
+      assert_equal "error", marker_on_disk(state_file)
+      first_calls = shell_calls.size
+      assert first_calls.positive?, "first evaluate must run shell probes"
+
+      state = RMR::StateStore.new(dir).reason_state("implementer_failed")
+      refute_nil state&.last_probe_at
+
+      shell_calls.clear
+      # Same fingerprint, well inside PERIODIC_REPROBE_SEC (600s).
+      orch.evaluate([ row ], now: NOW + 30)
+      assert_empty shell_calls,
+                   "second evaluate within periodic window must not re-invoke shell probes"
+      assert_equal "error", marker_on_disk(state_file)
+      assert_equal first_calls.positive?, true
+    end
+  end
+
+  def test_r8_periodic_floor_allows_reprobe_after_window
+    with_error_task(reason: "implementer_failed", message: AUTH_MSG) do |row, _dir, state_file|
+      shell_calls = []
+      factory = lambda { |cache|
+        RMR::Probes.new(
+          cache: cache,
+          runner: lambda { |cmd, _t|
+            shell_calls << cmd
+            [ "", "still broken", status1 ]
+          },
+          agent_health_check: -> { [ true, "ok" ] },
+          wrapper_path_resolver: method(:temp_wrapper),
+          binary_match_check: -> { [ true, "match" ] },
+          doctor_check: -> { [ true, "ok" ] },
+          ready_detector_check: -> { [ true, "ready" ] }
+        )
+      }
+      orch = make_orchestrator(probes_factory: factory)
+
+      orch.evaluate([ row ], now: NOW)
+      first_calls = shell_calls.size
+      assert first_calls.positive?
+
+      shell_calls.clear
+      orch.evaluate([ row ], now: NOW + RMR::HealthSignal::PERIODIC_REPROBE_SEC + 1)
+      assert_equal first_calls, shell_calls.size,
+                   "after periodic floor, probes must run again"
+      assert_equal "error", marker_on_disk(state_file)
+    end
+  end
+end
