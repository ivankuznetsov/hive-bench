@@ -0,0 +1,149 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/recoverable_marker_retry"
+require "hive/daemon/status_consumer"
+require "hive/markers"
+
+class RecoverableMarkerRetrySafetyTest < Minitest::Test
+  include HiveTestHelper
+
+  Safety = Hive::Daemon::RecoverableMarkerRetry::Safety
+  Row = Hive::Daemon::StatusConsumer::Row
+
+  def make_row(folder, state_file, stage:, live_task_lock: nil)
+    Row.new(
+      project: "p", slug: "s", stage: stage, workflow: "coding",
+      marker: "error",
+      marker_attrs: { "reason" => "implementer_failed", "message" => "x" },
+      folder: folder, state_file: state_file,
+      state_file_mtime: Time.now,
+      action: "error", suggested_command: nil,
+      claude_pid_alive: nil, live_task_lock: live_task_lock, diagnostic: nil
+    )
+  end
+
+  def test_clean_execute_worktree_safe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "task.md")
+      File.write(state, "# task\n\n<!-- ERROR reason=implementer_failed message=\"x\" -->\n")
+      wt = File.join(dir, "wt")
+      FileUtils.mkdir_p(wt)
+      row = make_row(dir, state, stage: "4-execute")
+      result = Safety.check(
+        row,
+        git_status_proc: ->(_path) { false },
+        worktree_path_resolver: ->(_r) { wt }
+      )
+      assert result.safe, result.rationale
+    end
+  end
+
+  def test_dirty_execute_worktree_unsafe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "task.md")
+      File.write(state, "# task\n\n<!-- ERROR reason=implementer_failed -->\n")
+      wt = File.join(dir, "wt")
+      FileUtils.mkdir_p(wt)
+      row = make_row(dir, state, stage: "4-execute")
+      result = Safety.check(
+        row,
+        git_status_proc: ->(_path) { true },
+        worktree_path_resolver: ->(_r) { wt }
+      )
+      refute result.safe
+      assert_match(/dirty worktree/, result.rationale)
+    end
+  end
+
+  def test_missing_worktree_is_safe_for_execute
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "task.md")
+      File.write(state, "# task\n\n<!-- ERROR reason=implementer_failed -->\n")
+      row = make_row(dir, state, stage: "4-execute")
+      result = Safety.check(
+        row,
+        worktree_path_resolver: ->(_r) { nil }
+      )
+      assert result.safe
+    end
+  end
+
+  def test_brainstorm_with_answered_rounds_unsafe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "brainstorm.md")
+      File.write(state, <<~MD)
+        # Brainstorm
+
+        ## Round 1
+        ### Q1. What?
+        ### A1.
+        User said yes please.
+        <!-- ERROR reason=claude_launch_failed message="ready" -->
+      MD
+      row = make_row(dir, state, stage: "2-brainstorm")
+      result = Safety.check(row)
+      refute result.safe
+      assert_match(/answered rounds/, result.rationale)
+    end
+  end
+
+  def test_plan_empty_launch_failed_safe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "plan.md")
+      File.write(state, "# plan\n\n<!-- ERROR reason=claude_launch_failed message=\"ready\" -->\n")
+      row = make_row(dir, state, stage: "3-plan")
+      result = Safety.check(row)
+      assert result.safe, result.rationale
+    end
+  end
+
+  def test_plan_substantial_body_unsafe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "plan.md")
+      File.write(state, <<~MD)
+        # Plan
+
+        ## Overview
+        This is a substantial plan body that an agent already wrote before
+        the launcher died mid-flight. Re-running from scratch would clobber it.
+
+        ## Implementation Units
+        Many details here that should not be discarded automatically.
+
+        <!-- ERROR reason=claude_launch_failed message="ready" -->
+      MD
+      row = make_row(dir, state, stage: "3-plan")
+      result = Safety.check(row)
+      refute result.safe
+      assert_match(/ambiguous plan/, result.rationale)
+    end
+  end
+
+  def test_live_task_lock_unsafe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "task.md")
+      File.write(state, "# task\n\n<!-- ERROR reason=implementer_failed -->\n")
+      row = make_row(dir, state, stage: "4-execute", live_task_lock: true)
+      result = Safety.check(row)
+      refute result.safe
+      assert_match(/live task lock/, result.rationale)
+    end
+  end
+
+  def test_terminal_success_marker_unsafe
+    Dir.mktmpdir do |dir|
+      state = File.join(dir, "task.md")
+      File.write(state, "# task\n\n<!-- EXECUTE_COMPLETE -->\n")
+      row = make_row(dir, state, stage: "4-execute")
+      result = Safety.check(
+        row,
+        worktree_path_resolver: ->(_r) { nil }
+      )
+      refute result.safe
+      assert_match(/terminal success/, result.rationale)
+    end
+  end
+end
diff --git a/test/unit/daemon/recoverable_marker_retry/state_store_test.rb b/test/unit/daemon/recoverable_marker_retry/state_store_test.rb
new file mode 100644
index 00000000..b52cfae6
--- /dev/null
+++ b/test/unit/daemon/recoverable_marker_retry/state_store_test.rb
@@ -0,0 +1,90 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/recoverable_marker_retry"
+
+class RecoverableMarkerRetryStateStoreTest < Minitest::Test
+  include HiveTestHelper
+
+  StateStore = Hive::Daemon::RecoverableMarkerRetry::StateStore
+  NOW = Time.utc(2026, 7, 10, 12, 0, 0)
+
+  def with_store
+    Dir.mktmpdir do |dir|
+      yield StateStore.new(dir), dir
+    end
+  end
+
+  def test_first_attempt_records
+    with_store do |store, _dir|
+      assert store.record_attempt!(
+        "implementer_failed",
+        recovery_kind: :codex_auth,
+        fingerprint: "fp1",
+        now: NOW
+      )
+      state = store.reason_state("implementer_failed")
+      assert_equal 1, state.attempts
+      refute state.exhausted
+      assert_equal "fp1", state.last_attempt_fingerprint
+    end
+  end
+
+  def test_second_attempt_exhausts_at_max
+    with_store do |store, _dir|
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "fp1", now: NOW)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "fp2", now: NOW + 2000)
+      state = store.reason_state("implementer_failed")
+      assert_equal 2, state.attempts
+      assert state.exhausted
+    end
+  end
+
+  def test_reset_reason_clears_budget
+    with_store do |store, _dir|
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "fp1", now: NOW)
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "fp2", now: NOW + 2000)
+      assert store.reset_reason!("implementer_failed")
+      assert_nil store.reason_state("implementer_failed")
+    end
+  end
+
+  def test_reset_all_deletes_file
+    with_store do |store, dir|
+      store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                  fingerprint: "fp1", now: NOW)
+      path = File.join(dir, StateStore::FILENAME)
+      assert File.exist?(path)
+      assert store.reset_all!
+      refute File.exist?(path)
+    end
+  end
+
+  def test_corrupt_state_is_fail_closed
+    with_store do |store, dir|
+      File.write(store.path, "{not json")
+      result = store.load
+      refute result[:ok]
+      assert result[:error]
+      refute store.record_attempt!("implementer_failed", recovery_kind: :codex_auth,
+                                                         fingerprint: "fp", now: NOW)
+    end
+  end
+
+  def test_survives_reload_from_disk
+    with_store do |store, dir|
+      store.record_attempt!("claude_launch_failed", recovery_kind: :claude_launcher,
+                                                    fingerprint: "fp", now: NOW)
+      reloaded = StateStore.new(dir)
+      state = reloaded.reason_state("claude_launch_failed")
+      assert_equal 1, state.attempts
+      assert_equal "claude_launcher", state.recovery_kind
+    end
+  end
+end
