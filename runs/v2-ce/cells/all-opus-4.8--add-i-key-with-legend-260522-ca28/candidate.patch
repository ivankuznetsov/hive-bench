+      # the stage-specific section (raw brainstorm.md / plan.md contents /
+      # execute-log tail) and are absent for 1-inbox. There is no
+      # scrolling this iteration: content beyond the visible area is cut
+      # with a `…` indicator.
+      module InfoOverlay
+        TITLE = "task info".freeze
+        DISMISS_HINT = "[q]/[Esc]/[i] close".freeze
+        OVERFLOW_INDICATOR = "…".freeze
+        MISSING = "—".freeze
+
+        module_function
+
+        def render(model)
+          state = model.info_overlay_state
+          return "" if state.nil?
+
+          width = [ model.cols.to_i - 4, 20 ].max
+          # Border (1 cell each side) + padding (2 cells each side) eat
+          # 6 cells of the box width before content; wrap/truncate our
+          # own lines to what's left so the ellipsis lands predictably.
+          text_width = [ width - 6, 1 ].max
+
+          # Vertical budget: border (2) + vertical padding (2) leave
+          # rows-4 for content; keep the dismiss hint always visible.
+          content_budget = [ model.rows.to_i - 4, 3 ].max
+          body_budget = [ content_budget - 2, 1 ].max
+
+          body = fit_vertically(body_lines(state, text_width, body_budget), body_budget)
+          lines = body + [ "", Styles::HINT.render(truncate(DISMISS_HINT, text_width)) ]
+          inner = Lipgloss.join_vertical(Lipgloss::TOP, *lines)
+
+          Lipgloss::Style.new
+                         .border(Lipgloss::Border::NORMAL)
+                         .padding(1, 2)
+                         .width(width)
+                         .render(inner)
+        end
+
+        # @api private — exposed for tests.
+        #
+        # `max_lines` bounds how many lines each content block wraps: since
+        # `fit_vertically` discards everything past the vertical budget,
+        # wrapping a large plan.md/brainstorm.md in full is wasted work —
+        # capping each block at the budget can never drop a visible line.
+        # Nil (the test default) means "no bound".
+        def body_lines(state, width, max_lines = nil)
+          lines = [ Styles::HEADER.render(truncate("#{TITLE} — #{state.slug}", width)), "" ]
+          lines.concat(field_lines(state, width))
+          lines << ""
+          lines << Styles::HEADER.render(truncate("original idea:", width))
+          lines.concat(content_block(state.original_text, width, placeholder: "(no original idea text)", max_lines: max_lines))
+          lines.concat(extra_section(state, width, max_lines))
+          lines
+        end
+
+        def field_lines(state, width)
+          [
+            field("stage", state.stage, width),
+            field("created", state.created_at, width),
+            field("folder", state.folder, width),
+            field("latest log", state.log_path, width, placeholder: "(no logs yet)")
+          ]
+        end
+
+        # 1-inbox carries no stage-specific section; a nil `extra_label`
+        # is the signal to render nothing extra at all.
+        def extra_section(state, width, max_lines = nil)
+          return [] if state.extra_label.to_s.empty?
+
+          [
+            "",
+            Styles::HEADER.render(truncate("#{state.extra_label}:", width)),
+            *content_block(state.extra_content, width, placeholder: "(empty)", max_lines: max_lines)
+          ]
+        end
+
+        def field(label, value, width, placeholder: MISSING)
+          text = value.to_s.empty? ? placeholder : Hive::Tui::Text.sanitize(value.to_s)
+          truncate("#{label}: #{text}", width)
+        end
+
+        def content_block(text, width, placeholder:, max_lines: nil)
+          clean = Hive::Tui::Text.sanitize(text.to_s)
+          return [ Styles::HINT.render(truncate(placeholder, width)) ] if clean.strip.empty?
+
+          wrap_text(clean, width, max_lines: max_lines).map { |line| truncate(line, width) }
+        end
+
+        # Keep the first `budget` lines; when content overflows, replace
+        # the final kept line with an ellipsis marker so the operator
+        # sees the panel was cut (no scrolling this iteration).
+        def fit_vertically(lines, budget)
+          return lines if lines.size <= budget
+
+          kept = lines.first([ budget - 1, 0 ].max)
+          kept + [ Styles::HINT.render(OVERFLOW_INDICATOR) ]
+        end
+
+        def wrap_text(text, width, max_lines: nil)
+          capacity = [ width.to_i, 1 ].max
+          wrapped = []
+          text.each_line(chomp: true) do |line|
+            wrapped.concat(chunk_line(line, capacity))
+            break if max_lines && wrapped.size >= max_lines
+          end
+          max_lines ? wrapped.first(max_lines) : wrapped
+        end
+
+        def chunk_line(line, capacity)
+          return [ "" ] if line.empty?
+
+          chunks = []
+          offset = 0
+          while offset < line.length
+            chunks << line[offset, capacity].to_s
+            offset += capacity
+          end
+          chunks
+        end
+
+        def truncate(line, width)
+          Views::Format.truncate(line, width.to_i)
+        end
+      end
+    end
+  end
+end
