diff --git a/test/unit/tui/views/info_overlay_test.rb b/test/unit/tui/views/info_overlay_test.rb
new file mode 100644
index 00000000..5321fc02
--- /dev/null
+++ b/test/unit/tui/views/info_overlay_test.rb
@@ -0,0 +1,178 @@
+require "test_helper"
+require "hive/tui/model"
+require "hive/tui/views/info_overlay"
+
+# Views::InfoOverlay renders the read-only, full-screen info panel from
+# a pre-gathered Model::InfoOverlayState. These tests pin the common
+# fields, the stage-specific extra section, the 1-inbox no-extra case,
+# and the overflow/size discipline (no scrolling this iteration).
+class HiveTuiViewsInfoOverlayTest < Minitest::Test
+  include HiveTestHelper
+
+  def state(**overrides)
+    defaults = {
+      slug: "ship-it",
+      stage: "1-inbox",
+      folder: "/proj/.hive-state/stages/1-inbox/ship-it",
+      created_at: "2026-05-20T00:00:00Z",
+      original_text: "Ship the info panel",
+      log_path: nil,
+      extra_label: nil,
+      extra_content: nil
+    }
+    Hive::Tui::Model::InfoOverlayState.new(**defaults.merge(overrides))
+  end
+
+  def model(info_state, cols: 100, rows: 40)
+    Hive::Tui::Model.initial.with(mode: :info, cols: cols, rows: rows, info_overlay_state: info_state)
+  end
+
+  def strip(text)
+    text.gsub(/\e\[[\d;]*m/, "")
+  end
+
+  def test_renders_common_fields
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(state)))
+    assert_includes out, "task info — ship-it"
+    assert_includes out, "1-inbox"
+    assert_includes out, "2026-05-20"
+    assert_includes out, "Ship the info panel"
+    assert_includes out, "1-inbox/ship-it" # folder path
+  end
+
+  def test_inbox_card_has_no_extra_section
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(state)))
+    refute_includes out, "brainstorm.md:"
+    refute_includes out, "plan.md:"
+    refute_includes out, "execute log:"
+  end
+
+  def test_brainstorm_card_renders_brainstorm_md_content
+    s = state(
+      stage: "2-brainstorm",
+      extra_label: "brainstorm.md",
+      extra_content: "# Brainstorm\n\nThe distilled requirements"
+    )
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    assert_includes out, "brainstorm.md:"
+    assert_includes out, "The distilled requirements"
+  end
+
+  def test_plan_card_renders_plan_md_content
+    s = state(
+      stage: "3-plan",
+      extra_label: "plan.md",
+      extra_content: "# Plan\n\nImplementation units"
+    )
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    assert_includes out, "plan.md:"
+    assert_includes out, "Implementation units"
+  end
+
+  def test_execute_card_renders_log_tail
+    s = state(
+      stage: "4-execute",
+      log_path: "/proj/.hive-state/logs/ship-it/execute.log",
+      extra_label: "latest execute log",
+      extra_content: "line 1\nline 2\nlast log line"
+    )
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    assert_includes out, "latest execute log:"
+    assert_includes out, "last log line"
+    assert_includes out, "execute.log",
+                    "the resolved log_path must render in the latest-log field, not just the placeholder"
+  end
+
+  # Production shape when the stage file is absent: the label is set
+  # (so the section renders) but the content is nil — the extra section
+  # must still render its header and fall back to the "(empty)"
+  # placeholder rather than swallowing the whole section.
+  def test_extra_section_with_empty_content_renders_placeholder
+    s = state(stage: "2-brainstorm", extra_label: "brainstorm.md", extra_content: nil)
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    assert_includes out, "brainstorm.md:"
+    assert_includes out, "(empty)"
+  end
+
+  def test_missing_optional_fields_render_placeholders
+    s = state(created_at: nil, original_text: nil, log_path: nil)
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    assert_includes out, "(no logs yet)"
+    assert_includes out, "(no original idea text)"
+  end
+
+  def test_dismiss_hint_is_shown
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(state)))
+    assert_includes out, "close"
+  end
+
+  def test_nil_state_renders_empty_string
+    empty = Hive::Tui::Model.initial.with(mode: :info, info_overlay_state: nil)
+    assert_equal "", Hive::Tui::Views::InfoOverlay.render(empty)
+  end
+
+  def test_overflow_is_truncated_and_output_fits_terminal
+    long_body = Array.new(500) { |i| "brainstorm line #{i}" }.join("\n")
+    s = state(stage: "2-brainstorm", extra_label: "brainstorm.md", extra_content: long_body)
+    out = Hive::Tui::Views::InfoOverlay.render(model(s, cols: 80, rows: 24))
+    rendered_rows = out.lines.count
+    assert_operator rendered_rows, :<=, 24,
+                    "panel must not exceed the terminal height (no scrolling this iteration)"
+    strip(out).lines.each do |line|
+      assert_operator line.chomp.length, :<=, 80,
+                      "no line may exceed the terminal width: #{line.inspect}"
+    end
+    assert_includes strip(out), "…", "overflow must be indicated with an ellipsis"
+  end
+
+  def test_time_created_at_renders_within_width_budget
+    # Production feeds created_at as a Time (from idea.md frontmatter);
+    # the view only .to_s's it. Prove a real Time value renders and
+    # stays within the width budget on a narrow terminal.
+    t = Time.utc(2026, 5, 20, 13, 45, 7)
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(state(created_at: t), cols: 80, rows: 40)))
+    assert_includes out, "2026-05-20"
+    out.lines.each do |line|
+      assert_operator line.chomp.length, :<=, 80,
+                      "Time created_at must not overflow the terminal width: #{line.inspect}"
+    end
+  end
+
+  def test_long_multiline_original_text_wraps_and_fits
+    # Exercises content_block/chunk_line wrapping of a multi-line
+    # original_text (distinct from the extra_content overflow path):
+    # every wrapped line must stay within width and the panel within height.
+    long_idea = Array.new(40) { |i| "idea paragraph line #{i} with enough words to wrap across the panel" }.join("\n")
+    out = Hive::Tui::Views::InfoOverlay.render(model(state(original_text: long_idea), cols: 80, rows: 24))
+    assert_operator out.lines.count, :<=, 24,
+                    "wrapped original_text must not exceed the terminal height"
+    strip(out).lines.each do |line|
+      assert_operator line.chomp.length, :<=, 80,
+                      "wrapped original_text line exceeds terminal width: #{line.inspect}"
+    end
+    assert_includes strip(out), "…", "overflow of long original text must be indicated"
+  end
+
+  def test_tiny_terminal_keeps_dismiss_hint_at_intended_floor
+    # rows<7 can't fit the full chrome; the content_budget floor of 3
+    # deliberately renders a minimum-height panel (border + padding + one
+    # body line + dismiss hint) so the hint stays visible — an accepted
+    # overflow. Pin the floor so it can't drift silently.
+    out = Hive::Tui::Views::InfoOverlay.render(model(state, cols: 80, rows: 3))
+    assert_equal 7, out.lines.count,
+                 "tiny terminal must render the intended 7-row floor, not collapse below the hint"
+    assert_includes strip(out), "close",
+                    "dismiss hint must stay visible even when the terminal is below the floor"
+  end
+
+  def test_control_bytes_in_content_are_sanitized
+    s = state(
+      stage: "3-plan",
+      extra_label: "plan.md",
+      extra_content: "safe\e[2Jline\x07here"
+    )
+    out = strip(Hive::Tui::Views::InfoOverlay.render(model(s)))
+    refute_includes out, "\e[2J"
+    refute_includes out, "\x07"
+  end
+end
