new file mode 100644
index 00000000..a518d08b
--- /dev/null
+++ b/test/unit/local/daemon_consistency_test.rb
@@ -0,0 +1,159 @@
+require "test_helper"
+require "shellwords"
+require "hive/local/daemon_consistency"
+
+class LocalDaemonConsistencyTest < Minitest::Test
+  include HiveTestHelper
+
+  def fake_installer(platform:, target_path:)
+    inst = Object.new
+    inst.define_singleton_method(:envelope_platform) { platform }
+    inst.define_singleton_method(:target_path) { target_path }
+    inst
+  end
+
+  def systemd_unit(binary)
+    <<~UNIT
+      [Service]
+      Environment=HIVE_BIN=#{binary}
+      Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
+      ExecStart=#{binary} daemon start
+    UNIT
+  end
+
+  def launchd_plist(binary)
+    <<~PLIST
+      <key>ProgramArguments</key>
+      <array>
+        <string>/bin/sh</string>
+        <string>-c</string>
+        <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+        <string>#{binary}</string>
+        <string>daemon</string>
+        <string>start</string>
+      </array>
+    PLIST
+  end
+
+  def check(platform:, unit_content:, current_binary:, target_path: "/tmp/hive-daemon.unit")
+    reader = ->(_path) { unit_content }
+    Hive::Local::DaemonConsistency.new(
+      daemon_installer: fake_installer(platform: platform, target_path: target_path),
+      current_binary: current_binary,
+      unit_reader: reader
+    ).call
+  end
+
+  def test_linux_consistent_when_unit_matches_current_binary
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "bin", "hive")
+      FileUtils.mkdir_p(File.dirname(bin))
+      File.write(bin, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, bin)
+      result = check(platform: "linux", unit_content: systemd_unit(bin), current_binary: bin)
+      assert_equal :consistent, result.status
+      assert_nil result.repair_command
+    end
+  end
+
+  def test_linux_drifted_when_unit_points_elsewhere
+    result = check(platform: "linux",
+                   unit_content: systemd_unit("/usr/bin/hive"),
+                   current_binary: "/opt/hive/bin/hive")
+    assert_equal :drifted, result.status
+    assert_equal "hive daemon install --force", result.repair_command
+    assert_equal "/usr/bin/hive", result.installed_binary
+  end
+
+  def test_linux_consistent_through_symlink
+    with_tmp_dir do |dir|
+      real = File.join(dir, "real", "hive")
+      FileUtils.mkdir_p(File.dirname(real))
+      File.write(real, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, real)
+      link = File.join(dir, "bin", "hive")
+      FileUtils.mkdir_p(File.dirname(link))
+      File.symlink(real, link)
+      # Unit bakes the realpath; CLI invoked via the symlink — same binary.
+      result = check(platform: "linux", unit_content: systemd_unit(real), current_binary: link)
+      assert_equal :consistent, result.status, result.detail
+    end
+  end
+
+  def test_linux_consistent_when_unit_stores_shellwords_escaped_hive_bin
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "with space", "hive")
+      FileUtils.mkdir_p(File.dirname(bin))
+      File.write(bin, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, bin)
+      escaped = Shellwords.escape(bin)
+      # Mirror what the installer writes: the Shellwords-escaped path in
+      # HIVE_BIN (and ExecStart). Without unescaping, same_binary? would
+      # realpath the escaped literal `/tmp/.../with\ space/hive` and
+      # ENOENT, false-reporting :drifted.
+      result = check(platform: "linux", unit_content: systemd_unit(escaped), current_binary: bin)
+      assert_equal :consistent, result.status, result.detail
+      assert_equal bin, result.installed_binary
+    end
+  end
+
+  def test_linux_consistent_when_unit_stores_shellwords_escaped_execstart_only
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "my hive", "bin", "hive")
+      FileUtils.mkdir_p(File.dirname(bin))
+      File.write(bin, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, bin)
+      escaped = Shellwords.escape(bin)
+      # No HIVE_BIN line — fall back to the first shell word of ExecStart,
+      # which must unescape the spaced path.
+      unit = "ExecStart=#{escaped} daemon start\n"
+      result = check(platform: "linux", unit_content: unit, current_binary: bin)
+      assert_equal :consistent, result.status, result.detail
+      assert_equal bin, result.installed_binary
+    end
+  end
+
+  def test_macos_consistent_when_plist_matches
+    result = check(platform: "macos",
+                   unit_content: launchd_plist("/opt/homebrew/bin/hive"),
+                   current_binary: "/opt/homebrew/bin/hive")
+    assert_equal :consistent, result.status
+  end
+
+  def test_macos_drifted_when_plist_points_elsewhere
+    result = check(platform: "macos",
+                   unit_content: launchd_plist("/usr/local/bin/hive"),
+                   current_binary: "/opt/homebrew/bin/hive")
+    assert_equal :drifted, result.status
+    assert_equal "hive daemon install --force", result.repair_command
+  end
+
+  def test_not_installed_when_unit_missing
+    inst = fake_installer(platform: "linux", target_path: "/nonexistent/hive-daemon.service")
+    result = Hive::Local::DaemonConsistency.new(
+      daemon_installer: inst,
+      current_binary: "/tmp/hive",
+      unit_reader: ->(_path) { nil }
+    ).call
+    assert_equal :not_installed, result.status
+    assert_equal "hive daemon install", result.repair_command
+  end
+
+  def test_unparseable_unit_treated_as_drifted
+    result = check(platform: "linux",
+                   unit_content: "garbage with no binary\n",
+                   current_binary: "/tmp/hive")
+    assert_equal :drifted, result.status
+    assert_match(/could not parse/, result.detail)
+  end
+
+  def test_unsupported_platform
+    inst = fake_installer(platform: "unsupported", target_path: nil)
+    result = Hive::Local::DaemonConsistency.new(
+      daemon_installer: inst,
+      current_binary: "/tmp/hive",
+      unit_reader: ->(_path) { nil }
+    ).call
+    assert_equal :unsupported, result.status
+  end
+end
