@@ -0,0 +1,159 @@
+require "test_helper"
+require "hive/commands/web/service_installer"
+require "hive/commands/web/service_control"
+
+class WebServiceControlTest < Minitest::Test
+  include HiveTestHelper
+
+  def installer(host_os:, systemctl_available: true, home: nil)
+    dir = home || Dir.mktmpdir("hive-webctl")
+    Hive::Commands::Web::ServiceInstaller.new(
+      host_os: host_os,
+      home: dir,
+      binary_path: "/tmp/hive",
+      systemctl_available: systemctl_available
+    )
+  end
+
+  def test_linux_start_calls_systemctl_start
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: installer(host_os: "linux"),
+      systemctl_available: true,
+      runner: ->(argv) { calls << argv; true }
+    )
+
+    assert control.start
+    assert_includes calls, %w[systemctl --user start hive-web]
+  end
+
+  def test_linux_stop_calls_systemctl_stop
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: installer(host_os: "linux"),
+      systemctl_available: true,
+      runner: ->(argv) { calls << argv; true }
+    )
+
+    assert control.stop
+    assert_includes calls, %w[systemctl --user stop hive-web]
+  end
+
+  def test_linux_restart_calls_systemctl_restart
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: installer(host_os: "linux"),
+      systemctl_available: true,
+      runner: ->(argv) { calls << argv; true }
+    )
+
+    assert control.restart
+    assert_includes calls, %w[systemctl --user restart hive-web]
+  end
+
+  def test_linux_active_true_when_is_active_exits_zero
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: installer(host_os: "linux"),
+      systemctl_available: true,
+      runner: ->(argv) { argv == %w[systemctl --user is-active hive-web] }
+    )
+
+    assert control.active?
+  end
+
+  def test_linux_start_raises_unavailable_without_systemd
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: installer(host_os: "linux"),
+      systemctl_available: false,
+      runner: ->(_argv) { true }
+    )
+
+    err = assert_raises(Hive::Commands::Web::ServiceControl::Unavailable) { control.start }
+    assert_match(/systemd-user not detected/, err.message)
+  end
+
+  def test_macos_start_loads_plist
+    inst = installer(host_os: "darwin23")
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(_argv) { true }
+    )
+
+    assert control.start
+    assert control.messages.any? { |m| m.include?("launchctl load") }
+  end
+
+  def test_macos_start_falls_back_to_launchctl_start_when_already_loaded
+    inst = installer(host_os: "darwin23")
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(argv) { calls << argv; argv.first == "launchctl" && argv[1] == "start" }
+    )
+
+    assert control.start, "load failed (already loaded) → fallback start must succeed"
+    assert(calls.any? { |c| c[1] == "load" })
+    assert(calls.any? { |c| c[1] == "start" && c[2] == "local.hive-web" })
+  end
+
+  def test_macos_stop_unloads_plist
+    inst = installer(host_os: "darwin23")
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(_argv) { true }
+    )
+
+    assert control.stop
+    assert control.messages.any? { |m| m.include?("launchctl unload") }
+  end
+
+  def test_macos_active_uses_launchctl_list
+    inst = installer(host_os: "darwin23")
+    seen = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(argv) { seen << argv; true }
+    )
+
+    assert control.active?
+    assert_includes seen, [ "launchctl", "list", "local.hive-web" ]
+  end
+
+  def test_macos_restart_succeeds_when_unload_and_load_both_succeed
+    inst = installer(host_os: "darwin23")
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(argv) { calls << argv; true }
+    )
+
+    assert control.restart, "both unload and load succeeded → restart ok"
+    assert(calls.any? { |c| c[1] == "unload" })
+    assert(calls.any? { |c| c[1] == "load" })
+  end
+
+  def test_macos_restart_reports_failure_when_unload_fails_but_load_succeeds
+    inst = installer(host_os: "darwin23")
+    calls = []
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      # unload fails, load succeeds — the half-restart must NOT be ok.
+      runner: ->(argv) { calls << argv; argv[1] == "load" }
+    )
+
+    refute control.restart, "a failed unload must not be masked as success by a later load"
+    assert(calls.any? { |c| c[1] == "unload" })
+    assert(calls.any? { |c| c[1] == "load" })
+  end
+
+  def test_unsupported_platform_start_raises_unavailable
+    inst = installer(host_os: "freebsd14")
+    control = Hive::Commands::Web::ServiceControl.new(
+      installer: inst,
+      runner: ->(_argv) { true }
+    )
+
+    assert_raises(Hive::Commands::Web::ServiceControl::Unavailable) { control.start }
+    refute control.active?
+  end
+end
diff --git a/test/unit/commands/web/service_installer_test.rb b/test/unit/commands/web/service_installer_test.rb
