diff --git a/lib/hive/commands/setup.rb b/lib/hive/commands/setup.rb
new file mode 100644
index 00000000..28a76cd9
--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,262 @@
+require "json"
+
+require "hive/config"
+require "hive/paths"
+require "hive/pid_file"
+require "hive/invoked_binary"
+require "hive/local/dependency_check"
+require "hive/local/daemon_consistency"
+require "hive/commands/setup/backend_prompt"
+
+module Hive
+  module Commands
+    # `hive setup` — one-command local (non-Docker) setup that provisions
+    # and validates the Hive CLI, Rails web bundle, qmd, daemon service,
+    # project enrollment, and web launch. Local mode operates on the
+    # user's real Hive/XDG state and checked-out repos (no sandbox) and
+    # mirrors the OpenClaw local UX: zero/low-config loopback, lifecycle
+    # commands, health checks, diagnostics.
+    #
+    # `hive setup --check` is non-mutating: it runs the dependency and
+    # daemon-consistency diagnostics and reports, exiting non-zero if any
+    # check fails. The full `hive setup` additionally ensures the daemon
+    # unit is installed and the daemon running, enrolls the current
+    # project for dispatch, persists global agent backends (interactive
+    # prompt, defaults when non-interactive), and prints the web launch
+    # path (optionally installing/starting the managed web service with
+    # `--start-web`).
+    class Setup
+      EXIT_OK = 0
+      EXIT_CHECK_FAILED = 65
+
+      attr_reader :report
+
+      def initialize(project_path: Dir.pwd, json: false, check_only: false, start_web: false,
+                     dependency_check: nil, daemon_consistency: nil,
+                     daemon_running: nil, shell: nil, registered_projects: nil,
+                     backend_prompt: nil, output: $stdout, err: $stderr)
+        @project_path = File.expand_path(project_path)
+        @json = json
+        @check_only = check_only
+        @start_web = start_web
+        @dependency_check = dependency_check || Hive::Local::DependencyCheck.new
+        @daemon_consistency = daemon_consistency || Hive::Local::DaemonConsistency.new
+        @daemon_running = daemon_running || method(:default_daemon_running?)
+        @shell = shell || method(:default_shell)
+        @registered_projects = registered_projects || Hive::Config.method(:registered_projects)
+        @backend_prompt = backend_prompt
+        @output = output
+        @err = err
+        @report = {}
+      end
+
+      def call
+        run_diagnostics
+        if @check_only
+          emit_report
+          return @report[:ok] ? EXIT_OK : EXIT_CHECK_FAILED
+        end
+
+        ensure_daemon
+        enroll_project
+        persist_agent_backends
+        ensure_web if @start_web
+        emit_report
+        @report[:ok] ? EXIT_OK : EXIT_CHECK_FAILED
+      end
+
+      private
+
+      # ── Diagnostics (shared by --check and full setup) ──────────────
+
+      def run_diagnostics
+        deps = @dependency_check.call
+        consistency = @daemon_consistency.call
+        # Stash so ensure_daemon can reuse the probe result instead of
+        # re-invoking @daemon_consistency.call (cheap and idempotent, but
+        # redundant double work on the full-setup path).
+        @daemon_consistency_result = consistency
+        @report = {
+          dependencies: deps.results.map { |r| serialize_dep(r) },
+          dependencies_ok: deps.ok?,
+          daemon: {
+            status: consistency.status.to_s,
+            installed_binary: consistency.installed_binary,
+            current_binary: consistency.current_binary,
+            detail: consistency.detail,
+            repair_command: consistency.repair_command
+          },
+          daemon_consistent: consistency.consistent?,
+          ok: deps.ok? && !consistency.drifted?
+        }
+      end
+
+      def serialize_dep(r)
+        {
+          name: r.name,
+          status: r.status.to_s,
+          detail: r.detail,
+          fix_command: r.fix_command
+        }
+      end
+
+      # ── Mutating steps (full setup only) ────────────────────────────
+
+      def ensure_daemon
+        # If the unit is drifted, surface the repair command rather than
+        # clobbering a hand-edited unit. install! without --force refuses
+        # to overwrite a drifted unit (returns :drifted), which is the
+        # safe default; the operator runs `hive daemon install --force`.
+        # Reuse the consistency probe run_diagnostics already performed
+        # instead of invoking @daemon_consistency.call a second time.
+        consistency = @daemon_consistency_result
+        if consistency.drifted?
+          @err.puts "hive setup: daemon unit is drifted (#{consistency.detail})."
+          @err.puts "  Repair with: #{consistency.repair_command}"
+          @report[:daemon_repair_needed] = true
+          @report[:ok] = false
+        else
+          ran = @shell.call([ "hive", "daemon", "install" ])
+          @report[:daemon_install_ran] = ran
+          @report[:ok] = false unless ran
+        end
+
+        unless @daemon_running.call
+          @err.puts "hive setup: starting daemon (detached)…"
+          started = @shell.call([ "hive", "daemon", "start", "--detach" ])
+          @report[:daemon_start_ran] = started
+          @report[:ok] = false unless started
+        end
+      end
+
+      def enroll_project
+        project = current_registered_project
+        if project
+          enrolled = @shell.call([ "hive", "daemon", "enable", project ])
+          @report[:enrolled_project] = enrolled ? project : nil
+          @report[:ok] = false unless enrolled
+        else
+          @err.puts "hive setup: #{truncate_home(@project_path)} is not a registered hive project."
+          @err.puts "  Run `hive init` here to enroll it for daemon dispatch."
+          @report[:enrollment_guidance] = true
+          # Enrollment is a core setup deliverable (the daemon will not
+          # pick up tasks from an unregistered project). Automation gating
+          # on `hive setup --json`'s `ok` must not proceed believing
+          # setup fully completed, so flip ok false on the guidance path.
+          @report[:ok] = false
+        end
+      end
+
+      def persist_agent_backends
+        prompt = @backend_prompt || Hive::Commands::Setup::BackendPrompt.new
+        selection = begin
+          prompt.collect
+        rescue Hive::Commands::Setup::BackendPrompt::Aborted
+          @err.puts "hive setup: agent backend selection aborted; keeping existing global agents."
+          return
+        end
+        Hive::Config.write_global_agents!(selection)
+        @report[:agent_backends] = selection
+      rescue Hive::ConfigError => e
+        @err.puts "hive setup: could not persist agent backends: #{e.message}"
+      end
+
+      def ensure_web
+        installed = @shell.call([ "hive", "web", "install" ])
+        @report[:ok] = false unless installed
+        started = @shell.call([ "hive", "web", "start" ])
+        @report[:web_started] = started
+        @report[:ok] = false unless started
+      end
+
+      # ── Reporting ───────────────────────────────────────────────────
+
+      def emit_report
+        if @json
+          emit_json_report
+        else
+          emit_text_report
+        end
+      end
+
+      def emit_json_report
+        payload = @report.transform_keys(&:to_s)
+        @output.puts JSON.generate(payload)
+      end
+
+      def emit_text_report
+        @output.puts "hive setup: local-mode diagnostic report"
+        @output.puts ""
+        @dependency_check.results.each do |r|
+          mark = r.ok? ? "✓" : "✗"
+          detail = r.detail.to_s.empty? ? "" : " — #{r.detail}"
+          @output.puts "  #{mark} #{r.name}#{detail}"
+          @output.puts "      fix: #{r.fix_command}" if r.failing? && r.fix_command
+        end
+        @output.puts ""
+        daemon = @report[:daemon]
+        mark = daemon_consistent?(daemon) ? "✓" : "✗"
+        @output.puts "  #{mark} daemon binary — #{daemon[:detail]}"
+        @output.puts "      fix: #{daemon[:repair_command]}" if daemon[:repair_command]
+        @output.puts ""
+
+        if @check_only
+          @output.puts(@report[:ok] ? "All checks passed." : "One or more checks failed — see fix commands above.")
+        else
+          summarize_actions
+        end
+      end
+
+      def daemon_consistent?(daemon)
+        daemon[:status] == "consistent"
+      end
+
+      def summarize_actions
+        lines = []
+        lines << "daemon service ensured" if @report[:daemon_install_ran]
+        lines << "daemon started" if @report[:daemon_start_ran]
+        if @report[:enrolled_project]
+          lines << "enrolled project #{@report[:enrolled_project]} for dispatch"
+        elsif @report[:enrollment_guidance]
+          lines << "project enrollment skipped (run `hive init`)"
+        end
+        lines << "agent backends: #{Array(@report[:agent_backends]).join(', ')}" if @report[:agent_backends]
+        lines << "web service installed and started" if @report[:web_started]
+        if @report[:daemon_repair_needed]
+          lines << "daemon unit drifted — repair needed (see above)"
+        end
+        @output.puts lines.join("; ") unless lines.empty?
+        @output.puts ""
+        @output.puts "Run the web UI in the foreground with `hive web`, or"
+        @output.puts "install the managed service with `hive web install && hive web start`."
+        @output.puts "Web will be at http://127.0.0.1:4567 (loopback, no auth by default)."
+      end
+
+      # ── Helpers ──────────────────────────────────────────────────────
+
+      def current_registered_project
+        projects = @registered_projects.call
+        match = projects.find { |p| p["path"] == @project_path }
+        match && match["name"]
+      end
+
+      def truncate_home(path)
+        home = ENV["HOME"].to_s
+        return path if home.empty? || !path.start_with?(home + "/")
+
+        "~#{path[home.length..]}"
+      end
+
+      def default_daemon_running?
+        probe = Object.new
+        probe.define_singleton_method(:pid_file) { File.join(Hive::Paths.state_home, ".daemon.pid") }
+        probe.extend(Hive::PidFile)
+        !probe.read_live_pid.nil?
+      end
+
+      def default_shell(argv)
+        system(*argv)
+      end
+    end
+  end
+end
