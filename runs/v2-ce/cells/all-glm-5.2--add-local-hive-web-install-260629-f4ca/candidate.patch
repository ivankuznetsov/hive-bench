diff --git a/test/unit/commands/setup_test.rb b/test/unit/commands/setup_test.rb
new file mode 100644
index 00000000..f1dc8b16
--- /dev/null
+++ b/test/unit/commands/setup_test.rb
@@ -0,0 +1,249 @@
+require "test_helper"
+require "json"
+require "hive/commands/setup"
+
+class SetupCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  # A dependency check double returning the given results.
+  def dep_check_double(results, ok: nil)
+    ok = results.all?(&:ok?) if ok.nil?
+    obj = Object.new
+    obj.define_singleton_method(:call) { obj }
+    obj.define_singleton_method(:results) { results }
+    obj.define_singleton_method(:ok?) { ok }
+    obj
+  end
+
+  def consistency_double(status:, installed: "/opt/hive/bin/hive", current: "/opt/hive/bin/hive",
+                         detail: "unit points at #{installed}", repair: nil)
+    r = Object.new
+    r.define_singleton_method(:call) { r }
+    r.define_singleton_method(:status) { status }
+    r.define_singleton_method(:installed_binary) { installed }
+    r.define_singleton_method(:current_binary) { current }
+    r.define_singleton_method(:detail) { detail }
+    r.define_singleton_method(:repair_command) { repair }
+    r.define_singleton_method(:consistent?) { status == :consistent }
+    r.define_singleton_method(:drifted?) { status == :drifted }
+    r
+  end
+
+  def make_result(name, status, detail: "", fix: nil)
+    Hive::Local::DependencyCheck::Result.new(name: name, status: status, detail: detail, fix_command: fix)
+  end
+
+  def stub_command(deps:, consistency:, daemon_running: false, shell_log: [],
+                   registered: [], backend_prompt: nil, **opts)
+    Hive::Commands::Setup.new(
+      project_path: opts.fetch(:project_path, Dir.mktmpdir("hive-setup")),
+      json: opts.fetch(:json, false),
+      check_only: opts.fetch(:check_only, false),
+      start_web: opts.fetch(:start_web, false),
+      dependency_check: deps,
+      daemon_consistency: consistency,
+      daemon_running: -> { daemon_running },
+      shell: ->(argv) { shell_log << argv; true },
+      registered_projects: -> { registered },
+      backend_prompt: backend_prompt,
+      output: StringIO.new,
+      err: StringIO.new
+    )
+  end
+
+  def test_check_only_exits_nonzero_when_dependencies_fail
+    with_xdg_home do
+      deps = dep_check_double([ make_result("git", :missing, detail: "not on PATH", fix: "Install git") ], ok: false)
+      consistency = consistency_double(status: :consistent)
+      cmd = stub_command(deps: deps, consistency: consistency, check_only: true)
+      exit_code = cmd.call
+      assert_equal 65, exit_code
+      refute cmd.report[:ok]
+    end
+  end
+
+  def test_check_only_exits_zero_when_all_pass
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok, detail: "ruby 3.4.10") ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      cmd = stub_command(deps: deps, consistency: consistency, check_only: true)
+      assert_equal 0, cmd.call
+      assert cmd.report[:ok]
+    end
+  end
+
+  def test_check_only_flags_daemon_drift
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :drifted, detail: "unit points at /usr/bin/hive",
+                                       repair: "hive daemon install --force")
+      cmd = stub_command(deps: deps, consistency: consistency, check_only: true)
+      exit_code = cmd.call
+      assert_equal 65, exit_code
+      refute cmd.report[:ok]
+      assert_equal "drifted", cmd.report[:daemon][:status]
+    end
+  end
+
+  def test_full_setup_starts_daemon_when_not_running
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      shell_log = []
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: false, shell_log: shell_log,
+                         registered: [], backend_prompt: stub_backend_prompt(%w[claude]))
+      cmd.call
+      assert shell_log.any? { |a| a == %w[hive daemon install] }
+      assert shell_log.any? { |a| a == %w[hive daemon start --detach] }
+      assert cmd.report[:daemon_install_ran]
+      assert cmd.report[:daemon_start_ran]
+    end
+  end
+
+  def test_full_setup_skips_start_when_daemon_already_running
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      shell_log = []
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: true, shell_log: shell_log,
+                         registered: [], backend_prompt: stub_backend_prompt(%w[claude]))
+      cmd.call
+      assert shell_log.any? { |a| a == %w[hive daemon install] }
+      refute shell_log.any? { |a| a[1] == "daemon" && a[2] == "start" }, "must not start when already running"
+      refute cmd.report[:daemon_start_ran]
+    end
+  end
+
+  def test_drifted_daemon_surfaces_repair_instead_of_install
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :drifted, repair: "hive daemon install --force")
+      shell_log = []
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: true, shell_log: shell_log,
+                         registered: [], backend_prompt: stub_backend_prompt(%w[claude]))
+      cmd.call
+      refute shell_log.any? { |a| a == %w[hive daemon install] }, "must not clobber a drifted unit"
+      assert cmd.report[:daemon_repair_needed]
+    end
+  end
+
+  def test_enrolls_registered_current_project
+    Dir.mktmpdir("hive-proj") do |dir|
+      with_xdg_home do
+        deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+        consistency = consistency_double(status: :consistent)
+        shell_log = []
+        registered = [ { "name" => "myproj", "path" => dir, "hive_state_path" => File.join(dir, ".hive-state") } ]
+        cmd = stub_command(deps: deps, consistency: consistency,
+                           daemon_running: true, shell_log: shell_log,
+                           registered: registered, project_path: dir,
+                           backend_prompt: stub_backend_prompt(%w[claude]))
+        cmd.call
+        assert shell_log.any? { |a| a == %w[hive daemon enable myproj] }
+        assert_equal "myproj", cmd.report[:enrolled_project]
+      end
+    end
+  end
+
+  def test_unregistered_project_emits_enrollment_guidance
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: true, registered: [],
+                         backend_prompt: stub_backend_prompt(%w[claude]))
+      err = cmd.instance_variable_get(:@err)
+      exit_code = cmd.call
+      assert cmd.report[:enrollment_guidance]
+      refute cmd.report[:ok], "unregistered project must not report setup fully completed"
+      assert_match(/hive init/, err.string)
+      assert_equal 65, exit_code, "unregistered project must exit non-zero so automation stops"
+    end
+  end
+
+  def test_full_setup_surfaces_ok_false_when_shell_calls_fail
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      shell_log = []
+      # Every `@shell.call` reports failure — install/start/enable must not
+      # be sealed as success; @report[:ok] must flip to false.
+      cmd = Hive::Commands::Setup.new(
+        project_path: Dir.mktmpdir("hive-setup"),
+        json: false, check_only: false, start_web: true,
+        dependency_check: deps, daemon_consistency: consistency,
+        daemon_running: -> { false },
+        shell: ->(argv) { shell_log << argv; false },
+        registered_projects: -> { [] },
+        backend_prompt: stub_backend_prompt(%w[claude]),
+        output: StringIO.new, err: StringIO.new
+      )
+      exit_code = cmd.call
+      refute cmd.report[:ok], "a failed shell call must flip @report[:ok] to false"
+      assert_equal 65, exit_code, "full setup must exit non-zero when a mutating step failed"
+      refute cmd.report[:daemon_install_ran], "failed install must not be reported as ran"
+      refute cmd.report[:daemon_start_ran], "failed daemon start must not be reported as ran"
+      refute cmd.report[:web_started], "failed web install/start must not be reported as started"
+    end
+  end
+
+  def test_start_web_runs_web_install_and_start
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      shell_log = []
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: true, shell_log: shell_log,
+                         registered: [], start_web: true,
+                         backend_prompt: stub_backend_prompt(%w[claude]))
+      cmd.call
+      assert shell_log.any? { |a| a == %w[hive web install] }
+      assert shell_log.any? { |a| a == %w[hive web start] }
+      assert cmd.report[:web_started]
+    end
+  end
+
+  def test_persists_agent_backends
+    with_xdg_home do
+      deps = dep_check_double([ make_result("ruby", :ok) ], ok: true)
+      consistency = consistency_double(status: :consistent)
+      cmd = stub_command(deps: deps, consistency: consistency,
+                         daemon_running: true, registered: [],
+                         backend_prompt: stub_backend_prompt(%w[claude codex]))
+      cmd.call
+      assert_equal %w[claude codex], cmd.report[:agent_backends]
+      # The persisted global agents should now reflect the selection.
+      assert_equal %w[claude codex], Hive::Config.load_global_agents
+    end
+  end
+
+  def test_json_report_shape
+    with_xdg_home do
+      out = StringIO.new
+      deps = dep_check_double([ make_result("git", :missing, fix: "Install git") ], ok: false)
+      consistency = consistency_double(status: :consistent)
+      cmd = Hive::Commands::Setup.new(
+        project_path: Dir.mktmpdir("hive-setup"),
+        json: true, check_only: true,
+        dependency_check: deps, daemon_consistency: consistency,
+        daemon_running: -> { false }, shell: ->(_a) { true },
+        registered_projects: -> { [] },
+        output: out, err: StringIO.new
+      )
+      cmd.call
+      payload = JSON.parse(out.string)
+      refute payload["ok"]
+      assert_equal "missing", payload["dependencies"].first["status"]
+      assert_equal "consistent", payload["daemon"]["status"]
+    end
+  end
+
+  def stub_backend_prompt(selection)
+    prompt = Object.new
+    prompt.define_singleton_method(:collect) { selection }
+    prompt
+  end
+end
