+                  "or `hive web status --json` for service state."
+        @output.puts JSON.generate(
+          "ok" => false,
+          "error_class" => "InvalidTaskPath",
+          "error_kind" => "invalid_task_path",
+          "exit_code" => Hive::ExitCodes::USAGE,
+          "message" => message
+        )
+        raise Hive::InvalidTaskPath, message
+      end
+
+      def safe_platform(installer)
+        installer.envelope_platform
+      rescue StandardError
+        "unsupported"
+      end
+
+      def safe_target_path(installer)
+        installer.target_path
+      rescue StandardError
+        nil
+      end
+
+      def safe_messages(installer)
+        installer.messages.dup
+      rescue StandardError
+        []
+      end
     end
   end
 end
