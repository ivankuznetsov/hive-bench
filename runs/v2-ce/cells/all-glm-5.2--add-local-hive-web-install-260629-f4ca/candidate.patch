+require "cgi"
+require "shellwords"
+require "hive/commands/service_installer/base"
+
+module Hive
+  module Commands
+    class Web
+      # Per-user autostart installer for the local (non-Docker) Hive web
+      # UI. Inherits the platform-agnostic mechanics (drift/backup,
+      # atomic write, shim-PATH detection, enable/load orchestration)
+      # from the shared base and supplies only the web service's
+      # identity and rendered unit/plist bodies.
+      #
+      # Mirrors the daemon and bot installers. Like the bot, the web
+      # service has no HIVE_BIN line (it does not shell out to a separate
+      # `hive status` consumer the way the daemon does) and no in-flight
+      # child drain, so there is no TimeoutStopSec=900 / KillMode=mixed
+      # and no upgrade-restart warning. The unit runs `hive web run` in
+      # the foreground; systemd/launchd is the supervisor.
+      class ServiceInstaller < Hive::Commands::ServiceInstaller::Base
+        def service_name
+          "hive-web"
+        end
+
+        def cli_label
+          "web"
+        end
+
+        def service_noun
+          "web service"
+        end
+
+        def unit_noun
+          "web unit"
+        end
+
+        def target_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/local.hive-web.plist")
+          when :linux then File.join(@home, ".config/systemd/user/hive-web.service")
+          end
+        end
+
+        private
+
+        def render_systemd
+          template = File.read(File.expand_path("../../../../examples/systemd/hive-web.service", __dir__))
+          # systemd .service files are POSIX-shell-ish — escape the
+          # resolved binary path so whitespace, `%`, or other special
+          # characters don't produce a malformed unit. No HIVE_BIN line
+          # to rewrite (only the daemon's status_consumer needs that).
+          escaped = Shellwords.escape(resolved_binary)
+          template
+            .sub(/^ExecStart=.*$/, "ExecStart=#{escaped} web run")
+            .sub(/^Environment=PATH=.*$/, build_path_line)
+        end
+
+        def render_launchd
+          template = File.read(File.expand_path("../../../../examples/launchd/hive-web.plist", __dir__))
+          binary = resolved_binary
+          # dirname BEFORE HTML-escaping so paths with `&`/`<`/`>` get
+          # the correct directory segmentation; then escape both for
+          # plist XML safety.
+          binary_dir = File.dirname(binary)
+          escaped_binary = CGI.escapeHTML(binary)
+          escaped_binary_dir = CGI.escapeHTML(binary_dir)
+          escaped_home = CGI.escapeHTML(@home)
+          template
+            .gsub(%r{<string>/Users/YOU/\.local/bin/hive</string>}, "<string>#{escaped_binary}</string>")
+            .gsub("/Users/YOU/Library/Logs", "#{escaped_home}/Library/Logs")
+            .gsub("/Users/YOU/.local/bin", escaped_binary_dir)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/local/daemon_consistency.rb b/lib/hive/local/daemon_consistency.rb
new file mode 100644
index 00000000..a76edaaa
--- /dev/null
+++ b/lib/hive/local/daemon_consistency.rb
@@ -0,0 +1,156 @@
+require "shellwords"
+require "hive/commands/daemon/service_installer"
+require "hive/invoked_binary"
+
+module Hive
+  module Local
+    # Detects drift between the installed daemon service unit's Hive binary
+    # and the currently-running CLI's binary — the documented local-mode
+    # failure where systemd/launchd drifts to `/usr/bin/hive` or a stale
+    # version after an upgrade. Used by `hive setup` so the daemon runs
+    # with the same Hive binary/version as the CLI.
+    #
+    # Non-mutating: it reads the on-disk unit and compares the rendered
+    # binary path to the current `Hive::InvokedBinary.path`. It does NOT
+    # rewrite or restart the unit; repair is delegated to
+    # `hive daemon install --force` (which the setup command surfaces).
+    #
+    # Version drift (same path, upgraded binary not yet restarted) is not
+    # detectable from the unit file alone — that is addressed by setup
+    # running `hive daemon install` (which restarts on upgrade) and is
+    # noted in wiki/gaps.
+    class DaemonConsistency
+      Result = Data.define(:status, :installed_binary, :current_binary, :detail, :repair_command) do
+        # :consistent — unit points at the current CLI binary.
+        # :drifted    — unit points at a different binary (repair with --force).
+        # :not_installed — no unit file on disk.
+        # :unsupported   — host has no native unit path.
+        def consistent?
+          status == :consistent
+        end
+
+        def drifted?
+          status == :drifted
+        end
+      end
+
+      def initialize(daemon_installer: nil, current_binary: Hive::InvokedBinary.path,
+                     unit_reader: method(:default_unit_reader))
+        @installer = daemon_installer || default_installer
+        @current_binary = current_binary
+        @unit_reader = unit_reader
+      end
+
+      def call
+        path = @installer.target_path
+        return Result.new(status: :unsupported, installed_binary: nil, current_binary: @current_binary,
+                          detail: "no native daemon unit path on this platform",
+                          repair_command: "run `hive daemon start` manually") if path.nil?
+
+        content = @unit_reader.call(path)
+        return Result.new(status: :not_installed, installed_binary: nil, current_binary: @current_binary,
+                          detail: "no daemon unit at #{path}",
+                          repair_command: "hive daemon install") unless content
+
+        installed = extract_binary(content, @installer.envelope_platform)
+        if installed.nil?
+          # The unit exists but we couldn't parse a binary path — treat as
+          # drifted so the operator re-renders it rather than silently
+          # trusting an unparseable hand-edit.
+          return Result.new(status: :drifted, installed_binary: nil, current_binary: @current_binary,
+                            detail: "could not parse binary from #{path}",
+                            repair_command: "hive daemon install --force")
+        end
+
+        if same_binary?(installed, @current_binary)
+          Result.new(status: :consistent, installed_binary: installed, current_binary: @current_binary,
+                     detail: "unit points at #{installed}", repair_command: nil)
+        else
+          Result.new(status: :drifted, installed_binary: installed, current_binary: @current_binary,
+                     detail: "unit points at #{installed}; CLI is #{@current_binary}",
+                     repair_command: "hive daemon install --force")
+        end
+      end
+
+      private
+
+      def extract_binary(content, platform)
+        case platform
+        when "linux"
+          # Prefer HIVE_BIN (daemon-specific), fall back to ExecStart's
+          # first token. The unit stores both Shellwords-escaped
+          # (`Environment=HIVE_BIN=#{Shellwords.escape(bin)}`), so a
+          # binary path with spaces round-trips as `/my\ dir/hive` —
+          # a literal backslash-space in the unit file. Capture the full
+          # line value (not `\S+`, which stops at the escaped space) and
+          # unescape before returning so same_binary? resolves the real
+          # path instead of the escaped literal (which would ENOENT and
+          # false-report :drifted).
+          match = content.match(/^Environment=HIVE_BIN=(.*)$/)
+          value = match && match[1].strip
+          return unescape_path(value) if match && !value.empty?
+
+          match = content.match(/^ExecStart=(.*)$/)
+          match && first_shellword(match[1].strip)
+        when "macos"
+          # The binary is the <string> immediately preceding
+          # <string>daemon</string> in ProgramArguments. launchd stores
+          # the path HTML-escaped (CGI.escapeHTML), not Shellwords-escaped,
+          # so no shell-unescape is needed here.
+          match = content.match(%r{<string>([^<]+)</string>\s*<string>daemon</string>})
+          match && match[1]
+        else
+          nil
+        end
+      end
+
+      # Resolve both paths through File.realpath so a symlinked wrapper
+      # (the common Homebrew / .local/bin case) compares equal to the
+      # realpath the installer baked into the unit.
+      def same_binary?(installed, current)
+        return true if installed == current
+        return false if installed.nil? || current.nil?
+
+        resolve(installed) == resolve(current)
+      rescue Errno::ENOENT
+        # One of the paths no longer exists — they can't be the same.
+        false
+      end
+
+      def resolve(path)
+        File.exist?(path) ? File.realpath(path) : File.expand_path(path)
+      end
+
+      # First shell word of an ExecStart value (e.g.
+      # `/my\ dir/hive daemon start` -> `/my dir/hive`). Resolves the
+      # escaped binary path; falls back to the raw first whitespace
+      # token if the value is hand-edited and not shell-parseable.
+      def first_shellword(value)
+        Shellwords.shellsplit(value).first
+      rescue ArgumentError
+        value.split.first
+      end
+
+      # The unit stores binary paths Shellwords-escaped (e.g.
+      # `/my\ dir/hive`); resolve the literal unescaped path so a binary
+      # whose realpath contains spaces compares equal instead of
+      # ENOENT-ing and false-reporting :drifted. `Shellwords.shellsplit`
+      # on a single token returns a one-element array of the unescaped
+      # path. Fall back to the raw token if the unit was hand-edited with
+      # an unparseable value (preserves the prior :drifted surfacing).
+      def unescape_path(token)
+        Shellwords.shellsplit(token.to_s).first
+      rescue ArgumentError
+        token
+      end
+
+      def default_installer
+        Hive::Commands::Daemon::ServiceInstaller.new
+      end
+
+      def default_unit_reader(path)
+        File.read(path) if File.exist?(path)
+      end
+    end
+  end
+end
diff --git a/lib/hive/local/dependency_check.rb b/lib/hive/local/dependency_check.rb
new file mode 100644
index 00000000..cdb5b893
--- /dev/null
+++ b/lib/hive/local/dependency_check.rb
@@ -0,0 +1,354 @@
+require "fileutils"
+require "open3"
+require "timeout"
+
+require "hive"
+
+module Hive
+  # Local (non-Docker) install/run mode helpers. These operate on the
+  # user's real Hive/XDG state and checked-out repos (no sandbox) and
+  # mirror the OpenClaw local UX pattern: zero/low-config loopback,
+  # diagnostics, and exact fix commands. See [[commands/web]] and the
+  # `hive setup` command.
+  module Local
+    # Verifies the prerequisites for running the Hive web UI and daemon
+    # locally (outside the Docker/hivebox image). Used by `hive setup`
+    # and surfaced via `hive setup --check`.
+    #
+    # The checker NEVER silently installs or authenticates external agent
+    # CLIs (claude / codex / gh) — it diagnoses and emits the exact
+    # command the operator must run. Hive-owned deps (qmd, the web
+    # bundle) are reported with bootstrap commands but not auto-fixed
+    # here; `hive setup` owns the bootstrap step.
+    #
+    # Every collaborator (binary lookup, command invocation, ruby/web-app
+    # paths) is injectable so the full matrix is unit-testable without a
+    # real toolchain.
+    class DependencyCheck
+      # status values a Result can carry. `ok` and `present` are passing;
+      # everything else is failing. `unauthenticated` is distinct from
+      # `missing` so setup can emit the right fix command (install vs
+      # login).
+      STATUSES = %i[ok present missing unauthenticated wrong_version unavailable].freeze
+      FAILING = %i[missing unauthenticated wrong_version unavailable].freeze
+
+      MIN_RUBY = "3.4.0"
+
+      Result = Data.define(:name, :status, :detail, :fix_command) do
+        def ok?
+          !FAILING.include?(status)
+        end
+
+        def failing?
+          FAILING.include?(status)
+        end
+      end
+
+      attr_reader :results
+
+      def initialize(which: method(:default_which), runner: method(:default_runner),
+                     ruby_version: RUBY_VERSION, web_app_dir: nil, claude_min_version: Hive::MIN_CLAUDE_VERSION,
+                     timeout: 15)
+        @which = which
+        @runner = runner
+        @ruby_version = ruby_version
+        @web_app_dir = web_app_dir || default_web_app_dir
+        @claude_min_version = claude_min_version
+        @timeout = timeout
+        @results = []
+      end
+
+      def call
+        @results = [
+          check_ruby,
+          check_binary("git", "Install git: https://git-scm.com/downloads " \
+                              "(e.g. `brew install git` or `sudo apt install git`)"),
+          check_binary("tmux", "Install tmux: e.g. `brew install tmux` or `sudo apt install tmux`"),
+          check_gh,
+          check_claude,
+          check_codex,
+          check_binary("node", "Install Node.js (LTS): https://nodejs.org/ " \
+                               "(provides `node` and `npm`)"),
+          check_binary("npm", "Install npm (ships with Node.js): https://nodejs.org/"),
+          check_qmd,
+          check_web_bundle,
+          check_sqlite
+        ].freeze
+        self
+      end
+
+      def failing
+        results.select(&:failing?)
+      end
+
+      def ok?
+        failing.empty?
+      end
+
+      # Human-readable summary for `hive setup` / `hive setup --check`.
+      def summary
+        call unless @results.any?
+        lines = @results.map do |r|
+          mark = r.ok? ? "✓" : "✗"
+          detail = r.detail.to_s.empty? ? "" : " — #{r.detail}"
+          "  #{mark} #{r.name}#{detail}"
+        end
+        lines << "" << (ok? ? "All local-mode dependencies are present." :
+                              "#{failing.length} dependency check(s) failed — see fix commands above.")
+        lines.join("\n")
+      end
+
+      private
+
+      # ── Individual checks ───────────────────────────────────────────
+
+      def check_ruby
+        if version_gte?(@ruby_version, MIN_RUBY)
+          Result.new(name: "ruby", status: :ok, detail: "ruby #{@ruby_version}", fix_command: nil)
+        else
+          Result.new(name: "ruby", status: :wrong_version,
+                     detail: "ruby #{@ruby_version} < #{MIN_RUBY}",
+                     fix_command: "Install Ruby >= #{MIN_RUBY} (https://www.ruby-lang.org/en/downloads/) " \
+                                  "or use a version manager (mise / rbenv / asdf)")
+        end
+      end
+
+      def check_binary(name, fix)
+        path = @which.call(name)
+        return Result.new(name: name, status: :present, detail: path, fix_command: nil) if path
+
+        Result.new(name: name, status: :missing, detail: "not on PATH", fix_command: fix)
+      end
+
+      def check_gh
+        path = @which.call("gh")
+        unless path
+          return Result.new(name: "gh", status: :missing, detail: "not on PATH",
+                            fix_command: "Install gh: https://cli.github.com/ then run `gh auth login`")
+        end
+
+        # `gh auth status` exits 0 only when authenticated. Treat a
+        # present-but-unauthenticated gh as a distinct failure so setup
+        # emits the login command rather than an install command.
+        _, _, status = run_with_timeout([ "gh", "auth", "status" ])
+        return Result.new(name: "gh", status: :ok, detail: "#{path} (authenticated)", fix_command: nil) if status&.success?
+
+        Result.new(name: "gh", status: :unauthenticated, detail: "#{path} (not logged in)",
+                   fix_command: "Run `gh auth login` to authenticate the GitHub CLI")
+      end
+
+      def check_claude
+        path = @which.call("claude")
+        unless path
+          return Result.new(name: "claude", status: :missing, detail: "not on PATH",
+                            fix_command: "Install claude: `npm install -g @anthropic-ai/claude-code` " \
+                                         "then run `claude setup-token`")
+        end
+
+        out, = run_with_timeout([ path, "--version" ])
+        version = parse_version(out)
+        if version && version_gte?(version, @claude_min_version)
+          return Result.new(name: "claude", status: :ok, detail: "#{path} (#{version})",
+                            fix_command: nil)
+        end
+
+        if version
+          Result.new(name: "claude", status: :wrong_version, detail: "#{path} (#{version} < #{@claude_min_version})",
+                     fix_command: "Upgrade claude: `npm install -g @anthropic-ai/claude-code` " \
+                                  "(>= #{@claude_min_version}), then `claude setup-token`")
+        else
+          Result.new(name: "claude", status: :unauthenticated, detail: "#{path} (no version / not authenticated)",
+                     fix_command: "Run `claude setup-token` to authenticate claude")
+        end
+      end
+
+      def check_codex
+        path = @which.call("codex")
+        unless path
+          return Result.new(name: "codex", status: :missing, detail: "not on PATH",
+                            fix_command: "Install codex: `npm install -g @openai/codex` " \
+                                         "then run `codex login --device-auth`")
+        end
+
+        Result.new(name: "codex", status: :present, detail: path, fix_command: nil)
+      end
+
+      # qmd is Hive-owned. It may live under XDG_DATA_HOME/hive/qmd/bin
+      # rather than on PATH; mirror doctor's discovery so the check and
+      # the agent runtime agree on what "installed" means.
+      def check_qmd
+        path = find_qmd
+        unless path
+          return Result.new(name: "qmd", status: :missing, detail: "not found",
+                            fix_command: "Install qmd: `npm install --global --prefix " \
+                                         "\"${XDG_DATA_HOME:-$HOME/.local/share}/hive/qmd\" @tobilu/qmd` " \
+                                         "(or run `hive update`, which repairs qmd on bash-channel installs)")
+        end
+
+        out, err, status = run_with_timeout([ path, "--version" ])
+        if status&.success?
+          Result.new(name: "qmd", status: :present, detail: "#{path} (#{out.strip})", fix_command: nil)
+        else
+          Result.new(name: "qmd", status: :unavailable, detail: "#{path} (failed to start: #{err.strip})",
+                     fix_command: "Reinstall qmd: `npm rebuild better-sqlite3` or rerun the install command above")
+        end
+      end
+
+      # The Rails web app is NOT packaged in the gem — local web mode
+      # requires the app to exist (a source checkout or HIVEBOX_WEB_APP_DIR).
+      def check_web_bundle
+        dir = @web_app_dir
+        unless dir && File.file?(File.join(dir, "config", "application.rb"))
+          return Result.new(name: "web bundle", status: :unavailable,
+                            detail: "Rails app not found",
+                            fix_command: "Point HIVEBOX_WEB_APP_DIR at a checkout of the hive web/ app, " \
+                                         "or run from a source checkout")
+        end
+
+        # `bundle check` exits 0 when the bundle is installed, non-zero
+        # when it isn't. Run it in the app dir; never auto-install.
+        _, _, status = run_with_timeout([ "bundle", "check" ], chdir: dir)
+        if status&.success?
+          Result.new(name: "web bundle", status: :ok, detail: dir, fix_command: nil)
+        else
+          Result.new(name: "web bundle", status: :missing, detail: "gems not installed",
+                     fix_command: "cd #{dir} && bundle install")
+        end
+      end
+
+      def check_sqlite
+        # The solid_cable/cache/queue stack ships sqlite3 via the Rails
+        # gem; a missing `sqlite3` binary on PATH is fine as long as the
+        # gem resolves. Surface the storage dir writability instead — a
+        # read-only state_home is the real operational blocker.
+        #
+        # `--check` is non-mutating: probe writability WITHOUT creating
+        # any directory (mkdir_p here would contradict the CLI's
+        # `--check is non-mutating` contract). `hive web` (run_foreground)
+        # creates the storage dir on the foreground/full-setup path, so a
+        # check must not.
+        storage = File.join(Hive::Paths.state_home, "web-storage")
+        unless writable_for?(storage)
+          return Result.new(name: "sqlite/storage", status: :unavailable,
+                            detail: "#{storage} not writable",
+                            fix_command: "Fix permissions on #{File.dirname(storage)} (or HIVE_HOME) so the web sqlite files can be written")
+        end
+
+        Result.new(name: "sqlite/storage", status: :ok, detail: storage, fix_command: nil)
+      end
+
+      # Non-mutating writability probe for `--check`: if the target exists,
+      # test it directly; otherwise walk up to the nearest existing
+      # ancestor and test that. Never creates a directory — run_foreground
+      # owns creation on the foreground path. A read-only filesystem or an
+      # unwritable ancestor surfaces as `false` (unavailable) without a
+      # mkdir side-effect.
+      def writable_for?(path)
+        dir = path
+        until File.exist?(dir)
+          parent = File.dirname(dir)
+          return false if parent == dir # reached root without an existing ancestor
+
+          dir = parent
+        end
+        File.writable?(dir)
+      end
+
+      # ── Helpers ──────────────────────────────────────────────────────
+
+      def find_qmd
+        env_qmd = ENV["HIVE_QMD_BIN"].to_s
+        return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+        path_qmd = @which.call("qmd")
+        return path_qmd if path_qmd
+
+        data_home = ENV["XDG_DATA_HOME"].to_s.empty? ? File.expand_path("~/.local/share") : ENV["XDG_DATA_HOME"]
+        candidate = File.join(data_home, "hive", "qmd", "bin", "qmd")
+        candidate if File.executable?(candidate)
+      end
+
+      def run_with_timeout(argv, chdir: nil)
+        @runner.call(argv, chdir: chdir)
+      end
+
+      def parse_version(out)
+        out.to_s[/(\d+\.\d+\.\d+)/, 1]
+      end
+
+      # Compare dotted versions as a tuple of integers. "3.4.10" > "3.4.9".
+      def version_gte?(actual, minimum)
+        a = actual.to_s.split(".").map { |n| Integer(n) rescue 0 }
+        m = minimum.to_s.split(".").map { |n| Integer(n) rescue 0 }
+        (a <=> m) >= 0
+      rescue ArgumentError
+        false
+      end
+
+      def default_web_app_dir
+        ENV["HIVEBOX_WEB_APP_DIR"] || File.expand_path("../../../web", __dir__)
+      end
+
+      def default_which(name)
+        ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, name)
+          return path if File.file?(path) && File.executable?(path)
+        end
+        nil
+      end
+
+      def default_runner(argv, chdir: nil)
+        # Spawn the child in its own process group so a timeout can reap
+        # the whole group (the binary plus any helper processes it forked).
+        # `Open3.capture3` under `Timeout.timeout` does NOT guarantee the
+        # child is killed when the timer fires — the block form waits on
+        # the process on the way out, leaking a hung `gh auth status` /
+        # `claude --version` / `bundle check`. We spawn with `pgroup:
+        # true`, drain stdout/stderr concurrently (capture3's deadlock
+        # guard for large stderr), and on timeout TERM the group before
+        # reaping so no subprocess is orphaned.
+        require "open3"
+        spawn_opts = { pgroup: true }
+        spawn_opts[:chdir] = chdir if chdir
+        stdin, stdout, stderr, wait_thr = Open3.popen3(*argv, **spawn_opts)
+        stdin.close
+        pid = wait_thr.pid
+        out_reader = Thread.new { stdout.read }
+        err_reader = Thread.new { stderr.read }
+        begin
+          out, err = Timeout.timeout(@timeout) { [ out_reader.value, err_reader.value ] }
+          status = wait_thr.value
+          [ out, err, status ]
+        rescue Timeout::Error
+          kill_process_group(pid)
+          # Killing the child closes its pipes, letting the readers finish.
+          out_reader.join(2)
+          err_reader.join(2)
+          status = begin
+                     wait_thr.value
+                   rescue Errno::ECHILD
+                     nil
+                   end
+          [ "", "timed out after #{@timeout}s", status ]
+        ensure
+          stdout.close unless stdout.closed?
+          stderr.close unless stderr.closed?
+        end
+      rescue SystemCallError => e
+        [ "", e.message, nil ]
+      end
+
+      # Signal the spawned process group (negative pid) and the leader so a
+      # hung child plus any helper it forked are reaped on timeout. Spawned
+      # with `pgroup: true`, the child is its own group leader so its pgid
+      # equals its pid; `-pid` reaches every member of that group.
+      def kill_process_group(pid)
+        Process.kill("TERM", -pid)
+      rescue Errno::ESRCH, Errno::EINVAL
+        Process.kill("TERM", pid)
+      rescue Errno::ESRCH, Errno::EINVAL
+        nil
+      end
+    end
+  end
+end
diff --git a/schemas/hive-web-install.v1.json b/schemas/hive-web-install.v1.json
new file mode 100644
index 00000000..4c7d4a74
--- /dev/null
+++ b/schemas/hive-web-install.v1.json
@@ -0,0 +1,105 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-web-install.v1.json",
+  "title": "hive web install output (v1)",
+  "description": "Stable contract emitted by `hive web install --json` (and `hive web install --force --json`) for the local (non-Docker) managed web service. Mirrors hive-daemon-install / hive-bot-install. Idempotent: a no-op install against a matching unit returns ok=true with outcome=unchanged. Drift without --force returns ok=false with outcome=drifted and exit_code=64 so agents can branch `hive web install --json || (test $? = 64 && hive web install --force --json)`. Internal failures (systemctl reload/start/restart, launchctl load) return ok=false with outcome=failed and exit_code=70. The web unit runs `hive web run` in the foreground; systemd/launchd is the supervisor.",
+  "oneOf": [
+    { "$ref": "#/$defs/SuccessPayload" },
+    { "$ref": "#/$defs/ErrorPayload" }
+  ],
+  "$defs": {
+    "SuccessPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "outcome",
+        "platform",
+        "target_path",
+        "restarted"
+      ],
+      "properties": {
+        "schema": { "const": "hive-web-install" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": true },
+        "outcome": {
+          "type": "string",
+          "enum": [ "written", "upgraded", "unchanged", "unsupported" ],
+          "description": "What happened on disk. `written` = no prior unit, new file created. `upgraded` = existing unit differed and --force overwrote it (backup_path is set). `unchanged` = existing unit already matches the rendered template. `unsupported` = autostart could not be enabled on this host (no native install path, or unit written but service manager absent)."
+        },
+        "platform": {
+          "type": "string",
+          "enum": [ "linux", "macos", "unsupported" ],
+          "description": "Resolved install platform from RbConfig::CONFIG[\"host_os\"]."
+        },
+        "target_path": {
+          "type": [ "string", "null" ],
+          "description": "Absolute path of the platform-native unit file. Null only on a host with no native install path at all; set (even on the `unsupported` outcome) whenever a unit file was actually written."
+        },
+        "backup_path": {
+          "type": [ "string", "null" ],
+          "description": "Absolute path of the timestamped backup file written before --force overwrote the unit. Null on outcomes other than `upgraded` and when the existing unit already matched."
+        },
+        "restarted": {
+          "type": "boolean",
+          "description": "True if this call restarted the running service on a force-upgrade. The web installer currently has no in-flight child drain to warn about, so this mirrors the bot's behavior. False on first-time install and on no-op `unchanged` outcomes."
+        },
+        "messages": {
+          "type": "array",
+          "items": { "type": "string" },
+          "description": "Operator-facing notices emitted by the installer (binary-path fallback warnings, systemd-missing notes, etc.). Stable line shape but no schema enum — meant for human display, not programmatic branching."
+        }
+      }
+    },
+    "ErrorPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "error_class",
+        "error_kind",
+        "exit_code",
+        "message"
+      ],
+      "properties": {
+        "schema": { "const": "hive-web-install" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": false },
+        "error_class": {
+          "type": "string",
+          "enum": [ "WebInstallDriftError", "WebInstallFailed", "Error" ]
+        },
+        "error_kind": {
+          "type": "string",
+          "enum": [ "drifted", "failed", "internal" ],
+          "description": "`drifted` = pre-existing unit differs from the rendered template and --force was not passed (recoverable, retry with --force). `failed` = a service-manager call (systemctl / launchctl) reported failure (investigate, see messages). `internal` = uncategorised."
+        },
+        "exit_code": {
+          "type": "integer",
+          "enum": [ 1, 64, 70 ],
+          "description": "Process exit code the CLI will set. 64 = USAGE (drift, retryable with --force). 70 = SOFTWARE (service-manager failure). 1 = GENERIC (uncategorised)."
+        },
+        "message": { "type": "string" },
+        "outcome": {
+          "type": "string",
+          "enum": [ "drifted", "failed" ]
+        },
+        "platform": {
+          "type": "string",
+          "enum": [ "linux", "macos", "unsupported" ]
+        },
+        "target_path": {
+          "type": [ "string", "null" ]
+        },
+        "messages": {
+          "type": "array",
+          "items": { "type": "string" }
+        }
+      }
+    }
+  }
+}
