new file mode 100644
index 00000000..0d1cbaa0
--- /dev/null
+++ b/test/unit/local/dependency_check_test.rb
@@ -0,0 +1,206 @@
+require "test_helper"
+require "hive/local/dependency_check"
+require "rbconfig"
+
+class LocalDependencyCheckTest < Minitest::Test
+  include HiveTestHelper
+
+  # A `which` stub that maps names → path (or nil). Returns nil for
+  # anything not in the map, so missing deps surface as :missing.
+  def which_stub(map)
+    ->(name) { map[name] }
+  end
+
+  # A `runner` stub that maps a joined command string → [out, err, status].
+  # status is wrapped in a Process::Status-like double responding to
+  # #success?. Unknown commands default to a failing exit so checks don't
+  # accidentally pass.
+  def runner_stub(map)
+    ->(argv, chdir: nil) do
+      key = argv.join(" ")
+      entry = map[key]
+      entry || [ "", "not stubbed", status_double(false) ]
+    end
+  end
+
+  def status_double(success)
+    Struct.new(:success?).new(success)
+  end
+
+  def check(ruby: "3.4.10", which: {}, runner: {}, web_app_dir: nil, claude_min: "2.1.118")
+    Hive::Local::DependencyCheck.new(
+      ruby_version: ruby,
+      which: which_stub(which),
+      runner: runner_stub(runner),
+      web_app_dir: web_app_dir,
+      claude_min_version: claude_min
+    ).tap(&:call)
+  end
+
+  def with_writable_state_home
+    with_xdg_home do |dir|
+      yield dir
+    end
+  end
+
+  def test_all_present_reports_ok
+    with_writable_state_home do
+      which = {
+        "git" => "/usr/bin/git", "tmux" => "/usr/bin/tmux",
+        "gh" => "/usr/bin/gh", "claude" => "/usr/bin/claude",
+        "codex" => "/usr/bin/codex", "node" => "/usr/bin/node",
+        "npm" => "/usr/bin/npm", "qmd" => "/usr/bin/qmd"
+      }
+      runner = {
+        "gh auth status" => [ "", "", status_double(true) ],
+        "/usr/bin/claude --version" => [ "2.1.179", "", status_double(true) ],
+        "/usr/bin/qmd --version" => [ "1.0.0", "", status_double(true) ]
+      }
+      Dir.mktmpdir("hive-webapp") do |app|
+        FileUtils.mkdir_p(File.join(app, "config"))
+        File.write(File.join(app, "config", "application.rb"), "# marker")
+        checker = check(which: which, runner: runner, web_app_dir: app)
+        runner_stub_for_bundle = runner.merge("bundle check" => [ "", "", status_double(true) ])
+        checker = Hive::Local::DependencyCheck.new(
+          ruby_version: "3.4.10", which: which_stub(which),
+          runner: runner_stub(runner_stub_for_bundle), web_app_dir: app
+        )
+        checker.call
+        assert checker.ok?, checker.summary
+        assert_empty checker.failing
+      end
+    end
+  end
+
+  def test_missing_git_reported_with_fix_command
+    with_writable_state_home do
+      checker = check(which: {})
+      git = checker.results.find { |r| r.name == "git" }
+      assert_equal :missing, git.status
+      assert_match(/Install git/, git.fix_command)
+      refute checker.ok?
+    end
+  end
+
+  def test_old_ruby_is_wrong_version
+    with_writable_state_home do
+      checker = check(ruby: "3.3.0")
+      ruby = checker.results.find { |r| r.name == "ruby" }
+      assert_equal :wrong_version, ruby.status
+      assert_match(/Install Ruby/, ruby.fix_command)
+    end
+  end
+
+  def test_gh_present_but_unauthenticated
+    with_writable_state_home do
+      which = { "gh" => "/usr/bin/gh" }
+      runner = { "gh auth status" => [ "", "not logged in", status_double(false) ] }
+      checker = check(which: which, runner: runner)
+      gh = checker.results.find { |r| r.name == "gh" }
+      assert_equal :unauthenticated, gh.status
+      assert_match(/gh auth login/, gh.fix_command)
+    end
+  end
+
+  def test_claude_version_too_old
+    with_writable_state_home do
+      which = { "claude" => "/usr/bin/claude" }
+      runner = { "/usr/bin/claude --version" => [ "2.1.100", "", status_double(true) ] }
+      checker = check(which: which, runner: runner, claude_min: "2.1.118")
+      claude = checker.results.find { |r| r.name == "claude" }
+      assert_equal :wrong_version, claude.status
+      assert_match(/Upgrade claude/, claude.fix_command)
+    end
+  end
+
+  def test_claude_missing_does_not_suggest_login
+    with_writable_state_home do
+      checker = check(which: {})
+      claude = checker.results.find { |r| r.name == "claude" }
+      assert_equal :missing, claude.status
+      assert_match(/npm install -g/, claude.fix_command)
+    end
+  end
+
+  def test_qmd_discovered_via_xdg_data_home
+    with_writable_state_home do |xdg|
+      data_home = ENV.fetch("XDG_DATA_HOME")
+      qmd_bin = File.join(data_home, "hive", "qmd", "bin", "qmd")
+      FileUtils.mkdir_p(File.dirname(qmd_bin))
+      File.write(qmd_bin, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, qmd_bin)
+      runner = { "#{qmd_bin} --version" => [ "1.2.3", "", status_double(true) ] }
+      checker = check(which: {}, runner: runner)
+      qmd = checker.results.find { |r| r.name == "qmd" }
+      assert_equal :present, qmd.status, checker.summary
+    end
+  end
+
+  def test_web_bundle_missing_when_no_app
+    with_writable_state_home do
+      checker = check(web_app_dir: "/nonexistent/path")
+      web = checker.results.find { |r| r.name == "web bundle" }
+      assert_equal :unavailable, web.status
+      assert_match(/HIVEBOX_WEB_APP_DIR/, web.fix_command)
+    end
+  end
+
+  def test_web_bundle_reports_bundle_install_when_gems_missing
+    with_writable_state_home do
+      Dir.mktmpdir("hive-webapp") do |app|
+        FileUtils.mkdir_p(File.join(app, "config"))
+        File.write(File.join(app, "config", "application.rb"), "# marker")
+        runner = { "bundle check" => [ "", "The following gems are missing", status_double(false) ] }
+        checker = Hive::Local::DependencyCheck.new(
+          which: which_stub({}), runner: runner_stub(runner), web_app_dir: app
+        )
+        checker.call
+        web = checker.results.find { |r| r.name == "web bundle" }
+        assert_equal :missing, web.status
+        assert_match(/bundle install/, web.fix_command)
+      end
+    end
+  end
+
+  def test_check_sqlite_is_non_mutating_and_does_not_create_storage_dir
+    with_writable_state_home do
+      checker = check(which: {})
+      sqlite = checker.results.find { |r| r.name == "sqlite/storage" }
+      assert_equal :ok, sqlite.status, checker.summary
+      storage = File.join(Hive::Paths.state_home, "web-storage")
+      refute File.exist?(storage),
+             "--check must probe writability without creating the storage dir"
+      # The state_home chain itself need not pre-exist either; run_foreground
+      # owns creation on the foreground path.
+      refute File.exist?(Hive::Paths.state_home)
+    end
+  end
+
+  def test_summary_lists_each_check
+    with_writable_state_home do
+      checker = check(which: {})
+      summary = checker.summary
+      assert_match(/ruby/, summary)
+      assert_match(/git/, summary)
+      assert_match(/failed/, summary)
+    end
+  end
+
+  def test_default_runner_returns_output_for_a_fast_process
+    checker = Hive::Local::DependencyCheck.new(which: which_stub({}))
+    out, _err, status = checker.send(:default_runner, [ RbConfig.ruby, "-e", "puts 42" ])
+    assert status.success?, "a fast-exiting process must report success"
+    assert_equal "42\n", out
+  end
+
+  def test_default_runner_reaps_a_hung_subprocess_on_timeout
+    checker = Hive::Local::DependencyCheck.new(which: which_stub({}), timeout: 1)
+    start = Process.clock_gettime(Process::CLOCK_MONOTONIC)
+    out, err, status = checker.send(:default_runner, [ RbConfig.ruby, "-e", "sleep 30" ])
+    elapsed = Process.clock_gettime(Process::CLOCK_MONOTONIC) - start
+    refute status&.success?, "a timed-out process must not report success"
+    assert_match(/timed out/, err)
+    # Must return promptly (well under the 30s sleep) once the group is killed.
+    assert elapsed < 10, "default_runner must reap the child on timeout; took #{elapsed}s"
+  end
+end
