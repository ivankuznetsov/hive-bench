diff --git a/examples/launchd/hive-web.plist b/examples/launchd/hive-web.plist
new file mode 100644
index 00000000..528fddb7
--- /dev/null
+++ b/examples/launchd/hive-web.plist
@@ -0,0 +1,94 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+  Sample launchd plist for `hive web` (macOS) — the local (non-Docker)
+  web UI service.
+
+  This file is installer-managed: `hive web install` rewrites the
+  ProgramArguments binary path and PATH to match the resolved binary +
+  Ruby manager detected on the host, then loads the plist. You normally
+  do not edit this by hand — re-run `hive web install` instead.
+
+  Install:
+    mkdir -p ~/Library/LaunchAgents
+    cp examples/launchd/hive-web.plist ~/Library/LaunchAgents/
+    $EDITOR ~/Library/LaunchAgents/hive-web.plist   # confirm absolute paths
+    launchctl load ~/Library/LaunchAgents/hive-web.plist
+
+  Verify it actually started (catches a wrong binary path before the
+  circuit-breaker silently throttles):
+    launchctl list | grep hive-web
+    cat ~/Library/Logs/hive-web.err.log
+
+  Stop / restart:
+    launchctl unload ~/Library/LaunchAgents/hive-web.plist
+    launchctl load   ~/Library/LaunchAgents/hive-web.plist
+    hive web stop / hive web restart     # same thing via the CLI
+
+  Note the absolute-path requirement: launchd doesn't read your shell's
+  rc files, so the `hive` binary must be invoked at its real location.
+  Replace `/Users/YOU/.local/bin/hive` with the path on your machine
+  (run `which hive` to find it). If installed via rbenv / asdf / mise,
+  point at the corresponding shim.
+
+  Local mode binds the loopback address (127.0.0.1:4567 by default) and
+  serves the Rails app. The Rails app (web/) is NOT packaged in the gem —
+  this plist only works where the app exists: a source checkout,
+  HIVEBOX_WEB_APP_DIR, or a layout that bundles it. `hive setup` verifies
+  the web bundle.
+
+  RESPAWN-LOOP CIRCUIT-BREAKER: launchd has no native equivalent of
+  systemd's StartLimitBurst. With KeepAlive { SuccessfulExit: false }
+  and a wrong ProgramArguments path, launchd would respawn forever,
+  filling ~/Library/Logs/hive-web.err.log with `command not found`. The
+  /bin/sh wrapper below converts "binary not executable" into a clean
+  exit 0 — which KeepAlive { SuccessfulExit: false } then respects (no
+  respawn). A real web-server crash still exits non-zero through `exec`
+  and respawns normally per ThrottleInterval.
+-->
+<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
+  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+<plist version="1.0">
+<dict>
+  <key>Label</key>
+  <string>local.hive-web</string>
+
+  <!-- ProgramArguments wraps the real invocation in a tiny /bin/sh
+       precheck. If the binary path passed as $0 is missing or not
+       executable, the wrapper exits 0 (clean) so KeepAlive's
+       SuccessfulExit:false STOPS respawning. If it IS executable, exec
+       hands the process tree to hive and a real crash will re-trigger
+       respawn through KeepAlive normally. -->
+  <key>ProgramArguments</key>
+  <array>
+    <string>/bin/sh</string>
+    <string>-c</string>
+    <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+    <string>/Users/YOU/.local/bin/hive</string>
+    <string>web</string>
+    <string>run</string>
+  </array>
+
+  <key>RunAtLoad</key>
+  <true/>
+
+  <key>KeepAlive</key>
+  <dict>
+    <key>SuccessfulExit</key>
+    <false/>
+  </dict>
+
+  <key>ThrottleInterval</key>
+  <integer>10</integer>
+
+  <key>StandardOutPath</key>
+  <string>/Users/YOU/Library/Logs/hive-web.out.log</string>
+  <key>StandardErrorPath</key>
+  <string>/Users/YOU/Library/Logs/hive-web.err.log</string>
+
+  <key>EnvironmentVariables</key>
+  <dict>
+    <key>PATH</key>
+    <string>/Users/YOU/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
+  </dict>
+</dict>
+</plist>
diff --git a/examples/systemd/hive-web.service b/examples/systemd/hive-web.service
new file mode 100644
index 00000000..adf2e517
--- /dev/null
+++ b/examples/systemd/hive-web.service
@@ -0,0 +1,77 @@
+# Sample systemd-user unit for `hive web` (Linux) — the local (non-Docker)
+# web UI service.
+#
+# This file is installer-managed: `hive web install` rewrites ExecStart=
+# and Environment=PATH= to match the resolved binary + Ruby manager
+# detected on the host, then enables + starts the unit. You normally do
+# not edit this by hand — re-run `hive web install` instead.
+#
+# BEFORE INSTALLING BY HAND: edit ExecStart= to match where YOUR `hive`
+# binary lives. `which hive` shows it. Common paths:
+#
+#   %h/.local/bin/hive                           ← README install (option-A
+#                                                  symlink: ln -s ~/Dev/hive/bin/hive ~/.local/bin/hive)
+#   %h/Dev/hive/bin/hive                         ← README install (option-B,
+#                                                  direct from clone, no symlink)
+#   /usr/local/bin/hive                          ← system gem install
+#   %h/.local/share/mise/shims/hive              ← mise / rbenv / asdf / chruby shim
+#
+# Install:
+#   mkdir -p ~/.config/systemd/user
+#   cp examples/systemd/hive-web.service ~/.config/systemd/user/
+#   $EDITOR ~/.config/systemd/user/hive-web.service   # confirm ExecStart=
+#   systemctl --user daemon-reload
+#   systemctl --user enable --now hive-web
+#
+# Verify it actually started (catches a wrong ExecStart= path before the
+# StartLimitBurst kicks in):
+#   systemctl --user status hive-web
+#   journalctl --user -u hive-web -n 50
+#
+# Stop / restart:
+#   systemctl --user stop hive-web
+#   systemctl --user restart hive-web
+#   hive web stop / hive web restart     # same thing via the CLI
+#
+# To survive logout (run when no user session is active):
+#   sudo loginctl enable-linger $USER
+#
+# Local mode binds the loopback address (127.0.0.1:4567 by default) and
+# serves the Rails app in the foreground; systemd is the supervisor and
+# Restart=on-failure brings the web server back if it crashes.
+# StartLimit* below caps the respawn loop so a wrong ExecStart= path
+# stops cleanly with `failed` instead of relaunching forever.
+#
+# The Rails app (web/) is NOT packaged in the gem — this unit only works
+# where the app exists: a source checkout, HIVEBOX_WEB_APP_DIR, or a
+# layout that bundles it. `hive setup` verifies the web bundle.
+
+[Unit]
+Description=Hive local web UI (loopback Rails server)
+After=network-online.target
+Wants=network-online.target
+# Hard cap on the auto-restart loop. If `hive web run` exits non-zero
+# 3 times within 5 minutes, systemd marks the unit `failed` instead of
+# respawning forever. This is the safety net for a misconfigured ExecStart=
+# (binary not on PATH, typo, missing rbenv shim, missing Rails app) —
+# `systemctl --user status` will show `failed` rather than silently
+# churning.
+StartLimitBurst=3
+StartLimitIntervalSec=300
+
+[Service]
+Type=simple
+# systemd user services do NOT inherit your interactive shell's PATH, so
+# PATH below covers (a) the gem's bin/hive wrapper whose
+# `#!/usr/bin/env ruby` shebang needs to find a Ruby with the gem's
+# dependencies and (b) the Rails bin/rails script the web command execs.
+# `hive web install` detects mise/rbenv/asdf and prepends the matching
+# shim directory automatically; otherwise the minimal PATH below covers
+# system-Ruby installs.
+Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
+ExecStart=%h/.local/bin/hive web run
+Restart=on-failure
+RestartSec=10s
+
+[Install]
+WantedBy=default.target
