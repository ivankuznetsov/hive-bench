new file mode 100644
index 00000000..e6dfe4ba
--- /dev/null
+++ b/lib/hive/commands/web/service_control.rb
@@ -0,0 +1,164 @@
+require "hive/commands/service_installer/base"
+
+module Hive
+  module Commands
+    class Web
+      # Start / stop / restart / active-probe for the managed local web
+      # service. The web server itself is a long-running foreground Rails
+      # process; unlike the daemon there is no in-gem pidfile or
+      # supervisor, so lifecycle commands drive the platform service
+      # manager directly (systemd-user on Linux, launchd on macOS).
+      #
+      # `hive web` (no subcommand) and `hive web run` always boot the
+      # server in the foreground without touching the service manager —
+      # the managed-service path is opt-in, mirroring the OpenClaw local
+      # UX (clear lifecycle commands, health checks, diagnostics).
+      #
+      # The installer supplies platform detection, the service identity,
+      # and the target unit path; this class supplies only the mutating
+      # service-manager calls and the read-only active probe. The runner
+      # is injectable so the lifecycle is unit-testable without a real
+      # systemctl/launchctl.
+      class ServiceControl
+        # Raised when the host has no service manager to drive (e.g.
+        # Linux without systemd-user). The web command surfaces this as
+        # guidance ("run `hive web` in the foreground or install first"),
+        # not a crash.
+        class Unavailable < StandardError
+          attr_reader :platform
+
+          def initialize(platform:, message:)
+            super(message)
+            @platform = platform
+          end
+        end
+
+        attr_reader :messages
+
+        def initialize(installer:, runner: nil, systemctl_available: nil)
+          @installer = installer
+          @runner = runner || ->(argv) { system(*argv, out: File::NULL, err: File::NULL) }
+          @systemctl_available = systemctl_available
+          @messages = []
+        end
+
+        def start
+          case platform
+          when "linux"
+            ensure_systemd!
+            call_runner(%w[systemctl --user start] + [ service_name ])
+          when "macos"
+            # `launchctl load` starts the job via RunAtLoad. If the plist
+            # is already loaded, load returns non-zero; fall back to
+            # `launchctl start <label>` so re-running `hive web start`
+            # after a manual stop is idempotent.
+            ok = call_runner([ "launchctl", "load", target_path ])
+            ok || call_runner([ "launchctl", "start", launchd_label ])
+          else
+            unavailable!
+          end
+        end
+
+        def stop
+          case platform
+          when "linux"
+            ensure_systemd!
+            # `stop` is idempotent: a non-running unit exits 0. Don't
+            # treat a missing unit as success though — that's "not
+            # installed", surfaced by the caller via service_state.
+            call_runner(%w[systemctl --user stop] + [ service_name ])
+          when "macos"
+            call_runner([ "launchctl", "unload", target_path ])
+          else
+            unavailable!
+          end
+        end
+
+        def restart
+          case platform
+          when "linux"
+            ensure_systemd!
+            call_runner(%w[systemctl --user restart] + [ service_name ])
+          when "macos"
+            unload_ok = call_runner([ "launchctl", "unload", target_path ])
+            load_ok = call_runner([ "launchctl", "load", target_path ])
+            # A half-restart (failed unload, succeeded load) must not be
+            # reported ok — surface the unload failure so the operator sees
+            # the real cause instead of a masked success.
+            unload_ok && load_ok
+          else
+            unavailable!
+          end
+        end
+
+        # Read-only "is the service currently running?" probe. No state
+        # change. Used by `hive web status` alongside the install-state
+        # snapshot and the HTTP health probe. Routed through call_runner so
+        # the is-active / launchctl-list probe leaves the same audit trail
+        # in `messages` that start/stop/restart do.
+        def active?
+          case platform
+          when "linux"
+            return false unless systemd?
+
+            call_runner(%w[systemctl --user is-active] + [ service_name ])
+          when "macos"
+            call_runner([ "launchctl", "list", launchd_label ])
+          else
+            false
+          end
+        end
+
+        private
+
+        def platform
+          @installer.envelope_platform
+        end
+
+        def service_name
+          @installer.service_name
+        end
+
+        def launchd_label
+          @installer.launchd_label
+        end
+
+        def target_path
+          @installer.target_path
+        end
+
+        def ensure_systemd!
+          return if systemd?
+
+          raise Unavailable.new(
+            platform: platform,
+            message: "systemd-user not detected; start the web server in the " \
+                     "foreground with `hive web` or enable systemd in WSL."
+          )
+        end
+
+        def systemd?
+          return @systemctl_available unless @systemctl_available.nil?
+
+          system("systemctl", "--user", "--version", out: File::NULL, err: File::NULL)
+        rescue Errno::ENOENT
+          false
+        end
+
+        def unavailable!
+          raise Unavailable.new(
+            platform: platform,
+            message: "managed web service is not supported on this platform; " \
+                     "run `hive web` in the foreground instead."
+          )
+        end
+
+        def call_runner(argv)
+          result = @runner.call(argv)
+          @messages << "#{argv.join(' ')} -> #{result ? 'ok' : 'failed'}"
+          result
+        end
+      end
+    end
+  end
+end
