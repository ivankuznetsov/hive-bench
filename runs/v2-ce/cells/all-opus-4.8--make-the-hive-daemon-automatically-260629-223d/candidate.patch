diff --git a/test/integration/daemon_auto_retry_test.rb b/test/integration/daemon_auto_retry_test.rb
new file mode 100644
index 00000000..5bc85a01
--- /dev/null
+++ b/test/integration/daemon_auto_retry_test.rb
@@ -0,0 +1,611 @@
+require "test_helper"
+require "hive/daemon/stale_agent_healer"
+require "hive/daemon/status_consumer"
+require "hive/daemon/logger"
+require "hive/daemon/health_probes"
+require "hive/markers"
+
+# Acceptance coverage for the daemon's health-recoverable auto-retry path
+# (StaleAgentHealer dependency-outage recovery). Drives the healer with an
+# injected fake HealthProbes, an injected config resolver, a controllable
+# clock (`now:`), and real temp task folders holding realistic markers.
+class DaemonAutoRetryTest < Minitest::Test
+  include HiveTestHelper
+
+  PR = Hive::Daemon::HealthProbes::ProbeResult
+  CK = Hive::Daemon::HealthProbes::Check
+
+  class FakeController
+    def running_task?(**) = false
+    def observe_state_file_mtime(**) = nil
+  end
+
+  class FakeLogger
+    attr_reader :events
+    def initialize = @events = []
+
+    def event(name, **attrs)
+      unless Hive::Daemon::Logger::EVENTS.include?(name)
+        raise ArgumentError, "FakeLogger rejected event #{name.inspect}; add it to Logger::EVENTS"
+      end
+      @events << [ name, attrs ]
+    end
+  end
+
+  # Configurable stand-in for HealthProbes.
+  class FakeProbes
+    attr_accessor :healthy, :fingerprint, :failing
+    attr_reader :probe_calls, :fingerprint_calls
+
+    def initialize(healthy: true, fingerprint: "fp-1", failing: [ "codex_exec_smoke" ])
+      @healthy = healthy
+      @fingerprint = fingerprint
+      @failing = failing
+      @probe_calls = 0
+      @fingerprint_calls = 0
+    end
+
+    def health_fingerprint(_reason, config:, project_root:, env: {})
+      @fingerprint_calls += 1
+      @fingerprint
+    end
+
+    def probe(_reason, config:, project_root:, env: {}, cache: nil)
+      @probe_calls += 1
+      if @healthy
+        PR.new(checks: [ CK.new(name: "doctor_green", ok: true) ])
+      else
+        PR.new(checks: @failing.map { |n| CK.new(name: n, ok: false) })
+      end
+    end
+  end
+
+  # A stand-in for the ProbeCommand result the git safety probe consumes:
+  # `ok`/`stdout` drive the clean/dirty decision, `failure_reason`/`stderr`
+  # feed the fail-to-unsafe log detail.
+  CmdResult = Struct.new(:ok, :stdout, :stderr, :failure_reason, keyword_init: true)
+
+  # Counting stand-in for ProbeCommand: records how many `git status` shell-outs
+  # the safety guard actually made and returns a fixed result.
+  class CountingProbeCommand
+    attr_reader :git_status_calls
+
+    def initialize(result:)
+      @result = result
+      @git_status_calls = 0
+    end
+
+    def run(argv, timeout_sec: nil, **)
+      @git_status_calls += 1 if Array(argv).include?("status")
+      @result
+    end
+  end
+
+  # Records write_request! calls instead of touching the real queue dir.
+  class FakeRequestQueue
+    attr_reader :requests
+    def initialize = @requests = []
+
+    def write_request!(**kwargs)
+      @requests << kwargs
+      "fake-req-#{@requests.size}"
+    end
+  end
+
+  def events_named(logger, name)
+    logger.events.select { |n, _| n == name }
+  end
+
+  def build_healer(probes:, auto_retry_enabled: true, project_root:, config: { "claude" => { "mode" => "headless" } },
+                   request_queue: nil, probe_command: nil)
+    @logger = FakeLogger.new
+    @request_queue = request_queue || FakeRequestQueue.new
+    kwargs = {
+      controller: FakeController.new,
+      logger: @logger,
+      auto_retry_enabled: auto_retry_enabled,
+      health_probes: probes,
+      request_queue: @request_queue,
+      config_resolver: ->(_project) { [ config, project_root ] }
+    }
+    kwargs[:probe_command] = probe_command if probe_command
+    Hive::Daemon::StaleAgentHealer.new(**kwargs)
+  end
+
+  # Build a parked ERROR row on disk with the given reason/attrs, plus a
+  # worktree.yml pointing at `worktree` (a real, clean-by-default git repo).
+  def seed_error_row(dir, stage:, reason:, attrs: {}, worktree: nil, slug: "t-260711-aaaa", body: "# task\n")
+    folder = File.join(dir, ".hive-state", "stages", stage, slug)
+    FileUtils.mkdir_p(folder)
+    state_file = File.join(folder, "task.md")
+    File.write(state_file, body)
+    Hive::Markers.set(state_file, :error, { "reason" => reason }.merge(attrs))
+    File.write(File.join(folder, "worktree.yml"), { "path" => worktree }.to_yaml) if worktree
+    mtime = Time.now - 60
+    File.utime(mtime, mtime, state_file)
+
+    on_disk = Hive::Markers.current(state_file)
+    Hive::Daemon::StatusConsumer::Row.new(
+      project: File.basename(dir),
+      slug: slug,
+      stage: stage,
+      marker: "error",
+      marker_attrs: on_disk.attrs,
+      folder: folder,
+      state_file: state_file,
+      state_file_mtime: File.mtime(state_file),
+      claude_pid_alive: nil,
+      live_task_lock: false
+    )
+  end
+
+  def marker_name(state_file)
+    Hive::Markers.current(state_file).name
+  end
+
+  # ── 1. task-58 codex-401 implementer_failed + green ⇒ auto-clears ─────
+
+  def test_codex_401_implementer_failed_clears_when_healthy
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "status" => "error", "message" => "codex exec failed: HTTP 401 Unauthorized" },
+                             worktree: wt)
+        healer = build_healer(probes: FakeProbes.new(healthy: true), project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :none, marker_name(row.state_file), "healthy codex-401 marker must be cleared"
+        cleared = events_named(@logger, :auto_retry_cleared)
+        assert_equal 1, cleared.size
+        assert_equal 1, cleared.first[1][:attempts]
+        # task events.jsonl also carries the audit record.
+        events = File.read(File.join(row.folder, "events.jsonl"))
+        assert_match(/auto_retry_cleared/, events)
+      end
+    end
+  end
+
+  # ── 2. claude_launch_failed clears only when the probe is green ───────
+
+  def test_claude_launch_failed_parked_when_probe_unhealthy
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        row = seed_error_row(dir, stage: "4-execute", reason: "claude_launch_failed",
+                             attrs: { "exception_class" => "Hive::AgentError", "message" => "prompt not ready" },
+                             worktree: wt)
+        healer = build_healer(probes: FakeProbes.new(healthy: false, failing: [ "claude_version" ]), project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :error, marker_name(row.state_file), "unhealthy launcher probe must leave the marker parked"
+        assert_empty events_named(@logger, :auto_retry_cleared)
+        skipped = events_named(@logger, :auto_retry_skipped)
+        assert_equal 1, skipped.size
+        assert_match(/claude_version/, skipped.first[1][:rationale])
+      end
+    end
+  end
+
+  def test_claude_launch_failed_clears_when_healthy
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        row = seed_error_row(dir, stage: "4-execute", reason: "claude_launch_failed",
+                             attrs: { "message" => "prompt not ready" }, worktree: wt)
+        healer = build_healer(probes: FakeProbes.new(healthy: true), project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :none, marker_name(row.state_file)
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+      end
+    end
+  end
+
+  # ── 3. Unknown implementer_failed (no 401) ⇒ never cleared ────────────
+
+  def test_unknown_implementer_failed_never_cleared
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "status" => "error", "message" => "3 tests failed, exit code 1" },
+                             worktree: wt)
+        probes = FakeProbes.new(healthy: true)
+        healer = build_healer(probes: probes, project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :error, marker_name(row.state_file), "a non-401 implementer failure must stay parked"
+        assert_equal 0, probes.probe_calls, "an ineligible reason must not even probe"
+        assert_empty events_named(@logger, :auto_retry_cleared)
+      end
+    end
+  end
+
+  # ── 4. 2-retry cap + 30-min backoff; exhausted ⇒ parked ───────────────
+
+  def test_retry_cap_and_backoff_then_exhaustion
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        probes = FakeProbes.new(healthy: true, fingerprint: "fp-stable")
+        healer = build_healer(probes: probes, project_root: dir)
+        t0 = Time.now
+
+        # tick 1: healthy ⇒ clear, attempt 1.
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        healer.heal([ row ], now: t0)
+        assert_equal :none, marker_name(row.state_file)
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+
+        # Stage re-failed: re-stamp the same error.
+        row2 = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                              attrs: { "message" => "401 unauthorized" }, worktree: wt)
+
+        # tick 2 at +60s: unchanged fingerprint within window ⇒ no re-probe,
+        # no second clear (retry blocked).
+        healer.heal([ row2 ], now: t0 + 60)
+        assert_equal :error, marker_name(row2.state_file), "second retry blocked within 30-min backoff"
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+
+        # tick 3 at +1801s: window elapsed ⇒ re-probe ⇒ clear, attempt 2.
+        healer.heal([ row2 ], now: t0 + 1801)
+        assert_equal :none, marker_name(row2.state_file)
+        assert_equal 2, events_named(@logger, :auto_retry_cleared).size
+
+        # tick 4: stage re-failed a third time ⇒ cap reached ⇒ exhausted, parked.
+        row3 = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                              attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        healer.heal([ row3 ], now: t0 + 3700)
