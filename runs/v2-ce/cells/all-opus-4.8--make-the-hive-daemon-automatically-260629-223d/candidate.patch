+++ b/test/unit/daemon/health_probes_test.rb
@@ -0,0 +1,237 @@
+require "test_helper"
+require "hive/daemon/health_probes"
+
+class DaemonHealthProbesTest < Minitest::Test
+  include HiveTestHelper
+
+  HP = Hive::Daemon::HealthProbes
+
+  # Fake ProbeCommand: dispatches on the joined argv via a matcher table.
+  class FakeProbe
+    Result = Struct.new(:ok, :stdout, :stderr, :timed_out, :duration_ms, :error, :status, keyword_init: true) do
+      def exit_status
+        status
+      end
+
+      # Mirror the real ProbeCommand::Result accessor so probe_detail can rely
+      # on it uniformly across the fake and the production struct.
+      def failure_reason
+        return nil if ok
+        return "timed out after #{duration_ms}ms" if timed_out
+        return error if error
+
+        "exit=#{exit_status.inspect}"
+      end
+    end
+
+    attr_reader :calls
+
+    def initialize(&handler)
+      @handler = handler
+      @calls = []
+    end
+
+    def run(argv, env: {}, timeout_sec: nil, max_bytes: nil)
+      @calls << argv
+      res = @handler.call(argv)
+      res || ok_result
+    end
+
+    def ok_result
+      Result.new(ok: true, stdout: "", stderr: "", timed_out: false, duration_ms: 1, error: nil, status: 0)
+    end
+  end
+
+  def ok_result(stdout: "ok")
+    FakeProbe::Result.new(ok: true, stdout: stdout, stderr: "", timed_out: false, duration_ms: 1, error: nil, status: 0)
+  end
+
+  def fail_result(stderr: "boom", status: 1)
+    FakeProbe::Result.new(ok: false, stdout: "", stderr: stderr, timed_out: false, duration_ms: 1, error: nil, status: status)
+  end
+
+  def timeout_result
+    FakeProbe::Result.new(ok: false, stdout: "", stderr: "", timed_out: true, duration_ms: 30_000, error: nil, status: nil)
+  end
+
+  def build(probe:, logged_in:)
+    hp = HP.new(probe_command: probe, logged_in: logged_in)
+    # Force the universal doctor gate green so tests exercise the
+    # reason-specific probes in isolation; a dedicated test flips it.
+    hp.define_singleton_method(:doctor_green?) { |*| true }
+    hp
+  end
+
+  # ── codex probe ──────────────────────────────────────────────────────
+
+  def test_codex_all_green_is_healthy
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(a) { a == :codex })
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    assert result.healthy, result.failing_names.inspect
+    assert_includes result.checks.map(&:name), "codex_exec_smoke"
+  end
+
+  def test_codex_logged_out_is_unhealthy_and_skips_smoke
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(_a) { false })
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    refute result.healthy
+    assert_empty probe.calls, "must not shell out to codex when logged out"
+    assert_includes result.failing_names, "codex_logged_in"
+  end
+
+  def test_codex_login_ok_but_smoke_fails_is_unhealthy
+    probe = FakeProbe.new do |argv|
+      argv.include?("exec") ? fail_result : ok_result
+    end
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    refute result.healthy
+    assert_includes result.failing_names, "codex_exec_smoke"
+  end
+
+  def test_codex_smoke_timeout_is_unhealthy
+    probe = FakeProbe.new do |argv|
+      argv.include?("exec") ? timeout_result : ok_result
+    end
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    refute result.healthy
+    smoke = result.checks.find { |c| c.name == "codex_exec_smoke" }
+    assert smoke.timed_out
+  end
+
+  def test_doctor_gate_short_circuits_before_shelling_out
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = HP.new(probe_command: probe, logged_in: ->(_a) { true })
+    hp.define_singleton_method(:doctor_green?) { |*| false }
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    refute result.healthy
+    assert_empty probe.calls, "unhealthy doctor gate must short-circuit before any CLI shell-out"
+    assert_equal [ "doctor_green" ], result.checks.map(&:name)
+  end
+
+  # ── per-tick cache ───────────────────────────────────────────────────
+
+  def test_cache_runs_external_cli_once_per_reason_project
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    cache = HP::ProbeCache.new
+    3.times { hp.probe("implementer_failed", config: {}, project_root: "/p", cache: cache) }
+    # login status + smoke = 2 calls total across the 3 probes.
+    assert_equal 2, probe.calls.size, "cache must collapse repeat probes into one CLI round"
+  end
+
+  # ── claude launcher probe ────────────────────────────────────────────
+
+  def test_claude_launcher_probe_healthy_in_headless_mode
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    # Headless mode → skip tmux; stub claude version OK.
+    hp.define_singleton_method(:claude_version_ok) { |*| [ true, "claude 9.9.9" ] }
+    result = hp.probe("claude_launch_failed", config: { "claude" => { "mode" => "headless" } }, project_root: "/p")
+    names = result.checks.map(&:name)
+    assert_includes names, "claude_wrapper_present"
+    assert_includes names, "ready_detector_selfcheck"
+    refute_includes names, "tmux_available", "headless mode must not probe tmux"
+    assert result.healthy, result.failing_names.inspect
+  end
+
+  def test_claude_launcher_probe_gates_on_tmux_in_tmux_mode
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    hp.define_singleton_method(:claude_version_ok) { |*| [ true, "claude 9.9.9" ] }
+    cfg = { "claude" => { "mode" => "tmux" } }
+
+    # tmux present ⇒ the gate is added and passes.
+    Hive::ClaudeLauncher.stub(:tmux_status, [ :present, "tmux 3.3a" ]) do
+      result = hp.probe("claude_launch_failed", config: cfg, project_root: "/p")
+      assert_includes result.checks.map(&:name), "tmux_available", "tmux mode must add the tmux gate"
+      assert result.healthy, result.failing_names.inspect
+    end
+
+    # tmux missing ⇒ the gate fails and sinks the whole launcher probe.
+    Hive::ClaudeLauncher.stub(:tmux_status, [ :missing, "tmux not found on PATH" ]) do
+      result = hp.probe("claude_launch_failed", config: cfg, project_root: "/p")
+      refute result.healthy
+      assert_includes result.failing_names, "tmux_available"
+    end
+  end
+
+  def test_claude_version_mismatch_is_unhealthy
+    probe = FakeProbe.new { |argv| ok_result }
+    hp = build(probe: probe, logged_in: ->(_a) { true })
+    hp.define_singleton_method(:claude_version_ok) { |*| [ false, "claude 1.0.0 below minimum 2.1.118" ] }
+    result = hp.probe("claude_launch_failed", config: { "claude" => { "mode" => "headless" } }, project_root: "/p")
+    refute result.healthy
+    assert_includes result.failing_names, "claude_version"
+  end
+
+  def test_ready_detector_selfcheck_matches_canonical_prompt
+    # The real detector must accept the positive sample and reject the
+    # negative one — this is the guard against a CLI revision drift.
+    assert Hive::ClaudeLauncher.claude_ready_prompt?(HP::READY_SELFCHECK_PANE)
+    refute Hive::ClaudeLauncher.claude_ready_prompt?(HP::NOT_READY_SELFCHECK_PANE)
+  end
+
+  # ── fingerprint ──────────────────────────────────────────────────────
+
+  def test_fingerprint_is_stable_for_unchanged_inputs
+    hp = HP.new(logged_in: ->(_a) { true })
+    a = hp.health_fingerprint("implementer_failed", config: { "x" => 1 }, project_root: "/p")
+    b = hp.health_fingerprint("implementer_failed", config: { "x" => 1 }, project_root: "/p")
+    assert_equal a, b
+  end
+
+  def test_fingerprint_changes_with_codex_login_state
+    logged = { codex: true }
+    hp = HP.new(logged_in: ->(a) { logged[a] == true })
+    before = hp.health_fingerprint("implementer_failed", config: {}, project_root: "/p")
+    logged[:codex] = false
+    after = hp.health_fingerprint("implementer_failed", config: {}, project_root: "/p")
+    refute_equal before, after
+  end
+
+  def test_fingerprint_changes_with_config
+    hp = HP.new(logged_in: ->(_a) { true })
+    a = hp.health_fingerprint("implementer_failed", config: { "model" => "old" }, project_root: "/p")
+    b = hp.health_fingerprint("implementer_failed", config: { "model" => "new" }, project_root: "/p")
+    refute_equal a, b
+  end
+
+  def test_fingerprint_is_order_independent_for_config
+    hp = HP.new(logged_in: ->(_a) { true })
+    a = hp.health_fingerprint("r", config: { "a" => 1, "b" => 2 }, project_root: "/p")
+    b = hp.health_fingerprint("r", config: { "b" => 2, "a" => 1 }, project_root: "/p")
+    assert_equal a, b
+  end
+
+  def test_fingerprint_changes_when_a_tracked_file_mtime_changes
+    # The acceptance FakeProbes returns a fixed fingerprint, so the real
+    # mtime sensitivity (a reinstall/upgrade bumps the wrapper/bin mtime and
+    # must re-open a retry) is exercised only here.
+    with_tmp_dir do |dir|
+      wrapper = File.join(dir, "interactive_claude_wrapper.sh")
+      File.write(wrapper, "#!/bin/sh\n")
+      hp = HP.new(logged_in: ->(_a) { true })
+      hp.define_singleton_method(:claude_wrapper_path) { wrapper }
+
+      before = hp.health_fingerprint("claude_launch_failed", config: {}, project_root: "/p")
+      future = Time.now + 120
+      File.utime(future, future, wrapper)
+      after = hp.health_fingerprint("claude_launch_failed", config: {}, project_root: "/p")
+
+      refute_equal before, after, "a changed tracked-file mtime must change the fingerprint"
+    end
+  end
+
+  def test_probe_never_raises_returns_unhealthy_on_internal_error
+    exploding = Object.new
+    def exploding.run(*) = raise("kaboom")
+    hp = HP.new(probe_command: exploding, logged_in: ->(_a) { true })
+    hp.define_singleton_method(:doctor_green?) { |*| true }
+    result = hp.probe("implementer_failed", config: {}, project_root: "/p")
+    refute result.healthy
+  end
+end
