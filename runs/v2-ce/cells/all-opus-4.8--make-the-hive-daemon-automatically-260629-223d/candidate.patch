+
+  # ── Bare `401` trust boundary: marker message ⇒ eligible; log tail ⇒ NOT ──
+  def test_bare_401_in_marker_message_is_eligible
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        # Bare `401` in the marker's own message (no anchored phrasing) is
+        # trusted ⇒ eligible ⇒ clears when healthy.
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "status" => "error", "message" => "codex exec failed with 401" },
+                             worktree: wt)
+        healer = build_healer(probes: FakeProbes.new(healthy: true), project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :none, marker_name(row.state_file), "bare 401 in marker message ⇒ eligible ⇒ clears"
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+      end
+    end
+  end
+
+  def test_bare_401_only_in_log_tail_is_not_eligible
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        # Marker message carries NO auth signature; a bare `401` appears only in
+        # the free-form events.jsonl tail (a count, not an auth error) ⇒ NOT
+        # trusted ⇒ ineligible ⇒ never probed or cleared.
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "status" => "error", "message" => "codex exec failed: connection reset" },
+                             worktree: wt)
+        File.write(File.join(row.folder, "events.jsonl"),
+                   %({"event":"progress","lines_written":401}\n))
+        probes = FakeProbes.new(healthy: true)
+        healer = build_healer(probes: probes, project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :error, marker_name(row.state_file), "bare 401 in log tail only ⇒ ineligible"
+        assert_equal 0, probes.probe_calls, "an ineligible reason must not probe"
+        assert_empty events_named(@logger, :auto_retry_cleared)
+      end
+    end
+  end
+
+  # ── 30-min backoff gate exercised via the fingerprint gate held OPEN ──────
+  # A changed fingerprint each tick drives past the re-probe gate so the
+  # SECOND retry is blocked specifically by the 30-min backoff gate (not the
+  # fingerprint gate), covering that skip rationale directly.
+  def test_backoff_gate_blocks_second_retry_when_fingerprint_changes
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        probes = FakeProbes.new(healthy: true, fingerprint: "fp-1")
+        healer = build_healer(probes: probes, project_root: dir)
+        t0 = Time.now
+
+        # tick 1: healthy ⇒ clear, attempt 1, heal_at recorded.
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        healer.heal([ row ], now: t0)
+        assert_equal :none, marker_name(row.state_file)
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+
+        # Stage re-failed: re-stamp the same error.
+        row2 = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                              attrs: { "message" => "401 unauthorized" }, worktree: wt)
+
+        # tick 2 at +60s with a CHANGED fingerprint: the re-probe gate opens
+        # (fingerprint differs), the probe runs healthy, but attempt 2 is within
+        # the 30-min backoff ⇒ blocked by the backoff gate specifically.
+        probes.fingerprint = "fp-2"
+        healer.heal([ row2 ], now: t0 + 60)
+
+        assert_equal :error, marker_name(row2.state_file), "second retry blocked by 30-min backoff"
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size, "no second clear within backoff"
+        skipped = events_named(@logger, :auto_retry_skipped)
+        assert_equal 1, skipped.size
+        assert_match(/within 30-min retry backoff/, skipped.first[1][:rationale])
+      end
+    end
+  end
+end
