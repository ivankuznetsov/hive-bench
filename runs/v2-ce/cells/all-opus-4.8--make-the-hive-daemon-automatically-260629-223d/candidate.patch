+          row.state_file,
+          expected_name: :error,
+          match_attrs: auto_recoverable_error_match_attrs(row, reason: reason)
+        )
+
+        observe_pre_clear_mtime(row)
+        attempts = (@auto_retry_attempts[key] += 1)
+        @auto_retry_last_heal_at[key] = now
+        @auto_retry_last_skip_signature.delete(key)
+        emit_auto_retry_cleared(row, reason: reason, key: key, attempts: attempts,
+                                fingerprint: fingerprint, checks: result.checks)
+
+        # 3-plan clears strand a markerless empty plan.md unless explicitly
+        # re-queued — reuse the exact agent-loss rerun path.
+        requeue_plan_rerun(row) if Hive::Workflows.coding_row?(row) && row.stage.to_s == "3-plan" # coding-scoped: coding plan pause needs bespoke rerun after marker clear
+      end
+
+      def auto_retry_key(row, reason)
+        [ row.project.to_s, row.slug.to_s, row.stage.to_s, reason.to_s ]
+      end
+
+      # Empty overlay ⇒ the spawned probe child inherits the daemon's env
+      # unchanged (Process.spawn merges an empty hash onto the parent env), so
+      # codex/claude probes see the same process-level vars (HIVE_CODEX_BIN,
+      # PATH) the daemon runs with. NOTE: if the real codex/claude launch
+      # injects per-project env, the probe env will diverge from that launch
+      # env — acceptable for v1 as a documented seam.
+      def auto_retry_env
+        {}
+      end
+
+      def auto_retry_failing_summary(result)
+        names = result.failing_names
+        names.empty? ? "health probe failed" : names.join(", ")
+      end
+
+      # ── Safety guard (Unit 6): never discard user work ────────────────
+      def auto_retry_safe?(row, reason:)
+        # Defense in depth: re-read the marker. An `error` must still be
+        # current — a terminal success marker must never be clobbered.
+        current = Hive::Markers.current(row.state_file)
+        return false unless current.name.to_s == "error"
+
+        if auto_retry_worktree_stage?(row)
+          auto_retry_worktree_clean?(row)
+        else
+          # Pre-worktree stages (brainstorm/plan): a clear+rerun restarts the
+          # stage from scratch, overwriting the artifact. Refuse when the
+          # artifact already holds answered/authored content.
+          !auto_retry_artifact_has_content?(row)
+        end
+      rescue StandardError => e
+        # Fail-safe direction unchanged: any unexpected error ⇒ treat as unsafe
+        # (never clear). But a persistent internal bug here (e.g. Markers.current
+        # always raising) would otherwise be indistinguishable from a genuinely
+        # dirty worktree, so surface it — throttled per (project, slug, stage)
+        # via the same signature map as the dependency-path rescue.
+        emit_auto_retry_error_throttled(row, error: e)
+        false
+      end
+
+      # Stages that own a feature worktree (index >= 4: execute onward).
+      def auto_retry_worktree_stage?(row)
+        Integer(row.stage.to_s.split("-", 2).first, exception: false).to_i >= 4
+      end
+
+      def auto_retry_worktree_clean?(row)
+        path = auto_retry_worktree_path(row)
+        return false unless path && Dir.exist?(path)
+
+        entries = auto_retry_git_porcelain(path)
+        return false if entries.nil? # git error / ambiguous ⇒ unsafe
+
+        entries.all? { |entry| auto_retry_safe_residue?(entry) }
+      end
+
+      def auto_retry_worktree_path(row)
+        yml = File.join(row.folder.to_s, "worktree.yml")
+        return nil unless File.exist?(yml)
+
+        data = YAML.safe_load(File.read(yml)) || {}
+        data.is_a?(Hash) ? data["path"] : nil
+      rescue StandardError
+        nil
+      end
+
+      # `git status --porcelain` paths, or nil on any error/timeout (unsafe).
+      # When git ITSELF fails (timeout / missing git / repo error) the caller
+      # still treats nil as "unsafe" — the fail-safe direction — but that reads
+      # to an operator as "user work present", so log the real git failure
+      # (throttled) to keep a persistently broken git diagnosable.
+      def auto_retry_git_porcelain(path)
+        result = @probe_command.run([ "git", "-C", path, "status", "--porcelain" ], timeout_sec: 15)
+        unless result.ok
+          log_git_probe_failure(path, detail: git_probe_failure_detail(result))
+          return nil
+        end
+
+        result.stdout.each_line.filter_map do |line|
+          stripped = line.chomp
+          next nil if stripped.strip.empty?
+
+          # Porcelain v1: XY<space>path. Drop the 3-char status prefix; strip a
+          # rename's "old -> new" to the new path.
+          entry = stripped[3..].to_s
+          entry.split(" -> ", 2).last
+        end
+      rescue StandardError => e
+        log_git_probe_failure(path, detail: "#{e.class}: #{e.message}")
+        nil
+      end
+
+      def git_probe_failure_detail(result)
+        reason = result.respond_to?(:failure_reason) ? result.failure_reason : nil
+        stderr = result.respond_to?(:stderr) ? result.stderr.to_s.strip : ""
+        stderr = stderr.byteslice(-256, 256).to_s unless stderr.empty?
+        [ reason, (stderr.empty? ? nil : "stderr=#{stderr}") ].compact.join("; ")
+      end
+
+      # Throttled per worktree path: a persistently broken git would otherwise
+      # log on every probe attempt. Re-log only when the failure detail changes.
+      def log_git_probe_failure(path, detail:)
+        signature = [ path.to_s, detail ].hash
+        return if @auto_retry_git_error_signature_by_worktree[path.to_s] == signature
+
+        @auto_retry_git_error_signature_by_worktree[path.to_s] = signature
+        @logger.event(:marker_heal_failed,
+                      reason: "auto_retry_git_probe",
+                      worktree_path: path.to_s,
+                      error: "git status probe failed (worktree treated as unsafe): #{detail}")
+      end
+
+      def auto_retry_safe_residue?(entry)
+        AUTO_RETRY_SAFE_RESIDUE.any? { |pattern| entry.match?(pattern) }
+      end
+
+      def auto_retry_artifact_has_content?(row)
+        body = File.read(row.state_file.to_s, encoding: "UTF-8")
+        # Strip hive markers and comments, then look for real authored content.
+        stripped = body.gsub(Hive::Markers::MARKER_RE, "")
+        stripped.each_line.any? do |line|
+          text = line.strip
+          !text.empty? && !text.start_with?("#", "<!--")
+        end
+      rescue Errno::ENOENT
+        # Missing artifact ⇒ nothing to overwrite ⇒ safe (no content).
+        false
+      rescue SystemCallError => e
+        # Any OTHER read error (EACCES, EIO, …) is ambiguous: we cannot confirm
+        # the artifact is empty, so fail to the SAFE direction — treat it as
+        # holding authored content (⇒ unsafe to clobber) and log, mirroring
+        # auto_retry_git_porcelain's fail-to-unsafe stance rather than silently
+        # green-lighting an overwrite.
+        @logger.event(:marker_heal_failed,
+                      project: row.project,
+                      slug: row.slug,
+                      stage: row.stage,
+                      reason: "auto_retry_artifact_read",
+                      error: "artifact read failed (treated as authored content ⇒ unsafe): #{e.class}: #{e.message}")
+        true
+      end
+
+      def default_config_resolver(project_name)
+        entry = Hive::Config.find_project(project_name)
+        return nil unless entry && entry["path"]
+
+        root = entry["path"]
+        [ Hive::Config.load(root), root ]
+      rescue Hive::ConfigError
+        nil
+      end
+
+      # Bounded tail of the task's events.jsonl for signature classification
+      # (the marker `message` attr is usually enough; this is belt-and-braces).
+      def auto_retry_log_tail(row)
+        path = File.join(row.folder.to_s, "events.jsonl")
+        return nil unless File.exist?(path)
+
+        File.open(path, "rb") do |file|
+          size = file.size
+          file.seek([ size - AUTO_RETRY_LOG_TAIL_BYTES, 0 ].max)
+          file.read
+        end
+      rescue SystemCallError
+        nil
+      end
+
+      # ── Audit (Unit 7) ────────────────────────────────────────────────
+      def emit_auto_retry_cleared(row, reason:, key:, attempts:, fingerprint:, checks:)
+        @logger.event(:auto_retry_cleared,
+                      project: row.project,
+                      slug: row.slug,
+                      stage: row.stage,
+                      reason: reason,
+                      marker_id: marker_id_for(row),
+                      fingerprint: fingerprint,
+                      attempts: attempts,
+                      max_attempts: AUTO_RETRY_LIMIT,
+                      checks: audit_checks(checks),
+                      state_file: row.state_file)
+        emit_task_event(row, :auto_retry_cleared,
+                        "cleared: #{reason} dependency healthy, attempt #{attempts}/#{AUTO_RETRY_LIMIT}")
+      end
+
+      # Negative decisions are throttled per recovery key: re-emit only when the
+      # fingerprint or the failing-check signature changes, so a persistently
+      # unhealthy parked marker does not flood the log every tick.
+      def emit_auto_retry_skip(row, reason:, key:, rationale:, fingerprint:, checks:)
+        signature = [ fingerprint, Array(checks).reject(&:ok).map(&:name), rationale ].hash
+        return if @auto_retry_last_skip_signature[key] == signature
+
+        @auto_retry_last_skip_signature[key] = signature
+        @logger.event(:auto_retry_skipped,
+                      project: row.project,
+                      slug: row.slug,
+                      stage: row.stage,
+                      reason: reason,
+                      marker_id: marker_id_for(row),
+                      fingerprint: fingerprint,
+                      attempts: @auto_retry_attempts[key],
+                      max_attempts: AUTO_RETRY_LIMIT,
+                      rationale: rationale,
+                      checks: audit_checks(checks),
+                      state_file: row.state_file)
+        emit_task_event(row, :auto_retry_skipped, rationale)
+      end
+
+      def emit_auto_retry_exhausted_once(row, reason:, key:)
+        return if @auto_retry_exhausted[key]
+
+        @auto_retry_exhausted[key] = true
+        @logger.event(:auto_retry_exhausted,
+                      project: row.project,
+                      slug: row.slug,
+                      stage: row.stage,
+                      reason: reason,
+                      marker_id: marker_id_for(row),
+                      attempts: @auto_retry_attempts[key],
+                      max_attempts: AUTO_RETRY_LIMIT,
+                      budget_scope: "per_process",
+                      suggested_next_action: "manual_fix",
+                      remediation: "auto-retry exhausted after #{AUTO_RETRY_LIMIT} attempts; " \
+                                   "fix the dependency and run `hive markers clear` on #{row.slug}",
+                      state_file: row.state_file)
+        emit_task_event(row, :auto_retry_skipped,
+                        "auto-retry exhausted (#{AUTO_RETRY_LIMIT}/#{AUTO_RETRY_LIMIT}); manual clear required")
+      end
+
+      def audit_checks(checks)
+        # Every element is a HealthProbes::Check; render its audit hash and drop
+        # anything else. A non-Check reaching here is a bug, not a value to leak
+        # raw into the daemon-log audit record.
+        Array(checks).select { |check| check.respond_to?(:to_audit) }.map(&:to_audit)
+      end
+
+      def marker_id_for(row)
+        marker_attrs_for(row)["marker_id"].to_s
+      end
+
+      # Compact per-task events.jsonl record. Probe stdout/stderr tails go to
+      # the daemon log only (audit_checks), never the per-task stream.
+      def emit_task_event(row, event_type, message)
+        Hive::Events.emit(
+          task_folder: row.folder.to_s,
+          slug: row.slug.to_s,
+          stage: row.stage.to_s,
+          event_type: event_type,
+          agent: "daemon",
+          message: message
+        )
+      rescue StandardError => e
+        @logger.event(:marker_heal_failed,
+                      project: row.project,
+                      slug: row.slug,
+                      stage: row.stage,
+                      reason: "auto_retry_event",
+                      error: "#{e.class}: #{e.message}")
+      end
+
       def heal_error_if_auto_recoverable(row, now:)
         return if row.live_task_lock == true
         return unless auto_recoverable_error?(row, now: now)
