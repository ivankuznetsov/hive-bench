+  # ── Negative-decision throttle: persistent unhealthy ⇒ one skip event ──
+
+  def test_persistent_unhealthy_skip_is_throttled_across_ticks
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        probes = FakeProbes.new(healthy: false, fingerprint: "fp-stable", failing: [ "codex_exec_smoke" ])
+        healer = build_healer(probes: probes, project_root: dir)
+        t0 = Time.now
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+
+        # tick 1: probe, unhealthy ⇒ skip #1.
+        healer.heal([ row ], now: t0)
+        # tick 2 past the window: re-probe (fingerprint unchanged), same failing
+        # signature ⇒ the per-key throttle suppresses a second skip event.
+        healer.heal([ row ], now: t0 + 1801)
+
+        assert_equal 2, probes.probe_calls, "both ticks past the backoff window must re-probe"
+        assert_equal 1, events_named(@logger, :auto_retry_skipped).size,
+                     "an unchanged unhealthy signature must log auto_retry_skipped exactly once"
+      end
+    end
+  end
+
+  # ── Unsafe worktree does NOT re-shell-out git on an unchanged fingerprint ─
+  # Guards the per-tick git-spam regression: a persistently-unsafe marker must
+  # record its fingerprint/probe timestamp on the unsafe return so the re-probe
+  # gate short-circuits subsequent ticks, running `git status` at most once per
+  # backoff window (not on EVERY tick).
+  def test_unsafe_worktree_does_not_reprobe_git_within_window
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        # A counting probe_command reports a dirty (unsafe) worktree.
+        cmd = CountingProbeCommand.new(result: CmdResult.new(ok: true, stdout: " M user_edit.rb\n", stderr: ""))
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        probes = FakeProbes.new(healthy: true, fingerprint: "fp-stable")
+        healer = build_healer(probes: probes, project_root: dir, probe_command: cmd)
+        t0 = Time.now
+
+        # tick 1: safety guard shells out to git (unsafe) ⇒ skip, records fp.
+        healer.heal([ row ], now: t0)
+        # tick 2 at +60s: unchanged fingerprint within window ⇒ re-probe gate
+        # short-circuits BEFORE the safety guard, so no second git shell-out.
+        healer.heal([ row ], now: t0 + 60)
+
+        assert_equal :error, marker_name(row.state_file), "unsafe worktree ⇒ must not clear"
+        assert_equal 1, cmd.git_status_calls, "git status must run at most once across unchanged ticks"
+        assert_equal 0, probes.probe_calls, "safety guard must fail before the health probe"
+        assert_equal 1, events_named(@logger, :auto_retry_skipped).size, "skip event throttled to one"
+      end
+    end
+  end
+
+  # ── Positive test for the safe-residue allowlist (plan Unit 6) ────────────
+  # A worktree dirty with ONLY .done / result.json / .claude/settings.json
+  # residue is still safe to clear+rerun — the allowlist must clear it.
+  def test_safe_residue_worktree_still_clears
+    with_tmp_git_repo do |wt|
+      # Track the .claude dir so git lists settings.json individually (an
+      # untracked bare dir would collapse to ".claude/" and miss the allowlist).
+      FileUtils.mkdir_p(File.join(wt, ".claude"))
+      File.write(File.join(wt, ".claude", ".keep"), "")
+      run!("git", "-C", wt, "add", ".claude/.keep")
+      run!("git", "-C", wt, "commit", "-m", "seed .claude", "--quiet")
+      # Only hive/agent scratch residue — never user source.
+      File.write(File.join(wt, ".done"), "")
+      File.write(File.join(wt, "result.json"), "{}\n")
+      File.write(File.join(wt, ".claude", "settings.json"), "{}\n")
+
+      with_tmp_dir do |dir|
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        healer = build_healer(probes: FakeProbes.new(healthy: true), project_root: dir)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :none, marker_name(row.state_file), "safe-residue-only worktree must clear"
+        assert_equal 1, events_named(@logger, :auto_retry_cleared).size
+      end
+    end
+  end
+
+  # ── Fail-closed git probe: git failure ⇒ unsafe, never reads as clean ─────
+  def test_git_probe_failure_treated_as_unsafe
+    with_tmp_git_repo do |wt|
+      with_tmp_dir do |dir|
+        # A failed git probe (timeout / repo error) must NOT read as "clean".
+        cmd = CountingProbeCommand.new(
+          result: CmdResult.new(ok: false, stdout: "", stderr: "fatal: not a git repository",
+                                failure_reason: "exit=128")
+        )
+        row = seed_error_row(dir, stage: "4-execute", reason: "implementer_failed",
+                             attrs: { "message" => "401 unauthorized" }, worktree: wt)
+        probes = FakeProbes.new(healthy: true)
+        healer = build_healer(probes: probes, project_root: dir, probe_command: cmd)
+
+        healer.heal([ row ], now: Time.now)
+
+        assert_equal :error, marker_name(row.state_file), "git failure ⇒ unsafe ⇒ must not clear"
+        assert_equal 0, probes.probe_calls, "safety guard must fail before the health probe"
+        git_fail = events_named(@logger, :marker_heal_failed)
+                   .select { |_, a| a[:reason] == "auto_retry_git_probe" }
+        assert_equal 1, git_fail.size, "a git-probe failure must be logged (throttled)"
+        assert_match(/unsafe/, git_fail.first[1][:error])
