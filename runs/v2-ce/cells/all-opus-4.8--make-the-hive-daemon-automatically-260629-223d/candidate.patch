+++ b/lib/hive/daemon/recovery_signatures.rb
@@ -0,0 +1,92 @@
+module Hive
+  module Daemon
+    # Deterministic classifiers for the two dependency-outage failure
+    # signatures the daemon auto-retry path is allowed to touch. Everything
+    # NOT matched here stays parked — the classifiers are intentionally
+    # conservative and text-anchored, NOT the LLM DiagnosisAgent (too heavy
+    # and nondeterministic for the tick loop).
+    #
+    # `implementer_failed` is stamped by Stages::Execute#mark_implementer_failure
+    # with `status` + `message` attrs; a generic implementer failure (a test
+    # failure, exit_code=1, empty message) must NOT match — only a recognized
+    # Codex auth-401 signature does. `claude_launch_failed` is stamped by
+    # Stages::Base#spawn_claude_with_tmux_marker! from any ClaudeLauncher
+    # AgentError; the reason is already specific, so eligibility past this
+    # point is decided by the launcher health probe, not further text matching.
+    module RecoverySignatures
+      # Anchored auth-failure phrasing. Codex surfaces a 401 as an HTTP status
+      # and/or one of these OpenAI/gateway error strings. Kept tight so a
+      # business-logic failure whose message merely mentions "authorized" in
+      # prose doesn't trip it — each alternative is a recognized auth-error
+      # token, matched case-insensitively. A BARE `401` is deliberately NOT
+      # here: it lives in CODEX_AUTH_401_MARKER_PATTERNS below, which is matched
+      # only against the marker's own message/status, never the free-form log
+      # tail (where "401" could be a line count, an HTTP test fixture, etc.).
+      CODEX_AUTH_401_PATTERNS = [
+        /\bhttp[\s_-]?401\b/i,
+        /\b401\s+unauthorized\b/i,
+        /\bstatus(?:[\s_-]?code)?[\s:=]+401\b/i,
+        /\bunauthorized\b/i,
+        /\bunauthenticated\b/i,
+        /missing\s+bearer/i,
+        /missing\s+basic\s+auth/i,
+        /invalid[\s_-]?api[\s_-]?key/i,
+        /\bauth(?:entication|orization)?\s+(?:error|failed|required)/i
+      ].freeze
+
+      # A bare `401` token is trusted ONLY in the marker's own message/status
+      # (which the execute stage stamps directly from the Codex failure), NOT
+      # in the free-form events.jsonl log tail — keeping the classifier tight
+      # per the plan's "tight anchored auth pattern" mandate.
+      CODEX_AUTH_401_MARKER_PATTERNS = [
+        /\b401\b/
+      ].freeze
+
+      module_function
+
+      # True only for an `implementer_failed` marker whose message and/or the
+      # supplied log tail carries a recognized Codex auth-401 signature.
+      # `marker_attrs` is the parsed marker attribute Hash (string keys);
+      # `log_tail` is an optional bounded string (task log / events tail).
+      #
+      # The anchored patterns match the full haystack (marker + log tail); a
+      # BARE `401` only counts when it appears in the marker's own
+      # message/status, so a log tail that merely contains "401" in unrelated
+      # output does not trip the classifier.
+      def codex_auth_401?(marker_attrs, log_tail = nil)
+        attrs = normalize(marker_attrs)
+        return false unless attrs["reason"].to_s == "implementer_failed"
+
+        marker_text = [ attrs["message"], attrs["status"] ].compact.join("\n")
+        haystack = [ marker_text, log_tail ].compact.join("\n")
+        return false if haystack.strip.empty?
+
+        return true if CODEX_AUTH_401_PATTERNS.any? { |pattern| haystack.match?(pattern) }
+
+        return false if marker_text.strip.empty?
+
+        CODEX_AUTH_401_MARKER_PATTERNS.any? { |pattern| marker_text.match?(pattern) }
+      end
+
+      # True for a `claude_launch_failed` marker. The reason is only ever
+      # stamped from a ClaudeLauncher.launch! failure, so no further text
+      # matching is needed here — the launcher health probe decides whether
+      # the environment has actually recovered.
+      def claude_launch?(marker_attrs)
+        normalize(marker_attrs)["reason"].to_s == "claude_launch_failed"
+      end
+
+      # Whether a reason is in the auto-retry allowlist at all (before running
+      # the reason-specific classifier). Cheap pre-filter for the healer.
+      def eligible_reason?(reason)
+        %w[implementer_failed claude_launch_failed].include?(reason.to_s)
+      end
+
+      def normalize(marker_attrs)
+        return {} unless marker_attrs.is_a?(Hash)
+
+        marker_attrs.transform_keys(&:to_s)
+      end
+    end
+  end
+end
