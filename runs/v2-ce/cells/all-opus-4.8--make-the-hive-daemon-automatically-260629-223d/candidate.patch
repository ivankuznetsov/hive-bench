+
+  def test_plan_stage_with_authored_content_is_not_retried
+    with_tmp_dir do |dir|
+      # An authored plan.md holds real content the clear+rerun would overwrite,
+      # so the pre-worktree safety branch must refuse (no git worktree here).
+      row = seed_error_row(dir, stage: "3-plan", reason: "claude_launch_failed",
+                           attrs: { "message" => "prompt not ready" },
