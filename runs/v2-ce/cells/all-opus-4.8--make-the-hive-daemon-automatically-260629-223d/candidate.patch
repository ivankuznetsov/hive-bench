diff --git a/lib/hive/daemon/health_probes.rb b/lib/hive/daemon/health_probes.rb
new file mode 100644
index 00000000..0f1df3c1
--- /dev/null
+++ b/lib/hive/daemon/health_probes.rb
@@ -0,0 +1,417 @@
+require "digest"
+require "stringio"
+
+require "hive/config"
+require "hive/agent_profiles"
+require "hive/claude_launcher"
+require "hive/commands/doctor"
+require "hive/invoked_binary"
+require "hive/daemon/probe_command"
+
+module Hive
+  module Daemon
+    # Health probes for the daemon auto-retry path. Given an eligible parked
+    # reason, run the checks that must all pass before the marker is safe to
+    # clear+retry, and produce a health-signal fingerprint used to gate
+    # re-probing.
+    #
+    # Execution model is mixed, per the plan: Hive-internal checks (doctor,
+    # version, ready-detector) run IN-PROCESS; external CLI checks (codex
+    # login/exec) shell out through ProbeCommand with a hard timeout. Any
+    # probe timeout OR exception maps uniformly to "not healthy" — a probe
+    # NEVER raises out of `probe`.
+    #
+    # The universal `doctor` gate runs first (cheap, in-process) so an
+    # unhealthy environment short-circuits before any shell-out.
+    #
+    # Injectable `probe_command:` seam lets tests substitute a fake runner;
+    # `logged_in:` overrides the codex/claude credential check.
+    class HealthProbes
+      # Per-command timeouts (the plan's 10–30s band). Login-status is a
+      # local file/keychain read (fast); the exec smoke test may round-trip
+      # the API, so it gets the wider cap.
+      CODEX_LOGIN_TIMEOUT_SEC = 15
+      CODEX_SMOKE_TIMEOUT_SEC = 30
+      # Minimal no-op prompt for the codex smoke test: prove the CLI can
+      # reach its backend and complete a turn, nothing more.
+      CODEX_SMOKE_PROMPT = "Reply with the single word: ok".freeze
+
+      # Canonical panes for the ready-detector self-check. If a Claude CLI
+      # revision changes its idle-prompt shape past what the detector
+      # recognizes, the positive sample stops matching and the launcher probe
+      # reports unhealthy instead of silently re-launching into a wall.
+      READY_SELFCHECK_PANE = "Claude Code v0.0.0\n\n❯\n⏵⏵ bypass permissions on".freeze
+      NOT_READY_SELFCHECK_PANE = "Claude Code\n\n❯ 2. No, cancel\nDo you want to proceed?".freeze
+
+      # Fresh-per-tick cache so many parked rows sharing a (reason,
+      # project_root) trigger the external CLI at most once per tick.
+      class ProbeCache
+        def initialize
+          @store = {}
+        end
+
+        def fetch(key)
+          return @store[key] if @store.key?(key)
+
+          @store[key] = yield
+        end
+      end
+
+      Check = Struct.new(:name, :ok, :detail, :stdout_tail, :stderr_tail, :timed_out, keyword_init: true) do
+        def to_audit
+          { "name" => name, "ok" => ok, "timed_out" => timed_out == true }.tap do |h|
+            h["detail"] = detail if detail
+          end
+        end
+      end
+
+      # `healthy` is DERIVED from the checks, not stored, so a "healthy: true
+      # with a failing check" state is unrepresentable: a result is healthy iff
+      # it has at least one check and every check passed (an empty check set is
+      # NOT healthy — a probe always records at least the doctor gate).
+      ProbeResult = Struct.new(:checks, keyword_init: true) do
+        def healthy
+          cs = Array(checks)
+          !cs.empty? && cs.all?(&:ok)
+        end
+
+        def failing
+          Array(checks).reject(&:ok)
+        end
+
+        def failing_names
+          failing.map(&:name)
+        end
+      end
+
+      def initialize(probe_command: Hive::Daemon::ProbeCommand, logged_in: nil, logger: nil)
+        @probe_command = probe_command
+        @logged_in = logged_in
+        @logger = logger
+      end
+
+      # Run the reason-appropriate probes and return a ProbeResult. Cached per
+      # (reason, project_root) when a ProbeCache is supplied. Never raises.
+      def probe(reason, config:, project_root:, env: {}, cache: nil)
+        key = [ reason.to_s, project_root.to_s ]
+        if cache
+          cache.fetch(key) { run_probe(reason.to_s, config, project_root, env) }
+        else
+          run_probe(reason.to_s, config, project_root, env)
+        end
+      rescue StandardError => e
+        # A crash INSIDE probing is a programmer/infra bug, NOT a routine
+        # "dependency unhealthy" outcome — surface it distinctly (named
+        # `probe_crashed`, detail carries the crash site) and log it so an
+        # operator can tell it apart from a legitimately failing check.
+        note_probe_error("probe", reason, project_root, e)
+        ProbeResult.new(checks: [ error_check("probe_crashed", e) ])
+      end
+
+      # Stable digest over the health signals whose change should re-open a
+      # retry: the recovery `reason` and `project_root` (so distinct
+      # tasks/reasons never share a fingerprint), daemon version +
+      # invoked-binary path, per-agent bin path/mtime (a reinstall/upgrade
+      # changes the mtime), codex/claude login state, codex credential mtime,
+      # the launcher wrapper mtime, and a canonical digest of the loaded
+      # config. Unchanged environment ⇒ identical fingerprint (the healer
+      # skips re-probing within the backoff window).
+      def health_fingerprint(reason, config:, project_root:, env: {})
+        parts = [
+          "reason=#{reason}",
+          "hive=#{Hive::VERSION}",
+          "invoked=#{safe { Hive::InvokedBinary.path }}",
+          "project=#{project_root}",
+          "config=#{config_digest(config)}",
+          "wrapper_mtime=#{file_mtime(claude_wrapper_path)}",
+          "codex_auth_mtime=#{file_mtime(codex_auth_path)}"
+        ]
+        %i[claude codex].each do |agent|
+          bin = safe { Hive::AgentProfiles.lookup(agent, cfg: config).bin }
+          bin_path = resolve_bin_path(bin)
+          parts << "#{agent}_bin=#{bin}"
+          parts << "#{agent}_bin_mtime=#{file_mtime(bin_path)}"
+          parts << "#{agent}_login=#{logged_in?(agent)}"
+        end
+        ::Digest::SHA256.hexdigest(parts.join("\n"))
+      rescue StandardError => e
+        # A fingerprint that cannot be computed falls back to a value derived
+        # only from reason+project_root. Log it: a fingerprint that throws
+        # every tick would otherwise silently degrade the backoff gate (the
+        # fallback is stable per task, so the periodic re-probe still bounds
+        # it, but the underlying error must not vanish without a trace).
+        note_probe_error("health_fingerprint", reason, project_root, e)
+        ::Digest::SHA256.hexdigest("fingerprint_error:#{reason}:#{project_root}")
+      end
+
+      # In-process doctor gate: green = no `missing` / `version_too_old` rows
+      # (warnings / not_applicable are allowed). Shells out only for tmux/qmd
+      # version checks inside Doctor itself, which are bounded there.
+      # Raises if Doctor itself crashes (does NOT swallow to `false`): a
+      # crashing Doctor is a distinct fault from a real missing dependency, and
+      # `doctor_check` catches it separately so the two are never conflated.
+      def doctor_green?(config, project_root)
+        doctor = Hive::Commands::Doctor.new(config: config, project_root: project_root, output: StringIO.new)
+        doctor.call
+        rows = Array(doctor.rows)
+        rows.none? { |row| %w[missing version_too_old].include?(row[:status].to_s) }
+      end
+
+      private
+
+      def run_probe(reason, config, project_root, env)
+        checks = [ doctor_check(config, project_root) ]
+        return ProbeResult.new(checks: checks) unless checks.last.ok
+
+        case reason
+        when "implementer_failed"
+          checks.concat(codex_auth_probe(config, env: env))
+        when "claude_launch_failed"
+          checks.concat(claude_launcher_probe(config))
+        else
+          checks << Check.new(name: "eligible_reason", ok: false, detail: "reason not in auto-retry allowlist: #{reason}")
+        end
+
+        ProbeResult.new(checks: checks)
+      end
+
+      def doctor_check(config, project_root)
+        green = doctor_green?(config, project_root)
+        Check.new(name: "doctor_green", ok: green,
+                  detail: green ? "no missing/version_too_old rows" : "hive doctor reports a missing/outdated dependency")
+      rescue StandardError => e
+        # Doctor itself crashed/transiently errored. Report that distinctly
+        # (`doctor_crashed`, detail carries the crash) instead of laundering it
+        # into a false "missing dependency" rationale that parks the task on a
+        # misdescribed fault. Also log it for operator visibility.
+        note_probe_error("doctor", nil, project_root, e)
+        error_check("doctor_crashed", e)
+      end
+
+      # Codex auth recovery: credential present AND `codex login status` OK AND
+      # a tiny `codex exec` smoke test completes — all in the same env the
+      # daemon will launch codex with.
+      def codex_auth_probe(config, env: {})
+        checks = []
+        present, login_error = logged_in_status(:codex)
+        detail = if login_error
+                   "codex login check raised: #{login_error}"
+                 else
+                   present ? "~/.codex/auth.json present" : "no codex credential on disk"
+                 end
+        checks << Check.new(name: "codex_logged_in", ok: present, detail: detail)
+        return checks unless present
+
+        # Resolve the codex bin config-aware (cfg: config) so the smoke test
+        # validates the SAME binary the fingerprint tracks and the daemon
+        # actually launches — a project config that overrides the codex bin
+        # must not smoke-test a different binary.
+        codex_bin = safe { Hive::AgentProfiles.lookup(:codex, cfg: config).bin } || "codex"
+        status = @probe_command.run([ codex_bin, "login", "status" ], env: env, timeout_sec: CODEX_LOGIN_TIMEOUT_SEC)
+        checks << check_from_result("codex_login_status", status)
+        return checks unless status.ok
+
+        smoke = @probe_command.run([ codex_bin, "exec", CODEX_SMOKE_PROMPT ], env: env, timeout_sec: CODEX_SMOKE_TIMEOUT_SEC)
+        checks << check_from_result("codex_exec_smoke", smoke)
+        checks
+      end
+
+      # Claude launcher recovery: wrapper file present in the active install,
+      # tmux available (tmux mode only), the ready-detector still recognizes a
+      # canonical idle prompt, and the claude CLI meets its min version.
+      # (The universal doctor gate already ran in `run_probe`.)
+      def claude_launcher_probe(config)
+        checks = []
+
+        wrapper = claude_wrapper_path
+        wrapper_ok = File.file?(wrapper)
+        checks << Check.new(name: "claude_wrapper_present", ok: wrapper_ok, detail: wrapper)
+
+        tmux_mode, tmux_mode_error = claude_tmux_mode_status(config)
+        if tmux_mode_error
+          # A raised mode check is NOT the same as "headless" — fail closed
+          # with the error surfaced rather than silently skipping the tmux gate.
+          checks << Check.new(name: "tmux_available", ok: false, detail: "claude mode check raised: #{tmux_mode_error}")
+        elsif tmux_mode
+          status, message = Hive::ClaudeLauncher.tmux_status
+          checks << Check.new(name: "tmux_available", ok: status == :present, detail: message)
+        end
+
+        detector_ok, detector_detail = ready_detector_selfcheck
+        checks << Check.new(name: "ready_detector_selfcheck", ok: detector_ok, detail: detector_detail)
+
+        version_ok, version_detail = claude_version_ok(config)
+        checks << Check.new(name: "claude_version", ok: version_ok, detail: version_detail)
+
+        checks
+      end
+
+      # [tmux_mode_bool, error_message_or_nil]. A raised mode check is reported
+      # distinctly (error non-nil) instead of being folded into a bare `false`,
+      # so a broken config read can't masquerade as "headless mode".
+      def claude_tmux_mode_status(config)
+        [ Hive::Config.claude_mode(config) == :tmux, nil ]
+      rescue StandardError => e
+        [ false, e.message ]
+      end
+
+      # [ok_bool, detail]. Follows the claude_version_ok pattern: a raised
+      # self-check threads e.message into the detail rather than collapsing to
+      # an un-annotated `false`.
+      def ready_detector_selfcheck
+        ok = Hive::ClaudeLauncher.claude_ready_prompt?(READY_SELFCHECK_PANE) &&
+          !Hive::ClaudeLauncher.claude_ready_prompt?(NOT_READY_SELFCHECK_PANE)
+        [ ok, ok ? "detector recognizes the idle prompt" : "detector no longer matches a canonical ready prompt" ]
+      rescue StandardError => e
+        [ false, "ready-detector self-check raised: #{e.message}" ]
+      end
+
+      def claude_version_ok(config)
+        version = Hive::AgentProfiles.lookup(:claude, cfg: config).check_version!
+        [ true, "claude #{version}" ]
+      rescue StandardError => e
+        [ false, e.message ]
+      end
+
+      def check_from_result(name, result)
+        Check.new(
+          name: name,
+          ok: result.ok,
+          detail: probe_detail(result),
+          stdout_tail: tail(result.stdout),
+          stderr_tail: tail(result.stderr),
+          timed_out: result.timed_out
+        )
+      end
+
+      def probe_detail(result)
+        result.failure_reason || "exit=#{result.exit_status.inspect}"
+      end
+
+      def error_check(name, error)
+        detail = "#{error.class}: #{error.message}"
+        site = Array(error.backtrace).first
+        detail = "#{detail} @ #{site}" if site
+        Check.new(name: name, ok: false, detail: detail)
+      end
+
+      # Log an internal probe/fingerprint crash so a programmer/infra bug is
+      # visible instead of vanishing into a routine "not healthy" outcome. A
+      # no-op when no logger was injected (unit tests build HealthProbes bare);
+      # the daemon threads its logger in via the healer.
+      def note_probe_error(context, reason, project_root, error)
+        return unless @logger
+
+        @logger.event(:marker_heal_failed,
+                      reason: "auto_retry_#{context}",
+                      marker_reason: reason,
+                      project_root: project_root.to_s,
+                      error: "#{error.class}: #{error.message}")
+      rescue StandardError
+        # Last-resort swallow: the logger IS the sink for this diagnostic, so if
+        # emitting the event itself raises there is nowhere left to report to —
+        # drop it rather than let a logger fault mask the probe crash we were
+        # already trying to surface.
+        nil
+      end
+
+      # Bounded tail of captured probe output for the daemon-log audit record.
+      # Kept small — the per-task events.jsonl stream carries only compact
+      # rationale; full stdout/stderr tails go to the daemon log.
+      STDIO_TAIL_BYTES = 512
+
+      def tail(str)
+        s = str.to_s.strip
+        return "" if s.empty?
+
+        s.byteslice(-STDIO_TAIL_BYTES, STDIO_TAIL_BYTES).to_s.scrub
+      end
+
+      # Boolean-only view for fingerprinting: a raised credential check folds
+      # to `false` (the fingerprint just needs a stable signal, not a reason).
+      def logged_in?(agent)
+        logged_in_raw(agent)
+      rescue StandardError
+        false
+      end
+
+      # [logged_in_bool, error_message_or_nil] for check details: distinguishes
+      # a genuine "not logged in" (false, nil) from a raised credential check
+      # (false, msg), following the claude_version_ok pattern.
+      def logged_in_status(agent)
+        [ logged_in_raw(agent), nil ]
+      rescue StandardError => e
+        [ false, e.message ]
+      end
+
+      def logged_in_raw(agent)
+        return @logged_in.call(agent) if @logged_in
+
+        Hive::AgentProfiles.logged_in?(agent)
+      end
+
+      def claude_wrapper_path
+        File.expand_path("../scripts/interactive_claude_wrapper.sh", __dir__)
+      end
+
+      def codex_auth_path
+        File.join(Dir.home, ".codex", "auth.json")
+      rescue StandardError
+        # Degraded fingerprint: $HOME unset (Dir.home raises) ⇒ drop the codex
+        # credential mtime from the fingerprint rather than crash. Benign — the
+        # fingerprint just loses one input and still tracks the other signals.
+        ""
+      end
+
+      def resolve_bin_path(bin)
+        return nil if bin.to_s.empty?
+        return bin if bin.include?(File::SEPARATOR) && File.exist?(bin)
+
+        ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+          candidate = File.join(dir, bin)
+          return candidate if File.file?(candidate) && File.executable?(candidate)
+        end
+        nil
+      end
+
+      def file_mtime(path)
+        return "absent" if path.to_s.empty?
+
+        File.mtime(path).to_f
+      rescue SystemCallError
+        "absent"
+      end
+
+      def config_digest(config)
+        ::Digest::SHA256.hexdigest(canonical(config).to_s)
+      rescue StandardError
+        "unknown"
+      end
+
+      # Order-independent serialization so an equivalent config always digests
+      # the same regardless of hash-insertion order.
+      def canonical(obj)
+        case obj
+        when Hash
+          obj.keys.map(&:to_s).sort.map do |k|
+            # Explicit key? lookup, not `obj[k] || obj[k.to_sym]`: the `||`
+            # fallback would collapse a literal `false` value to the symbol-key
+            # lookup, making a `false`↔`nil` config flip invisible to the digest.
+            value = obj.key?(k) ? obj[k] : obj[k.to_sym]
+            [ k, canonical(value) ]
+          end
+        when Array
+          obj.map { |element| canonical(element) }
+        else
+          obj
+        end
+      end
+
+      def safe
+        yield
+      rescue StandardError
+        nil
+      end
+    end
+  end
+end
