+require "test_helper"
+require "hive/daemon/recovery_signatures"
+
+class DaemonRecoverySignaturesTest < Minitest::Test
+  RS = Hive::Daemon::RecoverySignatures
+
+  # ── codex_auth_401? ──────────────────────────────────────────────────
+
+  def test_codex_401_message_is_eligible
+    attrs = { "reason" => "implementer_failed", "status" => "error",
+              "message" => "codex exec failed: HTTP 401 Unauthorized" }
+    assert RS.codex_auth_401?(attrs)
+  end
+
+  def test_codex_missing_bearer_message_is_eligible
+    attrs = { "reason" => "implementer_failed",
+              "message" => "request rejected: missing bearer token" }
+    assert RS.codex_auth_401?(attrs)
+  end
+
+  def test_codex_401_only_in_log_tail_is_eligible
+    attrs = { "reason" => "implementer_failed", "message" => "" }
+    log = "some earlier output\nError: 401 unauthorized from api\nmore"
+    assert RS.codex_auth_401?(attrs, log)
+  end
+
+  def test_generic_implementer_failure_is_not_eligible
+    attrs = { "reason" => "implementer_failed", "status" => "error",
+              "message" => "3 tests failed, exit code 1" }
+    refute RS.codex_auth_401?(attrs)
+  end
+
+  def test_empty_implementer_failure_is_not_eligible
+    attrs = { "reason" => "implementer_failed", "message" => "" }
+    refute RS.codex_auth_401?(attrs)
+    refute RS.codex_auth_401?(attrs, nil)
+  end
+
+  def test_prose_authorized_word_does_not_falsely_match
+    # "authorized the change" contains "authorized" but not as an auth-error
+    # token — the \bunauthorized\b / auth-error patterns must not fire.
+    attrs = { "reason" => "implementer_failed",
+              "message" => "the maintainer authorized the change but the build broke" }
+    refute RS.codex_auth_401?(attrs)
+  end
+
+  def test_non_implementer_reason_never_matches_codex
+    attrs = { "reason" => "dirty_worktree", "message" => "401 unauthorized" }
+    refute RS.codex_auth_401?(attrs)
+  end
+
+  def test_codex_handles_symbol_keys
+    attrs = { reason: "implementer_failed", message: "401 unauthorized" }
+    assert RS.codex_auth_401?(attrs)
+  end
+
+  # ── claude_launch? ───────────────────────────────────────────────────
+
+  def test_claude_launch_failed_is_eligible
+    assert RS.claude_launch?({ "reason" => "claude_launch_failed",
+                               "exception_class" => "Hive::AgentError",
+                               "message" => "claude interactive prompt did not become ready" })
+  end
+
+  def test_other_reason_is_not_claude_launch
+    refute RS.claude_launch?({ "reason" => "tmux_unavailable" })
+    refute RS.claude_launch?({ "reason" => "implementer_failed" })
+  end
+
+  # ── eligible_reason? ─────────────────────────────────────────────────
+
+  def test_eligible_reason_allowlist
+    assert RS.eligible_reason?("implementer_failed")
+    assert RS.eligible_reason?("claude_launch_failed")
+    refute RS.eligible_reason?("timeout")
+    refute RS.eligible_reason?("dirty_worktree")
+    refute RS.eligible_reason?(nil)
+  end
+
+  def test_nil_attrs_never_match
+    refute RS.codex_auth_401?(nil)
+    refute RS.claude_launch?(nil)
+  end
+end
