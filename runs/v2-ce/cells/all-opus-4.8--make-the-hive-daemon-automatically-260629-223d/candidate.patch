+require "test_helper"
+require "hive/daemon/probe_command"
+
+class DaemonProbeCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  PC = Hive::Daemon::ProbeCommand
+
+  def test_success_returns_ok_with_captured_stdout
+    result = PC.run([ "sh", "-c", "printf hello" ], timeout_sec: 5)
+    assert result.ok, "exit 0 should be ok"
+    assert_equal "hello", result.stdout
+    assert_equal 0, result.exit_status
+    refute result.timed_out
+    assert result.duration_ms >= 0
+  end
+
+  def test_non_zero_exit_returns_not_ok_with_stderr
+    result = PC.run([ "sh", "-c", "printf oops 1>&2; exit 3" ], timeout_sec: 5)
+    refute result.ok
+    assert_equal 3, result.exit_status
+    assert_equal "oops", result.stderr
+    refute result.timed_out
+  end
+
+  def test_timeout_returns_timed_out_and_reaps_process_group
+    # Spawn a child that itself spawns a grandchild sleeper, then sleeps.
+    # We capture the grandchild PID so we can assert the whole group is
+    # gone after the timeout kill.
+    with_tmp_dir do |dir|
+      pidfile = File.join(dir, "grandchild.pid")
+      script = "sh -c 'sleep 30 & echo $! > #{pidfile}; sleep 30'"
+      result = PC.run([ "sh", "-c", script ], timeout_sec: 1)
+
+      assert result.timed_out, "a child sleeping past the deadline must time out"
+      refute result.ok
+      # Give the SIGKILL a beat to land across the group.
+      sleep 0.3
+      # The grandchild pid is written at spawn (`echo $!`), well before the 1s
+      # deadline, so the pidfile MUST exist — assert it unconditionally rather
+      # than skipping the module's load-bearing "whole process group killed"
+      # guarantee on a pidfile race.
+      assert File.exist?(pidfile), "grandchild pidfile must have been written before the timeout"
+      grandchild = File.read(pidfile).to_i
+      assert grandchild.positive?, "grandchild pid must be captured, got #{grandchild.inspect}"
+      alive =
+        begin
+          Process.kill(0, grandchild)
+          true
+        rescue Errno::ESRCH
+          false
+        end
+      refute alive, "the process group (incl. grandchild sleeper) must be killed on timeout"
+    end
+  end
+
+  def test_oversized_output_is_truncated_to_max_bytes
+    result = PC.run([ "sh", "-c", "yes x | head -c 100000" ], timeout_sec: 10, max_bytes: 1024)
+    assert result.stdout.bytesize <= 1024, "stdout must be capped at max_bytes"
+  end
+
+  def test_missing_binary_returns_not_ok_without_raising
+    result = PC.run([ "hive-definitely-not-a-real-binary-xyz" ], timeout_sec: 5)
+    refute result.ok
+    refute result.timed_out
+    refute_nil result.error
+    assert_nil result.status
+  end
+
+  def test_env_is_passed_to_child
+    result = PC.run([ "sh", "-c", "printf %s \"$PROBE_TEST_VAR\"" ],
+                    env: { "PROBE_TEST_VAR" => "abc" }, timeout_sec: 5)
+    assert result.ok
+    assert_equal "abc", result.stdout
+  end
+
+  def test_empty_argv_raises_argument_error
+    assert_raises(ArgumentError) { PC.run([], timeout_sec: 5) }
+  end
+end
