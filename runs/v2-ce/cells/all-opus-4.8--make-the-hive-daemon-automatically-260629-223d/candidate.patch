@@ -0,0 +1,190 @@
+module Hive
+  module Daemon
+    # Timeout-bounded command runner for daemon health probes. Shells out
+    # to an external CLI (`codex`, `claude`, …) with a hard per-command
+    # deadline, capturing stdout+stderr and a clean `timed_out` signal so a
+    # probe can treat timeout OR non-zero exit OR spawn failure uniformly as
+    # "not healthy" without a rescue at every call site.
+    #
+    # Deliberately a small NEW module rather than an extraction of
+    # `Hive::GitOps#run_git_with_timeout` (which carries battle-tested
+    # rebase-abort semantics we don't want to perturb in a feature PR). The
+    # process-group spawn + `IO.select` deadline + byte-cap pattern is copied
+    # from there so a hung child is killed by its whole process group, not
+    # left dangling, and captured output stays bounded for audit records.
+    #
+    # `run` NEVER raises on a non-zero exit, a timeout, or a missing binary:
+    # it always returns a Result and lets the caller decide. The only way a
+    # caller sees an exception is a programmer error — an EMPTY argv, which
+    # raises ArgumentError (a non-Array argv is silently coerced by
+    # `Array(argv)`, so it does not raise) — which is not rescued on purpose.
+    module ProbeCommand
+      # 64 KiB is plenty for a login-status / version / smoke-test tail while
+      # keeping the daemon-log audit record small.
+      DEFAULT_MAX_BYTES = 64 * 1024
+      DEFAULT_TIMEOUT_SEC = 30
+      READ_CHUNK_BYTES = 4096
+
+      # `status` is the Process::Status (nil when the child never started or
+      # was killed on timeout). `ok` is DERIVED, not stored, so illegal
+      # combinations (`ok: true` with `timed_out: true`, or `ok: true` with a
+      # nil status) are unrepresentable: a probe succeeded iff it did not time
+      # out and the spawn produced a cleanly-exited status.
+      Result = Struct.new(
+        :status, :stdout, :stderr, :timed_out, :duration_ms, :error,
+        keyword_init: true
+      ) do
+        def ok
+          timed_out != true && status&.success? == true
+        end
+        alias_method :ok?, :ok
+
+        def exit_status
+          status&.exitstatus
+        end
+
+        # Single "why did this fail" accessor so callers don't re-branch across
+        # timed_out / error / exit_status. nil when the probe succeeded.
+        def failure_reason
+          return nil if ok
+          return "timed out after #{duration_ms}ms" if timed_out
+          return error if error
+
+          "exit=#{exit_status.inspect}"
+        end
+      end
+
+      module_function
+
+      def run(argv, env: {}, timeout_sec: DEFAULT_TIMEOUT_SEC, max_bytes: DEFAULT_MAX_BYTES)
+        argv = Array(argv).map(&:to_s)
+        raise ArgumentError, "ProbeCommand.run requires a non-empty argv" if argv.empty?
+
+        started = Process.clock_gettime(Process::CLOCK_MONOTONIC)
+        out_r, out_w = IO.pipe
+        err_r, err_w = IO.pipe
+        pid = Process.spawn(stringify_env(env), *argv, in: :close, out: out_w, err: err_w, pgroup: true)
+        out_w.close
+        err_w.close
+
+        out_buf = +""
+        err_buf = +""
+        readers = [ out_r, err_r ]
+        deadline = started + timeout_sec
+        timed_out = false
+        status = nil
+
+        loop do
+          remaining = deadline - Process.clock_gettime(Process::CLOCK_MONOTONIC)
+          if remaining <= 0
+            timed_out = true
+            break
+          end
+
+          ready, = IO.select(readers, [], [], [ remaining, 0.1 ].min)
+          drain_ready(ready, readers, out_r, out_buf, err_buf, max_bytes)
+
+          _, status = Process.waitpid2(pid, Process::WNOHANG)
+          next unless status
+
+          drain_remaining(readers, out_r, err_r, out_buf, err_buf, max_bytes)
+          break
+        end
+
+        if timed_out
+          terminate_process_group(pid)
+          readers.each { |r| r.close unless r.closed? }
+        end
+
+        duration_ms = ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).round
+        Result.new(
+          status: status,
+          stdout: out_buf,
+          stderr: err_buf,
+          timed_out: timed_out,
+          duration_ms: duration_ms,
+          error: nil
+        )
+      rescue Errno::ENOENT, Errno::EACCES => e
+        # Binary missing / not executable: a probe treats this as "not
+        # healthy" exactly like a timeout, so return a Result rather than
+        # raising. Pipes opened above are closed in `ensure`.
+        [ out_r, out_w, err_r, err_w ].each { |io| io&.close unless io&.closed? }
+        duration_ms = started ? ((Process.clock_gettime(Process::CLOCK_MONOTONIC) - started) * 1000).round : 0
+        Result.new(
+          status: nil, stdout: "", stderr: e.message,
+          timed_out: false, duration_ms: duration_ms, error: "#{e.class}: #{e.message}"
+        )
+      end
+
+      # Best-effort: SIGTERM then SIGKILL the whole process group so a child
+      # that forked its own workers is fully reaped (no orphan). The child is
+      # waitpid'd so it does not linger as a zombie.
+      def terminate_process_group(pid)
+        signal_group_or_pid(pid, "TERM")
+        sleep 0.2
+        signal_group_or_pid(pid, "KILL")
+        Process.waitpid(pid)
+      rescue Errno::ECHILD, Errno::ESRCH
+        nil
+      end
+
+      def signal_group_or_pid(pid, sig)
+        Process.kill(sig, -pid)
+      rescue Errno::ESRCH
+        begin
+          Process.kill(sig, pid)
+        rescue Errno::ESRCH
+          nil
+        end
+      end
+
+      def drain_ready(ready, readers, out_r, out_buf, err_buf, max_bytes)
+        (ready || []).each do |r|
+          chunk = r.read_nonblock(READ_CHUNK_BYTES)
+          append_capped(r == out_r ? out_buf : err_buf, chunk, max_bytes)
+        rescue IO::WaitReadable
+          # Spurious readiness: select flagged this reader but no data is
+          # actually available. Nothing to do — this does NOT loop here; we
+          # fall through to the caller's next IO.select iteration.
+        rescue EOFError
+          # This reader is drained; drop it so the next IO.select doesn't
+          # get handed a closed stream (which would raise IOError).
+          readers.delete(r)
+          r.close unless r.closed?
+        end
+      end
+
+      def drain_remaining(readers, out_r, _err_r, out_buf, err_buf, max_bytes)
+        readers.each do |r|
+          next if r.closed?
+
+          begin
+            loop do
+              chunk = r.read_nonblock(READ_CHUNK_BYTES)
+              append_capped(r == out_r ? out_buf : err_buf, chunk, max_bytes)
+            end
+          rescue IO::WaitReadable, EOFError, IOError
+            # done draining (or the reader hit EOF during the select loop)
+          ensure
+            r.close unless r.closed?
+          end
+        end
+      end
+
+      def append_capped(buf, chunk, max_bytes)
+        return if buf.bytesize >= max_bytes
+
+        buf << chunk.byteslice(0, max_bytes - buf.bytesize).to_s
+      end
+
+      # Process.spawn requires all env keys/values to be strings; a probe
+      # caller may pass symbol keys or nil values (to unset), so normalize.
+      def stringify_env(env)
+        (env || {}).each_with_object({}) do |(key, value), acc|
+          acc[key.to_s] = value.nil? ? nil : value.to_s
+        end
+      end
+    end
+  end
+end
