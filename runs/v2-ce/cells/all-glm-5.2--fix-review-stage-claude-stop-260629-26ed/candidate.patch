+  def test_claude_completion_fallback_event_is_emittable_and_renders
+    with_tmp_dir do |dir|
+      record = Hive::Events.emit(
+        task_folder: dir, slug: "fix-review-260629-abcd", stage: "6-review",
+        agent: "claude", event_type: :claude_completion_fallback,
+        message: "slug=fix-review-260629-abcd reason=stop_hook_absent_idle_prompt"
+      )
+
+      parsed = JSON.parse(File.read(File.join(dir, "events.jsonl")))
+      assert_equal "claude_completion_fallback", parsed.fetch("event_type")
+      assert_equal "claude", parsed.fetch("agent")
+      assert_match(/stop_hook_absent_idle_prompt/, parsed.fetch("message"))
+      # status.md renders the new type generically without crashing.
+      status = File.read(File.join(dir, "status.md"))
+      assert_match(/claude_completion_fallback/, status)
+      assert record
+    end
+  end
