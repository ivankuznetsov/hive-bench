+    # Consult a caller-supplied completion predicate on the missing-signal
+    # path. The launcher calls this ONLY at a wait deadline when the
+    # Stop-hook sentinel (`.done` / `result.json`) never appeared — never on
+    # a genuine crash / exit!=0 / unreadable-tmux path (those bypass the
+    # fallback). `context` is the hash handed to the predicate
+    # (`{task:, runner:, result_path:, done_path:, log_label:, status_mode:,
+    # expected_output:, session_name:}`). A predicate returns `nil` (cannot
+    # prove) or `{proven: true, reason:, evidence: {…}}`. On proof the
+    # launcher emits a `claude_completion_fallback` audit event and returns
+    # the payload; the caller then returns `:ok` instead of `:timeout`.
+    # A predicate that raises is treated as not-proven so a buggy predicate
+    # can never mask a real timeout.
+    def run_completion_fallback(task:, context:, fallback:, log_label:)
+      return nil unless fallback
+
+      result =
+        begin
+          fallback.call(context)
+        rescue StandardError => e
+          warn "[hive] completion_fallback predicate raised for " \
+               "#{task_slug(task)}: #{e.class}: #{e.message}"
+          nil
+        end
+      return nil unless result.is_a?(Hash) && result[:proven]
+
+      payload = {
+        slug: task_slug(task),
+        log_label: log_label,
+        status_mode: context[:status_mode]&.to_s,
+        sentinel_path: context[:done_path],
+        result_path: context[:result_path],
+        reason: result[:reason].to_s,
+        evidence: result[:evidence] || {}
+      }
+      payload[:session_name] = context[:session_name] if context[:session_name]
+      payload[:pid] = context[:pid] if context[:pid]
+      emit_completion_fallback!(task, payload)
+      payload
+    end
+
+    # Emit the non-error `claude_completion_fallback` audit event. The
+    # `message` is a compact single-line summary (Events truncates it to
+    # MAX_MESSAGE_BYTES / 1 KiB); the full structured payload is returned to
+    # the caller and carried on the result hash (`result[:completion_fallback]`)
+    # so no evidence is lost to truncation. Best-effort: an emit failure
+    # must not alter the spawn's outcome.
+    def emit_completion_fallback!(task, payload)
+      stage = task.respond_to?(:stage_name) ? "#{task.stage_index}-#{task.stage_name}" : nil
+      summary = "slug=#{payload[:slug]} reason=#{payload[:reason]} " \
+                "sentinel=#{payload[:sentinel_path]} evidence=#{payload[:evidence].inspect}"
+      Hive::Events.emit(
+        task_folder: task.folder,
+        slug: payload[:slug],
+        stage: stage.to_s,
+        event_type: :claude_completion_fallback,
+        agent: :claude,
+        message: summary
+      )
+      payload
+    rescue StandardError => e
+      warn "[hive] failed to emit claude_completion_fallback for " \
+           "#{payload[:slug]}: #{e.class}: #{e.message}"
+      payload
+    end
+
     # Read `result.json` (if present) and translate `status` into the
     # caller's symbol vocabulary. Unknown / unparseable shapes return
     # nil so the caller can fall through to its default success path.
