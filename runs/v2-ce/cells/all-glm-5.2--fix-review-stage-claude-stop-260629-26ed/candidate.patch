diff --git a/test/unit/claude_launcher_test.rb b/test/unit/claude_launcher_test.rb
index 1d6b2589..23b281b7 100644
--- a/test/unit/claude_launcher_test.rb
+++ b/test/unit/claude_launcher_test.rb
@@ -1304,6 +1304,50 @@ class ClaudeLauncherTest < Minitest::Test
     end
   end
 
+  def test_emit_completion_fallback_writes_event_and_returns_payload
+    with_tmp_task do |task|
+      payload = {
+        slug: task.slug,
+        log_label: "review-fix-pass01",
+        status_mode: "exit_code_only",
+        sentinel_path: Hive::ClaudeLauncher.done_path(task),
+        result_path: Hive::ClaudeLauncher.result_path(task),
+        reason: "stop_hook_absent_idle_prompt",
+        evidence: { idle_prompt: true, new_commit: "abc1234" }
+      }
+
+      returned = Hive::ClaudeLauncher.emit_completion_fallback!(task, payload)
+
+      assert_equal payload, returned
+      lines = File.readlines(File.join(task.folder, "events.jsonl"))
+      parsed = JSON.parse(lines.last)
+      assert_equal "claude_completion_fallback", parsed.fetch("event_type")
+      assert_equal "claude", parsed.fetch("agent")
+      assert_match(/stop_hook_absent_idle_prompt/, parsed.fetch("message"))
+      assert_match(/abc1234/, parsed.fetch("message"))
+      assert_equal "#{task.stage_index}-#{task.stage_name}", parsed.fetch("stage")
+    end
+  end
+
+  def test_emit_completion_fallback_truncates_large_payload_message
+    with_tmp_task do |task|
+      payload = {
+        slug: task.slug,
+        log_label: "review-fix-pass01",
+        sentinel_path: Hive::ClaudeLauncher.done_path(task),
+        result_path: Hive::ClaudeLauncher.result_path(task),
+        reason: "x" * (Hive::Events::MAX_MESSAGE_BYTES + 500),
+        evidence: { big: "y" * 2000 }
+      }
+
+      Hive::ClaudeLauncher.emit_completion_fallback!(task, payload)
+
+      parsed = JSON.parse(File.readlines(File.join(task.folder, "events.jsonl")).last)
+      assert_operator parsed.fetch("message").bytesize, :<=, Hive::Events::MAX_MESSAGE_BYTES
+      assert parsed.fetch("message").end_with?(Hive::Events::MESSAGE_TRUNCATION_SUFFIX)
+    end
+  end
+
   def test_wait_for_terminal_marker_preserves_pane_unreadable_error_on_timeout
     with_tmp_task do |task|
       Hive::Markers.set(task.state_file, :error, reason: "tmux_pane_unreadable", message: "pane gone")
