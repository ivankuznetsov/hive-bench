@@ -0,0 +1,39 @@
+require "test_helper"
+require "open3"
+require "rbconfig"
+require "rubygems/package"
+
+class GemPackageScriptsTest < Minitest::Test
+  PROJECT_ROOT = File.expand_path("../..", __dir__)
+  GEMSPEC_PATH = File.join(PROJECT_ROOT, "hive.gemspec")
+  LAUNCHER_SOURCES = %w[
+    lib/hive/claude_launcher.rb
+    lib/hive/stop_hook_installer.rb
+  ].freeze
+
+  def test_built_gem_contains_every_launcher_script_reference
+    script_paths = LAUNCHER_SOURCES.flat_map do |source_path|
+      source = File.read(File.join(PROJECT_ROOT, source_path), encoding: Encoding::UTF_8)
+      source.scan(/["'](scripts\/[^"']+\.sh)["']/).flatten.map { |path| "lib/hive/#{path}" }
+    end.uniq.sort
+
+    refute_empty script_paths, "launcher script discovery must not pass vacuously"
+    script_paths.each do |script_path|
+      assert_path_exists File.join(PROJECT_ROOT, script_path), "missing launcher script: #{script_path}"
+    end
+
+    Dir.mktmpdir("hive-gem-package") do |tmpdir|
+      gem_path = File.join(tmpdir, "hive-cli.gem")
+      stdout, stderr, status = Open3.capture3(
+        RbConfig.ruby, "-S", "gem", "build", GEMSPEC_PATH, "--output", gem_path,
+        chdir: PROJECT_ROOT
+      )
+      assert status.success?, "gem build failed:\n#{stdout}\n#{stderr}"
+
+      packaged_files = Gem::Package.new(gem_path).contents
+      script_paths.each do |script_path|
+        assert_includes packaged_files, script_path, "built gem omitted launcher script: #{script_path}"
+      end
+    end
+  end
+end
