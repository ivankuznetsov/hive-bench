diff --git a/web/app/controllers/daemon_health_controller.rb b/web/app/controllers/daemon_health_controller.rb
new file mode 100644
index 00000000..b47ad054
--- /dev/null
+++ b/web/app/controllers/daemon_health_controller.rb
@@ -0,0 +1,55 @@
+require "hive/daemon_consistency"
+
+# Surfaces daemon health to the operator: whether the daemon is running and
+# whether its installed unit points at the SAME binary the CLI resolves to
+# (ADR: local non-Docker mode, U5). A drifted/stale/not-installed daemon is
+# repairable in place via `hive daemon install --force`.
+class DaemonHealthController < ApplicationController
+  # Seam so tests (and the Docker box, where repair is a no-op) can stub the
+  # host-mutating install without spawning a real service manager. Returns a
+  # wire-friendly outcome hash.
+  cattr_accessor :repair_runner
+  self.repair_runner = ->(force:) { DaemonHealthController.default_repair(force: force) }
+
+  # Read-only health snapshot. Reuses the same pidfile probe `/health` uses,
+  # plus the binary-consistency classification.
+  def show
+    render json: {
+      ok: true,
+      daemon: { running: daemon_running? },
+      consistency: Hive::DaemonConsistency.new.call.to_h
+    }
+  end
+
+  # Owner-gated repair: re-run `daemon install --force`, which backs up the
+  # old unit and restarts (Linux) / reloads (macOS) on the wrapper path, so
+  # it fixes a drifted /usr/bin/hive unit. Confirm-gated in the UI.
+  def repair
+    outcome = self.class.repair_runner.call(force: true)
+    respond_to do |format|
+      format.json { render json: { ok: outcome["status"] != "failed", outcome: outcome } }
+      format.html do
+        if outcome["status"] == "failed"
+          redirect_to root_path, alert: "Daemon repair failed: #{outcome['message']}"
+        else
+          redirect_to root_path, notice: "Daemon repaired (#{outcome['status']})."
+        end
+      end
+    end
+  end
+
+  # Default (real) repair: run the daemon service installer with --force.
+  def self.default_repair(force:)
+    require "hive/commands/daemon"
+    Hive::Commands::Daemon.new("install", force: force).call
+    { "status" => "installed" }
+  rescue Hive::Error => e
+    { "status" => "failed", "message" => e.message }
+  end
+
+  private
+
+  def daemon_running?
+    !HealthController::DaemonProbe.new.read_live_pid.nil?
+  end
+end
