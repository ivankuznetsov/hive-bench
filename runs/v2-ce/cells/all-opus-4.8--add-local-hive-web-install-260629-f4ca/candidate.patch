diff --git a/lib/hive/commands/setup.rb b/lib/hive/commands/setup.rb
new file mode 100644
index 00000000..c1035e34
--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,292 @@
+require "json"
+
+require "hive"
+require "hive/config"
+require "hive/local_preflight"
+
+module Hive
+  module Commands
+    # `hive setup` — one command to bring up local (non-Docker) mode:
+    # preflight (U1) → bootstrap Hive-owned deps (U2) → ensure the daemon is
+    # installed on the SAME binary as the CLI and the project enrolled →
+    # ensure the web UI is installed/reachable at http://127.0.0.1:4567 →
+    # print status plus any external-CLI fix commands.
+    #
+    # Exit code contract:
+    #   * Hard-blocking failures (Ruby too old, a refused non-loopback bind,
+    #     a web bundle that will not install) exit non-zero with NO partial
+    #     mutation past the failing gate.
+    #   * External agent CLIs that are missing/unauthenticated are reported as
+    #     actionable WARNINGS and exit 0 — Hive diagnoses, never silently
+    #     installs or authenticates them.
+    #   * Re-running converges: the underlying installers are idempotent and
+    #     do not clobber hand-edited units without --force.
+    class Setup
+      SCHEMA = "hive-setup.v1".freeze
+      DEFAULT_BIND = "127.0.0.1".freeze
+      DEFAULT_PORT = 4567
+
+      def initialize(project: nil, bind: nil, port: nil, no_web_service: false,
+                     unsafe: false, json: false, output: $stdout,
+                     preflight: nil, qmd: nil, bundle: nil,
+                     daemon_runner: nil, web_runner: nil)
+        @project = project
+        @bind = bind
+        @port = port
+        @no_web_service = no_web_service
+        @unsafe = unsafe
+        @json = json
+        @output = output
+        @preflight = preflight
+        @qmd = qmd
+        @bundle = bundle
+        @daemon_runner = daemon_runner
+        @web_runner = web_runner
+        @steps = []
+        @warnings = []
+      end
+
+      def call
+        cfg = load_web_config
+        effective_bind = @bind || cfg.fetch("bind", DEFAULT_BIND)
+
+        # Gate 1 (no mutation before this): a refused non-loopback bind.
+        assert_bind_allowed!(effective_bind, cfg)
+
+        # Gate 2 (no mutation): preflight. A too-old Ruby is a hard stop.
+        preflight = @preflight || Hive::LocalPreflight.new
+        record_preflight(preflight)
+        assert_ruby_ok!(preflight)
+
+        # Mutating steps — each records a structured result the envelope
+        # aggregates. Hive-owned deps first, then daemon, then web.
+        bootstrap_qmd
+        bootstrap_web_bundle
+        ensure_daemon
+        ensure_web(effective_bind)
+
+        emit
+        raise Hive::Error, "hive setup: completed with blocking failures" unless ok?
+      end
+
+      private
+
+      def load_web_config
+        Hive::Config.load_global_web
+      rescue Hive::Error
+        { "bind" => DEFAULT_BIND, "port" => DEFAULT_PORT, "github" => {} }
+      end
+
+      # ── gates ──────────────────────────────────────────────────────────
+
+      def assert_bind_allowed!(bind, cfg)
+        return if loopback?(bind)
+        return if @unsafe
+        return if env_public_bind_allowed?
+        return if owner_configured?(cfg)
+
+        raise Hive::Error,
+              "hive setup: refusing to configure a non-loopback bind (#{bind}) without an auth/owner " \
+              "flow. Configure the GitHub owner/device-flow claim, or re-run with --unsafe. The default " \
+              "bind is 127.0.0.1 (loopback), which needs no auth."
+      end
+
+      def assert_ruby_ok!(preflight)
+        ruby = preflight.rows.find { |r| r[:key] == "ruby" }
+        return unless ruby && ruby[:status] == "version_too_old"
+
+        # Emit whatever we have (preflight only — nothing mutated) then fail.
+        @output.puts JSON.generate(envelope) if @json
+        unless @json
+          @output.puts "hive setup: #{ruby[:message]}"
+        end
+        raise Hive::Error, "hive setup: #{ruby[:message]}"
+      end
+
+      # ── steps ──────────────────────────────────────────────────────────
+
+      def record_preflight(preflight)
+        env = preflight.envelope
+        # Preflight itself is informational: it always "runs". The only
+        # preflight condition that hard-fails setup is a too-old Ruby, gated
+        # separately in assert_ruby_ok!. Every other required gap (external
+        # agent CLIs, git/node/npm) is surfaced as an actionable warning so
+        # automation continues — Hive diagnoses, it does not silently fix.
+        @steps << { "step" => "preflight", "ok" => true, "envelope_ok" => env["ok"],
+                    "summary" => env["summary"] }
+        preflight.rows.each do |row|
+          next if row[:key] == "ruby" # ruby is the hard gate, not a warning
+          next unless row[:required] && %w[missing version_too_old].include?(row[:status])
+
+          hint = row[:fix_command] ? " — #{row[:fix_command]}" : ""
+          @warnings << "#{row[:key]} is #{row[:status]}#{hint}"
+        end
+      end
+
+      def bootstrap_qmd
+        qmd = @qmd || begin
+          require "hive/qmd_bootstrap"
+          Hive::QmdBootstrap.new
+        end
+        result = qmd.ensure!
+        @steps << { "step" => "qmd", "ok" => result.kind != :failed, "outcome" => result.kind.to_s,
+                    "message" => result.message }
+        @warnings << "qmd: #{result.message}" if %i[failed skipped_no_npm].include?(result.kind)
+      rescue StandardError => e
+        @steps << { "step" => "qmd", "ok" => false, "outcome" => "error", "message" => e.message }
+        @warnings << "qmd bootstrap error: #{e.message}"
+      end
+
+      def bootstrap_web_bundle
+        bundle = @bundle || begin
+          require "hive/web/bundle_installer"
+          Hive::Web::BundleInstaller.new
+        end
+        # Gem-only install (no web/) → nothing to bootstrap, not a failure.
+        if bundle.respond_to?(:app_dir) && bundle.app_dir.nil?
+          @steps << { "step" => "web_bundle", "ok" => true, "outcome" => "skipped_no_web_app",
+                      "message" => "no web/ app on this install; skipping bundle bootstrap" }
+          return
+        end
+
+        result = bundle.install!
+        @steps << { "step" => "web_bundle", "ok" => true, "outcome" => result.bundle.to_s,
+                    "message" => "web bundle #{result.bundle}, db #{result.db}" }
+      rescue Hive::Error => e
+        # A web bundle that will not install is a hard blocker for web mode.
+        @steps << { "step" => "web_bundle", "ok" => false, "outcome" => "failed", "message" => e.message }
+      end
+
+      def ensure_daemon
+        runner = @daemon_runner || method(:default_daemon_runner)
+        install = runner.call(:install)
+        @steps << { "step" => "daemon_install", "ok" => install[:ok], "outcome" => install[:outcome],
+                    "message" => install[:message] }
+        @warnings << "daemon: #{install[:message]}" if install[:outcome] == "drifted"
+
+        target = enable_target
+        enable = runner.call(:enable, target)
+        @steps << { "step" => "daemon_enable", "ok" => enable[:ok], "outcome" => enable[:outcome],
+                    "message" => enable[:message] }
+      end
+
+      def ensure_web(bind)
+        if @no_web_service
+          cmd = [ "hive", "web" ]
+          cmd += [ "--bind", bind ] if @bind
+          cmd += [ "--port", @port.to_s ] if @port
+          @steps << { "step" => "web", "ok" => true, "outcome" => "foreground",
+                      "message" => "run the web UI in the foreground: #{cmd.join(' ')}" }
+          return
+        end
+
+        runner = @web_runner || method(:default_web_runner)
+        install = runner.call(:install)
+        @steps << { "step" => "web_install", "ok" => install[:ok], "outcome" => install[:outcome],
+                    "message" => install[:message] }
+        start = runner.call(:start)
+        @steps << { "step" => "web_start", "ok" => start[:ok], "outcome" => start[:outcome],
+                    "message" => start[:message] }
+      end
+
+      def enable_target
+        return @project if @project && !@project.to_s.strip.empty?
+
+        entry = Hive::Config.project_for_path(Dir.pwd)
+        entry && entry["name"]
+      rescue StandardError
+        @project
+      end
+
+      # ── default runners (call the real commands) ────────────────────────
+
+      def default_daemon_runner(subcommand, target = nil)
+        require "hive/commands/daemon"
+        case subcommand
+        when :install
+          Hive::Commands::Daemon.new("install", force: false).call
+          { ok: true, outcome: "installed", message: "daemon unit installed on the CLI's binary" }
+        when :enable
+          unless target
+            return { ok: false, outcome: "no_project",
+                     message: "no project to enroll (run from a hive repo or pass --project NAME)" }
+          end
+          Hive::Commands::Daemon.new("enable", target).call
+          { ok: true, outcome: "enabled", message: "project #{target} enrolled (daemon.enabled: true)" }
+        end
+      rescue Hive::DaemonInstallDriftError => e
+        { ok: true, outcome: "drifted", message: e.message }
+      rescue Hive::Error => e
+        { ok: false, outcome: "failed", message: e.message }
+      end
+
+      def default_web_runner(subcommand)
+        require "hive/commands/web"
+        args = { bind: @bind, port: @port, unsafe: @unsafe }
+        case subcommand
+        when :install
+          Hive::Commands::Web.new("install", force: false, **args).call
+          { ok: true, outcome: "installed", message: "web service unit installed" }
+        when :start
+          Hive::Commands::Web.new("start", **args).call
+          { ok: true, outcome: "started", message: "web service started (http://#{@bind || DEFAULT_BIND}:#{@port || DEFAULT_PORT})" }
+        end
+      rescue Hive::DaemonInstallDriftError => e
+        { ok: true, outcome: "drifted", message: e.message }
+      rescue Hive::Error => e
+        { ok: false, outcome: "failed", message: e.message }
+      end
+
+      # ── loopback / owner helpers (mirror the U4 web guard) ──────────────
+
+      def loopback?(bind)
+        b = bind.to_s.strip.downcase
+        b.empty? || %w[localhost ::1 [::1]].include?(b) || b.start_with?("127.")
+      end
+
+      def env_public_bind_allowed?
+        v = ENV["HIVE_WEB_ALLOW_PUBLIC_BIND"].to_s.strip.downcase
+        !v.empty? && !%w[0 false no off].include?(v)
+      end
+
+      def owner_configured?(cfg)
+        github = cfg["github"]
+        github.is_a?(Hash) && !github["owner"].to_s.strip.empty?
+      end
+
+      # ── output ──────────────────────────────────────────────────────────
+
+      def ok?
+        @steps.all? { |s| s["ok"] }
+      end
+
+      def envelope
+        {
+          "schema" => SCHEMA,
+          "ok" => ok?,
+          "steps" => @steps,
+          "warnings" => @warnings
+        }
+      end
+
+      def emit
+        if @json
+          @output.puts JSON.generate(envelope)
+          return
+        end
+
+        @steps.each do |s|
+          mark = s["ok"] ? "✓" : "✗"
+          @output.puts "#{mark} #{s['step']}: #{s['message'] || s['outcome']}"
+        end
+        unless @warnings.empty?
+          @output.puts ""
+          @output.puts "Action needed (Hive will not do these for you):"
+          @warnings.each { |w| @output.puts "  ! #{w}" }
+        end
+        @output.puts ""
+        @output.puts(ok? ? "hive setup: local mode is ready." : "hive setup: finished with blocking failures (see ✗ above).")
+      end
+    end
+  end
+end
