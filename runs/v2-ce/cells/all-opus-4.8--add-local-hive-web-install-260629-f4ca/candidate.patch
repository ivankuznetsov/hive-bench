diff --git a/lib/hive/commands/web/service_installer.rb b/lib/hive/commands/web/service_installer.rb
new file mode 100644
index 00000000..720cbdc8
--- /dev/null
+++ b/lib/hive/commands/web/service_installer.rb
@@ -0,0 +1,99 @@
+require "cgi"
+require "shellwords"
+require "hive/commands/service_installer/base"
+
+module Hive
+  module Commands
+    class Web
+      # Per-user autostart installer for the Hive web UI. A third subclass of
+      # the shared ServiceInstaller::Base pattern (alongside daemon and bot):
+      # inherits drift/backup, atomic write, shim-PATH detection, force
+      # semantics, platform detection, and resolved_binary, and supplies only
+      # the web service's identity and rendered unit/plist bodies.
+      #
+      # The web and daemon are DISTINCT services — installing one never
+      # touches the other's unit. ExecStart runs `hive web` (foreground);
+      # `hive web` itself reads bind/port/origin from global config, but an
+      # explicit bind/port passed here is baked into ExecStart so a
+      # setup-time override survives into the managed unit.
+      class ServiceInstaller < Hive::Commands::ServiceInstaller::Base
+        def initialize(bind: nil, port: nil, **kwargs)
+          super(**kwargs)
+          @bind = bind
+          @port = port
+        end
+
+        def service_name
+          "hive-web"
+        end
+
+        def cli_label
+          "web"
+        end
+
+        def service_noun
+          "web service"
+        end
+
+        def unit_noun
+          "web unit"
+        end
+
+        def target_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/local.hive-web.plist")
+          when :linux then File.join(@home, ".config/systemd/user/hive-web.service")
+          end
+        end
+
+        private
+
+        # The `hive web ...` argv baked into ExecStart / ProgramArguments,
+        # after the resolved binary. Bare `web` when no override; otherwise
+        # `web --bind X --port Y` so a setup-time bind/port persists.
+        def web_argv
+          argv = %w[web]
+          argv += [ "--bind", @bind.to_s ] if @bind
+          argv += [ "--port", @port.to_s ] if @port
+          argv
+        end
+
+        def render_systemd
+          template = File.read(File.expand_path("../../../../examples/systemd/hive-web.service", __dir__))
+          escaped = Shellwords.escape(resolved_binary)
+          exec_args = web_argv.map { |a| Shellwords.escape(a) }.join(" ")
+          template
+            .sub(/^ExecStart=.*$/, "ExecStart=#{escaped} #{exec_args}")
+            .sub(/^Environment=PATH=.*$/, build_path_line)
+        end
+
+        def render_launchd
+          template = File.read(File.expand_path("../../../../examples/launchd/local.hive-web.plist", __dir__))
+          binary = resolved_binary
+          binary_dir = File.dirname(binary)
+          escaped_binary = CGI.escapeHTML(binary)
+          escaped_binary_dir = CGI.escapeHTML(binary_dir)
+          escaped_home = CGI.escapeHTML(@home)
+          rendered = template
+            .gsub(%r{<string>/Users/YOU/\.local/bin/hive</string>}, "<string>#{escaped_binary}</string>")
+            .gsub("/Users/YOU/Library/Logs", "#{escaped_home}/Library/Logs")
+            .gsub("/Users/YOU/.local/bin", escaped_binary_dir)
+          inject_launchd_web_args(rendered)
+        end
+
+        # Insert extra `web` arguments (--bind/--port) into ProgramArguments
+        # after the baked `<string>web</string>` line, HTML-escaped for plist
+        # XML safety. No-op when only bare `web` is used.
+        def inject_launchd_web_args(rendered)
+          extra = web_argv[1..] || []
+          return rendered if extra.empty?
+
+          strings = extra.map { |a| "    <string>#{CGI.escapeHTML(a)}</string>" }.join("\n")
+          rendered.sub(%r{^(\s*)<string>web</string>$}) do
+            "#{Regexp.last_match(1)}<string>web</string>\n#{strings}"
+          end
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon_consistency.rb b/lib/hive/daemon_consistency.rb
new file mode 100644
index 00000000..5d635abc
--- /dev/null
+++ b/lib/hive/daemon_consistency.rb
@@ -0,0 +1,135 @@
+require "shellwords"
+
+require "hive"
+
+module Hive
+  # Verifies that the installed daemon unit points at the SAME binary the CLI
+  # resolves to, and (when a running-daemon version is known) that the running
+  # daemon is not on stale code. Used by `hive setup` and surfaced in the web
+  # UI as a drift banner with a repair action.
+  #
+  # Classification (closed set):
+  #   :not_installed — no unit file on disk.
+  #   :drifted       — the unit's ExecStart binary differs from the CLI's
+  #                    resolved binary (compared by realpath, not raw path,
+  #                    so symlinks don't false-positive).
+  #   :stale         — unit binary matches but the running daemon reports a
+  #                    different version than the CLI (old code still running).
+  #   :ok            — unit binary matches and (if known) versions agree.
+  #   :unknown       — cannot determine (unreadable unit, unresolvable CLI
+  #                    binary). Deliberately NOT :drifted, per the plan.
+  class DaemonConsistency
+    Result = Struct.new(:status, :cli_binary, :unit_binary, :unit_path,
+                        :cli_version, :running_version, :message, keyword_init: true) do
+      def ok?
+        status == :ok
+      end
+
+      def repairable?
+        %i[drifted stale not_installed].include?(status)
+      end
+
+      def to_h
+        {
+          "status" => status.to_s,
+          "cli_binary" => cli_binary,
+          "unit_binary" => unit_binary,
+          "unit_path" => unit_path,
+          "cli_version" => cli_version,
+          "running_version" => running_version,
+          "repairable" => repairable?,
+          "message" => message
+        }
+      end
+    end
+
+    # `installer` supplies the CLI's target binary + the unit path (defaults
+    # to the daemon ServiceInstaller). `running_version` is the version the
+    # live daemon reports (nil = unknown; skips the stale check). All inputs
+    # are injectable so unit tests drive every branch without a real unit.
+    def initialize(installer: nil, running_version: nil, cli_version: Hive::VERSION)
+      @installer = installer || default_installer
+      @running_version = running_version
+      @cli_version = cli_version
+    end
+
+    def call
+      cli_binary = safe(-> { @installer.target_binary })
+      unit_path = safe(-> { @installer.target_path })
+
+      if cli_binary.nil?
+        return result(:unknown, cli_binary: nil, unit_path: unit_path,
+                      message: "cannot resolve the CLI's hive binary; skipping drift check")
+      end
+
+      if unit_path.nil? || !File.exist?(unit_path)
+        return result(:not_installed, cli_binary: cli_binary, unit_path: unit_path,
+                      message: "no daemon unit installed; run `hive daemon install`")
+      end
+
+      unit_binary = extract_unit_binary(File.read(unit_path))
+      if unit_binary.nil?
+        return result(:unknown, cli_binary: cli_binary, unit_path: unit_path,
+                      message: "could not parse the unit's ExecStart binary at #{unit_path}")
+      end
+
+      unless same_path?(unit_binary, cli_binary)
+        return result(:drifted, cli_binary: cli_binary, unit_binary: unit_binary, unit_path: unit_path,
+                      message: "daemon unit at #{unit_path} runs #{unit_binary}, but the CLI resolves to " \
+                               "#{cli_binary}. Repair with `hive daemon install --force`.")
+      end
+
+      if @running_version && @running_version.to_s != @cli_version.to_s
+        return result(:stale, cli_binary: cli_binary, unit_binary: unit_binary, unit_path: unit_path,
+                      message: "the running daemon reports version #{@running_version} but the CLI is " \
+                               "#{@cli_version}; restart it with `hive daemon install --force`.")
+      end
+
+      result(:ok, cli_binary: cli_binary, unit_binary: unit_binary, unit_path: unit_path,
+             message: "daemon unit binary matches the CLI (#{cli_binary})")
+    end
+
+    private
+
+    def result(status, **fields)
+      Result.new(status: status, cli_version: @cli_version, running_version: @running_version, **fields)
+    end
+
+    def default_installer
+      require "hive/commands/daemon/service_installer"
+      require "hive/invoked_binary"
+      Hive::Commands::Daemon::ServiceInstaller.new(binary_path: Hive::InvokedBinary.path)
+    end
+
+    # Pull the hive binary out of a systemd ExecStart= line or a launchd
+    # ProgramArguments array. Best-effort across both formats.
+    def extract_unit_binary(text)
+      if (exec = text[/^ExecStart=(.+)$/, 1])
+        tokens = Shellwords.split(exec) rescue exec.split
+        return tokens.first
+      end
+
+      # launchd: the first <string> that names an absolute path to a hive
+      # binary (skipping /bin/sh, -c, and the precheck wrapper script).
+      text.scan(%r{<string>([^<]+)</string>}).flatten.find do |s|
+        s.start_with?("/") && %w[hive hv].include?(File.basename(s))
+      end
+    end
+
+    def same_path?(a, b)
+      real(a) == real(b)
+    end
+
+    def real(path)
+      File.realpath(path)
+    rescue SystemCallError
+      File.expand_path(path)
+    end
+
+    def safe(callable)
+      callable.call
+    rescue StandardError
+      nil
+    end
+  end
+end
diff --git a/lib/hive/local_preflight.rb b/lib/hive/local_preflight.rb
new file mode 100644
index 00000000..7ff58eee
--- /dev/null
+++ b/lib/hive/local_preflight.rb
@@ -0,0 +1,310 @@
+require "open3"
+require "timeout"
+require "rbconfig"
+
+require "hive/paths"
+
+module Hive
+  # Reusable preflight for the local (non-Docker) web/daemon mode. Verifies
+  # every prerequisite Hive needs to boot the web UI and daemon against the
+  # user's real XDG/home state and emits Doctor-style rows plus a
+  # `hive-local-preflight.v1` JSON envelope.
+  #
+  # Two classes of dependency:
+  #
+  #   * Hive-owned (qmd, the web/ Rails bundle) — Hive may bootstrap these
+  #     itself (see Hive::Web::BundleInstaller / Hive::QmdBootstrap). Rows
+  #     carry `fixable_by_hive: true`.
+  #   * External agent CLIs (gh, claude, codex) — Hive NEVER installs or
+  #     authenticates these. It diagnoses their absence and emits the exact
+  #     fix command the operator must run themselves. Rows carry
+  #     `fixable_by_hive: false` and a populated `fix_command`.
+  #
+  # The checker is side-effect free apart from cheap, non-mutating version
+  # probes (`<bin> --version`). It never shells out to install or log in.
+  class LocalPreflight
+    SCHEMA = "hive-local-preflight.v1".freeze
+
+    MIN_RUBY = "3.4".freeze
+    MIN_TMUX = "3.0".freeze
+
+    # Statuses that make the overall preflight fail (a required dependency is
+    # absent or too old). `warning` / `present` / `not_applicable` do not.
+    FAILING = %w[missing version_too_old].freeze
+
+    # A probe result carrier so tests can inject a spy and assert the checker
+    # never spawns an install/login. `argv` is the full command line the
+    # checker ran; `stdout` and `ok` are the captured result.
+    Probe = Struct.new(:stdout, :ok, keyword_init: true)
+
+    # `which` and `probe` are injectable so unit tests can drive every branch
+    # without a real PATH or subprocesses. `ruby_version` defaults to the
+    # running interpreter; `web_app_dir` mirrors Hive::Commands::Web's
+    # resolution; `bundle_checker` returns true when the web bundle is
+    # satisfied (defaults to a real `bundle check`).
+    def initialize(which: nil, probe: nil, ruby_version: RUBY_VERSION,
+                   web_app_dir: nil, qmd_locator: nil, bundle_checker: nil,
+                   host_os: RbConfig::CONFIG["host_os"])
+      @which = which || method(:default_which)
+      @probe = probe || method(:default_probe)
+      @ruby_version = ruby_version
+      @web_app_dir = web_app_dir == :unset ? nil : (web_app_dir || default_web_app_dir)
+      @qmd_locator = qmd_locator || method(:default_qmd_locator)
+      @bundle_checker = bundle_checker || method(:real_bundle_check)
+      @host_os = host_os
+      @rows = nil
+    end
+
+    # Ordered list of probe rows. Cached after the first call.
+    def rows
+      @rows ||= [
+        ruby_row,
+        binary_row(key: "git", label: "git", fix_command: nil,
+                   fixable_by_hive: false, required: true),
+        tmux_row,
+        external_cli_row(key: "gh", fix_command: "gh auth login"),
+        external_cli_row(key: "claude", fix_command: "claude setup-token"),
+        external_cli_row(key: "codex", fix_command: "codex login --device-auth"),
+        binary_row(key: "node", label: "node", fix_command: nil,
+                   fixable_by_hive: false, required: true),
+        binary_row(key: "npm", label: "npm", fix_command: nil,
+                   fixable_by_hive: false, required: true),
+        qmd_row,
+        web_bundle_row,
+        sqlite_row
+      ]
+    end
+
+    # True when every required dependency is present (and new enough).
+    def ok?
+      rows.none? { |r| r[:required] && FAILING.include?(r[:status]) }
+    end
+
+    def envelope
+      {
+        "schema" => SCHEMA,
+        "ok" => ok?,
+        "checks" => rows,
+        "summary" => summary
+      }
+    end
+
+    def summary
+      {
+        "present" => rows.count { |r| r[:status] == "present" },
+        "missing" => rows.count { |r| r[:status] == "missing" },
+        "version_too_old" => rows.count { |r| r[:status] == "version_too_old" },
+        "warning" => rows.count { |r| r[:status] == "warning" },
+        "not_applicable" => rows.count { |r| r[:status] == "not_applicable" }
+      }
+    end
+
+    private
+
+    def row(key:, kind:, status:, required:, fixable_by_hive:, message:, fix_command: nil)
+      {
+        key: key,
+        kind: kind,
+        status: status,
+        required: required,
+        fixable_by_hive: fixable_by_hive,
+        message: message,
+        fix_command: fix_command
+      }
+    end
+
+    def ruby_row
+      if version_ge?(@ruby_version, MIN_RUBY)
+        row(key: "ruby", kind: "runtime", status: "present", required: true,
+            fixable_by_hive: false,
+            message: "Ruby #{@ruby_version} (>= #{MIN_RUBY})")
+      else
+        row(key: "ruby", kind: "runtime", status: "version_too_old", required: true,
+            fixable_by_hive: false,
+            message: "Ruby #{@ruby_version} is below the required #{MIN_RUBY}; " \
+                     "install Ruby #{MIN_RUBY}+ (rbenv/mise/asdf install #{MIN_RUBY}) and re-run",
+            fix_command: nil)
+      end
+    end
+
+    def tmux_row
+      path = @which.call("tmux")
+      unless path
+        return row(key: "tmux", kind: "dependency", status: "missing", required: true,
+                   fixable_by_hive: false,
+                   message: "tmux not found on PATH; install tmux >= #{MIN_TMUX}",
+                   fix_command: nil)
+      end
+
+      version = probe_version(path, "-V")
+      if version && !version_ge?(version, MIN_TMUX)
+        row(key: "tmux", kind: "dependency", status: "version_too_old", required: true,
+            fixable_by_hive: false,
+            message: "tmux #{version} at #{path} is below the required #{MIN_TMUX}")
+      else
+        row(key: "tmux", kind: "dependency", status: "present", required: true,
+            fixable_by_hive: false,
+            message: [ path, version ].compact.join(" "))
+      end
+    end
+
+    # git/node/npm — a required binary Hive does not own and does not install;
+    # its absence is a hard, operator-fixable gap with no canned command.
+    def binary_row(key:, label:, fix_command:, fixable_by_hive:, required:)
+      path = @which.call(key)
+      if path
+        version = probe_version(path, "--version")
+        row(key: key, kind: "dependency", status: "present", required: required,
+            fixable_by_hive: fixable_by_hive,
+            message: [ path, version ].compact.join(" "))
+      else
+        row(key: key, kind: "dependency", status: "missing", required: required,
+            fixable_by_hive: fixable_by_hive,
+            message: "#{label} not found on PATH",
+            fix_command: fix_command)
+      end
+    end
+
+    # External agent CLI: presence only, never a login/install probe. When
+    # missing we emit the exact command the operator must run themselves.
+    def external_cli_row(key:, fix_command:)
+      path = @which.call(key)
+      if path
+        row(key: key, kind: "agent_cli", status: "present", required: true,
+            fixable_by_hive: false,
+            message: "#{path} (authenticate separately with `#{fix_command}` if not already signed in)",
+            fix_command: fix_command)
+      else
+        row(key: key, kind: "agent_cli", status: "missing", required: true,
+            fixable_by_hive: false,
+            message: "#{key} not found on PATH; Hive will not install or authenticate it for you — " \
+                     "install it, then run `#{fix_command}`",
+            fix_command: fix_command)
+      end
+    end
+
+    def qmd_row
+      qmd = @qmd_locator.call
+      if qmd
+        row(key: "qmd", kind: "dependency", status: "present", required: false,
+            fixable_by_hive: true,
+            message: "#{qmd} (Hive-managed llm-wiki search tool)")
+      else
+        row(key: "qmd", kind: "dependency", status: "missing", required: false,
+            fixable_by_hive: true,
+            message: "qmd not found; Hive can bootstrap it (needs Node.js/npm) via `hive setup`",
+            fix_command: "hive setup")
+      end
+    end
+
+    def web_bundle_row
+      unless @web_app_dir
+        return row(key: "web_bundle", kind: "dependency", status: "not_applicable", required: false,
+                   fixable_by_hive: true,
+                   message: "the web/ Rails app was not found (gem-only install); " \
+                            "run from a source checkout or set HIVEBOX_WEB_APP_DIR to manage the web UI")
+      end
+
+      if @bundle_checker.call(@web_app_dir)
+        row(key: "web_bundle", kind: "dependency", status: "present", required: true,
+            fixable_by_hive: true,
+            message: "web/ Rails bundle is installed (#{@web_app_dir})")
+      else
+        row(key: "web_bundle", kind: "dependency", status: "missing", required: true,
+            fixable_by_hive: true,
+            message: "web/ Rails bundle is not installed; Hive can bootstrap it via `hive setup`",
+            fix_command: "hive setup")
+      end
+    end
+
+    def sqlite_row
+      path = @which.call("sqlite3")
+      if path
+        version = probe_version(path, "--version")
+        row(key: "sqlite3", kind: "dependency", status: "present", required: false,
+            fixable_by_hive: false,
+            message: [ path, version ].compact.join(" "))
+      else
+        # The Rails app links the sqlite3 gem's bundled libsqlite, so a
+        # missing `sqlite3` CLI is a warning (handy for inspection) rather
+        # than a hard block.
+        row(key: "sqlite3", kind: "dependency", status: "warning", required: false,
+            fixable_by_hive: false,
+            message: "the sqlite3 CLI is not on PATH; the web bundle ships its own SQLite so this is " \
+                     "informational, but install sqlite3 for manual DB inspection")
+      end
+    end
+
+    # ── defaults (injectable) ──────────────────────────────────────────
+
+    def default_which(name)
+      ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+        candidate = File.join(dir, name)
+        return candidate if File.file?(candidate) && File.executable?(candidate)
+      end
+      nil
+    end
+
+    def default_probe(argv)
+      out, _err, status = Timeout.timeout(10) { Open3.capture3(*argv) }
+      Probe.new(stdout: out.to_s, ok: status.success?)
+    rescue Timeout::Error, SystemCallError
+      Probe.new(stdout: "", ok: false)
+    end
+
+    def probe_version(path, flag)
+      result = @probe.call([ path, flag ])
+      return nil unless result&.ok
+
+      result.stdout.to_s.lines.first.to_s.strip[/\d+\.\d+(\.\d+)?/]
+    end
+
+    def default_web_app_dir
+      candidates = [
+        ENV["HIVEBOX_WEB_APP_DIR"],
+        File.expand_path("../../web", __dir__)
+      ].compact
+      candidates.find { |dir| File.file?(File.join(dir, "config", "application.rb")) }
+    end
+
+    # Mirrors Hive::Commands::Doctor#find_qmd (HIVE_QMD_BIN → PATH →
+    # data_home/qmd/bin/qmd) so the two locators agree on where a
+    # Hive-managed qmd lives.
+    def default_qmd_locator
+      env_qmd = ENV["HIVE_QMD_BIN"].to_s
+      return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+      path_qmd = @which.call("qmd")
+      return path_qmd if path_qmd
+
+      candidate = File.join(Hive::Paths.data_home, "qmd", "bin", "qmd")
+      return candidate if File.file?(candidate) && File.executable?(candidate)
+
+      nil
+    end
+
+    # The web-bundle check needs a BUNDLE_GEMFILE env, which the injectable
+    # probe signature ([path, flag]) does not carry, so it runs Open3 with an
+    # env hash directly instead of routing through @probe. Tests inject a
+    # `bundle_checker:` to drive the present/missing branches deterministically.
+    def real_bundle_check(app_dir)
+      _out, _err, status = Timeout.timeout(60) do
+        Open3.capture3({ "BUNDLE_GEMFILE" => File.join(app_dir, "Gemfile") },
+                       "bundle", "check", chdir: app_dir)
+      end
+      status.success?
+    rescue Timeout::Error, SystemCallError
+      false
+    end
+
+    # ── version comparison ─────────────────────────────────────────────
+
+    def version_ge?(actual, minimum)
+      (version_tuple(actual) <=> version_tuple(minimum)) >= 0
+    end
+
+    def version_tuple(version)
+      version.to_s.scan(/\d+/).map(&:to_i)
+    end
+  end
+end
diff --git a/lib/hive/qmd_bootstrap.rb b/lib/hive/qmd_bootstrap.rb
new file mode 100644
index 00000000..e3a8a517
--- /dev/null
+++ b/lib/hive/qmd_bootstrap.rb
@@ -0,0 +1,139 @@
+require "open3"
+require "fileutils"
+require "timeout"
+
+require "hive"
+require "hive/paths"
+
+module Hive
+  # Ruby-callable qmd bootstrap so `hive setup` can provision the
+  # Hive-managed qmd the same way install.sh's install_qmd does: npm
+  # install into data_home/qmd, rebuild the native better-sqlite3 addon,
+  # and symlink it into bin_home. Additive to install.sh (which stays the
+  # source of truth for the shell install path); this no-ops when qmd
+  # already resolves so re-running is safe.
+  class QmdBootstrap
+    NPM_PACKAGE = ENV.fetch("HIVE_QMD_NPM_PACKAGE", "@tobilu/qmd").freeze
+
+    Result = Struct.new(:kind, :qmd_bin, :message, keyword_init: true)
+
+    # `which` and `runner` are injectable so unit tests exercise the
+    # already-present / needs-install / npm-missing branches without touching
+    # the network or the real filesystem.
+    def initialize(data_home: nil, bin_home: nil, which: nil, runner: nil)
+      @data_home = data_home || Hive::Paths.data_home
+      @bin_home = bin_home || Hive::Paths.bin_home
+      @which = which || method(:default_which)
+      @runner = runner || method(:default_runner)
+    end
+
+    # Idempotently ensure qmd is available. Returns a Result whose kind is
+    # one of :already_present, :installed, :skipped_no_npm, :failed.
+    def ensure!
+      if (existing = resolve_qmd)
+        return Result.new(kind: :already_present, qmd_bin: existing,
+                          message: "qmd already available at #{existing}")
+      end
+
+      unless @which.call("npm")
+        return Result.new(kind: :skipped_no_npm, qmd_bin: nil,
+                          message: "qmd not installed: npm was not found on PATH. Install Node.js/npm, " \
+                                   "then re-run `hive setup` (or `hive update`).")
+      end
+
+      install_qmd
+    end
+
+    private
+
+    def qmd_home
+      File.join(@data_home, "qmd")
+    end
+
+    def qmd_bin
+      File.join(qmd_home, "bin", "qmd")
+    end
+
+    def qmd_link
+      File.join(@bin_home, "qmd")
+    end
+
+    def install_qmd
+      FileUtils.mkdir_p(qmd_home)
+      _out, ok = @runner.call("npm", "install", "--global", "--prefix", qmd_home,
+                              "--no-audit", "--no-fund", NPM_PACKAGE)
+      unless ok
+        return Result.new(kind: :failed, qmd_bin: nil,
+                          message: "qmd install failed; rerun `hive update`, or run: " \
+                                   "npm install --global --prefix #{qmd_home} #{NPM_PACKAGE}")
+      end
+
+      # A Node upgrade can leave a stale native build behind; rebuild so the
+      # NODE_MODULE_VERSION mismatch class of failures is repaired. Best
+      # effort — a rebuild failure is not fatal if the addon already loads.
+      @runner.call("npm", "rebuild", "--global", "--prefix", qmd_home, "better-sqlite3")
+
+      unless File.file?(qmd_bin) && File.executable?(qmd_bin)
+        return Result.new(kind: :failed, qmd_bin: nil,
+                          message: "qmd install completed but no executable was found at #{qmd_bin}")
+      end
+
+      link_qmd
+      Result.new(kind: :installed, qmd_bin: qmd_bin,
+                 message: "qmd installed at #{qmd_bin}")
+    end
+
+    # Link data_home/qmd/bin/qmd into bin_home, but never clobber an
+    # unrelated qmd the operator put there (mirrors install.sh's guard).
+    def link_qmd
+      FileUtils.mkdir_p(@bin_home)
+      if File.exist?(qmd_link) || File.symlink?(qmd_link)
+        existing = real(qmd_link)
+        managed = real(qmd_bin)
+        return unless existing == managed || existing.nil?
+      end
+      FileUtils.ln_sf(qmd_bin, qmd_link)
+    rescue SystemCallError
+      # A non-writable bin_home is not fatal — qmd still resolves at its
+      # managed path via HIVE_QMD_BIN / the Doctor locator.
+      nil
+    end
+
+    def real(path)
+      File.realpath(path)
+    rescue SystemCallError
+      nil
+    end
+
+    # HIVE_QMD_BIN → PATH → data_home/qmd/bin/qmd, matching the Doctor and
+    # LocalPreflight locators.
+    def resolve_qmd
+      env_qmd = ENV["HIVE_QMD_BIN"].to_s
+      return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+      path_qmd = @which.call("qmd")
+      return path_qmd if path_qmd
+
+      return qmd_bin if File.file?(qmd_bin) && File.executable?(qmd_bin)
+
+      nil
+    end
+
+    def default_which(name)
+      ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+        candidate = File.join(dir, name)
+        return candidate if File.file?(candidate) && File.executable?(candidate)
+      end
+      nil
+    end
+
+    def default_runner(*argv)
+      out, status = Timeout.timeout(600) { Open3.capture2e(*argv) }
+      [ out.to_s, status.success? ]
+    rescue Timeout::Error => e
+      [ "timed out: #{e.message}", false ]
+    rescue SystemCallError => e
+      [ "could not run #{argv.first}: #{e.message}", false ]
+    end
+  end
+end
diff --git a/lib/hive/web/bundle_installer.rb b/lib/hive/web/bundle_installer.rb
new file mode 100644
index 00000000..064e2095
--- /dev/null
+++ b/lib/hive/web/bundle_installer.rb
@@ -0,0 +1,116 @@
+require "open3"
+require "timeout"
+
+require "hive"
+
+module Hive
+  module Web
+    # Provisions the deps Hive owns so `hive web` can boot locally: the
+    # web/ Rails bundle plus the solid-stack SQLite databases. Idempotent —
+    # a satisfied bundle short-circuits via `bundle check`, and
+    # `bin/rails db:prepare` no-ops when the databases already exist.
+    #
+    # Locates web/ exactly like Hive::Commands::Web (HIVEBOX_WEB_APP_DIR →
+    # web/ next to lib/) and refuses gracefully with a typed Hive::Error
+    # when the app is absent (a gem-only install), rather than crashing.
+    class BundleInstaller
+      # Result carrier so callers (hive setup, tests) can branch on what
+      # actually happened without scraping stdout.
+      Result = Struct.new(:bundle, :db, :app_dir, keyword_init: true) do
+        def ok?
+          %i[installed already_installed].include?(bundle) &&
+            %i[prepared skipped].include?(db)
+        end
+      end
+
+      # `runner` runs [env, *argv, opts] and returns [combined_output, ok].
+      # Injectable so unit tests drive install/check/prepare without real
+      # subprocesses.
+      def initialize(app_dir: nil, runner: nil, bundle_check: nil)
+        @app_dir = app_dir == :unset ? nil : (app_dir || default_app_dir)
+        @runner = runner || method(:default_runner)
+        @bundle_check = bundle_check
+      end
+
+      attr_reader :app_dir
+
+      # Ensure the web bundle and databases are ready. Returns a Result.
+      # Raises Hive::Error when web/ is absent or a step fails.
+      def install!
+        unless @app_dir
+          raise Hive::Error,
+                "hive setup: the hivebox web app (web/) was not found, so its Rails bundle " \
+                "cannot be installed. Run from a source checkout or point HIVEBOX_WEB_APP_DIR " \
+                "at the Rails app (a gem-only install has no web tier)."
+        end
+
+        bundle_kind = ensure_bundle
+        db_kind = ensure_databases
+        Result.new(bundle: bundle_kind, db: db_kind, app_dir: @app_dir)
+      end
+
+      private
+
+      def gemfile
+        File.join(@app_dir, "Gemfile")
+      end
+
+      def env
+        { "BUNDLE_GEMFILE" => gemfile }
+      end
+
+      def ensure_bundle
+        return :already_installed if bundle_satisfied?
+
+        output, ok = @runner.call(env, "bundle", "install", chdir: @app_dir)
+        unless ok
+          raise Hive::Error,
+                "hive setup: `bundle install` failed in #{@app_dir}.\n#{tail(output)}"
+        end
+        :installed
+      end
+
+      def bundle_satisfied?
+        return @bundle_check.call(@app_dir) if @bundle_check
+
+        _output, ok = @runner.call(env, "bundle", "check", chdir: @app_dir)
+        ok
+      end
+
+      def ensure_databases
+        output, ok = @runner.call(env, "bin/rails", "db:prepare", chdir: @app_dir)
+        unless ok
+          raise Hive::Error,
+                "hive setup: `bin/rails db:prepare` failed in #{@app_dir}.\n#{tail(output)}"
+        end
+        :prepared
+      end
+
+      def default_app_dir
+        candidates = [
+          ENV["HIVEBOX_WEB_APP_DIR"],
+          File.expand_path("../../../web", __dir__)
+        ].compact
+        candidates.find { |dir| File.file?(File.join(dir, "config", "application.rb")) }
+      end
+
+      def default_runner(env, *argv, chdir:)
+        out, status = Timeout.timeout(1200) do
+          Open3.capture2e(env, *argv, chdir: chdir)
+        end
+        [ out.to_s, status.success? ]
+      rescue Timeout::Error => e
+        [ "timed out: #{e.message}", false ]
+      rescue SystemCallError => e
+        [ "could not run #{argv.first}: #{e.message}", false ]
+      end
+
+      # Last few lines of combined output, so the typed error carries the
+      # actionable tail (native-gem build error, missing toolchain) without
+      # dumping a full bundle log into the exception message.
+      def tail(output, lines: 15)
+        output.to_s.lines.last(lines).join.strip
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/supervisor.rb b/lib/hive/web/supervisor.rb
index 510a66d4..2a031d12 100644
--- a/lib/hive/web/supervisor.rb
+++ b/lib/hive/web/supervisor.rb
@@ -28,10 +28,18 @@ module Hive
       def run
         had_supervisor_pid = ENV.key?("HIVEBOX_SUPERVISOR_PID")
         previous_supervisor_pid = ENV["HIVEBOX_SUPERVISOR_PID"]
