@@ -0,0 +1,80 @@
+require "test_helper"
+require "hive/web/bundle_installer"
+
+class BundleInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  def stub_app_dir
+    Dir.mktmpdir("hive-webapp") do |dir|
+      FileUtils.mkdir_p(File.join(dir, "config"))
+      File.write(File.join(dir, "config", "application.rb"), "# rails app marker")
+      yield dir
+    end
+  end
+
+  def recording_runner(results)
+    calls = []
+    runner = lambda do |env, *argv, **_opts|
+      calls << argv
+      cmd = argv.join(" ")
+      out, ok = results.fetch(cmd) { [ "", true ] }
