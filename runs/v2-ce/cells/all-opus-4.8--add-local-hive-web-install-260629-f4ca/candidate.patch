--- /dev/null
+++ b/examples/systemd/hive-web.service
@@ -0,0 +1,54 @@
+# Sample systemd-user unit for the Hive web UI (Linux, local non-Docker mode).
+#
+# The web UI is a Rails app under web/; this unit runs `hive web` in the
+# foreground with systemd as the supervisor. It operates on the SAME real
+# XDG/home Hive state as the TUI and the daemon — one source of truth.
+#
+# BEFORE INSTALLING: edit ExecStart= to match where YOUR `hive` binary
+# lives (`which hive`). `hive web install` writes this file for you with
+# ExecStart= and Environment=PATH= already resolved, so prefer that over a
+# manual copy.
+#
+# Install (managed):
+#   hive web install            # writes + enables this unit
+#   hive web start              # start it now
+#   hive web status             # service + running snapshot
+#
+# Install (manual):
+#   mkdir -p ~/.config/systemd/user
+#   cp examples/systemd/hive-web.service ~/.config/systemd/user/
+#   $EDITOR ~/.config/systemd/user/hive-web.service   # confirm ExecStart=
+#   systemctl --user daemon-reload
+#   systemctl --user enable --now hive-web
+#
+# Verify it started (catches a wrong ExecStart= path before StartLimit kicks in):
+#   systemctl --user status hive-web
+#   journalctl --user -u hive-web -n 50
+#
+# The default bind is 127.0.0.1:4567 (loopback, no auth required). Binding a
+# non-loopback address is refused unless a GitHub owner/device-flow is
+# configured or `hive web --unsafe` is used — see wiki/commands/web.md.
+
+[Unit]
+Description=Hive web UI (local mode)
+After=default.target
+# Hard cap on the auto-restart loop so a wrong ExecStart= path fails cleanly
+# instead of respawning forever.
+StartLimitBurst=3
+StartLimitIntervalSec=300
+
+[Service]
+Type=simple
+# systemd user services do NOT inherit your interactive shell's PATH. The
+# gem's bin/hive wrapper's `#!/usr/bin/env ruby` shebang needs a Ruby with
+# the gem's dependencies; `hive web install` detects mise/rbenv/asdf and
+# prepends the matching shim directory automatically.
+Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
+ExecStart=%h/.local/bin/hive web
+Restart=on-failure
+RestartSec=5s
+KillMode=mixed
+TimeoutStopSec=30
+
+[Install]
+WantedBy=default.target
