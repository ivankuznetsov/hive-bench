+require "test_helper"
+
+class DaemonHealthTest < ActionDispatch::IntegrationTest
+  setup do
+    sign_in!
+    @default_runner = DaemonHealthController.repair_runner
+  end
+
+  teardown do
+    DaemonHealthController.repair_runner = @default_runner
+  end
+
+  test "show reports daemon running state and binary-consistency status" do
+    get "/daemon_health"
+    assert_response :success
+    body = response.parsed_body
+    assert body.key?("daemon")
+    assert body["consistency"].key?("status"),
+           "the consistency classification must be surfaced for a drift banner"
+    assert body["consistency"].key?("repairable")
+  end
+
+  test "repair invokes daemon install --force through the seam" do
+    calls = []
+    DaemonHealthController.repair_runner = lambda do |force:|
+      calls << force
+      { "status" => "installed" }
+    end
+
+    post "/daemon_health/repair", headers: { "Accept" => "application/json" }
+    assert_response :success
+    assert_equal [ true ], calls, "repair must run the installer with force: true"
+    assert_equal true, response.parsed_body["ok"]
+  end
+
+  test "a failed repair surfaces the error, not a green result" do
+    DaemonHealthController.repair_runner = ->(force:) { { "status" => "failed", "message" => "boom" } }
+
+    post "/daemon_health/repair", headers: { "Accept" => "application/json" }
+    assert_equal false, response.parsed_body["ok"]
+    assert_match "boom", response.parsed_body.dig("outcome", "message")
+  end
+
+  test "daemon health requires login" do
+    reset!
+    get "/daemon_health"
+    assert_redirected_to login_path
+  end
+end
