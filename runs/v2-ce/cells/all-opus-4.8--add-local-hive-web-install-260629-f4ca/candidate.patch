+require "test_helper"
+require "hive/qmd_bootstrap"
+
+class QmdBootstrapTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_already_present_via_path_is_a_no_op
+    with_env("HIVE_QMD_BIN" => nil) do
+      which = ->(name) { name == "qmd" ? "/usr/bin/qmd" : nil }
+      ran = []
+      runner = ->(*argv) { ran << argv; [ "", true ] }
+      result = Hive::QmdBootstrap.new(which: which, runner: runner).ensure!
+      assert_equal :already_present, result.kind
+      assert_empty ran, "an already-resolvable qmd must not trigger an install"
+    end
+  end
+
+  def test_missing_npm_skips_gracefully
+    with_env("HIVE_QMD_BIN" => nil) do
+      which = ->(_name) { nil } # no qmd, no npm
+      ran = []
+      runner = ->(*argv) { ran << argv; [ "", true ] }
+      result = Hive::QmdBootstrap.new(which: which, runner: runner,
+                                      data_home: Dir.mktmpdir, bin_home: Dir.mktmpdir).ensure!
+      assert_equal :skipped_no_npm, result.kind
+      assert_match(/npm was not found/, result.message)
+      assert_empty ran, "no npm means no install attempt"
+    end
+  end
+
+  def test_installs_when_qmd_missing_but_npm_present
+    with_env("HIVE_QMD_BIN" => nil) do
+      Dir.mktmpdir do |data_home|
+        bin_home = Dir.mktmpdir
+        which = ->(name) { name == "npm" ? "/usr/bin/npm" : nil }
+        ran = []
+        runner = lambda do |*argv|
+          ran << argv
+          # Simulate npm placing the executable on the first install call.
+          if argv[0, 2] == %w[npm install]
+            qmd = File.join(data_home, "qmd", "bin", "qmd")
+            FileUtils.mkdir_p(File.dirname(qmd))
+            File.write(qmd, "#!/bin/sh\n")
+            FileUtils.chmod(0o755, qmd)
+          end
+          [ "", true ]
+        end
+        result = Hive::QmdBootstrap.new(which: which, runner: runner,
+                                        data_home: data_home, bin_home: bin_home).ensure!
+        assert_equal :installed, result.kind
+        assert_includes ran.map { |c| c[0, 2] }, %w[npm install]
+        assert File.symlink?(File.join(bin_home, "qmd")), "installed qmd must be linked into bin_home"
+      end
+    end
+  end
+
+  def test_install_failure_reports_repair_hint
+    with_env("HIVE_QMD_BIN" => nil) do
+      which = ->(name) { name == "npm" ? "/usr/bin/npm" : nil }
+      runner = ->(*_argv) { [ "npm ERR!", false ] }
+      result = Hive::QmdBootstrap.new(which: which, runner: runner,
+                                      data_home: Dir.mktmpdir, bin_home: Dir.mktmpdir).ensure!
+      assert_equal :failed, result.kind
+      assert_match(/hive update/, result.message)
+    end
+  end
+end
