@@ -0,0 +1,66 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+  Sample launchd plist for the Hive web UI (macOS, local non-Docker mode).
+
+  The web UI is a Rails app under web/, served by `hive web`. It shares the
+  SAME real XDG/home Hive state as the TUI and the daemon.
+
+  Install (managed):
+    hive web install            # writes this plist and loads it
+    hive web status             # service + running snapshot
+
+  Install (manual):
+    mkdir -p ~/Library/LaunchAgents
+    cp examples/launchd/local.hive-web.plist ~/Library/LaunchAgents/
+    $EDITOR ~/Library/LaunchAgents/local.hive-web.plist   # confirm absolute paths
+    launchctl load ~/Library/LaunchAgents/local.hive-web.plist
+
+  Note the absolute-path requirement: launchd doesn't read your shell's rc
+  files, so the `hive` binary must be invoked at its real location (run
+  `which hive`). `hive web install` resolves it for you.
+
+  RESPAWN-LOOP CIRCUIT-BREAKER: the /bin/sh wrapper below converts "binary
+  not executable" into a clean exit 0 — which KeepAlive { SuccessfulExit:
+  false } then respects (no respawn). A real crash still exits non-zero
+  through exec and respawns per ThrottleInterval.
+-->
+<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
+  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+<plist version="1.0">
+<dict>
+  <key>Label</key>
+  <string>local.hive-web</string>
+
+  <key>ProgramArguments</key>
+  <array>
+    <string>/bin/sh</string>
+    <string>-c</string>
+    <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+    <string>/Users/YOU/.local/bin/hive</string>
+    <string>web</string>
+  </array>
+
+  <key>RunAtLoad</key>
+  <true/>
+
+  <key>KeepAlive</key>
+  <dict>
+    <key>SuccessfulExit</key>
+    <false/>
+  </dict>
+
+  <key>ThrottleInterval</key>
+  <integer>30</integer>
+
+  <key>StandardOutPath</key>
+  <string>/Users/YOU/Library/Logs/hive-web.out.log</string>
+  <key>StandardErrorPath</key>
+  <string>/Users/YOU/Library/Logs/hive-web.err.log</string>
+
+  <key>EnvironmentVariables</key>
+  <dict>
+    <key>PATH</key>
+    <string>/Users/YOU/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
+  </dict>
+</dict>
+</plist>
