diff --git a/test/unit/commands/setup_test.rb b/test/unit/commands/setup_test.rb
new file mode 100644
index 00000000..aa60a3c5
--- /dev/null
+++ b/test/unit/commands/setup_test.rb
@@ -0,0 +1,160 @@
+require "test_helper"
+require "hive/commands/setup"
+
+class SetupTest < Minitest::Test
+  include HiveTestHelper
+
+  # Preflight double with a controllable row set + envelope.
+  class FakePreflight
+    def initialize(rows)
+      @rows = rows
+    end
+
+    attr_reader :rows
+
+    def envelope
+      { "ok" => rows.all? { |r| !%w[missing version_too_old].include?(r[:status]) || !r[:required] },
+        "summary" => { "present" => rows.count { |r| r[:status] == "present" } } }
+    end
+  end
+
+  def rows(overrides = {})
+    base = {
+      "ruby" => { key: "ruby", kind: "runtime", status: "present", required: true },
+      "gh" => { key: "gh", kind: "agent_cli", status: "present", required: true, fix_command: "gh auth login" },
+      "claude" => { key: "claude", kind: "agent_cli", status: "present", required: true, fix_command: "claude setup-token" }
+    }.merge(overrides)
+    base.values
+  end
+
+  class FakeQmd
+    Res = Struct.new(:kind, :message, keyword_init: true)
+    def initialize(kind) = (@kind = kind)
+    def ensure! = Res.new(kind: @kind, message: "qmd #{@kind}")
+  end
+
+  class FakeBundle
+    def initialize(app_dir: "/app/web", result: nil, error: nil)
+      @app_dir = app_dir
+      @result = result
+      @error = error
+    end
+
+    attr_reader :app_dir
+
+    def install!
+      raise @error if @error
+
+      @result || Struct.new(:bundle, :db).new(:installed, :prepared)
+    end
+  end
+
+  def ok_daemon_runner
+    ->(sub, target = nil) { { ok: true, outcome: sub.to_s, message: "daemon #{sub} #{target}" } }
+  end
+
+  def ok_web_runner
+    ->(sub) { { ok: true, outcome: sub.to_s, message: "web #{sub}" } }
+  end
+
+  def build(**overrides)
+    defaults = {
+      project: "demo",
+      json: true,
+      output: StringIO.new,
+      preflight: FakePreflight.new(rows),
+      qmd: FakeQmd.new(:already_present),
+      bundle: FakeBundle.new,
+      daemon_runner: ok_daemon_runner,
+      web_runner: ok_web_runner
+    }
+    Hive::Commands::Setup.new(**defaults.merge(overrides))
+  end
+
+  def run_json(setup)
+    out = setup.instance_variable_get(:@output)
+    setup.call rescue nil
+    JSON.parse(out.string.lines.last)
+  end
+
+  def test_happy_path_all_present_exits_zero
+    setup = build
+    out = setup.instance_variable_get(:@output)
+    setup.call # must not raise
+    doc = JSON.parse(out.string)
+    assert doc["ok"], "all steps ok must be ok"
+    steps = doc["steps"].map { |s| s["step"] }
+    assert_includes steps, "daemon_install"
+    assert_includes steps, "daemon_enable"
+    assert_includes steps, "web_install"
+    assert_includes steps, "web_start"
+    assert_empty doc["warnings"]
+  end
+
+  def test_missing_external_cli_warns_but_exits_zero
+    missing_gh = rows("gh" => { key: "gh", kind: "agent_cli", status: "missing",
+                                required: true, fix_command: "gh auth login" })
+    setup = build(preflight: FakePreflight.new(missing_gh))
+    out = setup.instance_variable_get(:@output)
+    setup.call # missing external CLI must NOT raise
+    doc = JSON.parse(out.string)
+    assert doc["ok"]
+    assert(doc["warnings"].any? { |w| w.include?("gh auth login") },
+           "the exact fix command must be surfaced as a warning")
+  end
+
+  def test_old_ruby_hard_fails_before_any_mutation
+    old = rows("ruby" => { key: "ruby", kind: "runtime", status: "version_too_old",
+                           required: true, message: "Ruby 3.3 too old" })
+    mutations = []
+    setup = build(
+      preflight: FakePreflight.new(old),
+      daemon_runner: ->(sub, _t = nil) { mutations << sub; { ok: true, outcome: "x", message: "x" } },
+      web_runner: ->(sub) { mutations << sub; { ok: true, outcome: "x", message: "x" } }
+    )
+    assert_raises(Hive::Error) { setup.call }
+    assert_empty mutations, "a too-old Ruby must stop before any daemon/web mutation"
+  end
+
+  def test_non_loopback_bind_without_owner_is_refused
+    setup = build(bind: "0.0.0.0")
+    err = assert_raises(Hive::Error) { setup.call }
+    assert_match(/refusing to configure a non-loopback/, err.message)
+  end
+
+  def test_non_loopback_bind_allowed_with_unsafe
+    setup = build(bind: "0.0.0.0", unsafe: true)
+    setup.call # must not raise
+    assert setup.send(:ok?)
+  end
+
+  def test_web_bundle_failure_is_blocking
+    setup = build(bundle: FakeBundle.new(error: Hive::Error.new("native gem build failed")))
+    out = setup.instance_variable_get(:@output)
+    assert_raises(Hive::Error) { setup.call }
+    doc = JSON.parse(out.string)
+    bundle_step = doc["steps"].find { |s| s["step"] == "web_bundle" }
+    refute bundle_step["ok"], "a failed bundle install must mark the step failed"
+    refute doc["ok"], "a blocking failure must make setup not-ok"
+  end
+
+  def test_no_web_service_prints_foreground_command
+    setup = build(no_web_service: true)
+    out = setup.instance_variable_get(:@output)
+    setup.call
+    doc = JSON.parse(out.string)
+    web = doc["steps"].find { |s| s["step"] == "web" }
+    assert_equal "foreground", web["outcome"]
+    assert_match(/hive web/, web["message"])
+  end
+
+  def test_gem_only_install_skips_bundle
+    setup = build(bundle: FakeBundle.new(app_dir: nil))
+    out = setup.instance_variable_get(:@output)
+    setup.call
+    doc = JSON.parse(out.string)
+    web_bundle = doc["steps"].find { |s| s["step"] == "web_bundle" }
+    assert_equal "skipped_no_web_app", web_bundle["outcome"]
+    assert doc["ok"]
+  end
+end
