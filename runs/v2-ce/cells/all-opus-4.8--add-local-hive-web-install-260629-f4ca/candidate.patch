@@ -0,0 +1,112 @@
+require "test_helper"
+require "hive/daemon_consistency"
+
+class DaemonConsistencyTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeInstaller = Struct.new(:target_binary, :target_path)
+
+  def write_systemd_unit(dir, binary)
+    path = File.join(dir, "hive-daemon.service")
+    File.write(path, <<~UNIT)
+      [Service]
+      ExecStart=#{binary} daemon start
+    UNIT
+    path
+  end
+
+  def test_ok_when_unit_binary_matches_cli
+    Dir.mktmpdir do |dir|
+      bin = File.join(dir, "hive")
+      File.write(bin, "#!/bin/sh\n")
+      unit = write_systemd_unit(dir, bin)
+      installer = FakeInstaller.new(bin, unit)
+      result = Hive::DaemonConsistency.new(installer: installer).call
+      assert_equal :ok, result.status
+      refute result.repairable?
+    end
+  end
+
+  def test_drifted_when_unit_points_elsewhere
+    Dir.mktmpdir do |dir|
+      unit = write_systemd_unit(dir, "/usr/bin/hive")
+      installer = FakeInstaller.new(File.join(dir, ".local/bin/hive"), unit)
+      result = Hive::DaemonConsistency.new(installer: installer).call
+      assert_equal :drifted, result.status
+      assert result.repairable?
+      assert_match(/daemon install --force/, result.message)
+    end
+  end
+
+  def test_not_installed_when_no_unit_file
+    Dir.mktmpdir do |dir|
+      installer = FakeInstaller.new(File.join(dir, "hive"), File.join(dir, "missing.service"))
+      result = Hive::DaemonConsistency.new(installer: installer).call
+      assert_equal :not_installed, result.status
+      assert result.repairable?
+    end
+  end
+
+  def test_stale_when_running_version_differs
+    Dir.mktmpdir do |dir|
+      bin = File.join(dir, "hive")
+      File.write(bin, "#!/bin/sh\n")
+      unit = write_systemd_unit(dir, bin)
+      installer = FakeInstaller.new(bin, unit)
+      result = Hive::DaemonConsistency.new(
+        installer: installer, running_version: "0.0.1-old", cli_version: "9.9.9"
+      ).call
+      assert_equal :stale, result.status
+      assert result.repairable?
+    end
+  end
+
+  def test_unknown_when_cli_binary_unresolvable
+    installer = FakeInstaller.new(nil, "/whatever")
+    result = Hive::DaemonConsistency.new(installer: installer).call
+    assert_equal :unknown, result.status
+    refute result.repairable?, "an undeterminable state must not masquerade as drift"
+  end
+
+  def test_symlinked_binary_is_not_false_drift
+    Dir.mktmpdir do |dir|
+      real = File.join(dir, "hive-real")
+      File.write(real, "#!/bin/sh\n")
+      link = File.join(dir, "hive")
+      File.symlink(real, link)
+      unit = write_systemd_unit(dir, real)      # unit names the real path
+      installer = FakeInstaller.new(link, unit) # CLI resolves via the symlink
+      result = Hive::DaemonConsistency.new(installer: installer).call
+      assert_equal :ok, result.status, "realpath comparison must see symlink and target as equal"
+    end
+  end
+
+  def test_launchd_program_arguments_binary_is_extracted
+    Dir.mktmpdir do |dir|
+      bin = File.join(dir, "hive")
+      File.write(bin, "#!/bin/sh\n")
+      unit = File.join(dir, "local.hive-daemon.plist")
+      File.write(unit, <<~PLIST)
+        <array>
+          <string>/bin/sh</string>
+          <string>-c</string>
+          <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+          <string>#{bin}</string>
+          <string>daemon</string>
+          <string>start</string>
+        </array>
+      PLIST
+      installer = FakeInstaller.new(bin, unit)
+      result = Hive::DaemonConsistency.new(installer: installer).call
+      assert_equal :ok, result.status
+      assert_equal bin, result.unit_binary
+    end
+  end
+
+  def test_to_h_is_wire_friendly
+    installer = FakeInstaller.new(nil, nil)
+    h = Hive::DaemonConsistency.new(installer: installer).call.to_h
+    assert_equal "unknown", h["status"]
+    assert h.key?("repairable")
+  end
+end
