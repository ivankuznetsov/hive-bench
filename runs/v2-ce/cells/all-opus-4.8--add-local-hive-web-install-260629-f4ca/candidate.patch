@@ -0,0 +1,134 @@
+require "test_helper"
+require "hive/local_preflight"
+
+class LocalPreflightTest < Minitest::Test
+  include HiveTestHelper
+
+  # A which/probe pair that resolves every binary and reports a modern
+  # version, so the "all present" baseline needs no per-test wiring.
+  def all_present_which
+    ->(name) { "/usr/bin/#{name}" }
+  end
+
+  def version_probe(map = Hash.new("9.9.9"))
+    lambda do |argv|
+      bin = File.basename(argv.first)
+      Hive::LocalPreflight::Probe.new(stdout: "#{bin} version #{map[bin]}\n", ok: true)
+    end
+  end
+
+  def preflight(**overrides)
+    defaults = {
+      which: all_present_which,
+      probe: version_probe,
+      web_app_dir: :unset,
+      qmd_locator: -> { "/data/qmd/bin/qmd" },
+      bundle_checker: ->(_dir) { true }
+    }
+    Hive::LocalPreflight.new(**defaults.merge(overrides))
+  end
+
+  def find_row(pre, key)
+    pre.rows.find { |r| r[:key] == key }
+  end
+
+  def test_all_present_is_ok_and_envelope_shape
+    pre = preflight(web_app_dir: "/app/web")
+    assert pre.ok?, "all deps present must be ok"
+
+    env = pre.envelope
+    assert_equal "hive-local-preflight.v1", env["schema"]
+    assert env["ok"]
+    assert env["checks"].is_a?(Array)
+    assert env["checks"].any? { |r| r[:key] == "ruby" }
+    # Summary counts add up to the row count.
+    total = env["summary"].values.sum
+    assert_equal env["checks"].length, total
+  end
+
+  def test_missing_external_clis_report_fix_commands_and_stay_unfixable
+    which = ->(name) { %w[gh claude codex].include?(name) ? nil : "/usr/bin/#{name}" }
+    pre = preflight(which: which)
+
+    {
+      "gh" => "gh auth login",
+      "claude" => "claude setup-token",
+      "codex" => "codex login --device-auth"
+    }.each do |key, cmd|
+      r = find_row(pre, key)
+      assert_equal "missing", r[:status], "#{key} must be missing"
+      refute r[:fixable_by_hive], "#{key} must never be Hive-fixable"
+      assert_equal cmd, r[:fix_command], "#{key} must carry its exact fix command"
+    end
+
+    refute pre.ok?, "a missing required agent CLI fails the preflight"
+  end
+
+  # The checker must diagnose external CLIs, never install or authenticate
+  # them. Drive it with a spy probe and assert it never ran an install/login.
+  def test_never_spawns_install_or_login_for_external_clis
+    spawned = []
+    spy = lambda do |argv|
+      spawned << argv
+      Hive::LocalPreflight::Probe.new(stdout: "9.9.9\n", ok: true)
+    end
+    which = ->(_name) { nil } # everything missing — maximally tempting to "fix"
+    Hive::LocalPreflight.new(which: which, probe: spy, web_app_dir: :unset,
+                             qmd_locator: -> { nil }, bundle_checker: ->(_d) { false }).rows
+
+    forbidden = /\b(install|login|setup-token|auth)\b/
+    spawned.each do |argv|
+      joined = argv.flatten.join(" ")
+      refute_match forbidden, joined, "preflight must not spawn install/login: #{joined}"
+    end
+  end
+
+  def test_old_ruby_is_version_too_old
+    pre = preflight(ruby_version: "3.3.5")
+    r = find_row(pre, "ruby")
+    assert_equal "version_too_old", r[:status]
+    refute pre.ok?
+  end
+
+  def test_new_ruby_passes
+    pre = preflight(ruby_version: "3.4.1")
+    assert_equal "present", find_row(pre, "ruby")[:status]
+  end
+
+  def test_missing_qmd_is_fixable_by_hive
+    pre = preflight(qmd_locator: -> { nil })
+    r = find_row(pre, "qmd")
+    assert_equal "missing", r[:status]
+    assert r[:fixable_by_hive]
+    refute r[:required], "qmd is not a hard blocker"
+    # qmd is optional, so its absence alone does not fail the preflight.
+    assert pre.ok?
+  end
+
+  def test_unbundled_web_is_missing_and_fixable
+    pre = preflight(web_app_dir: "/app/web", bundle_checker: ->(_dir) { false })
+    r = find_row(pre, "web_bundle")
+    assert_equal "missing", r[:status]
+    assert r[:fixable_by_hive]
+    refute pre.ok?, "an unbundled web app blocks local web mode"
+  end
+
+  def test_web_bundle_not_applicable_without_app_dir
+    pre = preflight(web_app_dir: :unset)
+    r = find_row(pre, "web_bundle")
+    assert_equal "not_applicable", r[:status]
+    assert pre.ok?, "gem-only install (no web/) must not hard-fail preflight"
+  end
+
+  def test_old_tmux_is_version_too_old
+    pre = preflight(probe: version_probe(Hash.new("9.9.9").merge("tmux" => "2.9")))
+    assert_equal "version_too_old", find_row(pre, "tmux")[:status]
+  end
+
+  def test_missing_sqlite_cli_is_warning_only
+    which = ->(name) { name == "sqlite3" ? nil : "/usr/bin/#{name}" }
+    pre = preflight(which: which)
+    assert_equal "warning", find_row(pre, "sqlite3")[:status]
+    assert pre.ok?, "a missing sqlite3 CLI is informational, not blocking"
+  end
+end
