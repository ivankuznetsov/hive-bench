+require "test_helper"
+require "json"
+require "open3"
+
+class AurPackageTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+
+  def write_release(path, sha: "b" * 64)
+    File.write(path, JSON.generate(
+      version: "0.1.0",
+      assets: [ { target: "x86_64-linux-gnu", sha256: sha } ]
+    ))
+  end
+
+  def render(release_path, output)
+    Open3.capture3("ruby", File.join(ROOT, "packaging/aur/render.rb"), release_path, output)
+  end
+
+  def test_rendered_pkgbuild_and_srcinfo_agree_and_install_receipt
+    with_tmp_dir do |dir|
+      release = File.join(dir, "release.json")
+      output = File.join(dir, "aur")
+      write_release(release)
+      _out, err, status = render(release, output)
+      assert status.success?, err
+      pkgbuild = File.read(File.join(output, "PKGBUILD"))
+      srcinfo = File.read(File.join(output, ".SRCINFO"))
+      assert_includes pkgbuild, "pkgver=0.1.0"
+      assert_includes srcinfo, "\tpkgver = 0.1.0"
+      assert_includes pkgbuild, "b" * 64
+      assert_includes srcinfo, "b" * 64
+      assert_includes pkgbuild, "install -Dm755 \"$root/bin/hv\""
+      assert_includes pkgbuild, '"channel": "aur"'
+      assert_includes pkgbuild, "conflicts=('hive')"
+      refute_match(/ruby|gem install|bundle install/i, pkgbuild)
+
+      _out, verify_err, verify_status = Open3.capture3(
+        "bash", File.join(ROOT, "packaging/verify-channel.sh"), release, output
+      )
+      assert verify_status.success?, verify_err
+    end
+  end
+
+  def test_render_rejects_missing_target_and_invalid_checksum
+    with_tmp_dir do |dir|
+      release = File.join(dir, "release.json")
+      write_release(release, sha: "nope")
+      _out, err, status = render(release, File.join(dir, "out"))
+      refute status.success?
+      assert_match(/invalid Linux checksum/, err)
+      File.write(release, JSON.generate(version: "0.1.0", assets: []))
+      _out, err, status = render(release, File.join(dir, "out"))
+      refute status.success?
+      assert_match(/no x86_64/, err)
+    end
+  end
+
+
+  def test_release_workflow_builds_installed_package_before_aur_push
+    workflow = File.read(File.join(ROOT, ".github/workflows/release.yml"))
+    assert_includes workflow, "makepkg --noconfirm"
+    assert_includes workflow, "namcap PKGBUILD"
+    assert_includes workflow, "pacman -U --noconfirm"
+    assert_includes workflow, "ssh://aur@aur.archlinux.org/hive-bin.git"
+    assert_match(/AUR_SSH_PRIVATE_KEY missing.*incomplete/, workflow)
+  end
+end
