+name: Packer smoke
+
+on:
+  pull_request:
+    paths:
+      - "Gemfile"
+      - "Gemfile.lock"
+      - "bin/**"
+      - "lib/**"
+      - "templates/**"
+      - "schemas/**"
+      - "examples/**"
+      - "packaging/build/**"
+      - "packaging/spike/**"
+      - ".github/workflows/packer-smoke.yml"
+  workflow_dispatch:
+
+permissions:
+  contents: read
+
+jobs:
+  linux:
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 1
+      - name: Resolve the canonical builder definition
+        id: toolchain
+        run: bash packaging/build/toolchain.sh github-output >> "$GITHUB_OUTPUT"
+      - name: Build twice in the pinned official Tebako builder
+        env:
+          HIVE_SOURCE_COMMIT: "${{ github.sha }}"
+        run: |
+          epoch="$(git log -1 --format=%ct)"
+          docker build --file packaging/build/Dockerfile.tebako \
+            --tag "hive-tebako-builder:$GITHUB_SHA" packaging/build
+          for pass in 1 2; do
+            docker run --rm -v "$PWD:/mnt/w" -w /mnt/w \
+              -e SOURCE_DATE_EPOCH="$epoch" -e HIVE_SOURCE_COMMIT \
+              "hive-tebako-builder:$GITHUB_SHA" packaging/build/release.sh x86_64-linux-gnu
+            cp tmp/release/hive-*-x86_64-linux-gnu.tar.gz "/tmp/hive-$pass.tar.gz"
+          done
+          sha256sum /tmp/hive-1.tar.gz /tmp/hive-2.tar.gz
+          cmp /tmp/hive-1.tar.gz /tmp/hive-2.tar.gz
+      - name: Native runtime smoke without Ruby
+        run: |
+          archive="$(ls tmp/release/hive-*-x86_64-linux-gnu.tar.gz)"
+          mkdir extracted
+          tar -xzf "$archive" -C extracted
+          root="$(find extracted -mindepth 1 -maxdepth 1 -type d -name 'hive-*' -print -quit)"
+          packaging/spike/packer-smoke.sh "$root/bin/hive" "$root/share/hive"
+
+  macos:
+    runs-on: macos-15
+    steps:
+      - uses: actions/checkout@v4
+      - name: Resolve the canonical builder definition
+        id: toolchain
+        run: bash packaging/build/toolchain.sh github-output >> "$GITHUB_OUTPUT"
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: ${{ steps.toolchain.outputs.ruby_version }}
+          bundler-cache: true
+      - run: gem install tebako --version "${{ steps.toolchain.outputs.tebako_version }}" --no-document
+      - run: packaging/build/release.sh arm64-darwin
+      - name: Native runtime smoke without Ruby
+        run: |
+          archive="$(ls tmp/release/hive-*-arm64-darwin.tar.gz)"
+          mkdir extracted
+          tar -xzf "$archive" -C extracted
+          root="$(find extracted -mindepth 1 -maxdepth 1 -type d -name 'hive-*' -print -quit)"
+          packaging/spike/packer-smoke.sh "$root/bin/hive" "$root/share/hive"
diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
new file mode 100644
index 00000000..6a326999
--- /dev/null
+++ b/.github/workflows/release.yml
@@ -0,0 +1,251 @@
+name: Canonical release
+
+on:
+  pull_request:
+    paths:
+      - "packaging/**"
+      - "bin/**"
+      - "lib/**"
+      - "templates/**"
+      - "schemas/**"
+      - "examples/**"
+      - ".github/workflows/release.yml"
+  workflow_dispatch:
+  push:
+    tags: ["v[0-9]+.[0-9]+.[0-9]+"]
+
+permissions:
+  contents: read
+
+jobs:
+  build:
+    name: vendored Ruby / ${{ matrix.target }}
+    strategy:
+      fail-fast: true
+      matrix:
+        include:
+          - target: arm64-darwin
+            runner: macos-15
+          - target: x86_64-linux-gnu
+            runner: ubuntu-22.04
+    runs-on: ${{ matrix.runner }}
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+      - name: Resolve the canonical builder definition
+        id: toolchain
+        run: bash packaging/build/toolchain.sh github-output >> "$GITHUB_OUTPUT"
+      - uses: ruby/setup-ruby@v1
+        if: matrix.target == 'arm64-darwin'
+        with:
+          ruby-version: ${{ steps.toolchain.outputs.ruby_version }}
+          bundler-cache: true
+      - name: Validate immutable tag and source version
+        if: startsWith(github.ref, 'refs/tags/')
+        env:
+          TAG: ${{ github.ref_name }}
+        run: |
+          set -euo pipefail
+          version="$(ruby -Ilib -e 'require "hive"; print Hive::VERSION')"
+          test "$TAG" = "v$version"
+          test "$(git rev-list -n 1 "$TAG")" = "$GITHUB_SHA"
+          git tag --verify "$TAG"
+      - name: Build macOS arm64 with pinned Tebako
+        if: matrix.target == 'arm64-darwin'
+        run: |
+          gem install tebako --version "${{ steps.toolchain.outputs.tebako_version }}" --no-document
+          SOURCE_DATE_EPOCH="$(git log -1 --format=%ct)" packaging/build/release.sh arm64-darwin
+      - name: Build Linux at the pinned glibc baseline
+        if: matrix.target == 'x86_64-linux-gnu'
+        run: |
+          docker build --file packaging/build/Dockerfile.tebako \
+            --tag "hive-tebako-builder:$GITHUB_SHA" packaging/build
+          docker run --rm -v "$PWD:/mnt/w" -w /mnt/w \
+            -e SOURCE_DATE_EPOCH="$(git log -1 --format=%ct)" \
+            -e HIVE_SOURCE_COMMIT="$GITHUB_SHA" \
+            "hive-tebako-builder:$GITHUB_SHA" packaging/build/release.sh x86_64-linux-gnu
+      - name: Native runtime smoke with Ruby removed from PATH
+        run: |
+          set -euo pipefail
+          mkdir extracted
+          tar -xzf tmp/release/hive-*-${{ matrix.target }}.tar.gz -C extracted
+          root="$(find extracted -mindepth 1 -maxdepth 1 -type d -name 'hive-*' -print -quit)"
+          packaging/spike/packer-smoke.sh "$root/bin/hive" "$root/share/hive"
+      - uses: actions/upload-artifact@v4
+        with:
+          name: hive-${{ matrix.target }}
+          path: tmp/release/hive-*-${{ matrix.target }}.tar.gz
+          if-no-files-found: error
+
+  finalize:
+    runs-on: ubuntu-22.04
+    needs: build
+    permissions:
+      contents: read
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/download-artifact@v4
+        with:
+          pattern: hive-*
+          path: artifacts
+          merge-multiple: true
+      - name: Build and verify the canonical release manifest
+        env:
+          RELEASE_TAG: ${{ startsWith(github.ref, 'refs/tags/') && github.ref_name || '' }}
+        run: |
+          set -euo pipefail
+          version="$(ruby -Ilib -e 'require "hive"; print Hive::VERSION')"
+          tag="${RELEASE_TAG:-v$version}"
+          ruby packaging/release/finalize.rb "$version" "$tag" artifacts dist
+          cd dist
+          sha256sum --check SHA256SUMS
+      - uses: actions/upload-artifact@v4
+        with:
+          name: canonical-release
+          path: dist/*
+
+  publish-candidate:
+    if: startsWith(github.ref, 'refs/tags/')
+    runs-on: ubuntu-22.04
+    needs: finalize
+    permissions:
+      contents: write
+      id-token: write
+      attestations: write
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/download-artifact@v4
+        with:
+          name: canonical-release
+          path: dist
+      - uses: sigstore/cosign-installer@v3
+      - name: Sign release metadata
+        run: |
+          cosign sign-blob --yes --output-signature dist/SHA256SUMS.sig \
+            --output-certificate dist/SHA256SUMS.pem dist/SHA256SUMS
+      - uses: actions/attest-build-provenance@v2
+        with:
+          subject-path: |
+            dist/hive-*.tar.gz
+            dist/release.json
+            dist/install.sh
+            dist/install.sh.sha256
+      - name: Publish immutable non-latest candidate assets
+        env:
+          GH_TOKEN: ${{ github.token }}
+        run: |
+          gh release create "$GITHUB_REF_NAME" dist/* \
+            --repo ivankuznetsov/hive --verify-tag \
+            --title "$GITHUB_REF_NAME" --generate-notes \
+            --prerelease --latest=false
+
+  publish-homebrew:
+    if: startsWith(github.ref, 'refs/tags/')
+    runs-on: ubuntu-22.04
+    needs: publish-candidate
+    permissions:
+      contents: read
+    env:
+      TAP_TOKEN: ${{ secrets.HOMEBREW_TAP_TOKEN }}
+    steps:
+      - uses: actions/download-artifact@v4
+        with:
+          name: canonical-release
+          path: dist
+      - name: Require scoped tap credentials
+        run: test -n "$TAP_TOKEN" || { echo "HOMEBREW_TAP_TOKEN missing; macOS channel is incomplete" >&2; exit 1; }
+      - name: Dispatch canonical formula inputs
+        env:
+          GH_TOKEN: ${{ env.TAP_TOKEN }}
+        run: |
+          payload="$(jq -c '{version, tag, asset: (.assets[] | select(.target == "arm64-darwin") | {name, sha256})}' dist/release.json)"
+          test -n "$payload"
+          jq -n --argjson client_payload "$payload" \
+            '{event_type: "hive-release", client_payload: $client_payload}' | \
+            gh api repos/ivankuznetsov/homebrew-hive/dispatches --method POST --input -
+
+  publish-aur:
+    if: startsWith(github.ref, 'refs/tags/')
+    runs-on: ubuntu-22.04
+    needs: publish-candidate
+    permissions:
+      contents: read
+    env:
+      AUR_SSH_PRIVATE_KEY: ${{ secrets.AUR_SSH_PRIVATE_KEY }}
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/download-artifact@v4
+        with:
+          name: canonical-release
+          path: dist
+      - name: Render package from canonical release metadata
+        run: |
+          ruby packaging/aur/render.rb dist/release.json dist/aur
+          packaging/verify-channel.sh dist/release.json dist/aur
+      - name: Build, lint, install, and run without Ruby in clean Arch
+        run: |
+          docker run --rm -v "$PWD:/src" archlinux:latest bash -lc '
+            set -euo pipefail
+            pacman -Syu --noconfirm base-devel namcap
+            useradd -m builder
+            cp -R /src/dist/aur /tmp/hive-bin
+            chown -R builder:builder /tmp/hive-bin
+            cd /tmp/hive-bin
+            su builder -c "makepkg --noconfirm"
+            namcap PKGBUILD hive-bin-*.pkg.tar.zst
+            pacman -U --noconfirm hive-bin-*.pkg.tar.zst
+            ! command -v ruby
+            hive --version
+            hv --version
+            test -f /usr/share/hive/install-receipt.json
+          '
+      - name: Require scoped AUR credentials
+        run: test -n "$AUR_SSH_PRIVATE_KEY" || { echo "AUR_SSH_PRIVATE_KEY missing; Arch channel is incomplete" >&2; exit 1; }
+      - name: Publish hive-bin
+        run: |
+          install -d -m 0700 ~/.ssh
+          printf '%s\n' "$AUR_SSH_PRIVATE_KEY" > ~/.ssh/aur
+          chmod 0600 ~/.ssh/aur
+          ssh-keyscan aur.archlinux.org >> ~/.ssh/known_hosts
+          export GIT_SSH_COMMAND="ssh -i $HOME/.ssh/aur -o IdentitiesOnly=yes"
+          git clone ssh://aur@aur.archlinux.org/hive-bin.git aur-repo
+          cp dist/aur/PKGBUILD dist/aur/.SRCINFO dist/aur/hive.install aur-repo/
+          cd aur-repo
+          git config user.name "Hive release bot"
+          git config user.email "release@hive.invalid"
+          git add PKGBUILD .SRCINFO hive.install
+          git diff --cached --quiet && { echo "AUR package is stale or already published unexpectedly" >&2; exit 1; }
+          git commit -m "hive-bin ${GITHUB_REF_NAME#v}"
+          git push origin master
+
+  acceptance:
+    if: startsWith(github.ref, 'refs/tags/')
+    needs: [publish-homebrew, publish-aur]
+    uses: ./.github/workflows/install-acceptance.yml
+    with:
+      version: ${{ github.ref_name }}
+    secrets: inherit
+
+  promote-release:
+    if: startsWith(github.ref, 'refs/tags/')
+    runs-on: ubuntu-22.04
+    needs: acceptance
+    permissions:
+      contents: write
+    steps:
+      - name: Promote the fully accepted candidate to latest
+        env:
+          GH_TOKEN: ${{ github.token }}
+        run: |
+          gh release edit "$GITHUB_REF_NAME" --repo ivankuznetsov/hive \
+            --prerelease=false --latest
+
+  release-complete:
+    if: startsWith(github.ref, 'refs/tags/')
+    runs-on: ubuntu-22.04
+    needs: promote-release
+    permissions:
+      contents: read
+    steps:
+      - run: echo "All canonical assets, channels, and tier-1 acceptance scenarios passed for $GITHUB_REF_NAME"
