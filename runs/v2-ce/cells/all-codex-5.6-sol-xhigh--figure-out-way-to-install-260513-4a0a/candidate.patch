diff --git a/packaging/spike/packer-smoke.sh b/packaging/spike/packer-smoke.sh
new file mode 100755
index 00000000..f24e412a
--- /dev/null
+++ b/packaging/spike/packer-smoke.sh
@@ -0,0 +1,62 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+binary="${1:-}"
+asset_root="${2:-}"
+[[ -x "$binary" ]] || { echo "usage: packer-smoke.sh EXECUTABLE ASSET_ROOT" >&2; exit 64; }
+[[ -d "$asset_root" ]] || { echo "missing packaged asset root: $asset_root" >&2; exit 66; }
+
+root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+smoke_home="$(mktemp -d)"
+safe_path="$smoke_home/path"
+python_path="$(command -v python3)"
+mkdir -p "$safe_path" "$smoke_home/home"
+trap '"$binary" daemon stop >/dev/null 2>&1 || true; rm -rf "$smoke_home"' EXIT
+
+for command_name in git gh ps sh bash; do
+  command_path="$(command -v "$command_name" 2>/dev/null || true)"
+  [[ -z "$command_path" ]] || ln -s "$command_path" "$safe_path/$command_name"
+done
+
+if PATH="$safe_path" command -v ruby >/dev/null 2>&1; then
+  echo "ruby leaked into the isolated packaged-binary PATH" >&2
+  exit 70
+fi
+
+cat >"$smoke_home/home/config.yml" <<'YAML'
+---
+registered_projects: []
+YAML
+
+run_hive() {
+  env -i HOME="$smoke_home" HIVE_HOME="$smoke_home/home" HIVE_ASSET_ROOT="$asset_root" \
+    HIVE_PACKAGED_SMOKE="${HIVE_PACKAGED_SMOKE:-}" PATH="$safe_path" TERM=xterm-256color "$binary" "$@"
+}
+
+run_hive --version >/dev/null
+run_hive --help >/dev/null
+HIVE_PACKAGED_SMOKE=1 run_hive --packaged-runtime-smoke >/dev/null
+
+set +e
+doctor_output="$(run_hive doctor --json 2>&1)"
+doctor_status=$?
+set -e
+[[ "$doctor_status" -eq 0 || "$doctor_status" -eq 65 ]] || {
+  echo "packaged doctor failed to start: $doctor_output" >&2; exit 70;
+}
+grep -q '"schema"' <<<"$doctor_output"
+
+run_hive daemon start >"$smoke_home/daemon.log" 2>&1 &
+daemon_pid=$!
+for _attempt in {1..100}; do
+  [[ -s "$smoke_home/home/.daemon.pid" ]] && break
+  kill -0 "$daemon_pid" 2>/dev/null || { cat "$smoke_home/daemon.log" >&2; exit 70; }
+  sleep 0.05
+done
+run_hive daemon status >/dev/null
+run_hive daemon stop >/dev/null
+wait "$daemon_pid"
+
+env -i HOME="$smoke_home" HIVE_HOME="$smoke_home/home" HIVE_ASSET_ROOT="$asset_root" \
+  PATH="$safe_path" TERM=xterm-256color "$python_path" "$root/packaging/spike/tui_smoke.py" "$binary"
+
diff --git a/packaging/spike/tui_smoke.py b/packaging/spike/tui_smoke.py
new file mode 100755
index 00000000..081e0a0e
--- /dev/null
+++ b/packaging/spike/tui_smoke.py
@@ -0,0 +1,69 @@
+#!/usr/bin/env python3
+
+import os
+import pty
+import select
+import signal
+import sys
+import time
+
+RENDER_MARKERS = (b"Projects", b"Tasks")
+
+
+def main() -> int:
+    if len(sys.argv) != 2:
+        print("usage: tui_smoke.py /path/to/hive", file=sys.stderr)
+        return 64
+
+    pid, fd = pty.fork()
+    if pid == 0:
+        os.execve(sys.argv[1], [sys.argv[1], "tui"], os.environ.copy())
+
+    output = bytearray()
+    deadline = time.monotonic() + 15
+    sent_quit = False
+    while time.monotonic() < deadline:
+        readable, _, _ = select.select([fd], [], [], 0.1)
+        if readable:
+            try:
+                output.extend(os.read(fd, 65536))
+            except OSError:
+                pass
+        rendered = all(marker in output for marker in RENDER_MARKERS)
+        if rendered and not sent_quit:
+            try:
+                os.write(fd, b"q")
+                sent_quit = True
+            except OSError:
+                pass
+        exited, status = os.waitpid(pid, os.WNOHANG)
+        if exited:
+            exit_code = os.waitstatus_to_exitcode(status)
+            if not rendered or not sent_quit:
+                print(
+                    "packaged TUI exited before the render-and-quit handshake; "
+                    f"exit={exit_code} output={bytes(output[-1000:])!r}",
+                    file=sys.stderr,
+                )
+                return 70
+            if exit_code != 0:
+                print(
+                    f"packaged TUI failed after rendering; exit={exit_code} "
+                    f"output={bytes(output[-1000:])!r}",
+                    file=sys.stderr,
+                )
+            return exit_code
+
+    os.kill(pid, signal.SIGTERM)
+    os.waitpid(pid, 0)
+    print(
+        "packaged TUI did not complete the render-and-quit handshake; "
+        f"rendered={all(marker in output for marker in RENDER_MARKERS)} "
+        f"quit_sent={sent_quit} output={bytes(output[-1000:])!r}",
+        file=sys.stderr,
+    )
+    return 70
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
