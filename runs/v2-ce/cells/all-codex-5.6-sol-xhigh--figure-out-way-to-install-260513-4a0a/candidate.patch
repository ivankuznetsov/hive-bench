+++ b/test/unit/commands/uninstall_test.rb
@@ -0,0 +1,211 @@
+require "test_helper"
+require "stringio"
+require "json"
+require "hive/commands/uninstall"
+
+class UninstallCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeService = Struct.new(:calls, :messages, :result) do
+    def remove!
+      calls << :remove
+      result || :ok
+    end
+  end
+
+  def setup_fixture(dir)
+    project = File.join(dir, "project")
+    state_file = File.join(project, ".hive-state/stages/4-execute/task/task.md")
+    control = File.join(project, ".hive/project.yml")
+    FileUtils.mkdir_p(File.dirname(state_file))
+    FileUtils.mkdir_p(File.dirname(control))
+    File.write(state_file, "durable work\n")
+    File.write(File.join(project, ".hive-state/.git"), "gitdir: /tmp/fixture-gitdir\n")
+    File.write(control, { "schema_version" => 1, "state_worktree" => ".hive-state" }.to_yaml)
+    FileUtils.mkdir_p(Hive::Paths.config_home)
+    File.write(Hive::Config.global_config_path, {
+      "registered_projects" => [ { "name" => "project", "path" => project } ]
+    }.to_yaml)
+    FileUtils.mkdir_p(Hive::Paths.cache_home)
+    File.write(File.join(Hive::Paths.cache_home, "cache"), "cache")
+
+    executable = File.join(Hive::Paths.bin_home, "hive")
+    hv = File.join(Hive::Paths.bin_home, "hv")
+    version_root = File.join(Hive::Paths.data_home, "versions/0.1.0-x86_64-linux-gnu")
+    assets = File.join(version_root, "share/hive")
+    FileUtils.mkdir_p(File.dirname(executable))
+    FileUtils.mkdir_p(File.join(version_root, "bin"))
+    FileUtils.mkdir_p(File.join(assets, "templates"))
+    File.write(File.join(version_root, "bin/hive"), "binary")
+    File.write(File.join(version_root, "bin/hv"), "fallback")
+    File.symlink(File.join(version_root, "bin/hive"), executable)
+    File.symlink(File.join(version_root, "bin/hv"), hv)
+    File.write(File.join(assets, "templates/a"), "asset")
+    FileUtils.chmod(0o755, File.join(version_root, "bin/hive"))
+    FileUtils.chmod(0o755, File.join(version_root, "bin/hv"))
+    receipt = {
+      "schema_version" => 1, "channel" => "bash", "package" => "hive",
+      "installed_command" => "hive", "executable" => executable,
+      "asset_root" => assets, "version" => "0.1.0",
+      "service_label" => "local.hive-daemon",
+      "owned_files" => [ executable, hv, version_root ]
+    }
+    receipt_path = Hive::InstallChannel.write_receipt(receipt)
+    [ project, state_file, control, Hive::InstallChannel.read_receipt(receipt_path) ]
+  end
+
+  def test_default_bash_uninstall_removes_only_receipt_owned_core_and_preserves_work
+    with_xdg_home do |dir|
+      project, state_file, control, receipt = setup_fixture(dir)
+      service = FakeService.new([], [], :ok)
+      Hive::Commands::Uninstall.new(receipt: receipt, service_installer: service).call
+      assert_equal "durable work\n", File.read(state_file)
+      assert File.file?(control)
+      refute File.exist?(receipt.fetch("executable"))
+      refute File.exist?(receipt.fetch("asset_root"))
+      assert File.directory?(Hive::Paths.state_home)
+      assert_equal [ :remove ], service.calls
+      assert File.directory?(project)
+    end
+  end
+
+  def test_purge_yes_removes_config_cache_and_explicit_metadata_but_never_state_work
+    with_xdg_home do |dir|
+      _project, state_file, control, receipt = setup_fixture(dir)
+      Hive::Commands::Uninstall.new(
+        receipt: receipt, service_installer: FakeService.new([], [], :ok),
+        purge: true, yes: true, project_metadata: true
+      ).call
+      assert_equal "durable work\n", File.read(state_file)
+      refute File.exist?(control)
+      refute File.exist?(Hive::Paths.config_home)
+      refute File.exist?(Hive::Paths.cache_home)
+      assert File.directory?(Hive::Paths.state_home)
+    end
+  end
+
+  def test_declined_metadata_cleanup_preserves_control_scaffold
+    with_xdg_home do |dir|
+      _project, _state_file, control, receipt = setup_fixture(dir)
+      Hive::Commands::Uninstall.new(
+        receipt: receipt, service_installer: FakeService.new([], [], :ok),
+        project_metadata: true, input: StringIO.new("n\n"), output: StringIO.new
+      ).call
+      assert File.file?(control)
+    end
+  end
+
+  def test_dry_run_json_mutates_nothing
+    with_xdg_home do |dir|
+      _project, state_file, _control, receipt = setup_fixture(dir)
+      out = StringIO.new
+      service = FakeService.new([], [], :ok)
+      Hive::Commands::Uninstall.new(
+        receipt: receipt, service_installer: service, dry_run: true, json: true, output: out
+      ).call
+      payload = JSON.parse(out.string)
+      assert_equal "hive-uninstall", payload["schema"]
+      assert_equal true, payload["dry_run"]
+      assert File.file?(receipt.fetch("executable"))
+      assert_equal "durable work\n", File.read(state_file)
+      assert_empty service.calls
+    end
+  end
+
+  def test_manager_uninstall_runs_after_service_cleanup
+    events = []
+    service = Object.new
+    service.define_singleton_method(:messages) { [] }
+    service.define_singleton_method(:remove!) { events << :service; :ok }
+    Hive::Commands::Uninstall.new(
+      receipt: { "channel" => "brew" }, service_installer: service,
+      runner: ->(argv) { events << argv; true }
+    ).call
+    assert_equal :service, events[0]
+    assert_equal %w[brew uninstall ivankuznetsov/hive/hive], events[1]
+  end
+
+  def test_service_failure_stops_before_manager_or_binary_removal
+    events = []
+    service = Object.new
+    service.define_singleton_method(:messages) { [ "disable failed" ] }
+    service.define_singleton_method(:remove!) { events << :service; :failed }
+    command = Hive::Commands::Uninstall.new(
+      receipt: { "channel" => "brew" }, service_installer: service,
+      runner: ->(argv) { events << argv; true }
+    )
+    error = assert_raises(Hive::UnavailableError) { command.call }
+    assert_match(/disable failed/, error.message)
+    assert_equal [ :service ], events
+  end
+
+  def test_receipt_escape_fails_closed_without_removing_external_file
+    with_xdg_home do |dir|
+      _project, state_file, _control, receipt = setup_fixture(dir)
+      external = File.join(dir, "external")
+      File.write(external, "keep")
+      receipt["owned_files"] << external
+      assert_raises(Hive::ConfigError) do
+        Hive::Commands::Uninstall.new(receipt: receipt, service_installer: FakeService.new([], [], :ok)).call
+      end
+      assert_equal "keep", File.read(external)
+      assert_equal "durable work\n", File.read(state_file)
+    end
+  end
+
+  def test_receipt_executable_outside_validated_bin_layout_fails_before_mutation
+    with_xdg_home do |dir|
+      _project, state_file, _control, receipt = setup_fixture(dir)
+      external = File.join(dir, "unrelated-hive")
+      File.write(external, "keep")
+      receipt["executable"] = external
+      receipt["owned_files"] << external
+      service = FakeService.new([], [], :ok)
+
+      assert_raises(Hive::ConfigError) do
+        Hive::Commands::Uninstall.new(receipt: receipt, service_installer: service).call
+      end
+      assert_equal "keep", File.read(external)
+      assert_equal "durable work\n", File.read(state_file)
+      assert_empty service.calls
+    end
+  end
+
+  def test_replaced_wrapper_is_preserved_and_aborts_before_other_cleanup
+    with_xdg_home do |dir|
+      _project, state_file, _control, receipt = setup_fixture(dir)
+      executable = receipt.fetch("executable")
+      File.unlink(executable)
+      File.write(executable, "replacement")
+      service = FakeService.new([], [], :ok)
+
+      error = assert_raises(Hive::ConfigError) do
+        Hive::Commands::Uninstall.new(receipt: receipt, service_installer: service).call
+      end
+      assert_match(/wrapper was replaced/, error.message)
+      assert_equal "replacement", File.read(executable)
+      assert File.directory?(File.dirname(File.dirname(receipt.fetch("asset_root"))))
+      assert_equal "durable work\n", File.read(state_file)
+      assert_empty service.calls
+    end
+  end
+
+  def test_changed_wrapper_symlink_is_preserved_and_aborts_before_other_cleanup
+    with_xdg_home do |dir|
+      _project, _state_file, _control, receipt = setup_fixture(dir)
+      hv = File.join(Hive::Paths.bin_home, "hv")
+      replacement = File.join(dir, "other-hv")
+      File.write(replacement, "replacement")
+      File.unlink(hv)
+      File.symlink(replacement, hv)
+      service = FakeService.new([], [], :ok)
+
+      error = assert_raises(Hive::ConfigError) do
+        Hive::Commands::Uninstall.new(receipt: receipt, service_installer: service).call
+      end
+      assert_match(/wrapper target changed/, error.message)
+      assert_equal replacement, File.expand_path(File.readlink(hv), File.dirname(hv))
+      assert_empty service.calls
+    end
+  end
+end
