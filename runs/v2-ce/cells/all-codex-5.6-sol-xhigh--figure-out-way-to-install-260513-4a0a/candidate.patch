diff --git a/lib/hive/assets.rb b/lib/hive/assets.rb
new file mode 100644
index 00000000..ba54828c
--- /dev/null
+++ b/lib/hive/assets.rb
@@ -0,0 +1,92 @@
+require "hive/paths"
+
+module Hive
+  module Assets
+    REQUIRED_DIRECTORIES = %w[templates schemas].freeze
+
+    module_function
+
+    def root
+      if (explicit = Hive::Paths.env_value("HIVE_ASSET_ROOT"))
+        return validate_explicit_root!(explicit)
+      end
+
+      candidate_roots.each do |candidate|
+        return File.realpath(candidate) if valid_root?(candidate)
+      end
+      raise Hive::ConfigError, "could not locate Hive runtime assets; reinstall Hive or set HIVE_ASSET_ROOT"
+    end
+
+    def path(relative)
+      relative = validate_relative!(relative)
+      candidate = File.expand_path(relative, root)
+      assert_contained!(candidate)
+      raise Hive::ConfigError, "Hive runtime asset is missing: #{relative}" unless File.exist?(candidate)
+
+      resolved = File.realpath(candidate)
+      assert_contained!(resolved)
+      resolved
+    end
+
+    def directory(relative)
+      resolved = path(relative)
+      raise Hive::ConfigError, "Hive runtime asset is not a directory: #{relative}" unless File.directory?(resolved)
+
+      resolved
+    end
+
+    def read(relative)
+      File.read(path(relative))
+    end
+
+    def candidate_roots
+      roots = []
+      executable = begin
+        File.realpath($PROGRAM_NAME)
+      rescue SystemCallError
+        File.expand_path($PROGRAM_NAME)
+      end
+      roots << File.expand_path("../share/hive", File.dirname(executable))
+      roots << Hive::Paths.data_home
+      if (prefix = Hive::Paths.env_value("HOMEBREW_PREFIX"))
+        roots << File.join(File.expand_path(prefix), "share", "hive")
+      end
+      roots << Hive::Paths.env_value("HIVE_SYSTEM_SHARE")
+      roots.concat(%w[/opt/homebrew/share/hive /usr/local/share/hive /usr/share/hive])
+      roots << File.expand_path("../..", __dir__)
+      roots.compact.uniq
+    end
+
+    def valid_root?(candidate)
+      File.directory?(candidate) && REQUIRED_DIRECTORIES.all? { |name| File.directory?(File.join(candidate, name)) }
+    end
+
+    def validate_explicit_root!(candidate)
+      unless File.absolute_path?(candidate)
+        raise Hive::ConfigError, "HIVE_ASSET_ROOT must be an absolute path: #{candidate.inspect}"
+      end
+      expanded = File.expand_path(candidate)
+      unless valid_root?(expanded)
+        raise Hive::ConfigError,
+              "HIVE_ASSET_ROOT #{expanded} is missing required directories: #{REQUIRED_DIRECTORIES.join(', ')}"
+      end
+      File.realpath(expanded)
+    end
+
+    def validate_relative!(relative)
+      value = relative.to_s
+      if value.empty? || value.include?("\0") || File.absolute_path?(value) ||
+         value.split(File::SEPARATOR).any? { |part| part == ".." }
+        raise Hive::ConfigError, "runtime asset path must be safe and relative: #{relative.inspect}"
+      end
+      value
+    end
+
+    def assert_contained!(candidate)
+      asset_root = root
+      return if candidate == asset_root || candidate.start_with?("#{asset_root}#{File::SEPARATOR}")
+
+      raise Hive::ConfigError, "runtime asset path resolves outside #{asset_root}: #{candidate}"
+    end
+  end
+end
