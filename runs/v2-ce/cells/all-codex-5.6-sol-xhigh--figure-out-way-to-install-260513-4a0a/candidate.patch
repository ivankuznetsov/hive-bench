diff --git a/test/unit/tui_smoke_script_test.rb b/test/unit/tui_smoke_script_test.rb
new file mode 100644
index 00000000..07b118ba
--- /dev/null
+++ b/test/unit/tui_smoke_script_test.rb
@@ -0,0 +1,66 @@
+require "test_helper"
+require "open3"
+
+class TuiSmokeScriptTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+  SMOKE = File.join(ROOT, "packaging/spike/tui_smoke.py")
+
+  def setup
+    super
+    @python = ENV.fetch("PATH", "").split(File::PATH_SEPARATOR)
+      .map { |dir| File.join(dir, "python3") }
+      .find { |path| File.file?(path) && File.executable?(path) }
+  end
+
+  def run_smoke(child)
+    skip "python3 is required for the packaged TUI smoke contract" unless @python
+
+    Open3.capture3(@python, SMOKE, child)
+  end
+
+  def write_child(dir, body)
+    path = File.join(dir, "fake-hive")
+    File.write(path, "#!/usr/bin/env python3\n#{body}")
+    FileUtils.chmod(0o755, path)
+    path
+  end
+
+  def test_immediate_success_without_a_render_fails_the_smoke
+    with_tmp_dir do |dir|
+      child = write_child(dir, "raise SystemExit(0)\n")
+      _out, err, status = run_smoke(child)
+
+      refute status.success?
+      assert_equal 70, status.exitstatus
+      assert_match(/exited before the render-and-quit handshake/, err)
+    end
+  end
+
+  def test_quit_is_gated_on_both_dashboard_render_markers
+    source = File.read(SMOKE)
+
+    assert_includes source, 'RENDER_MARKERS = (b"Projects", b"Tasks")'
+    assert_match(/rendered = all\(marker in output for marker in RENDER_MARKERS\)/, source)
+    assert_match(/if rendered and not sent_quit:.*os\.write\(fd, b"q"\)/m, source)
+    assert_match(/if not rendered or not sent_quit:/, source)
+  end
+
+  def test_rendered_dashboard_must_receive_q_before_success
+    with_tmp_dir do |dir|
+      child = write_child(dir, <<~PY)
+        import os
+        import sys
+
+        if sys.argv[1:] != ["tui"]:
+            raise SystemExit(64)
+        os.write(1, b"\\x1b[2JProjects   Tasks\\r\\n")
+        raise SystemExit(0 if os.read(0, 1) == b"q" else 70)
+      PY
+      _out, err, status = run_smoke(child)
+
+      assert status.success?, err
+    end
+  end
+end
