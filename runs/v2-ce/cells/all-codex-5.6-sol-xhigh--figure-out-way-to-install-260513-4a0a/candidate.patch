--- /dev/null
+++ b/lib/hive/executable.rb
@@ -0,0 +1,49 @@
+require "shellwords"
+require "hive/install_channel"
+
+module Hive
+  module Executable
+    module_function
+
+    def path
+      explicit = Hive::Paths.env_value("HIVE_EXECUTABLE") || Hive::Paths.env_value("HIVE_BIN")
+      return validate!(explicit, "environment override") if explicit
+
+      receipt = Hive::InstallChannel.receipt
+      return validate!(receipt.fetch("executable"), receipt.fetch("receipt_path")) if receipt
+
+      invoked = File.expand_path($PROGRAM_NAME)
+      return invoked if hive_launcher?(invoked)
+
+      checkout = File.expand_path("../../bin/hive", __dir__)
+      return checkout if File.file?(checkout) && File.executable?(checkout)
+
+      raise Hive::ConfigError, "could not resolve the package-owned Hive executable; reinstall Hive"
+    end
+
+    def argv(*arguments)
+      [ path, *arguments.map(&:to_s) ]
+    end
+
+    def shell(*arguments)
+      argv(*arguments).shelljoin
+    end
+
+    def command_name
+      receipt = Hive::InstallChannel.receipt
+      receipt ? receipt.fetch("installed_command") : File.basename(path)
+    end
+
+    def validate!(candidate, source)
+      expanded = File.expand_path(candidate)
+      unless File.file?(expanded) && File.executable?(expanded) && %w[hive hv].include?(File.basename(expanded))
+        raise Hive::ConfigError, "Hive executable from #{source} is not a runnable hive/hv file: #{expanded}"
+      end
+      expanded
+    end
+
+    def hive_launcher?(candidate)
+      File.file?(candidate) && File.executable?(candidate) && %w[hive hv].include?(File.basename(candidate))
+    end
+  end
+end
