@@ -0,0 +1,198 @@
+require "fileutils"
+require "json"
+require "hive/config"
+require "hive/install_channel"
+require "hive/commands/daemon/service_installer"
+
+module Hive
+  module Commands
+    class Uninstall
+      def initialize(dry_run: false, json: false, purge: false, yes: false,
+                     project_metadata: false, input: $stdin, output: $stdout,
+                     runner: nil, env: ENV, receipt: nil, service_installer: nil)
+        @dry_run = dry_run
+        @json = json
+        @purge = purge
+        @yes = yes
+        @project_metadata = project_metadata
+        @input = input
+        @output = output
+        @runner = runner || ->(argv) { system(*argv) }
+        @env = env
+        @receipt = receipt
+        @service_installer = service_installer || Hive::Commands::Daemon::ServiceInstaller.new
+      end
+
+      def call
+        receipt = @receipt || Hive::InstallChannel.receipt
+        policy = Hive::InstallChannel.lifecycle(receipt: receipt, env: @env)
+        preflight_bash_owned(policy)
+        projects = safe_projects
+        actions = planned_actions(policy, receipt, projects)
+        payload = {
+          "schema" => "hive-uninstall", "schema_version" => 1, "ok" => true,
+          "dry_run" => @dry_run, "purge" => @purge, "channel" => policy.channel,
+          "actions" => actions, "preserved" => preserved_paths(projects)
+        }
+        if @dry_run
+          render(payload)
+          return 0
+        end
+
+        remove_service
+        remove_project_metadata(projects) if metadata_approved?
+        remove_config_and_cache if @purge
+        remove_channel(policy, receipt)
+        render(payload)
+        0
+      rescue Hive::Error => e
+        emit_error(e)
+        raise
+      end
+
+      private
+
+      def safe_projects
+        Hive::Config.registered_projects
+      rescue Hive::ConfigError
+        []
+      end
+
+      def planned_actions(policy, receipt, projects)
+        actions = [ "remove per-user daemon service" ]
+        actions << "remove explicitly approved .hive/project.yml metadata" if @project_metadata && !projects.empty?
+        actions << "remove XDG config and cache (never state)" if @purge
+        actions << policy.action_description(:uninstall)
+        actions << "remove receipt #{receipt['receipt_path']}" if receipt&.fetch("receipt_path", nil)
+        actions
+      end
+
+      def preserved_paths(projects)
+        [ Hive::Paths.state_home, *projects.map { |project| project["hive_state_path"] } ].uniq
+      end
+
+      def remove_service
+        result = @service_installer.remove!
+        return if %i[ok unsupported].include?(result)
+
+        details = Array(@service_installer.messages).last
+        message = result == :unsafe ? "daemon service removal was unsafe" : "daemon service removal failed"
+        message = "#{message}: #{details}" if details
+        raise Hive::UnavailableError, message
+      end
+
+      def metadata_approved?
+        return false unless @project_metadata
+        return true if @yes
+
+        @output.print "Remove generated .hive/project.yml metadata from registered projects? [y/N]: " unless @json
+        %w[y yes].include?(@input.gets.to_s.strip.downcase)
+      end
+
+      def remove_project_metadata(projects)
+        projects.each do |project|
+          control = Hive::Paths.project_control_path(project.fetch("path"))
+          next unless File.file?(control) && !File.symlink?(control)
+
+          File.delete(control)
+          dir = File.dirname(control)
+          Dir.rmdir(dir) if Dir.exist?(dir) && Dir.empty?(dir)
+        end
+      end
+
+      def remove_config_and_cache
+        if Hive::Paths.hive_home_collapsed?
+          @output.puts "hive: HIVE_HOME is collapsed; preserving it because it also contains state" unless @json
+          return
+        end
+        FileUtils.rm_rf(Hive::Paths.config_home)
+        FileUtils.rm_rf(Hive::Paths.cache_home)
+      end
+
+      def remove_channel(policy, receipt)
+        argv = policy.command_for(:uninstall)
+        return remove_bash_owned(receipt) if policy.channel == "bash"
+        return unless argv
+
+        policy.run!(@runner, argv, operation: "uninstall")
+      end
+
+      def remove_bash_owned(receipt)
+        receipt_path = receipt["receipt_path"] && File.expand_path(receipt.fetch("receipt_path"))
+        @bash_wrapper_paths.each { |path| safe_remove(path, recursive: false) }
+        safe_remove(@bash_layout.version_root, recursive: true)
+        safe_remove(receipt_path, recursive: false) if receipt_path
+      end
+
+      def preflight_bash_owned(policy)
+        return unless policy.channel == "bash"
+
+        @bash_layout = policy.bash_layout
+        owned_paths = Array(policy.receipt.fetch("owned_files")).map { |path| File.expand_path(path) }
+        unless owned_paths.include?(@bash_layout.version_root)
+          raise Hive::ConfigError,
+                "bash receipt version payload is not listed in owned_files: #{@bash_layout.version_root}"
+        end
+        @bash_wrapper_paths = owned_paths.select { |path| @bash_layout.wrapper?(path) }.uniq
+        @bash_wrapper_paths.each { |path| validate_wrapper_identity!(path) }
+
+        root = @bash_layout.version_root
+        if File.exist?(root) || File.symlink?(root)
+          stat = File.lstat(root)
+          unless stat.directory? && !stat.symlink?
+            raise Hive::ConfigError, "bash version payload identity changed; refusing to remove #{root}"
+          end
+        end
+      end
+
+      def validate_wrapper_identity!(path)
+        return unless File.exist?(path) || File.symlink?(path)
+
+        unless File.symlink?(path)
+          raise Hive::ConfigError,
+                "installed wrapper was replaced; preserving #{path} (expected a receipt-owned symlink)"
+        end
+        actual = File.expand_path(File.readlink(path), File.dirname(path))
+        expected = @bash_layout.expected_wrapper(path)
+        return if actual == expected
+
+        raise Hive::ConfigError,
+              "installed wrapper target changed; preserving #{path} (expected #{expected}, found #{actual})"
+      end
+
+      def safe_remove(path, recursive:)
+        return unless path && (File.exist?(path) || File.symlink?(path))
+
+        stat = File.lstat(path)
+        if stat.symlink? || stat.file?
+          File.unlink(path)
+        elsif stat.directory? && recursive
+          FileUtils.rm_rf(path)
+        end
+      rescue Errno::ENOENT
+        nil
+      end
+
+      def render(payload)
+        if @json
+          @output.puts JSON.generate(payload)
+        else
+          @output.puts "hive: #{payload['dry_run'] ? 'would uninstall' : 'uninstalled'} core (#{payload['channel']})"
+          @output.puts "hive: preserved #{payload['preserved'].join(', ')}"
+          @output.puts "hive: agent packages and marketplaces were not changed"
+        end
+      end
+
+      def emit_error(error)
+        return unless @json
+
+        @output.puts JSON.generate(
+          "schema" => "hive-uninstall", "schema_version" => 1, "ok" => false,
+          "error_class" => error.class.name.split("::").last,
+          "error_kind" => error.is_a?(Hive::ConfigError) ? "config" : "unavailable",
+          "exit_code" => error.exit_code, "message" => error.message
+        )
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/update.rb b/lib/hive/commands/update.rb
new file mode 100644
index 00000000..98f5fa2d
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,220 @@
+require "json"
+require "shellwords"
+require "hive/install_channel"
+
+module Hive
+  module Commands
+    class Update
+      SEMVER_TAG = /\Av\d+\.\d+\.\d+\z/
+
+      def initialize(dry_run: false, json: false, output: $stdout, runner: nil, env: ENV,
+                     channel: nil, receipt: nil, version: nil)
+        @dry_run = dry_run
+        @json = json
+        @output = output
+        @runner = runner || ->(argv) { system(*argv) }
+        @env = env
+        @receipt = receipt
+        @channel = channel
+        @version = version
+      end
+
+      def call
+        receipt = @receipt || Hive::InstallChannel.receipt
+        policy = Hive::InstallChannel.lifecycle(receipt: receipt, channel: @channel, env: @env)
+        argv = command_for(policy)
+        payload = {
+          "schema" => "hive-update", "schema_version" => 1, "ok" => true,
+          "dry_run" => @dry_run, "channel" => policy.channel, "command" => argv
+        }
+        if @dry_run || argv.nil?
+          render(payload)
+          return 0
+        end
+
+        policy.run!(@runner, argv, operation: "update")
+
+        render(payload)
+        0
+      rescue Hive::Error => e
+        emit_error(e)
+        raise
+      end
+
+      def command_for(channel_or_policy)
+        policy = if channel_or_policy.is_a?(Hive::InstallChannel::Lifecycle)
+          channel_or_policy
+        else
+          Hive::InstallChannel.lifecycle(receipt: @receipt, channel: channel_or_policy, env: @env)
+        end
+        if @version && policy.channel != "bash"
+          raise Hive::ConfigError, "--version is supported only for bash-managed Hive installations"
+        end
+
+        policy.command_for(:update) { |bash_policy| bash_command(bash_policy) }
+      end
+
+      private
+
+      def bash_command(policy)
+        requested_version = @version.to_s
+        if !requested_version.empty? && !requested_version.match?(SEMVER_TAG)
+          raise Hive::ConfigError, "invalid update version #{requested_version.inspect}; expected vMAJOR.MINOR.PATCH"
+        end
+        prefix = policy.receipt ? policy.detected_prefix.to_s : ""
+        script = <<~'BASH'
+          set -euo pipefail
+          repository="ivankuznetsov/hive"
+          requested_tag="${1:-}"
+          prefix="${2:-}"
+          base_url="https://github.com/$repository/releases"
+          issuer="https://token.actions.githubusercontent.com"
+          identity_base="https://github.com/$repository/.github/workflows/release.yml@refs/tags/"
+          tmpdir="$(mktemp -d)"
+          trap 'rm -rf "$tmpdir"' EXIT
+          curl_args=(--fail --silent --show-error --location --connect-timeout 10 --max-time 120 --retry 3 --retry-all-errors)
+
+          command -v cosign >/dev/null 2>&1 || {
+            echo "hive update: cosign is required to authenticate the release bootstrap" >&2
+            exit 69
+          }
+
+          download() {
+            curl "${curl_args[@]}" "$1" -o "$2"
+          }
+
+          sha256_file() {
+            if command -v sha256sum >/dev/null 2>&1; then
+              sha256sum "$1" | awk '{print $1}'
+            elif command -v shasum >/dev/null 2>&1; then
+              shasum -a 256 "$1" | awk '{print $1}'
+            else
+              echo "hive update: sha256sum or shasum is required" >&2
+              return 69
+            fi
+          }
+
+          metadata_value() {
+            sed -nE "s/^[[:space:]]*\"$1\":[[:space:]]*\"([^\"]+)\",?$/\\1/p" "$2"
+          }
+
+          verify_signature() {
+            local dir="$1" tag="$2"
+            cosign verify-blob \
+              --certificate "$dir/SHA256SUMS.pem" \
+              --signature "$dir/SHA256SUMS.sig" \
+              --certificate-oidc-issuer "$issuer" \
+              --certificate-identity "${identity_base}${tag}" \
+              "$dir/SHA256SUMS" >/dev/null
+          }
+
+          verify_checksum() {
+            local dir="$1" name="$2" expected actual
+            expected="$(awk -v file="$name" 'NF == 2 && $2 == file { print $1 }' "$dir/SHA256SUMS")"
+            [[ "$expected" =~ ^[0-9a-f]{64}$ ]] || {
+              echo "hive update: signed checksum entry missing or duplicated for $name" >&2
+              return 1
+            }
+            actual="$(sha256_file "$dir/$name")"
+            [[ "$actual" == "$expected" ]] || {
+              echo "hive update: checksum mismatch for $name" >&2
+              return 1
+            }
+          }
+
+          download_release_bundle() {
+            local url="$1" dir="$2"
+            mkdir -p "$dir"
+            download "$url/release.json" "$dir/release.json"
+            download "$url/SHA256SUMS" "$dir/SHA256SUMS"
+            download "$url/SHA256SUMS.sig" "$dir/SHA256SUMS.sig"
+            download "$url/SHA256SUMS.pem" "$dir/SHA256SUMS.pem"
+          }
+
+          validate_metadata() {
+            local file="$1" expected_tag="$2" version tag manifest_repository
+            version="$(metadata_value version "$file")"
+            tag="$(metadata_value tag "$file")"
+            manifest_repository="$(metadata_value repository "$file")"
+            [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ && "$tag" == "v$version" ]] || {
+              echo "hive update: release metadata has an invalid immutable version/tag" >&2
+              return 1
+            }
+            [[ "$tag" == "$expected_tag" && "$manifest_repository" == "$repository" ]] || {
+              echo "hive update: release metadata repository/tag mismatch" >&2
+              return 1
+            }
+          }
+
+          if [[ -z "$requested_tag" ]]; then
+            latest="$tmpdir/latest"
+            download_release_bundle "$base_url/latest/download" "$latest"
+            release_version="$(metadata_value version "$latest/release.json")"
+            release_tag="$(metadata_value tag "$latest/release.json")"
+            release_repository="$(metadata_value repository "$latest/release.json")"
+            [[ "$release_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ && "$release_tag" == "v$release_version" ]] || {
+              echo "hive update: latest release metadata has an invalid immutable version/tag" >&2
+              exit 1
+            }
+            [[ "$release_repository" == "$repository" ]] || {
+              echo "hive update: latest release metadata repository mismatch" >&2
+              exit 1
+            }
+            verify_signature "$latest" "$release_tag"
+            verify_checksum "$latest" release.json
+          else
+            [[ "$requested_tag" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
+              echo "hive update: invalid requested release tag" >&2
+              exit 64
+            }
+            release_tag="$requested_tag"
+          fi
+
+          tagged="$tmpdir/tagged"
+          download_release_bundle "$base_url/download/$release_tag" "$tagged"
+          download "$base_url/download/$release_tag/install.sh" "$tagged/install.sh"
+          download "$base_url/download/$release_tag/install.sh.sha256" "$tagged/install.sh.sha256"
+          verify_signature "$tagged" "$release_tag"
+          verify_checksum "$tagged" release.json
+          verify_checksum "$tagged" install.sh
+          verify_checksum "$tagged" install.sh.sha256
+          validate_metadata "$tagged/release.json" "$release_tag"
+
+          installer_checksum="$(awk 'NF == 2 && $2 == "install.sh" { print $1 }' "$tagged/install.sh.sha256")"
+          [[ "$installer_checksum" =~ ^[0-9a-f]{64}$ && "$installer_checksum" == "$(sha256_file "$tagged/install.sh")" ]] || {
+            echo "hive update: authenticated installer checksum is invalid" >&2
+            exit 1
+          }
+
+          install_args=("--version=$release_tag")
+          [[ -z "$prefix" ]] || install_args+=("--prefix=$prefix")
+          bash "$tagged/install.sh" "${install_args[@]}"
+        BASH
+        [ "bash", "-c", script, "hive-update", requested_version, prefix ]
+      end
+
+      def render(payload)
+        if @json
+          @output.puts JSON.generate(payload)
+        elsif payload["command"]
+          @output.puts "channel: #{payload['channel']}"
+          @output.puts "command: #{payload['command'].shelljoin}"
+        else
+          @output.puts "channel: dev"
+          @output.puts "suggested action: update the source checkout with git"
+        end
+      end
+
+      def emit_error(error)
+        return unless @json
+
+        @output.puts JSON.generate(
+          "schema" => "hive-update", "schema_version" => 1, "ok" => false,
+          "error_class" => error.class.name.split("::").last,
+          "error_kind" => error.is_a?(Hive::ConfigError) ? "config" : "unavailable",
+          "exit_code" => error.exit_code, "message" => error.message
+        )
+      end
+    end
+  end
+end
