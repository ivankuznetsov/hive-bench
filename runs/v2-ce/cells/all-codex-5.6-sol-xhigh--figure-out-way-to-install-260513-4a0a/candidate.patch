new file mode 100755
index 00000000..9fcd47b1
--- /dev/null
+++ b/packaging/homebrew/render.rb
@@ -0,0 +1,16 @@
+#!/usr/bin/env ruby
+
+require "erb"
+require "json"
+
+release_path, template_path, output_path = ARGV
+abort "usage: render.rb RELEASE_JSON TEMPLATE OUTPUT" unless output_path
+release = JSON.parse(File.read(release_path))
+version = release.fetch("version")
+abort "invalid release version" unless version.match?(/\A\d+\.\d+\.\d+\z/)
+asset = release.fetch("assets").find { |row| row["target"] == "arm64-darwin" }
+abort "release has no arm64-darwin asset" unless asset
+sha256 = asset.fetch("sha256")
+abort "invalid arm64-darwin checksum" unless sha256.match?(/\A[0-9a-f]{64}\z/)
+rendered = ERB.new(File.read(template_path), trim_mode: "-").result(binding)
+File.write(output_path, rendered)
diff --git a/packaging/release/finalize.rb b/packaging/release/finalize.rb
new file mode 100755
index 00000000..b73a828a
--- /dev/null
+++ b/packaging/release/finalize.rb
@@ -0,0 +1,136 @@
+#!/usr/bin/env ruby
+
+require "digest"
+require "fileutils"
+require "json"
+require "rubygems/package"
+require "yaml"
+require "zlib"
+
+ROOT = File.expand_path("../..", __dir__)
+SPEC = YAML.safe_load_file(File.join(__dir__, "manifest.yml"), permitted_classes: [], aliases: false)
+SEMVER = /\A\d+\.\d+\.\d+\z/
+
+version, tag, source_dir, output_dir = ARGV
+abort "usage: finalize.rb VERSION vVERSION SOURCE_DIR OUTPUT_DIR" unless output_dir
+abort "invalid release version #{version.inspect}" unless version.match?(SEMVER)
+abort "tag #{tag.inspect} does not match version #{version}" unless tag == "v#{version}"
+
+source_dir = File.expand_path(source_dir)
+output_dir = File.expand_path(output_dir)
+FileUtils.mkdir_p(output_dir)
+
+def archive_entries(path)
+  entries = {}
+  Zlib::GzipReader.open(path) do |gzip|
+    Gem::Package::TarReader.new(gzip) do |tar|
+      tar.each do |entry|
+        name = entry.full_name
+        abort "unsafe archive path in #{path}: #{name}" if name.start_with?("/") || name.split("/").include?("..")
+        entries[name] = { mode: entry.header.mode, data: entry.file? ? entry.read : nil }
+      end
+    end
+  end
+  entries
+rescue Zlib::GzipFile::Error, Gem::Package::TarInvalidError => e
+  abort "invalid release archive #{path}: #{e.message}"
+end
+
+def definition_value(contents, directive, key)
+  values = contents.scan(/^#{Regexp.escape(directive)} #{Regexp.escape(key)}=(.+)$/).flatten
+  abort "builder definition must contain one #{directive} #{key}=... entry" unless values.one?
+
+  values.first
+end
+
+builder_spec = SPEC.fetch("builder")
+builder_definition = builder_spec.fetch("definition")
+builder_definition_path = File.expand_path(builder_definition, ROOT)
+unless builder_definition_path.start_with?("#{ROOT}#{File::SEPARATOR}") && File.file?(builder_definition_path)
+  abort "builder definition is outside the repository or missing: #{builder_definition}"
+end
+builder_contents = File.read(builder_definition_path)
+builder_image = definition_value(builder_contents, "ARG", "TEBAKO_IMAGE")
+builder_image_digest = builder_image[/@((?:sha256:)[0-9a-f]{64})\z/, 1]
+abort "builder image must be pinned by sha256 digest" unless builder_image_digest
+builder = {
+  "packer" => builder_spec.fetch("packer"),
+  "packer_version" => definition_value(builder_contents, "ENV", "TEBAKO_VERSION"),
+  "embedded_ruby" => definition_value(builder_contents, "ENV", "TEBAKO_RUBY_VERSION"),
+  "linux_image" => builder_image,
+  "linux_image_digest" => builder_image_digest,
+  "definition" => builder_definition,
+  "definition_sha256" => Digest::SHA256.file(builder_definition_path).hexdigest
+}
+
+assets = []
+commits = []
+SPEC.fetch("targets").each do |target, target_spec|
+  filename = "hive-#{version}-#{target}.tar.gz"
+  archive = File.join(source_dir, filename)
+  abort "missing release artifact #{filename}" unless File.file?(archive) && File.size?(archive)
+
+  entries = archive_entries(archive)
+  root = "hive-#{version}-#{target}"
+  SPEC.fetch("required_paths").each do |relative|
+    abort "#{filename} is missing #{relative}" unless entries.key?(File.join(root, relative))
+  end
+  %w[bin/hive bin/hv].each do |relative|
+    executable = entries.fetch(File.join(root, relative))
+    abort "#{filename} #{relative} is not executable" if (executable.fetch(:mode) & 0o111).zero?
+  end
+
+  metadata = JSON.parse(entries.fetch(File.join(root, "share/hive/build-metadata.json")).fetch(:data))
+  abort "#{filename} metadata version mismatch" unless metadata["version"] == version
+  abort "#{filename} metadata target mismatch" unless metadata["target"] == target
+  abort "#{filename} metadata packer mismatch" unless metadata["packer"] == builder.fetch("packer")
+  abort "#{filename} metadata packer version mismatch" unless metadata["packer_version"] == builder.fetch("packer_version")
+  abort "#{filename} metadata Ruby mismatch" unless metadata["embedded_ruby"] == builder.fetch("embedded_ruby")
+  abort "#{filename} metadata builder image mismatch" unless metadata["builder_image"] == builder.fetch("linux_image")
+  unless metadata["builder_image_digest"] == builder.fetch("linux_image_digest")
+    abort "#{filename} metadata builder image digest mismatch"
+  end
+  unless metadata["builder_definition"] == builder.fetch("definition") &&
+         metadata["builder_definition_sha256"] == builder.fetch("definition_sha256")
+    abort "#{filename} metadata builder definition mismatch"
+  end
+  commits << metadata.fetch("source_commit")
+
+  destination = File.join(output_dir, filename)
+  FileUtils.cp(archive, destination) unless archive == destination
+  assets << {
+    "name" => filename,
+    "target" => target,
+    "sha256" => Digest::SHA256.file(destination).hexdigest,
+    "size" => File.size(destination),
+    "minimum_os" => target_spec.fetch("minimum_os"),
+    "architecture" => target_spec.fetch("architecture")
+  }
+end
+
+abort "target artifacts came from different commits" unless commits.uniq.one?
+
+release = {
+  "schema_version" => SPEC.fetch("schema_version"),
+  "repository" => SPEC.fetch("repository"),
+  "version" => version,
+  "tag" => tag,
+  "source_commit" => commits.first,
+  "builder" => builder,
+  "assets" => assets.sort_by { |asset| asset.fetch("name") }
+}
+installer_source = File.join(ROOT, "install.sh")
+abort "release installer is missing or not executable" unless File.file?(installer_source) && File.executable?(installer_source)
+installer_destination = File.join(output_dir, "install.sh")
+FileUtils.cp(installer_source, installer_destination)
+installer_sha = Digest::SHA256.file(installer_destination).hexdigest
+File.write(File.join(output_dir, "install.sh.sha256"), "#{installer_sha}  install.sh\n")
+release["installer"] = { "name" => "install.sh", "sha256" => installer_sha,
+                         "checksum" => "install.sh.sha256" }
+File.write(File.join(output_dir, "release.json"), JSON.pretty_generate(release) + "\n")
+checksummed_names = release.fetch("assets").map { |asset| asset.fetch("name") }
+checksummed_names.concat(%w[install.sh install.sh.sha256 release.json])
+checksums = checksummed_names.sort.map do |name|
+  "#{Digest::SHA256.file(File.join(output_dir, name)).hexdigest}  #{name}"
+end
+File.write(File.join(output_dir, "SHA256SUMS"), checksums.join("\n") + "\n")
