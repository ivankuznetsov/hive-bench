@@ -0,0 +1,27 @@
+name: uninstall_preserves_work
+description: Core cleanup removes owned installation/control files but never accumulated work.
+tags: [install, uninstall, preservation, cli-only]
+removable:
+  - receipt-owned hive/hv wrappers
+  - receipt-owned versioned payload
+  - user service registration
+  - XDG config and cache under purge
+  - .hive/project.yml only with explicit scope and consent
+preserved:
+  - .hive-state/**
+  - XDG_STATE_HOME/hive/** except install-receipt.json
+  - agent marketplace and package state
+  - agent credentials and provider keys
+  - unrelated hive and hv commands
+steps:
+  - kind: write_file
+    path: "{sandbox}/.hive-state/preservation-sentinel"
+    content: "durable acceptance work\n"
+  - kind: cli
+    args: [uninstall, --project-metadata, --yes]
+  - kind: state_assert
+    path: "{sandbox}/.hive/project.yml"
+    absent: true
+  - kind: state_assert
+    path: "{sandbox}/.hive-state/preservation-sentinel"
+    contains: "durable acceptance work"
diff --git a/test/integration/agent_package_doctor_test.rb b/test/integration/agent_package_doctor_test.rb
