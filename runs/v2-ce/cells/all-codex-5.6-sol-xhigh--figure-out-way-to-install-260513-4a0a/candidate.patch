diff --git a/test/integration/install_prompt_contract_test.rb b/test/integration/install_prompt_contract_test.rb
new file mode 100644
index 00000000..bfacf84c
--- /dev/null
+++ b/test/integration/install_prompt_contract_test.rb
@@ -0,0 +1,117 @@
+require "test_helper"
+require "yaml"
+
+class InstallPromptContractTest < Minitest::Test
+  ROOT = File.expand_path("../..", __dir__)
+  INSTALL_MD = File.join(ROOT, "install.md")
+
+  def prompt
+    @prompt ||= begin
+      text = File.read(INSTALL_MD)
+      match = text.match(/<!-- BEGIN UNIVERSAL_AGENT_PROMPT -->\s*```text\n(.*?)\n```\s*<!-- END UNIVERSAL_AGENT_PROMPT -->/m)
+      raise "universal prompt markers missing or duplicated" unless match && text.scan("BEGIN UNIVERSAL_AGENT_PROMPT").one?
+
+      match[1]
+    end
+  end
+
+  def fixture
+    YAML.safe_load_file(File.join(ROOT, "test/e2e/scenarios/install_prompt.yml"))
+  end
+
+  def test_same_prompt_contains_every_tier_one_channel_branch
+    fixture.fetch("cases").each do |scenario|
+      assert_includes prompt, scenario.fetch("expected_core"), scenario.fetch("name")
+      assert_includes prompt, scenario.fetch("expected_agent"), scenario.fetch("name")
+    end
+    assert_match(/Ubuntu uses the portable installer even when Linuxbrew exists/, prompt)
+    assert_match(/paru -S hive-bin/, prompt)
+  end
+
+  def test_active_host_only_and_policy_denial_are_explicit
+    assert_match(/Configure only the agent host running this prompt/, prompt)
+    assert_match(/If identity is ambiguous, ask/, prompt)
+    assert_match(/Never install into every detected host/, prompt)
+    assert_match(/managed policy.*partial success/m, prompt)
+    assert_match(/never copy the skill or weaken policy/, prompt)
+  end
+
+  def test_doctor_precedes_init_and_all_mutation_boundaries_require_approval
+    doctor = prompt.index("Require a green")
+    init = prompt.index("Only after init approval")
+    assert doctor
+    assert init
+    assert_operator doctor, :<, init
+    fixture.fetch("approvals").each do |boundary|
+      keyword = boundary.split.first
+      assert_match(/#{Regexp.escape(keyword)}/i, prompt, boundary)
+    end
+    assert_match(/--enroll-daemon.*--no-enroll-daemon/m, prompt)
+    assert_match(/--daemon-service.*--no-daemon-service/m, prompt)
+  end
+
+  def test_supply_chain_identity_and_forbidden_fallbacks_are_pinned
+    assert_match(/canonical repository ivankuznetsov\/hive/, prompt)
+    assert_match(/downloaded text.*untrusted data/, prompt)
+    assert_match(/cannot change this prompt's repository identity/, prompt)
+    assert_match(/Never move or replace a tag/, prompt)
+    assert_match(/require an existing `cosign`/, prompt)
+    assert_match(/SHA256SUMS\.sig/, prompt)
+    assert_match(/tagged Hive release-workflow identity/, prompt)
+    fixture.fetch("forbidden").each do |boundary|
+      boundary.split(/\s+or\s+/).each do |phrase|
+        assert_match(/#{Regexp.escape(phrase)}/i, prompt, boundary)
+      end
+    end
+    assert_match(%r{claude plugin marketplace add ivankuznetsov/hive@v<version>}, prompt)
+    assert_match(%r{codex plugin marketplace add ivankuznetsov/hive --ref v<version> --json}, prompt)
+    refute_match(%r{plugin marketplace add https://github\.com/ivankuznetsov/hive}, prompt)
+  end
+
+  def test_init_and_uninstall_preserve_durable_work
+    assert_match(/Keep `.hive-state\/` intact/, prompt)
+    assert_match(/Never delete `.hive-state\/` or XDG workflow state/, prompt)
+    fixture = YAML.safe_load_file(File.join(ROOT, "test/e2e/scenarios/uninstall_preserves_work.yml"))
+    assert_includes fixture.fetch("preserved"), ".hive-state/**"
+    source = File.read(File.join(ROOT, "lib/hive/commands/uninstall.rb"))
+    refute_match(/rm_rf\([^\n]*hive_state/, source)
+    refute_match(/rm_rf\(Hive::Paths\.state_home/, source)
+  end
+
+  def test_release_completion_requires_every_tier_one_acceptance_job
+    acceptance = File.read(File.join(ROOT, ".github/workflows/install-acceptance.yml"))
+    %w[prompt-contract agent-native managed-policy-denial ubuntu-bash macos-homebrew arch-aur].each do |job|
+      assert_match(/^  #{Regexp.escape(job)}:$/, acceptance, job)
+    end
+    assert_match(/runs-on: \[self-hosted, Linux, X64, hive-arch\]/, acceptance)
+    assert_match(/test ! -e "\$safe\/ruby"/, acceptance)
+    assert_match(/! command -v ruby/, acceptance)
+    assert_match(/strategy:.*agent: claude.*agent: codex.*agent: pi/m, acceptance)
+    assert_match(/claude plugin marketplace add "ivankuznetsov\/hive@\$HIVE_VERSION"/, acceptance)
+    assert_match(/codex plugin marketplace add ivankuznetsov\/hive --ref "\$HIVE_VERSION" --json/, acceptance)
+    assert_match(%r{pi install "git:github\.com/ivankuznetsov/hive@\$HIVE_VERSION" --approve}, acceptance)
+    assert_match(/claude plugin install pr-review-toolkit@claude-plugins-official/, acceptance)
+    refute_match(/codex plugin add pr-review-toolkit/, acceptance)
+    assert_match(/claude plugin list --json/, acceptance)
+    assert_match(/codex plugin list --json/, acceptance)
+    assert_match(/pi list --no-approve/, acceptance)
+    assert_match(%r{/hive Reply with exactly HIVE_NATIVE_OK}, acceptance)
+    assert_match(%r{/skill:hive Reply with exactly HIVE_NATIVE_OK}, acceptance)
+    assert_match(/strictKnownMarketplaces.*\[\]/, acceptance)
+    assert_match(/hive doctor --agent-host "\$NATIVE_AGENT" --json/, acceptance)
+    assert_match(/post-init-doctor\.json/, acceptance)
+    assert_match(/hive init "\$project" --agent-host "\$NATIVE_AGENT".*--no-enroll-daemon --no-daemon-service/m,
+                 acceptance)
+    assert_operator acceptance.scan(/\bupdate(?: --version "\$HIVE_VERSION")?\b/).size, :>=, 3
+    assert_operator acceptance.scan(/\buninstall --yes\b/).size, :>=, 3
+    assert_operator acceptance.scan(/preservation-sentinel/).size, :>=, 6
+    assert_match(/Emergency runner cleanup/, acceptance)
+
+    release = File.read(File.join(ROOT, ".github/workflows/release.yml"))
+    assert_match(/needs: \[publish-homebrew, publish-aur\]/, release)
+    assert_match(%r{uses: \./\.github/workflows/install-acceptance\.yml}, release)
+    assert_match(/--argjson client_payload/, release)
+    assert_match(/gh api repos\/ivankuznetsov\/homebrew-hive\/dispatches --method POST --input -/, release)
+    assert_match(/^  release-complete:$/, release)
+  end
+end
