@@ -0,0 +1,79 @@
+require "test_helper"
+require "json"
+require "open3"
+
+class DoctorCliContractTest < Minitest::Test
+  include HiveTestHelper
+
+  BIN = File.expand_path("../../bin/hive", __dir__)
+
+  def test_config_load_failure_is_still_a_versioned_json_envelope
+    with_tmp_dir do |dir|
+      home = File.join(dir, "config")
+      FileUtils.mkdir_p(home)
+      File.write(File.join(home, "config.yml"), "registered_projects: [\n")
+
+      out, err, status = Open3.capture3(
+        { "HIVE_HOME" => home }, BIN, "doctor", "--json", chdir: dir
+      )
+
+      assert_equal 78, status.exitstatus, err
+      envelope = JSON.parse(out)
+      assert_equal "hive-doctor.v1", envelope["schema"]
+      assert_equal [], envelope["checks"]
+      assert_equal 1, envelope.dig("summary", "errors")
+      assert_equal "config", envelope.dig("error", "error_kind")
+    end
+  end
+
+  def test_active_host_flag_checks_only_pi_on_a_clean_host
+    with_tmp_dir do |dir|
+      home = File.join(dir, "home")
+      config = File.join(dir, "config")
+      FileUtils.mkdir_p(File.join(home, ".pi/agent/skills/ce-brainstorm"))
+      FileUtils.mkdir_p(File.join(home, ".pi/agent/skills/wiki-plan"))
+      FileUtils.mkdir_p(File.join(home, ".pi/agent/skills/ce-code-review"))
+      File.write(File.join(home, ".pi/agent/skills/ce-brainstorm/SKILL.md"), "---\nname: ce-brainstorm\n---\n")
+      File.write(File.join(home, ".pi/agent/skills/wiki-plan/SKILL.md"), "---\nname: wiki-plan\n---\n")
+      File.write(File.join(home, ".pi/agent/skills/ce-code-review/SKILL.md"), "---\nname: ce-code-review\n---\n")
+      FileUtils.mkdir_p(config)
+      File.write(File.join(config, "config.yml"), { "registered_projects" => [] }.to_yaml)
+      fake_pi = File.join(dir, "pi")
+      File.write(fake_pi, "#!/bin/sh\necho 'pi 99.0.0'\n")
+      FileUtils.chmod(0o755, fake_pi)
+
+      out, err, status = Open3.capture3(
+        { "HOME" => home, "HIVE_HOME" => config, "HIVE_PI_BIN" => fake_pi },
+        BIN, "doctor", "--agent-host=pi", "--json", chdir: dir
+      )
+
+      assert_equal 0, status.exitstatus, err
+      envelope = JSON.parse(out)
+      assert_equal "pi", envelope["active_agent_host"]
+      agent_rows = envelope.fetch("checks").select { |row| row["label"].start_with?("agent/") }
+      assert_equal [ "agent/pi" ], agent_rows.map { |row| row.fetch("label") }
+      stage_rows = envelope.fetch("checks").select { |row| row["kind"] == "stage" }
+      assert_equal %w[pi pi], stage_rows.map { |row| row.fetch("agent") }
