diff --git a/lib/hive/commands/daemon/service_installer.rb b/lib/hive/commands/daemon/service_installer.rb
new file mode 100644
index 00000000..e55b965a
--- /dev/null
+++ b/lib/hive/commands/daemon/service_installer.rb
@@ -0,0 +1,246 @@
+require "cgi"
+require "fileutils"
+require "rbconfig"
+require "shellwords"
+require "hive/assets"
+require "hive/agent_profiles"
+require "hive/config"
+require "hive/paths"
+require "hive/executable"
+
+module Hive
+  module Commands
+    class Daemon
+      # Idempotent owner of Hive's one per-user daemon service. Project
+      # enrollment remains a separate config concern (`daemon enable`).
+      class ServiceInstaller
+        LABEL = "local.hive-daemon".freeze
+        UNIT = "hive-daemon.service".freeze
+
+        attr_reader :messages
+
+        def initialize(host_os: RbConfig::CONFIG["host_os"], home: nil, binary_path: nil,
+                       runner: nil, systemctl_available: nil, config: {})
+          @host_os = host_os
+          @home = File.expand_path(home || ENV["HOME"] || Dir.home)
+          @binary_path = binary_path
+          @runner = runner || ->(argv) { system(*argv) }
+          @systemctl_available = systemctl_available
+          @config = config
+          @messages = []
+        end
+
+        def install!(activate:)
+          return unsupported unless supported?
+
+          content = platform == :macos ? render_launchd : render_systemd
+          written = write_if_safe(target_path, content)
+          return written if written == :drifted
+
+          reconcile_activation(activate, written: written) ? :ok : :failed
+        end
+
+        def status
+          return { status: :unsupported, path: nil, registered: false, active: false } unless supported?
+
+          exists = File.file?(target_path) && !File.symlink?(target_path)
+          expected = exists && File.read(target_path) == (platform == :macos ? render_launchd : render_systemd)
+          active = exists && manager_status
+          { status: expected ? :installed : (exists ? :drifted : :absent), path: target_path,
+            registered: exists, active: active }
+        end
+
+        def remove!
+          return unsupported unless supported?
+
+          path = target_path
+          if File.symlink?(path)
+            @messages << "refusing to remove symlinked service file #{path}; remove it manually"
+            return :unsafe
+          end
+          file_exists = File.exist?(path)
+          active = (platform == :macos || !file_exists) && manager_status
+          return :ok unless file_exists || active
+
+          return :failed unless deregister(active: active)
+
+          File.delete(path) if File.file?(path)
+          reload_manager ? :ok : :failed
+        end
+
+        def target_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/#{LABEL}.plist")
+          when :linux then File.join(@home, ".config/systemd/user/#{UNIT}")
+          end
+        end
+
+        private
+
+        def platform
+          return :macos if @host_os.match?(/darwin/i)
+          return :linux if @host_os.match?(/linux/i)
+
+          :unsupported
+        end
+
+        def supported? = platform != :unsupported
+
+        def unsupported
+          @messages << "daemon service installation is unsupported on this platform; run `hive daemon start` manually"
+          :unsupported
+        end
+
+        def write_if_safe(path, content)
+          if File.exist?(path)
+            if File.symlink?(path)
+              @messages << "refusing symlinked service file #{path}"
+              return :drifted
+            end
+            return :unchanged if File.read(path) == content
+
+            @messages << "customized service at #{path} was preserved; remove it or reconcile manually"
+            return :drifted
+          end
+
+          FileUtils.mkdir_p(File.dirname(path))
+          Hive::Paths.atomic_write(path, content, mode: 0o600)
+          :written
+        end
+
+        def reconcile_activation(activate, written:)
+          return true unless activate
+
+          if platform == :macos
+            return true if written == :unchanged && manager_status
+
+            run([ "launchctl", "bootstrap", "gui/#{Process.uid}", target_path ])
+          elsif systemctl_available?
+            run(%w[systemctl --user daemon-reload]) &&
+              run(%w[systemctl --user enable --now hive-daemon.service])
+          else
+            @messages << "systemd user manager is unavailable; the unit was written but not enabled or started"
+            false
+          end
+        end
+
+        def manager_status
+          if platform == :macos
+            run([ "launchctl", "print", "gui/#{Process.uid}/#{LABEL}" ], quiet: true)
+          elsif systemctl_available?
+            run(%w[systemctl --user is-active --quiet hive-daemon.service], quiet: true)
+          else
+            false
+          end
+        end
+
+        def deregister(active:)
+          if platform == :macos
+            return true unless active
+
+            target = if File.exist?(target_path)
+              [ "gui/#{Process.uid}", target_path ]
+            else
+              [ "gui/#{Process.uid}/#{LABEL}" ]
+            end
+            run([ "launchctl", "bootout", *target ])
+          elsif systemctl_available?
+            run(%w[systemctl --user disable --now hive-daemon.service])
+          else
+            @messages << "systemd user manager is unavailable; the service file was preserved"
+            false
+          end
+        end
+
+        def reload_manager
+          return true unless platform == :linux
+          unless systemctl_available?
+            @messages << "systemd user manager is unavailable; daemon-reload was not run"
+            return false
+          end
+
+          run(%w[systemctl --user daemon-reload])
+        end
+
+        def run(argv, quiet: false)
+          result = @runner.call(argv)
+          ok = result.respond_to?(:success?) ? result.success? : !!result
+          @messages << "service manager command failed: #{argv.join(' ')}" unless ok || quiet
+          ok
+        rescue Errno::ENOENT => e
+          @messages << "service manager unavailable: #{e.message}" unless quiet
+          false
+        end
+
+        def systemctl_available?
+          return @systemctl_available unless @systemctl_available.nil?
+
+          system("systemctl", "--user", "--version", out: File::NULL, err: File::NULL)
+        rescue Errno::ENOENT
+          false
+        end
+
+        def resolved_binary
+          candidate = @binary_path || Hive::Executable.path
+          unless candidate && File.file?(candidate) && File.executable?(candidate)
+            raise Hive::ConfigError,
+                  "cannot install daemon service: package-owned hive/hv executable was not found"
+          end
+
+          File.expand_path(candidate)
+        end
+
+        def service_path
+          dirs = [ File.dirname(resolved_binary) ]
+          configured_agent_names.each do |name|
+            profile = Hive::AgentProfiles.lookup(name.to_sym, cfg: @config)
+            found = profile.bin.include?(File::SEPARATOR) ? profile.bin : which(profile.bin)
+            dirs << File.dirname(File.expand_path(found)) if found
+          rescue Hive::ConfigError
+            next
+          end
+          %w[git gh].each do |command|
+            found = which(command)
+            dirs << File.dirname(found) if found
+          end
+          dirs.concat(%w[/opt/homebrew/bin /usr/local/bin /usr/bin /bin])
+          dirs.uniq.join(File::PATH_SEPARATOR)
+        end
+
+        def configured_agent_names
+          names = Hive::Config::ROLE_AGENT_PATHS.filter_map { |path| @config.dig(*path) }
+          names = Hive::AgentProfiles.registered_names if names.empty?
+          names.map(&:to_sym).uniq
+        end
+
+        def which(name)
+          return File.expand_path(name) if name.include?(File::SEPARATOR) && File.executable?(name)
+
+          ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+            candidate = File.join(dir, name)
+            return File.expand_path(candidate) if File.file?(candidate) && File.executable?(candidate)
+          end
+          nil
+        end
+
+        def render_systemd
+          Hive::Assets.read("examples/systemd/hive-daemon.service")
+            .sub(/^ExecStart=.*$/, "ExecStart=#{Shellwords.escape(resolved_binary)} daemon start")
+            .sub(/^Type=simple$/, "Type=simple\nEnvironment=\"PATH=#{systemd_quote(service_path)}\"")
+        end
+
+        def render_launchd
+          Hive::Assets.read("examples/launchd/hive-daemon.plist")
+            .gsub("/Users/YOU/.local/bin/hive", CGI.escapeHTML(resolved_binary))
+            .gsub("/Users/YOU/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
+                  CGI.escapeHTML(service_path))
+            .gsub("/Users/YOU/Library/Logs", CGI.escapeHTML(File.join(@home, "Library/Logs")))
+        end
+
+        def systemd_quote(value)
+          value.gsub("\\", "\\\\").gsub('"', '\\"').gsub("%", "%%")
+        end
+      end
+    end
+  end
+end
