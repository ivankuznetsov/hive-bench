diff --git a/lib/hive/skill_check/native_packages.rb b/lib/hive/skill_check/native_packages.rb
new file mode 100644
index 00000000..e6ac2bf7
--- /dev/null
+++ b/lib/hive/skill_check/native_packages.rb
@@ -0,0 +1,237 @@
+require "json"
+require "open3"
+require "pathname"
+require "timeout"
+
+module Hive
+  module SkillCheck
+    # Confirms that files under an agent package/plugin cache still belong to
+    # an enabled package according to the host's native package manager. Cache
+    # files alone are not authoritative: disable, policy denial, interrupted
+    # removal, and stale marketplace snapshots can all leave them behind.
+    module NativePackages
+      LIST_TIMEOUT_SEC = 3
+      NEGATIVE_STATES = %w[blocked denied disabled unavailable uninstalled].freeze
+
+      module_function
+
+      def validate(agent:, candidate:, invocation:, project_root: nil)
+        package = managed_package(agent, candidate, invocation, project_root: project_root)
+        return [ true, nil ] unless package
+
+        result = list(agent, project_root: project_root)
+        unless result.fetch(:ok)
+          detail = result.fetch(:error).to_s.strip
+          detail = "command failed" if detail.empty?
+          return [ false, "#{agent}: native package list failed (#{detail}); refusing stale cache #{candidate}" ]
+        end
+
+        listed = if agent == :pi
+          text_lists_package?(result.fetch(:output), package)
+        else
+          json_lists_enabled_package?(
+            result.fetch(:output), package, expected_version: cached_version(candidate, package)
+          )
+        end
+        return [ true, nil ] if listed
+
+        [ false,
+          "#{agent}: package #{package.inspect} is not enabled in native list output; " \
+          "ignoring stale or policy-blocked cache #{candidate}" ]
+      end
+
+      def reset!
+        @list_cache = {}
+      end
+
+      def list(agent, project_root: nil)
+        key = [ agent, binary(agent), ENV["HOME"], ENV["CLAUDE_CONFIG_DIR"],
+                ENV["CODEX_HOME"], ENV["PI_CODING_AGENT_DIR"], project_root ]
+        cache.fetch(key) { cache[key] = run_list(agent, project_root: project_root) }
+      end
+
+      def run_list(agent, project_root: nil)
+        argv = case agent
+        when :claude then [ binary(agent), "plugin", "list", "--json" ]
+        when :codex then [ binary(agent), "plugin", "list", "--json" ]
+        when :pi then [ binary(agent), "list", "--no-approve" ]
+        else return { ok: false, output: "", error: "unsupported agent #{agent}" }
+        end
+
+        options = {}
+        options[:chdir] = File.expand_path(project_root) if project_root
+        out, err, status = Timeout.timeout(LIST_TIMEOUT_SEC) { Open3.capture3(*argv, **options) }
+        { ok: status.success?, output: out.to_s, error: err.to_s }
+      rescue Timeout::Error
+        { ok: false, output: "", error: "timed out after #{LIST_TIMEOUT_SEC}s" }
+      rescue SystemCallError => e
+        { ok: false, output: "", error: e.message }
+      end
+
+      def binary(agent)
+        key = { claude: "HIVE_CLAUDE_BIN", codex: "HIVE_CODEX_BIN", pi: "HIVE_PI_BIN" }.fetch(agent)
+        value = ENV[key].to_s
+        value.empty? ? agent.to_s : value
+      end
+
+      def managed_package(agent, candidate, invocation, project_root: nil)
+        path = File.expand_path(candidate)
+        case agent
+        when :claude, :codex
+          invocation.plugin || plugin_from_path(path)
+        when :pi
+          pi_package_from_path(path, project_root: project_root)
+        end
+      end
+
+      def plugin_from_path(path)
+        match = path.match(%r{/plugins/cache/[^/]+/([^/]+)/})
+        return match[1] if match
+
+        path[%r{/plugins/marketplaces/[^/]+/plugins/([^/]+)/}, 1]
+      end
+
+      def pi_package_from_path(path, project_root: nil)
+        if (match = path.match(%r{/node_modules/((?:@[^/]+/)?[^/]+)/}))
+          return match[1]
+        end
+
+        pi_git_roots(project_root).each do |git_root|
+          next unless contained?(path, git_root)
+
+          relative = path.delete_prefix(File.expand_path(git_root) + File::SEPARATOR)
+          components = relative.split(File::SEPARATOR)
+          return components[2] if components.length >= 3
+        end
+
+        explicit_pi_package_roots(project_root).each do |root, identifier|
+          return identifier if contained?(path, root)
+        end
+
+        nil
+      end
+
+      def pi_git_roots(project_root)
+        home = ENV["HOME"] || Dir.home
+        pi_root = ENV["PI_CODING_AGENT_DIR"].to_s
+        pi_root = File.join(home, ".pi/agent") if pi_root.empty?
+        roots = [ File.join(File.expand_path(pi_root), "git") ]
+        roots << File.join(File.expand_path(project_root), ".pi/git") if project_root
+        roots
+      end
+
+      def explicit_pi_package_roots(project_root)
+        roots = ENV["PI_PACKAGE_DIR"].to_s.split(File::PATH_SEPARATOR).reject(&:empty?).map do |root|
+          expanded = File.expand_path(root)
+          [ expanded, File.basename(expanded) ]
+        end
+
+        home = ENV["HOME"] || Dir.home
+        pi_root = ENV["PI_CODING_AGENT_DIR"].to_s
+        pi_root = File.join(home, ".pi/agent") if pi_root.empty?
+        settings = [ File.join(pi_root, "settings.json") ]
+        settings << File.join(File.expand_path(project_root), ".pi/settings.json") if project_root
+        settings.each do |path|
+          data = JSON.parse(File.read(path))
+          Array(data["packages"]).each do |entry|
+            source = entry.is_a?(Hash) ? entry["source"] : entry
+            next unless source.is_a?(String) && local_source?(source)
+
+            root = expand_local_source(source, File.dirname(path), home)
+            roots << [ root, File.basename(root) ]
+          end
+        rescue JSON::ParserError, SystemCallError
+          next
+        end
+        roots
+      end
+
+      def local_source?(source)
+        !source.strip.empty? && !source.start_with?("npm:", "git:", "http://", "https://", "ssh://", "git://")
+      end
+
+      def expand_local_source(source, base, home)
+        return home if source == "~"
+        return File.join(home, source.delete_prefix("~/")) if source.start_with?("~/")
+
+        Pathname.new(source).absolute? ? File.expand_path(source) : File.expand_path(source, base)
+      end
+
+      def contained?(path, root)
+        expanded = File.expand_path(root)
+        path == expanded || path.start_with?(expanded + File::SEPARATOR)
+      end
+
+      def json_lists_enabled_package?(output, package, expected_version: nil)
+        parsed = JSON.parse(output)
+        hashes_in(parsed).any? do |entry|
+          entry_enabled?(entry) &&
+            entry_identifiers(entry).any? { |value| identifier_matches?(value, package) } &&
+            entry_version_matches?(entry, expected_version)
+        end
+      rescue JSON::ParserError
+        false
+      end
+
+      def hashes_in(value)
+        case value
+        when Hash then [ value ] + value.values.flat_map { |child| hashes_in(child) }
+        when Array then value.flat_map { |child| hashes_in(child) }
+        else []
+        end
+      end
+
+      def entry_identifiers(entry)
+        entry.filter_map do |key, value|
+          value.to_s if %w[name id plugin package source].include?(key.to_s.downcase) &&
+                        (value.is_a?(String) || value.is_a?(Symbol))
+        end
+      end
+
+      def entry_enabled?(entry)
+        hashes_in(entry).all? do |node|
+          node.none? do |key, value|
+            normalized_key = key.to_s.downcase
+            (value == false && %w[enabled installed active].include?(normalized_key)) ||
+              (value == true && %w[disabled blocked denied].include?(normalized_key)) ||
+              (value.is_a?(String) && %w[status state installation].include?(normalized_key) &&
+                NEGATIVE_STATES.include?(value.downcase))
+          end
+        end
+      end
+
+      def entry_version_matches?(entry, expected_version)
+        return true unless expected_version
+
+        versions = hashes_in(entry).flat_map do |node|
+          node.filter_map do |key, value|
+            value.to_s if key.to_s.downcase == "version" && (value.is_a?(String) || value.is_a?(Numeric))
+          end
+        end
+        versions.empty? || versions.include?(expected_version)
+      end
+
+      def cached_version(candidate, package)
+        path = File.expand_path(candidate)
+        path[%r{/plugins/cache/[^/]+/#{Regexp.escape(package)}/([^/]+)/}, 1]
+      end
+
+      def identifier_matches?(value, package)
+        normalized = value.to_s.downcase
+        wanted = package.to_s.downcase
+        normalized == wanted || normalized.start_with?("#{wanted}@") || normalized.end_with?("/#{wanted}")
+      end
+
+      def text_lists_package?(output, package)
+        normalized = output.to_s.downcase
+        wanted = package.to_s.downcase
+        normalized.match?(/(?:\A|[^a-z0-9_.@\/-])#{Regexp.escape(wanted)}(?:\z|[^a-z0-9_.@\/-])/) ||
+          normalized.include?("/#{wanted}")
+      end
+
+      def cache
+        @list_cache ||= {}
+      end
+    end
+  end
+end
