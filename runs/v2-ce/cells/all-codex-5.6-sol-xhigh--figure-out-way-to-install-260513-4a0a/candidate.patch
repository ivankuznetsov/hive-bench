index 00000000..06abdc25
--- /dev/null
+++ b/test/integration/agent_package_doctor_test.rb
@@ -0,0 +1,81 @@
+require "test_helper"
+require "stringio"
+require "hive/commands/doctor"
+
+class AgentPackageDoctorTest < Minitest::Test
+  include HiveTestHelper
+
+  def write(path)
+    FileUtils.mkdir_p(File.dirname(path))
+    File.write(path, "---\nname: fixture\ndescription: fixture\n---\n")
+  end
+
+  def config(agent)
+    {
+      "brainstorm" => { "agent" => agent, "skill" => "/compound-engineering:ce-brainstorm" },
+      "plan" => { "agent" => agent, "skill" => "/wiki-plan" },
+      "review" => {
+        "reviewers" => [
+          { "kind" => "agent", "name" => "ce", "agent" => agent, "skill" => "ce-code-review" },
+          { "kind" => "agent", "name" => "pr", "agent" => agent, "skill" => "pr-review-toolkit:review-pr" }
+        ]
+      }
+    }
+  end
+
+  def install_fixtures(home, agent)
+    case agent
+    when "claude"
+      write("#{home}/.claude/skills/hive/SKILL.md")
+      write("#{home}/.claude/skills/wiki-plan/SKILL.md")
+      write("#{home}/.claude/plugins/cache/mp/compound-engineering/1.0.0/skills/ce-brainstorm/SKILL.md")
+      write("#{home}/.claude/plugins/cache/mp/compound-engineering/1.0.0/skills/ce-code-review/SKILL.md")
+      write("#{home}/.claude/plugins/cache/mp/pr-review-toolkit/1.0.0/skills/review-pr/SKILL.md")
+    when "codex"
+      write("#{home}/.codex/skills/hive/SKILL.md")
+      write("#{home}/.codex/skills/wiki-plan/SKILL.md")
+      write("#{home}/.codex/plugins/cache/mp/compound-engineering/1.0.0/skills/ce-brainstorm/SKILL.md")
+      write("#{home}/.codex/plugins/cache/mp/compound-engineering/1.0.0/skills/ce-code-review/SKILL.md")
+      write("#{home}/.codex/plugins/cache/mp/pr-review-toolkit/1.0.0/skills/review-pr/SKILL.md")
+    when "pi"
+      %w[hive wiki-plan ce-brainstorm ce-code-review review-pr].each do |skill|
+        write("#{home}/.pi/agent/skills/#{skill}/SKILL.md")
+      end
+    end
+  end
+
+  def test_each_host_resolves_hive_and_default_dependencies
+    with_tmp_dir do |home|
+      previous = ENV["HOME"]
+      previous_claude = ENV["HIVE_CLAUDE_BIN"]
+      previous_codex = ENV["HIVE_CODEX_BIN"]
+      ENV["HOME"] = home
+      %w[claude codex].each do |agent|
+        path = File.join(home, "fake-#{agent}")
+        File.write(path, <<~SH)
+          #!/bin/sh
+          printf '%s\n' '[{"name":"hive","enabled":true},{"name":"compound-engineering","enabled":true},{"name":"pr-review-toolkit","enabled":true}]'
+        SH
+        FileUtils.chmod(0o755, path)
+        ENV["HIVE_#{agent.upcase}_BIN"] = path
+      end
+      Hive::SkillCheck::NativePackages.reset!
+      %w[claude codex pi].each do |agent|
+        install_fixtures(home, agent)
+        profile = Hive::AgentProfiles.lookup(agent.to_sym)
+        status, = profile.verify_skill(profile.format_skill_invocation("hive"))
+        assert_equal :present, status, "#{agent} should resolve the installed Hive skill"
+        out = StringIO.new
+        code = Hive::Commands::Doctor.new(
+          config: config(agent), project_root: nil, output: out, mode: :skills
+        ).call
+        assert_equal 0, code, "#{agent} dependency doctor failed:\n#{out.string}"
+      end
+    ensure
+      previous.nil? ? ENV.delete("HOME") : ENV["HOME"] = previous
+      previous_claude.nil? ? ENV.delete("HIVE_CLAUDE_BIN") : ENV["HIVE_CLAUDE_BIN"] = previous_claude
+      previous_codex.nil? ? ENV.delete("HIVE_CODEX_BIN") : ENV["HIVE_CODEX_BIN"] = previous_codex
+      Hive::SkillCheck::NativePackages.reset!
+    end
+  end
+end
