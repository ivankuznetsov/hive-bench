+++ b/test/unit/homebrew_formula_test.rb
@@ -0,0 +1,56 @@
+require "test_helper"
+require "json"
+require "open3"
+
+class HomebrewFormulaTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+
+  def release(path, sha: "a" * 64)
+    File.write(path, JSON.generate(
+      version: "0.1.0",
+      assets: [ { target: "arm64-darwin", sha256: sha } ]
+    ))
+  end
+
+  def render(release_path, output)
+    Open3.capture3(
+      "ruby", File.join(ROOT, "packaging/homebrew/render.rb"), release_path,
+      File.join(ROOT, "packaging/homebrew/hive.rb.erb"), output
+    )
+  end
+
+  def test_renders_canonical_binary_formula_and_receipt
+    with_tmp_dir do |dir|
+      metadata = File.join(dir, "release.json")
+      output = File.join(dir, "hive.rb")
+      release(metadata)
+      _out, err, status = render(metadata, output)
+      assert status.success?, err
+      formula = File.read(output)
+      assert_includes formula, "hive-0.1.0-arm64-darwin.tar.gz"
+      assert_includes formula, "a" * 64
+      assert_includes formula, 'channel: "brew"'
+      assert_includes formula, 'bin.install "bin/hive", "bin/hv"'
+      refute_match(/depends_on.*ruby/i, formula)
+      refute_match(/service do/, formula, "init owns service consent")
+    end
+  end
+
+  def test_render_rejects_missing_target_and_bad_checksum
+    with_tmp_dir do |dir|
+      metadata = File.join(dir, "release.json")
+      output = File.join(dir, "hive.rb")
+      release(metadata, sha: "bad")
+      _out, err, status = render(metadata, output)
+      refute status.success?
+      assert_match(/invalid.*checksum/, err)
+
+      File.write(metadata, JSON.generate(version: "0.1.0", assets: []))
+      _out, err, status = render(metadata, output)
+      refute status.success?
+      assert_match(/no arm64/, err)
+    end
+  end
+end
