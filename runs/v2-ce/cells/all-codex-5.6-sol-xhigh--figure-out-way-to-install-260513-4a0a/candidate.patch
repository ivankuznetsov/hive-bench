--- /dev/null
+++ b/install.sh
@@ -0,0 +1,286 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+readonly REPOSITORY="ivankuznetsov/hive"
+readonly COSIGN_ISSUER="https://token.actions.githubusercontent.com"
+readonly COSIGN_IDENTITY="https://github.com/ivankuznetsov/hive/.github/workflows/release.yml@refs/tags/"
+readonly CURL_CONNECT_TIMEOUT_SECONDS=10
+readonly CURL_TOTAL_TIMEOUT_SECONDS=120
+readonly CURL_RETRIES=2
+readonly CURL_RETRY_MAX_TIME_SECONDS=300
+
+version="${HIVE_VERSION:-}"
+prefix="${HIVE_PREFIX:-}"
+dry_run=0
+no_color="${NO_COLOR:-}"
+
+die() { printf 'hive installer: %s\n' "$*" >&2; exit 1; }
+note() { printf 'hive installer: %s\n' "$*"; }
+download() {
+  local url="$1" destination="$2"
+  curl \
+    --fail \
+    --silent \
+    --show-error \
+    --location \
+    --connect-timeout "$CURL_CONNECT_TIMEOUT_SECONDS" \
+    --max-time "$CURL_TOTAL_TIMEOUT_SECONDS" \
+    --retry "$CURL_RETRIES" \
+    --retry-delay 1 \
+    --retry-max-time "$CURL_RETRY_MAX_TIME_SECONDS" \
+    --output "$destination" \
+    "$url"
+}
+
+for argument in "$@"; do
+  case "$argument" in
+    --version=*) version="${argument#*=}" ;;
+    --prefix=*) prefix="${argument#*=}" ;;
+    --dry-run) dry_run=1 ;;
+    --help|-h)
+      echo "usage: install.sh [--version=vMAJOR.MINOR.PATCH] [--prefix=/absolute/path] [--dry-run]"
+      exit 0
+      ;;
+    *) die "unknown argument: $argument" ;;
+  esac
+done
+
+[[ "$REPOSITORY" == "ivankuznetsov/hive" ]] || die "canonical repository identity changed"
+if [[ -n "$version" ]]; then
+  [[ "$version" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "invalid version: $version"
+fi
+if [[ -n "$prefix" ]]; then
+  [[ "$prefix" == /* ]] || die "--prefix must be absolute"
+  [[ "$prefix" =~ ^/[A-Za-z0-9_./+-]+$ && "$prefix" != *".."* ]] || die "unsafe --prefix: $prefix"
+  prefix="${prefix%/}"
+fi
+
+os="$(uname -s)"
+arch="$(uname -m)"
+case "$os/$arch" in
+  Darwin/arm64) target="arm64-darwin" ;;
+  Linux/x86_64|Linux/amd64) target="x86_64-linux-gnu" ;;
+  *) die "unsupported platform $os/$arch; tier-1 is macOS arm64 or Linux x86_64" ;;
+esac
+
+xdg_value() {
+  local name="$1" fallback="$2" value
+  value="${!name:-}"
+  [[ -n "$value" ]] && printf '%s' "$value" || printf '%s' "$fallback"
+}
+
+home="${HOME:?HOME must be set}"
+if [[ -n "$prefix" ]]; then
+  bin_home="$prefix/bin"
+  data_root="$prefix/share/hive"
+else
+  bin_home="$(xdg_value XDG_BIN_HOME "$home/.local/bin")"
+  data_root="$(xdg_value XDG_DATA_HOME "$home/.local/share")/hive"
+fi
+state_root="$(xdg_value XDG_STATE_HOME "$home/.local/state")/hive"
+
+tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/hive-install.XXXXXX")"
+chmod 0700 "$tmpdir"
+cleanup() { rm -rf "$tmpdir"; }
+trap cleanup EXIT HUP INT TERM
+
+base_url="https://github.com/$REPOSITORY/releases"
+if [[ -z "$version" ]]; then
+  download "$base_url/latest/download/release.json" "$tmpdir/release.json" || die "cannot download latest release metadata"
+  release_version="$(sed -nE 's/^[[:space:]]*"version":[[:space:]]*"([0-9]+\.[0-9]+\.[0-9]+)",?$/\1/p' "$tmpdir/release.json")"
+  [[ "$release_version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || die "latest release metadata has no valid version"
+  version="v$release_version"
+fi
+plain_version="${version#v}"
+archive="hive-$plain_version-$target.tar.gz"
+tag_url="$base_url/download/$version"
+
+if [[ "$dry_run" == 1 ]]; then
+  note "target=$target version=$version"
+  note "archive=$tag_url/$archive"
+  note "bin=$bin_home data=$data_root state=$state_root"
+  exit 0
+fi
+
+for tool in curl tar sed awk; do command -v "$tool" >/dev/null 2>&1 || die "required tool not found: $tool"; done
+
+download "$tag_url/$archive" "$tmpdir/$archive" || die "archive download failed"
+download "$tag_url/SHA256SUMS" "$tmpdir/SHA256SUMS" || die "checksum download failed"
+checksum_line="$(awk -v file="$archive" '$2 == file && NF == 2 { print }' "$tmpdir/SHA256SUMS")"
+[[ "$(printf '%s\n' "$checksum_line" | wc -l | tr -d ' ')" == 1 ]] || die "checksum entry missing or duplicated for $archive"
+expected="${checksum_line%%  *}"
+[[ "$expected" =~ ^[0-9a-f]{64}$ ]] || die "invalid checksum entry for $archive"
+if command -v sha256sum >/dev/null 2>&1; then
+  actual="$(sha256sum "$tmpdir/$archive" | awk '{print $1}')"
+elif command -v shasum >/dev/null 2>&1; then
+  actual="$(shasum -a 256 "$tmpdir/$archive" | awk '{print $1}')"
+else
+  die "sha256sum or shasum is required"
+fi
+[[ "$actual" == "$expected" ]] || die "checksum mismatch for $archive"
+
+if command -v cosign >/dev/null 2>&1 || [[ "${HIVE_REQUIRE_COSIGN:-0}" == 1 ]]; then
+  command -v cosign >/dev/null 2>&1 || die "cosign verification required but cosign is missing"
+  download "$tag_url/SHA256SUMS.sig" "$tmpdir/SHA256SUMS.sig" || die "signature download failed"
+  download "$tag_url/SHA256SUMS.pem" "$tmpdir/SHA256SUMS.pem" || die "certificate download failed"
+  cosign verify-blob \
+    --certificate "$tmpdir/SHA256SUMS.pem" \
+    --signature "$tmpdir/SHA256SUMS.sig" \
+    --certificate-oidc-issuer "$COSIGN_ISSUER" \
+    --certificate-identity-regexp "^${COSIGN_IDENTITY//./\\.}v[0-9]+\\.[0-9]+\\.[0-9]+$" \
+    "$tmpdir/SHA256SUMS" >/dev/null || die "release signature identity verification failed"
+fi
+
+root="hive-$plain_version-$target"
+while IFS= read -r entry; do
+  [[ -n "$entry" ]] || continue
+  [[ "$entry" != /* && "$entry" != *"../"* && ( "$entry" == "$root" || "$entry" == "$root/"* ) ]] || die "unsafe archive entry: $entry"
+done < <(tar -tzf "$tmpdir/$archive")
+if tar -tvzf "$tmpdir/$archive" | awk '
+  substr($1, 1, 1) == "l" || $0 ~ / link to / { found = 1 }
+  END { exit(found ? 0 : 1) }
+'; then
+  die "archive contains symbolic or hard links"
+fi
+
+mkdir -p "$tmpdir/extracted"
+tar -xzf "$tmpdir/$archive" -C "$tmpdir/extracted"
+extracted="$tmpdir/extracted/$root"
+[[ -s "$extracted/bin/hive" && -x "$extracted/bin/hive" ]] || die "archive contains no executable hive"
+[[ -s "$extracted/bin/hv" && -x "$extracted/bin/hv" ]] || die "archive contains no executable hv"
+for required in templates/hive_config.yml.erb schemas/hive-status.v2.json examples/systemd/hive-daemon.service; do
+  [[ -f "$extracted/share/hive/$required" ]] || die "archive missing runtime asset $required"
+done
+
+mkdir -p "$bin_home" "$data_root/versions" "$state_root"
+version_root="$data_root/versions/$plain_version-$target"
+stage_root="$data_root/versions/.stage-$plain_version-$target-$$"
+existing_receipt="$state_root/install-receipt.json"
+old_version_root=""
+is_direct_version_child() {
+  local candidate="$1" relative
+  [[ "$candidate" == "$data_root/versions/"* ]] || return 1
+  relative="${candidate#"$data_root/versions/"}"
+  [[ -n "$relative" && "$relative" != "." && "$relative" != ".." && "$relative" != */* ]]
+}
+remove_version_tree() {
+  local candidate="$1"
+  is_direct_version_child "$candidate" || die "refusing to remove path outside the version root: $candidate"
+  rm -rf -- "$candidate"
+}
+receipt_owns_wrapper() {
+  local wrapper="$1" command="$2"
+  [[ -n "$old_version_root" && -f "$existing_receipt" && -L "$wrapper" ]] || return 1
+  grep -Fq "\"$wrapper\"" "$existing_receipt" || return 1
+  [[ "$(readlink "$wrapper" 2>/dev/null || true)" == "$old_version_root/bin/$command" ]]
+}
+if [[ -f "$existing_receipt" ]]; then
+  old_asset_root="$(sed -nE 's/^[[:space:]]*"asset_root":[[:space:]]*"([^"]+)",?$/\1/p' "$existing_receipt")"
+  candidate_old="${old_asset_root%/share/hive}"
+  if [[ -n "$old_asset_root" ]]; then
+    [[ "$old_asset_root" == "$candidate_old/share/hive" ]] || die "existing receipt has an unsafe asset_root"
+    is_direct_version_child "$candidate_old" || die "existing receipt has an unsafe asset_root"
+    old_version_name="${candidate_old#"$data_root/versions/"}"
+    [[ "$old_version_name" =~ ^[0-9]+\.[0-9]+\.[0-9]+-(arm64-darwin|x86_64-linux-gnu)$ ]] || \
+      die "existing receipt has an unsafe asset_root"
+    old_version_root="$candidate_old"
+  fi
+fi
+
+remove_version_tree "$stage_root"
+mkdir -p "$stage_root"
+cp -R "$extracted/bin" "$extracted/share" "$stage_root/"
+
+primary="hive"
+existing_hive="$(command -v hive 2>/dev/null || true)"
+destination_hive="$bin_home/hive"
+destination_hive_owned=0
+if receipt_owns_wrapper "$destination_hive" hive; then
+  destination_hive_owned=1
+fi
+if [[ ( -e "$destination_hive" || -L "$destination_hive" ) && "$destination_hive_owned" == 0 ]]; then
+  primary="hv"
+  note "existing non-Hive command 'hive' preserved at $destination_hive; installing Hive as hv"
+elif [[ -n "$existing_hive" ]]; then
+  path_hive_owned=0
+  if [[ "$existing_hive" == "$destination_hive" && "$destination_hive_owned" == 1 ]]; then
+    path_hive_owned=1
+  fi
+  if [[ "$path_hive_owned" == 0 ]]; then
+    primary="hv"
+    note "existing non-Hive command 'hive' preserved at $existing_hive; installing Hive as hv"
+  fi
+fi
+install_hv=1
+if [[ -e "$bin_home/hv" || -L "$bin_home/hv" ]]; then
+  if ! receipt_owns_wrapper "$bin_home/hv" hv; then
+    install_hv=0
+    [[ "$primary" != hv ]] || die "both hive and hv already belong to other programs; refusing to overwrite either"
+    note "existing non-Hive command 'hv' preserved at $bin_home/hv"
+  fi
+fi
+
+if [[ -d "$version_root" ]]; then
+  [[ -x "$version_root/bin/hive" ]] || die "existing version payload is incomplete: $version_root"
+  remove_version_tree "$stage_root"
+else
+  mv "$stage_root" "$version_root"
+fi
+
+json_escape() { sed 's/\\/\\\\/g; s/"/\\"/g' <<<"$1" | tr -d '\n'; }
+receipt_tmp="$state_root/.install-receipt.$$"
+primary_path="$bin_home/$primary"
+extra_owned=""
+if [[ "$primary" == hive ]]; then
+  extra_owned="$(printf ',\n    "%s"' "$(json_escape "$bin_home/hive")")"
+fi
+if [[ "$install_hv" == 1 ]]; then
+  extra_owned+="$(printf ',\n    "%s"' "$(json_escape "$bin_home/hv")")"
+fi
+cat >"$receipt_tmp" <<JSON
+{
+  "schema_version": 1,
+  "channel": "bash",
+  "package": "hive",
+  "installed_command": "$primary",
+  "executable": "$(json_escape "$primary_path")",
+  "asset_root": "$(json_escape "$version_root/share/hive")",
+  "version": "$plain_version",
+  "service_label": "local.hive-daemon",
+  "owned_files": [
+    "$(json_escape "$version_root")"$extra_owned
+  ]
+}
+JSON
+chmod 0600 "$receipt_tmp"
+mv "$receipt_tmp" "$existing_receipt"
+
+atomic_link() {
+  local target_path="$1" link_path="$2" temp_link
+  temp_link="$link_path.tmp.$$"
+  ln -s "$target_path" "$temp_link"
+  mv -f "$temp_link" "$link_path"
+}
+if [[ "$install_hv" == 1 ]]; then atomic_link "$version_root/bin/hv" "$bin_home/hv"; fi
+if [[ "$primary" == hive ]]; then atomic_link "$version_root/bin/hive" "$bin_home/hive"; fi
