+require "test_helper"
+require "json"
+require "yaml"
+
+class AgentPackageTest < Minitest::Test
+  ROOT = File.expand_path("../..", __dir__)
+  PACKAGE = File.join(ROOT, "agent-package")
+
+  def json(relative)
+    JSON.parse(File.read(File.join(ROOT, relative)))
+  end
+
+  def test_all_hosts_point_to_one_canonical_skill_version
+    version = Hive::VERSION
+    codex = json("agent-package/.codex-plugin/plugin.json")
+    claude = json("agent-package/.claude-plugin/plugin.json")
+    claude_marketplace = json(".claude-plugin/marketplace.json").fetch("plugins").fetch(0)
+    pi = json("agent-package/package.json")
+    root_pi = json("package.json")
+    assert_equal "hive", codex.fetch("name")
+    assert_equal "hive", claude.fetch("name")
+    assert_equal [ version ], [ codex["version"], claude["version"], claude_marketplace["version"],
+                               pi["version"], root_pi["version"] ].uniq
+    assert_equal "./skills/", codex.fetch("skills")
+    assert_equal [ "./skills/hive" ], pi.dig("pi", "skills")
+    assert_equal [ "./agent-package/skills/hive" ], root_pi.dig("pi", "skills")
+    assert File.file?(File.join(PACKAGE, "skills/hive/SKILL.md"))
+    assert_equal 1, Dir.glob(File.join(ROOT, "**/skills/hive/SKILL.md")).size
+  end
+
+  def test_skill_frontmatter_is_minimal_and_body_has_safety_boundaries
+    content = File.read(File.join(PACKAGE, "skills/hive/SKILL.md"))
+    frontmatter = YAML.safe_load(content.split("---", 3).fetch(1))
+    assert_equal %w[description name], frontmatter.keys.sort
+    assert_equal "hive", frontmatter.fetch("name")
+    assert_match(/update.*uninstall/i, frontmatter.fetch("description"))
+    assert_operator content.lines.size, :<, 500
+    assert_match(/Never delete `.hive-state\/`/, content)
+    assert_match(/Never request, accept, or persist API keys/, content)
+    assert_match(/Configure only the agent host/, content)
+  end
+
+  def test_codex_marketplace_has_required_policy_and_canonical_package_path
+    marketplace = json(".agents/plugins/marketplace.json")
+    entry = marketplace.fetch("plugins").fetch(0)
+    assert_equal "hive", marketplace.fetch("name")
+    assert_equal "AVAILABLE", entry.dig("policy", "installation")
+    assert_equal "ON_INSTALL", entry.dig("policy", "authentication")
+    assert_equal "Developer Tools", entry.fetch("category")
+    source = entry.dig("source", "path")
+    refute_includes source.split("/"), ".."
+    assert_equal File.join(ROOT, "agent-package"), File.expand_path(source, ROOT)
+  end
+
+  def test_manifests_have_no_dangling_component_paths_or_unsupported_hooks
+    codex = json("agent-package/.codex-plugin/plugin.json")
+    refute codex.key?("hooks")
+    refute codex.key?("apps")
+    refute codex.key?("mcpServers")
+    assert File.directory?(File.expand_path(codex.fetch("skills"), PACKAGE))
+    refute_match(/\[TODO:/, JSON.generate(codex))
+  end
+
+  def test_dependency_manifest_covers_every_default_external_skill_family
+    dependencies = YAML.safe_load_file(File.join(PACKAGE, "dependencies.yml"))
+    assert_equal 1, dependencies.fetch("schema_version")
+    assert_equal %w[compound-engineering llm-wiki pr-review-toolkit],
+                 dependencies.fetch("dependencies").keys.sort
+    selectors = dependencies.fetch("dependencies").values.flat_map { |row| row.fetch("required_skills") }
+    %w[wiki-plan ce-brainstorm ce-code-review ce-test-browser review-pr].each do |skill|
+      assert_includes selectors, skill
+    end
+    assert_equal %w[claude], dependencies.dig("dependencies", "pr-review-toolkit", "supported_hosts")
+  end
+
+  def test_core_installer_never_mutates_agent_marketplace_state
+    installer = File.read(File.join(ROOT, "install.sh"))
+    refute_match(/\.claude-plugin|\.codex-plugin|\.agents\/plugins|pi install|codex plugin|claude plugin/, installer)
+  end
+end
