@@ -0,0 +1,60 @@
+require "test_helper"
+require "json"
+require "hive/commands/daemon"
+
+class DaemonServiceCommandTest < Minitest::Test
+  FakeInstaller = Struct.new(:calls, :messages) do
+    def target_path = "/tmp/hive-daemon.service"
+
+    def install!(activate:)
+      calls << [ :install, activate ]
+      :ok
+    end
+
+    def status
+      calls << [ :status ]
+      { status: :installed, path: target_path, registered: true, active: true }
+    end
+
+    def remove!
+      calls << [ :remove ]
+      :ok
+    end
+  end
+
+  def installer
+    FakeInstaller.new([], [])
+  end
+
+  def test_install_activates_only_through_explicit_service_action
+    fake = installer
+    out, = capture_io do
+      Hive::Commands::Daemon.new("service", "install", service_installer: fake).call
+    end
+    assert_equal [ [ :install, true ] ], fake.calls
+    assert_match(/service install: ok/, out)
+  end
+
+  def test_status_json_is_versioned
+    fake = installer
+    out, = capture_io do
+      Hive::Commands::Daemon.new("service", "status", service_installer: fake, json: true).call
+    end
+    payload = JSON.parse(out)
