@@ -0,0 +1,78 @@
+require "test_helper"
+require "hive/assets"
+
+class AssetsTest < Minitest::Test
+  include HiveTestHelper
+
+  def with_env(values)
+    old = values.keys.to_h { |key| [ key, ENV.fetch(key, nil) ] }
+    values.each { |key, value| value.nil? ? ENV.delete(key) : ENV[key] = value }
+    yield
+  ensure
+    old.each { |key, value| value.nil? ? ENV.delete(key) : ENV[key] = value }
+  end
+
+  def make_asset_root(path)
+    FileUtils.mkdir_p(File.join(path, "templates"))
+    FileUtils.mkdir_p(File.join(path, "schemas"))
+    File.write(File.join(path, "templates/example.erb"), "hello")
+    File.write(File.join(path, "schemas/example.json"), "{}")
+    path
+  end
+
+  def test_explicit_asset_root_resolves_and_reads_assets
+    with_tmp_dir do |dir|
+      root = make_asset_root(File.join(dir, "share/hive"))
+      with_env("HIVE_ASSET_ROOT" => root) do
+        assert_equal root, Hive::Assets.root
+        assert_equal "hello", Hive::Assets.read("templates/example.erb")
+      end
+    end
+  end
+
+  def test_xdg_and_homebrew_roots_are_supported
+    with_tmp_dir do |dir|
+      xdg = make_asset_root(File.join(dir, "data/hive"))
+      with_env("HIVE_ASSET_ROOT" => nil, "XDG_DATA_HOME" => File.join(dir, "data"), "HOMEBREW_PREFIX" => nil) do
+        assert_equal xdg, Hive::Assets.root
+      end
+
+      FileUtils.rm_rf(xdg)
+      brew = make_asset_root(File.join(dir, "brew/share/hive"))
+      with_env("HIVE_ASSET_ROOT" => nil, "XDG_DATA_HOME" => File.join(dir, "empty"),
+               "HOMEBREW_PREFIX" => File.join(dir, "brew")) do
+        assert_equal brew, Hive::Assets.root
+      end
+    end
+  end
+
+  def test_missing_explicit_root_fails_closed_and_paths_cannot_escape
+    with_tmp_dir do |dir|
+      missing = File.join(dir, "missing")
+      with_env("HIVE_ASSET_ROOT" => missing) do
+        assert_raises(Hive::ConfigError) { Hive::Assets.root }
+      end
+      with_env("HIVE_ASSET_ROOT" => "../relative-assets") do
+        assert_raises(Hive::ConfigError) { Hive::Assets.root }
+      end
+
+      root = make_asset_root(File.join(dir, "share/hive"))
+      with_env("HIVE_ASSET_ROOT" => root) do
+        assert_raises(Hive::ConfigError) { Hive::Assets.path("../secret") }
+        assert_raises(Hive::ConfigError) { Hive::Assets.path("/etc/passwd") }
+      end
+    end
+  end
+
+  def test_source_checkout_is_a_valid_fallback
+    with_env(
+      "HIVE_ASSET_ROOT" => nil,
+      "XDG_DATA_HOME" => "/definitely/missing/hive-assets",
+      "HOMEBREW_PREFIX" => "/definitely/missing/homebrew",
+      "HIVE_SYSTEM_SHARE" => "/definitely/missing/system-share"
+    ) do
+      assert_equal File.expand_path("../..", __dir__), Hive::Assets.root
+      assert File.file?(Hive::Assets.path("templates/hive_config.yml.erb"))
+    end
+  end
+end
