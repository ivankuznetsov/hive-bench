+require "test_helper"
+require "hive/config"
+
+class ConfigAgentSelectorsTest < Minitest::Test
+  include HiveTestHelper
+
+  def with_home
+    with_tmp_dir do |dir|
+      old = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = dir
+      yield dir
+    ensure
+      old.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old
+    end
+  end
+
+  def test_global_selectors_are_loaded_and_project_selectors_win
+    with_home do |home|
+      Hive::Config.write_global_agent_selectors!(
+        "claude" => { "model" => "global-sonnet" },
+        "pi" => { "provider" => "anthropic", "model" => "global-pi" }
+      )
+      project = File.join(home, "project")
+      FileUtils.mkdir_p(File.join(project, ".hive-state"))
+      File.write(File.join(project, ".hive-state/config.yml"), <<~YAML)
+        agents:
+          claude:
+            model: project-opus
+      YAML
+
+      cfg = Hive::Config.load(project)
+      assert_equal "project-opus", cfg.dig("agents", "claude", "model")
+      assert_equal "anthropic", cfg.dig("agents", "pi", "provider")
+      assert_equal "global-pi", cfg.dig("agents", "pi", "model")
+    end
+  end
+
+  def test_writer_preserves_global_siblings_and_never_accepts_secrets
+    with_home do |home|
+      File.write(File.join(home, "config.yml"), { "registered_projects" => [ { "name" => "x", "path" => "/x" } ] }.to_yaml)
+      Hive::Config.write_global_agent_selectors!("codex" => { "model" => "gpt-5" })
+      parsed = YAML.safe_load(File.read(File.join(home, "config.yml")))
+      assert_equal "x", parsed.dig("registered_projects", 0, "name")
+      assert_equal "gpt-5", parsed.dig("agents", "codex", "model")
+      refute parsed.to_yaml.match?(/api[_-]?key|token|secret/i)
+
+      assert_raises(Hive::ConfigError) do
+        Hive::Config.write_global_agent_selectors!("codex" => { "model" => "sk-secret123456" })
+      end
+      assert_equal parsed, YAML.safe_load(File.read(File.join(home, "config.yml")))
+    end
+  end
+
+  def test_global_config_cannot_override_agent_binary_through_selector_loader
+    with_home do |home|
+      File.write(File.join(home, "config.yml"), { "agents" => { "codex" => { "bin" => "/tmp/evil", "model" => "gpt-5" } } }.to_yaml)
+      assert_equal({ "codex" => { "model" => "gpt-5" } }, Hive::Config.load_global_agent_selectors)
+    end
+  end
+end
