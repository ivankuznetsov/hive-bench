diff --git a/.github/workflows/install-acceptance.yml b/.github/workflows/install-acceptance.yml
new file mode 100644
index 00000000..23ff1e76
--- /dev/null
+++ b/.github/workflows/install-acceptance.yml
@@ -0,0 +1,445 @@
+name: Tier-1 install acceptance
+
+on:
+  workflow_call:
+    inputs:
+      version:
+        description: Immutable release tag to verify
+        required: true
+        type: string
+    secrets:
+      ANTHROPIC_API_KEY:
+        description: Claude Code credential used for the native skill invocation
+        required: true
+      OPENAI_API_KEY:
+        description: Codex and Pi credential used for native skill invocation
+        required: true
+  workflow_dispatch:
+    inputs:
+      version:
+        description: Immutable release tag to verify (vMAJOR.MINOR.PATCH)
+        required: true
+        type: string
+
+permissions:
+  contents: read
+
+env:
+  HIVE_REPOSITORY: ivankuznetsov/hive
+  HIVE_VERSION: ${{ inputs.version }}
+
+jobs:
+  prompt-contract:
+    name: Universal prompt and package contracts
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v4
+      - name: Resolve the canonical Ruby toolchain
+        id: toolchain
+        run: bash packaging/build/toolchain.sh github-output >> "$GITHUB_OUTPUT"
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: ${{ steps.toolchain.outputs.ruby_version }}
+          bundler-cache: true
+      - name: Validate the shared prompt and package manifests
+        run: |
+          bundle exec ruby -Itest test/integration/install_prompt_contract_test.rb
+          bundle exec ruby -Itest test/unit/agent_package_test.rb
+          bundle exec ruby -Itest test/integration/agent_package_doctor_test.rb
+
+  agent-native:
+    name: Scenario C / native ${{ matrix.agent }} package flow
+    needs: prompt-contract
+    runs-on: ubuntu-22.04
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          - agent: claude
+            npm_package: "@anthropic-ai/claude-code@2.1.206"
+          - agent: codex
+            npm_package: "@openai/codex@0.144.1"
+          - agent: pi
+            npm_package: "@earendil-works/pi-coding-agent@0.80.6"
+    env:
+      ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
+      OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
+      NATIVE_AGENT: ${{ matrix.agent }}
+      NATIVE_PACKAGE: ${{ matrix.npm_package }}
+    steps:
+      - uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+      - uses: sigstore/cosign-installer@v3
+      - name: Create an isolated one-host environment
+        run: |
+          set -euo pipefail
+          home="$RUNNER_TEMP/native-$NATIVE_AGENT/home"
+          mkdir -p "$home" "$home/bin"
+          {
+            echo "HOME=$home"
+            echo "XDG_BIN_HOME=$home/bin"
+            echo "XDG_CONFIG_HOME=$home/config"
+            echo "XDG_DATA_HOME=$home/data"
+            echo "XDG_STATE_HOME=$home/state"
+            echo "XDG_CACHE_HOME=$home/cache"
+            echo "CLAUDE_CONFIG_DIR=$home/.claude"
+            echo "CODEX_HOME=$home/.codex"
+            echo "PI_CODING_AGENT_DIR=$home/.pi/agent"
+          } >> "$GITHUB_ENV"
+          case "$NATIVE_AGENT" in
+            claude) mkdir -p "$home/.claude" ;;
+            codex) mkdir -p "$home/.codex" ;;
+            pi) mkdir -p "$home/.pi/agent" ;;
+          esac
+          {
+            echo "$RUNNER_TEMP/native-$NATIVE_AGENT/npm/bin"
+            echo "$home/bin"
+          } >> "$GITHUB_PATH"
+      - name: Install the real native agent CLI
+        run: |
+          set -euo pipefail
+          case "$NATIVE_AGENT" in
+            claude) test -n "$ANTHROPIC_API_KEY" ;;
+            codex|pi) test -n "$OPENAI_API_KEY" ;;
+          esac
+          npm install --global --prefix "$RUNNER_TEMP/native-$NATIVE_AGENT/npm" "$NATIVE_PACKAGE"
+          "$NATIVE_AGENT" --version
+      - name: Authenticate and install the tagged Hive core
+        run: |
+          set -euo pipefail
+          base="https://github.com/$HIVE_REPOSITORY/releases/download/$HIVE_VERSION"
+          for asset in install.sh install.sh.sha256 SHA256SUMS SHA256SUMS.sig SHA256SUMS.pem; do
+            curl -fsSLo "$RUNNER_TEMP/$asset" "$base/$asset"
+          done
+          cosign verify-blob \
+            --certificate "$RUNNER_TEMP/SHA256SUMS.pem" \
+            --signature "$RUNNER_TEMP/SHA256SUMS.sig" \
+            --certificate-oidc-issuer https://token.actions.githubusercontent.com \
+            --certificate-identity-regexp '^https://github.com/ivankuznetsov/hive/.github/workflows/release.yml@refs/tags/v[0-9]+\.[0-9]+\.[0-9]+$' \
+            "$RUNNER_TEMP/SHA256SUMS"
+          grep -E '  (install\.sh|install\.sh\.sha256)$' "$RUNNER_TEMP/SHA256SUMS" > "$RUNNER_TEMP/bootstrap.sums"
+          (cd "$RUNNER_TEMP" && sha256sum --check bootstrap.sums && sha256sum --check install.sh.sha256)
+          bash "$RUNNER_TEMP/install.sh" --version="$HIVE_VERSION"
+          test "$(hive --version)" = "${HIVE_VERSION#v}"
+      - name: Exercise native add, install, and list operations
+        run: |
+          set -euo pipefail
+          case "$NATIVE_AGENT" in
+            claude)
+              claude plugin marketplace add "ivankuznetsov/hive@$HIVE_VERSION"
+              claude plugin install hive@hive
+              claude plugin marketplace add ivankuznetsov/agent-plugins
+              claude plugin install llm-wiki@aikuznetsov-marketplace
+              claude plugin marketplace add EveryInc/compound-engineering-plugin
+              claude plugin install compound-engineering@compound-engineering-plugin
+              claude plugin marketplace add anthropics/claude-plugins-official
+              claude plugin install pr-review-toolkit@claude-plugins-official
+              claude plugin list --json > "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"hive"' "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"llm-wiki"' "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"compound-engineering"' "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"pr-review-toolkit"' "$RUNNER_TEMP/native-list.json"
+              ;;
+            codex)
+              codex plugin marketplace add ivankuznetsov/hive --ref "$HIVE_VERSION" --json
+              codex plugin add hive@hive --json
+              codex plugin marketplace add ivankuznetsov/agent-plugins --json
+              codex plugin add llm-wiki@aikuznetsov-marketplace --json
+              codex plugin marketplace add EveryInc/compound-engineering-plugin --json
+              codex plugin add compound-engineering@compound-engineering-plugin --json
+              codex plugin list --json > "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"hive"' "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"llm-wiki"' "$RUNNER_TEMP/native-list.json"
+              grep -Fq '"compound-engineering"' "$RUNNER_TEMP/native-list.json"
+              ;;
+            pi)
+              pi install "git:github.com/ivankuznetsov/hive@$HIVE_VERSION" --approve
+              pi install git:github.com/ivankuznetsov/agent-plugins --approve
+              pi install git:github.com/EveryInc/compound-engineering-plugin --approve
+              pi list --no-approve > "$RUNNER_TEMP/native-list.txt"
+              grep -Fq 'ivankuznetsov/hive' "$RUNNER_TEMP/native-list.txt"
+              grep -Fq 'ivankuznetsov/agent-plugins' "$RUNNER_TEMP/native-list.txt"
+              grep -Fq 'EveryInc/compound-engineering-plugin' "$RUNNER_TEMP/native-list.txt"
+              ;;
+          esac
+      - name: Require a green active-host-only doctor before init
+        run: |
+          set -euo pipefail
+          project="$RUNNER_TEMP/native-$NATIVE_AGENT/project"
+          mkdir -p "$project"
+          git -C "$project" init
+          git -C "$project" config user.name "Hive acceptance"
+          git -C "$project" config user.email "acceptance@hive.invalid"
+          touch "$project/README.md"
+          git -C "$project" add README.md
+          git -C "$project" commit -m initial
+          (cd "$project" && hive doctor --agent-host "$NATIVE_AGENT" --json) > "$RUNNER_TEMP/doctor.json"
+          jq -e '.schema == "hive-doctor.v1" and .summary.errors == 0' "$RUNNER_TEMP/doctor.json"
+          jq -e --arg host "$NATIVE_AGENT" \
+            '([.checks[] | select(.category == "agent") | .agent] | unique) == [$host]' \
+            "$RUNNER_TEMP/doctor.json"
+          hive init "$project" --agent-host "$NATIVE_AGENT" \
+            --no-enroll-daemon --no-daemon-service
+          test -f "$project/.hive/project.yml"
+          test ! -e "$HOME/.config/systemd/user/hive-daemon.service"
+          test "$(awk '$1 == "agent:" { print $2 }' "$project/.hive-state/config.yml" | sort -u)" = "$NATIVE_AGENT"
+          (cd "$project" && hive doctor --agent-host "$NATIVE_AGENT" --json) > "$RUNNER_TEMP/post-init-doctor.json"
+          jq -e '.schema == "hive-doctor.v1" and .summary.errors == 0' "$RUNNER_TEMP/post-init-doctor.json"
+          for inactive in claude codex pi; do
+            test "$inactive" = "$NATIVE_AGENT" && continue
+            case "$inactive" in
+              claude) test ! -e "$CLAUDE_CONFIG_DIR" ;;
+              codex) test ! -e "$CODEX_HOME" ;;
+              pi) test ! -e "$PI_CODING_AGENT_DIR" ;;
+            esac
+          done
+      - name: Invoke the installed Hive skill through the native host
+        run: |
+          set -euo pipefail
+          project="$RUNNER_TEMP/native-$NATIVE_AGENT/project"
+          case "$NATIVE_AGENT" in
+            claude)
+              (cd "$project" && claude -p --bare --tools "" --model haiku --max-budget-usd 0.05 \
+                '/hive Reply with exactly HIVE_NATIVE_OK.') > "$RUNNER_TEMP/invoke.out"
+              ;;
+            codex)
+              codex exec --ephemeral --sandbox read-only -C "$project" \
+                '/hive Reply with exactly HIVE_NATIVE_OK.' > "$RUNNER_TEMP/invoke.out"
+              ;;
+            pi)
+              (cd "$project" && pi --provider openai --model gpt-5-nano --no-tools --no-session -p \
+                '/skill:hive Reply with exactly HIVE_NATIVE_OK.') > "$RUNNER_TEMP/invoke.out"
+              ;;
+          esac
+          grep -Fq HIVE_NATIVE_OK "$RUNNER_TEMP/invoke.out"
+
+  managed-policy-denial:
+    name: Scenario C / managed marketplace denial
+    needs: prompt-contract
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/setup-node@v4
+        with:
+          node-version: "22"
+      - name: Enforce Claude managed policy against the real CLI
+        run: |
+          set -euo pipefail
+          npm install --global @anthropic-ai/claude-code@2.1.206
+          sudo install -d -m 0755 /etc/claude-code
+          printf '%s\n' '{"strictKnownMarketplaces":[]}' | \
+            sudo tee /etc/claude-code/managed-settings.json >/dev/null
+          trap 'sudo rm -f /etc/claude-code/managed-settings.json' EXIT
+          if claude plugin marketplace add "ivankuznetsov/hive@$HIVE_VERSION" \
+              > "$RUNNER_TEMP/policy.out" 2>&1; then
+            echo "managed policy unexpectedly allowed the Hive marketplace" >&2
+            exit 1
+          fi
+          grep -Eiq 'managed|policy|blocked|not allowed' "$RUNNER_TEMP/policy.out"
+
+  ubuntu-bash:
+    name: Portable channel / Ubuntu lifecycle and preservation
+    needs: [agent-native, managed-policy-denial]
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: sigstore/cosign-installer@v3
+      - name: Authenticate the tagged bootstrap
+        run: |
+          set -euo pipefail
+          [[ "$HIVE_VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]
+          base="https://github.com/$HIVE_REPOSITORY/releases/download/$HIVE_VERSION"
+          for asset in install.sh install.sh.sha256 SHA256SUMS SHA256SUMS.sig SHA256SUMS.pem; do
+            curl -fsSLo "$asset" "$base/$asset"
+          done
+          cosign verify-blob \
+            --certificate SHA256SUMS.pem --signature SHA256SUMS.sig \
+            --certificate-oidc-issuer https://token.actions.githubusercontent.com \
+            --certificate-identity-regexp '^https://github.com/ivankuznetsov/hive/.github/workflows/release.yml@refs/tags/v[0-9]+\.[0-9]+\.[0-9]+$' \
+            SHA256SUMS
+          grep -E '  (install\.sh|install\.sh\.sha256)$' SHA256SUMS > bootstrap.sums
+          sha256sum --check bootstrap.sums
+          sha256sum --check install.sh.sha256
+      - name: Exercise install, pinned update, service cleanup, and uninstall
+        run: |
+          set -euo pipefail
+          safe="$RUNNER_TEMP/safe-bin"
+          export HOME="$RUNNER_TEMP/home"
+          export XDG_BIN_HOME="$HOME/bin"
+          export XDG_CONFIG_HOME="$HOME/config"
+          export XDG_DATA_HOME="$HOME/data"
+          export XDG_STATE_HOME="$HOME/state"
+          export XDG_CACHE_HOME="$HOME/cache"
+          export HIVE_SYSTEMCTL_LOG="$RUNNER_TEMP/systemctl.log"
+          mkdir -p "$safe" "$XDG_BIN_HOME" "$XDG_STATE_HOME/hive" "$RUNNER_TEMP/project/.hive-state"
+          for tool in awk bash chmod cosign cp curl dirname find git grep head jq ln mkdir mktemp mv ps readlink rm sed sha256sum shasum sort tar tr uname wc; do
+            path="$(command -v "$tool" || true)"
+            test -n "$path" && ln -sf "$path" "$safe/$tool"
+          done
+          printf '%s\n' '#!/usr/bin/env bash' 'printf "%s\\n" "$*" >> "${HIVE_SYSTEMCTL_LOG:?}"' > "$safe/systemctl"
+          chmod 0755 "$safe/systemctl"
+          printf '%s\n' '#!/usr/bin/env bash' 'echo unrelated-hive' > "$XDG_BIN_HOME/hive"
+          chmod 0755 "$XDG_BIN_HOME/hive"
+          unowned_before="$(sha256sum "$XDG_BIN_HOME/hive")"
+          printf 'durable project work\n' > "$RUNNER_TEMP/project/.hive-state/preservation-sentinel"
+          printf 'durable global state\n' > "$XDG_STATE_HOME/hive/preservation-sentinel"
+          project_before="$(sha256sum "$RUNNER_TEMP/project/.hive-state/preservation-sentinel")"
+          state_before="$(sha256sum "$XDG_STATE_HOME/hive/preservation-sentinel")"
+          test ! -e "$safe/ruby"
+
+          PATH="$safe" "$safe/bash" install.sh --version="$HIVE_VERSION"
+          hive_bin="$XDG_BIN_HOME/hv"
+          test -x "$hive_bin"
+          test "$(PATH="$safe" "$hive_bin" --version)" = "${HIVE_VERSION#v}"
+          test "$unowned_before" = "$(sha256sum "$XDG_BIN_HOME/hive")"
+
+          PATH="$safe" "$hive_bin" daemon service install
+          test -f "$XDG_CONFIG_HOME/systemd/user/hive-daemon.service"
+          PATH="$safe" "$hive_bin" update --version "$HIVE_VERSION"
+          test "$(PATH="$safe" "$hive_bin" --version)" = "${HIVE_VERSION#v}"
+          test "$unowned_before" = "$(sha256sum "$XDG_BIN_HOME/hive")"
+
+          PATH="$safe" "$hive_bin" uninstall --yes
+          test ! -e "$XDG_CONFIG_HOME/systemd/user/hive-daemon.service"
+          test ! -e "$hive_bin"
+          test "$unowned_before" = "$(sha256sum "$XDG_BIN_HOME/hive")"
+          test "$project_before" = "$(sha256sum "$RUNNER_TEMP/project/.hive-state/preservation-sentinel")"
+          test "$state_before" = "$(sha256sum "$XDG_STATE_HOME/hive/preservation-sentinel")"
+          grep -Fq 'enable --now hive-daemon.service' "$HIVE_SYSTEMCTL_LOG"
+          grep -Fq 'disable --now hive-daemon.service' "$HIVE_SYSTEMCTL_LOG"
+
+  macos-homebrew:
+    name: Scenario A / macOS Homebrew lifecycle and preservation
+    needs: [agent-native, managed-policy-denial]
+    runs-on: macos-15
+    steps:
+      - name: Wait for and install the release-matching tap formula
+        run: |
+          set -euo pipefail
+          expected="${HIVE_VERSION#v}"
+          brew tap ivankuznetsov/hive
+          installed=""
+          for attempt in $(seq 1 20); do
+            brew update
+            brew install ivankuznetsov/hive/hive || brew upgrade ivankuznetsov/hive/hive || true
+            installed="$("$(brew --prefix)/bin/hive" --version 2>/dev/null || true)"
+            test "$installed" = "$expected" && break
+            sleep 15
+          done
+          test "$installed" = "$expected"
+      - name: Exercise update, launchd cleanup, uninstall, and preservation
+        run: |
+          set -euo pipefail
+          hive_bin="$(brew --prefix)/bin/hive"
+          safe="$RUNNER_TEMP/safe-bin"
+          unowned="$RUNNER_TEMP/unowned-bin"
+          export HOME="$RUNNER_TEMP/home"
+          export XDG_CONFIG_HOME="$HOME/config"
+          export XDG_DATA_HOME="$HOME/data"
+          export XDG_STATE_HOME="$HOME/state"
+          export XDG_CACHE_HOME="$HOME/cache"
+          mkdir -p "$safe" "$unowned" "$HOME" "$XDG_STATE_HOME/hive" "$RUNNER_TEMP/project/.hive-state"
+          for tool in brew git gh launchctl ps shasum; do
+            path="$(command -v "$tool" || true)"
+            test -n "$path" && ln -sf "$path" "$safe/$tool"
+          done
+          printf '%s\n' '#!/bin/sh' 'echo unrelated-hive' > "$unowned/hive"
+          chmod 0755 "$unowned/hive"
+          unowned_before="$(shasum -a 256 "$unowned/hive")"
+          printf 'durable project work\n' > "$RUNNER_TEMP/project/.hive-state/preservation-sentinel"
+          printf 'durable global state\n' > "$XDG_STATE_HOME/hive/preservation-sentinel"
+          project_before="$(shasum -a 256 "$RUNNER_TEMP/project/.hive-state/preservation-sentinel")"
+          state_before="$(shasum -a 256 "$XDG_STATE_HOME/hive/preservation-sentinel")"
+          test ! -e "$safe/ruby"
+          lifecycle_path="$unowned:$safe:/usr/bin:/bin:/usr/sbin:/sbin"
+
+          PATH="$lifecycle_path" "$hive_bin" daemon service install
+          test -f "$HOME/Library/LaunchAgents/local.hive-daemon.plist"
+          PATH="$lifecycle_path" "$hive_bin" daemon service status
+          PATH="$lifecycle_path" "$hive_bin" update
+          test "$("$hive_bin" --version)" = "${HIVE_VERSION#v}"
+          test "$unowned_before" = "$(shasum -a 256 "$unowned/hive")"
+
+          PATH="$lifecycle_path" "$hive_bin" uninstall --yes
+          test ! -e "$HOME/Library/LaunchAgents/local.hive-daemon.plist"
+          test ! -e "$hive_bin"
+          test "$unowned_before" = "$(shasum -a 256 "$unowned/hive")"
+          test "$project_before" = "$(shasum -a 256 "$RUNNER_TEMP/project/.hive-state/preservation-sentinel")"
+          test "$state_before" = "$(shasum -a 256 "$XDG_STATE_HOME/hive/preservation-sentinel")"
+          ! brew list --versions ivankuznetsov/hive/hive
+      - name: Emergency runner cleanup
+        if: always()
+        run: |
+          export HOME="$RUNNER_TEMP/home"
+          if test -x "$(brew --prefix)/bin/hive"; then
+            "$(brew --prefix)/bin/hive" daemon service remove 2>/dev/null || true
+          fi
+          brew uninstall ivankuznetsov/hive/hive 2>/dev/null || true
+
+  arch-aur:
+    name: Scenario B/D / Arch AUR lifecycle and preservation
+    needs: [agent-native, managed-policy-denial]
+    runs-on: [self-hosted, Linux, X64, hive-arch]
+    steps:
+      - uses: actions/checkout@v4
+      - name: Install the published AUR package with an existing helper
+        run: |
+          set -euo pipefail
+          if command -v yay >/dev/null 2>&1; then
+            yay -Syu --noconfirm hive-bin
+            helper=yay
+          elif command -v paru >/dev/null 2>&1; then
+            paru -Syu --noconfirm hive-bin
+            helper=paru
+          else
+            echo "tier-1 Arch runner must provide yay or paru" >&2
+            exit 1
+          fi
+          test "$(hive --version)" = "${HIVE_VERSION#v}"
+          test "$(hv --version)" = "${HIVE_VERSION#v}"
+          ! command -v ruby
+          echo "AUR_HELPER=$helper" >> "$GITHUB_ENV"
+      - name: Exercise update, systemd cleanup, uninstall, and preservation
+        run: |
+          set -euo pipefail
+          hive_bin="$(command -v hive)"
+          root="$RUNNER_TEMP/hive-arch-project"
+          unowned="$RUNNER_TEMP/unowned-bin"
+          export HOME="$RUNNER_TEMP/hive-arch-home"
+          export XDG_CONFIG_HOME="$HOME/config"
+          export XDG_DATA_HOME="$HOME/data"
+          export XDG_STATE_HOME="$HOME/state"
+          export XDG_CACHE_HOME="$HOME/cache"
+          rm -rf "$root" "$HOME" "$unowned"
+          mkdir -p "$root/.hive-state" "$HOME" "$unowned" "$XDG_STATE_HOME/hive"
+          printf '%s\n' '#!/bin/sh' 'echo unrelated-hive' > "$unowned/hive"
+          chmod 0755 "$unowned/hive"
+          unowned_before="$(sha256sum "$unowned/hive")"
+          printf 'durable project work\n' > "$root/.hive-state/preservation-sentinel"
+          printf 'durable global state\n' > "$XDG_STATE_HOME/hive/preservation-sentinel"
+          project_before="$(sha256sum "$root/.hive-state/preservation-sentinel")"
+          state_before="$(sha256sum "$XDG_STATE_HOME/hive/preservation-sentinel")"
+
+          PATH="$unowned:$PATH" "$hive_bin" daemon service install
+          test -f "$XDG_CONFIG_HOME/systemd/user/hive-daemon.service"
+          set +o pipefail
+          yes | PATH="$unowned:$PATH" "$hive_bin" update
+          update_status="${PIPESTATUS[1]}"
+          set -o pipefail
+          test "$update_status" -eq 0
+          test "$("$hive_bin" --version)" = "${HIVE_VERSION#v}"
+          test "$unowned_before" = "$(sha256sum "$unowned/hive")"
+
+          set +o pipefail
+          yes | PATH="$unowned:$PATH" "$hive_bin" uninstall --yes
+          uninstall_status="${PIPESTATUS[1]}"
+          set -o pipefail
+          test "$uninstall_status" -eq 0
+          test ! -e "$XDG_CONFIG_HOME/systemd/user/hive-daemon.service"
+          test ! -e "$hive_bin"
+          test "$unowned_before" = "$(sha256sum "$unowned/hive")"
+          test "$project_before" = "$(sha256sum "$root/.hive-state/preservation-sentinel")"
+          test "$state_before" = "$(sha256sum "$XDG_STATE_HOME/hive/preservation-sentinel")"
+          ! pacman -Q hive-bin
+      - name: Emergency runner cleanup
+        if: always()
+        run: sudo pacman -Rns --noconfirm hive-bin 2>/dev/null || true
