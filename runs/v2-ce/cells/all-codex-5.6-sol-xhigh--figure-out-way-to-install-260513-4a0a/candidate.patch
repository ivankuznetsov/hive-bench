new file mode 100755
index 00000000..a381fc7c
--- /dev/null
+++ b/packaging/aur/render.rb
@@ -0,0 +1,22 @@
+#!/usr/bin/env ruby
+
+require "fileutils"
+require "json"
+
+release_path, output_dir = ARGV
+abort "usage: render.rb RELEASE_JSON OUTPUT_DIR" unless output_dir
+release = JSON.parse(File.read(release_path))
+version = release.fetch("version")
+abort "invalid release version" unless version.match?(/\A\d+\.\d+\.\d+\z/)
+asset = release.fetch("assets").find { |row| row["target"] == "x86_64-linux-gnu" }
+abort "release has no x86_64-linux-gnu asset" unless asset
+sha = asset.fetch("sha256")
+abort "invalid Linux checksum" unless sha.match?(/\A[0-9a-f]{64}\z/)
+
+FileUtils.mkdir_p(output_dir)
+%w[PKGBUILD .SRCINFO].each do |name|
+  template = File.join(__dir__, "#{name}.template")
+  rendered = File.read(template).gsub("@VERSION@", version).gsub("@SHA256@", sha)
+  File.write(File.join(output_dir, name), rendered)
+end
+FileUtils.cp(File.join(__dir__, "hive.install"), File.join(output_dir, "hive.install"))
