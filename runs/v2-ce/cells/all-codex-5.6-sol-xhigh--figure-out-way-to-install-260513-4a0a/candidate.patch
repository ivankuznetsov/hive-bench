@@ -0,0 +1,87 @@
+require "test_helper"
+require "open3"
+
+class HvWrapperTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+  WRAPPER = File.join(ROOT, "bin/hv")
+
+  def executable(path, body)
+    FileUtils.mkdir_p(File.dirname(path))
+    File.write(path, "#!/bin/sh\n#{body}\n")
+    FileUtils.chmod(0o755, path)
+  end
+
+  def test_symlinked_wrapper_executes_versioned_package_sibling_not_path_hive
+    with_tmp_dir do |dir|
+      version_bin = File.join(dir, "data/hive/versions/0.1.0-x86_64-linux-gnu/bin")
+      command = File.join(dir, "bin/hv")
+      apache = File.join(dir, "apache/hive")
+      FileUtils.mkdir_p(version_bin)
+      FileUtils.mkdir_p(File.dirname(command))
+      FileUtils.cp(WRAPPER, File.join(version_bin, "hv"))
+      FileUtils.chmod(0o755, File.join(version_bin, "hv"))
+      executable(File.join(version_bin, "hive"), "printf 'package:%s\\n' \"$*\"")
+      executable(apache, "printf 'apache\\n'")
+      File.symlink(File.join(version_bin, "hv"), command)
+
+      out, err, status = Open3.capture3({ "PATH" => "#{File.dirname(apache)}:/usr/bin:/bin" }, command, "status")
+      assert status.success?, err
+      assert_equal "package:status\n", out
+    end
+  end
+
+  def test_same_directory_native_package_wrapper_executes_its_sibling
+    with_tmp_dir do |dir|
+      package_bin = File.join(dir, "package/bin")
+      FileUtils.mkdir_p(package_bin)
+      FileUtils.cp(WRAPPER, File.join(package_bin, "hv"))
+      FileUtils.chmod(0o755, File.join(package_bin, "hv"))
+      executable(File.join(package_bin, "hive"), "printf 'native:%s\\n' \"$*\"")
+
+      out, err, status = Open3.capture3(File.join(package_bin, "hv"), "doctor")
+      assert status.success?, err
+      assert_equal "native:doctor\n", out
+    end
+  end
+
+  def test_unowned_hive_executable_override_and_path_hive_are_rejected
+    with_tmp_dir do |dir|
+      package_bin = File.join(dir, "package/bin")
+      unrelated = File.join(dir, "unrelated/hive")
+      FileUtils.mkdir_p(package_bin)
+      FileUtils.cp(WRAPPER, File.join(package_bin, "hv"))
+      FileUtils.chmod(0o755, File.join(package_bin, "hv"))
+      executable(unrelated, "printf 'unrelated\\n'")
+
+      env = {
+        "HIVE_EXECUTABLE" => unrelated,
+        "PATH" => "#{File.dirname(unrelated)}:/usr/bin:/bin"
+      }
+      out, err, status = Open3.capture3(env, File.join(package_bin, "hv"))
+      refute status.success?
+      assert_equal "", out
+      assert_equal 127, status.exitstatus
+      assert_match(/package-owned Hive executable not found/, err)
+    end
+  end
+
+  def test_same_directory_symlink_to_unowned_hive_is_rejected
+    with_tmp_dir do |dir|
+      package_bin = File.join(dir, "package/bin")
+      unrelated = File.join(dir, "unrelated/hive")
+      FileUtils.mkdir_p(package_bin)
+      FileUtils.cp(WRAPPER, File.join(package_bin, "hv"))
+      FileUtils.chmod(0o755, File.join(package_bin, "hv"))
+      executable(unrelated, "printf 'unrelated\\n'")
+      File.symlink(unrelated, File.join(package_bin, "hive"))
+
+      out, err, status = Open3.capture3(File.join(package_bin, "hv"))
+      refute status.success?
+      assert_equal "", out
+      assert_equal 127, status.exitstatus
+      assert_match(/package-owned Hive executable not found/, err)
+    end
+  end
+end
diff --git a/test/unit/install_channel_test.rb b/test/unit/install_channel_test.rb
new file mode 100644
index 00000000..00f58aed
--- /dev/null
+++ b/test/unit/install_channel_test.rb
@@ -0,0 +1,135 @@
+require "test_helper"
+require "hive/install_channel"
+
+class InstallChannelTest < Minitest::Test
+  include HiveTestHelper
+
+  def receipt(executable:, asset_root:, channel: "bash", **overrides)
+    {
+      "schema_version" => 1,
+      "channel" => channel,
+      "package" => channel == "aur" ? "hive-bin" : "ivankuznetsov/hive/hive",
+      "installed_command" => "hive",
+      "executable" => executable,
+      "asset_root" => asset_root,
+      "version" => "0.1.0",
+      "service_label" => "local.hive-daemon",
+      "owned_files" => [ executable ]
+    }.merge(overrides.transform_keys(&:to_s))
+  end
+
+  def test_round_trip_detects_every_managed_channel
+    with_tmp_dir do |dir|
+      executable = File.join(dir, "bin/hive")
+      assets = File.join(dir, "share/hive")
+      %w[bash brew aur].each do |channel|
+        path = File.join(dir, "#{channel}.json")
+        Hive::InstallChannel.write_receipt(receipt(executable: executable, asset_root: assets, channel: channel), path: path)
+        assert_equal channel, Hive::InstallChannel.detect(paths: [ path ])
+      end
+    end
+  end
+
+  def test_malformed_higher_priority_receipt_fails_closed
+    with_tmp_dir do |dir|
+      bad = File.join(dir, "bad.json")
+      good = File.join(dir, "good.json")
+      File.write(bad, "{bad")
+      Hive::InstallChannel.write_receipt(receipt(executable: "/opt/hive", asset_root: "/opt/share/hive"), path: good)
+      assert_raises(Hive::ConfigError) { Hive::InstallChannel.detect(paths: [ bad, good ]) }
+    end
+  end
+
+  def test_conflicting_auto_discovered_receipts_fail_closed
+    with_tmp_dir do |dir|
+      first = File.join(dir, "bash.json")
+      second = File.join(dir, "brew.json")
+      Hive::InstallChannel.write_receipt(receipt(executable: "/opt/hive", asset_root: "/opt/share/hive"), path: first)
+      Hive::InstallChannel.write_receipt(
+        receipt(executable: "/opt/homebrew/bin/hive", asset_root: "/opt/homebrew/share/hive", channel: "brew"),
+        path: second
+      )
+
+      error = assert_raises(Hive::ConfigError) do
+        Hive::InstallChannel.receipt(paths: [ first, second ])
+      end
+      assert_match(/conflicting installation receipts/, error.message)
+      assert_match(/HIVE_INSTALL_RECEIPT/, error.message)
+    end
+  end
+
+  def test_duplicate_receipts_for_the_same_installation_keep_priority_order
+    with_tmp_dir do |dir|
+      first = File.join(dir, "first.json")
+      second = File.join(dir, "second.json")
+      data = receipt(executable: "/opt/hive", asset_root: "/opt/share/hive")
+      Hive::InstallChannel.write_receipt(data, path: first)
+      Hive::InstallChannel.write_receipt(data, path: second)
+
+      assert_equal File.expand_path(first), Hive::InstallChannel.receipt(paths: [ first, second ]).fetch("receipt_path")
+    end
+  end
+
+  def test_explicit_receipt_is_authoritative_over_auto_discovered_conflicts
+    with_tmp_dir do |dir|
+      explicit = File.join(dir, "explicit.json")
+      stale = File.join(dir, "stale.json")
+      Hive::InstallChannel.write_receipt(
+        receipt(executable: "/usr/bin/hive", asset_root: "/usr/share/hive", channel: "aur"), path: explicit
+      )
+      Hive::InstallChannel.write_receipt(
+        receipt(executable: "/tmp/bin/hive", asset_root: "/tmp/share/hive"), path: stale
+      )
+      previous = ENV["HIVE_INSTALL_RECEIPT"]
+      ENV["HIVE_INSTALL_RECEIPT"] = explicit
+      selected = Hive::InstallChannel.receipt(paths: [ explicit, stale ])
+      assert_equal "aur", selected.fetch("channel")
+      assert_equal File.expand_path(explicit), selected.fetch("receipt_path")
+    ensure
+      previous.nil? ? ENV.delete("HIVE_INSTALL_RECEIPT") : ENV["HIVE_INSTALL_RECEIPT"] = previous
+    end
+  end
+
+  def test_bash_layout_binds_payload_and_wrappers_to_one_installation
+    with_xdg_home do |dir|
+      version_root = File.join(Hive::Paths.data_home, "versions/0.1.0-x86_64-linux-gnu")
+      executable = File.join(Hive::Paths.bin_home, "hive")
+      data = receipt(
+        executable: executable, asset_root: File.join(version_root, "share/hive"),
+        package: "hive", owned_files: [ executable, version_root ]
+      )
+      layout = Hive::InstallChannel.bash_layout(data)
+      assert_equal version_root, layout.version_root
+      assert_equal File.dirname(executable), layout.bin_root
+
+      external = File.join(dir, "unrelated")
+      assert_raises(Hive::ConfigError) do
+        Hive::InstallChannel.bash_layout(data.merge("executable" => external, "owned_files" => [ external, version_root ]))
+      end
+      assert_raises(Hive::ConfigError) do
+        Hive::InstallChannel.bash_layout(data.merge("owned_files" => [ executable, version_root, external ]))
+      end
+    end
+  end
+
+  def test_bash_layout_derives_a_valid_custom_prefix
+    prefix = "/opt/hive-custom"
+    version_root = File.join(prefix, "share/hive/versions/0.1.0-arm64-darwin")
+    executable = File.join(prefix, "bin/hv")
+    data = receipt(
+      executable: executable, asset_root: File.join(version_root, "share/hive"), package: "hive",
+      installed_command: "hv", owned_files: [ executable, version_root ]
+    )
+    assert_equal prefix, Hive::InstallChannel.lifecycle(receipt: data).detected_prefix
+  end
+
+  def test_receipt_rejects_relative_paths_unknown_channels_and_credentials
+    base = receipt(executable: "/opt/hive", asset_root: "/opt/share/hive")
+    assert_raises(Hive::ConfigError) { Hive::InstallChannel.validate_receipt!(base.merge("executable" => "bin/hive")) }
+    assert_raises(Hive::ConfigError) { Hive::InstallChannel.validate_receipt!(base.merge("channel" => "gem")) }
+    assert_raises(Hive::ConfigError) do
+      Hive::InstallChannel.validate_receipt!(base.merge("owned_files" => [ "/opt/hive/../unrelated" ]))
+    end
+    refute base.keys.any? { |key| key.match?(/token|secret|key/i) }
+  end
+end
diff --git a/test/unit/install_script_test.rb b/test/unit/install_script_test.rb
new file mode 100644
index 00000000..cea7c231
--- /dev/null
+++ b/test/unit/install_script_test.rb
@@ -0,0 +1,232 @@
+require "test_helper"
+require "digest"
+require "json"
+require "open3"
+require "shellwords"
+
+class InstallScriptTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+  INSTALLER = File.join(ROOT, "install.sh")
+
+  def fixture_release(dir)
+    target = "x86_64-linux-gnu"
+    root = File.join(dir, "hive-0.1.0-#{target}")
+    %w[bin/hive bin/hv].each do |relative|
+      path = File.join(root, relative)
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, "#!/bin/sh\necho 0.1.0\n")
+      FileUtils.chmod(0o755, path)
+    end
+    %w[templates/hive_config.yml.erb schemas/hive-status.v2.json examples/systemd/hive-daemon.service].each do |relative|
+      path = File.join(root, "share/hive", relative)
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, "fixture\n")
+    end
+    archive = File.join(dir, "hive-0.1.0-#{target}.tar.gz")
+    _out, err, status = Open3.capture3("tar", "-czf", archive, "-C", dir, File.basename(root))
+    assert status.success?, err
+    File.write(File.join(dir, "SHA256SUMS"), "#{Digest::SHA256.file(archive).hexdigest}  #{File.basename(archive)}\n")
+    archive
+  end
+
+  def fake_curl(dir, fixtures)
+    path = File.join(dir, "curl")
+    File.write(path, <<~SH)
+      #!/usr/bin/env bash
+      set -euo pipefail
+      if [[ -n "${HIVE_TEST_CURL_LOG:-}" ]]; then
+        printf '%s\n' "$*" >> "$HIVE_TEST_CURL_LOG"
+      fi
+      out=""
+      url=""
+      while [[ $# -gt 0 ]]; do
+        case "$1" in
+          -o|--output) out="$2"; shift 2 ;;
+          --connect-timeout|--max-time|--retry|--retry-delay|--retry-max-time) shift 2 ;;
+          -*) shift ;;
+          *) url="$1"; shift ;;
+        esac
+      done
+      cp #{Shellwords.escape(fixtures)}/"${url##*/}" "$out"
+    SH
+    FileUtils.chmod(0o755, path)
+  end
+
+  def install_env(dir, fakebin)
+    {
+      "HOME" => File.join(dir, "home"),
+      "XDG_CONFIG_HOME" => File.join(dir, "config"),
+      "XDG_DATA_HOME" => File.join(dir, "data"),
+      "XDG_STATE_HOME" => File.join(dir, "state"),
+      "XDG_CACHE_HOME" => File.join(dir, "cache"),
+      "XDG_BIN_HOME" => File.join(dir, "bin"),
+      "PATH" => "#{fakebin}:/usr/bin:/bin"
+    }
+  end
+
+  def test_installs_verified_versioned_payload_and_receipt_idempotently
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      fixture_release(fixtures)
+      fake_curl(fakebin, fixtures)
+      env = install_env(dir, fakebin)
+
+      2.times do
+        out, err, status = Open3.capture3(env, "bash", INSTALLER, "--version=v0.1.0")
+        assert status.success?, "#{out}\n#{err}"
+      end
+      assert File.symlink?(File.join(dir, "bin/hive"))
+      assert File.symlink?(File.join(dir, "bin/hv"))
+      receipt = JSON.parse(File.read(File.join(dir, "state/hive/install-receipt.json")))
+      assert_equal "bash", receipt.fetch("channel")
+      assert_equal "hive", receipt.fetch("installed_command")
+      version_out, version_err, version_status = Open3.capture3(File.join(dir, "bin/hive"))
+      assert version_status.success?, version_err
+      assert_equal "0.1.0\n", version_out
+      assert File.file?(File.join(receipt.fetch("asset_root"), "templates/hive_config.yml.erb"))
+    end
+  end
+
+  def test_unrelated_hive_collision_is_preserved_and_hv_is_selected
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      fixture_release(fixtures)
+      fake_curl(fakebin, fixtures)
+      unrelated = File.join(fakebin, "hive")
+      File.write(unrelated, "#!/bin/sh\necho apache\n")
+      FileUtils.chmod(0o755, unrelated)
+
+      out, err, status = Open3.capture3(install_env(dir, fakebin), "bash", INSTALLER, "--version=v0.1.0")
+      assert status.success?, "#{out}\n#{err}"
+      assert_equal "#!/bin/sh\necho apache\n", File.read(unrelated)
+      refute File.exist?(File.join(dir, "bin/hive"))
+      assert File.symlink?(File.join(dir, "bin/hv"))
+      receipt = JSON.parse(File.read(File.join(dir, "state/hive/install-receipt.json")))
+      assert_equal "hv", receipt.fetch("installed_command")
+    end
+  end
+
+  def test_unrelated_destination_hive_is_preserved_when_bin_home_is_not_on_path
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      destination = File.join(dir, "bin/hive")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      FileUtils.mkdir_p(File.dirname(destination))
+      fixture_release(fixtures)
+      fake_curl(fakebin, fixtures)
+      File.write(destination, "#!/bin/sh\necho unrelated\n")
+      FileUtils.chmod(0o755, destination)
+
+      out, err, status = Open3.capture3(install_env(dir, fakebin), "bash", INSTALLER, "--version=v0.1.0")
+      assert status.success?, "#{out}\n#{err}"
+      assert_equal "#!/bin/sh\necho unrelated\n", File.read(destination)
+      assert File.symlink?(File.join(dir, "bin/hv"))
+      receipt = JSON.parse(File.read(File.join(dir, "state/hive/install-receipt.json")))
+      assert_equal "hv", receipt.fetch("installed_command")
+    end
+  end
+
+  def test_rejects_traversal_in_existing_receipt_before_cleanup
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      state_root = File.join(dir, "state/hive")
+      victim = File.join(dir, "data/victim")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      FileUtils.mkdir_p(state_root)
+      FileUtils.mkdir_p(victim)
+      fixture_release(fixtures)
+      fake_curl(fakebin, fixtures)
+      sentinel = File.join(victim, "keep-me")
+      File.write(sentinel, "owned by user\n")
+      malicious_root = File.join(dir, "data/hive/versions/../../victim")
+      File.write(
+        File.join(state_root, "install-receipt.json"),
+        JSON.pretty_generate("asset_root" => File.join(malicious_root, "share/hive"))
+      )
+
+      _out, err, status = Open3.capture3(install_env(dir, fakebin), "bash", INSTALLER, "--version=v0.1.0")
+      refute status.success?
+      assert_match(/existing receipt has an unsafe asset_root/, err)
+      assert_equal "owned by user\n", File.read(sentinel)
+    end
+  end
+
+  def test_every_download_uses_bounded_timeout_and_retry_policy
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      curl_log = File.join(dir, "curl.log")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      fixture_release(fixtures)
+      File.write(File.join(fixtures, "release.json"), JSON.pretty_generate("version" => "0.1.0"))
+      File.write(File.join(fixtures, "SHA256SUMS.sig"), "fixture signature\n")
+      File.write(File.join(fixtures, "SHA256SUMS.pem"), "fixture certificate\n")
+      fake_curl(fakebin, fixtures)
+      cosign = File.join(fakebin, "cosign")
+      File.write(cosign, "#!/bin/sh\nexit 0\n")
+      FileUtils.chmod(0o755, cosign)
+      env = install_env(dir, fakebin).merge(
+        "HIVE_TEST_CURL_LOG" => curl_log,
+        "HIVE_REQUIRE_COSIGN" => "1",
+        "HIVE_VERSION" => nil
+      )
+
+      out, err, status = Open3.capture3(env, "bash", INSTALLER)
+      assert status.success?, "#{out}\n#{err}"
+      downloads = File.readlines(curl_log, chomp: true)
+      assert_equal 5, downloads.length
+      downloads.each do |arguments|
+        assert_includes arguments, "--connect-timeout 10"
+        assert_includes arguments, "--max-time 120"
+        assert_includes arguments, "--retry 2"
+        assert_includes arguments, "--retry-max-time 300"
+      end
+    end
+  end
+
+  def test_checksum_mismatch_fails_before_installation
+    with_tmp_dir do |dir|
+      fixtures = File.join(dir, "fixtures")
+      fakebin = File.join(dir, "fakebin")
+      FileUtils.mkdir_p(fixtures)
+      FileUtils.mkdir_p(fakebin)
+      fixture_release(fixtures)
+      File.write(File.join(fixtures, "SHA256SUMS"), "#{'0' * 64}  hive-0.1.0-x86_64-linux-gnu.tar.gz\n")
+      fake_curl(fakebin, fixtures)
+      _out, err, status = Open3.capture3(install_env(dir, fakebin), "bash", INSTALLER, "--version=v0.1.0")
+      refute status.success?
+      assert_match(/checksum mismatch/, err)
+      refute File.exist?(File.join(dir, "state/hive/install-receipt.json"))
+      refute File.exist?(File.join(dir, "bin/hive"))
+    end
+  end
+
+  def test_rejects_malformed_inputs_and_dry_run_does_not_download
+    _out, err, status = Open3.capture3("bash", INSTALLER, "--version=v1/../../evil", "--dry-run")
+    refute status.success?
+    assert_match(/invalid version/, err)
+
+    out, err, status = Open3.capture3("bash", INSTALLER, "--version=v0.1.0", "--dry-run")
+    assert status.success?, err
+    assert_match(/target=x86_64-linux-gnu/, out)
+
+    out, err, status = Open3.capture3(
+      "bash", INSTALLER, "--version=v0.1.0", "--prefix=/opt/hive-test", "--dry-run"
+    )
+    assert status.success?, err
+    assert_match(%r{bin=/opt/hive-test/bin data=/opt/hive-test/share/hive}, out)
+  end
+end
