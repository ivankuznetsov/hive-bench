diff --git a/packaging/build/archive.rb b/packaging/build/archive.rb
new file mode 100755
index 00000000..645c3808
--- /dev/null
+++ b/packaging/build/archive.rb
@@ -0,0 +1,40 @@
+#!/usr/bin/env ruby
+
+require "fileutils"
+require "rubygems/package"
+require "zlib"
+
+source, destination = ARGV
+abort "usage: archive.rb SOURCE_DIR DESTINATION.tar.gz" unless source && destination
+
+source = File.expand_path(source)
+abort "archive source does not exist: #{source}" unless File.directory?(source)
+
+FileUtils.mkdir_p(File.dirname(File.expand_path(destination)))
+entries = Dir.glob(File.join(source, "**", "*"), File::FNM_DOTMATCH)
+  .reject { |path| [ ".", ".." ].include?(File.basename(path)) }
+  .sort
+
+File.open(destination, "wb") do |file|
+  gzip = Zlib::GzipWriter.new(file, Zlib::BEST_COMPRESSION)
+  gzip.mtime = Gem.source_date_epoch.to_i
+  Gem::Package::TarWriter.new(gzip) do |tar|
+    root_name = File.basename(source)
+    tar.mkdir(root_name, 0o755)
+    entries.each do |path|
+      stat = File.lstat(path)
+      relative = File.join(root_name, path.delete_prefix("#{source}/"))
+      mode = stat.mode & 0o777
+      if stat.directory?
+        tar.mkdir(relative, mode)
+      elsif stat.symlink?
+        tar.add_symlink(relative, File.readlink(path), mode)
+      elsif stat.file?
+        tar.add_file_simple(relative, mode, stat.size) { |io| io.write(File.binread(path)) }
+      else
+        abort "unsupported archive entry: #{path}"
+      end
+    end
+  end
+  gzip.close
+end
diff --git a/packaging/build/detect_binary.rb b/packaging/build/detect_binary.rb
new file mode 100755
index 00000000..dbb30cf4
--- /dev/null
+++ b/packaging/build/detect_binary.rb
@@ -0,0 +1,17 @@
+#!/usr/bin/env ruby
+
+path = ARGV.fetch(0)
+header = File.binread(path, 64)
+
+format = if header.start_with?("\x7FELF".b)
+  endian = header.getbyte(5)
+  machine = header.byteslice(18, 2).unpack1(endian == 2 ? "n" : "v")
+  machine == 62 ? "elf-x86_64" : "elf-machine-#{machine}"
+elsif header.byteslice(0, 4) == "\xCF\xFA\xED\xFE".b
+  cpu_type = header.byteslice(4, 4).unpack1("V")
+  cpu_type == 0x0100000C ? "macho-arm64" : "macho-cpu-#{cpu_type}"
+else
+  "unknown"
+end
+
+puts format
diff --git a/packaging/build/release.sh b/packaging/build/release.sh
new file mode 100755
index 00000000..39daac98
--- /dev/null
+++ b/packaging/build/release.sh
@@ -0,0 +1,101 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+readonly target="${1:-}"
+
+case "$target" in
+  arm64-darwin|x86_64-linux-gnu) ;;
+  "") echo "usage: packaging/build/release.sh <arm64-darwin|x86_64-linux-gnu>" >&2; exit 64 ;;
+  *) echo "unsupported release target: $target" >&2; exit 64 ;;
+esac
+
+repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+cd "$repo_root"
+eval "$(bash packaging/build/toolchain.sh env)"
+readonly TEBAKO_IMAGE TEBAKO_VERSION TEBAKO_RUBY_VERSION TEBAKO_IMAGE_DIGEST TEBAKO_DEFINITION_SHA256
+
+version="$(ruby -Ilib -e 'require "hive"; print Hive::VERSION')"
+source_epoch="${SOURCE_DATE_EPOCH:-$(git log -1 --format=%ct)}"
+source_commit="${HIVE_SOURCE_COMMIT:-$(git rev-parse HEAD)}"
+release_dir="${HIVE_RELEASE_DIR:-$repo_root/tmp/release}"
+stage="$release_dir/hive-$version-$target"
+archive="$release_dir/hive-$version-$target.tar.gz"
+tebako_bin="${HIVE_TEBAKO_BIN:-tebako}"
+
+command -v "$tebako_bin" >/dev/null 2>&1 || {
+  echo "tebako $TEBAKO_VERSION is required; use the pinned builder in packaging/build/Dockerfile.tebako" >&2
+  exit 69
+}
+tebako_actual="$($tebako_bin --version 2>/dev/null | head -n 1 || true)"
+[[ "$tebako_actual" == *"$TEBAKO_VERSION"* ]] || {
+  echo "expected tebako $TEBAKO_VERSION, got: ${tebako_actual:-unknown}" >&2
+  exit 69
+}
+
+rm -rf "$stage" "$archive"
+mkdir -p "$stage/bin" "$stage/share/hive"
+
+press_args=(
+  press
+  "--root=$repo_root"
+  "--entry-point=$repo_root/bin/hive"
+  "--output=$stage/bin/hive"
+  "--Ruby=${TEBAKO_RUBY_VERSION}"
+)
+if [[ "$target" == "x86_64-linux-gnu" ]]; then
+  press_args+=(--patchelf)
+fi
+
+BUNDLE_WITHOUT=development:test "$tebako_bin" "${press_args[@]}"
+[[ -s "$stage/bin/hive" ]] || { echo "tebako produced an empty executable" >&2; exit 70; }
+chmod 0755 "$stage/bin/hive"
+cp bin/hv "$stage/bin/hv"
+chmod 0755 "$stage/bin/hv"
+
+file_info="$(ruby packaging/build/detect_binary.rb "$stage/bin/hive")"
+case "$target" in
+  arm64-darwin)
+    [[ "$file_info" == "macho-arm64" ]] || {
+      echo "wrong executable format for $target: $file_info" >&2; exit 70;
+    }
+    ;;
+  x86_64-linux-gnu)
+    [[ "$file_info" == "elf-x86_64" ]] || {
+      echo "wrong executable format for $target: $file_info" >&2; exit 70;
+    }
+    ;;
+esac
+
+cp LICENSE README.md "$stage/"
+cp -R templates "$stage/share/hive/templates"
+cp -R schemas "$stage/share/hive/schemas"
+cp -R examples "$stage/share/hive/examples"
+cp -R wiki "$stage/share/hive/wiki"
+cp -R scripts "$stage/share/hive/scripts"
+
+binary_sha="$(sha256sum "$stage/bin/hive" 2>/dev/null | awk '{print $1}' || shasum -a 256 "$stage/bin/hive" | awk '{print $1}')"
+ruby -rjson -e '
+  payload = {
+    "schema_version" => 1,
+    "target" => ARGV.fetch(0),
+    "version" => ARGV.fetch(1),
+    "source_commit" => ARGV.fetch(2),
+    "source_date_epoch" => Integer(ARGV.fetch(3)),
+    "packer" => "tebako",
+    "packer_version" => ARGV.fetch(4),
+    "embedded_ruby" => ARGV.fetch(5),
+    "builder_image" => ARGV.fetch(6),
+    "builder_image_digest" => ARGV.fetch(7),
+    "builder_definition" => "packaging/build/Dockerfile.tebako",
+    "builder_definition_sha256" => ARGV.fetch(8),
+    "executable_sha256" => ARGV.fetch(9)
+  }
+  File.write(ARGV.fetch(10), JSON.pretty_generate(payload) + "\n")
+' "$target" "$version" "$source_commit" "$source_epoch" "$TEBAKO_VERSION" "$TEBAKO_RUBY_VERSION" \
+  "$TEBAKO_IMAGE" "$TEBAKO_IMAGE_DIGEST" "$TEBAKO_DEFINITION_SHA256" "$binary_sha" \
+  "$stage/share/hive/build-metadata.json"
+
+export SOURCE_DATE_EPOCH="$source_epoch"
+ruby packaging/build/archive.rb "$stage" "$archive"
+[[ -s "$archive" ]] || { echo "release archive is empty: $archive" >&2; exit 70; }
+printf '%s\n' "$archive"
diff --git a/packaging/build/toolchain.sh b/packaging/build/toolchain.sh
new file mode 100644
index 00000000..08d6eff0
--- /dev/null
+++ b/packaging/build/toolchain.sh
@@ -0,0 +1,50 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+root="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+definition="${HIVE_BUILDER_DEFINITION:-$root/packaging/build/Dockerfile.tebako}"
+
+value_for() {
+  local directive="$1" key="$2" value
+  value="$(sed -nE "s/^${directive} ${key}=(.+)$/\\1/p" "$definition")"
+  [[ "$(printf '%s\n' "$value" | wc -l | tr -d ' ')" == 1 && -n "$value" ]] || {
+    echo "builder definition must contain one ${directive} ${key}=... entry" >&2
+    exit 65
+  }
+  printf '%s' "$value"
+}
+
+tebako_image="$(value_for ARG TEBAKO_IMAGE)"
+tebako_version="$(value_for ENV TEBAKO_VERSION)"
+tebako_ruby_version="$(value_for ENV TEBAKO_RUBY_VERSION)"
+[[ "$tebako_image" =~ @sha256:[0-9a-f]{64}$ ]] || {
+  echo "TEBAKO_IMAGE must be pinned by sha256 digest" >&2
+  exit 65
+}
+
+if command -v sha256sum >/dev/null 2>&1; then
+  definition_sha256="$(sha256sum "$definition" | awk '{print $1}')"
+else
+  definition_sha256="$(shasum -a 256 "$definition" | awk '{print $1}')"
+fi
+
+case "${1:-env}" in
+  env)
+    printf 'TEBAKO_IMAGE=%q\n' "$tebako_image"
+    printf 'TEBAKO_VERSION=%q\n' "$tebako_version"
+    printf 'TEBAKO_RUBY_VERSION=%q\n' "$tebako_ruby_version"
+    printf 'TEBAKO_IMAGE_DIGEST=%q\n' "${tebako_image##*@}"
+    printf 'TEBAKO_DEFINITION_SHA256=%q\n' "$definition_sha256"
+    ;;
+  github-output)
+    printf 'tebako_image=%s\n' "$tebako_image"
+    printf 'tebako_version=%s\n' "$tebako_version"
+    printf 'ruby_version=%s\n' "$tebako_ruby_version"
+    printf 'image_digest=%s\n' "${tebako_image##*@}"
+    printf 'definition_sha256=%s\n' "$definition_sha256"
+    ;;
+  *)
+    echo "usage: toolchain.sh [env|github-output]" >&2
+    exit 64
+    ;;
+esac
