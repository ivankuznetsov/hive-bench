+name: install_prompt
+description: One unchanged prompt chooses the tier-1 core channel and active agent package.
+tags: [install, prompt-contract, cli-only]
+prompt_source: install.md
+cases:
+  - name: macos-arm64-claude
+    os: macOS
+    arch: arm64
+    active_host: claude
+    expected_core: brew install ivankuznetsov/hive/hive
+    expected_agent: claude plugin install hive@hive
+  - name: arch-x86_64-codex
+    os: Arch
+    arch: x86_64
+    active_host: codex
+    expected_core: yay -S hive-bin
+    expected_agent: codex plugin add hive@hive
+  - name: ubuntu-x86_64-pi
+    os: Ubuntu
+    arch: x86_64
+    linuxbrew: true
+    active_host: pi
+    expected_core: bash install.sh --version=v<version>
+    expected_agent: pi install git:github.com/ivankuznetsov/hive@v<version>
+approvals:
+  - core installation
+  - active-host marketplace or package changes
+  - external skill dependencies
+  - project initialization
+  - project daemon enrollment
+  - user service installation and start
+forbidden:
+  - sudo
+  - edit shell profiles
+  - system Ruby or Bundler
+  - copy SKILL.md files
+  - install an agent CLI
+  - weaken sandbox
+steps:
+  - kind: cli
+    args: [version]
