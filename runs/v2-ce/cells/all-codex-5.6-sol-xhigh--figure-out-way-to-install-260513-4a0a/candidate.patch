diff --git a/test/unit/packaging_contract_test.rb b/test/unit/packaging_contract_test.rb
new file mode 100644
index 00000000..a09a95aa
--- /dev/null
+++ b/test/unit/packaging_contract_test.rb
@@ -0,0 +1,147 @@
+require "test_helper"
+require "digest"
+require "json"
+require "open3"
+require "rbconfig"
+
+class PackagingContractTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+
+  def read(path)
+    File.read(File.join(ROOT, path))
+  end
+
+  def test_linux_builder_is_the_pinned_official_tebako_image
+    dockerfile = read("packaging/build/Dockerfile.tebako")
+
+    assert_includes dockerfile, "ghcr.io/tamatebako/tebako-ubuntu-20.04"
+    assert_match(/@sha256:[0-9a-f]{64}/, dockerfile)
+    assert_includes dockerfile, "TEBAKO_VERSION=0.14.0"
+    assert_includes dockerfile, "TEBAKO_RUBY_VERSION=3.4.2"
+  end
+
+  def test_both_workflows_and_macos_read_the_one_builder_definition
+    release = read(".github/workflows/release.yml")
+    smoke = read(".github/workflows/packer-smoke.yml")
+    script = read("packaging/build/release.sh")
+    manifest = read("packaging/release/manifest.yml")
+
+    [ release, smoke ].each do |workflow|
+      assert_includes workflow, "docker build --file packaging/build/Dockerfile.tebako"
+      assert_includes workflow, "bash packaging/build/toolchain.sh github-output"
+      refute_match(/ghcr\.io\/tamatebako\/.*@sha256:/, workflow)
+      refute_match(/ruby-version: [\"']?3\.4\.2/, workflow)
+      refute_match(/tebako --version 0\.14\.0/, workflow)
+    end
+    refute_includes script, 'TEBAKO_VERSION="0.14.0"'
+    refute_includes script, 'TEBAKO_RUBY_VERSION="3.4.2"'
+    refute_includes manifest, "packer_version:"
+    refute_includes manifest, "embedded_ruby:"
+  end
+
+  def test_release_builder_has_only_tier_one_targets_and_no_system_ruby_fallback
+    script = read("packaging/build/release.sh")
+
+    assert_includes script, "arm64-darwin"
+    assert_includes script, "x86_64-linux-gnu"
+    refute_includes script, "linux-aarch64"
+    refute_match(/gem install|bundle exec|hive-cli/, script)
+    assert_includes script, "--Ruby=${TEBAKO_RUBY_VERSION}"
+    assert_includes script, "--patchelf"
+  end
+
+  def test_native_smoke_exercises_runtime_assets_cli_daemon_and_tui_without_ruby
+    smoke = read("packaging/spike/packer-smoke.sh")
+
+    assert_includes smoke, "--packaged-runtime-smoke"
+    assert_includes smoke, "doctor --json"
+    assert_includes smoke, "daemon start"
+    assert_includes smoke, "daemon status"
+    assert_includes smoke, "daemon stop"
+    assert_includes smoke, "tui_smoke.py"
+    assert_includes smoke, "command -v ruby"
+  end
+
+  def test_lockfile_carries_both_tier_one_native_gem_platforms
+    lock = read("Gemfile.lock")
+
+    assert_match(/^  arm64-darwin$/, lock)
+    assert_match(/^  x86_64-linux$/, lock)
+    assert_match(/bubbletea \(0\.1\.4-arm64-darwin\)/, lock)
+    assert_match(/lipgloss \(0\.2\.2-arm64-darwin\)/, lock)
+  end
+
+  def test_archiver_is_byte_reproducible
+    with_tmp_dir do |dir|
+      stage = File.join(dir, "hive-1.2.3-x86_64-linux-gnu")
+      FileUtils.mkdir_p(File.join(stage, "bin"))
+      File.write(File.join(stage, "bin", "hive"), "payload\n")
+      File.chmod(0o755, File.join(stage, "bin", "hive"))
+      outputs = %w[first.tar.gz second.tar.gz].map { |name| File.join(dir, name) }
+
+      outputs.each do |output|
+        _stdout, stderr, status = Open3.capture3(
+          { "SOURCE_DATE_EPOCH" => "1_700_000_000".delete("_") },
+          RbConfig.ruby, File.join(ROOT, "packaging/build/archive.rb"), stage, output
+        )
+        assert status.success?, stderr
+      end
+
+      assert_equal Digest::SHA256.file(outputs.first).hexdigest,
+                   Digest::SHA256.file(outputs.last).hexdigest
+    end
+  end
+
+  def test_release_builder_stages_the_complete_runtime_layout
+    with_tmp_dir do |dir|
+      packer = File.join(dir, "tebako")
+      File.write(packer, <<~SH)
+        #!/usr/bin/env bash
+        set -euo pipefail
+        if [[ "${1:-}" == "--version" ]]; then
+          echo "tebako 0.14.0"
+          exit 0
+        fi
+        for arg in "$@"; do
+          case "$arg" in
+            --output=*) cp /bin/true "${arg#--output=}" ;;
+          esac
+        done
+      SH
+      File.chmod(0o755, packer)
+      out, err, status = Open3.capture3(
+        {
+          "HIVE_RELEASE_DIR" => dir,
+          "HIVE_TEBAKO_BIN" => packer,
+          "SOURCE_DATE_EPOCH" => "1700000000",
+          "HIVE_SOURCE_COMMIT" => "a" * 40
+        },
+        File.join(ROOT, "packaging/build/release.sh"), "x86_64-linux-gnu"
+      )
+
+      assert status.success?, err
+      archive = out.strip
+      assert File.file?(archive)
+      extracted = File.join(dir, "extracted")
+      FileUtils.mkdir_p(extracted)
+      _tar_out, tar_err, tar_status = Open3.capture3("tar", "-xzf", archive, "-C", extracted)
+      assert tar_status.success?, tar_err
+      stage = Dir.glob(File.join(extracted, "hive-*-x86_64-linux-gnu")).fetch(0)
+      assert File.executable?(File.join(stage, "bin/hive"))
+      assert File.executable?(File.join(stage, "bin/hv"))
+      assert File.file?(File.join(stage, "share/hive/templates/hive_config.yml.erb"))
+      assert File.file?(File.join(stage, "share/hive/schemas/hive-status.v2.json"))
+      assert File.file?(File.join(stage, "share/hive/examples/systemd/hive-daemon.service"))
+      assert File.executable?(File.join(stage, "share/hive/scripts/stop_hook.sh"))
+      metadata = JSON.parse(File.read(File.join(stage, "share/hive/build-metadata.json")))
+      assert_equal "tebako", metadata.fetch("packer")
+      assert_equal "3.4.2", metadata.fetch("embedded_ruby")
+      assert_match(/@sha256:[0-9a-f]{64}\z/, metadata.fetch("builder_image"))
+      assert_match(/\Asha256:[0-9a-f]{64}\z/, metadata.fetch("builder_image_digest"))
+      assert_equal "packaging/build/Dockerfile.tebako", metadata.fetch("builder_definition")
+      assert_match(/\A[0-9a-f]{64}\z/, metadata.fetch("builder_definition_sha256"))
+    end
+  end
+end
diff --git a/test/unit/paths_test.rb b/test/unit/paths_test.rb
new file mode 100644
index 00000000..7d2141da
--- /dev/null
+++ b/test/unit/paths_test.rb
@@ -0,0 +1,158 @@
+require "test_helper"
+require "hive/paths"
+require "hive/commands/daemon"
+
+class PathsTest < Minitest::Test
+  include HiveTestHelper
+
+  XDG_KEYS = %w[
+    HOME HIVE_HOME XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME
+    XDG_CACHE_HOME XDG_BIN_HOME HIVE_SYSTEM_SHARE
+  ].freeze
+
+  def with_env(values)
+    old = values.keys.to_h { |key| [ key, ENV.fetch(key, nil) ] }
+    values.each { |key, value| value.nil? ? ENV.delete(key) : ENV[key] = value }
+    yield
+  ensure
+    old.each { |key, value| value.nil? ? ENV.delete(key) : ENV[key] = value }
+  end
+
+  def test_default_paths_follow_xdg_base_directory_defaults
+    with_tmp_dir do |dir|
+      values = XDG_KEYS.to_h { |key| [ key, nil ] }.merge("HOME" => File.join(dir, "home"))
+      with_env(values) do
+        assert_equal File.join(dir, "home/.config/hive"), Hive::Paths.config_home
+        assert_equal File.join(dir, "home/.local/share/hive"), Hive::Paths.data_home
+        assert_equal File.join(dir, "home/.local/state/hive"), Hive::Paths.state_home
+        assert_equal File.join(dir, "home/.cache/hive"), Hive::Paths.cache_home
+        assert_equal File.join(dir, "home/.local/bin"), Hive::Paths.bin_home
+      end
+    end
+  end
+
+  def test_each_xdg_override_is_independent_and_empty_is_unset
+    with_tmp_dir do |dir|
+      with_env(
+        "HOME" => File.join(dir, "home"),
+        "HIVE_HOME" => nil,
+        "XDG_CONFIG_HOME" => File.join(dir, "config"),
+        "XDG_DATA_HOME" => File.join(dir, "data"),
+        "XDG_STATE_HOME" => File.join(dir, "state"),
+        "XDG_CACHE_HOME" => File.join(dir, "cache"),
+        "XDG_BIN_HOME" => ""
+      ) do
+        assert_equal File.join(dir, "config/hive"), Hive::Paths.config_home
+        assert_equal File.join(dir, "data/hive"), Hive::Paths.data_home
+        assert_equal File.join(dir, "state/hive"), Hive::Paths.state_home
+        assert_equal File.join(dir, "cache/hive"), Hive::Paths.cache_home
+        assert_equal File.join(dir, "home/.local/bin"), Hive::Paths.bin_home
+      end
+    end
+  end
+
+  def test_hive_home_collapses_control_paths_without_changing_bin_home
+    with_tmp_dir do |dir|
+      with_env("HOME" => File.join(dir, "home"), "HIVE_HOME" => File.join(dir, "hive")) do
+        assert_equal File.join(dir, "hive"), Hive::Paths.config_home
+        assert_equal Hive::Paths.config_home, Hive::Paths.data_home
+        assert_equal Hive::Paths.config_home, Hive::Paths.state_home
+        assert_equal Hive::Paths.config_home, Hive::Paths.cache_home
+        assert_equal File.join(dir, "home/.local/bin"), Hive::Paths.bin_home
+        assert Hive::Paths.hive_home_collapsed?
+      end
+    end
+  end
+
+  def test_daemon_runtime_files_live_under_xdg_state_home
+    with_tmp_dir do |dir|
+      with_env(
+        "HOME" => File.join(dir, "home"),
+        "HIVE_HOME" => nil,
+        "XDG_STATE_HOME" => File.join(dir, "state")
+      ) do
+        daemon = Hive::Commands::Daemon.new("status")
+        assert_equal File.join(dir, "state/hive/.daemon.pid"), daemon.pid_file
+        assert_equal File.join(dir, "state/hive/logs/daemon.log"), daemon.log_file
+      end
+    end
+  end
+
+  def test_legacy_config_is_copied_atomically_once_and_retained
+    with_tmp_dir do |dir|
+      home = File.join(dir, "home")
+      legacy = File.join(home, "Dev/hive/config.yml")
+      FileUtils.mkdir_p(File.dirname(legacy))
+      File.write(legacy, "registered_projects: []\n")
+      with_env("HOME" => home, "HIVE_HOME" => nil, "XDG_CONFIG_HOME" => File.join(dir, "config")) do
+        Hive::Paths.ensure_migrated!
+        target = File.join(dir, "config/hive/config.yml")
+        assert_equal File.read(legacy), File.read(target)
+        assert File.file?(legacy), "legacy recovery source must be retained"
+        assert_equal "#{legacy}\n", File.read(File.join(dir, "config/hive/.migrated-from"))
+
+        File.write(target, "registered_projects:\n  - name: newer\n")
+        Hive::Paths.ensure_migrated!
+        assert_includes File.read(target), "newer"
+      end
+    end
+  end
+
+  def test_hive_home_skips_xdg_migration
+    with_tmp_dir do |dir|
+      home = File.join(dir, "home")
+      legacy = File.join(home, "Dev/hive/config.yml")
+      FileUtils.mkdir_p(File.dirname(legacy))
+      File.write(legacy, "registered_projects: []\n")
+      with_env("HOME" => home, "HIVE_HOME" => File.join(dir, "collapsed")) do
+        Hive::Paths.ensure_migrated!
+        refute File.exist?(File.join(dir, "collapsed/config.yml"))
+        assert File.file?(legacy)
+      end
+    end
+  end
+
+  def test_project_state_path_prefers_versioned_control_scaffold
+    with_tmp_dir do |dir|
+      assert_equal File.join(dir, ".hive-state"), Hive::Paths.project_state_path(dir)
+
+      Hive::Paths.write_project_scaffold!(dir, state_worktree: ".state/hive")
+      assert_equal File.join(dir, ".state/hive"), Hive::Paths.project_state_path(dir)
+      assert_equal 1, YAML.safe_load(File.read(File.join(dir, ".hive/project.yml"))).fetch("schema_version")
+    end
+  end
+
+  def test_project_scaffold_rejects_traversal_and_partial_collisions
+    with_tmp_dir do |dir|
+      FileUtils.mkdir_p(File.join(dir, ".hive"))
+      assert_raises(Hive::ConfigError) { Hive::Paths.preflight_project_scaffold!(dir) }
+      File.write(File.join(dir, ".hive/project.yml"), "schema_version: 1\nstate_worktree: ../../escape\n")
+      assert_raises(Hive::ConfigError) { Hive::Paths.project_state_path(dir) }
+    end
+  end
+
+  def test_project_scaffold_rejects_a_symlinked_state_escape
+    with_tmp_dir do |dir|
+      outside = File.join(File.dirname(dir), "outside-#{File.basename(dir)}")
+      FileUtils.mkdir_p(outside)
+      FileUtils.mkdir_p(File.join(dir, ".hive"))
+      File.symlink(outside, File.join(dir, ".hive-state"))
+      File.write(File.join(dir, ".hive/project.yml"), "schema_version: 1\nstate_worktree: .hive-state\n")
+
+      assert_raises(Hive::ConfigError) { Hive::Paths.project_state_path(dir) }
+    ensure
+      FileUtils.rm_rf(outside) if outside
+    end
+  end
+
+  def test_project_control_file_cannot_be_a_symlink
+    with_tmp_dir do |dir|
+      outside = File.join(dir, "outside.yml")
+      File.write(outside, "schema_version: 1\nstate_worktree: .hive-state\n")
+      FileUtils.mkdir_p(File.join(dir, ".hive"))
+      File.symlink(outside, File.join(dir, ".hive/project.yml"))
+
+      assert_raises(Hive::ConfigError) { Hive::Paths.project_state_path(dir) }
+    end
+  end
+end
diff --git a/test/unit/release_manifest_test.rb b/test/unit/release_manifest_test.rb
new file mode 100644
index 00000000..463c44d2
--- /dev/null
+++ b/test/unit/release_manifest_test.rb
@@ -0,0 +1,152 @@
+require "test_helper"
+require "digest"
+require "json"
+require "open3"
+require "yaml"
+
+class ReleaseManifestTest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+
+  def spec
+    YAML.safe_load_file(File.join(ROOT, "packaging/release/manifest.yml"))
+  end
+
+  def builder_definition
+    File.join(ROOT, spec.dig("builder", "definition"))
+  end
+
+  def builder_value(directive, key)
+    File.read(builder_definition).match(/^#{directive} #{key}=(.+)$/).captures.fetch(0)
+  end
+
+  def build_fixture(dir, target:, version: "0.1.0", commit: "a" * 40, omit: nil)
+    stage = File.join(dir, "hive-#{version}-#{target}")
+    spec.fetch("required_paths").each do |relative|
+      next if relative == omit
+
+      path = File.join(stage, relative)
+      FileUtils.mkdir_p(File.dirname(path))
+      content = if relative == "share/hive/build-metadata.json"
+        JSON.generate(version: version, target: target, source_commit: commit,
+                      packer: "tebako", packer_version: builder_value("ENV", "TEBAKO_VERSION"),
+                      embedded_ruby: builder_value("ENV", "TEBAKO_RUBY_VERSION"),
+                      builder_image: builder_value("ARG", "TEBAKO_IMAGE"),
+                      builder_image_digest: builder_value("ARG", "TEBAKO_IMAGE").split("@").last,
+                      builder_definition: spec.dig("builder", "definition"),
+                      builder_definition_sha256: Digest::SHA256.file(builder_definition).hexdigest)
+      else
+        "fixture\n"
+      end
+      File.write(path, content)
+    end
+    %w[bin/hive bin/hv].each do |relative|
+      FileUtils.chmod(0o755, File.join(stage, relative)) unless omit == relative
+    end
+    archive = File.join(dir, "hive-#{version}-#{target}.tar.gz")
+    env = { "SOURCE_DATE_EPOCH" => "1700000000" }
+    _out, err, status = Open3.capture3(env, "ruby", File.join(ROOT, "packaging/build/archive.rb"), stage, archive)
+    assert status.success?, err
+    archive
+  end
+
+  def finalize(source, output, version: "0.1.0", tag: "v0.1.0")
+    Open3.capture3("ruby", File.join(ROOT, "packaging/release/finalize.rb"), version, tag, source, output)
+  end
+
+  def test_spec_has_only_tier_one_targets_and_pinned_builder
+    assert_equal %w[arm64-darwin x86_64-linux-gnu], spec.fetch("targets").keys
+    assert_equal "packaging/build/Dockerfile.tebako", spec.dig("builder", "definition")
+    assert_equal "0.14.0", builder_value("ENV", "TEBAKO_VERSION")
+    assert_equal "3.4.2", builder_value("ENV", "TEBAKO_RUBY_VERSION")
+    assert_match(/@sha256:[0-9a-f]{64}\z/, builder_value("ARG", "TEBAKO_IMAGE"))
+  end
+
+  def test_release_workflow_gates_publication_on_signed_matching_tag_and_attestation
+    workflow = File.read(File.join(ROOT, ".github/workflows/release.yml"))
+    assert_includes workflow, 'git tag --verify "$TAG"'
+    assert_includes workflow, "actions/attest-build-provenance@v2"
+    %w[dist/release.json dist/install.sh dist/install.sh.sha256].each do |trusted_asset|
+      assert_includes workflow, trusted_asset
+    end
+    assert_includes workflow, "--verify-tag"
+    assert_includes workflow, "needs: finalize"
+    assert_includes workflow, "--prerelease --latest=false"
+    assert_match(/promote-release:.*needs: acceptance.*--prerelease=false --latest/m, workflow)
+    assert_match(/release-complete:.*needs: promote-release/m, workflow)
+    refute_match(/gem install hive|bundle exec hive/, workflow)
+  end
+
+  def test_finalizer_emits_consistent_release_and_strict_checksums
+    with_tmp_dir do |dir|
+      spec.fetch("targets").each_key { |target| build_fixture(dir, target: target) }
+      output = File.join(dir, "out")
+      _out, err, status = finalize(dir, output)
+      assert status.success?, err
+      release = JSON.parse(File.read(File.join(output, "release.json")))
+      assert_equal "ivankuznetsov/hive", release.fetch("repository")
+      assert_equal "v0.1.0", release.fetch("tag")
+      assert_equal 2, release.fetch("assets").size
+      assert_equal "install.sh", release.dig("installer", "name")
+      assert_match(/\Asha256:[0-9a-f]{64}\z/, release.dig("builder", "linux_image_digest"))
+      assert_equal Digest::SHA256.file(builder_definition).hexdigest,
+                   release.dig("builder", "definition_sha256")
+      assert File.executable?(File.join(output, "install.sh"))
+      assert_match(/\A[0-9a-f]{64}  install\.sh\n\z/, File.read(File.join(output, "install.sh.sha256")))
+      lines = File.readlines(File.join(output, "SHA256SUMS"), chomp: true)
+      assert_equal 5, lines.size
+      assert_equal %w[
+        hive-0.1.0-arm64-darwin.tar.gz
+        hive-0.1.0-x86_64-linux-gnu.tar.gz
+        install.sh
+        install.sh.sha256
+        release.json
+      ], lines.map { |line| line.split("  ", 2).fetch(1) }
+      _sum_out, sum_err, sum_status = Open3.capture3("sha256sum", "--check", "SHA256SUMS", chdir: output)
+      assert sum_status.success?, sum_err
+    end
+  end
+
+  def test_signed_checksum_set_detects_trusted_bootstrap_and_manifest_tampering
+    with_tmp_dir do |dir|
+      spec.fetch("targets").each_key { |target| build_fixture(dir, target: target) }
+      output = File.join(dir, "out")
+      _out, err, status = finalize(dir, output)
+      assert status.success?, err
+
+      %w[release.json install.sh install.sh.sha256].each do |name|
+        path = File.join(output, name)
+        original = File.binread(path)
+        File.open(path, "ab") { |file| file.write("tampered") }
+        _sum_out, _sum_err, sum_status = Open3.capture3("sha256sum", "--check", "SHA256SUMS", chdir: output)
+        refute sum_status.success?, "#{name} substitution must invalidate SHA256SUMS"
+        File.binwrite(path, original)
+      end
+    end
+  end
+
+  def test_finalizer_rejects_tag_mismatch_missing_asset_and_commit_mismatch
+    with_tmp_dir do |dir|
+      build_fixture(dir, target: "arm64-darwin", commit: "a" * 40)
+      build_fixture(dir, target: "x86_64-linux-gnu", commit: "b" * 40)
+      _out, err, status = finalize(dir, File.join(dir, "out"))
+      refute status.success?
+      assert_match(/different commits/, err)
+
+      _out, err, status = finalize(dir, File.join(dir, "out2"), tag: "v0.1.1")
+      refute status.success?
+      assert_match(/does not match/, err)
+    end
+  end
+
+  def test_finalizer_rejects_incomplete_runtime_assets
+    with_tmp_dir do |dir|
+      build_fixture(dir, target: "arm64-darwin", omit: "share/hive/scripts/stop_hook.sh")
+      build_fixture(dir, target: "x86_64-linux-gnu")
+      _out, err, status = finalize(dir, File.join(dir, "out"))
+      refute status.success?
+      assert_match(/missing share\/hive\/scripts\/stop_hook/, err)
+    end
+  end
+end
