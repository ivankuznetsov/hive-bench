--- /dev/null
+++ b/bin/hv
@@ -0,0 +1,46 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+resolve_path() {
+  local path="$1" directory target hops=0
+  [[ "$path" == /* ]] || path="$PWD/$path"
+  while [[ -L "$path" ]]; do
+    ((hops += 1))
+    [[ "$hops" -le 40 ]] || return 1
+    directory="$(cd -P "$(dirname "$path")" >/dev/null 2>&1 && pwd)" || return 1
+    target="$(readlink "$path")" || return 1
+    if [[ "$target" == /* ]]; then
+      path="$target"
+    else
+      path="$directory/$target"
+    fi
+  done
+  directory="$(cd -P "$(dirname "$path")" >/dev/null 2>&1 && pwd)" || return 1
+  printf '%s/%s\n' "$directory" "$(basename "$path")"
+}
+
+self_path="$(resolve_path "${BASH_SOURCE[0]}")" || {
+  echo "hv: package-owned Hive executable not found; reinstall from install.md" >&2
+  exit 127
+}
+owned_hive="$(dirname "$self_path")/hive"
+owned_hive_resolved=""
+if [[ -x "$owned_hive" ]]; then
+  owned_hive_resolved="$(resolve_path "$owned_hive")" || owned_hive_resolved=""
+  if [[ "$(dirname "$owned_hive_resolved")" != "$(dirname "$self_path")" ]]; then
+    owned_hive_resolved=""
+  fi
+fi
+
+if [[ -n "${HIVE_EXECUTABLE:-}" && -x "$HIVE_EXECUTABLE" && -n "$owned_hive_resolved" ]]; then
+  explicit_resolved="$(resolve_path "$HIVE_EXECUTABLE")" || explicit_resolved=""
+  if [[ "$explicit_resolved" == "$owned_hive_resolved" ]]; then
+    exec "$HIVE_EXECUTABLE" "$@"
+  fi
+fi
+if [[ -n "$owned_hive_resolved" ]]; then
+  exec "$owned_hive" "$@"
+fi
+
+echo "hv: package-owned Hive executable not found; reinstall from install.md" >&2
+exit 127
