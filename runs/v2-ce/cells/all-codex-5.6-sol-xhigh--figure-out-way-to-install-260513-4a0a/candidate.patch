diff --git a/lib/hive/install_channel.rb b/lib/hive/install_channel.rb
new file mode 100644
index 00000000..cc2b6c6d
--- /dev/null
+++ b/lib/hive/install_channel.rb
@@ -0,0 +1,261 @@
+require "json"
+require "hive"
+require "hive/paths"
+
+module Hive
+  module InstallChannel
+    VALID = %w[brew aur bash dev].freeze
+    BREW_PACKAGE = "ivankuznetsov/hive/hive".freeze
+    AUR_PACKAGE = "hive-bin".freeze
+    BASH_TARGETS = %w[arm64-darwin x86_64-linux-gnu].freeze
+    REQUIRED_RECEIPT_KEYS = %w[
+      schema_version channel package installed_command executable asset_root
+      version service_label owned_files
+    ].freeze
+
+    BashLayout = Struct.new(
+      :asset_root, :version_root, :data_root, :bin_root, :custom_prefix,
+      keyword_init: true
+    ) do
+      def expected_wrapper(path)
+        File.join(version_root, "bin", File.basename(path))
+      end
+
+      def wrapper?(path)
+        File.dirname(path) == bin_root && %w[hive hv].include?(File.basename(path))
+      end
+    end
+
+    class Lifecycle
+      attr_reader :channel, :receipt
+
+      def initialize(receipt:, channel: nil, env: ENV)
+        @receipt = receipt
+        @channel = channel || receipt&.fetch("channel") || "dev"
+        @env = env
+        raise Hive::ConfigError, "unknown Hive installation channel #{@channel.inspect}" unless VALID.include?(@channel)
+        if receipt && channel && receipt.fetch("channel") != channel
+          raise Hive::ConfigError,
+                "installation receipt channel #{receipt.fetch('channel').inspect} does not match #{channel.inspect}"
+        end
+      end
+
+      def command_for(operation)
+        case [ channel, operation ]
+        when [ "brew", :update ] then [ "brew", "upgrade", BREW_PACKAGE ]
+        when [ "brew", :uninstall ] then [ "brew", "uninstall", BREW_PACKAGE ]
+        when [ "aur", :update ] then [ aur_helper("update"), "-Syu", AUR_PACKAGE ]
+        when [ "aur", :uninstall ] then [ aur_helper("remove"), "-Rns", AUR_PACKAGE ]
+        when [ "bash", :update ] then yield(self)
+        when [ "bash", :uninstall ], [ "dev", :update ], [ "dev", :uninstall ] then nil
+        else raise Hive::ConfigError, "unsupported Hive lifecycle operation #{operation.inspect}"
+        end
+      end
+
+      def action_description(operation)
+        case [ channel, operation ]
+        when [ "brew", :uninstall ] then "brew uninstall #{BREW_PACKAGE}"
+        when [ "aur", :uninstall ] then "AUR helper remove #{AUR_PACKAGE}"
+        when [ "bash", :uninstall ] then "remove receipt-owned executable and assets"
+        when [ "dev", :uninstall ] then "leave source checkout unchanged"
+        else command_for(operation) { [] }.join(" ")
+        end
+      end
+
+      def run!(runner, argv, operation:)
+        result = runner.call(argv)
+        ok = result.respond_to?(:success?) ? result.success? : !!result
+        raise Hive::UnavailableError, "hive #{operation} failed through #{channel}" unless ok
+
+        true
+      rescue Errno::ENOENT => e
+        raise Hive::UnavailableError, "hive #{operation} helper missing: #{e.message}"
+      end
+
+      def bash_layout
+        raise Hive::ConfigError, "bash installation receipt is missing" unless receipt
+        raise Hive::ConfigError, "installation receipt is not for the bash channel" unless channel == "bash"
+
+        @bash_layout ||= InstallChannel.bash_layout(receipt)
+      end
+
+      def detected_prefix
+        channel == "bash" && receipt ? bash_layout.custom_prefix : nil
+      end
+
+      private
+
+      def aur_helper(action)
+        helper = which("yay") || which("paru")
+        raise Hive::UnavailableError, "install yay or paru to #{action} #{AUR_PACKAGE}" unless helper
+
+        File.basename(helper)
+      end
+
+      def which(command)
+        @env.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, command)
+          return path if File.file?(path) && File.executable?(path)
+        end
+        nil
+      end
+    end
+
+    module_function
+
+    def receipt_path
+      File.join(Hive::Paths.state_home, "install-receipt.json")
+    end
+
+    def candidate_receipts
+      explicit = Hive::Paths.env_value("HIVE_INSTALL_RECEIPT")
+      paths = [ explicit, receipt_path, File.join(Hive::Paths.data_home, "install-receipt.json") ]
+      if RUBY_PLATFORM.include?("darwin")
+        %w[/opt/homebrew /usr/local].each do |prefix|
+          paths << File.join(prefix, "share/hive/install-receipt.json")
+        end
+      end
+      paths << "/usr/share/hive/install-receipt.json"
+      paths.compact.uniq
+    end
+
+    def receipt(paths: candidate_receipts)
+      explicit = Hive::Paths.env_value("HIVE_INSTALL_RECEIPT")
+      if explicit && paths.include?(explicit) && !File.exist?(explicit)
+        raise Hive::ConfigError, "explicit installation receipt does not exist: #{explicit}"
+      end
+      if explicit && paths.include?(explicit)
+        return read_receipt(explicit)
+      end
+
+      found = paths.filter_map do |path|
+        read_receipt(path) if File.exist?(path)
+      end
+      return nil if found.empty?
+
+      identities = found.group_by { |data| receipt_identity(data) }
+      if identities.size > 1
+        details = found.map { |data| "#{data.fetch('channel')}:#{data.fetch('receipt_path')}" }.join(", ")
+        raise Hive::ConfigError, "conflicting installation receipts found (#{details}); set HIVE_INSTALL_RECEIPT explicitly"
+      end
+
+      found.first
+    end
+
+    def detect(paths: candidate_receipts)
+      receipt(paths: paths)&.fetch("channel") || "dev"
+    end
+
+    def read_receipt(path)
+      data = JSON.parse(File.read(path))
+      validate_receipt!(data, path)
+      data.merge("receipt_path" => File.expand_path(path))
+    rescue JSON::ParserError, Errno::EACCES, Errno::EISDIR => e
+      raise Hive::ConfigError, "invalid installation receipt at #{path}: #{e.message}"
+    end
+
+    def write_receipt(data, path: receipt_path)
+      validate_receipt!(data, path)
+      Hive::Paths.atomic_write(path, JSON.pretty_generate(data) + "\n")
+      File.expand_path(path)
+    end
+
+    def validate_receipt!(data, path = "receipt")
+      raise Hive::ConfigError, "installation receipt at #{path} must be an object" unless data.is_a?(Hash)
+
+      missing = REQUIRED_RECEIPT_KEYS - data.keys
+      raise Hive::ConfigError, "installation receipt at #{path} missing #{missing.join(', ')}" unless missing.empty?
+      raise Hive::ConfigError, "unsupported installation receipt schema" unless data["schema_version"] == 1
+      unless VALID.include?(data["channel"]) && data["channel"] != "dev"
+        raise Hive::ConfigError, "unknown receipt channel #{data['channel'].inspect}"
+      end
+      unless data["version"].to_s.match?(/\A\d+\.\d+\.\d+\z/)
+        raise Hive::ConfigError, "invalid receipt version #{data['version'].inspect}"
+      end
+      %w[executable asset_root].each do |key|
+        value = data[key]
+        unless value.is_a?(String) && File.absolute_path?(value) && !value.split(File::SEPARATOR).include?("..")
+          raise Hive::ConfigError, "receipt #{key} must be an absolute contained path"
+        end
+      end
+      unless %w[hive hv].include?(data["installed_command"])
+        raise Hive::ConfigError, "receipt installed_command must be hive or hv"
+      end
+      unless data["owned_files"].is_a?(Array) && data["owned_files"].all? { |file| file.is_a?(String) && File.absolute_path?(file) }
+        raise Hive::ConfigError, "receipt owned_files must contain absolute paths"
+      end
+      if data["owned_files"].any? { |file| file.split(File::SEPARATOR).include?("..") }
+        raise Hive::ConfigError, "receipt owned_files must contain normalized paths"
+      end
+      data
+    end
+
+    def lifecycle(receipt: nil, channel: nil, env: ENV)
+      Lifecycle.new(receipt: receipt, channel: channel, env: env)
+    end
+
+    def bash_layout(data)
+      validate_receipt!(data)
+      raise Hive::ConfigError, "installation receipt is not for the bash channel" unless data.fetch("channel") == "bash"
+
+      asset_root = File.expand_path(data.fetch("asset_root"))
+      version_root = File.dirname(File.dirname(asset_root))
+      expected_asset_root = File.join(version_root, "share/hive")
+      payload = File.basename(version_root)
+      target = BASH_TARGETS.find { |candidate| payload == "#{data.fetch('version')}-#{candidate}" }
+      versions_root = File.dirname(version_root)
+      unless asset_root == expected_asset_root && File.basename(versions_root) == "versions" && target
+        raise Hive::ConfigError, "bash asset root is not under a versioned tier-1 payload: #{asset_root}"
+      end
+
+      data_root = File.dirname(versions_root)
+      prefix = File.dirname(File.dirname(data_root)) if File.basename(data_root) == "hive" &&
+                                                       File.basename(File.dirname(data_root)) == "share"
+      prefix_bin = File.join(prefix, "bin") if prefix && File.join(prefix, "share/hive") == data_root
+      executable = File.expand_path(data.fetch("executable"))
+      bin_roots = [ Hive::Paths.bin_home, prefix_bin ].compact.map { |path| File.expand_path(path) }.uniq
+      bin_root = File.dirname(executable)
+      unless bin_roots.include?(bin_root) && File.basename(executable) == data.fetch("installed_command")
+        raise Hive::ConfigError, "bash receipt executable is outside the installation bin layout: #{executable}"
+      end
+
+      xdg_layout = data_root == File.expand_path(Hive::Paths.data_home) &&
+                   bin_root == File.expand_path(Hive::Paths.bin_home)
+      prefix_layout = prefix_bin == bin_root
+      unless xdg_layout || prefix_layout
+        raise Hive::ConfigError, "bash receipt data and bin roots do not describe one installation"
+      end
+
+      custom_prefix = prefix if prefix_layout
+      layout = BashLayout.new(
+        asset_root: asset_root, version_root: version_root, data_root: data_root,
+        bin_root: bin_root, custom_prefix: custom_prefix
+      )
+      owned_paths = Array(data.fetch("owned_files")).map { |raw_path| File.expand_path(raw_path) }
+      unless owned_paths.include?(executable)
+        raise Hive::ConfigError, "bash receipt executable is not listed in owned_files: #{executable}"
+      end
+      owned_paths.each do |path|
+        payload_owned = path == version_root || path.start_with?("#{version_root}#{File::SEPARATOR}")
+        unless payload_owned || layout.wrapper?(path)
+          raise Hive::ConfigError, "receipt-owned path escapes the installation: #{path}"
+        end
+      end
+      layout
+    end
+
+    def detected_prefix(data = receipt)
+      return nil unless data
+
+      lifecycle(receipt: data).detected_prefix
+    end
+
+    def receipt_identity(data)
+      REQUIRED_RECEIPT_KEYS.to_h do |key|
+        value = data.fetch(key)
+        value = value.sort if key == "owned_files"
+        [ key, value ]
+      end
+    end
+  end
+end
diff --git a/lib/hive/paths.rb b/lib/hive/paths.rb
new file mode 100644
index 00000000..accb7394
--- /dev/null
+++ b/lib/hive/paths.rb
@@ -0,0 +1,191 @@
+require "fileutils"
+require "tempfile"
+require "yaml"
+
+module Hive
+  module Paths
+    PROJECT_SCHEMA_VERSION = 1
+    PROJECT_CONTROL_DIR = ".hive".freeze
+    PROJECT_CONTROL_FILE = "project.yml".freeze
+    LEGACY_STATE_WORKTREE = ".hive-state".freeze
+
+    module_function
+
+    def config_home
+      hive_home_override || File.join(base_home("XDG_CONFIG_HOME", ".config"), "hive")
+    end
+
+    def data_home
+      hive_home_override || File.join(base_home("XDG_DATA_HOME", ".local/share"), "hive")
+    end
+
+    def state_home
+      hive_home_override || File.join(base_home("XDG_STATE_HOME", ".local/state"), "hive")
+    end
+
+    def cache_home
+      hive_home_override || File.join(base_home("XDG_CACHE_HOME", ".cache"), "hive")
+    end
+
+    def bin_home
+      File.expand_path(env_value("XDG_BIN_HOME") || File.join(home, ".local/bin"))
+    end
+
+    def hive_home_collapsed?
+      !hive_home_override.nil?
+    end
+
+    def ensure_migrated!
+      return false if hive_home_override
+
+      target = File.join(config_home, "config.yml")
+      return false if File.exist?(target)
+
+      legacy = File.join(home, "Dev", "hive", "config.yml")
+      return false unless File.file?(legacy)
+
+      payload = File.binread(legacy)
+      created = atomic_write(target, payload, overwrite: false, mode: 0o600)
+      return false unless created
+
+      atomic_write(File.join(config_home, ".migrated-from"), "#{legacy}\n", overwrite: false, mode: 0o600)
+      true
+    rescue Errno::EACCES, Errno::EROFS, Errno::ENOSPC => e
+      raise Hive::ConfigError, "legacy config migration failed: #{e.message}"
+    end
+
+    def atomic_write(path, content, overwrite: true, mode: 0o600)
+      path = File.expand_path(path)
+      FileUtils.mkdir_p(File.dirname(path))
+      tempfile = Tempfile.new([ ".#{File.basename(path)}", ".tmp" ], File.dirname(path))
+      tempfile.binmode
+      tempfile.chmod(mode)
+      tempfile.write(content)
+      tempfile.flush
+      tempfile.fsync
+      tempfile.close
+
+      if overwrite
+        File.rename(tempfile.path, path)
+      else
+        begin
+          File.link(tempfile.path, path)
+        rescue Errno::EEXIST
+          return false
+        ensure
+          File.unlink(tempfile.path) if File.exist?(tempfile.path)
+        end
+      end
+      true
+    ensure
+      tempfile&.close!
+    end
+
+    def project_control_path(project_root)
+      File.join(File.expand_path(project_root), PROJECT_CONTROL_DIR, PROJECT_CONTROL_FILE)
+    end
+
+    def project_state_path(project_root)
+      root = File.expand_path(project_root)
+      control = project_control_path(root)
+      return File.join(root, LEGACY_STATE_WORKTREE) unless File.exist?(control)
+
+      data = load_project_control(control)
+      resolve_state_worktree(root, data.fetch("state_worktree"), source: control)
+    end
+
+    def preflight_project_scaffold!(project_root)
+      root = File.expand_path(project_root)
+      directory = File.join(root, PROJECT_CONTROL_DIR)
+      return :create unless File.exist?(directory)
+
+      unless File.directory?(directory)
+        raise Hive::ConfigError, "project control path #{directory} exists but is not a directory"
+      end
+
+      entries = Dir.children(directory)
+      control = project_control_path(root)
+      if entries == [ PROJECT_CONTROL_FILE ] && File.file?(control)
+        data = load_project_control(control)
+        resolved = resolve_state_worktree(root, data.fetch("state_worktree"), source: control)
+        return :existing if resolved == File.join(root, LEGACY_STATE_WORKTREE)
+      end
+
+      raise Hive::ConfigError,
+            "project control directory #{directory} is partial or belongs to another tool; " \
+            "move it aside before running hive init"
+    end
+
+    def write_project_scaffold!(project_root, state_worktree: LEGACY_STATE_WORKTREE)
+      root = File.expand_path(project_root)
+      resolve_state_worktree(root, state_worktree, source: project_control_path(root))
+      payload = {
+        "schema_version" => PROJECT_SCHEMA_VERSION,
+        "state_worktree" => state_worktree
+      }.to_yaml
+      atomic_write(project_control_path(root), payload, mode: 0o644)
+      project_control_path(root)
+    end
+
+    def load_project_control(path)
+      if File.lstat(path).symlink?
+        raise Hive::ConfigError, "project control #{path} must not be a symlink"
+      end
+      data = YAML.safe_load(File.read(path)) || {}
+      unless data.is_a?(Hash) && data["schema_version"] == PROJECT_SCHEMA_VERSION &&
+             data["state_worktree"].is_a?(String)
+        raise Hive::ConfigError,
+              "project control #{path} must contain schema_version: #{PROJECT_SCHEMA_VERSION} " \
+              "and a string state_worktree"
+      end
+      data
+    rescue Psych::Exception, Errno::EACCES, Errno::EISDIR => e
+      raise Hive::ConfigError, "project control #{path} is not readable YAML: #{e.message}"
+    end
+
+    def resolve_state_worktree(project_root, pointer, source:)
+      if pointer.empty? || pointer.include?("\0") || File.absolute_path?(pointer) ||
+         pointer.split(File::SEPARATOR).any? { |part| part == "." || part == ".." }
+        raise Hive::ConfigError, "state_worktree in #{source} must be a safe project-relative path"
+      end
+
+      resolved = File.expand_path(pointer, project_root)
+      prefix = "#{File.expand_path(project_root)}#{File::SEPARATOR}"
+      unless resolved.start_with?(prefix)
+        raise Hive::ConfigError, "state_worktree in #{source} resolves outside #{project_root}"
+      end
+      if File.exist?(resolved)
+        unless File.directory?(resolved)
+          raise Hive::ConfigError, "state_worktree in #{source} is not a directory: #{resolved}"
+        end
+        real_root = File.realpath(project_root)
+        real_state = File.realpath(resolved)
+        unless real_state.start_with?("#{real_root}#{File::SEPARATOR}")
+          raise Hive::ConfigError, "state_worktree in #{source} escapes the project through a symlink"
+        end
+        unless File.exist?(File.join(resolved, ".git"))
+          raise Hive::ConfigError, "state_worktree in #{source} is not a git worktree: #{resolved}"
+        end
+      end
+      resolved
+    end
+
+    def base_home(env_key, fallback)
+      File.expand_path(env_value(env_key) || File.join(home, fallback))
+    end
+
+    def home
+      File.expand_path(env_value("HOME") || Dir.home)
+    end
+
+    def env_value(key)
+      value = ENV[key]
+      value unless value.nil? || value.empty?
+    end
+
+    def hive_home_override
+      value = env_value("HIVE_HOME")
+      File.expand_path(value) if value
+    end
+  end
+end
