+++ b/packaging/homebrew/hive.rb.erb
@@ -0,0 +1,36 @@
+require "json"
+
+class Hive < Formula
+  desc "Multi-agent, folder-as-state software delivery pipeline"
+  homepage "https://github.com/ivankuznetsov/hive"
+  version "<%= version %>"
+  license "MIT"
+
+  on_arm do
+    url "https://github.com/ivankuznetsov/hive/releases/download/v<%= version %>/hive-<%= version %>-arm64-darwin.tar.gz"
+    sha256 "<%= sha256 %>"
+  end
+
+  def install
+    bin.install "bin/hive", "bin/hv"
+    pkgshare.install Dir["share/hive/*"]
+    receipt = {
+      schema_version: 1,
+      channel: "brew",
+      package: "ivankuznetsov/hive/hive",
+      installed_command: "hive",
+      executable: (opt_bin/"hive").to_s,
+      asset_root: (opt_share/"hive").to_s,
+      version: version.to_s,
+      service_label: "local.hive-daemon",
+      owned_files: []
+    }
+    (pkgshare/"install-receipt.json").write(JSON.pretty_generate(receipt) + "\n")
+  end
+
+  test do
+    assert_equal version.to_s, shell_output("#{bin}/hive --version").strip
+    assert_predicate bin/"hv", :executable?
+    assert_predicate pkgshare/"templates/hive_config.yml.erb", :exist?
+  end
+end
