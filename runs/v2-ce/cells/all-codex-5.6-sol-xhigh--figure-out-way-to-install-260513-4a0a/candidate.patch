@@ -0,0 +1,173 @@
+require "test_helper"
+require "hive/commands/daemon/service_installer"
+
+class DaemonServiceInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  def executable(dir, name = "hv")
+    path = File.join(dir, "bin", name)
+    FileUtils.mkdir_p(File.dirname(path))
+    File.write(path, "#!/bin/sh\n")
+    FileUtils.chmod(0o755, path)
+    path
+  end
+
+  def test_linux_install_renders_stable_executable_and_activates_only_when_requested
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "linux", home: dir, binary_path: hive,
+        systemctl_available: true,
+        runner: ->(argv) { commands << argv; true }
+      )
+
+      assert_equal :ok, installer.install!(activate: false)
+      unit = installer.target_path
+      assert_includes File.read(unit), "ExecStart=#{hive} daemon start"
+      assert_includes File.read(unit), "Environment=\"PATH=#{File.dirname(hive)}:"
+      assert_empty commands
+
+      assert_equal :ok, installer.install!(activate: true)
+      assert_equal [ %w[systemctl --user daemon-reload],
+                     %w[systemctl --user enable --now hive-daemon.service] ], commands
+      assert_equal :installed, installer.status[:status]
+    end
+  end
+
+  def test_macos_escapes_paths_and_bootstraps_after_consent
+    with_tmp_dir do |dir|
+      home = File.join(dir, "home&user")
+      hive = executable(File.join(dir, "Hive & Tools"))
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "darwin", home: home, binary_path: hive,
+        runner: ->(argv) { commands << argv; true }
+      )
+      assert_equal :ok, installer.install!(activate: true)
+      plist = File.read(installer.target_path)
+      assert_includes plist, CGI.escapeHTML(hive)
+      assert_includes plist, "home&amp;user/Library/Logs"
+      assert_equal [ [ "launchctl", "bootstrap", "gui/#{Process.uid}", installer.target_path ] ], commands
+
+      assert_equal :ok, installer.install!(activate: true)
+      assert_equal [ "launchctl", "print", "gui/#{Process.uid}/local.hive-daemon" ], commands.last
+      assert_equal 1, commands.count { |argv| argv.include?("bootstrap") }
+    end
+  end
+
+  def test_drift_is_preserved_and_remove_refuses_symlink
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "linux", home: dir, binary_path: hive, systemctl_available: false
+      )
+      FileUtils.mkdir_p(File.dirname(installer.target_path))
+      File.write(installer.target_path, "custom\n")
+      assert_equal :drifted, installer.install!(activate: true)
+      assert_equal "custom\n", File.read(installer.target_path)
+
+      File.delete(installer.target_path)
+      File.symlink(File.join(dir, "somewhere"), installer.target_path)
+      assert_equal :unsafe, installer.remove!
+      assert File.symlink?(installer.target_path)
+    end
+  end
+
+  def test_remove_deregisters_before_unlink_and_is_idempotent
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "linux", home: dir, binary_path: hive,
+        systemctl_available: true,
+        runner: ->(argv) { commands << argv; true }
+      )
+      installer.install!(activate: false)
+      assert_equal :ok, installer.remove!
+      refute File.exist?(installer.target_path)
+      assert_equal %w[systemctl --user disable --now hive-daemon.service], commands[0]
+      assert_equal %w[systemctl --user daemon-reload], commands[1]
+      assert_equal :ok, installer.remove!
+    end
+  end
+
+  def test_linux_remove_preserves_unit_and_stops_when_disable_fails
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "linux", home: dir, binary_path: hive,
+        systemctl_available: true,
+        runner: ->(argv) { commands << argv; false }
+      )
+      installer.install!(activate: false)
+
+      assert_equal :failed, installer.remove!
+      assert File.file?(installer.target_path)
+      assert_equal [ %w[systemctl --user disable --now hive-daemon.service] ], commands
+      assert_match(/service manager command failed/, installer.messages.join)
+    end
+  end
+
+  def test_macos_remove_preserves_plist_and_stops_when_bootout_fails
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "darwin", home: dir, binary_path: hive,
+        runner: lambda do |argv|
+          commands << argv
+          argv.include?("print")
+        end
+      )
+      installer.install!(activate: false)
+
+      assert_equal :failed, installer.remove!
+      assert File.file?(installer.target_path)
+      assert_equal [
+        [ "launchctl", "print", "gui/#{Process.uid}/local.hive-daemon" ],
+        [ "launchctl", "bootout", "gui/#{Process.uid}", installer.target_path ]
+      ], commands
+      assert_match(/service manager command failed/, installer.messages.join)
+    end
+  end
+
+  def test_macos_remove_stops_when_loaded_job_has_no_plist_and_bootout_fails
+    with_tmp_dir do |dir|
+      hive = executable(dir)
+      commands = []
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "darwin", home: dir, binary_path: hive,
+        runner: lambda do |argv|
+          commands << argv
+          argv.include?("print")
+        end
+      )
+
+      assert_equal :failed, installer.remove!
+      assert_equal [
+        [ "launchctl", "print", "gui/#{Process.uid}/local.hive-daemon" ],
+        [ "launchctl", "bootout", "gui/#{Process.uid}/local.hive-daemon" ]
+      ], commands
+      assert_match(/service manager command failed/, installer.messages.join)
+    end
+  end
+
+  def test_missing_executable_fails_before_writing_registration
+    with_tmp_dir do |dir|
+      installer = Hive::Commands::Daemon::ServiceInstaller.new(
+        host_os: "linux", home: dir, binary_path: File.join(dir, "missing"),
+        systemctl_available: true
+      )
+      assert_raises(Hive::ConfigError) { installer.install!(activate: true) }
+      refute File.exist?(installer.target_path)
+    end
+  end
+
+  def test_unsupported_platform_has_actionable_result
+    installer = Hive::Commands::Daemon::ServiceInstaller.new(host_os: "freebsd")
+    assert_equal :unsupported, installer.install!(activate: true)
+    assert_match(/manually/, installer.messages.join)
+  end
+end
