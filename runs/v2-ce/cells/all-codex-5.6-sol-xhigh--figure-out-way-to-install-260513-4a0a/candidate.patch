diff --git a/lib/hive/config/active_agent_host.rb b/lib/hive/config/active_agent_host.rb
new file mode 100644
index 00000000..b59425d7
--- /dev/null
+++ b/lib/hive/config/active_agent_host.rb
@@ -0,0 +1,50 @@
+module Hive
+  module Config
+    # Produces a host-isolated config view for first-run doctor and init.
+    # The explicit host is authoritative: every stage/review role and every
+    # configured reviewer is rebound to that one native agent installation.
+    module ActiveAgentHost
+      module_function
+
+      def normalize(host)
+        return nil if host.nil? || host.to_s.strip.empty?
+
+        name = host.to_s.strip.downcase
+        return name if Hive::AgentProfiles.registered_names.map(&:to_s).include?(name)
+
+        raise Hive::ConfigError,
+              "unknown active agent host #{host.inspect}; expected #{Hive::AgentProfiles.registered_names.join(', ')}"
+      end
+
+      def apply(config, host)
+        name = normalize(host)
+        return config unless name
+
+        isolated = deep_dup(config)
+        Hive::Config::ROLE_AGENT_PATHS.each { |path| set_path(isolated, path, name) }
+        Array(isolated.dig("review", "reviewers")).each do |reviewer|
+          reviewer["agent"] = name if reviewer.is_a?(Hash)
+        end
+        isolated["active_agent_host"] = name
+        isolated
+      end
+
+      def deep_dup(value)
+        case value
+        when Hash then value.to_h { |key, child| [ key, deep_dup(child) ] }
+        when Array then value.map { |child| deep_dup(child) }
+        else value
+        end
+      end
+
+      def set_path(config, path, value)
+        parent = path[0...-1].inject(config) { |memo, key| memo[key] ||= {} }
+        parent[path.last] = value
+      end
+    end
+
+    def self.for_agent_host(config, host)
+      ActiveAgentHost.apply(config, host)
+    end
+  end
+end
diff --git a/lib/hive/config/agent_selectors.rb b/lib/hive/config/agent_selectors.rb
new file mode 100644
index 00000000..a86e73c3
--- /dev/null
+++ b/lib/hive/config/agent_selectors.rb
@@ -0,0 +1,104 @@
+module Hive
+  module Config
+    AGENT_SELECTOR_KEYS = %w[provider model].freeze
+
+    def self.load_global_agent_selectors
+      AgentSelectors.load
+    end
+
+    def self.write_global_agent_selectors!(selectors)
+      AgentSelectors.write!(selectors)
+    end
+
+    # Owns persistence of the provider/model-only global agent settings.
+    # Config keeps compatibility delegators, while this module contains the
+    # write boundary and the validation that prevents arbitrary agent config
+    # (especially credentials and binary paths) from entering global state.
+    module AgentSelectors
+      module_function
+
+      def load
+        Hive::Config.validate_hive_home!
+        path = Hive::Config.global_config_path
+        return {} unless File.exist?(path)
+
+        data = Hive::Config.load_global_config(path)
+        unless data.is_a?(Hash)
+          raise Hive::ConfigError, "global config at #{path} must be a hash"
+        end
+
+        agents = data["agents"]
+        return {} if agents.nil?
+        unless agents.is_a?(Hash)
+          raise Hive::ConfigError,
+                "agents in #{Hive::Config.describe_source(path)} must be a Hash; got #{agents.class}"
+        end
+
+        agents.each_with_object({}) do |(name, values), result|
+          next unless registered_names.include?(name.to_s)
+          unless values.is_a?(Hash)
+            raise Hive::ConfigError,
+                  "agents.#{name} in #{Hive::Config.describe_source(path)} must be a Hash"
+          end
+
+          selectors = values.slice(*Hive::Config::AGENT_SELECTOR_KEYS)
+          next if selectors.empty?
+
+          validate_profile!(name, selectors)
+          result[name.to_s] = selectors.transform_values { |value| value.to_s.strip }
+        end
+      end
+
+      def write!(selectors)
+        raise Hive::ConfigError, "agent selectors must be a Hash" unless selectors.is_a?(Hash)
+
+        normalized = selectors.each_with_object({}) do |(name, values), result|
+          name = name.to_s
+          unless registered_names.include?(name)
+            raise Hive::ConfigError, "unknown agent selector profile #{name.inspect}"
+          end
+          unless values.is_a?(Hash)
+            raise Hive::ConfigError, "agent selectors for #{name} must be a Hash"
+          end
+
+          unknown = values.keys.map(&:to_s) - Hive::Config::AGENT_SELECTOR_KEYS
+          unless unknown.empty?
+            raise Hive::ConfigError, "unknown selector keys for #{name}: #{unknown.join(', ')}"
+          end
+
+          clean = values.each_with_object({}) do |(key, value), out|
+            next if value.nil? || value.to_s.strip.empty?
+
+            out[key.to_s] = value.to_s.strip
+          end
+          validate_profile!(name, clean)
+          result[name] = clean unless clean.empty?
+        end
+
+        Hive::Paths.ensure_migrated!
+        path = Hive::Config.global_config_path
+        data = File.exist?(path) ? Hive::Config.load_global_config(path) : {}
+        raise Hive::ConfigError, "global config at #{path} must be a hash" unless data.is_a?(Hash)
+
+        agents = data["agents"] || {}
+        unless agents.is_a?(Hash)
+          raise Hive::ConfigError,
+                "agents in #{Hive::Config.describe_source(path)} must be a Hash"
+        end
+
+        normalized.each { |name, values| agents[name] = (agents[name] || {}).merge(values) }
+        data["agents"] = agents
+        Hive::Config.write_global_config!(data)
+        normalized
+      end
+
+      def registered_names
+        Hive::AgentProfiles.registered_names.map(&:to_s)
+      end
+
+      def validate_profile!(name, selectors)
+        Hive::AgentProfiles.lookup(name.to_sym).with_overrides(selectors)
+      end
+    end
+  end
+end
