@@ -0,0 +1,187 @@
+require "test_helper"
+require "stringio"
+require "json"
+require "digest"
+require "hive/commands/update"
+
+class UpdateCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_brew_delegates_exact_package_without_swapping_binary
+    calls = []
+    command = Hive::Commands::Update.new(channel: "brew", runner: ->(argv) { calls << argv; true })
+    assert_equal 0, command.call
+    assert_equal [ %w[brew upgrade ivankuznetsov/hive/hive] ], calls
+  end
+
+  def test_aur_prefers_yay_then_falls_back_to_paru
+    with_tmp_dir do |dir|
+      %w[yay paru].each do |name|
+        File.write(File.join(dir, name), "#!/bin/sh\n")
+        FileUtils.chmod(0o755, File.join(dir, name))
+      end
+      command = Hive::Commands::Update.new(channel: "aur", dry_run: true, env: { "PATH" => dir })
+      assert_equal %w[yay -Syu hive-bin], command.command_for("aur")
+      File.delete(File.join(dir, "yay"))
+      assert_equal %w[paru -Syu hive-bin], command.command_for("aur")
+    end
+  end
+
+  def test_aur_without_helper_is_actionable
+    command = Hive::Commands::Update.new(channel: "aur", env: { "PATH" => "" })
+    error = assert_raises(Hive::UnavailableError) { command.call }
+    assert_match(/yay or paru/, error.message)
+  end
+
+  def test_bash_update_downloads_verifies_and_executes_temp_installer
+    calls = []
+    command = Hive::Commands::Update.new(
+      channel: "bash", output: StringIO.new, runner: ->(argv) { calls << argv; true }
+    )
+    command.call
+    script = calls.fetch(0).fetch(2)
+    assert_includes script, "$base_url/latest/download"
+    assert_includes script, "$base_url/download/$release_tag"
+    assert_includes script, "verify_signature \"$tagged\" \"$release_tag\""
+    assert_includes script, "verify_checksum \"$tagged\" release.json"
+    assert_includes script, "verify_checksum \"$tagged\" install.sh"
+    assert_includes script, "install.sh.sha256"
+    assert_includes script, 'install_args=("--version=$release_tag")'
+    assert_includes script, 'bash "$tagged/install.sh" "${install_args[@]}"'
+    assert_includes script, "cosign is required"
+    refute_match(/curl[^;]+\|\s*bash/, script)
+  end
+
+  def test_bash_update_preserves_receipt_derived_custom_prefix_and_explicit_tag
+    prefix = "/opt/hive-custom"
+    version_root = File.join(prefix, "share/hive/versions/0.1.0-arm64-darwin")
+    executable = File.join(prefix, "bin/hive")
+    receipt = {
+      "schema_version" => 1, "channel" => "bash", "package" => "hive",
+      "installed_command" => "hive", "executable" => executable,
+      "asset_root" => File.join(version_root, "share/hive"), "version" => "0.1.0",
+      "service_label" => "local.hive-daemon", "owned_files" => [ executable, version_root ]
+    }
+    command = Hive::Commands::Update.new(
+      receipt: receipt, version: "v0.2.0", dry_run: true, output: StringIO.new
+    )
+    argv = command.command_for("bash")
+    assert_equal "v0.2.0", argv.fetch(4)
+    assert_equal prefix, argv.fetch(5)
+  end
+
+  def test_invalid_or_native_channel_version_is_rejected
+    assert_raises(Hive::ConfigError) do
+      Hive::Commands::Update.new(channel: "bash", version: "latest").command_for("bash")
+    end
+    assert_raises(Hive::ConfigError) do
+      Hive::Commands::Update.new(channel: "brew", version: "v0.2.0").command_for("brew")
+    end
+  end
+
+  def test_bash_update_authenticates_latest_then_executes_the_same_immutable_tag
+    with_tmp_dir do |dir|
+      fixture = File.join(dir, "release")
+      tools = File.join(dir, "tools")
+      FileUtils.mkdir_p([ fixture, tools ])
+      release_json = JSON.pretty_generate(
+        "schema_version" => 1, "repository" => "ivankuznetsov/hive",
+        "version" => "0.2.0", "tag" => "v0.2.0"
+      ) + "\n"
+      installer = <<~'BASH'
+        #!/usr/bin/env bash
+        printf '%s\n' "$@" > "$HIVE_INSTALLER_ARGS"
+      BASH
+      File.write(File.join(fixture, "release.json"), release_json)
+      File.write(File.join(fixture, "install.sh"), installer)
+      installer_sha = Digest::SHA256.hexdigest(installer)
+      File.write(File.join(fixture, "install.sh.sha256"), "#{installer_sha}  install.sh\n")
+      checksums = %w[release.json install.sh install.sh.sha256].map do |name|
+        "#{Digest::SHA256.file(File.join(fixture, name)).hexdigest}  #{name}"
+      end
+      File.write(File.join(fixture, "SHA256SUMS"), checksums.join("\n") + "\n")
+      File.write(File.join(fixture, "SHA256SUMS.sig"), "signature\n")
+      File.write(File.join(fixture, "SHA256SUMS.pem"), "certificate\n")
+
+      File.write(File.join(tools, "curl"), <<~'BASH')
+        #!/usr/bin/env bash
+        set -euo pipefail
+        url=""
+        output=""
+        while (($#)); do
+          case "$1" in
+            -o) output="$2"; shift 2 ;;
+            http*) url="$1"; shift ;;
+            *) shift ;;
+          esac
+        done
+        cp "$HIVE_UPDATE_FIXTURE/${url##*/}" "$output"
+      BASH
+      File.write(File.join(tools, "cosign"), <<~'BASH')
+        #!/usr/bin/env bash
+        printf '%s\n' "$*" >> "$HIVE_COSIGN_LOG"
+        exit "${HIVE_COSIGN_EXIT:-0}"
+      BASH
+      FileUtils.chmod(0o755, [ File.join(tools, "curl"), File.join(tools, "cosign") ])
+
+      prefix = File.join(dir, "prefix")
+      version_root = File.join(prefix, "share/hive/versions/0.1.0-x86_64-linux-gnu")
+      executable = File.join(prefix, "bin/hive")
+      receipt = {
+        "schema_version" => 1, "channel" => "bash", "package" => "hive",
+        "installed_command" => "hive", "executable" => executable,
+        "asset_root" => File.join(version_root, "share/hive"), "version" => "0.1.0",
+        "service_label" => "local.hive-daemon", "owned_files" => [ executable, version_root ]
+      }
+      argv = Hive::Commands::Update.new(receipt: receipt).command_for("bash")
+      args_log = File.join(dir, "installer-args")
+      cosign_log = File.join(dir, "cosign-log")
+      env = {
+        "PATH" => "#{tools}#{File::PATH_SEPARATOR}#{ENV.fetch('PATH', '')}",
+        "HIVE_UPDATE_FIXTURE" => fixture,
+        "HIVE_INSTALLER_ARGS" => args_log,
+        "HIVE_COSIGN_LOG" => cosign_log
+      }
+
+      assert system(env, *argv)
+      assert_equal [ "--version=v0.2.0", "--prefix=#{prefix}" ], File.readlines(args_log, chomp: true)
+      assert_equal 2, File.readlines(cosign_log).size
+      assert File.readlines(cosign_log).all? { |line| line.include?("@refs/tags/v0.2.0") }
+
+      File.delete(args_log)
+      refute system(env.merge("HIVE_COSIGN_EXIT" => "1"), *argv)
+      refute File.exist?(args_log), "the installer must not run after signature verification fails"
+    end
+  end
+
+  def test_dry_run_json_is_deterministic_and_does_not_run
+    out = StringIO.new
+    calls = []
+    Hive::Commands::Update.new(
+      channel: "brew", dry_run: true, json: true, output: out,
+      runner: ->(argv) { calls << argv; true }
+    ).call
+    payload = JSON.parse(out.string)
+    assert_equal "hive-update", payload["schema"]
+    assert_equal true, payload["dry_run"]
+    assert_equal %w[brew upgrade ivankuznetsov/hive/hive], payload["command"]
+    assert_empty calls
+  end
+
+  def test_runner_failure_is_not_reported_as_success
+    command = Hive::Commands::Update.new(channel: "brew", runner: ->(_argv) { false })
+    assert_raises(Hive::UnavailableError) { command.call }
+  end
+
+  def test_json_failure_emits_one_error_envelope
+    out = StringIO.new
+    command = Hive::Commands::Update.new(
+      channel: "brew", json: true, output: out, runner: ->(_argv) { false }
+    )
+    assert_raises(Hive::UnavailableError) { command.call }
+    payload = JSON.parse(out.string)
+    assert_equal false, payload["ok"]
+    assert_equal "unavailable", payload["error_kind"]
+    assert_equal 1, out.string.lines.size
+  end
+end
