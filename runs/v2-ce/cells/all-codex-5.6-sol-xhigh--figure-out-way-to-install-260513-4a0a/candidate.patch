+require "test_helper"
+require "hive/executable"
+require "hive/tui/subprocess"
+
+class ExecutableTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_explicit_package_executable_wins_over_unrelated_path_hive
+    with_tmp_dir do |dir|
+      owned = File.join(dir, "owned/hv")
+      apache = File.join(dir, "apache/hive")
+      [ owned, apache ].each do |path|
+        FileUtils.mkdir_p(File.dirname(path))
+        File.write(path, "#!/bin/sh\n")
+        FileUtils.chmod(0o755, path)
+      end
+      old_executable = ENV["HIVE_EXECUTABLE"]
+      old_path = ENV["PATH"]
+      ENV["HIVE_EXECUTABLE"] = owned
+      ENV["PATH"] = File.dirname(apache)
+      assert_equal owned, Hive::Executable.path
+      assert_equal [ owned, "status", "--json" ], Hive::Executable.argv("status", "--json")
+    ensure
+      old_executable.nil? ? ENV.delete("HIVE_EXECUTABLE") : ENV["HIVE_EXECUTABLE"] = old_executable
+      ENV["PATH"] = old_path
+    end
+  end
+
+  def test_invalid_override_fails_closed
+    old = ENV["HIVE_EXECUTABLE"]
+    ENV["HIVE_EXECUTABLE"] = "/definitely/missing/hive"
+    assert_raises(Hive::ConfigError) { Hive::Executable.path }
+  ensure
+    old.nil? ? ENV.delete("HIVE_EXECUTABLE") : ENV["HIVE_EXECUTABLE"] = old
+  end
+
+
+  def test_tui_subprocess_rewrites_literal_hive_to_package_owned_executable
+    with_tmp_dir do |dir|
+      owned = File.join(dir, "hv")
+      File.write(owned, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, owned)
+      old = ENV["HIVE_EXECUTABLE"]
+      ENV["HIVE_EXECUTABLE"] = owned
+      argv = Hive::Tui::Subprocess.package_hive_argv(%w[hive status --json])
+      assert_equal [ owned, "status", "--json" ], argv
+    ensure
+      old.nil? ? ENV.delete("HIVE_EXECUTABLE") : ENV["HIVE_EXECUTABLE"] = old
+    end
+  end
+end
