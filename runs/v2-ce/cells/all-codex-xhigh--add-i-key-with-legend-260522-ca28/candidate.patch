diff --git a/lib/hive/tui/views/info_panel.rb b/lib/hive/tui/views/info_panel.rb
new file mode 100644
index 00000000..a26ea171
--- /dev/null
+++ b/lib/hive/tui/views/info_panel.rb
@@ -0,0 +1,100 @@
+require "lipgloss"
+require "hive/tui/model"
+require "hive/tui/styles"
+require "hive/tui/text"
+require "hive/tui/views/format"
+
+module Hive
+  module Tui
+    module Views
+      module InfoPanel
+        FOOTER = "[q] close  [Esc] close  [i] close".freeze
+        TRUNCATION_LABEL = "content truncated".freeze
+
+        module_function
+
+        def render(model)
+          state = model.info_panel_state
+          return "" if state.nil?
+
+          width = [ model.cols.to_i - 1, 1 ].max
+          height = [ model.rows.to_i, 2 ].max
+          content = content_lines(state, width)
+          visible = fit_content(content, height - 1, width)
+          visible << Styles::HINT.render(truncate(FOOTER, width))
+          Lipgloss.join_vertical(Lipgloss::TOP, *visible)
+        end
+
+        def content_lines(state, width)
+          lines = []
+          lines << Styles::HEADER.render(truncate("Task info · #{safe(state.slug)}", width))
+          lines << Styles::HINT.render(truncate("read-only local task details", width))
+          lines << ""
+          lines << field("Slug", state.slug, width)
+          lines << field("Stage", state.stage, width)
+          lines << field("Created", state.created_at, width)
+          lines << field("Task folder", state.task_folder, width)
+          lines << field("Latest log", latest_log_label(state.latest_log_path), width)
+          append_extra(lines, state, width)
+          lines << ""
+          lines << Styles::HEADER.render(truncate("Original idea", width))
+          lines.concat(wrapped_block(state.original_text, width))
+          lines << Styles::HINT.render(truncate("Original idea truncated", width)) if state.original_text_truncated
+          lines
+        end
+
+        def append_extra(lines, state, width)
+          return if state.extra_title.to_s.empty? || state.extra_body.nil?
+
+          title = safe(state.extra_title)
+          lines << ""
+          lines << Styles::HEADER.render(truncate(title, width))
+          lines.concat(wrapped_block(state.extra_body, width))
+          lines << Styles::HINT.render(truncate("#{title} truncated", width)) if state.extra_body_truncated
+        end
+
+        def fit_content(content, capacity, width)
+          capacity = [ capacity.to_i, 1 ].max
+          return content.first(capacity) if content.length <= capacity
+          return [ Styles::HINT.render(truncate(TRUNCATION_LABEL, width)) ] if capacity == 1
+
+          content.first(capacity - 1) + [ Styles::HINT.render(truncate(TRUNCATION_LABEL, width)) ]
+        end
+
+        def field(label, value, width)
+          truncate("#{label}: #{safe(value)}", width)
+        end
+
+        def latest_log_label(path)
+          text = path.to_s
+          text.empty? ? "(none)" : text
+        end
+
+        def wrapped_block(text, width)
+          text.to_s.lines.flat_map { |line| hard_wrap(safe(line.chomp), width) }
+        end
+
+        def hard_wrap(line, width)
+          return [ "" ] if line.empty?
+
+          capacity = [ width.to_i, 1 ].max
+          chunks = []
+          offset = 0
+          while offset < line.length
+            chunks << truncate(line[offset, capacity].to_s, capacity)
+            offset += capacity
+          end
+          chunks
+        end
+
+        def safe(value)
+          Hive::Tui::Text.sanitize(value.to_s)
+        end
+
+        def truncate(string, width)
+          Views::Format.truncate(string, width)
+        end
+      end
+    end
+  end
+end
