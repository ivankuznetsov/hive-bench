+require "test_helper"
+require "hive/tui/model"
+require "hive/tui/views/info_panel"
+
+class HiveTuiViewsInfoPanelTest < Minitest::Test
+  def state(extra_title: "brainstorm.md", extra_body: "## Notes\nQuestion one\n",
+            latest_log_path: "/tmp/demo/.hive-state/logs/some-slug/brainstorm.log",
+            original_text: "Build a task from the user's note",
+            original_text_truncated: false, extra_body_truncated: false)
+    Hive::Tui::Model::InfoPanelState.new(
+      slug: "some-slug",
+      stage: "2-brainstorm",
+      created_at: "2026-05-20 00:00:00 UTC",
+      original_text: original_text,
+      task_folder: "/tmp/demo/.hive-state/stages/2-brainstorm/some-slug",
+      latest_log_path: latest_log_path,
+      extra_title: extra_title,
+      extra_body: extra_body,
+      original_text_truncated: original_text_truncated,
+      extra_body_truncated: extra_body_truncated
+    )
+  end
+
+  def model_for(info_state = state, cols: 100, rows: 30)
+    Hive::Tui::Model.initial.with(mode: :info_panel, info_panel_state: info_state, cols: cols, rows: rows)
+  end
+
+  def test_renders_common_fields_and_original_text
+    output = Hive::Tui::Views::InfoPanel.render(model_for)
+
+    assert_includes output, "Task info"
+    assert_includes output, "some-slug"
+    assert_includes output, "Stage: 2-brainstorm"
+    assert_includes output, "Created: 2026-05-20 00:00:00 UTC"
+    assert_includes output, "Task folder: /tmp/demo/.hive-state/stages/2-brainstorm/some-slug"
+    assert_includes output, "Latest log: /tmp/demo/.hive-state/logs/some-slug/brainstorm.log"
+    assert_includes output, "Original idea"
+    assert_includes output, "Build a task from the user's note"
+    assert_includes output, "[q] close"
+  end
+
+  def test_renders_extra_section_when_payload_supplies_it
+    output = Hive::Tui::Views::InfoPanel.render(model_for)
+
+    assert_includes output, "brainstorm.md"
+    assert_includes output, "Question one"
+  end
+
+  def test_keeps_extra_section_visible_when_original_text_exceeds_available_rows
+    long_original = (1..40).map { |i| "idea line #{i}" }.join("\n")
+    output = Hive::Tui::Views::InfoPanel.render(
+      model_for(
+        state(extra_title: "plan.md", extra_body: "required plan context", original_text: long_original),
+        rows: 14
+      )
+    )
+
+    assert_operator output.lines.length, :<=, 14
+    assert_includes output, "plan.md"
+    assert_includes output, "required plan context"
+    assert_includes output, "content truncated"
+  end
+
+  def test_omits_extra_section_when_payload_has_no_extra
+    output = Hive::Tui::Views::InfoPanel.render(
+      model_for(state(extra_title: nil, extra_body: nil, latest_log_path: nil))
+    )
+
+    assert_includes output, "Latest log: (none)"
+    refute_includes output, "brainstorm.md"
+  end
+
+  def test_sanitizes_rendered_file_text
+    output = Hive::Tui::Views::InfoPanel.render(
+      model_for(state(original_text: "safe \e[31mred\e[0m bell\a text"))
+    )
+
+    refute_includes output, "\e[31m"
+    refute_includes output, "\a"
+    assert_includes output, "safe red bell? text"
+  end
+
+  def test_marks_field_level_truncation
+    output = Hive::Tui::Views::InfoPanel.render(
+      model_for(state(original_text_truncated: true, extra_body_truncated: true))
+    )
+
+    assert_includes output, "Original idea truncated"
+    assert_includes output, "brainstorm.md truncated"
+  end
+
+  def test_truncates_to_available_rows_with_visible_indicator
+    long_body = (1..40).map { |i| "extra line #{i}" }.join("\n")
+    output = Hive::Tui::Views::InfoPanel.render(
+      model_for(state(extra_title: "plan.md", extra_body: long_body), rows: 12)
+    )
+
+    assert_operator output.lines.length, :<=, 12
+    assert_includes output, "content truncated"
+    assert_includes output, "[q] close"
+  end
+end
