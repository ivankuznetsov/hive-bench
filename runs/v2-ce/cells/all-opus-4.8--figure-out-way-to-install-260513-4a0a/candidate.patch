+#!/usr/bin/env bash
+# Acceptance A: `brew install ivankuznetsov/hive/hive` on clean macOS arm64.
+# Homebrew + a published release are required, so this is a manual VM/host
+# checklist rather than a hermetic script. It drives the steps and asserts
+# where it can.
+#
+# Pass criteria: brew installs hive with NO ruby dependency pulled, and
+# `hive --version` prints the release version.
+set -euo pipefail
+command -v brew >/dev/null 2>&1 || { echo "skip: brew not available (run on macOS/Linuxbrew)"; exit 0; }
+
+echo "==> Acceptance A steps (run on a clean macOS arm64 host):"
+cat <<'STEPS'
+  1. brew tap ivankuznetsov/hive           # or install directly (auto-taps)
+  2. brew install ivankuznetsov/hive/hive
+  3. hive --version                          # must print the release version
+  4. brew list hive                          # confirm NO ruby dependency was pulled
+  5. brew test hive                          # runs the formula's `hive --version` test
+  6. hive init .                             # first-run flow works
+STEPS
+echo "a-brew.sh documented the steps; execute them on a real macOS arm64 host to complete acceptance A."
