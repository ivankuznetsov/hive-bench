+    {
+      "target": "x86_64-linux-gnu",
+      "tier": 1,
+      "runner": "ubuntu-22.04",
+      "os": "linux",
+      "arch": "x86_64",
+      "libc": "gnu",
+      "artifact": "hive-<version>-x86_64-linux-gnu.tar.gz",
+      "continue_on_error": false
+    },
+    {
+      "target": "x86_64-darwin",
+      "tier": 2,
+      "runner": "macos-13",
+      "os": "darwin",
+      "arch": "x86_64",
+      "artifact": "hive-<version>-x86_64-darwin.tar.gz",
