         "header and separator must be the same width even with long reviewer labels"
     end
   end
+
+  # --- `hive doctor --deps` runtime-dependency rows --------------------
+  # Exercises the four runtime status branches (present / warning / missing /
+  # version_too_old) and the missing-required-tool exit-code effect. PATH is
+  # pinned to a fake bin dir so the probe is deterministic.
+
+  def with_fake_path(tools)
+    with_tmp_dir do |dir|
+      tools.each do |name, body|
+        path = File.join(dir, name)
+        File.write(path, body || "#!/bin/sh\nexit 0\n")
+        File.chmod(0o755, path)
+      end
+      old = ENV["PATH"]
+      ENV["PATH"] = dir
+      begin
+        yield dir
+      ensure
+        old.nil? ? ENV.delete("PATH") : ENV["PATH"] = old
+      end
+    end
+  end
+
+  def all_skills_present(home)
+    write_file("#{home}/.claude/plugins/cache/mp/compound-engineering/3.0.1/skills/ce-brainstorm/SKILL.md")
+    write_file("#{home}/.claude/commands/plan.md")
+  end
+
+  def deps_config
+    base_config(
+      "brainstorm" => { "agent" => "claude", "skill" => "/compound-engineering:ce-brainstorm" },
+      "plan" => { "agent" => "claude", "skill" => "/plan" }
+    )
+  end
+
+  def test_deps_all_present_renders_present_and_exits_zero
+    with_fake_home do |home|
+      all_skills_present(home)
+      newer = "#{Hive::MIN_CLAUDE_VERSION}.0"
+      with_fake_path(
+        "git" => nil, "bash" => nil, "gh" => nil, "jq" => nil,
+        "claude" => "#!/bin/sh\necho '#{newer} (Claude Code)'\n"
+      ) do
+        out = StringIO.new
+        code = Hive::Commands::Doctor.new(
+          config: deps_config, project_root: nil, deps: true, output: out
+        ).call
+        assert_equal Hive::Commands::Doctor::EXIT_SUCCESS, code
+        # Runtime rows appear and report present.
+        assert_match(/\bgit\b/, out.string)
+        assert_match(/\bjq\b/, out.string)
+      end
+    end
+  end
+
+  def test_deps_covers_four_status_branches_and_fails_exit_code
+    with_fake_home do |home|
+      all_skills_present(home)
+      # git present (required→present), bash absent (required→missing),
+      # gh present (recommended→present), jq absent (recommended→warning),
+      # claude too old (→version_too_old).
+      with_fake_path(
+        "git" => nil, "gh" => nil,
+        "claude" => "#!/bin/sh\necho '0.0.1'\n"
+      ) do
+        out = StringIO.new
+        code = Hive::Commands::Doctor.new(
+          config: deps_config, project_root: nil, deps: true, output: out
+        ).call
+        # A missing REQUIRED tool (bash) OR a too-old versioned tool flips exit.
+        assert_equal Hive::Commands::Doctor::EXIT_MISSING_SKILL, code
+        s = out.string
+        assert_match(/required tool bash not found/, s)
+        assert_match(/recommended tool jq not found/, s)
+        assert_match(/older than #{Regexp.escape(Hive::MIN_CLAUDE_VERSION)}/, s)
+      end
+    end
+  end
+
+  def test_deps_off_by_default_adds_no_runtime_rows
+    with_fake_home do |home|
+      all_skills_present(home)
+      out = StringIO.new
+      code = Hive::Commands::Doctor.new(
+        config: deps_config, project_root: nil, output: out
+      ).call
+      assert_equal Hive::Commands::Doctor::EXIT_SUCCESS, code
+      refute_match(/required tool .* not found/, out.string)
+    end
+  end
 end
