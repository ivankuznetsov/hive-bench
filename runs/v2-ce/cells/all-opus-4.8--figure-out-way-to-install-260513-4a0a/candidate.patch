index 00000000..49558826
--- /dev/null
+++ b/packaging/build/build-artifact.sh
@@ -0,0 +1,295 @@
+#!/usr/bin/env bash
+#
+# build-artifact.sh — build a relocatable, self-contained `hive` app-directory
+# tarball for a single release target.
+#
+# Usage:
+#   packaging/build/build-artifact.sh <target>
+#
+# where <target> is one of:
+#   arm64-darwin        macOS Apple Silicon (tier-1)
+#   x86_64-linux-gnu    Linux glibc         (tier-1)
+#   x86_64-darwin       macOS Intel         (tier-2, best-effort)
+#
+# Output:
+#   dist/hive-<version>-<target>.tar.gz
+#
+# The tarball extracts to a directory `hive-<version>-<target>/` that is
+# self-contained: it carries its own gems (vendor/bundle/), a Ruby runtime
+# (ruby/), the application code (lib/, libexec/, templates/, schemas/), and a
+# launcher (bin/hive) that wires up GEM_HOME/GEM_PATH/RUBYLIB relative to its
+# own location before exec'ing the bundled Ruby. NO system Ruby is required at
+# runtime once the bundled runtime is in place.
+#
+# This script must run *on* the target platform (a native CI runner) so that
+# the platform-specific FFI native gems (bubbletea / lipgloss — see
+# Gemfile.lock) and the copied Ruby prefix match the host ABI. Cross-building
+# is out of scope.
+#
+set -euo pipefail
+
+# ---------------------------------------------------------------------------
+# 0. Arguments and repo layout
+# ---------------------------------------------------------------------------
+if [ "$#" -ne 1 ]; then
+  echo "usage: $0 <target>" >&2
+  echo "  <target>: arm64-darwin | x86_64-linux-gnu | x86_64-darwin" >&2
+  exit 2
+fi
+
+TARGET="$1"
+
+case "$TARGET" in
+  arm64-darwin | x86_64-linux-gnu | x86_64-darwin) ;;
+  *)
+    echo "error: unknown target '$TARGET'" >&2
+    echo "  supported: arm64-darwin | x86_64-linux-gnu | x86_64-darwin" >&2
+    exit 2
+    ;;
+esac
+
+# Resolve the repository root from this script's location so the build works
+# regardless of the caller's CWD.
+SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
+REPO_ROOT="$(cd -- "$SCRIPT_DIR/../.." && pwd)"
+cd -- "$REPO_ROOT"
+
+# ---------------------------------------------------------------------------
+# 1. Read the version from the single source of truth (lib/hive.rb)
+# ---------------------------------------------------------------------------
+# Matches:  VERSION = "0.1.0".freeze
+VERSION="$(grep -E 'VERSION = "[0-9]+\.[0-9]+\.[0-9]+"' lib/hive.rb \
+  | head -n1 \
+  | sed -E 's/.*VERSION = "([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')"
+
+if [ -z "$VERSION" ]; then
+  echo "error: could not read Hive::VERSION from lib/hive.rb" >&2
+  exit 1
+fi
+
+APP_NAME="hive-${VERSION}-${TARGET}"
+DIST_DIR="${REPO_ROOT}/dist"
+STAGE_ROOT="${DIST_DIR}/stage"
+STAGE_DIR="${STAGE_ROOT}/${APP_NAME}"
+TARBALL="${DIST_DIR}/${APP_NAME}.tar.gz"
+
+echo ">> Building ${APP_NAME}"
+echo "   version : ${VERSION}"
+echo "   target  : ${TARGET}"
+echo "   stage   : ${STAGE_DIR}"
+
+# ---------------------------------------------------------------------------
+# 2. Prepare a clean staging directory
+# ---------------------------------------------------------------------------
+rm -rf -- "${STAGE_DIR}"
+mkdir -p -- "${STAGE_DIR}"
+mkdir -p -- "${DIST_DIR}"
+
+# ---------------------------------------------------------------------------
+# 3. Copy the application code
+# ---------------------------------------------------------------------------
+# lib/ templates/ schemas/ are the runtime payload the CLI loads at run time.
+echo ">> Copying application code (lib/ templates/ schemas/)"
+cp -R -- "${REPO_ROOT}/lib" "${STAGE_DIR}/lib"
+cp -R -- "${REPO_ROOT}/templates" "${STAGE_DIR}/templates"
+cp -R -- "${REPO_ROOT}/schemas" "${STAGE_DIR}/schemas"
+
+# The real CLI entrypoint (repo bin/hive) is copied to libexec/hive; the
+# staged bin/hive is a launcher that sets up the environment then execs it.
+echo ">> Copying entrypoint to libexec/hive"
+mkdir -p -- "${STAGE_DIR}/libexec"
+cp -- "${REPO_ROOT}/bin/hive" "${STAGE_DIR}/libexec/hive"
+chmod +x "${STAGE_DIR}/libexec/hive"
+
+# The Gemfile / Gemfile.lock must travel with the app so Bundler can resolve
+# the vendored gems at runtime (the launcher points BUNDLE_GEMFILE at them).
+cp -- "${REPO_ROOT}/Gemfile" "${STAGE_DIR}/Gemfile"
+cp -- "${REPO_ROOT}/Gemfile.lock" "${STAGE_DIR}/Gemfile.lock"
+
+# Stage the LICENSE so it travels in the tarball. The AUR PKGBUILD and the
+# Homebrew formula install it (e.g. install -Dm644 .../usr/lib/hive/LICENSE),
+# which fails if it is missing from the artifact.
+cp -- "${REPO_ROOT}/LICENSE" "${STAGE_DIR}/LICENSE"
+
+# ---------------------------------------------------------------------------
+# 4. Vendor the runtime gems into vendor/bundle
+# ---------------------------------------------------------------------------
+# We install only the default gem group (no development/test) so the shipped
+# bundle stays small and the platform-specific FFI native gems (bubbletea /
+# lipgloss) get compiled/fetched for the host platform.
+#
+# NOTE (R1 — Charm FFI gems): bubbletea/lipgloss ship precompiled
+# platform-specific variants (see Gemfile.lock: `-x86_64-linux-gnu`). Bundler
+# must resolve the variant that matches THIS runner. If a precompiled variant
+# for the target platform is unavailable (see R2 for arm64-darwin), the
+# install falls back to compiling from source, which needs a Go toolchain.
+echo ">> Vendoring gems into vendor/bundle (production group only)"
+(
+  cd -- "${STAGE_DIR}"
+  export BUNDLE_GEMFILE="${STAGE_DIR}/Gemfile"
+  bundle config set --local path "vendor/bundle"
+  bundle config set --local without "development:test"
+  bundle config set --local deployment "true"
+  # Ensure the lockfile carries the current host platform so the native
+  # variant of the Charm gems is selected for this target. A failed platform
+  # lock must fail the build (set -e) rather than silently resolve the wrong
+  # Charm FFI native gem — do NOT swallow this with `|| true`.
+  bundle lock --add-platform "${TARGET}"
+  bundle install --jobs 4
+  # Drop cached .gem files and build intermediates to keep the tarball lean.
+  rm -rf -- vendor/bundle/ruby/*/cache
+)
+
+# ---------------------------------------------------------------------------
+# 5. Bundle a relocatable Ruby runtime under ruby/
+# ---------------------------------------------------------------------------
+# TODO (R1/R2 — portable Ruby): A truly relocatable Ruby build needs a
+# toolchain such as ruby-build with a relocation-safe --enable-load-relative
+# configure flag, or a packager like tebako that welds Ruby + app into a single
+# binary. Wiring that up is tracked in the plan (R1: Charm FFI gems interplay
+# with a welded runtime; R2: arm64-darwin precompiled gem availability).
+#
+# Until that lands, CI on a NATIVE runner falls back to copying the runner's
+# Ruby prefix into ruby/. `ruby -e 'print RbConfig::CONFIG["prefix"]'` yields
+# the install prefix; we copy bin/, lib/ and (when present) the shared libruby
+# so the launcher can exec ruby/bin/ruby with no system Ruby on PATH.
+#
+# The copied prefix is host-ABI-specific — which is exactly why this script
+# must run on the target platform. It is NOT relocatable across machines with
+# a different Ruby install layout, but it is self-contained on the target's
+# own filesystem after extraction, which is the property `install.sh` relies
+# on for a `curl | bash` install onto the same OS/arch family.
+echo ">> Bundling Ruby runtime under ruby/"
+RUBY_PREFIX="$(ruby -e 'print RbConfig::CONFIG["prefix"]')"
+# Refuse to copy a shared system prefix: copying /usr (etc.) would vacuum the
+# entire system's /usr/bin, /usr/lib, /usr/include into the tarball. The build
+# must run against an isolated toolchain Ruby prefix (e.g. ruby/setup-ruby's
+# relocatable install, rbenv/ruby-build, etc.), not the OS Ruby.
+case "${RUBY_PREFIX}" in
+  /usr | /usr/local | /)
+    echo "!! ERROR: Ruby prefix is a shared system prefix: '${RUBY_PREFIX}'." >&2
+    echo "!!        Copying a system Ruby prefix would vacuum /usr/bin, /usr/lib," >&2
+    echo "!!        etc. into the tarball. Run the build against an isolated" >&2
+    echo "!!        toolchain Ruby prefix instead. See R1/R2 in packaging/build/README.md." >&2
+    exit 1
+    ;;
+esac
+if [ -n "${RUBY_PREFIX}" ] && [ -d "${RUBY_PREFIX}" ]; then
+  mkdir -p -- "${STAGE_DIR}/ruby"
+  # Copy the essential subtrees. Use -L to dereference symlinks so the copy
+  # is self-contained rather than pointing back at the runner's filesystem.
+  for sub in bin lib include; do
+    if [ -d "${RUBY_PREFIX}/${sub}" ]; then
+      # Prefer -L (dereference) so the copy is self-contained. If that fails
+      # (commonly a dangling symlink in the prefix), fall back to a plain copy
+      # but LOUDLY warn — do not suppress stderr — since a symlink-verbatim copy
+      # may not be self-contained on the target's filesystem.
+      if ! cp -RL -- "${RUBY_PREFIX}/${sub}" "${STAGE_DIR}/ruby/${sub}"; then
+        echo "!! WARNING: could not dereference a symlink under ${RUBY_PREFIX}/${sub}" >&2
+        echo "!!          (possible dangling symlink). Falling back to a plain copy;" >&2
+        echo "!!          the bundled ruby/ may not be fully self-contained." >&2
+        cp -R -- "${RUBY_PREFIX}/${sub}" "${STAGE_DIR}/ruby/${sub}"
+      fi
+    fi
+  done
+else
+  echo "!! WARNING: could not resolve a Ruby prefix to bundle." >&2
+  echo "!!          The launcher will fall back to system ruby at runtime." >&2
+  echo "!!          See R1/R2 in packaging/build/README.md." >&2
+fi
+
+# ---------------------------------------------------------------------------
+# 6. Write the bin/hive launcher
+# ---------------------------------------------------------------------------
+# The launcher is intentionally dependency-free POSIX-ish bash. It:
+#   * resolves its own directory following symlinks (the install symlinks
+#     ~/.local/bin/hive -> <app>/bin/hive, so we must chase the link),
+#   * sets HIVE_ROOT to the app directory,
+#   * points GEM_HOME/GEM_PATH at the vendored bundle's ruby ABI dir (globbed),
+#   * points RUBYLIB at the app's lib/,
+#   * execs the bundled ruby (ruby/bin/ruby) if present, else system ruby,
+#     running libexec/hive (a copy of the repo bin/hive).
+echo ">> Writing bin/hive launcher"
+mkdir -p -- "${STAGE_DIR}/bin"
+cat > "${STAGE_DIR}/bin/hive" <<'LAUNCHER'
+#!/usr/bin/env bash
+#
+# hive launcher — generated by packaging/build/build-artifact.sh.
+#
+# Resolves its own app directory (following symlinks), wires up a relocatable
+# Ruby + gem environment, and execs the real CLI (libexec/hive) under the
+# bundled Ruby. Self-contained: no system Ruby required when ruby/ is present.
+#
+set -euo pipefail
+
+# --- resolve this script's real directory, following symlinks ---------------
+SOURCE="${BASH_SOURCE[0]}"
+while [ -h "$SOURCE" ]; do
+  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
+  SOURCE="$(readlink "$SOURCE")"
+  # If the symlink target is relative, resolve it against the link's dir.
+  case "$SOURCE" in
+    /*) ;;
+    *) SOURCE="$DIR/$SOURCE" ;;
+  esac
+done
+BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
+
+# The app root is the parent of bin/.
+HIVE_ROOT="$(cd -P "$BIN_DIR/.." >/dev/null 2>&1 && pwd)"
+export HIVE_ROOT
+
+# --- gem environment --------------------------------------------------------
+# vendor/bundle/ruby/<abi>/ holds the installed gems; the <abi> dir name is
+# the Ruby ABI version (e.g. 3.4.0), so glob for it rather than hardcoding.
+GEM_ROOT=""
+for candidate in "$HIVE_ROOT"/vendor/bundle/ruby/*; do
+  if [ -d "$candidate" ]; then
+    GEM_ROOT="$candidate"
+    break
+  fi
+done
+
+if [ -n "$GEM_ROOT" ]; then
+  export GEM_HOME="$GEM_ROOT"
+  export GEM_PATH="$GEM_ROOT"
+fi
+
+# Let Bundler find the shipped Gemfile so `bundler/setup` resolves the
+# vendored gems deterministically.
+if [ -f "$HIVE_ROOT/Gemfile" ]; then
+  export BUNDLE_GEMFILE="$HIVE_ROOT/Gemfile"
+fi
+
+# Application code on the load path.
+export RUBYLIB="$HIVE_ROOT/lib${RUBYLIB:+:$RUBYLIB}"
+
+# --- select the Ruby interpreter --------------------------------------------
+# Prefer the bundled runtime; fall back to a system ruby only if we shipped
+# none (see R1/R2 in packaging/build/README.md).
+if [ -x "$HIVE_ROOT/ruby/bin/ruby" ]; then
+  RUBY_BIN="$HIVE_ROOT/ruby/bin/ruby"
+  # Ensure the bundled ruby's own libs/bins are found first.
+  export PATH="$HIVE_ROOT/ruby/bin:$PATH"
+else
+  RUBY_BIN="$(command -v ruby || true)"
+  if [ -z "$RUBY_BIN" ]; then
+    echo "hive: no bundled Ruby found and no system ruby on PATH." >&2
+    echo "hive: reinstall from https://github.com/ivankuznetsov/hive/releases" >&2
+    exit 70
+  fi
+fi
+
+exec "$RUBY_BIN" "$HIVE_ROOT/libexec/hive" "$@"
+LAUNCHER
+chmod +x "${STAGE_DIR}/bin/hive"
+
+# ---------------------------------------------------------------------------
+# 7. Create the tarball
+# ---------------------------------------------------------------------------
+echo ">> Creating tarball ${TARBALL}"
+rm -f -- "${TARBALL}"
+tar czf "${TARBALL}" -C "${STAGE_ROOT}" "${APP_NAME}"
+
+echo ">> Done: ${TARBALL}"
+echo "   $(cd "${DIST_DIR}" && ls -lh "${APP_NAME}.tar.gz" | awk '{print $5}') on disk"
