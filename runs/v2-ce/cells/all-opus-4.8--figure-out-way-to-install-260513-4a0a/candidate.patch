@@ -0,0 +1,35 @@
+# Acceptance C — prompt installer (`install.md`)
+
+Manual checklist. Run once per tier-1 OS in Claude Code AND one non-Claude
+agent (Codex or Pi).
+
+## Steps
+
+1. Open the agent CLI in a scratch directory.
+2. Paste:
+
+   ```
+   Read https://github.com/ivankuznetsov/hive/blob/main/install.md and follow it to install Hive on this machine.
+   ```
+
+3. Confirm the agent:
+   - detects the host OS/arch,
+   - picks the right channel (brew on macOS/Linuxbrew, `yay -S hive-bin` on
+     Arch, else the `install.sh` one-liner),
+   - runs it and STOPS if it fails,
+   - verifies `hive --version`,
+   - offers to run `hive init` in the cwd,
+   - offers the hive **skills** package via the agent marketplace **only if**
+     the agent exposes one (Claude Code: add marketplace). It must NEVER
+     install skills by copy-paste or via the core binary.
+
+## Pass criteria
+
+| Host / agent | Expected channel | Skills step |
+|--------------|------------------|-------------|
+| macOS arm64 / Claude Code | brew | offered via `claude plugin marketplace add` |
+| Arch / Codex | `yay -S hive-bin` | skipped or stubbed (Codex marketplace unconfirmed) |
+| Ubuntu 22.04 / Claude Code | brew (linuxbrew) or install.sh | offered via marketplace |
+
+No destructive step runs without a stop-condition; no shell rc file is edited
+silently.
diff --git a/test/acceptance/d-uninstall.sh b/test/acceptance/d-uninstall.sh
new file mode 100755
index 00000000..32fcb860
--- /dev/null
+++ b/test/acceptance/d-uninstall.sh
@@ -0,0 +1,51 @@
+#!/usr/bin/env bash
+# Acceptance D: `hive uninstall` removes the binary + daemon service and
+# PRESERVES accumulated work. Runs against an install.sh-style layout in an
+# isolated HOME so it is safe on any box (no package manager needed).
+#
+# Pass criteria: after uninstall the app dir + launcher symlink are gone, but
+# the state home (accumulated work) survives.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+VERSION="0.1.0"
+WORK="$(mktemp -d)"
+trap 'rm -rf -- "${WORK}"' EXIT
+fail() { printf 'FAIL: %s\n' "$*" >&2; exit 1; }
+ok()   { printf 'ok: %s\n' "$*"; }
+
+export HOME="${WORK}/home"
+export XDG_DATA_HOME="${HOME}/.local/share"
+export XDG_STATE_HOME="${HOME}/.local/state"
+export XDG_CONFIG_HOME="${HOME}/.config"
+unset HIVE_HOME
+
+# Simulate an install.sh layout: app dir + launcher symlink.
+APP="${XDG_DATA_HOME}/hive/${VERSION}/bin"
+mkdir -p "${APP}"
+cp "${REPO_ROOT}/bin/hive" "${APP}/hive"
+mkdir -p "${HOME}/.local/bin"
+ln -sf "${APP}/hive" "${HOME}/.local/bin/hive"
+
+# Seed accumulated work under the state home.
+mkdir -p "${XDG_STATE_HOME}/hive"
+echo '{"done":true}' > "${XDG_STATE_HOME}/hive/completed.json"
+
+# Drive uninstall through the repo checkout (dev bin/hive), forcing the
+# install_sh channel so it exercises real file removal against our layout.
+GEM_PATH="/tmp/hgems:$(ruby -e 'print Gem.path.join(":")' 2>/dev/null || true)" \
+  ruby -I"${REPO_ROOT}/lib" -r hive -r hive/install_channel -r hive/commands/uninstall -e '
+    ch = Hive::InstallChannel::Detected.new(
+      kind: :install_sh,
+      binary_path: File.join(ENV["XDG_DATA_HOME"], "hive", "0.1.0", "bin", "hive"),
+      update_command: nil, uninstall_command: "hive uninstall",
+      auto_updatable: true, note: "install.sh"
+    )
+    Hive::Commands::Uninstall.new(purge: true, channel: ch).call
+  ' || fail "uninstall raised"
+
+[ ! -e "${XDG_DATA_HOME}/hive/${VERSION}" ] || fail "app dir was not removed"
+[ ! -L "${HOME}/.local/bin/hive" ] || fail "launcher symlink was not removed"
+[ -f "${XDG_STATE_HOME}/hive/completed.json" ] || fail "accumulated work was NOT preserved"
+ok "uninstall removed binary + app dir and preserved work under state home"
+echo "Acceptance D passed."
diff --git a/test/acceptance/smoke-install-sh.sh b/test/acceptance/smoke-install-sh.sh
new file mode 100755
index 00000000..cf811b1b
--- /dev/null
+++ b/test/acceptance/smoke-install-sh.sh
@@ -0,0 +1,111 @@
+#!/usr/bin/env bash
+# Hermetic smoke test for install.sh: exercises OS/arch detection, checksum
+# verification, XDG placement, idempotent re-run, and the `hv` fallback —
+# against a fake local "release server" (a file:// URL is not portable, so we
+# stub curl/wget indirectly by serving from a temp dir). No network, no real
+# artifact. CI-friendly.
+#
+# Strategy: build a minimal fake tarball matching the app-dir shape, host it
+# under a temp dir, and point install.sh at it by overriding the download +
+# checksum tooling through a PATH shim. This keeps install.sh unmodified.
+set -euo pipefail
+
+REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+INSTALL_SH="${REPO_ROOT}/install.sh"
+VERSION="0.1.0"
+
+WORK="$(mktemp -d)"
+trap 'rm -rf -- "${WORK}"' EXIT
+
+fail() { printf 'FAIL: %s\n' "$*" >&2; exit 1; }
+ok()   { printf 'ok: %s\n' "$*"; }
+
+# --- 1. Build a fake app-dir tarball --------------------------------------
+detect_target() {
+  case "$(uname -s):$(uname -m)" in
+    Darwin:arm64) echo arm64-darwin ;;
+    Darwin:x86_64) echo x86_64-darwin ;;
+    Linux:x86_64|Linux:amd64) echo x86_64-linux-gnu ;;
+    *) echo "UNSUPPORTED" ;;
+  esac
+}
+TARGET="$(detect_target)"
+[ "${TARGET}" != "UNSUPPORTED" ] || { echo "skip: unsupported host platform for smoke"; exit 0; }
+
+STAGE="${WORK}/hive-${VERSION}-${TARGET}"
+mkdir -p "${STAGE}/bin"
+cat > "${STAGE}/bin/hive" <<'LAUNCHER'
+#!/bin/sh
+echo "0.1.0"
+LAUNCHER
+chmod +x "${STAGE}/bin/hive"
+
+SERVE="${WORK}/serve"
+mkdir -p "${SERVE}"
+TARBALL="hive-${VERSION}-${TARGET}.tar.gz"
+tar czf "${SERVE}/${TARBALL}" -C "${WORK}" "hive-${VERSION}-${TARGET}"
+( cd "${SERVE}" && { sha256sum "${TARBALL}" 2>/dev/null || shasum -a 256 "${TARBALL}"; } > SHA256SUMS )
+
+# --- 2. PATH shim: a fake `curl` that copies from our serve dir ------------
+SHIM="${WORK}/shim"
+mkdir -p "${SHIM}"
+cat > "${SHIM}/curl" <<SHIMEOF
+#!/usr/bin/env bash
+# emulate: curl -fsSL <url> -o <dest>  — map any URL to \${SERVE}/<basename>
+dest=""
+url=""
+while [ \$# -gt 0 ]; do
+  case "\$1" in
+    -o) dest="\$2"; shift 2 ;;
+    -*) shift ;;
+    *) url="\$1"; shift ;;
+  esac
+done
+base="\$(basename "\${url}")"
+[ -f "${SERVE}/\${base}" ] || exit 22
+cp "${SERVE}/\${base}" "\${dest}"
+SHIMEOF
+chmod +x "${SHIM}/curl"
+
+# --- 3. Isolated HOME + XDG -----------------------------------------------
+# Use a curated PATH (shim + coreutils only) so an ambient `hive` installed
+# elsewhere on the build box (e.g. /usr/local/bin) does not spuriously trip
+# the hv fallback in the plain-install phase.
+CLEAN_PATH="${SHIM}:/usr/bin:/bin"
+export HOME="${WORK}/home"
+export XDG_DATA_HOME="${HOME}/.local/share"
+mkdir -p "${HOME}/.local/bin"
+export PATH="${CLEAN_PATH}"
+export HIVE_VERSION="${VERSION}"
+
+# --- 4. Run install.sh -----------------------------------------------------
+bash "${INSTALL_SH}" >/dev/null 2>&1 || fail "install.sh exited non-zero"
+
+LINK="${HOME}/.local/bin/hive"
+[ -L "${LINK}" ] || fail "expected ~/.local/bin/hive symlink"
+"${LINK}" --version | grep -q "${VERSION}" || fail "installed hive did not report version"
+ok "fresh install placed hive under XDG and symlinked it"
+
+# --- 5. Idempotent re-run repoints, does not error ------------------------
+bash "${INSTALL_SH}" >/dev/null 2>&1 || fail "install.sh re-run failed"
+[ -L "${LINK}" ] || fail "symlink lost on re-run"
+ok "re-run is idempotent"
+
+# --- 6. hv fallback when a foreign hive is on PATH ------------------------
+FOREIGN="${WORK}/foreign"
+mkdir -p "${FOREIGN}"
+cat > "${FOREIGN}/hive" <<'FEOF'
+#!/bin/sh
+echo "Apache Hive 3.1.3"
+FEOF
+chmod +x "${FOREIGN}/hive"
+# Fresh HOME so our managed hive is not already first on PATH.
+export HOME="${WORK}/home2"
+export XDG_DATA_HOME="${HOME}/.local/share"
+mkdir -p "${HOME}/.local/bin"
+export PATH="${SHIM}:${FOREIGN}:/usr/bin:/bin"
+bash "${INSTALL_SH}" >/dev/null 2>&1 || fail "install.sh (hv fallback) failed"
+[ -L "${HOME}/.local/bin/hv" ] || fail "expected hv fallback symlink when foreign hive present"
+ok "hv fallback links as hv when a foreign hive is on PATH"
+
+echo "ALL install.sh smoke assertions passed."
diff --git a/test/integration/hv_alias_test.rb b/test/integration/hv_alias_test.rb
