diff --git a/packaging/skills/plugins/hive-workflow/skills/hive-workflow/SKILL.md b/packaging/skills/plugins/hive-workflow/skills/hive-workflow/SKILL.md
new file mode 100644
index 00000000..235d9e6e
--- /dev/null
+++ b/packaging/skills/plugins/hive-workflow/skills/hive-workflow/SKILL.md
@@ -0,0 +1,127 @@
+---
+name: hive-workflow
+description: Drive the hive compound-engineering pipeline from a coding agent. Use when the user asks to capture an idea, advance a task through a stage (brainstorm/plan/develop/open-pr/review/finalize/archive), check task status, triage review findings, or otherwise operate hive. Prefers hive's typed --json envelopes over scraping human output.
+---
+
+# Driving the hive pipeline
+
+`hive` turns a rough idea into a merge-ready PR through an eight-stage pipeline.
+Every task is a folder; the folder's location IS the task state. Advancing a task
+one stage is the approval gesture. The stages:
+
+```
+1-inbox -> 2-brainstorm -> 3-plan -> 4-execute -> 5-open-pr -> 6-review -> 7-finalize -> 8-done
+capture     refine          design     build         draft PR      harden      publish       archive
+```
+
+Use this skill whenever the user expresses intent in natural language ("brainstorm
+the bookmark idea", "run review and tell me the findings") and translate it into
+`hive <verb>` calls. Almost every verb supports `--json` and emits a typed
+envelope — prefer `--json` and parse fields, do not scrape human tables.
+
+## Ground rules
+
+- Verify hive is installed first: `hive --version` (expected 0.1.0). If missing,
+  point the user at the repo-root `install.md` prompt; do not try to install it
+  from this skill.
+- `hive tui` is human-only and rejects `--json` (exit 64). Never call it for
+  programmatic work — use `hive status --json` and the typed verbs instead.
+- A task is identified by a **slug** or by its **task-folder path**. A bare slug
+  is resolved across all registered projects; if it exists in more than one
+  project, pass `--project <name>`. If it exists at more than one stage in a
+  project, pass `--stage <stage>` or an absolute folder path.
+- Stage names accept either the short form (`plan`) or the full folder form
+  (`3-plan`).
+
+## Capturing and inspecting work
+
+- Attach hive to a project (once per project):
+  `hive init .` — creates `.hive-state/` and registers the project globally.
+- Capture a new idea into `1-inbox`:
+  `hive new <project> "<title / short description>"` — prints the new slug.
+- See everything in flight:
+  `hive status --json` — emits the `hive-status` envelope (schema v2). Each row
+  carries an `action_key` and a nullable `diagnostic` (null when green,
+  populated for red recovery/error rows). Rows the user must act on have
+  `action_key` of `needs_input` or `review_findings`.
+- Diagnose one red task without the full snapshot:
+  `hive status --diagnose <slug> --json` (add `--project` / `--stage` to
+  disambiguate). Add `--write` to have the configured execute agent write
+  `diagnostics/red-status.md` (bounded run; `--force` bypasses idempotency).
+
+## Advancing a task through a stage
+
+Each workflow verb does double duty: it MOVES a completed task from the previous
+stage into this stage AND runs this stage's agent. Run with `--json` and
+summarize the envelope, surfacing any waiting/recovery markers.
+
+- `hive brainstorm <target>` — inbox -> brainstorm (refine what the user wants).
+- `hive plan <target>` — brainstorm -> plan (fix the approach).
+- `hive develop <target>` — plan -> execute (write the code).
+- `hive open-pr <target>` (alias `hive pr`) — execute -> open-pr (draft the PR).
+- `hive review <target>` — open-pr -> review (harden; writes review findings).
+- `hive finalize <target>` — review -> finalize (publish/ship).
+- `hive archive <target>` — finalize -> done.
+
+Useful flags on these verbs:
+- `--from <stage>` — assert the task is currently at `<stage>` before acting. Use
+  this on retries so a previously-successful call fails loudly (exit 4,
+  WRONG_STAGE) instead of silently advancing a second stage.
+- `--project <name>` — scope slug resolution to one project.
+
+Lower-level equivalents:
+- `hive run <target>` — run the stage agent for a task in place (does not move it).
+  `--stage`, `--project`, `--no-rebase` supported.
+- `hive approve <target>` — the agent-callable `mv`: advance to the next stage,
+  or `--to <stage>` for an explicit destination (including backward moves for
+  recovery). Forward auto-advance needs a terminal marker; `--force` bypasses it.
+  `--from <stage>` gives idempotency on retry.
+- `hive rebase-status <target> --json` — read-only: would the next run auto-rebase?
+
+## Triaging review findings
+
+The review stage writes GFM-checkbox findings. Accepted (`[x]`) findings are
+re-injected into the next `hive develop` (fix) pass.
+
+- List: `hive findings <target> --json` (`--pass N` for an older pass).
+- Accept: `hive accept-finding <target> [ID...]` — or `--all`, or
+  `--severity high|medium|low|nit`. Ticks `[x]`.
+- Reject: `hive reject-finding <target> [ID...]` — same flags; unticks back to `[ ]`.
+
+A common loop: `hive review <slug> --json` -> `hive findings <slug> --json` ->
+accept the ones worth fixing -> `hive develop <slug>` to re-inject them.
+
+## Recovery and markers
+
+- Clear a recovery marker so a task can be retried:
+  `hive markers clear <target> --name <NAME>` where NAME is one of
+  `REVIEW_STALE`, `REVIEW_CI_STALE`, `REVIEW_ERROR`, `EXECUTE_STALE`, `ERROR`.
+  Terminal-success markers (`COMPLETE`, `EXECUTE_COMPLETE`, `REVIEW_COMPLETE`)
+  cannot be cleared this way — use `hive approve` to move the task instead.
+
+## Registry and diagnostics
+
+- `hive doctor --json` — verify each stage's configured skill is installed for
+  its agent. Run this as a preflight before spawning stages.
+- `hive forget <name>` / `hive prune` — remove projects from / clean the registry.
+- `hive migrate [path]` — rename task folders from the pre-open-pr layout.
+- `hive metrics rollback-rate --json` — fraction of fix-agent commits later
+  reverted (`--days N`, `--project <name>`).
+- `hive daemon <start|stop|status|reload|tail|enable|disable> [project|--all]` —
+  the opt-in per-project daemon that polls `hive status --json` and auto-dispatches
+  verbs for tasks ready to advance. Stops at human-input/recovery gates.
+
+## The TUI (hand back to the human)
+
+When the user wants to watch progress rather than script it, tell them to run
+`hive tui` themselves — the live two-pane dashboard over `hive status`, driving
+every verb on a single keystroke (`b`/`p`/`d`/`P`/`r`/`F`/`a`, `n` to capture,
+`Enter` for the contextual next action, `?` for help, `q` to quit). It is
+human-only; you cannot drive it programmatically.
+
+## Envelopes
+
+Every `--json` verb returns a typed document on success and a structured error
+envelope on failure (with `ok`, `error_class`, `error_kind`, `exit_code`,
+`message`). Prefer switching on `action_key`, `error_kind`, and exit codes over
+parsing prose. Schemas ship in the hive repo under `schemas/`.
diff --git a/schemas/hive-uninstall.v1.json b/schemas/hive-uninstall.v1.json
new file mode 100644
index 00000000..82080f4e
--- /dev/null
+++ b/schemas/hive-uninstall.v1.json
@@ -0,0 +1,84 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-uninstall.v1.json",
+  "title": "hive uninstall output (v1)",
+  "description": "Stable contract emitted by `hive uninstall --json`. Stops and deregisters the daemon service, removes the managed binary/symlink (or prints the channel uninstall command for managed installs), and ALWAYS preserves accumulated work (~/.local/state/hive) and project .hive-state content. --purge is non-interactive but still preserves work.",
+  "oneOf": [
+    { "$ref": "#/$defs/SuccessPayload" },
+    { "$ref": "#/$defs/ErrorPayload" }
+  ],
+  "$defs": {
+    "SuccessPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "channel",
+        "purge",
+        "service_deregistered",
+        "binary_removed",
+        "binary_command",
+        "preserved",
+        "message"
+      ],
+      "properties": {
+        "schema": { "const": "hive-uninstall" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": true },
+        "channel": {
+          "type": "string",
+          "enum": ["brew", "aur", "install_sh", "dev", "unknown"]
+        },
+        "purge": { "type": "boolean" },
+        "service_deregistered": {
+          "type": "boolean",
+          "description": "true when a launchd/systemd-user unit was stopped and removed."
+        },
+        "binary_removed": {
+          "type": "boolean",
+          "description": "true when hive removed its own symlink/app-dir (install.sh channel); false for managed installs where the package manager owns the files."
+        },
+        "binary_command": {
+          "type": ["string", "null"],
+          "description": "For managed installs, the channel command the user should run to remove the binary (e.g. `brew uninstall hive`); null when hive removed the files itself."
+        },
+        "preserved": {
+          "type": "array",
+          "items": { "type": "string" },
+          "description": "Paths deliberately left intact (accumulated work / state)."
+        },
+        "message": { "type": "string" }
+      }
+    },
+    "ErrorPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "error_class",
+        "error_kind",
+        "exit_code",
+        "message"
+      ],
+      "properties": {
+        "schema": { "const": "hive-uninstall" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": false },
+        "error_class": { "type": "string" },
+        "error_kind": {
+          "type": "string",
+          "enum": ["internal"]
+        },
+        "exit_code": {
+          "type": "integer",
+          "enum": [1, 70]
+        },
+        "message": { "type": "string" }
+      }
+    }
+  }
+}
diff --git a/schemas/hive-update.v1.json b/schemas/hive-update.v1.json
