new file mode 100644
index 00000000..4483e216
--- /dev/null
+++ b/lib/hive/platform.rb
@@ -0,0 +1,56 @@
+require "rbconfig"
+
+module Hive
+  # Single owner of OS/platform detection and PATH executable lookup.
+  #
+  # Before this module the service backend (Hive::Service.detect_platform +
+  # its own `which`), the runtime preflight (Hive::Preflight.current_os + its
+  # own PATHEXT-aware `which`), and install-channel detection each
+  # reimplemented these with subtly different semantics that could disagree.
+  # Centralising them here keeps the two vocabularies (:darwin/:linux for
+  # service management, :macos/:arch/:fedora/:debian for install hints) under
+  # one owner backed by a single `which`.
+  module Platform
+    module_function
+
+    # True on macOS.
+    def macos?
+      (RbConfig::CONFIG["host_os"] =~ /darwin/i) ? true : false
+    end
+
+    # Coarse service-management kind: :darwin (launchd) / :linux (systemd).
+    # Consumed by Hive::Service.backend.
+    def service_kind
+      macos? ? :darwin : :linux
+    end
+
+    # Finer OS-family bucket for install-hint selection:
+    # :macos / :arch / :fedora / :debian. Probes package-manager tools to
+    # distinguish the common Linux families. Consumed by Hive::Preflight.
+    def os_family
+      return :macos if macos?
+
+      if which("pacman") then :arch
+      elsif which("dnf") || which("rpm") then :fedora
+      else :debian
+      end
+    end
+
+    # Locate an executable on PATH. Honours PATHEXT (a no-op on POSIX, where
+    # it is unset → a single empty extension). Returns the absolute candidate
+    # path or nil. This is the ONLY `which` in the codebase.
+    def which(name)
+      exts = ENV.fetch("PATHEXT", "").split(File::PATH_SEPARATOR)
+      exts = [ "" ] if exts.empty?
+      ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+        next if dir.empty?
+
+        exts.each do |ext|
+          candidate = File.join(dir, "#{name}#{ext}")
+          return candidate if File.file?(candidate) && File.executable?(candidate)
+        end
+      end
+      nil
+    end
+  end
+end
