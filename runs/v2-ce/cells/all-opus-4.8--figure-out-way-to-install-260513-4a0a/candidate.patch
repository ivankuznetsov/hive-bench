+#!/usr/bin/env bash
+#
+# hive installer — one-liner:
+#
+#   curl -fsSL https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh | bash
+#
+# Downloads the prebuilt, self-contained hive app-directory tarball for your
+# platform, verifies its checksum, installs it under an XDG data dir, and
+# symlinks the launcher onto your PATH. No sudo, no system Ruby required.
+#
+# Environment overrides:
+#   HIVE_VERSION   version to install (default: the version baked in below).
+#                  Release automation templates this to the latest version.
+#
+set -euo pipefail
+
+# ---------------------------------------------------------------------------
+# Configuration
+# ---------------------------------------------------------------------------
+REPO="ivankuznetsov/hive"
+
+# Default version. Release automation rewrites this line to the latest tag.
+# Override at runtime with HIVE_VERSION=x.y.z.
+HIVE_VERSION="${HIVE_VERSION:-0.1.0}"
+
+RELEASE_BASE="https://github.com/${REPO}/releases/download/v${HIVE_VERSION}"
+
+# XDG install locations (no sudo needed).
+DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
+INSTALL_ROOT="${DATA_HOME}/hive"
+VERSION_DIR="${INSTALL_ROOT}/${HIVE_VERSION}"
+BIN_DIR="${HOME}/.local/bin"
+
+# ---------------------------------------------------------------------------
+# Small helpers
+# ---------------------------------------------------------------------------
+info()  { printf '==> %s\n' "$*"; }
+warn()  { printf 'WARN: %s\n' "$*" >&2; }
+die()   { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
+
+# ---------------------------------------------------------------------------
+# 1. Detect platform and map to a release target
+# ---------------------------------------------------------------------------
+detect_target() {
+  local os arch
+  os="$(uname -s)"
+  arch="$(uname -m)"
+
+  case "${os}:${arch}" in
+    Darwin:arm64)          echo "arm64-darwin" ;;
+    Darwin:x86_64)         echo "x86_64-darwin" ;;
+    Linux:x86_64)          echo "x86_64-linux-gnu" ;;
+    Linux:amd64)           echo "x86_64-linux-gnu" ;;
+    *)
+      # tier-3 and unknown: Alpine/musl, aarch64-linux, BSD, etc.
+      die "unsupported platform: ${os}/${arch}.
+       Prebuilt hive tarballs exist for: macOS arm64, macOS x86_64, Linux x86_64 (glibc).
+       For other platforms install from source: https://github.com/${REPO}#install"
+      ;;
+  esac
+}
+
+TARGET="$(detect_target)"
+TARBALL="hive-${HIVE_VERSION}-${TARGET}.tar.gz"
+info "Platform: $(uname -s)/$(uname -m) -> ${TARGET}"
+info "Version : ${HIVE_VERSION}"
+
+# ---------------------------------------------------------------------------
+# 2. Pick a downloader and a checksum tool
+# ---------------------------------------------------------------------------
+if command -v curl >/dev/null 2>&1; then
+  download() { curl -fsSL "$1" -o "$2"; }
+elif command -v wget >/dev/null 2>&1; then
+  download() { wget -qO "$2" "$1"; }
+else
+  die "need either curl or wget to download release assets."
+fi
+
+# sha256 verification: Linux ships sha256sum; macOS ships shasum -a 256.
+if command -v sha256sum >/dev/null 2>&1; then
+  verify_checksum() { sha256sum -c "$1"; }
+elif command -v shasum >/dev/null 2>&1; then
+  verify_checksum() { shasum -a 256 -c "$1"; }
+else
+  die "need either sha256sum or shasum to verify the download."
+fi
+
+# ---------------------------------------------------------------------------
+# 3. Download tarball + SHA256SUMS into a temp dir and verify
+# ---------------------------------------------------------------------------
+TMP_DIR="$(mktemp -d)"
+cleanup() { rm -rf -- "${TMP_DIR}"; }
+trap cleanup EXIT
+
+info "Downloading ${TARBALL}"
+download "${RELEASE_BASE}/${TARBALL}" "${TMP_DIR}/${TARBALL}" \
+  || die "failed to download ${RELEASE_BASE}/${TARBALL}"
+
+info "Downloading SHA256SUMS"
+download "${RELEASE_BASE}/SHA256SUMS" "${TMP_DIR}/SHA256SUMS" \
+  || die "failed to download ${RELEASE_BASE}/SHA256SUMS"
+
+# Verify only the line for our tarball. `-c` expects filenames relative to CWD,
+# so run it from the temp dir against a filtered checksum file.
+info "Verifying checksum"
+(
+  cd "${TMP_DIR}"
+  # sha256sum lines are `<hash>  <filename>` (two spaces). Match the filename
+  # exactly by field equality so a substring or regex-metachar name can't slip
+  # through. awk exits 0 even on no match, so assert the output is non-empty.
+  awk -v f="${TARBALL}" '$2==f' SHA256SUMS > "${TARBALL}.sha256"
+  [ -s "${TARBALL}.sha256" ] || die "no checksum entry for ${TARBALL} in SHA256SUMS"
+  verify_checksum "${TARBALL}.sha256" \
+    || die "checksum verification FAILED for ${TARBALL} — refusing to install."
+)
+info "Checksum OK"
+
+# ---------------------------------------------------------------------------
+# 4. Extract into the versioned install dir (idempotent)
+# ---------------------------------------------------------------------------
+# Fresh extraction per install so `hive update` re-runs land a clean tree.
+info "Installing to ${VERSION_DIR}"
+rm -rf -- "${VERSION_DIR}"
+mkdir -p -- "${VERSION_DIR}"
+# The tarball contains a top-level hive-<version>-<target>/ dir; strip it so
+# the app files land directly under VERSION_DIR.
+tar xzf "${TMP_DIR}/${TARBALL}" -C "${VERSION_DIR}" --strip-components=1
+
+APP_LAUNCHER="${VERSION_DIR}/bin/hive"
+[ -x "${APP_LAUNCHER}" ] || die "extracted tarball is missing an executable bin/hive"
+
+# ---------------------------------------------------------------------------
+# 5. hv fallback (U11): avoid clobbering a foreign `hive` (e.g. Apache Hive)
+# ---------------------------------------------------------------------------
+# If a `hive` already resolves on PATH AND it is not one of ours (not under
+# our install root and not our managed symlink), install as `hv` instead so we
+# never shadow an unrelated tool.
+LINK_NAME="hive"
+EXISTING_HIVE="$(command -v hive 2>/dev/null || true)"
+if [ -n "${EXISTING_HIVE}" ]; then
+  # Resolve the existing hive to its real target (chase symlinks) for the
+  # "is it ours?" test.
+  RESOLVED="${EXISTING_HIVE}"
+  if [ -L "${EXISTING_HIVE}" ]; then
+    # readlink -f is not on macOS by default; fall back to a plain readlink and
+    # accept a best-effort resolution.
+    RESOLVED="$(readlink -f "${EXISTING_HIVE}" 2>/dev/null || readlink "${EXISTING_HIVE}" 2>/dev/null || echo "${EXISTING_HIVE}")"
+  fi
+  case "${RESOLVED}" in
+    "${INSTALL_ROOT}/"* | "${BIN_DIR}/hive")
+      # Ours (a previous install) — safe to repoint.
+      ;;
+    *)
+      LINK_NAME="hv"
+      warn "A different 'hive' is already on your PATH: ${EXISTING_HIVE}"
+      warn "To avoid shadowing it, installing this launcher as 'hv' instead."
+      warn "Invoke the tool as 'hv' (e.g. 'hv init', 'hv tui')."
+      ;;
+  esac
+fi
+
+# ---------------------------------------------------------------------------
+# 6. Symlink onto PATH (idempotent — repoint on re-run)
+# ---------------------------------------------------------------------------
+mkdir -p -- "${BIN_DIR}"
+LINK_PATH="${BIN_DIR}/${LINK_NAME}"
+ln -sf -- "${APP_LAUNCHER}" "${LINK_PATH}"
+info "Linked ${LINK_PATH} -> ${APP_LAUNCHER}"
+
+# ---------------------------------------------------------------------------
+# 7. PATH check (print, do not edit rc files)
+# ---------------------------------------------------------------------------
+case ":${PATH}:" in
+  *":${BIN_DIR}:"*) ;;
+  *)
+    warn "${BIN_DIR} is not on your PATH."
+    warn "Add this line to your shell rc (~/.bashrc, ~/.zshrc, ...):"
+    printf '\n    export PATH="%s:$PATH"\n\n' "${BIN_DIR}"
+    ;;
+esac
+
+# ---------------------------------------------------------------------------
+# 8. Optional runtime-dependency preflight (non-blocking warn only)
+# ---------------------------------------------------------------------------
+# packaging/lib/preflight.sh is authored separately; reference it defensively.
+# It runs a runtime-dependency check (git, bash, claude, gh, jq). We only warn —
+# a missing runtime dep never blocks install. This runs on BOTH the local-
+# checkout path (script sits next to packaging/) and the piped `curl | bash`
+# path (no local checkout — we fetch preflight.sh next to the release assets).
+PREFLIGHT_LOCAL="$(dirname -- "${BASH_SOURCE[0]:-$0}")/packaging/lib/preflight.sh"
+PREFLIGHT=""
+if [ -f "${PREFLIGHT_LOCAL}" ]; then
+  PREFLIGHT="${PREFLIGHT_LOCAL}"
+else
+  # Piped install (curl|bash): ${BASH_SOURCE[0]} is 'bash', so there is no local
+  # checkout — fetch preflight.sh from the release base. A download failure is a
+  # graceful non-blocking no-op (preflight is best-effort).
+  if download "${RELEASE_BASE}/preflight.sh" "${TMP_DIR}/preflight.sh" 2>/dev/null; then
+    PREFLIGHT="${TMP_DIR}/preflight.sh"
+  fi
+fi
+if [ -n "${PREFLIGHT}" ] && [ -f "${PREFLIGHT}" ]; then
+  # shellcheck disable=SC1090  # path is resolved at runtime
+  . "${PREFLIGHT}" && command -v hive_preflight >/dev/null 2>&1 && hive_preflight || true
+fi
+
+# ---------------------------------------------------------------------------
+# 9. Success summary
+# ---------------------------------------------------------------------------
+printf '\n'
+info "hive ${HIVE_VERSION} installed."
+info "Run '${LINK_NAME} --version' to confirm, then '${LINK_NAME} init .' inside a project to get started."
