+        "schema_version",
+        "ok",
+        "channel",
+        "command",
+        "executed",
+        "dry_run",
+        "auto_updatable",
+        "message"
+      ],
+      "properties": {
+        "schema": { "const": "hive-update" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": true },
+        "channel": {
+          "type": "string",
+          "enum": ["brew", "aur", "install_sh", "dev", "unknown"],
+          "description": "How hive was installed, as detected from the resolved launcher path."
+        },
+        "command": {
+          "type": ["string", "null"],
+          "description": "The exact native updater command; null when no automatic path exists."
+        },
+        "executed": {
+          "type": "boolean",
+          "description": "true when hive update actually ran the command (auto_updatable channels, not --dry-run)."
+        },
+        "dry_run": { "type": "boolean" },
+        "auto_updatable": {
+          "type": "boolean",
+          "description": "false for channels gated behind a user confirmation (AUR helper, dev checkout)."
+        },
+        "message": { "type": "string" }
+      }
+    },
+    "ErrorPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "error_class",
+        "error_kind",
+        "exit_code",
+        "message"
+      ],
+      "properties": {
+        "schema": { "const": "hive-update" },
+        "schema_version": { "const": 1 },
+        "ok": { "const": false },
+        "error_class": { "type": "string" },
+        "error_kind": {
+          "type": "string",
+          "enum": ["internal"],
+          "description": "internal = uncategorised crash (exit 70)."
+        },
+        "exit_code": {
+          "type": "integer",
+          "enum": [1, 70],
+          "description": "Hive::ExitCodes. 1=GENERIC, 70=SOFTWARE."
+        },
+        "message": { "type": "string" }
+      }
+    }
+  }
+}
