+++ b/packaging/homebrew/hive.rb
@@ -0,0 +1,65 @@
+# Homebrew formula for hive.
+#
+# This file is the SOURCE OF TRUTH. On release it is synced to the tap repo at
+# github.com/ivankuznetsov/homebrew-hive as Formula/hive.rb, and the placeholder
+# sha256 values below are filled in by release automation from the published
+# SHA256SUMS file.
+#
+# The release artifacts are relocatable, self-contained app-directory tarballs
+# that bundle their own Ruby. There is intentionally NO `depends_on "ruby"`.
+class Hive < Formula
+  desc "TUI and agent-driven CLI for orchestrating parallel coding tasks"
+  homepage "https://github.com/ivankuznetsov/hive"
+  license "MIT"
+  version "0.1.0"
+
+  on_macos do
+    on_arm do
+      url "https://github.com/ivankuznetsov/hive/releases/download/v0.1.0/hive-0.1.0-arm64-darwin.tar.gz"
+      # REPLACE_WITH_SHA256_AT_RELEASE: release automation fills this from SHA256SUMS.
+      sha256 "REPLACE_WITH_SHA256_AT_RELEASE"
+    end
+    on_intel do
+      url "https://github.com/ivankuznetsov/hive/releases/download/v0.1.0/hive-0.1.0-x86_64-darwin.tar.gz"
+      # REPLACE_WITH_SHA256_AT_RELEASE: release automation fills this from SHA256SUMS.
+      sha256 "REPLACE_WITH_SHA256_AT_RELEASE"
+    end
+  end
+
+  on_linux do
+    on_intel do
+      url "https://github.com/ivankuznetsov/hive/releases/download/v0.1.0/hive-0.1.0-x86_64-linux-gnu.tar.gz"
+      # REPLACE_WITH_SHA256_AT_RELEASE: release automation fills this from SHA256SUMS.
+      sha256 "REPLACE_WITH_SHA256_AT_RELEASE"
+    end
+  end
+
+  def install
+    # The tarball extracts to a self-contained app directory containing
+    # bin/hive (launcher), a bundled Ruby, vendor/bundle/, lib/, templates/,
+    # schemas/. Install the whole thing under libexec and symlink the launcher.
+    libexec.install Dir["*"]
+    bin.install_symlink libexec/"bin/hive"
+  end
+
+  def caveats
+    <<~EOS
+      Get started by running:
+        hive init
+
+      hive shells out to a few runtime tools. Install the ones you need:
+        git    (version control; almost always required)
+        gh     (github-cli, for PR and release workflows)
+        jq     (JSON processing)
+        claude (the Claude Code CLI, for agent-driven runs)
+
+      If another `hive` is already on your PATH and you would rather not shadow
+      it, link this formula's launcher under the `hv` alias instead:
+        ln -sf #{opt_libexec}/bin/hive #{HOMEBREW_PREFIX}/bin/hv
+    EOS
+  end
+
+  test do
+    assert_match version.to_s, shell_output("#{bin}/hive --version")
+  end
+end
diff --git a/packaging/lib/preflight.sh b/packaging/lib/preflight.sh
new file mode 100755
index 00000000..14d27905
--- /dev/null
+++ b/packaging/lib/preflight.sh
@@ -0,0 +1,55 @@
+#!/usr/bin/env bash
+# Runtime-dependency preflight for the pre-Ruby install.sh phase. Mirrors
+# lib/hive/preflight.rb: checks that git/bash/claude/gh/jq are present and
+# prints per-OS install hints for any that are missing. NEVER installs
+# anything and NEVER blocks the install — hive's runtime tools are runtime
+# (not build-time) dependencies. The richer version-aware Ruby preflight
+# runs later at `hive init` / `hive doctor --deps`.
+#
+# Usage: source this file and call `hive_preflight`. Returns 0 always;
+# missing tools are reported on stderr as warnings.
+
+# Coarse OS bucket for hint selection, matching Hive::Preflight.current_os.
+hive_preflight_os() {
+  case "$(uname -s)" in
+    Darwin) echo "macos"; return ;;
+  esac
+  if command -v pacman >/dev/null 2>&1; then echo "arch"
+  elif command -v dnf >/dev/null 2>&1 || command -v rpm >/dev/null 2>&1; then echo "fedora"
+  else echo "debian"
+  fi
+}
+
+# hive_preflight_hint <tool> <os> — echo the install hint for a tool/os.
+hive_preflight_hint() {
+  tool="$1"; os="$2"
+  case "$tool" in
+    git)    case "$os" in macos) echo "brew install git" ;; arch) echo "sudo pacman -S git" ;; fedora) echo "sudo dnf install git" ;; *) echo "sudo apt install git" ;; esac ;;
+    bash)   case "$os" in macos) echo "brew install bash" ;; arch) echo "sudo pacman -S bash" ;; fedora) echo "sudo dnf install bash" ;; *) echo "sudo apt install bash" ;; esac ;;
+    claude) echo "npm install -g @anthropic-ai/claude-code" ;;
+    gh)     case "$os" in macos) echo "brew install gh" ;; arch) echo "sudo pacman -S github-cli" ;; fedora) echo "sudo dnf install gh" ;; *) echo "sudo apt install gh" ;; esac ;;
+    jq)     case "$os" in macos) echo "brew install jq" ;; arch) echo "sudo pacman -S jq" ;; fedora) echo "sudo dnf install jq" ;; *) echo "sudo apt install jq" ;; esac ;;
+    *)      echo "install $tool" ;;
+  esac
+}
+
+# hive_preflight — check every runtime tool; warn (never fail) on missing.
+# Required tools (git, bash) get a stronger message than recommended ones.
+hive_preflight() {
+  os="$(hive_preflight_os)"
+  # "<tool>:<required>" pairs. required=1 → stronger wording.
+  for pair in "git:1" "bash:1" "claude:0" "gh:0" "jq:0"; do
+    tool="${pair%%:*}"
+    required="${pair##*:}"
+    if command -v "$tool" >/dev/null 2>&1; then
+      continue
+    fi
+    hint="$(hive_preflight_hint "$tool" "$os")"
+    if [ "$required" = "1" ]; then
+      printf 'hive: warning — required runtime tool %s not found. Install: %s\n' "$tool" "$hint" >&2
+    else
+      printf 'hive: note — recommended tool %s not found. Install: %s\n' "$tool" "$hint" >&2
+    fi
+  done
+  return 0
+}
