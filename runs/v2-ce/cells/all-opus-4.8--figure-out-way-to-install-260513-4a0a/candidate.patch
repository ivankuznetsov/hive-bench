+++ b/test/integration/hv_alias_test.rb
@@ -0,0 +1,44 @@
+require "test_helper"
+require "open3"
+
+# U11: the CLI is usable under either the `hive` or the `hv` command name.
+# install.sh links the binary as `hv` when a conflicting `hive` is already on
+# PATH; Thor derives the program name shown in usage from $PROGRAM_NAME, so
+# help/usage text must read correctly under the alias.
+class HvAliasTest < Minitest::Test
+  include HiveTestHelper
+
+  HIVE_BIN = File.expand_path("../../bin/hive", __dir__).freeze
+
+  def run_as(name, *args)
+    with_tmp_dir do |dir|
+      link = File.join(dir, name)
+      File.symlink(HIVE_BIN, link)
+      gem_path = "/tmp/hgems:#{`ruby -e 'print Gem.path.join(":")'`}"
+      out, _err, status = Open3.capture3({ "GEM_PATH" => gem_path }, link, *args)
+      yield out, status
+    end
+  end
+
+  def test_version_works_under_hv_alias
+    run_as("hv", "--version") do |out, status|
+      assert status.success?
+      assert_equal Hive::VERSION, out.strip
+    end
+  end
+
+  def test_help_usage_reflects_the_invoked_name
+    run_as("hv", "help") do |out, status|
+      assert status.success?
+      assert_match(/^\s*hv \w/, out, "usage lines should read 'hv <command>' under the alias")
+      refute_match(/^\s*hive /, out, "no 'hive ' usage lines should leak under the hv alias")
+    end
+  end
+
+  def test_default_name_still_reads_hive
+    run_as("hive", "help") do |out, status|
+      assert status.success?
+      assert_match(/^\s*hive \w/, out)
+    end
+  end
+end
diff --git a/test/integration/init_service_provider_test.rb b/test/integration/init_service_provider_test.rb
new file mode 100644
index 00000000..d9a59589
--- /dev/null
+++ b/test/integration/init_service_provider_test.rb
@@ -0,0 +1,163 @@
+require "test_helper"
+require "fileutils"
+require "hive/commands/init"
+
+# U3: init collects provider/model into the GLOBAL config, registers the
+# daemon service (never starting it silently), and never writes agent
+# slash-command directories.
+class InitServiceProviderTest < Minitest::Test
+  include HiveTestHelper
+
+  # Fake Hive::Service backend: records register/enable/installed? calls,
+  # writes nothing to disk.
+  class FakeService
+    attr_reader :registrations, :enables
+
+    def initialize(installed: false)
+      @installed = installed
+      @registrations = 0
+      @enables = 0
+    end
+
+    def installed?
+      @installed
+    end
+
+    def register
+      @registrations += 1
+      @installed = true
+      "/fake/unit/path"
+    end
+
+    def enable
+      @enables += 1
+    end
+  end
+
+  def tty_stringio(text)
+    io = StringIO.new(text)
+    io.define_singleton_method(:tty?) { true }
+    io
+  end
+
+  def make_tty_prompts(input_text)
+    input = StringIO.new(input_text)
+    input.define_singleton_method(:tty?) { true }
+    Hive::Commands::Init::Prompts.new(
+      input: input, output: StringIO.new, summary_io: StringIO.new
+    )
+  end
+
+  # Agent-flow answers for Prompts#collect: planning, development,
+  # reviewers, triage, 9 limits, daemon-enable, final confirm.
+  def default_prompt_inputs
+    ([ "", "", "", "" ] + Array.new(9, "") + [ "", "" ]).join("\n") + "\n"
+  end
+
+  def test_tty_init_writes_provider_model_and_registers_without_starting_on_no
+    with_tmp_global_config do |ghome|
+      with_tmp_git_repo do |dir|
+        svc = FakeService.new
+        # provider (blank → anthropic), model (blank → default), daemon "n"
+        io_in = tty_stringio("\n\nn\n")
+        capture_io do
+          Hive::Commands::Init.new(
+            dir,
+            prompts: make_tty_prompts(default_prompt_inputs),
+            service: svc,
+            io: { in: io_in, out: StringIO.new }
+          ).call
+        end
+
+        global = YAML.safe_load(File.read(File.join(ghome, "config.yml")))
+        assert_equal Hive::Config::DEFAULT_PROVIDER, global["provider"]
+        assert_equal Hive::Config::DEFAULT_MODEL, global["model"]
+        # registered_projects survived the provider/model merge.
+        assert(global["registered_projects"].any? { |p| p["path"] == dir })
+
+        assert_equal 1, svc.registrations, "service registered"
+        assert_equal 0, svc.enables, "answering n must not start the daemon"
+      end
+    end
+  end
+
+  def test_tty_init_enables_daemon_on_yes
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        svc = FakeService.new
+        io_in = tty_stringio("openai\n\ny\n") # provider openai, model default, daemon y
+        capture_io do
+          Hive::Commands::Init.new(
+            dir,
+            prompts: make_tty_prompts(default_prompt_inputs),
+            service: svc,
+            io: { in: io_in, out: StringIO.new }
+          ).call
+        end
+        assert_equal 1, svc.enables, "answering y enables+starts the daemon"
+      end
+    end
+  end
+
+  def test_non_tty_init_registers_via_injected_backend_without_starting
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        svc = FakeService.new
+        # Non-tty $stdin (default StringIO from test_helper). Injected
+        # backend is honoured even off-TTY, but must not start.
+        capture_io do
+          Hive::Commands::Init.new(dir, service: svc).call
+        end
+        assert_equal 1, svc.registrations
+        assert_equal 0, svc.enables
+      end
+    end
+  end
+
+  def test_reinit_does_not_duplicate_service_registration
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        svc = FakeService.new(installed: true) # already installed
+        capture_io { Hive::Commands::Init.new(dir, service: svc).call }
+        # register is idempotent (overwrites); installed? already true means
+        # no NEW unit is created — the single register call is an overwrite,
+        # not a duplicate, and enable was never called.
+        assert svc.installed?
+        assert_equal 0, svc.enables
+      end
+    end
+  end
+
+  def test_init_never_writes_agent_skill_directories
+    with_tmp_global_config do
+      with_tmp_dir do |home|
+        old_home = ENV["HOME"]
+        ENV["HOME"] = home
+        begin
+          with_tmp_git_repo do |dir|
+            capture_io { Hive::Commands::Init.new(dir, service: FakeService.new).call }
+            refute File.exist?(File.join(home, ".claude", "commands")), "must not write ~/.claude/commands"
+            refute File.exist?(File.join(home, ".claude", "skills")), "must not write ~/.claude/skills"
+            refute File.exist?(File.join(home, ".codex", "skills")), "must not write ~/.codex/skills"
+            refute File.exist?(File.join(home, ".config", "pi")), "must not write ~/.config/pi"
+          end
+        ensure
+          old_home.nil? ? ENV.delete("HOME") : ENV["HOME"] = old_home
+        end
+      end
+    end
+  end
+
+  def test_non_tty_init_without_injected_backend_skips_real_registration
+    # No service injected, non-tty, HIVE_SKIP not needed: resolve_service_backend
+    # returns nil (no TTY, no opt-in) so nothing is written to the real home.
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        out, = capture_io { Hive::Commands::Init.new(dir).call }
+        # Provider/model default line printed; nothing crashed.
+        assert Dir.exist?(File.join(dir, ".hive-state"))
+        refute_nil out
+      end
+    end
+  end
+end
diff --git a/test/integration/uninstall_test.rb b/test/integration/uninstall_test.rb
new file mode 100644
index 00000000..0df4a547
--- /dev/null
+++ b/test/integration/uninstall_test.rb
@@ -0,0 +1,224 @@
+require "test_helper"
+require "json"
+require "json_schemer"
+require "hive/install_channel"
+require "hive/commands/uninstall"
+
+class UninstallTest < Minitest::Test
+  include HiveTestHelper
+
+  class FakeService
+    attr_reader :unregistrations
+
+    def initialize(installed: true)
+      @installed = installed
+      @unregistrations = 0
+    end
+
+    def installed?
+      @installed
+    end
+
+    def unregister
+      @unregistrations += 1
+      @installed = false
+      true
+    end
+  end
+
+  UNINSTALL_SCHEMA = JSONSchemer.schema(
+    JSON.parse(File.read(Hive::Schemas.schema_path("hive-uninstall")))
+  )
+
+  def channel(kind, binary_path: "/x/hive", uninstall_command: nil)
+    Hive::InstallChannel::Detected.new(
+      kind: kind, binary_path: binary_path,
+      update_command: nil, uninstall_command: uninstall_command,
+      auto_updatable: false, note: kind.to_s
+    )
+  end
+
+  # Isolate HOME + XDG dirs so uninstall touches only tmp paths and the
+  # data/state homes are distinct (no HIVE_HOME collapse).
+  def with_isolated_home
+    with_tmp_dir do |home|
+      saved = %w[HOME HIVE_HOME XDG_CONFIG_HOME XDG_STATE_HOME XDG_DATA_HOME].to_h { |k| [ k, ENV[k] ] }
+      ENV["HOME"] = home
+      ENV.delete("HIVE_HOME")
+      ENV["XDG_CONFIG_HOME"] = File.join(home, ".config")
+      ENV["XDG_STATE_HOME"] = File.join(home, ".local", "state")
+      ENV["XDG_DATA_HOME"] = File.join(home, ".local", "share")
+      begin
+        yield home
+      ensure
+        saved.each { |k, v| v.nil? ? ENV.delete(k) : ENV[k] = v }
+      end
+    end
+  end
+
+  def seed_work
+    state = Hive::Paths.state_home
+    FileUtils.mkdir_p(state)
+    work = File.join(state, "completed-pipeline.json")
+    File.write(work, "{}")
+    work
+  end
+
+  def test_default_uninstall_deregisters_service_and_preserves_work
+    with_isolated_home do
+      work = seed_work
+      svc = FakeService.new
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(service: svc, channel: channel(:dev), output: out).call
+      assert_equal 1, svc.unregistrations
+      assert File.exist?(work), "accumulated work must be preserved"
+      assert_includes out.string, "preserved"
+    end
+  end
+
+  def test_purge_preserves_work_but_removes_global_config
+    with_isolated_home do
+      work = seed_work
+      cfg = Hive::Config.global_config_path
+      FileUtils.mkdir_p(File.dirname(cfg))
+      File.write(cfg, { "registered_projects" => [] }.to_yaml)
+
+      svc = FakeService.new
+      Hive::Commands::Uninstall.new(purge: true, service: svc, channel: channel(:dev), output: StringIO.new).call
+
+      refute File.exist?(cfg), "--purge removes the global config/registry"
+      assert File.exist?(work), "--purge STILL preserves accumulated work"
+    end
+  end
+
+  def test_managed_install_prints_channel_command_not_rm
+    with_isolated_home do
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(
+        service: FakeService.new(installed: false),
+        channel: channel(:brew, uninstall_command: "brew uninstall hive"),
+        output: out
+      ).call
+      assert_includes out.string, "brew uninstall hive"
+    end
+  end
+
+  def test_install_sh_removes_files_but_keeps_state_home
+    with_isolated_home do
+      work = seed_work
+      data = Hive::Paths.data_home
+      app_bin = File.join(data, "0.1.0", "bin")
+      FileUtils.mkdir_p(app_bin)
+      launcher = File.join(app_bin, "hive")
+      File.write(launcher, "#!/bin/sh\n")
+      FileUtils.mkdir_p(Hive::Paths.bin_dir)
+      link = File.join(Hive::Paths.bin_dir, "hive")
+      File.symlink(launcher, link)
+
+      ch = channel(:install_sh, binary_path: File.realpath(launcher))
+      Hive::Commands::Uninstall.new(service: FakeService.new(installed: false), channel: ch, output: StringIO.new).call
+
+      refute File.exist?(File.join(data, "0.1.0")), "app dir removed"
+      refute File.symlink?(link), "launcher symlink removed"
+      assert File.exist?(work), "state home work preserved"
+    end
+  end
+
+  def test_never_removes_agent_skill_dirs
+    with_isolated_home do |home|
+      claude = File.join(home, ".claude", "skills", "x")
+      FileUtils.mkdir_p(claude)
+      Hive::Commands::Uninstall.new(
+        purge: true, service: FakeService.new(installed: false),
+        channel: channel(:install_sh, binary_path: "/nonexistent/hive"), output: StringIO.new
+      ).call
+      assert Dir.exist?(claude), "agent skill dirs are never touched by uninstall"
+    end
+  end
+
+  def test_json_envelope_validates
+    with_isolated_home do
+      seed_work
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(
+        json: true, service: FakeService.new, channel: channel(:brew, uninstall_command: "brew uninstall hive"),
+        output: out
+      ).call
+      doc = JSON.parse(out.string)
+      assert UNINSTALL_SCHEMA.valid?(doc), UNINSTALL_SCHEMA.validate(doc).map { |e| e["error"] }.join("; ")
+      assert_equal "brew", doc["channel"]
+      assert doc["service_deregistered"]
+      refute doc["binary_removed"]
+      assert_equal "brew uninstall hive", doc["binary_command"]
+      assert(doc["preserved"].any? { |p| p.include?("state") })
+    end
+  end
+
+  # HIVE_HOME collapse: when data_home == state_home, removing the "app dir"
+  # would delete accumulated work, so remove_install_sh_files must no-op. This
+  # exercises the guard in the collapsed layout the other tests deliberately
+  # avoid.
+  def test_collapsed_home_never_removes_install_sh_files
+    with_tmp_dir do |home|
+      saved = %w[HOME HIVE_HOME XDG_CONFIG_HOME XDG_STATE_HOME XDG_DATA_HOME].to_h { |k| [ k, ENV[k] ] }
+      ENV["HOME"] = home
+      ENV["HIVE_HOME"] = home # collapses data_home == state_home == home
+      %w[XDG_CONFIG_HOME XDG_STATE_HOME XDG_DATA_HOME].each { |k| ENV.delete(k) }
+      begin
+        assert_equal Hive::Paths.data_home, Hive::Paths.state_home, "precondition: collapsed"
+        verdir = File.join(home, "0.1.0")
+        FileUtils.mkdir_p(File.join(verdir, "bin"))
+        launcher = File.join(verdir, "bin", "hive")
+        File.write(launcher, "#!/bin/sh\n")
+        ch = channel(:install_sh, binary_path: launcher)
+        out = StringIO.new
+        Hive::Commands::Uninstall.new(service: FakeService.new(installed: false), channel: ch, output: out).call
+        assert File.directory?(verdir), "collapsed home must never remove files (work-safety)"
+        refute out.string.include?("removed hive files")
+      ensure
+        saved.each { |k, v| v.nil? ? ENV.delete(k) : ENV[k] = v }
+      end
+    end
+  end
+
+  # Data-loss guard: a binary_path whose first data_home segment is NOT
+  # version-shaped (e.g. .../hive/bin/hive) must not rm_rf that segment.
+  def test_non_version_segment_is_not_removed
+    with_isolated_home do
+      data = Hive::Paths.data_home
+      bindir = File.join(data, "bin")
+      FileUtils.mkdir_p(bindir)
+      File.write(File.join(bindir, "hive"), "#!/bin/sh\n")
+      ch = channel(:install_sh, binary_path: File.join(bindir, "hive"))
+      Hive::Commands::Uninstall.new(service: FakeService.new(installed: false), channel: ch, output: StringIO.new).call
+      assert File.directory?(bindir), "a non-version-shaped segment must not be rm_rf'd"
+    end
+  end
+
+  # A genuine launchctl/systemctl failure during deregister must be surfaced,
+  # not reported as a clean "no daemon service to deregister".
+  def test_deregister_failure_is_surfaced
+    with_isolated_home do
+      failing = Object.new
+      def failing.installed?; true; end
+      def failing.unregister; raise Hive::Error, "launchctl bootout failed"; end
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(service: failing, channel: channel(:dev), output: out).call
+      assert_match(/FAILED/, out.string, "failed deregister must not read as clean")
+      refute_match(/no daemon service to deregister/, out.string)
+    end
+  end
+
+  def test_deregister_failure_json_marks_not_deregistered
+    with_isolated_home do
+      failing = Object.new
+      def failing.installed?; true; end
+      def failing.unregister; raise Hive::Error, "systemctl disable failed"; end
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(json: true, service: failing, channel: channel(:dev), output: out).call
+      doc = JSON.parse(out.string)
+      refute doc["service_deregistered"], "a failed deregister must not report true"
+      assert_includes doc["message"], "FAILED"
+    end
+  end
+end
