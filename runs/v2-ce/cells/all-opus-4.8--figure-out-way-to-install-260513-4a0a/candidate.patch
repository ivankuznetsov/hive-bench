+++ b/lib/hive/preflight.rb
@@ -0,0 +1,146 @@
+require "open3"
+require "rbconfig"
+require "hive"
+require "hive/platform"
+
+module Hive
+  # Runtime-dependency preflight. Reports which external tools hive shells
+  # out to at runtime are present, missing, or too old, with per-OS
+  # actionable install hints. It NEVER installs anything — hive's own
+  # install is not blocked by a missing runtime tool (they are runtime, not
+  # build-time, dependencies). Consumed by `hive doctor`, `hive init`'s
+  # post-init preflight, and mirrored in shell for install.sh's pre-Ruby
+  # phase (packaging/lib/preflight.sh).
+  module Preflight
+    # Each tool: the binary name, whether hive hard-requires it or merely
+    # recommends it, an optional version probe + minimum, and OS-keyed
+    # install hints. `claude` reuses Hive::MIN_CLAUDE_VERSION.
+    TOOLS = [
+      {
+        tool: "git", required: true,
+        hints: { macos: "brew install git", arch: "sudo pacman -S git",
+                 debian: "sudo apt install git", fedora: "sudo dnf install git" }
+      },
+      {
+        tool: "bash", required: true,
+        hints: { macos: "brew install bash", arch: "sudo pacman -S bash",
+                 debian: "sudo apt install bash", fedora: "sudo dnf install bash" }
+      },
+      {
+        tool: "claude", required: false, min: Hive::MIN_CLAUDE_VERSION,
+        hints: { macos: "npm install -g @anthropic-ai/claude-code",
+                 arch: "npm install -g @anthropic-ai/claude-code",
+                 debian: "npm install -g @anthropic-ai/claude-code",
+                 fedora: "npm install -g @anthropic-ai/claude-code" }
+      },
+      {
+        tool: "gh", required: false,
+        hints: { macos: "brew install gh", arch: "sudo pacman -S github-cli",
+                 debian: "sudo apt install gh", fedora: "sudo dnf install gh" }
+      },
+      {
+        tool: "jq", required: false,
+        hints: { macos: "brew install jq", arch: "sudo pacman -S jq",
+                 debian: "sudo apt install jq", fedora: "sudo dnf install jq" }
+      }
+    ].freeze
+
+    # Value object for a single tool probe. Encapsulates the invariant that
+    # was previously recomputed ad-hoc by Doctor readers:
+    #   ok == found && !too_old?
+    # `Result.for` is the ONE place that derives `ok`, `hint`, and
+    # `blocking?`; every consumer reads them off the struct instead of
+    # re-deriving. Struct index access (`result[:tool]`) is preserved so
+    # existing hash-shaped readers keep working.
+    Result = Struct.new(:tool, :required, :found, :path, :version, :min, :ok, :hint,
+                        keyword_init: true) do
+      # True when a versioned tool is present but older than its minimum.
+      def too_old?
+        !!(found && min && version && Hive::Preflight.version_lt?(version, min))
+      end
+
+      # A result is blocking when a REQUIRED tool is absent or a tool with a
+      # minimum version is present-but-too-old. Missing recommended tools
+      # warn but do not block.
+      def blocking?
+        return true if required && !found
+        return true if found && min && !ok
+
+        false
+      end
+
+      # Sole constructor: derives found/too_old/ok/hint from the raw probe
+      # so the ok == found && !too_old? invariant lives in exactly one place.
+      def self.for(spec, path:, version:)
+        found = !path.nil?
+        too_old = !!(version && spec[:min] && Hive::Preflight.version_lt?(version, spec[:min]))
+        ok = found && !too_old
+        new(
+          tool: spec[:tool], required: spec[:required], found: found,
+          path: path, version: version, min: spec[:min], ok: ok,
+          hint: ok ? nil : Hive::Preflight.hint_for(spec)
+        )
+      end
+    end
+
+    module_function
+
+    # Return an Array of Preflight::Result value objects. `ok` is false when
+    # a required tool is missing OR any tool with a `min` is present-but-too-
+    # old. Recommended (non-required) missing tools have ok:false too so
+    # callers can surface them, but see `blocking?`.
+    def check
+      TOOLS.map { |spec| check_tool(spec) }
+    end
+
+    def check_tool(spec)
+      path = Hive::Platform.which(spec[:tool])
+      version = path && spec[:min] ? probe_version(spec[:tool]) : nil
+      Result.for(spec, path: path, version: version)
+    end
+
+    # Back-compat module-level predicate; delegates to Result#blocking? so
+    # the blocking rule has a single definition on the value object.
+    def blocking?(result)
+      result.blocking?
+    end
+
+    # Best-effort `<tool> --version` parse. Returns the first dotted-number
+    # token, or nil if the probe fails or emits nothing recognisable.
+    def probe_version(tool)
+      out, _err, status = Open3.capture3(tool, "--version")
+      return nil unless status.success?
+
+      out[/\d+(?:\.\d+){1,3}/]
+    rescue StandardError
+      nil
+    end
+
+    # Semantic-ish "a < b" over dotted-number strings. Missing segments are
+    # treated as 0 so "2.1" < "2.1.5".
+    def version_lt?(a, b)
+      pa = a.split(".").map(&:to_i)
+      pb = b.split(".").map(&:to_i)
+      len = [ pa.size, pb.size ].max
+      len.times do |i|
+        av = pa[i] || 0
+        bv = pb[i] || 0
+        return true if av < bv
+        return false if av > bv
+      end
+      false
+    end
+
+    def hint_for(spec)
+      spec[:hints][current_os] || spec[:hints][:debian]
+    end
+
+    # Coarse OS bucket for hint selection (:macos/:arch/:fedora/:debian).
+    # Delegates to the single owner, Hive::Platform, so the shell mirror
+    # (packaging/lib/preflight.sh) and the service backend can't drift onto
+    # a divergent OS vocabulary.
+    def current_os
+      Hive::Platform.os_family
+    end
+  end
+end
diff --git a/lib/hive/service.rb b/lib/hive/service.rb
new file mode 100644
index 00000000..74397e18
--- /dev/null
+++ b/lib/hive/service.rb
@@ -0,0 +1,83 @@
+require "rbconfig"
+require "hive"
+require "hive/paths"
+require "hive/platform"
+require "hive/launcher"
+
+module Hive
+  # Cross-platform service abstraction that registers the hive daemon loop
+  # (`hive daemon start`) as a launchd agent (macOS) or a `systemd --user`
+  # unit (Linux), wired to `hive daemon {start,stop,status}`.
+  #
+  # `Hive::Service.backend` returns the platform-appropriate backend; every
+  # backend implements the same surface:
+  #
+  #   register    — write the unit file (idempotent)
+  #   unregister  — stop + remove the unit file
+  #   enable      — enable + start now (bootstrap / systemctl enable --now)
+  #   start / stop
+  #   status      — :active / :inactive / :not_installed
+  #   installed?  — the unit file exists on disk
+  #   render      — the unit-file text (pure; no side effects)
+  #
+  # Real launchctl / systemctl invocations go through an injectable
+  # `runner` (default: shell out) so unit tests exercise rendering and
+  # dispatch without a live service manager.
+  module Service
+    LABEL = "dev.hive.daemon".freeze
+    SYSTEMD_UNIT = "hive-daemon".freeze
+
+    module_function
+
+    def backend(platform: detect_platform, runner: nil, binary_path: nil)
+      case platform
+      when :darwin
+        require "hive/service/launchd"
+        Launchd.new(runner: runner, binary_path: binary_path)
+      when :linux
+        require "hive/service/systemd_user"
+        SystemdUser.new(runner: runner, binary_path: binary_path)
+      else
+        raise Hive::Error, "unsupported platform for service management: #{platform.inspect}"
+      end
+    end
+
+    # :darwin (launchd) / :linux (systemd). Delegates to the single platform
+    # owner so this vocabulary can't diverge from Preflight's OS buckets.
+    def detect_platform
+      Hive::Platform.service_kind
+    end
+
+    # True when a hive service unit is installed for the current platform.
+    # Guarded so callers (the daemon command) can decide whether to
+    # delegate lifecycle to the service manager or keep the dev-checkout
+    # fork behaviour. Never raises on an unsupported platform — returns
+    # false so the fork path stays the default.
+    def installed?(platform: detect_platform)
+      backend(platform: platform).installed?
+    rescue Hive::Error
+      false
+    end
+
+    # Resolve the installed `hive` (or `hv`) launcher path to bake into the
+    # unit's ExecStart. Delegates to Hive::Launcher (the single owner of
+    # launcher-path resolution) so a service ExecStart resolves the same real
+    # path `hive update` reasons about, instead of a second `which` with
+    # divergent symlink semantics.
+    def resolved_binary
+      Hive::Launcher.installed
+    end
+
+    # Default log path for the service-managed daemon (StandardOutPath /
+    # journald redirect). Under ~/.local/state/hive/logs by default.
+    def log_path
+      File.join(Hive::Paths.state_home, "logs", "daemon.log")
+    end
+
+    # Template dir shipped with hive; resolved via Paths.shared_asset so an
+    # installed artifact and a dev checkout both find it.
+    def template(name)
+      Hive::Paths.shared_asset(File.join("packaging", "service", name))
+    end
+  end
+end
diff --git a/lib/hive/service/base.rb b/lib/hive/service/base.rb
new file mode 100644
index 00000000..41e19cb7
--- /dev/null
+++ b/lib/hive/service/base.rb
@@ -0,0 +1,150 @@
+require "erb"
+require "fileutils"
+require "open3"
+require "hive/service"
+
+module Hive
+  module Service
+    # Shared scaffolding for the launchd / systemd-user backends: unit-file
+    # rendering, the injectable command runner, and the register / unregister
+    # file mechanics. Subclasses provide the platform-specific unit path,
+    # template name, and the launchctl / systemctl command sequences.
+    class Base
+      # A runner is `->(argv) { [stdout, stderr, Process::Status] }`. Tests
+      # inject a recording stub; production shells out via Open3.
+      DEFAULT_RUNNER = ->(argv) { Open3.capture3(*argv) }
+
+      # The closed set of symbols every backend's #status may return. A
+      # stray/omitted symbol used to silently read as "not running" upstream;
+      # `valid_status!` rejects anything outside this set.
+      STATUSES = %i[active inactive not_installed].freeze
+
+      def initialize(runner: nil, binary_path: nil)
+        @runner = runner || DEFAULT_RUNNER
+        @binary_path = binary_path
+      end
+
+      # --- abstract surface -------------------------------------------------
+      # Subclasses MUST implement these. Declaring them here means a subclass
+      # that forgets one raises a named NotImplementedError instead of a bare
+      # NoMethodError deep inside render/register/a file write.
+      def unit_path
+        raise NotImplementedError, "#{self.class}#unit_path"
+      end
+
+      def template_name
+        raise NotImplementedError, "#{self.class}#template_name"
+      end
+
+      def enable
+        raise NotImplementedError, "#{self.class}#enable"
+      end
+
+      def start
+        raise NotImplementedError, "#{self.class}#start"
+      end
+
+      def stop
+        raise NotImplementedError, "#{self.class}#stop"
+      end
+
+      # Must return one of STATUSES.
+      def status
+        raise NotImplementedError, "#{self.class}#status"
+      end
+
+      def binary_path
+        @binary_path ||= Hive::Service.resolved_binary
+      end
+
+      def log_path
+        Hive::Service.log_path
+      end
+
+      # Environment variables baked into the unit. Propagate an explicit
+      # HIVE_HOME so a service-managed daemon resolves the same home the
+      # operator used at `hive init` time.
+      def env
+        e = { "HIVE_SERVICE_MANAGED" => "1" }
+        e["HIVE_HOME"] = ENV["HIVE_HOME"] if ENV["HIVE_HOME"] && !ENV["HIVE_HOME"].empty?
+        e
+      end
+
+      def render
+        template = File.read(Hive::Service.template(template_name))
+        ERB.new(template, trim_mode: "-").result(binding)
+      end
+
+      def installed?
+        File.exist?(unit_path)
+      end
+
+      # Write the unit file (creating parent dirs) and run the post-write
+      # reload/bootstrap sequence. Idempotent: re-rendering over an existing
+      # unit is a no-op-equivalent overwrite. Raises Hive::Error if the
+      # post-register hook (daemon-reload / bootstrap) genuinely fails, so a
+      # caller can't report "registered and started" over a service manager
+      # that never picked the unit up.
+      def register
+        FileUtils.mkdir_p(File.dirname(unit_path))
+        FileUtils.mkdir_p(File.dirname(log_path))
+        File.write(unit_path, render)
+        post_register
+        unit_path
+      end
+
+      def unregister
+        return false unless installed?
+
+        pre_unregister
+        File.delete(unit_path) if File.exist?(unit_path)
+        true
+      end
+
+      # Reject a status symbol outside the closed STATUSES set — a typo or a
+      # new-but-unhandled state must not silently read as "not running".
+      def valid_status!(sym)
+        return sym if STATUSES.include?(sym)
+
+        raise Hive::Error,
+              "#{self.class}#status produced #{sym.inspect}, not one of #{STATUSES.inspect}"
+      end
+
+      protected
+
+      # Run a command through the injected runner; returns true on success.
+      # Use for probes where a non-zero exit is a legitimate signal (status)
+      # or benign (a launchd bootstrap that no-ops on an already-loaded unit).
+      def run(argv)
+        _out, _err, status = @runner.call(argv)
+        status.respond_to?(:success?) ? status.success? : !!status
+      end
+
+      # Run a command that MUST succeed for the operation to have taken
+      # effect. On a non-zero exit, raise Hive::Error carrying the tool's
+      # stderr instead of collapsing the failure to a discarded `false` — so
+      # `hive init` / `hive uninstall` surface the real launchctl/systemctl
+      # error rather than falsely reporting success. `action` is a short
+      # human phrase ("start the systemd user service").
+      def run!(argv, action:)
+        out, err, status = @runner.call(argv)
+        ok = status.respond_to?(:success?) ? status.success? : !!status
+        return true if ok
+
+        detail = err.to_s.strip
+        detail = out.to_s.strip if detail.empty?
+        raise Hive::Error,
+              "failed to #{action} (`#{argv.join(' ')}`)" \
+              "#{detail.empty? ? '' : ": #{detail}"}"
+      end
+
+      def run_capture(argv)
+        @runner.call(argv)
+      end
+
+      # Hooks — overridden by subclasses that need launchctl/systemctl.
+      def post_register; end
+      def pre_unregister; end
+    end
+  end
+end
diff --git a/lib/hive/service/launchd.rb b/lib/hive/service/launchd.rb
new file mode 100644
index 00000000..66041681
--- /dev/null
+++ b/lib/hive/service/launchd.rb
@@ -0,0 +1,73 @@
+require "hive/service/base"
+
+module Hive
+  module Service
+    # macOS launchd backend. Writes a LaunchAgent plist under
+    # ~/Library/LaunchAgents and drives it with `launchctl bootstrap /
+    # bootout / kickstart / print`.
+    class Launchd < Base
+      def label
+        Hive::Service::LABEL
+      end
+
+      def template_name
+        "dev.hive.daemon.plist.erb"
+      end
+
+      def unit_path
+        File.expand_path("~/Library/LaunchAgents/#{label}.plist")
+      end
+
+      def domain_target
+        "gui/#{Process.uid}"
+      end
+
+      def service_target
+        "#{domain_target}/#{label}"
+      end
+
+      # Enable = register + bootstrap into the GUI domain + kickstart.
+      def enable
+        register
+        start
+      end
+
+      def start
+        # `bootstrap` LOADS the job into the GUI domain; it exits non-zero
+        # benignly when the job is already loaded, so its result is not a
+        # clean "running now" signal and we treat it as best-effort. `kickstart`
+        # is what actually (re)starts the loaded job, so THAT is the
+        # authoritative step — raise if it fails.
+        run([ "launchctl", "bootstrap", domain_target, unit_path ])
+        run!([ "launchctl", "kickstart", "-k", service_target ],
+             action: "start the launchd job")
+      end
+
+      def stop
+        run!([ "launchctl", "bootout", service_target ],
+             action: "stop the launchd job")
+      end
+
+      # :active / :inactive / :not_installed. launchctl print exits non-zero
+      # when the service isn't loaded.
+      def status
+        return :not_installed unless installed?
+
+        valid_status!(run([ "launchctl", "print", service_target ]) ? :active : :inactive)
+      end
+
+      protected
+
+      # Best-effort load on register; a genuine problem surfaces at enable/
+      # start time (kickstart), and re-registering an already-bootstrapped
+      # unit fails benignly.
+      def post_register
+        run([ "launchctl", "bootstrap", domain_target, unit_path ])
+      end
+
+      def pre_unregister
+        run([ "launchctl", "bootout", service_target ])
+      end
+    end
+  end
+end
diff --git a/lib/hive/service/systemd_user.rb b/lib/hive/service/systemd_user.rb
new file mode 100644
index 00000000..9ab6fc16
--- /dev/null
+++ b/lib/hive/service/systemd_user.rb
@@ -0,0 +1,69 @@
+require "hive/service/base"
+
+module Hive
+  module Service
+    # Linux `systemd --user` backend. Writes a unit under
+    # ~/.config/systemd/user and drives it with `systemctl --user`.
+    class SystemdUser < Base
+      def unit_name
+        "#{Hive::Service::SYSTEMD_UNIT}.service"
+      end
+
+      def template_name
+        "hive-daemon.service.erb"
+      end
+
+      def unit_path
+        base = ENV["XDG_CONFIG_HOME"]
+        base = File.expand_path("~/.config") if base.nil? || base.empty?
+        File.join(base, "systemd", "user", unit_name)
+      end
+
+      # Enable = register + `systemctl --user enable --now` (enable at login
+      # AND start immediately). Raises Hive::Error if systemctl fails so the
+      # caller doesn't report success over a service that never enabled.
+      def enable
+        register
+        run!([ "systemctl", "--user", "enable", "--now", unit_name ],
+             action: "enable the systemd user service")
+      end
+
+      def start
+        run!([ "systemctl", "--user", "start", unit_name ],
+             action: "start the systemd user service")
+      end
+
+      def stop
+        run!([ "systemctl", "--user", "stop", unit_name ],
+             action: "stop the systemd user service")
+      end
+
+      # `systemctl --user is-active` prints active/inactive and exits 0 only
+      # when active. Map to :active / :inactive / :not_installed.
+      def status
+        return :not_installed unless installed?
+
+        out, _err, st = run_capture([ "systemctl", "--user", "is-active", unit_name ])
+        active = (st.respond_to?(:success?) && st.success?) || out.to_s.strip == "active"
+        valid_status!(active ? :active : :inactive)
+      end
+
+      protected
+
+      # A failed daemon-reload means the written unit won't be picked up;
+      # raise so `register` doesn't silently claim success.
+      def post_register
+        run!([ "systemctl", "--user", "daemon-reload" ],
+             action: "reload the systemd user daemon")
+      end
+
+      # Best-effort: the file deletion in Base#unregister is the authoritative
+      # removal. A disable failure on an already-disabled unit is benign, so
+      # we don't raise here; a genuine failure is surfaced by the unit still
+      # existing on a subsequent status probe.
+      def pre_unregister
+        run([ "systemctl", "--user", "disable", "--now", unit_name ])
+      end
+    end
+  end
+end
