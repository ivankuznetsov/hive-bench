index 00000000..4605b7da
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,103 @@
+require "json"
+require "open3"
+require "hive"
+require "hive/install_channel"
+
+module Hive
+  module Commands
+    # `hive update` — upgrade hive through the channel's NATIVE updater.
+    # Never swaps the binary in place (R6): brew/aur/install.sh own their
+    # files. Prints the exact command; runs it for channels safe to run
+    # unattended (brew, install.sh), and prints-only for channels that need
+    # a user gate (aur helper, dev checkout) or with --dry-run.
+    class Update
+      include Hive::Schemas::EnvelopeEmitter
+
+      def initialize(dry_run: false, json: false, channel: nil, runner: nil, output: $stdout)
+        @dry_run = dry_run
+        @json = json
+        @channel = channel
+        @runner = runner || InstallChannel::DEFAULT_RUNNER
+        @output = output
+      end
+
+      def call
+        call_with_envelope { do_call }
+      end
+
+      def envelope_schema
+        "hive-update"
+      end
+
+      def envelope_error_kind(error)
+        case error
+        when Hive::InternalError then "internal"
+        else "internal"
+        end
+      end
+
+      private
+
+      def do_call
+        channel = @channel || InstallChannel.detect
+        command = channel.update_command
+        executed = false
+
+        if command.nil?
+          message = "hive update: #{channel.note}. No automatic update path; " \
+                    "reinstall from https://github.com/ivankuznetsov/hive."
+        elsif @dry_run || !channel.auto_updatable
+          reason = @dry_run ? "dry-run" : "requires confirmation"
+          message = "hive update (#{channel.kind}, #{reason}): run this to upgrade:\n  #{command}"
+        else
+          ok, err = run_command(command)
+          # The native updater actually ran. If it FAILED, do not seal an
+          # ok:true / exit-0 envelope — that hid a broken `brew upgrade`
+          # behind a success signal. Raise so the JSON path emits an
+          # ok:false error envelope and the exit code is 70 (internal),
+          # honouring the documented "0 success; 70 internal error" contract.
+          # The updater's stderr is included so a wrapper sees why.
+          unless ok
+            detail = err.to_s.strip
+            raise Hive::InternalError,
+                  "hive update: `#{command}` failed" \
+                  "#{detail.empty? ? '' : ":\n#{detail}"}"
+          end
+          executed = true
+          message = "hive update: ran `#{command}`"
+        end
+
+        if @json
+          @output.puts JSON.generate(envelope(channel, command, executed, message))
+          @stdout_written = true
+        else
+          @output.puts message
+        end
+      end
+
+      # Run the channel's update command through a login shell (its string may
+      # contain a pipe, e.g. install.sh's `curl … | bash`). Returns
+      # [ok, stderr] so a failure can be surfaced with the updater's own
+      # diagnostics rather than discarded.
+      def run_command(command)
+        _out, err, status = @runner.call([ "bash", "-lc", command ])
+        ok = status.respond_to?(:success?) ? status.success? : !!status
+        [ ok, err ]
+      end
+
+      def envelope(channel, command, executed, message)
+        {
+          "schema" => "hive-update",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-update"),
+          "ok" => true,
+          "channel" => channel.kind.to_s,
+          "command" => command,
+          "executed" => executed,
+          "dry_run" => @dry_run,
+          "auto_updatable" => channel.auto_updatable,
+          "message" => message
+        }
+      end
+    end
+  end
+end
