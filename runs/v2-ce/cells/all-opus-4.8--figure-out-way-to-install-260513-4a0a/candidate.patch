+++ b/test/unit/preflight_test.rb
@@ -0,0 +1,143 @@
+require "test_helper"
+require "hive/preflight"
+
+class PreflightTest < Minitest::Test
+  include HiveTestHelper
+
+  def setup
+    @saved_path = ENV["PATH"]
+  end
+
+  def teardown
+    ENV["PATH"] = @saved_path
+  end
+
+  # Build a fake bin dir containing executable stubs for the named tools,
+  # point PATH at it exclusively, and yield.
+  def with_fake_path(tools)
+    with_tmp_dir do |dir|
+      tools.each do |name, body|
+        path = File.join(dir, name)
+        File.write(path, body || "#!/bin/sh\nexit 0\n")
+        FileUtils.chmod(0o755, path)
+      end
+      ENV["PATH"] = dir
+      yield dir
+    end
+  end
+
+  def result_for(results, tool)
+    results.find { |r| r[:tool] == tool }
+  end
+
+  def test_all_present_environment_has_no_blocking_results
+    stubs = {
+      "git" => nil, "bash" => nil, "gh" => nil, "jq" => nil,
+      "claude" => "#!/bin/sh\necho '9.9.9 (Claude Code)'\n"
+    }
+    with_fake_path(stubs) do
+      results = Hive::Preflight.check
+      results.each { |r| assert r[:found], "#{r[:tool]} should be found" }
+      refute results.any? { |r| Hive::Preflight.blocking?(r) }, "nothing should block when all present"
+    end
+  end
+
+  def test_missing_recommended_tools_surface_hints_but_do_not_block
+    # Only the required tools present; gh + jq + claude absent.
+    with_fake_path("git" => nil, "bash" => nil) do
+      results = Hive::Preflight.check
+      %w[gh jq claude].each do |tool|
+        r = result_for(results, tool)
+        refute r[:found], "#{tool} should be missing"
+        refute_nil r[:hint], "#{tool} should carry an install hint"
+        refute Hive::Preflight.blocking?(r), "missing recommended #{tool} must not block"
+      end
+    end
+  end
+
+  def test_missing_required_tool_blocks
+    with_fake_path("bash" => nil, "gh" => nil, "jq" => nil, "claude" => nil) do
+      results = Hive::Preflight.check
+      git = result_for(results, "git")
+      refute git[:found]
+      assert Hive::Preflight.blocking?(git), "missing required git must block"
+      refute_nil git[:hint]
+    end
+  end
+
+  def test_claude_below_min_version_flagged
+    old = "#!/bin/sh\necho '0.0.1'\n"
+    with_fake_path("git" => nil, "bash" => nil, "claude" => old) do
+      results = Hive::Preflight.check
+      c = result_for(results, "claude")
+      assert c[:found]
+      assert_equal Hive::MIN_CLAUDE_VERSION, c[:min]
+      refute c[:ok], "claude 0.0.1 must be flagged below MIN_CLAUDE_VERSION"
+      assert Hive::Preflight.blocking?(c), "too-old versioned tool must block"
+    end
+  end
+
+  def test_os_hints_are_os_appropriate
+    # macOS uses brew; arch uses pacman. Probe the hint map directly via a
+    # representative spec so we don't depend on the host OS.
+    jq_spec = Hive::Preflight::TOOLS.find { |s| s[:tool] == "jq" }
+    assert_equal "brew install jq", jq_spec[:hints][:macos]
+    assert_equal "sudo pacman -S jq", jq_spec[:hints][:arch]
+    assert_equal "sudo apt install jq", jq_spec[:hints][:debian]
+  end
+
+  def test_version_lt_treats_missing_segments_as_zero
+    assert Hive::Preflight.version_lt?("2.1", "2.1.5")
+    refute Hive::Preflight.version_lt?("2.1.5", "2.1")
+    refute Hive::Preflight.version_lt?("2.1.0", "2.1")
+  end
+
+  # A versioned tool that is PRESENT but whose --version emits nothing
+  # parseable is treated as version-unknown → not too-old → ok:true (we do
+  # not block on an unverifiable version). Guards probe_version's nil path.
+  def test_present_tool_with_unparseable_version_is_ok_not_blocking
+    unparseable = "#!/bin/sh\necho 'Claude Code (build abcdef, no dotted version)'\n"
+    with_fake_path("git" => nil, "bash" => nil, "claude" => unparseable) do
+      c = result_for(Hive::Preflight.check, "claude")
+      assert c[:found], "claude present"
+      assert_nil c[:version], "no dotted-number token parsed"
+      assert c[:ok], "unverifiable version must not be flagged too-old"
+      refute Hive::Preflight.blocking?(c)
+    end
+  end
+
+  # `--version` exiting non-zero → probe_version returns nil (same ok:true
+  # unverifiable path).
+  def test_present_tool_whose_version_probe_exits_nonzero_is_ok
+    failing = "#!/bin/sh\nexit 3\n"
+    with_fake_path("git" => nil, "bash" => nil, "claude" => failing) do
+      c = result_for(Hive::Preflight.check, "claude")
+      assert c[:found]
+      assert_nil c[:version]
+      assert c[:ok]
+    end
+  end
+
+  # probe_version returns the first dotted-number token, or nil on failure.
+  def test_probe_version_parses_and_tolerates_failure
+    with_fake_path("foo" => "#!/bin/sh\necho 'foo 3.14.1 (extra)'\n") do
+      assert_equal "3.14.1", Hive::Preflight.probe_version("foo")
+    end
+    assert_nil Hive::Preflight.probe_version("definitely-not-a-real-binary-xyz")
+  end
+
+  # The value object owns the ok == found && !too_old? invariant; readers
+  # (Doctor) rely on it instead of recomputing.
+  def test_result_value_object_enforces_ok_invariant
+    spec = { tool: "claude", required: false, min: "2.0.0", hints: { debian: "x" } }
+    old = Hive::Preflight::Result.for(spec, path: "/x/claude", version: "1.0.0")
+    assert old.too_old?
+    refute old.ok
+    assert old.blocking?
+
+    fresh = Hive::Preflight::Result.for(spec, path: "/x/claude", version: "2.5.0")
+    refute fresh.too_old?
+    assert fresh.ok
+    refute fresh.blocking?
+  end
+end
diff --git a/test/unit/service_test.rb b/test/unit/service_test.rb
new file mode 100644
index 00000000..4fee2de5
--- /dev/null
+++ b/test/unit/service_test.rb
@@ -0,0 +1,297 @@
+require "test_helper"
+require "hive/service"
+require "hive/service/launchd"
+require "hive/service/systemd_user"
+
+class ServiceTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeStatus = Struct.new(:success) do
+    def success?
+      success
+    end
+  end
+
+  # Recording runner: captures argv, returns a canned [out, err, status].
+  class RecordingRunner
+    attr_reader :calls
+
+    def initialize(out: "", success: true)
+      @out = out
+      @success = success
+      @calls = []
+    end
+
+    def call(argv)
+      @calls << argv
+      [ @out, "", FakeStatus.new(@success) ]
+    end
+
+    def to_proc
+      method(:call).to_proc
+    end
+  end
+
+  # --- Platform dispatch -----------------------------------------------
+
+  def test_backend_selects_launchd_on_darwin
+    assert_instance_of Hive::Service::Launchd, Hive::Service.backend(platform: :darwin)
+  end
+
+  def test_backend_selects_systemd_on_linux
+    assert_instance_of Hive::Service::SystemdUser, Hive::Service.backend(platform: :linux)
+  end
+
+  def test_backend_raises_on_unsupported_platform
+    assert_raises(Hive::Error) { Hive::Service.backend(platform: :plan9) }
+  end
+
+  # --- Unit rendering (golden-ish) -------------------------------------
+
+  def test_launchd_plist_renders_binary_and_log_path
+    svc = Hive::Service::Launchd.new(binary_path: "/opt/hive/bin/hive")
+    plist = svc.render
+    assert_includes plist, "<string>/opt/hive/bin/hive</string>"
+    assert_includes plist, "<string>daemon</string>"
+    assert_includes plist, "<string>start</string>"
+    assert_includes plist, "<string>dev.hive.daemon</string>"
+    assert_includes plist, "daemon.log"
+  end
+
+  def test_systemd_unit_renders_execstart_and_log_path
+    svc = Hive::Service::SystemdUser.new(binary_path: "/opt/hive/bin/hive")
+    unit = svc.render
+    # Binary path is quoted so a space in the launcher path can't split the
+    # systemd ExecStart into a bogus extra argument.
+    assert_includes unit, 'ExecStart="/opt/hive/bin/hive" daemon start'
+    assert_includes unit, 'ExecReload="/opt/hive/bin/hive" daemon reload'
+    assert_includes unit, "WantedBy=default.target"
+  end
+
+  def test_render_bakes_hive_home_env_when_set
+    with_tmp_dir do |dir|
+      prev = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = dir
+      begin
+        unit = Hive::Service::SystemdUser.new(binary_path: "/x/hive").render
+        # Env line is quoted so a space in HIVE_HOME (e.g. "/Users/Jane Doe")
+        # can't truncate the value.
+        assert_includes unit, %(Environment="HIVE_HOME=#{dir}")
+      ensure
+        prev.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = prev
+      end
+    end
+  end
+
+  # --- register / unregister file mechanics ----------------------------
+
+  def test_systemd_register_writes_unit_and_runs_daemon_reload
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        runner = RecordingRunner.new
+        svc = Hive::Service::SystemdUser.new(runner: runner.to_proc, binary_path: "/x/hive")
+        refute svc.installed?
+        path = svc.register
+        assert File.exist?(path), "unit file written"
+        assert svc.installed?
+        assert_includes path, File.join("systemd", "user", "hive-daemon.service")
+        assert(runner.calls.any? { |c| c == %w[systemctl --user daemon-reload] })
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  def test_systemd_unregister_disables_and_removes_unit
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        runner = RecordingRunner.new
+        svc = Hive::Service::SystemdUser.new(runner: runner.to_proc, binary_path: "/x/hive")
+        svc.register
+        assert svc.unregister
+        refute svc.installed?, "unit file removed"
+        assert(runner.calls.any? { |c| c.first(3) == %w[systemctl --user disable] })
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  # --- status mapping ---------------------------------------------------
+
+  def test_status_not_installed_when_unit_absent
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        svc = Hive::Service::SystemdUser.new(runner: RecordingRunner.new.to_proc, binary_path: "/x/hive")
+        assert_equal :not_installed, svc.status
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  def test_status_active_and_inactive_via_runner
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        active = RecordingRunner.new(out: "active\n", success: true)
+        svc = Hive::Service::SystemdUser.new(runner: active.to_proc, binary_path: "/x/hive")
+        svc.register
+        assert_equal :active, svc.status
+
+        inactive = RecordingRunner.new(out: "inactive\n", success: false)
+        svc2 = Hive::Service::SystemdUser.new(runner: inactive.to_proc, binary_path: "/x/hive")
+        assert_equal :inactive, svc2.status
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  def test_installed_predicate_survives_unsupported_platform
+    refute Hive::Service.installed?(platform: :plan9)
+  end
+
+  # --- systemd status OR-clauses ---------------------------------------
+  # `status` is active when is-active exits 0 OR prints "active"; the two
+  # branches must each independently map to :active.
+
+  def test_systemd_status_active_via_exit_code_branch
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        # exit 0 but EMPTY stdout — only the success? branch can match.
+        runner = RecordingRunner.new(out: "", success: true)
+        svc = Hive::Service::SystemdUser.new(runner: runner.to_proc, binary_path: "/x/hive")
+        svc.register
+        assert_equal :active, svc.status
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  def test_systemd_status_active_via_stdout_branch
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        # Register with a healthy runner (daemon-reload must succeed), then
+        # probe status with a runner whose is-active exits NON-ZERO but prints
+        # "active" — so only the stdout branch of the OR can map to :active.
+        Hive::Service::SystemdUser.new(runner: RecordingRunner.new.to_proc,
+                                       binary_path: "/x/hive").register
+        runner = RecordingRunner.new(out: "active\n", success: false)
+        svc = Hive::Service::SystemdUser.new(runner: runner.to_proc, binary_path: "/x/hive")
+        assert svc.installed?
+        assert_equal :active, svc.status
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  # --- systemd failure propagation -------------------------------------
+
+  def test_systemd_register_raises_when_daemon_reload_fails
+    with_tmp_dir do |home|
+      prev = ENV["XDG_CONFIG_HOME"]
+      ENV["XDG_CONFIG_HOME"] = home
+      begin
+        runner = RecordingRunner.new(success: false)
+        svc = Hive::Service::SystemdUser.new(runner: runner.to_proc, binary_path: "/x/hive")
+        # A failed `systemctl --user daemon-reload` must not be swallowed:
+        # register would otherwise return the unit_path as if it succeeded.
+        assert_raises(Hive::Error) { svc.register }
+      ensure
+        prev.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = prev
+      end
+    end
+  end
+
+  # --- launchd lifecycle (macOS backend argv sequence) -----------------
+
+  def with_home(dir)
+    prev = ENV["HOME"]
+    ENV["HOME"] = dir
+    yield
+  ensure
+    prev.nil? ? ENV.delete("HOME") : ENV["HOME"] = prev
+  end
+
+  def test_launchd_register_writes_plist_and_bootstraps
+    with_tmp_dir do |home|
+      with_home(home) do
+        runner = RecordingRunner.new
+        svc = Hive::Service::Launchd.new(runner: runner.to_proc, binary_path: "/x/hive")
+        refute svc.installed?
+        path = svc.register
+        assert File.exist?(path), "plist written"
+        assert svc.installed?
+        assert_includes path, File.join("Library", "LaunchAgents", "dev.hive.daemon.plist")
+        assert(runner.calls.any? { |c| c.first(2) == %w[launchctl bootstrap] })
+      end
+    end
+  end
+
+  def test_launchd_enable_bootstraps_then_kickstarts
+    with_tmp_dir do |home|
+      with_home(home) do
+        runner = RecordingRunner.new
+        svc = Hive::Service::Launchd.new(runner: runner.to_proc, binary_path: "/x/hive")
+        svc.enable
+        assert(runner.calls.any? { |c| c.first(2) == %w[launchctl bootstrap] })
+        assert(runner.calls.any? { |c| c.first(2) == %w[launchctl kickstart] })
+      end
+    end
+  end
+
+  def test_launchd_enable_raises_when_kickstart_fails
+    with_tmp_dir do |home|
+      with_home(home) do
+        # kickstart is the authoritative "running now" step; a failure must
+        # propagate rather than collapse to a discarded false.
+        runner = RecordingRunner.new(success: false)
+        svc = Hive::Service::Launchd.new(runner: runner.to_proc, binary_path: "/x/hive")
+        assert_raises(Hive::Error) { svc.enable }
+      end
+    end
+  end
+
+  def test_launchd_unregister_boots_out_and_removes_plist
+    with_tmp_dir do |home|
+      with_home(home) do
+        runner = RecordingRunner.new
+        svc = Hive::Service::Launchd.new(runner: runner.to_proc, binary_path: "/x/hive")
+        svc.register
+        assert svc.unregister
+        refute svc.installed?, "plist removed"
+        assert(runner.calls.any? { |c| c.first(2) == %w[launchctl bootout] })
+      end
+    end
+  end
+
+  def test_launchd_status_maps_print_result
+    with_tmp_dir do |home|
+      with_home(home) do
+        active = RecordingRunner.new(success: true)
+        svc = Hive::Service::Launchd.new(runner: active.to_proc, binary_path: "/x/hive")
+        assert_equal :not_installed, svc.status
+        svc.register
+        assert_equal :active, svc.status
+
+        inactive = RecordingRunner.new(success: false)
+        svc2 = Hive::Service::Launchd.new(runner: inactive.to_proc, binary_path: "/x/hive")
+        assert_equal :inactive, svc2.status, "print exits non-zero when not loaded"
+      end
+    end
+  end
+end
diff --git a/test/unit/update_test.rb b/test/unit/update_test.rb
new file mode 100644
index 00000000..56584dee
--- /dev/null
+++ b/test/unit/update_test.rb
@@ -0,0 +1,231 @@
+require "test_helper"
+require "json"
+require "json_schemer"
+require "hive/install_channel"
+require "hive/commands/update"
+
+class UpdateTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeStatus = Struct.new(:success) do
+    def success?
+      success
+    end
+  end
+
+  # Runner stub keyed by the first-token of argv → [out, success].
+  class StubRunner
+    attr_reader :calls
+
+    def initialize(responses)
+      @responses = responses
+      @calls = []
+    end
+
+    def call(argv)
+      @calls << argv
+      key = argv.first
+      out, success = @responses.fetch(key, [ "", false ])
+      [ out, "", FakeStatus.new(success) ]
+    end
+
+    def to_proc
+      method(:call).to_proc
+    end
+  end
+
+  UPDATE_SCHEMA = JSONSchemer.schema(
+    JSON.parse(File.read(Hive::Schemas.schema_path("hive-update")))
+  )
+
+  # --- InstallChannel.detect -------------------------------------------
+
+  def test_detects_brew_when_path_under_brew_prefix
+    runner = StubRunner.new("brew" => [ "/opt/homebrew\n", true ])
+    ch = Hive::InstallChannel.detect(binary_path: "/opt/homebrew/bin/hive", runner: runner.to_proc)
+    assert_equal :brew, ch.kind
+    assert_equal "brew upgrade ivankuznetsov/hive/hive", ch.update_command
+    assert ch.auto_updatable
+  end
+
+  def test_detects_aur_when_pacman_owns_the_path
+    runner = StubRunner.new(
+      "brew" => [ "", false ],
+      "pacman" => [ "hive-bin 0.1.0-1\n", true ]
+    )
+    ch = Hive::InstallChannel.detect(binary_path: "/usr/bin/hive", runner: runner.to_proc)
+    assert_equal :aur, ch.kind
+    assert_equal "yay -Syu hive-bin", ch.update_command
+    refute ch.auto_updatable, "AUR helper must be user-gated"
+  end
+
+  def test_detects_install_sh_under_data_home
+    with_tmp_dir do |home|
+      prev = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = home
+      begin
+        path = File.join(home, "0.1.0", "bin", "hive")
+        runner = StubRunner.new("brew" => [ "", false ], "pacman" => [ "", false ])
+        ch = Hive::InstallChannel.detect(binary_path: path, runner: runner.to_proc)
+        assert_equal :install_sh, ch.kind
+        assert_includes ch.update_command, "install.sh"
+        assert ch.auto_updatable
+      ensure
+        prev.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = prev
+      end
+    end
+  end
+
+  # Isolate detection from the ambient install: no HIVE_HOME / XDG override so
+  # data_home resolves to the real default, and the tmp paths under test can't
+  # accidentally match it.
+  def with_no_install_env
+    saved = %w[HIVE_HOME XDG_DATA_HOME].to_h { |k| [ k, ENV[k] ] }
+    saved.each_key { |k| ENV.delete(k) }
+    yield
+  ensure
+    saved.each { |k, v| v.nil? ? ENV.delete(k) : ENV[k] = v }
+  end
+
+  def test_detects_dev_checkout
+    with_no_install_env do
+      with_tmp_dir do |root|
+        FileUtils.mkdir_p(File.join(root, ".git"))
+        FileUtils.mkdir_p(File.join(root, "lib"))
+        File.write(File.join(root, "lib", "hive.rb"), "")
+        FileUtils.mkdir_p(File.join(root, "bin"))
+        binp = File.join(root, "bin", "hive")
+        File.write(binp, "")
+        runner = StubRunner.new("brew" => [ "", false ], "pacman" => [ "", false ])
+        ch = Hive::InstallChannel.detect(binary_path: binp, runner: runner.to_proc)
+        assert_equal :dev, ch.kind
+        refute ch.auto_updatable, "dev checkout must not auto-update"
+        refute ch.actionable?
+      end
+    end
+  end
+
+  def test_detects_unknown_when_nothing_matches
+    with_no_install_env do
+      with_tmp_dir do |dir|
+        binp = File.join(dir, "hive")
+        File.write(binp, "")
+        runner = StubRunner.new("brew" => [ "", false ], "pacman" => [ "", false ])
+        ch = Hive::InstallChannel.detect(binary_path: binp, runner: runner.to_proc)
+        assert_equal :unknown, ch.kind
+        assert_nil ch.update_command
+        refute ch.actionable?
+      end
+    end
+  end
+
+  # A symlinked launcher (the shape install.sh / a package manager drops on
+  # PATH) must be resolved to its REAL path before channel matching, else a
+  # brew/aur install detects as :unknown.
+  def test_detect_follows_symlink_to_real_path
+    with_no_install_env do
+      with_tmp_dir do |dir|
+        prefix = File.join(dir, "brewprefix")
+        FileUtils.mkdir_p(File.join(prefix, "bin"))
+        real = File.join(prefix, "bin", "hive")
+        File.write(real, "")
+        link = File.join(dir, "hive")
+        File.symlink(real, link)
+        runner = StubRunner.new("brew" => [ "#{prefix}\n", true ])
+        ch = Hive::InstallChannel.detect(binary_path: link, runner: runner.to_proc)
+        assert_equal :brew, ch.kind, "symlink resolved into the brew prefix"
+        assert_equal File.realpath(real), ch.binary_path
+      end
+    end
+  end
+
+  # Detected.build validates its inputs (kind enum + auto_updatable invariant).
+  def test_detected_build_validates_kind_and_invariant
+    assert_raises(ArgumentError) do
+      Hive::InstallChannel::Detected.build(
+        kind: :nonsense, binary_path: "/x", update_command: nil,
+        uninstall_command: nil, auto_updatable: false, note: "n"
+      )
+    end
+    assert_raises(ArgumentError) do
+      Hive::InstallChannel::Detected.build(
+        kind: :brew, binary_path: "/x", update_command: nil,
+        uninstall_command: nil, auto_updatable: true, note: "n"
+      )
+    end
+  end
+
+  # --- Update command ---------------------------------------------------
+
+  def brew_channel
+    Hive::InstallChannel::Detected.new(
+      kind: :brew, binary_path: "/opt/homebrew/bin/hive",
+      update_command: "brew upgrade ivankuznetsov/hive/hive",
+      uninstall_command: "brew uninstall hive", auto_updatable: true, note: "brew"
+    )
+  end
+
+  def aur_channel
+    Hive::InstallChannel::Detected.new(
+      kind: :aur, binary_path: "/usr/bin/hive",
+      update_command: "yay -Syu hive-bin",
+      uninstall_command: "sudo pacman -R hive-bin", auto_updatable: false, note: "aur"
+    )
+  end
+
+  def test_brew_channel_runs_the_upgrade_command
+    runner = StubRunner.new("bash" => [ "", true ])
+    out = StringIO.new
+    Hive::Commands::Update.new(channel: brew_channel, runner: runner.to_proc, output: out).call
+    assert(runner.calls.any? { |c| c[0] == "bash" && c[2].include?("brew upgrade") })
+    assert_includes out.string, "ran `brew upgrade"
+  end
+
+  def test_dry_run_prints_without_executing
+    runner = StubRunner.new("bash" => [ "", true ])
+    out = StringIO.new
+    Hive::Commands::Update.new(channel: brew_channel, dry_run: true, runner: runner.to_proc, output: out).call
+    assert_empty runner.calls, "dry-run must not execute anything"
+    assert_includes out.string, "brew upgrade"
+  end
+
+  def test_aur_channel_prints_but_does_not_run
+    runner = StubRunner.new("bash" => [ "", true ])
+    out = StringIO.new
+    Hive::Commands::Update.new(channel: aur_channel, runner: runner.to_proc, output: out).call
+    assert_empty runner.calls, "AUR helper must not run unattended"
+    assert_includes out.string, "yay -Syu hive-bin"
+  end
+
+  def test_json_envelope_validates
+    runner = StubRunner.new("bash" => [ "", true ])
+    out = StringIO.new
+    Hive::Commands::Update.new(channel: brew_channel, json: true, runner: runner.to_proc, output: out).call
+    doc = JSON.parse(out.string)
+    assert UPDATE_SCHEMA.valid?(doc), UPDATE_SCHEMA.validate(doc).map { |e| e["error"] }.join("; ")
+    assert_equal "brew", doc["channel"]
+    assert doc["executed"]
+  end
+
+  # A native updater that RAN and failed must not seal an ok:true / exit-0
+  # result. It raises (→ exit 70) instead of reporting success.
+  def test_failed_native_updater_raises_not_ok
+    runner = StubRunner.new("bash" => [ "", false ])
+    out = StringIO.new
+    err = assert_raises(Hive::InternalError) do
+      Hive::Commands::Update.new(channel: brew_channel, runner: runner.to_proc, output: out).call
+    end
+    assert_match(/failed/, err.message)
+    refute_match(/ran `brew upgrade/, out.string, "must not print a success line")
+  end
+
+  def test_failed_native_updater_json_emits_error_envelope
+    runner = StubRunner.new("bash" => [ "", false ])
+    out = StringIO.new
+    assert_raises(Hive::InternalError) do
+      Hive::Commands::Update.new(channel: brew_channel, json: true, runner: runner.to_proc, output: out).call
+    end
+    doc = JSON.parse(out.string)
+    refute doc["ok"], "a failed update must not report ok:true"
+  end
+end
