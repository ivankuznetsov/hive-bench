+[Unit]
+Description=hive autonomous pipeline daemon
+Documentation=https://github.com/ivankuznetsov/hive
+After=network-online.target
+Wants=network-online.target
+
+[Service]
+Type=simple
+# The service manager owns the lifecycle, so the daemon runs in the
+# foreground here (no --detach self-fork).
+ExecStart="<%= binary_path %>" daemon start
