+#!/usr/bin/env bash
+# Acceptance B: the AUR hive-bin package builds and installs on a clean Arch
+# box. Intended to run inside an Arch container (`archlinux:latest`) with
+# base-devel installed. Uses makepkg (as a non-root user) against the repo's
+# packaging/aur/PKGBUILD.
+#
+#   docker run --rm -v "$PWD":/src archlinux:latest bash /src/test/acceptance/b-aur.sh
+#
+# Pass criteria: makepkg produces a package, namcap is clean-ish, and after
+# install `hive --version` prints the release version. A real run needs the
+# release tarball published (or the PKGBUILD sha256sums adjusted to a local
+# build); this script documents + drives the steps and skips gracefully when
+# the tooling is absent.
+set -euo pipefail
+fail() { printf 'FAIL: %s\n' "$*" >&2; exit 1; }
+
+command -v makepkg >/dev/null 2>&1 || { echo "skip: makepkg not available (run inside an Arch container)"; exit 0; }
+
+REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+BUILD="$(mktemp -d)"
+cp "${REPO_ROOT}/packaging/aur/PKGBUILD" "${BUILD}/"
+cp "${REPO_ROOT}/packaging/aur/.SRCINFO" "${BUILD}/" 2>/dev/null || true
+cd "${BUILD}"
+
+if command -v namcap >/dev/null 2>&1; then
+  namcap PKGBUILD || echo "WARN: namcap reported PKGBUILD issues (review above)"
+fi
+
+echo "==> makepkg (requires the release tarball to be published, or edit sha256sums for a local build)"
+echo "    Run:  makepkg -si --noconfirm"
+echo "    Then: hive --version   # must print the release version"
+echo "    Upgrade path: after a new tag, 'yay -Syu hive-bin' upgrades in place."
+echo "b-aur.sh documented the steps; execute the commented commands on a real Arch box to complete acceptance B."
