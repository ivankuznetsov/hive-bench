index 00000000..9dc360b1
--- /dev/null
+++ b/.github/workflows/release.yml
@@ -0,0 +1,281 @@
+name: Release
+
+# Triggered on a semver tag push (v1.2.3). The tag is the release trigger and
+# the source of the version string; the version baked into lib/hive.rb must
+# match the tag (release-time invariant — asserted below).
+on:
+  push:
+    tags:
+      - "v*"
+
+# The release job needs write access to create the GitHub Release and upload
+# assets. Build/verify jobs only read.
+permissions:
+  contents: write
+
+concurrency:
+  group: release-${{ github.ref }}
+  cancel-in-progress: false
+
+jobs:
+  # ---------------------------------------------------------------------------
+  # build: one job per release target. Each runs on a native runner so the
+  # platform-specific FFI native gems (bubbletea/lipgloss) and the bundled Ruby
+  # prefix match the host ABI. Tier-2 (x86_64-darwin) is best-effort and does
+  # not fail the release.
+  # ---------------------------------------------------------------------------
+  build:
+    name: build ${{ matrix.target }}
+    runs-on: ${{ matrix.runner }}
+    continue-on-error: ${{ matrix.continue-on-error }}
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          # tier-1: macOS Apple Silicon
+          - target: arm64-darwin
+            runner: macos-14
+            tier: 1
+            continue-on-error: false
+          # tier-1: Linux glibc
+          - target: x86_64-linux-gnu
+            runner: ubuntu-22.04
+            tier: 1
+            continue-on-error: false
+          # tier-2: macOS Intel (best-effort — must not block the release)
+          - target: x86_64-darwin
+            runner: macos-13
+            tier: 2
+            continue-on-error: true
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v6
+
+      - name: Set up Ruby
+        uses: ruby/setup-ruby@v1
+        with:
+          # Match .ruby-version / Gemfile (~> 3.4). setup-ruby installs a
+          # relocatable-ish prefix that build-artifact.sh copies into ruby/.
+          ruby-version: "3.4"
+          bundler-cache: false
+
+      # ${{ github.ref_name }} is the tag (e.g. v0.1.0). Strip the leading v to
+      # get the plain version, and assert it matches lib/hive.rb so a mistagged
+      # release fails loudly instead of shipping a mismatched artifact.
+      - name: Resolve and verify version
+        id: version
+        shell: bash
+        run: |
+          set -euo pipefail
+          TAG="${{ github.ref_name }}"
+          VERSION="${TAG#v}"
+          SRC_VERSION="$(grep -E 'VERSION = "[0-9]+\.[0-9]+\.[0-9]+"' lib/hive.rb \
+            | head -n1 \
+            | sed -E 's/.*VERSION = "([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')"
+          echo "tag=$TAG"           >> "$GITHUB_OUTPUT"
+          echo "version=$VERSION"   >> "$GITHUB_OUTPUT"
+          if [ "$VERSION" != "$SRC_VERSION" ]; then
+            echo "::error::tag version ($VERSION) != lib/hive.rb version ($SRC_VERSION)"
+            exit 1
+          fi
+          echo "Building hive $VERSION for ${{ matrix.target }}"
+
+      - name: Build artifact
+        shell: bash
+        run: |
+          chmod +x packaging/build/build-artifact.sh
+          packaging/build/build-artifact.sh "${{ matrix.target }}"
+
+      # Verify on a CLEAN environment: extract to a temp dir with no repo on
+      # the load path, then exercise the launcher. `--version` must print the
+      # exact version; a non-TTY `status --json` must not crash the runtime
+      # (a non-zero exit from a legit "no config" error is acceptable — a
+      # runtime/loader crash is not, which we detect via a signal-level abort).
+      - name: Verify artifact on a clean environment
+        shell: bash
+        run: |
+          set -euo pipefail
+          VERSION="${{ steps.version.outputs.version }}"
+          TARGET="${{ matrix.target }}"
+          TARBALL="dist/hive-${VERSION}-${TARGET}.tar.gz"
+          test -f "$TARBALL" || { echo "::error::missing $TARBALL"; exit 1; }
+
+          WORK="$(mktemp -d)"
+          tar xzf "$TARBALL" -C "$WORK"
+          APP="$WORK/hive-${VERSION}-${TARGET}"
+          test -x "$APP/bin/hive" || { echo "::error::launcher not executable"; exit 1; }
+
+          echo "== hive --version =="
+          OUT="$("$APP/bin/hive" --version)"
+          echo "$OUT"
+          if [ "$OUT" != "$VERSION" ]; then
+            echo "::error::--version printed '$OUT', expected '$VERSION'"
+            exit 1
+          fi
+
+          echo "== hive status --json (non-TTY smoke) =="
+          # Run with stdin/stdout not a TTY. We only require the Ruby runtime
+          # not to crash (segfault / load error). A clean exit or a graceful
+          # non-zero Hive error exit code are both fine; a 139/134-style abort
+          # is a runtime failure.
+          set +e
+          "$APP/bin/hive" status --json < /dev/null > /tmp/status.out 2>/tmp/status.err
+          RC=$?
+          set -e
+          echo "exit=$RC"
+          cat /tmp/status.err || true
+          if [ "$RC" -ge 128 ]; then
+            echo "::error::runtime crashed (signal exit $RC)"
+            cat /tmp/status.out || true
+            exit 1
+          fi
+          echo "clean-environment verification OK"
+
+      - name: Upload artifact
+        uses: actions/upload-artifact@v4
+        with:
+          name: hive-${{ matrix.target }}
+          path: dist/hive-${{ steps.version.outputs.version }}-${{ matrix.target }}.tar.gz
+          if-no-files-found: error
+          retention-days: 7
+
+  # ---------------------------------------------------------------------------
+  # release: gather every built tarball, compute SHA256SUMS, and create/update
+  # the GitHub Release attaching all tarballs + SHA256SUMS + the repo-root
+  # install.sh. Runs even if the tier-2 build was skipped/failed (needs: build
+  # with the tier-2 job marked continue-on-error, so a tier-2 failure does not
+  # cascade here).
+  # ---------------------------------------------------------------------------
+  release:
+    name: publish release
+    needs: build
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v6
+
+      - name: Resolve version
+        id: version
+        shell: bash
+        run: |
+          set -euo pipefail
+          TAG="${{ github.ref_name }}"
+          echo "tag=$TAG"          >> "$GITHUB_OUTPUT"
+          echo "version=${TAG#v}"  >> "$GITHUB_OUTPUT"
+
+      - name: Download all build artifacts
+        uses: actions/download-artifact@v4
+        with:
+          path: dist-artifacts
+
+      # download-artifact drops each job's artifact into its own subdir; flatten
+      # them into ./dist so sha256sum sees a flat set of hive-*.tar.gz files.
+      - name: Collect tarballs
+        shell: bash
+        run: |
+          set -euo pipefail
+          mkdir -p dist
+          find dist-artifacts -name 'hive-*.tar.gz' -exec cp -v {} dist/ \;
+          echo "== collected =="
+          ls -l dist
+
+      - name: Generate SHA256SUMS
+        working-directory: dist
+        shell: bash
+        run: |
+          set -euo pipefail
+          sha256sum hive-*.tar.gz > SHA256SUMS
+          echo "== SHA256SUMS =="
+          cat SHA256SUMS
+
+      # Create or update the GitHub Release and attach every tarball, the
+      # checksums file, and the one-liner installer (install.sh from repo root).
+      - name: Create / update GitHub Release
+        uses: softprops/action-gh-release@v2
+        with:
+          tag_name: ${{ steps.version.outputs.tag }}
+          name: hive ${{ steps.version.outputs.version }}
+          generate_release_notes: true
+          fail_on_unmatched_files: true
+          files: |
+            dist/hive-*.tar.gz
+            dist/SHA256SUMS
+            install.sh
+            packaging/lib/preflight.sh
+
+  # ---------------------------------------------------------------------------
+  # bump-formulae: wire the shape of the downstream package-manager bumps.
+  #
+  # After the release assets exist, the Homebrew formula and the AUR PKGBUILD
+  # must be re-pointed at the new url + sha256. Full automation (committing to a
+  # tap repo / pushing to the AUR) is out of scope for this pass — the steps
+  # below compute the new values and show exactly which fields change. Promote
+  # the placeholders to real commits/pushes when the tap + AUR credentials are
+  # provisioned. See packaging/build/README.md.
+  # ---------------------------------------------------------------------------
+  bump-formulae:
+    name: bump homebrew + aur (placeholder)
+    needs: release
+    runs-on: ubuntu-latest
+    steps:
+      - name: Checkout
+        uses: actions/checkout@v6
+
+      - name: Resolve version
+        id: version
+        shell: bash
+        run: |
+          set -euo pipefail
+          echo "version=${GITHUB_REF_NAME#v}" >> "$GITHUB_OUTPUT"
+
+      # Homebrew: the formula points at the arm64-darwin (and/or x86_64) tarball.
+      # We fetch the just-published checksums so the new sha256 is authoritative.
+      - name: Compute new Homebrew url/sha256
+        shell: bash
+        run: |
+          # STUB (not real automation): this only prints the fields that WOULD
+          # change; it does not commit/push to any tap. A failed SHA256SUMS fetch
+          # deliberately exit-0s (green) so the placeholder never blocks a release.
+          set -euo pipefail
+          VERSION="${{ steps.version.outputs.version }}"
+          BASE="https://github.com/ivankuznetsov/hive/releases/download/v${VERSION}"
+          echo "Fetching SHA256SUMS from $BASE/SHA256SUMS"
+          curl -fsSL "$BASE/SHA256SUMS" -o /tmp/SHA256SUMS || {
+            echo "::warning::SHA256SUMS not yet available; skipping formula bump"
+            exit 0
+          }
+          echo "== new Homebrew fields (packaging/homebrew/hive.rb) =="
+          for tgt in arm64-darwin x86_64-linux-gnu x86_64-darwin; do
+            SUM="$(awk -v f="hive-${VERSION}-${tgt}.tar.gz" '$2==f{print $1}' /tmp/SHA256SUMS || true)"
+            [ -n "$SUM" ] || continue
+            echo "  target=$tgt"
+            echo "    url    \"$BASE/hive-${VERSION}-${tgt}.tar.gz\""
+            echo "    sha256 \"$SUM\""
+          done
+          # TODO: sed the values into packaging/homebrew/hive.rb and open a PR
+          # against the tap repo (or commit here if the formula lives in-tree).
+
+      # AUR: PKGBUILD needs pkgver + the matching sha256sums entry (x86_64-linux-gnu).
+      - name: Compute new AUR pkgver/sha256sums
+        shell: bash
+        run: |
+          # STUB (not real automation): prints the fields that WOULD change; it
+          # does not push to the AUR. Self-contained: it re-fetches SHA256SUMS
+          # itself rather than assuming the prior brew step (which exit-0s on a
+          # failed fetch) left /tmp/SHA256SUMS behind. Once promoted from stub,
+          # these steps should share an uploaded artifact instead of /tmp.
+          set -euo pipefail
+          VERSION="${{ steps.version.outputs.version }}"
+          BASE="https://github.com/ivankuznetsov/hive/releases/download/v${VERSION}"
+          curl -fsSL "$BASE/SHA256SUMS" -o /tmp/SHA256SUMS || {
+            echo "::warning::SHA256SUMS not yet available; skipping AUR bump"
+            exit 0
+          }
+          echo "== new AUR fields (packaging/aur/PKGBUILD) =="
+          echo "  pkgver=$VERSION"
+          if [ -f /tmp/SHA256SUMS ]; then
+            SUM="$(awk -v f="hive-${VERSION}-x86_64-linux-gnu.tar.gz" '$2==f{print $1}' /tmp/SHA256SUMS || true)"
+            [ -n "$SUM" ] && echo "  sha256sums=('$SUM')"
+          fi
+          # TODO: update packaging/aur/PKGBUILD (pkgver + sha256sums), regenerate
+          # .SRCINFO, and push to the AUR remote once credentials are provisioned.
