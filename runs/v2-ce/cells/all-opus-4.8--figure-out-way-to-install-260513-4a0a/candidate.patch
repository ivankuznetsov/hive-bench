diff --git a/lib/hive/install_channel.rb b/lib/hive/install_channel.rb
new file mode 100644
index 00000000..65e51b65
--- /dev/null
+++ b/lib/hive/install_channel.rb
@@ -0,0 +1,182 @@
+require "open3"
+require "rbconfig"
+require "hive"
+require "hive/paths"
+require "hive/launcher"
+
+module Hive
+  # Detect how this hive was installed by inspecting the resolved launcher
+  # path, so `hive update` / `hive uninstall` can drive the right native
+  # tooling instead of swapping files in place.
+  #
+  # Channels:
+  #   :brew       — the launcher lives under a Homebrew prefix
+  #   :aur        — pacman reports a `hive-bin` package owns the launcher
+  #   :install_sh — the launcher lives under the XDG data home (~/.local/share/hive)
+  #   :dev        — a bin/hive inside a git checkout
+  #   :unknown    — none of the above
+  module InstallChannel
+    # A detected install channel. `Detected.build` is the validated
+    # constructor: it constrains `kind` to the documented enum and enforces
+    # the invariant Update#do_call relies on — an `auto_updatable` channel
+    # MUST carry a non-nil `update_command` (otherwise "run it unattended"
+    # has nothing to run). `#actionable?` is the single predicate for
+    # "hive can drive an unattended update on this channel".
+    Detected = Struct.new(:kind, :binary_path, :update_command, :uninstall_command,
+                          :auto_updatable, :note, keyword_init: true) do
+      KINDS = %i[brew aur install_sh dev unknown].freeze
+
+      # True when hive may run this channel's update command unattended.
+      def actionable?
+        auto_updatable && !update_command.nil?
+      end
+
+      # Validated factory. Raises ArgumentError on an out-of-enum kind or a
+      # violated auto_updatable ⇒ update_command invariant, turning a silent
+      # data-bag mistake into a loud failure at construction.
+      def self.build(**attrs)
+        d = new(**attrs)
+        unless KINDS.include?(d.kind)
+          raise ArgumentError,
+                "InstallChannel::Detected kind #{d.kind.inspect} is not one of #{KINDS.inspect}"
+        end
+        if d.auto_updatable && d.update_command.nil?
+          raise ArgumentError,
+                "InstallChannel::Detected(#{d.kind}): auto_updatable channels require a " \
+                "non-nil update_command"
+        end
+        d
+      end
+    end
+
+    TAP = "ivankuznetsov/hive/hive".freeze
+    AUR_PKG = "hive-bin".freeze
+    INSTALL_SH_URL = "https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh".freeze
+
+    module_function
+
+    DEFAULT_RUNNER = ->(argv) { Open3.capture3(*argv) }
+
+    # Resolve the absolute path of the running hive launcher. Delegates to
+    # Hive::Launcher (single owner of launcher-path resolution) so channel
+    # detection and the service unit's ExecStart agree on the real path.
+    def resolved_binary
+      Hive::Launcher.current
+    end
+
+    def detect(binary_path: resolved_binary, runner: DEFAULT_RUNNER)
+      real = Hive::Launcher.resolve(binary_path)
+
+      if (prefix = brew_prefix(runner)) && real.start_with?(prefix)
+        return brew_channel(real)
+      end
+      return aur_channel(real) if aur_owned?(real, runner)
+      return install_sh_channel(real) if under_data_home?(real)
+      return dev_channel(real) if dev_checkout?(real)
+
+      unknown_channel(real)
+    end
+
+    def brew_channel(path)
+      Detected.build(
+        kind: :brew, binary_path: path,
+        update_command: "brew upgrade #{TAP}",
+        uninstall_command: "brew uninstall hive",
+        auto_updatable: true,
+        note: "installed via Homebrew"
+      )
+    end
+
+    def aur_channel(path)
+      Detected.build(
+        kind: :aur, binary_path: path,
+        update_command: "yay -Syu #{AUR_PKG}",
+        uninstall_command: "sudo pacman -R #{AUR_PKG}",
+        # Running an AUR helper unattended can prompt / need sudo — gate it.
+        auto_updatable: false,
+        note: "installed via the AUR #{AUR_PKG} package"
+      )
+    end
+
+    def install_sh_channel(path)
+      Detected.build(
+        kind: :install_sh, binary_path: path,
+        update_command: "curl -fsSL #{INSTALL_SH_URL} | bash",
+        uninstall_command: "hive uninstall",
+        auto_updatable: true,
+        note: "installed via install.sh under #{Hive::Paths.data_home}"
+      )
+    end
+
+    def dev_channel(path)
+      Detected.build(
+        kind: :dev, binary_path: path,
+        update_command: "git pull",
+        uninstall_command: nil,
+        auto_updatable: false,
+        note: "running from a git checkout — update with git, not a package manager"
+      )
+    end
+
+    def unknown_channel(path)
+      Detected.build(
+        kind: :unknown, binary_path: path,
+        update_command: nil,
+        uninstall_command: nil,
+        auto_updatable: false,
+        note: "could not determine how hive was installed"
+      )
+    end
+
+    # --- detection probes -------------------------------------------------
+
+    def brew_prefix(runner)
+      out, _err, status = runner.call([ "brew", "--prefix" ])
+      return nil unless status.respond_to?(:success?) && status.success?
+
+      prefix = out.to_s.strip
+      prefix.empty? ? nil : prefix
+    rescue Errno::ENOENT
+      # brew simply isn't installed — the common, expected case. Not Homebrew.
+      nil
+    rescue StandardError => e
+      # A brew that exists but ERRORED (transient). Log why rather than
+      # silently misdetecting the channel — a wrong channel drives the wrong
+      # update/uninstall command downstream.
+      warn "hive: install-channel detection: `brew --prefix` errored " \
+           "(#{e.class}: #{e.message}); treating as not-Homebrew."
+      nil
+    end
+
+    def aur_owned?(path, runner)
+      out, _err, status = runner.call([ "pacman", "-Qo", path ])
+      return false unless status.respond_to?(:success?) && status.success?
+
+      out.to_s.include?(AUR_PKG)
+    rescue Errno::ENOENT
+      # pacman isn't present — not an Arch/AUR system. Expected.
+      false
+    rescue StandardError => e
+      warn "hive: install-channel detection: `pacman -Qo` errored " \
+           "(#{e.class}: #{e.message}); treating as not-AUR."
+      false
+    end
+
+    # True when the launcher lives under hive's effective data home. Derived
+    # solely from Hive::Paths.data_home (which already appends the `hive`
+    # segment and honours XDG_DATA_HOME / HIVE_HOME), so no literal
+    # ~/.local/share/hive that would drift when those are overridden.
+    def under_data_home?(path)
+      path.start_with?(File.join(Hive::Paths.data_home, ""))
+    end
+
+    def dev_checkout?(path)
+      # bin/hive inside a directory that has a sibling .git.
+      return false unless File.basename(path) == "hive"
+
+      repo_root = File.expand_path("..", File.dirname(path))
+      File.exist?(File.join(repo_root, ".git")) &&
+        File.exist?(File.join(repo_root, "lib", "hive.rb"))
+    end
+  end
+end
diff --git a/lib/hive/launcher.rb b/lib/hive/launcher.rb
new file mode 100644
index 00000000..4b96781f
--- /dev/null
+++ b/lib/hive/launcher.rb
@@ -0,0 +1,41 @@
+require "hive/platform"
+
+module Hive
+  # Single owner of hive-launcher path resolution.
+  #
+  # Both install-channel detection ("which running binary am I, so I can tell
+  # how hive was installed?") and the service backend ("which installed
+  # launcher do I bake into the unit's ExecStart?") resolve through here, so a
+  # service unit's ExecStart can no longer drift from the path `hive update`
+  # reasoned about. Resolution follows one symlink level to the real file
+  # (R7: resolve the binary from its real path).
+  module Launcher
+    module_function
+
+    # Resolve a path to its real target, following a symlink if present.
+    # Never raises — falls back to the expanded input on error.
+    def resolve(path)
+      expanded = File.expand_path(path)
+      File.symlink?(expanded) ? File.realpath(expanded) : expanded
+    rescue StandardError
+      File.expand_path(path)
+    end
+
+    # The currently-running launcher, symlink-resolved. Used to detect how
+    # THIS hive was installed.
+    def current
+      resolve($PROGRAM_NAME)
+    end
+
+    # The installed `hive`/`hv` launcher on PATH (symlink-resolved), or the
+    # running program as a last resort — so a dev checkout still renders a
+    # usable service unit.
+    def installed
+      %w[hive hv].each do |name|
+        path = Hive::Platform.which(name)
+        return resolve(path) if path
+      end
+      current
+    end
+  end
+end
diff --git a/lib/hive/paths.rb b/lib/hive/paths.rb
new file mode 100644
index 00000000..9d1301e7
--- /dev/null
+++ b/lib/hive/paths.rb
@@ -0,0 +1,97 @@
+require "fileutils"
+
+module Hive
+  # XDG-best-practice path resolver for hive's global (per-user) files.
+  #
+  # Resolution precedence for every directory:
+  #   1. `HIVE_HOME` env — when set, EVERY path collapses under this single
+  #      directory. This is the explicit-override escape hatch (used by the
+  #      test suite and by operators who want a self-contained home). It
+  #      preserves the historical single-directory layout (config.yml,
+  #      .daemon.pid, logs/ all under one root) exactly.
+  #   2. Legacy `~/Dev/hive` — when it already exists on disk (a pre-XDG
+  #      install), keep using it so existing users' registry / daemon state
+  #      is not orphaned. Back-compat only; never created fresh.
+  #   3. XDG base dirs — the default for fresh installs, honouring the
+  #      `$XDG_*` env overrides:
+  #        config → $XDG_CONFIG_HOME/hive or ~/.config/hive
+  #        data   → $XDG_DATA_HOME/hive   or ~/.local/share/hive
+  #        state  → $XDG_STATE_HOME/hive  or ~/.local/state/hive
+  #        cache  → $XDG_CACHE_HOME/hive  or ~/.cache/hive
+  #        bin    → ~/.local/bin
+  #
+  # The split between config (config.yml) and state (registry runtime files
+  # like .daemon.pid, logs/) matters only when HIVE_HOME is unset and no
+  # legacy dir exists; with either override present the two collapse to the
+  # same directory, matching the pre-XDG behaviour.
+  module Paths
+    module_function
+
+    # Absolute path of the pre-XDG install home. Expanded dynamically (not
+    # frozen at load) so it honours the live $HOME — tests point $HOME at a
+    # tmp dir and expect resolution to follow.
+    def legacy_home
+      File.expand_path("~/Dev/hive")
+    end
+
+    # True when an explicit HIVE_HOME override is in effect. When true,
+    # config_home == state_home == data_home == the override dir.
+    def hive_home_override
+      env = ENV["HIVE_HOME"]
+      return nil if env.nil? || env.empty?
+
+      File.expand_path(env)
+    end
+
+    # True when a legacy ~/Dev/hive install already exists on disk.
+    def legacy_home?
+      File.directory?(legacy_home)
+    end
+
+    # Directory holding the global config.yml.
+    def config_home
+      hive_home_override || (legacy_home? ? legacy_home : xdg_dir("XDG_CONFIG_HOME", "~/.config"))
+    end
+
+    # Directory holding per-user tracking / runtime state (registry runtime
+    # files, daemon pid, logs). Splits from config_home only on a fresh XDG
+    # install.
+    def state_home
+      hive_home_override || (legacy_home? ? legacy_home : xdg_dir("XDG_STATE_HOME", "~/.local/state"))
+    end
+
+    # Directory holding installed shared assets (templates/, schemas/, stage
+    # prompts) when hive is installed from a packaged artifact. Dev checkouts
+    # fall back to repo-relative paths (see Hive::Paths.shared_asset).
+    def data_home
+      hive_home_override || (legacy_home? ? legacy_home : xdg_dir("XDG_DATA_HOME", "~/.local/share"))
+    end
+
+    # Directory for regenerable cache files.
+    def cache_home
+      hive_home_override || (legacy_home? ? legacy_home : xdg_dir("XDG_CACHE_HOME", "~/.cache"))
+    end
+
+    # Where the `hive` (or `hv`) launcher symlink is dropped by install.sh.
+    def bin_dir
+      File.expand_path("~/.local/bin")
+    end
+
+    # Resolve a shared asset (templates/, schemas/) by relative name. Prefers
+    # the installed copy under data_home, falling back to the repo-relative
+    # path so a dev checkout keeps working without an install step.
+    def shared_asset(relative)
+      installed = File.join(data_home, relative)
+      return installed if File.exist?(installed)
+
+      File.expand_path("../../#{relative}", __dir__)
+    end
+
+    # $XDG_<VAR>/hive, honouring the env override, else <fallback>/hive.
+    def xdg_dir(env_var, fallback)
+      base = ENV[env_var]
+      base = fallback if base.nil? || base.empty?
+      File.join(File.expand_path(base), "hive")
+    end
+  end
+end
