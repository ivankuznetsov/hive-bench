       assert_match(/rebase.*must be a Hash/, err.message)
     end
   end
+
+  # --- R3 legacy back-compat (migrate_legacy_global_config!) ------------
+  # A legacy ~/Dev/hive install must keep working on upgrade: its project
+  # registry is read in place and NEVER orphaned. migrate_legacy_global_config!
+  # is copy-never-delete; because Paths keeps the legacy home authoritative
+  # while it exists (legacy_home? ⇒ config_home == legacy), the copy is a safe
+  # no-op and the legacy file remains the live config.
+
+  def with_legacy_home
+    with_tmp_dir do |home|
+      saved = %w[HOME HIVE_HOME XDG_CONFIG_HOME XDG_STATE_HOME XDG_DATA_HOME]
+              .to_h { |k| [ k, ENV[k] ] }
+      ENV["HOME"] = home
+      ENV.delete("HIVE_HOME")
+      %w[XDG_CONFIG_HOME XDG_STATE_HOME XDG_DATA_HOME].each { |k| ENV.delete(k) }
+      legacy_dir = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy_dir)
+      begin
+        yield home, legacy_dir
+      ensure
+        saved.each { |k, v| v.nil? ? ENV.delete(k) : ENV[k] = v }
+      end
+    end
+  end
+
+  def test_legacy_registry_is_read_in_place_and_not_orphaned
+    with_legacy_home do |_home, legacy_dir|
+      legacy_cfg = File.join(legacy_dir, "config.yml")
+      File.write(legacy_cfg, {
+        "registered_projects" => [ { "name" => "proj", "path" => "/tmp/proj" } ]
+      }.to_yaml)
+
+      assert Hive::Paths.legacy_home?, "legacy dir present ⇒ authoritative"
+      assert_equal legacy_cfg, Hive::Config.global_config_path
+
+      # migrate is a no-op here (config already resolves to legacy) and must
+      # never delete the legacy file.
+      assert_nil Hive::Config.migrate_legacy_global_config!
+      assert File.exist?(legacy_cfg), "legacy config never deleted"
+
+      # The registry survives the upgrade path: proj is still visible.
+      names = Hive::Config.registered_projects.map { |p| p["name"] }
+      assert_includes names, "proj"
+    end
+  end
+
+  def test_migrate_is_noop_when_no_legacy_config_present
+    with_legacy_home do |_home, legacy_dir|
+      refute File.exist?(File.join(legacy_dir, "config.yml"))
+      assert_nil Hive::Config.migrate_legacy_global_config!
+    end
+  end
+
+  def test_migrate_is_noop_under_hive_home_override
+    with_tmp_dir do |dir|
+      prev = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = dir
+      begin
+        # An explicit HIVE_HOME override collapses all homes onto dir; the
+        # legacy migration must not fire.
+        assert_nil Hive::Config.migrate_legacy_global_config!
+      ensure
+        prev.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = prev
+      end
+    end
+  end
