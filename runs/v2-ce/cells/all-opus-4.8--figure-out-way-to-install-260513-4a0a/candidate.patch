diff --git a/lib/hive/commands/uninstall.rb b/lib/hive/commands/uninstall.rb
new file mode 100644
index 00000000..2966fe3d
--- /dev/null
+++ b/lib/hive/commands/uninstall.rb
@@ -0,0 +1,249 @@
+require "json"
+require "fileutils"
+require "hive"
+require "hive/config"
+require "hive/paths"
+require "hive/install_channel"
+
+module Hive
+  module Commands
+    # `hive uninstall` — remove the binary and daemon/service registration,
+    # prompt before any project-scoped cleanup, and NEVER delete accumulated
+    # work or completed pipeline state by default. `--purge` is
+    # non-interactive but still preserves work. Skills are removed via the
+    # agent marketplace, not here.
+    class Uninstall
+      include Hive::Schemas::EnvelopeEmitter
+
+      def initialize(purge: false, json: false, service: nil, channel: nil,
+                     io: nil, output: $stdout)
+        @purge = purge
+        @json = json
+        @service = service
+        @channel = channel
+        @in = io&.fetch(:in, $stdin) || $stdin
+        @output = output
+      end
+
+      def call
+        call_with_envelope { do_call }
+      end
+
+      def envelope_schema
+        "hive-uninstall"
+      end
+
+      def envelope_error_kind(_error)
+        "internal"
+      end
+
+      private
+
+      def do_call
+        channel = @channel || InstallChannel.detect
+        preserved = []
+
+        service_state = deregister_service
+        service_deregistered = (service_state == :deregistered)
+        binary_removed, binary_command = handle_binary(channel)
+
+        # Accumulated work / completed pipeline outputs are NEVER removed.
+        preserved << Hive::Paths.state_home
+        preserved.concat(preserve_project_scaffolds)
+
+        handle_global_config(preserved)
+
+        message = build_message(channel, service_state, binary_removed, binary_command)
+        print_skills_hint unless @json
+
+        if @json
+          @output.puts JSON.generate(
+            "schema" => "hive-uninstall",
+            "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-uninstall"),
+            "ok" => true,
+            "channel" => channel.kind.to_s,
+            "purge" => @purge,
+            "service_deregistered" => service_deregistered,
+            "binary_removed" => binary_removed,
+            "binary_command" => binary_command,
+            "preserved" => preserved.uniq,
+            "message" => message
+          )
+          @stdout_written = true
+        else
+          @output.puts message
+        end
+      end
+
+      # Stop + remove the launchd/systemd-user unit. Returns a tri-state:
+      #   :deregistered  — a unit existed and was stopped + removed
+      #   :not_installed — no unit is installed (nothing to do; not a failure)
+      #   :failed        — a unit IS installed but launchctl/systemctl or the
+      #                    file removal genuinely errored; the unit may still
+      #                    be running.
+      # The prior code collapsed a real launchctl/systemctl failure into the
+      # same `false` as "nothing installed", so `hive uninstall` reported "no
+      # daemon service to deregister" (reads as clean success) while the unit
+      # kept running. Now a genuine failure is surfaced loudly and reflected
+      # in the message. Never raises on an unsupported platform (Service
+      # .installed? already returns false there).
+      def deregister_service
+        backend = @service
+        unless backend
+          require "hive/service"
+          return :not_installed unless Hive::Service.installed?
+
+          backend = Hive::Service.backend
+        end
+        return :not_installed unless backend.installed?
+
+        backend.unregister ? :deregistered : :not_installed
+      rescue LoadError
+        :not_installed
+      rescue Hive::Error => e
+        warn "hive: WARNING: failed to deregister the daemon service " \
+             "(#{e.message}). The unit may still be running — remove it manually."
+        :failed
+      end
+
+      # For the install.sh channel hive owns its files, so remove the
+      # bin-dir launcher symlink(s) and the versioned app directory — but
+      # ONLY when the data home is distinct from the state home, so a
+      # HIVE_HOME-collapsed layout can never lose work here. Managed
+      # installs (brew/aur) return their uninstall command instead of
+      # touching package-manager-owned files.
+      def handle_binary(channel)
+        case channel.kind
+        when :install_sh
+          removed = remove_install_sh_files(channel)
+          [ removed, nil ]
+        when :brew, :aur
+          [ false, channel.uninstall_command ]
+        else
+          [ false, nil ]
+        end
+      end
+
+      def remove_install_sh_files(channel)
+        data_home = Hive::Paths.data_home
+        return false if data_home == Hive::Paths.state_home # collapsed — never risk work
+
+        removed = false
+        # 1) launcher symlinks in bin_dir that resolve under data_home.
+        %w[hive hv].each do |name|
+          link = File.join(Hive::Paths.bin_dir, name)
+          next unless File.symlink?(link)
+
+          target = File.realpath(link) rescue nil
+          next unless target&.start_with?(File.join(data_home, ""))
+
+          File.delete(link)
+          removed = true
+        end
+        # 2) the versioned app dir: <data_home>/<version>/...
+        real = channel.binary_path
+        if real.start_with?(File.join(data_home, ""))
+          rel = real.sub(File.join(data_home, ""), "")
+          version_seg = rel.split(File::SEPARATOR).first
+          # Guard against a mis-resolved path: only rm_rf a segment that is
+          # actually version-shaped (e.g. "0.1.0", "0.1.0-rc1"). Without this,
+          # a binary_path that resolved to something like <data_home>/bin/hive
+          # would take version_seg == "bin" and delete <data_home>/bin. An
+          # unexpected shape is left in place with a manual-removal hint
+          # rather than blindly destroyed.
+          if version_seg && version_seg.match?(VERSION_SEGMENT)
+            app_dir = File.join(data_home, version_seg)
+            if File.directory?(app_dir)
+              FileUtils.rm_rf(app_dir)
+              removed = true
+            end
+          elsif version_seg && !version_seg.empty?
+            warn "hive: refusing to remove #{File.join(data_home, version_seg)} — " \
+                 "#{version_seg.inspect} is not a version-shaped directory. " \
+                 "If it is a stale hive install, remove it manually."
+          end
+        end
+        removed
+      end
+
+      # A data-home child dir hive created for a versioned install, e.g.
+      # "0.1.0" or "0.1.0-rc1". Anchors the rm_rf guard above.
+      VERSION_SEGMENT = /\A\d+\.\d+\.\d+(?:[-.+][0-9A-Za-z.-]+)?\z/
+
+      # Registered project .hive-state scaffolds are worktree-backed and hold
+      # user work; they are PRESERVED. On an interactive run (not --purge) we
+      # surface them so the operator knows how to remove them manually via
+      # `git worktree remove`. Returns the list of preserved scaffold paths.
+      def preserve_project_scaffolds
+        projects = Hive::Config.registered_projects
+        return [] if projects.empty?
+
+        paths = projects.map { |p| p["hive_state_path"] }.compact
+        if !@purge && interactive? && !paths.empty?
+          @output.puts "hive: leaving #{paths.size} project scaffold(s) intact (they hold your work):"
+          paths.each { |p| @output.puts "  #{p}   # remove with: git worktree remove #{p}" }
+        end
+        paths
+      rescue Hive::ConfigError
+        []
+      end
+
+      # The global config.yml holds the project registry + provider/model.
+      # Removed on --purge, or on an interactive yes. The state home (work)
+      # is never touched here.
+      def handle_global_config(preserved)
+        path = Hive::Config.global_config_path
+        return unless File.exist?(path)
+
+        if @purge || (interactive? && confirm_remove_config?(path))
+          File.delete(path)
+          @output.puts "hive: removed global config #{path}" unless @json
+        else
+          preserved << path
+        end
+      rescue Errno::EACCES => e
+        @output.puts "hive: could not remove global config: #{e.message}" unless @json
+      end
+
+      def confirm_remove_config?(path)
+        @output.print "Remove hive global config (project registry) at #{path}? [y/N]: "
+        @output.flush
+        answer = read_line.downcase
+        answer == "y" || answer == "yes"
+      end
+
+      def print_skills_hint
+        @output.puts ""
+        @output.puts "hive: agent skills (if installed) are removed through your agent's marketplace, " \
+                     "e.g. `claude plugin marketplace remove hive` — not by hive uninstall."
+      end
+
+      def build_message(channel, service_state, binary_removed, binary_command)
+        parts = []
+        parts << case service_state
+                 when :deregistered then "daemon service deregistered"
+                 when :failed       then "daemon service deregistration FAILED (unit may still be running)"
+                 else                    "no daemon service to deregister"
+                 end
+        if binary_removed
+          parts << "removed hive files"
+        elsif binary_command
+          parts << "run `#{binary_command}` to remove the #{channel.kind} package"
+        else
+          parts << "binary left in place (#{channel.note})"
+        end
+        parts << "work under #{Hive::Paths.state_home} preserved"
+        "hive uninstall: #{parts.join('; ')}."
+      end
+
+      def interactive?
+        @in.respond_to?(:tty?) && @in.tty?
+      end
+
+      def read_line
+        line = @in.gets
+        line.nil? ? "" : line.chomp.strip
+      end
+    end
+  end
+end
