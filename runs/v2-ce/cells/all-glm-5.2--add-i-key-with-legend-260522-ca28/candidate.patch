+    module Views
+      # Full-screen, read-only info panel for a focused task (entered
+      # with `i` on a right-pane-focused grid row). Renders the captured
+      # `Model::InfoState` payload — slug, stage, created_at, original
+      # idea text, working-dir path, latest log path, plus a
+      # stage-specific extra (brainstorm.md / plan.md / latest
+      # execute-log tail). Pure view function: all disk reads happen at
+      # keystroke time in `BubbleModel#open_info` so this module never
+      # touches the filesystem and the render thread never blocks.
+      #
+      # Composition mirrors `Views::RedStatusDetail`: header bar +
+      # bordered panel (borderless below 40 cols) + close-key footer.
+      # Content taller than the screen is truncated with a trailing `…`
+      # indicator; full scrolling is a deferred follow-up (per plan
+      # non-goal). Dynamic values are sanitized so control bytes / ANSI
+      # in captured content cannot corrupt layout — same invariant
+      # `RedStatusDetail` enforces.
+      module Info
+        FOOTER = "[q/Esc/i] close".freeze
+
+        module_function
+
+        def render(model)
+          state = model.info_state
+          return "" if state.nil?
+
+          row = state.row
+          header_width = [ model.cols.to_i - 1, 1 ].max
+          outer_width = [ model.cols.to_i - 2, 1 ].max
+          bordered = model.cols.to_i >= 40
+          inner_width = bordered ? [ outer_width - 2, 1 ].max : outer_width
+          body_height = [ model.rows.to_i - 5, 1 ].max
+          footer_lines = footer_lines_for(inner_width)
+          flash_line = flash_line_for(model, inner_width)
+
+          reserved = footer_lines.size + 1 # footer + leading blank
+          reserved += 1 if flash_line
+          inner_body_height = [ body_height - reserved, 1 ].max
+          body_lines = composed_content_lines(state, inner_width)
+          visible = body_lines.first(inner_body_height)
+          if body_lines.length > inner_body_height
+            visible = visible[0...inner_body_height - 1]
+            visible << truncate("…", inner_width)
+          end
+          visible << ""
+          visible << flash_line if flash_line
+          visible.concat(footer_lines)
+          body = Lipgloss.join_vertical(Lipgloss::TOP, *visible)
+          panel = if bordered
+                    Styles::PANE_FOCUSED_BORDER.width(inner_width).render(body)
+          else
+                    body
+          end
+
+          Lipgloss.join_vertical(Lipgloss::TOP, header_bar(row, header_width), panel)
+        end
+
+        def composed_content_lines(state, inner_width)
+          row = state.row
+          body_lines = []
+          body_lines << truncate("slug: #{safe(row.slug)}", inner_width)
+          body_lines << truncate("stage: #{safe(row.stage)}", inner_width)
+          body_lines << truncate("created_at: #{created_at_label(state.created_at)}", inner_width)
+          body_lines << truncate("working dir: #{safe(state.working_dir)}", inner_width)
+          body_lines << truncate("latest log: #{log_label(state.log_path)}", inner_width)
+          body_lines << ""
+          body_lines << Styles::HEADER.render(truncate("Original idea:", inner_width))
+          body_lines.concat(wrapped(state.original_text.to_s, inner_width))
+          append_extra(body_lines, state, inner_width)
+          body_lines
+        end
+
+        def append_extra(body_lines, state, inner_width)
+          return if state.extra_kind.nil? || state.extra_content.nil?
+
+          body_lines << ""
+          case state.extra_kind
+          when :brainstorm
+            body_lines << Styles::HEADER.render(truncate("brainstorm.md:", inner_width))
+            body_lines.concat(wrapped(state.extra_content, inner_width))
+          when :plan
+            body_lines << Styles::HEADER.render(truncate("plan.md:", inner_width))
+            body_lines.concat(wrapped(state.extra_content, inner_width))
+          when :execute_log
+            body_lines << Styles::HEADER.render(truncate("Latest execute log (tail):", inner_width))
+            body_lines.concat(wrapped(state.extra_content, inner_width))
+          end
+        end
+
+        def footer_lines_for(inner_width)
+          [ Styles::HINT.render(truncate(FOOTER, inner_width)) ]
+        end
+
+        def flash_line_for(model, inner_width)
+          return nil unless model.respond_to?(:flash_active?) && model.flash_active?
+
+          text = safe(model.flash.to_s).strip
+          return nil if text.empty?
+
+          Styles::HINT.render(truncate(text, inner_width))
+        end
+
+        def header_bar(row, width)
+          prefix = "INFO · "
+          project_stage = "#{safe(row.project_name)}/#{safe(row.stage)}"
+          slug = safe(row.slug)
+          path = safe(row.worktree_path || row.folder)
+
+          line = header_line(prefix, project_stage, slug, path, width)
+          Styles::HEADER.render(line)
+        end
+
+        # Single fall-through axis (mirrors RedStatusDetail#header_line):
+        # try the longest stem that still fits and append a truncated
+        # final field.
+        def header_line(prefix, project_stage, slug, path, width)
+          first = "#{prefix}#{project_stage}"
+          with_slug = "#{first} · #{slug}"
+          with_path_prefix = "#{with_slug} · "
+
+          candidates = [
+            [ with_path_prefix, path ],
+            [ "#{first} · ", slug ],
+            [ prefix, project_stage ]
+          ]
+
+          candidates.each do |stem, value|
+            next unless stem.length < width
+
+            return stem + truncate(value, width - stem.length)
+          end
+
+          truncate(first, width)
+        end
+
+        def created_at_label(created_at)
+          return "-" if created_at.nil?
+
+          created_at.respond_to?(:iso8601) ? created_at.iso8601 : safe(created_at.to_s)
+        end
+
+        def log_label(log_path)
+          log_path.to_s.empty? ? "-" : safe(log_path)
+        end
+
+        # Split on lines BEFORE sanitising so newlines (`\n`, 0x0a) are
+        # preserved as paragraph breaks rather than collapsed into `?` by
+        # `Hive::Tui::Text.sanitize` (whose CONTROL_CHARS_PATTERN matches
+        # 0x0a/0x0d/0x09). Sanitising the whole blob first would replace
+        # every line break with `?` and collapse multi-line stage extras
+        # (brainstorm.md / plan.md / execute-log tail) into one mangled row.
+        def wrapped(text, width)
+          text = text.to_s
+          return [ "" ] if text.empty?
+
+          text.lines.flat_map { |line| wrap_line(safe(line.chomp), width) }
+        end
+
+        def wrap_line(line, width)
+          return [ "" ] if line.empty?
+          return [ truncate(line, width) ] if width <= 8
+
+          words = line.split(/\s+/)
+          rows = []
+          current = +""
+          words.each do |word|
+            if current.empty?
+              current = word
+            elsif "#{current} #{word}".length <= width
+              current << " " << word
+            else
+              rows << truncate(current, width)
+              current = word
+            end
+          end
+          rows << truncate(current, width) unless current.empty?
+          rows
+        end
+
+        def safe(value)
+          Hive::Tui::Text.sanitize(value.to_s)
+        end
+
+        def truncate(string, width)
+          Views::Format.truncate(string, width)
+        end
+      end
+    end
+  end
+end
