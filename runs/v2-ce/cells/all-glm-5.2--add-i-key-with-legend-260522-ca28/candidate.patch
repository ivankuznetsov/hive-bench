+  def test_open_info_stage_extra_that_is_a_directory_omits_extras_without_flash
+    # Finding (pi-ce-code-review-02): a stage-extra path that is a
+    # directory (Errno::EISDIR) must not bubble out to the top-level
+    # `update` safety net as an "internal error" flash. `read_info_file`
+    # rescues the broad `*Hive::Tui::LogTail::FILESYSTEM_RESCUE` set
+    # (matching the sibling `red_status_detail_log_snapshot`), so the
+    # extras section is omitted and the panel opens with common fields.
+    with_tmp_dir do |dir|
+      write_idea_md(dir, original_text: "dir as extra")
+      # `brainstorm.md` exists as a directory, so `File.exist?` is true
+      # but `File.read` raises Errno::EISDIR.
+      Dir.mkdir(File.join(dir, "brainstorm.md"))
+      row = open_info_row(dir, stage: "2-brainstorm")
+
+      _, cmd = @model.update(Hive::Tui::Messages::OpenInfo.new(row: row))
