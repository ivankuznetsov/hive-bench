+    )
+    assert_includes out, "Latest execute log (tail):"
+    assert_includes out, "line 50"
+  end
+
+  def test_wrapped_preserves_line_breaks_in_brainstorm_extra
+    # Regression guard for the sanitize-before-split ordering bug:
+    # `Hive::Tui::Text.sanitize`'s CONTROL_CHARS_PATTERN matches `\n`
+    # (0x0a), so sanitising the whole blob first replaced every line
+    # break with `?` and collapsed the extra into one mangled row. Each
+    # source line must render as its own bordered row with no `?`.
+    content = "# Brainstorm\n\nGoal: ship feature.\n- point one\n- point two"
+    out = render(state(row(stage: "2-brainstorm"),
+                       extra_kind: :brainstorm, extra_content: content))
+    contents = out.lines(chomp: true).map { |l| l.sub(/\A│/, "").sub(/│\z/, "").rstrip }
+
+    assert_includes contents, "brainstorm.md:"
+    assert_includes contents, "# Brainstorm"
+    assert_includes contents, "Goal: ship feature."
+    assert_includes contents, "- point one"
+    assert_includes contents, "- point two"
+    refute_includes out, "?",
+                    "newlines must be preserved as row breaks, not replaced with '?'"
+  end
+
+  def test_wrapped_preserves_line_breaks_in_execute_log_extra
+    content = "line 49\nline 50\nline 51"
+    out = render(state(row(stage: "4-execute"),
+                       extra_kind: :execute_log, extra_content: content))
+    contents = out.lines(chomp: true).map { |l| l.sub(/\A│/, "").sub(/│\z/, "").rstrip }
+
+    assert_includes contents, "line 49"
+    assert_includes contents, "line 50"
+    assert_includes contents, "line 51"
+    refute_includes out, "?"
+  end
+
+  def test_wrapped_preserves_line_breaks_in_original_idea
+    out = render(state(row, original_text: "Line one of idea\nLine two of idea"))
+    contents = out.lines(chomp: true).map { |l| l.sub(/\A│/, "").sub(/│\z/, "").rstrip }
+
+    assert_includes contents, "Line one of idea"
+    assert_includes contents, "Line two of idea"
+    refute_includes out, "?"
+  end
+
+  def test_wrapped_strips_ansi_but_keeps_newlines_in_extra
+    # Multi-line content with embedded ANSI: ANSI is stripped per line,
+    # newlines survive as row breaks — control-byte safety and
+    # structural preservation are not mutually exclusive.
+    content = "\e[1mHeader\e[0m\nbody line"
+    out = render(state(row(stage: "2-brainstorm"),
+                       extra_kind: :brainstorm, extra_content: content))
+    refute_match(/\e\[/, out)
+    contents = out.lines(chomp: true).map { |l| l.sub(/\A│/, "").sub(/│\z/, "").rstrip }
+    assert_includes contents, "Header"
+    assert_includes contents, "body line"
+    refute_includes out, "?"
+  end
+
+  def test_omits_extra_section_when_extra_content_is_nil
+    out = render(state(row(stage: "2-brainstorm"), extra_kind: :brainstorm, extra_content: nil))
+    refute_includes out, "brainstorm.md:"
+  end
+
+  def test_renders_dash_when_log_path_is_nil
+    out = render(state(row, log_path: nil))
+    assert_includes out, "latest log: -"
+  end
+
+  def test_renders_log_path_when_present
+    out = render(state(row, log_path: "/tmp/demo/.hive-state/logs/info-task/run.log"))
+    assert_includes out, "latest log: /tmp/demo/.hive-state/logs/info-task/run.log"
+  end
+
+  def test_renders_dash_when_created_at_is_nil
+    out = render(state(row, created_at: nil))
+    assert_includes out, "created_at: -"
+  end
+
+  def test_renders_close_footer
+    out = render(state(row))
+    assert_includes out, "[q/Esc/i] close"
+  end
+
+  def test_truncates_overflow_body_with_ellipsis
+    # Many lines of idea text in a short terminal → truncated with … .
+    text = (1..200).map { |i| "idea line #{i}" }.join("\n")
+    out = render(state(row, original_text: text), cols: 80, rows: 8)
+    assert_includes out, "…", "overflow body must end with an ellipsis indicator"
+    # The body must not blow past the terminal height in raw rows.
+    # Header line + panel; just sanity-check the ellipsis is present.
+  end
+
+  def test_narrow_borderless_render_stays_single_column
+    out = render(state(row), cols: 40, rows: 24)
+    footer_line = out.lines(chomp: true).last.to_s
+    assert footer_line.length <= 39,
+           "footer must fit usable_width at cols=40; got #{footer_line.length} chars"
+  end
+
+  def test_strips_control_bytes_in_original_text
+    # ANSI / control bytes in captured content must not leak into layout.
+    out = render(state(row, original_text: "clean\e[31mred\e[0m text"))
+    refute_match(/\e\[/, out, "no raw ANSI escape should leak into the info panel render")
+    assert_includes out, "clean"
+    assert_includes out, "text"
+  end
+
+  def test_strips_control_bytes_in_paths
+    out = render(state(row,
+                       working_dir: "/tmp/\e[31mevil\e[0m",
+                       log_path: "/tmp/\x1b[32mlg\e[0m"))
+    refute_match(/\e\[/, out)
+  end
+
+  def test_header_includes_project_stage_and_slug
+    out = render(state(row(stage: "2-brainstorm", slug: "info-task")))
+    header = out.lines.first.to_s.chomp
+    assert_includes header, "INFO · demo/2-brainstorm · info-task"
+  end
+end
