+  def test_default_footer_truncates_below_80_cols_without_second_row
+    # Plan U1: at cols >= 80 the full 79-char legend renders; below 80 the
+    # footer is `Format.truncate`-clamped to a single line so narrow terminals
+    # never spill onto a second row (the existing truncation contract).
