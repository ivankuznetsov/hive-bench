+require "test_helper"
+require "hive/tui/model"
+require "hive/tui/snapshot"
+require "hive/tui/views/info"
+
+class HiveTuiViewsInfoTest < Minitest::Test
+  include HiveTestHelper
+
+  def row(stage: "1-inbox", slug: "info-task", folder: "/tmp/demo/.hive-state/stages/#{stage}/#{slug}",
+          project_name: "demo", worktree_path: nil)
+    Hive::Tui::Snapshot::Row.new(
+      project_name: project_name, stage: stage, slug: slug, folder: folder,
+      worktree_path: worktree_path,
+      state_file: File.join(folder, "task.md"), marker: "complete", attrs: {},
+      mtime: nil, age_seconds: 0, claude_pid: nil, claude_pid_alive: nil,
+      action_key: "ready_to_plan", action_label: "Ready to plan",
+      suggested_command: nil, next_action: nil, diagnostic: nil
+    )
+  end
+
+  def state(row, **overrides)
+    defaults = {
+      row: row,
+      created_at: Time.utc(2026, 5, 20, 0, 0, 0),
+      original_text: "Build the thing.",
+      working_dir: row.folder,
+      log_path: nil,
+      extra_kind: nil,
+      extra_content: nil
+    }
+    Hive::Tui::Model::InfoState.new(**defaults.merge(overrides))
+  end
+
+  def model_for(state, cols: 100, rows: 24)
+    Hive::Tui::Model.initial.with(mode: :info, info_state: state, cols: cols, rows: rows)
+  end
+
+  def render(state, cols: 100, rows: 24)
+    Hive::Tui::Views::Info.render(model_for(state, cols: cols, rows: rows))
+  end
+
+  def test_render_returns_empty_when_info_state_is_nil
+    model = Hive::Tui::Model.initial.with(mode: :info, info_state: nil)
+    assert_equal "", Hive::Tui::Views::Info.render(model)
+  end
+
+  def test_renders_common_fields_for_1_inbox
+    out = render(state(row(stage: "1-inbox")))
+    assert_includes out, "slug: info-task"
+    assert_includes out, "stage: 1-inbox"
+    assert_includes out, "created_at: 2026-05-20T00:00:00Z"
+    assert_includes out, "working dir: /tmp/demo/.hive-state/stages/1-inbox/info-task"
+    assert_includes out, "latest log: -"
+    assert_includes out, "Original idea:"
+    assert_includes out, "Build the thing."
+    refute_includes out, "brainstorm.md:"
+    refute_includes out, "plan.md:"
+    refute_includes out, "Latest execute log (tail):"
+  end
+
+  def test_renders_brainstorm_extra_for_2_brainstorm
+    out = render(
+      state(row(stage: "2-brainstorm"),
+            extra_kind: :brainstorm, extra_content: "# Brainstorm\n\nGoal: ship.")
+    )
+    assert_includes out, "stage: 2-brainstorm"
+    assert_includes out, "brainstorm.md:"
+    assert_includes out, "Goal: ship."
+  end
+
+  def test_renders_plan_extra_for_3_plan
+    out = render(
