+name: AUR Package
+
+on:
+  workflow_dispatch:
+    inputs:
+      version:
+        description: "Release tag, e.g. v0.1.0"
+        required: true
+      sha256:
+        description: "SHA256 of hive-<version>-linux-x86_64-gnu.tar.gz"
+        required: true
+      repo:
+        description: "Release repo slug"
+        required: false
+        default: "<org>/hive"
+
+permissions:
+  contents: read
+
+jobs:
+  render-and-validate:
+    runs-on: ubuntu-latest
+    container: archlinux:base-devel
+    steps:
+      - uses: actions/checkout@v6
+      - name: Install Ruby
+        run: pacman -Syu --noconfirm ruby git
+      - name: Render PKGBUILD and .SRCINFO
+        run: >-
+          ruby packaging/aur/update_pkgbuild.rb
+          --version "${{ inputs.version }}"
+          --sha256 "${{ inputs.sha256 }}"
+          --repo "${{ inputs.repo }}"
+      - name: Check .SRCINFO freshness
+        working-directory: packaging/aur/hive-bin
+        run: makepkg --printsrcinfo | diff -u .SRCINFO -
+      - name: Build package metadata
+        working-directory: packaging/aur/hive-bin
+        run: makepkg --verifysource --noconfirm
