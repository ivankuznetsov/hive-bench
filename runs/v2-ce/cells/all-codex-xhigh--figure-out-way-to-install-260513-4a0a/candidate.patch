+    assert_includes pkgbuild, "pkgver=1.2.3"
+    assert_includes pkgbuild, "hive-v1.2.3-linux-x86_64-gnu.tar.gz"
+    assert_includes pkgbuild, "sha256sums_x86_64=('#{sha}')"
+    assert_includes srcinfo, "pkgver = 1.2.3"
+    assert_includes srcinfo, "source_x86_64 = https://github.com/example/hive/releases/download/v1.2.3/hive-v1.2.3-linux-x86_64-gnu.tar.gz"
