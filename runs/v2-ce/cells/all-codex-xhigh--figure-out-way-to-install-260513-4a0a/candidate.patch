index 00000000..c6cfa6b0
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,29 @@
+require "hive/install_receipt"
+require "hive/package_manager"
+
+module Hive
+  module Commands
+    class Update
+      def initialize(dry_run: false, receipt: Hive::InstallReceipt.new, output: $stdout, runner: Hive::PackageManager)
+        @dry_run = dry_run
+        @receipt = receipt
+        @output = output
+        @runner = runner
+      end
+
+      def call
+        command = Hive::PackageManager.update_command_for(@receipt)
+        unless command
+          @output.puts "hive update: install channel is unknown; reinstall from the current GitHub Release or native package manager."
+          raise Hive::Error, "hive update failed: install channel is unknown"
+        end
+
+        @output.puts "hive update: delegating to #{command.join(' ')}"
+        ok = @runner.run(command, dry_run: @dry_run, output: @output)
+        raise Hive::Error, "hive update failed" unless ok
+
+        true
+      end
+    end
+  end
+end
