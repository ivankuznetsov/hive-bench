diff --git a/lib/hive/commands/uninstall.rb b/lib/hive/commands/uninstall.rb
new file mode 100644
index 00000000..a3205c72
--- /dev/null
+++ b/lib/hive/commands/uninstall.rb
@@ -0,0 +1,84 @@
+require "fileutils"
+require "hive/install_receipt"
+require "hive/project_cleanup"
+require "hive/service"
+
+module Hive
+  module Commands
+    class Uninstall
+      def initialize(project_root: Dir.pwd, purge: false, yes: false, receipt: Hive::InstallReceipt.new,
+                     input: $stdin, output: $stdout, service: Hive::Service.manager)
+        @project_root = project_root
+        @purge = purge
+        @yes = yes
+        @receipt = receipt
+        @input = input
+        @output = output
+        @service = service
+      end
+
+      def call
+        remove_service_registration
+        remove_script_binary_if_owned
+        cleanup_project_scaffold
+        @output.puts "hive uninstall: skills are managed by agent marketplaces; remove them there if desired."
+        true
+      end
+
+      private
+
+      def remove_service_registration
+        path =
+          if @service.respond_to?(:service_path)
+            @service.service_path
+          else
+            @service.register[:path]
+          end
+        if path && File.exist?(path)
+          File.delete(path)
+          @output.puts "hive uninstall: removed service registration #{path}"
+        else
+          @output.puts "hive uninstall: no service registration found"
+        end
+      end
+
+      def remove_script_binary_if_owned
+        case @receipt.channel
+        when "script"
+          path = @receipt.script_binary_path
+          if File.exist?(path)
+            File.delete(path)
+            @output.puts "hive uninstall: removed #{path}"
+          else
+            @output.puts "hive uninstall: script binary already absent"
+          end
+        when "homebrew", "brew"
+          @output.puts "hive uninstall: use `brew uninstall #{@receipt.repo}/hive` to remove the package."
+        when "aur"
+          @output.puts "hive uninstall: use your AUR helper to remove `hive-bin`."
+        else
+          @output.puts "hive uninstall: install channel unknown; no binary removed."
+        end
+      end
+
+      def cleanup_project_scaffold
+        confirm = @purge && (@yes || confirm_project_cleanup?)
+        Hive::ProjectCleanup.cleanup_project_scaffold(
+          project_root: @project_root,
+          confirm: confirm,
+          output: @output
+        )
+        @output.puts "hive uninstall: preserving ~/.local/state/hive work artifacts by default."
+      end
+
+      def confirm_project_cleanup?
+        return false unless @input.respond_to?(:tty?) && @input.tty?
+
+        @output.print "hive uninstall: remove project .hive/ scaffold in #{@project_root}? [y/N]: "
+        @output.flush
+        answer = @input.gets
+        %w[y yes].include?(answer.to_s.chomp.strip.downcase)
+      end
+    end
+  end
+end
