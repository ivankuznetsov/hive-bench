diff --git a/.github/workflows/release.yml b/.github/workflows/release.yml
new file mode 100644
index 00000000..f0b67cb2
--- /dev/null
+++ b/.github/workflows/release.yml
@@ -0,0 +1,89 @@
+name: Release
+
+on:
+  push:
+    tags:
+      - "v[0-9]+.[0-9]+.[0-9]+"
+      - "v[0-9]+.[0-9]+.[0-9]+-*"
+  workflow_dispatch:
+    inputs:
+      tag:
+        description: "Semver tag to build, e.g. v0.1.0"
+        required: true
+
+permissions:
+  contents: write
+
+jobs:
+  contract:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - run: bundle exec ruby -Itest -Ilib test/release/artifact_contract_test.rb
+
+  build-linux:
+    needs: contract
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Validate semver tag
+        run: ruby -r ./packaging/build/build_release.rb -e 'Hive::Packaging::BuildRelease.validate_semver_tag!(ENV.fetch("GITHUB_REF_NAME"))'
+      - name: Install Tebako
+        run: gem install tebako --no-document
+      - name: Build Linux artifact
+        run: ruby packaging/build/build_release.rb "$GITHUB_REF_NAME"
+        env:
+          HIVE_RELEASE_TARGETS: linux-x86_64-gnu
+      - uses: actions/upload-artifact@v4
+        with:
+          name: hive-linux-release-assets
+          path: dist/hive-${{ github.ref_name }}-linux-x86_64-gnu*
+
+  build-macos:
+    needs: contract
+    runs-on: macos-14
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Validate semver tag
+        run: ruby -r ./packaging/build/build_release.rb -e 'Hive::Packaging::BuildRelease.validate_semver_tag!(ENV.fetch("GITHUB_REF_NAME"))'
+      - name: Install Tebako
+        run: gem install tebako --no-document
+      - name: Build macOS artifact
+        run: ruby packaging/build/build_release.rb "$GITHUB_REF_NAME"
+        env:
+          HIVE_RELEASE_TARGETS: darwin-arm64
+      - uses: actions/upload-artifact@v4
+        with:
+          name: hive-macos-release-assets
+          path: dist/hive-${{ github.ref_name }}-darwin-arm64*
+
+  publish:
+    needs: [build-linux, build-macos]
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/download-artifact@v4
+        with:
+          path: dist
+          merge-multiple: true
+      - name: Create checksum manifest
+        run: |
+          cd dist
+          sha256sum hive-${{ github.ref_name }}-*.tar.gz > hive-${{ github.ref_name }}-checksums.txt
+      - name: Publish GitHub Release
+        uses: softprops/action-gh-release@v2
+        with:
+          tag_name: ${{ github.ref_name }}
+          fail_on_unmatched_files: true
+          files: dist/*
