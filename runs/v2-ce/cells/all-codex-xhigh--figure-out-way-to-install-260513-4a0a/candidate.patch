+require "test_helper"
+
+class SkillsManifestTest < Minitest::Test
+  ROOT = File.expand_path("../../skills/hive", __dir__)
+
+  def test_manifest_declares_marketplace_only_distribution
+    manifest = YAML.safe_load(File.read(File.join(ROOT, "manifest.yml")))
+
+    assert_equal "hive", manifest.fetch("name")
+    assert_equal "marketplace-only", manifest.fetch("distribution")
+    assert_includes manifest.fetch("prohibited"), "direct-agent-directory-copy"
+  end
+
+  def test_each_marketplace_target_degrades_to_manual_follow_up
+    manifest = YAML.safe_load(File.read(File.join(ROOT, "manifest.yml")))
+
+    manifest.fetch("marketplaces").each do |agent, path|
+      target = YAML.safe_load(File.read(File.join(ROOT, path)))
+      assert_equal agent, target.fetch("agent")
+      assert_equal "native-marketplace-required", target.fetch("install_policy")
+      assert_equal "manual-follow-up-required", target.fetch("fallback")
+      assert_match(/do not copy files/i, target.fetch("notes"))
+    end
+  end
+end
