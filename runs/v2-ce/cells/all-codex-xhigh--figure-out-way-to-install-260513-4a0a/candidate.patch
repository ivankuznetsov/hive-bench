+@test "detects macOS arm64" {
+  export HIVE_TEST_UNAME_S=Darwin
+  export HIVE_TEST_UNAME_M=arm64
+  run detect_platform
+  [ "$status" -eq 0 ]
+  [ "$output" = "darwin-arm64" ]
+}
+
+@test "rejects Alpine" {
+  export HIVE_TEST_UNAME_S=Linux
+  export HIVE_TEST_UNAME_M=x86_64
+  export HIVE_TEST_OS_ID=alpine
+  run detect_platform
+  [ "$status" -ne 0 ]
