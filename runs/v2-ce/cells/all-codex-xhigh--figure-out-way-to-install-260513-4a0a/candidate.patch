+# Homebrew Tap
+
+macOS arm64 is installed from the project tap:
+
+```bash
+brew install <org>/hive/hive
+```
+
+The formula consumes the macOS arm64 GitHub Release artifact built by
+`packaging/build/build_release.rb`; it does not depend on system Ruby.
+
+Release update flow:
+
+```bash
+ruby packaging/homebrew/update_formula.rb \\
+  --version v0.1.0 \\
+  --sha256 "$(shasum -a 256 dist/hive-v0.1.0-darwin-arm64.tar.gz | cut -d' ' -f1)" \\
+  --repo <org>/hive
+```
+
+The formula installs both `hive` and an `hv` symlink. `hv` exists for users who
+already have another `hive` command, commonly Apache Hive, earlier on `PATH`.
+
+After installation:
+
+```bash
+hive --version
+hive init
+```
diff --git a/packaging/homebrew/update_formula.rb b/packaging/homebrew/update_formula.rb
new file mode 100755
index 00000000..20c62820
--- /dev/null
+++ b/packaging/homebrew/update_formula.rb
@@ -0,0 +1,83 @@
+#!/usr/bin/env ruby
+
+require "optparse"
+require_relative "../build/build_release"
+
+module Hive
+  module Packaging
+    module Homebrew
+      module FormulaRenderer
+        DEFAULT_REPO = ENV.fetch("HIVE_RELEASE_REPO", "<org>/hive").freeze
+        TARGET = "darwin-arm64".freeze
+
+        module_function
+
+        def render(version:, sha256:, repo: DEFAULT_REPO)
+          artifact = Hive::Packaging::BuildRelease.artifact_name(version: version, target: TARGET)
+          release_url = "https://github.com/#{repo}/releases/download/#{version}/#{artifact}"
+          <<~RUBY
+            class Hive < Formula
+              desc "Multi-agent software delivery pipeline"
+              homepage "https://github.com/#{repo}"
+              url "#{release_url}"
+              sha256 "#{sha256}"
+              version "#{version.delete_prefix("v")}"
+
+              depends_on arch: :arm64
+
+              def install
+                bin.install "hive"
+                bin.install_symlink "hive" => "hv"
+              end
+
+              def caveats
+                <<~EOS
+                  Hive stores global config in ~/.config/hive/config.yml, shared assets in
+                  ~/.local/share/hive, state in ~/.local/state/hive, and cache files in
+                  ~/.cache/hive unless XDG_* variables override those roots.
+
+                  Run `hive init` inside each project you want Hive to manage. Init registers
+                  the daemon service definition and prompts before enabling autostart.
+
+                  This formula also installs `hv` as an alias. Use `hv` if another `hive`
+                  executable appears earlier on PATH.
+                EOS
+              end
+
+              test do
+                assert_match version.to_s, shell_output("\#{bin}/hive --version")
+                assert_match version.to_s, shell_output("\#{bin}/hv --version")
+              end
+            end
+          RUBY
+        end
+      end
+
+      module CLI
+        module_function
+
+        def run(argv)
+          options = { repo: FormulaRenderer::DEFAULT_REPO, output: "packaging/homebrew/Formula/hive.rb" }
+          parser = OptionParser.new do |opts|
+            opts.banner = "usage: update_formula.rb --version v0.1.0 --sha256 SHA [--repo ORG/REPO]"
+            opts.on("--version VERSION", "Semver release tag, e.g. v0.1.0") { |v| options[:version] = v }
+            opts.on("--sha256 SHA", "macOS artifact SHA256") { |v| options[:sha256] = v }
+            opts.on("--repo REPO", "GitHub repo slug") { |v| options[:repo] = v }
+            opts.on("--output PATH", "Formula path") { |v| options[:output] = v }
+          end
+          parser.parse!(argv)
+          abort parser.to_s unless options[:version] && options[:sha256]
+
+          content = FormulaRenderer.render(
+            version: options.fetch(:version),
+            sha256: options.fetch(:sha256),
+            repo: options.fetch(:repo)
+          )
+          File.write(options.fetch(:output), content)
+        end
+      end
+    end
+  end
+end
+
+Hive::Packaging::Homebrew::CLI.run(ARGV) if $PROGRAM_NAME == __FILE__
