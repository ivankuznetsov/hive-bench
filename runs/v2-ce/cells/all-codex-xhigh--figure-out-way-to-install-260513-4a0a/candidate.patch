+require "fileutils"
+
+module Hive
+  module ProjectCleanup
+    module_function
+
+    def cleanup_project_scaffold(project_root:, confirm:, output: $stdout)
+      path = File.join(project_root, ".hive")
+      unless File.exist?(path)
+        output.puts "hive uninstall: no .hive/ scaffold found"
+        return :missing
+      end
+
+      unless confirm
+        output.puts "hive uninstall: preserving #{path}"
+        return :preserved
+      end
+
+      FileUtils.rm_rf(path)
+      output.puts "hive uninstall: removed #{path}"
+      :removed
+    end
+  end
+end
