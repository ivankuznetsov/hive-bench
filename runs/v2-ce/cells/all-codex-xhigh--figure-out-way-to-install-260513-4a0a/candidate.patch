diff --git a/packaging/aur/update_pkgbuild.rb b/packaging/aur/update_pkgbuild.rb
new file mode 100755
index 00000000..4357d345
--- /dev/null
+++ b/packaging/aur/update_pkgbuild.rb
@@ -0,0 +1,108 @@
+#!/usr/bin/env ruby
+
+require "optparse"
+require_relative "../build/build_release"
+
+module Hive
+  module Packaging
+    module Aur
+      module Renderer
+        DEFAULT_REPO = ENV.fetch("HIVE_RELEASE_REPO", "<org>/hive").freeze
+        TARGET = "linux-x86_64-gnu".freeze
+
+        module_function
+
+        def pkgver(version)
+          Hive::Packaging::BuildRelease.validate_semver_tag!(version).delete_prefix("v")
+        end
+
+        def artifact(version)
+          Hive::Packaging::BuildRelease.artifact_name(version: version, target: TARGET)
+        end
+
+        def render_pkgbuild(version:, sha256:, repo: DEFAULT_REPO, pkgrel: 1)
+          package_version = pkgver(version)
+          <<~PKGBUILD
+            # Maintainer: Hive contributors
+            pkgname=hive-bin
+            pkgver=#{package_version}
+            pkgrel=#{pkgrel}
+            pkgdesc='Multi-agent software delivery pipeline'
+            arch=('x86_64')
+            url='https://github.com/#{repo}'
+            license=('MIT')
+            depends=()
+            provides=('hive')
+            conflicts=('hive')
+            install=hive-bin.install
+            source_x86_64=("https://github.com/#{repo}/releases/download/v${pkgver}/#{artifact(version)}")
+            sha256sums_x86_64=('#{sha256}')
+
+            package() {
+              install -Dm755 "$srcdir/hive" "$pkgdir/usr/bin/hive"
+              ln -s hive "$pkgdir/usr/bin/hv"
+            }
+          PKGBUILD
+        end
+
+        def render_srcinfo(version:, sha256:, repo: DEFAULT_REPO, pkgrel: 1)
+          package_version = pkgver(version)
+          <<~SRCINFO
+            pkgbase = hive-bin
+            	pkgdesc = Multi-agent software delivery pipeline
+            	pkgver = #{package_version}
+            	pkgrel = #{pkgrel}
+            	url = https://github.com/#{repo}
+            	install = hive-bin.install
+            	arch = x86_64
+            	license = MIT
+            	provides = hive
+            	conflicts = hive
+            #{"\t"}source_x86_64 = https://github.com/#{repo}/releases/download/v#{package_version}/#{artifact(version)}
+            	sha256sums_x86_64 = #{sha256}
+
+            pkgname = hive-bin
+          SRCINFO
+        end
+      end
+
+      module CLI
+        module_function
+
+        def run(argv)
+          options = {
+            repo: Renderer::DEFAULT_REPO,
+            pkgbuild: "packaging/aur/hive-bin/PKGBUILD",
+            srcinfo: "packaging/aur/hive-bin/.SRCINFO",
+            pkgrel: 1
+          }
+          parser = OptionParser.new do |opts|
+            opts.banner = "usage: update_pkgbuild.rb --version v0.1.0 --sha256 SHA [--repo ORG/REPO]"
+            opts.on("--version VERSION") { |v| options[:version] = v }
+            opts.on("--sha256 SHA") { |v| options[:sha256] = v }
+            opts.on("--repo REPO") { |v| options[:repo] = v }
+            opts.on("--pkgrel N", Integer) { |v| options[:pkgrel] = v }
+            opts.on("--pkgbuild PATH") { |v| options[:pkgbuild] = v }
+            opts.on("--srcinfo PATH") { |v| options[:srcinfo] = v }
+          end
+          parser.parse!(argv)
+          abort parser.to_s unless options[:version] && options[:sha256]
+
+          File.write(options.fetch(:pkgbuild), Renderer.render_pkgbuild(**render_options(options)))
+          File.write(options.fetch(:srcinfo), Renderer.render_srcinfo(**render_options(options)))
+        end
+
+        def render_options(options)
+          {
+            version: options.fetch(:version),
+            sha256: options.fetch(:sha256),
+            repo: options.fetch(:repo),
+            pkgrel: options.fetch(:pkgrel)
+          }
+        end
+      end
+    end
+  end
+end
+
+Hive::Packaging::Aur::CLI.run(ARGV) if $PROGRAM_NAME == __FILE__
diff --git a/packaging/build/README.md b/packaging/build/README.md
new file mode 100644
index 00000000..cb36a21a
--- /dev/null
+++ b/packaging/build/README.md
@@ -0,0 +1,35 @@
+# Release Build
+
+Hive release assets are built from semver tags and consumed by every install
+channel. The canonical asset contract is implemented in
+`packaging/build/build_release.rb`.
+
+Tier-1 targets:
+
+- `darwin-arm64`
+- `linux-x86_64-gnu`
+
+Artifact names are deterministic:
+
+```text
+hive-v0.1.0-darwin-arm64.tar.gz
+hive-v0.1.0-linux-x86_64-gnu.tar.gz
+hive-v0.1.0-checksums.txt
+```
+
+The build script uses Tebako's documented `press --root --entry-point --output
+--Ruby` interface to produce a bundle-mode executable with Ruby and gems
+embedded. GitHub Releases are the only artifact source for Homebrew, AUR, and
+the script installer.
+
+Local dry run of the contract tests:
+
+```bash
