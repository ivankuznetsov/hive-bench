+    assert_equal "/home/tester/.config/hive", Hive::Paths.config_dir(env)
+    assert_equal "/home/tester/.local/share/hive", Hive::Paths.data_dir(env)
+    assert_equal "/home/tester/.local/state/hive", Hive::Paths.state_dir(env)
+    assert_equal "/home/tester/.cache/hive", Hive::Paths.cache_dir(env)
+  end
+
