@@ -0,0 +1,48 @@
+require "yaml"
+require "fileutils"
+require "hive/config"
+
+module Hive
+  module FirstRunConfig
+    DEFAULT_PROVIDER = "claude".freeze
+    DEFAULT_MODEL = "default".freeze
+
+    module_function
+
+    def ensure!(input: $stdin, output: $stderr)
+      path = Hive::Config.global_config_path
+      data = File.exist?(path) ? Hive::Config.load_global_config(path) : {}
+      raise Hive::ConfigError, "global config at #{path} must be a hash" unless data.is_a?(Hash)
+
+      data["first_run"] ||= {}
+      changed = false
+      unless present_string?(data.dig("first_run", "provider"))
+        data["first_run"]["provider"] = prompt(input, output, "Provider", DEFAULT_PROVIDER)
+        changed = true
+      end
+      unless present_string?(data.dig("first_run", "model"))
+        data["first_run"]["model"] = prompt(input, output, "Model", DEFAULT_MODEL)
+        changed = true
+      end
+
+      return data unless changed
+
+      FileUtils.mkdir_p(File.dirname(path))
+      Hive::Config.write_global_config!(data)
+      data
+    end
+
+    def prompt(input, output, label, default)
+      return default unless input.respond_to?(:tty?) && input.tty?
+
+      output.print "#{label} [#{default}]: "
+      value = input.gets
+      value = value.nil? ? "" : value.strip
+      value.empty? ? default : value
+    end
+
+    def present_string?(value)
+      value.is_a?(String) && !value.strip.empty?
+    end
+  end
+end
diff --git a/lib/hive/install/command_name.rb b/lib/hive/install/command_name.rb
new file mode 100644
index 00000000..0cf062b6
--- /dev/null
+++ b/lib/hive/install/command_name.rb
@@ -0,0 +1,29 @@
+module Hive
+  module Install
+    module CommandName
+      module_function
+
+      def choose(preferred: "hive", fallback: "hv", install_dir:, path_env: ENV.fetch("PATH", ""))
+        existing = first_on_path(preferred, path_env: path_env)
+        return preferred unless existing
+
+        installed_preferred = File.expand_path(File.join(install_dir, preferred))
+        same_path?(existing, installed_preferred) ? preferred : fallback
+      end
+
+      def first_on_path(name, path_env:)
+        path_env.split(File::PATH_SEPARATOR).each do |dir|
+          next if dir.nil? || dir.empty?
+
+          candidate = File.expand_path(File.join(dir, name))
+          return candidate if File.file?(candidate) && File.executable?(candidate)
+        end
+        nil
+      end
+
+      def same_path?(left, right)
+        File.expand_path(left) == File.expand_path(right)
+      end
+    end
+  end
+end
