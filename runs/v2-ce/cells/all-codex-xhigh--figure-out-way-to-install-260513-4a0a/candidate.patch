+++ b/lib/hive/package_manager.rb
@@ -0,0 +1,29 @@
+require "open3"
+
+module Hive
+  module PackageManager
+    module_function
+
+    def update_command_for(receipt)
+      case receipt.channel
+      when "homebrew", "brew"
+        [ "brew", "upgrade", "#{receipt.repo}/hive" ]
+      when "aur"
+        [ receipt.aur_helper, "-Syu", "hive-bin" ]
+      when "script"
+        [ "bash", "-c", "curl -fsSL #{receipt.install_script_url} | bash" ]
+      else
+        nil
+      end
+    end
+
+    def run(command, dry_run: false, output: $stdout)
+      if dry_run
+        output.puts command.join(" ")
+        return true
+      end
+
+      system(*command)
+    end
+  end
+end
