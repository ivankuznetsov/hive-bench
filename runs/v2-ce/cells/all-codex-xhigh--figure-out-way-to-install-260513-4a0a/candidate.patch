diff --git a/install.sh b/install.sh
new file mode 100755
index 00000000..47aaae61
--- /dev/null
+++ b/install.sh
@@ -0,0 +1,235 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+HIVE_REPO="${HIVE_REPO:-<org>/hive}"
+HIVE_VERSION="${HIVE_VERSION:-v0.1.0}"
+HIVE_RELEASE_BASE_URL="${HIVE_RELEASE_BASE_URL:-https://github.com/${HIVE_REPO}/releases/download/${HIVE_VERSION}}"
+HIVE_INSTALL_BIN_DIR="${HIVE_INSTALL_BIN_DIR:-${HOME}/.local/bin}"
+HIVE_INSTALL_PREFER_NATIVE="${HIVE_INSTALL_PREFER_NATIVE:-1}"
+HIVE_INSTALL_DRY_RUN="${HIVE_INSTALL_DRY_RUN:-0}"
+
+log() {
+  printf 'hive install: %s\n' "$*" >&2
+}
+
+die() {
+  log "$*"
+  exit 1
+}
+
+have() {
+  command -v "$1" >/dev/null 2>&1
+}
+
+uname_s() {
+  printf '%s\n' "${HIVE_TEST_UNAME_S:-$(uname -s)}"
+}
+
+uname_m() {
+  printf '%s\n' "${HIVE_TEST_UNAME_M:-$(uname -m)}"
+}
+
+os_release_id() {
+  if [[ -n "${HIVE_TEST_OS_ID:-}" ]]; then
+    printf '%s\n' "$HIVE_TEST_OS_ID"
+    return
+  fi
+  if [[ -r /etc/os-release ]]; then
+    # shellcheck disable=SC1091
+    . /etc/os-release
+    printf '%s\n' "${ID:-}"
+  fi
+}
+
+detect_platform() {
+  local os arch distro
+  os="$(uname_s)"
+  arch="$(uname_m)"
+  distro="$(os_release_id)"
+
+  case "$os" in
+    Darwin)
+      [[ "$arch" == "arm64" ]] || return_unsupported "macOS support is tier-1 only on arm64 for v1"
+      printf 'darwin-arm64\n'
+      ;;
+    Linux)
+      case "$distro" in
+        alpine) return_unsupported "Alpine is out of scope for Hive v1; use Ubuntu 22.04+, Arch, or macOS arm64" ;;
+        nixos) return_unsupported "NixOS is out of scope for Hive v1; use Ubuntu 22.04+, Arch, or macOS arm64" ;;
+      esac
+      [[ "$arch" == "x86_64" || "$arch" == "amd64" ]] ||
+        return_unsupported "Linux support is tier-1 only on x86_64 glibc for v1"
+      printf 'linux-x86_64-gnu\n'
+      ;;
+    FreeBSD|OpenBSD|NetBSD|DragonFly)
+      return_unsupported "BSD platforms are out of scope for Hive v1"
+      ;;
+    *)
+      return_unsupported "unsupported platform ${os}/${arch}; tier-1 is macOS arm64, Ubuntu 22.04+, and Arch"
+      ;;
+  esac
+}
+
+return_unsupported() {
+  printf '%s\n' "$1" >&2
+  return 64
+}
+
+is_arch_linux() {
+  [[ "$(uname_s)" == "Linux" && "$(os_release_id)" == "arch" ]]
+}
+
+native_channel_command() {
+  if [[ "$HIVE_INSTALL_PREFER_NATIVE" != "1" ]]; then
+    return 1
+  fi
+
+  if [[ "$(uname_s)" == "Darwin" ]] && have brew; then
+    printf 'brew install %s/hive\n' "${HIVE_REPO}"
+    return 0
+  fi
+
+  if is_arch_linux; then
+    if have yay; then
+      printf 'yay -S hive-bin\n'
+      return 0
+    fi
+    if have paru; then
+      printf 'paru -S hive-bin\n'
+      return 0
+    fi
+  fi
+
+  return 1
+}
+
+artifact_name_for() {
+  local platform="$1"
+  printf 'hive-%s-%s.tar.gz\n' "$HIVE_VERSION" "$platform"
+}
+
+choose_binary_name() {
+  local install_dir="$1"
+  local existing install_root
+  existing="$(command -v hive || true)"
+  install_root="$(cd "$install_dir" 2>/dev/null && pwd || printf '%s' "$install_dir")"
+  if [[ -n "$existing" && "$(cd "$(dirname "$existing")" && pwd)/$(basename "$existing")" != "${install_root}/hive" ]]; then
+    printf 'hv\n'
+  else
+    printf 'hive\n'
+  fi
+}
+
+sha256_file() {
+  if have sha256sum; then
+    sha256sum "$1" | awk '{print $1}'
+  elif have shasum; then
+    shasum -a 256 "$1" | awk '{print $1}'
+  else
+    die "missing checksum tool: install sha256sum or shasum"
+  fi
+}
+
+verify_checksum() {
+  local file="$1"
+  local checksums="$2"
+  local expected actual base
+  base="$(basename "$file")"
+  expected="$(awk -v name="$base" '$2 == name {print $1}' "$checksums")"
+  [[ -n "$expected" ]] || die "checksum for $base not found in $checksums"
+  actual="$(sha256_file "$file")"
+  [[ "$actual" == "$expected" ]] || die "checksum mismatch for $base"
+}
+
+write_receipt() {
+  local receipt="$1" channel="$2" version="$3" artifact_url="$4" checksum="$5" binary_name="$6"
+  mkdir -p "$(dirname "$receipt")"
+  cat >"$receipt" <<YAML
+channel: ${channel}
+version: ${version}
+artifact_url: ${artifact_url}
+checksum: ${checksum}
+binary_name: ${binary_name}
+installed_at: "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
+YAML
+}
+
+print_dependency_hints() {
+  local missing=0
+  for tool in git bash; do
+    if ! have "$tool"; then
+      log "required tool missing: ${tool}. Install it with your OS package manager and rerun."
+      missing=1
+    fi
+  done
+  for tool in jq gh claude; do
+    if ! have "$tool"; then
+      log "optional tool missing: ${tool}. Some Hive workflows may ask for it later."
+    fi
+  done
+  return "$missing"
+}
+
+install_via_native_channel() {
+  local command_line="$1"
+  log "using native install channel: ${command_line}"
+  if [[ "$HIVE_INSTALL_DRY_RUN" == "1" ]]; then
+    printf '%s\n' "$command_line"
+  else
+    # Intentional shell split: command_line is generated internally by native_channel_command.
+    # shellcheck disable=SC2086
+    $command_line
+  fi
+}
+
+install_release_artifact() {
+  local platform artifact artifact_url tmp checksums command_name checksum receipt
+  platform="$(detect_platform)"
+  artifact="$(artifact_name_for "$platform")"
+  artifact_url="${HIVE_RELEASE_BASE_URL}/${artifact}"
+  tmp="$(mktemp -d)"
+  HIVE_INSTALL_TMP="$tmp"
+  trap 'rm -rf "$HIVE_INSTALL_TMP"' EXIT
+
+  command_name="$(choose_binary_name "$HIVE_INSTALL_BIN_DIR")"
+  log "selected command name: ${command_name}"
+
+  if [[ "$HIVE_INSTALL_DRY_RUN" == "1" ]]; then
+    log "dry run: would download ${artifact_url}"
+    return 0
+  fi
+
+  mkdir -p "$HIVE_INSTALL_BIN_DIR" "${XDG_CONFIG_HOME:-${HOME}/.config}/hive" \
+    "${XDG_DATA_HOME:-${HOME}/.local/share}/hive" \
+    "${XDG_STATE_HOME:-${HOME}/.local/state}/hive" \
+    "${XDG_CACHE_HOME:-${HOME}/.cache}/hive"
+
+  have curl || die "missing curl; install curl or use Homebrew/AUR directly"
+  curl -fsSL "$artifact_url" -o "$tmp/$artifact"
+  curl -fsSL "${HIVE_RELEASE_BASE_URL}/hive-${HIVE_VERSION}-checksums.txt" -o "$tmp/checksums.txt"
+  verify_checksum "$tmp/$artifact" "$tmp/checksums.txt"
+  checksum="$(sha256_file "$tmp/$artifact")"
+
+  tar -xzf "$tmp/$artifact" -C "$tmp"
+  install -m 0755 "$tmp/hive" "$HIVE_INSTALL_BIN_DIR/$command_name"
+  receipt="${XDG_CONFIG_HOME:-${HOME}/.config}/hive/install_receipt.yml"
+  write_receipt "$receipt" "script" "$HIVE_VERSION" "$artifact_url" "$checksum" "$command_name"
+
+  "$HIVE_INSTALL_BIN_DIR/$command_name" --version
+  log "installed ${command_name} to ${HIVE_INSTALL_BIN_DIR}/${command_name}"
+}
+
+main() {
+  print_dependency_hints || die "required tools are missing"
+
+  if native="$(native_channel_command)"; then
+    install_via_native_channel "$native"
+    return
+  fi
+
+  install_release_artifact
+}
+
+if [[ "${HIVE_INSTALL_SOURCE_ONLY:-0}" != "1" ]]; then
+  main "$@"
+fi
