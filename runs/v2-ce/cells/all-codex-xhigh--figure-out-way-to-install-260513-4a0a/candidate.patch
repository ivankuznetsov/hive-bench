@@ -0,0 +1,88 @@
+require "test_helper"
+require "open3"
+
+class InstallShTest < Minitest::Test
+  include HiveTestHelper
+
+  INSTALL_SH = File.expand_path("../../install.sh", __dir__)
+
+  def bash_eval(script, env: {})
+    merged = {
+      "HIVE_INSTALL_SOURCE_ONLY" => "1",
+      "HOME" => "/home/tester"
+    }.merge(env)
+    Open3.capture3(merged, "bash", "-c", "source #{INSTALL_SH.shellescape}; #{script}")
+  end
+
+  def test_detects_macos_arm64
+    out, err, status = bash_eval("detect_platform", env: {
+      "HIVE_TEST_UNAME_S" => "Darwin",
+      "HIVE_TEST_UNAME_M" => "arm64"
+    })
+
+    assert status.success?, err
+    assert_equal "darwin-arm64", out.strip
+  end
+
+  def test_detects_linux_x86_64_gnu
+    out, err, status = bash_eval("detect_platform", env: {
+      "HIVE_TEST_UNAME_S" => "Linux",
+      "HIVE_TEST_UNAME_M" => "x86_64",
+      "HIVE_TEST_OS_ID" => "ubuntu"
+    })
+
+    assert status.success?, err
+    assert_equal "linux-x86_64-gnu", out.strip
+  end
+
+  def test_rejects_alpine_nixos_and_bsd
+    [
+      [ "Linux", "x86_64", "alpine", /Alpine is out of scope/ ],
+      [ "Linux", "x86_64", "nixos", /NixOS is out of scope/ ],
+      [ "FreeBSD", "x86_64", "", /BSD platforms are out of scope/ ]
+    ].each do |os, arch, distro, message|
+      _out, err, status = bash_eval("detect_platform", env: {
+        "HIVE_TEST_UNAME_S" => os,
+        "HIVE_TEST_UNAME_M" => arch,
+        "HIVE_TEST_OS_ID" => distro
+      })
+
+      refute status.success?
+      assert_match message, err
+    end
+  end
+
+  def test_choose_binary_name_uses_hv_when_unrelated_hive_exists
+    with_tmp_dir do |path_dir|
+      with_tmp_dir do |install_dir|
+        existing = File.join(path_dir, "hive")
+        File.write(existing, "#!/usr/bin/env bash\nexit 0\n")
+        FileUtils.chmod(0o755, existing)
+
+        out, err, status = bash_eval("choose_binary_name #{install_dir.shellescape}", env: {
+          "PATH" => "#{path_dir}:#{ENV.fetch('PATH')}"
+        })
+
+        assert status.success?, err
+        assert_equal "hv", out.strip
+      end
+    end
+  end
+
+  def test_write_receipt_records_script_install_metadata
+    with_tmp_dir do |dir|
+      receipt = File.join(dir, "install_receipt.yml")
+      script = "write_receipt #{receipt.shellescape} script v0.1.0 https://example/artifact.tgz abc123 hv"
+
+      _out, err, status = bash_eval(script)
+
+      assert status.success?, err
+      data = YAML.safe_load(File.read(receipt))
+      assert_equal "script", data.fetch("channel")
+      assert_equal "v0.1.0", data.fetch("version")
+      assert_equal "https://example/artifact.tgz", data.fetch("artifact_url")
+      assert_equal "abc123", data.fetch("checksum")
+      assert_equal "hv", data.fetch("binary_name")
+    end
+  end
+end
