index 00000000..50e65b42
--- /dev/null
+++ b/test/unit/dependency_check_test.rb
@@ -0,0 +1,38 @@
+require "test_helper"
+require "hive/dependency_check"
+
+class DependencyCheckTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_required_missing_dependency_reports_hint_and_raises
+    io = StringIO.new
+    err = assert_raises(Hive::DependencyError) do
+      Hive::DependencyCheck.verify!(required: [ "git" ], env: { "PATH" => "" }, io: io)
+    end
+
+    assert_match(/missing required dependency: git/, err.message)
+    assert_match(/required dependency missing: git/, io.string)
+    assert_match(/Install git/, io.string)
+  end
+
+  def test_optional_missing_dependency_reports_hint_and_continues
+    io = StringIO.new
+    deps = Hive::DependencyCheck.verify!(optional: [ "claude" ], env: { "PATH" => "" }, io: io)
+
+    assert_equal [ "claude" ], deps.map(&:name)
+    assert_match(/optional dependency missing: claude/, io.string)
+    assert_match(/Install the Claude CLI/, io.string)
+  end
+
+  def test_present_dependency_is_detected_on_path
+    with_tmp_dir do |dir|
+      executable = File.join(dir, "git")
+      File.write(executable, "#!/bin/sh\nexit 0\n")
+      FileUtils.chmod(0o755, executable)
+
+      deps = Hive::DependencyCheck.verify!(required: [ "git" ], env: { "PATH" => dir }, io: StringIO.new)
+
+      assert_equal true, deps.first.present
+    end
+  end
+end
