+require "test_helper"
+require "hive/commands/init"
+
+class HiveInitCommandPackagingTest < Minitest::Test
+  include HiveTestHelper
+
+  Service = Struct.new(:path, :enable_calls) do
+    def register
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, "service")
+      { supported: true, path: path, autostarted: false }
+    end
+
+    def enable_and_start
+      enable_calls << :enable_and_start
+      { supported: true, ok: true, path: path }
+    end
+  end
+
+  def test_init_scaffolds_project_hive_directory
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        capture_io { Hive::Commands::Init.new(dir).call }
+
+        assert File.exist?(File.join(dir, ".hive", "config.yml"))
+        assert File.exist?(File.join(dir, ".hive", "README.md"))
+      end
+    end
+  end
+
+  def test_init_does_not_overwrite_existing_project_hive_config
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        FileUtils.mkdir_p(File.join(dir, ".hive"))
+        cfg = File.join(dir, ".hive", "config.yml")
+        File.write(cfg, "custom: true\n")
+
+        capture_io { Hive::Commands::Init.new(dir).call }
+
+        assert_equal "custom: true\n", File.read(cfg)
+      end
+    end
+  end
+
+  def test_init_registers_service_without_enabling_autostart_by_default
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        service = Service.new(File.join(dir, "service", "hive.service"), [])
+
+        capture_io { Hive::Commands::Init.new(dir, service: service).call }
+
+        assert File.exist?(service.path)
+        assert_empty service.enable_calls
+      end
+    end
+  end
+
+  def test_init_enables_and_starts_service_after_explicit_prompt_answer
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        service = Service.new(File.join(dir, "service", "hive.service"), [])
+        prompts = Struct.new(:answers) { def collect = answers }.new(default_answers.merge("daemon_autostart" => true))
+
+        capture_io { Hive::Commands::Init.new(dir, prompts: prompts, service: service).call }
+
+        assert_equal [ :enable_and_start ], service.enable_calls
+      end
+    end
+  end
+
+  def default_answers
+    {
+      "planning_agent" => "claude",
+      "development_agent" => "codex",
+      "enabled_reviewers" => Hive::Commands::Init::Prompts::DEFAULT_REVIEWER_NAMES,
+      "triage_bias" => "courageous",
+      "budgets" => Hive::Commands::Init::Prompts::LIMIT_KEYS.each_with_object({}) do |key, hash|
+        hash[key] = Hive::Config::DEFAULTS["budget_usd"].fetch(key)
+      end,
+      "timeouts" => Hive::Commands::Init::Prompts::LIMIT_KEYS.each_with_object({}) do |key, hash|
+        hash[key] = Hive::Config::DEFAULTS["timeout_sec"].fetch(key)
+      end,
+      "daemon_enabled" => true,
+      "daemon_autostart" => false
+    }
+  end
+end
