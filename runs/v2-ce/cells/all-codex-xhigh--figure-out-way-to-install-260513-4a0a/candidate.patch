+++ b/lib/hive/service/systemd_user.rb
@@ -0,0 +1,58 @@
+require "erb"
+require "fileutils"
+require "open3"
+require "hive/paths"
+
+module Hive
+  module Service
+    class SystemdUser
+      UNIT_NAME = "hive.service".freeze
+
+      attr_reader :binary_path
+
+      def initialize(binary_path:, home: ENV.fetch("HOME", Dir.home))
+        @binary_path = binary_path
+        @home = home
+      end
+
+      def supported?
+        true
+      end
+
+      def service_path
+        if ENV["HIVE_HOME"]
+          File.join(ENV.fetch("HIVE_HOME"), "systemd", "user", UNIT_NAME)
+        else
+          File.join(@home, ".config", "systemd", "user", UNIT_NAME)
+        end
+      end
+
+      def register
+        FileUtils.mkdir_p(File.dirname(service_path))
+        File.write(service_path, render)
+        { supported: true, path: service_path, autostarted: false }
+      end
+
+      def enable_and_start
+        register unless File.exist?(service_path)
+        out, err, status = Open3.capture3("systemctl", "--user", "enable", "--now", UNIT_NAME)
+        { supported: true, ok: status.success?, stdout: out, stderr: err, path: service_path }
+      rescue Errno::ENOENT => e
+        { supported: true, ok: false, stderr: e.message, path: service_path }
+      end
+
+      def status
+        out, err, status = Open3.capture3("systemctl", "--user", "is-active", UNIT_NAME)
+        state = status.success? ? out.strip : "stopped"
+        { supported: true, state: state, stdout: out, stderr: err, path: service_path }
+      rescue Errno::ENOENT => e
+        { supported: true, state: "unsupported", stderr: e.message, path: service_path }
+      end
+
+      def render
+        template = File.read(File.expand_path("../../../templates/service/systemd.service.erb", __dir__))
+        ERB.new(template, trim_mode: "-").result(binding)
+      end
+    end
+  end
+end
