+
+    def state_home(env = ENV)
+      expand(env.fetch("XDG_STATE_HOME", File.join(home(env), ".local", "state")))
+    end
+
+    def cache_home(env = ENV)
+      expand(env.fetch("XDG_CACHE_HOME", File.join(home(env), ".cache")))
+    end
+
+    def config_dir(env = ENV)
+      File.join(config_home(env), APP_NAME)
+    end
+
+    def data_dir(env = ENV)
+      File.join(data_home(env), APP_NAME)
+    end
+
+    def state_dir(env = ENV)
+      File.join(state_home(env), APP_NAME)
+    end
+
+    def cache_dir(env = ENV)
+      File.join(cache_home(env), APP_NAME)
+    end
+
+    def config_file(env = ENV)
+      File.join(config_dir(env), "config.yml")
+    end
+
+    def install_receipt(env = ENV)
+      File.join(config_dir(env), "install_receipt.yml")
+    end
+
+    def legacy_hive_home(env = ENV)
+      File.join(home(env), "Dev", APP_NAME)
+    end
+
+    def legacy_global_config(env = ENV)
+      File.join(legacy_hive_home(env), "config.yml")
+    end
+
+    def legacy_dot_state(env = ENV)
+      File.join(home(env), ".hive-state")
+    end
+
+    def ensure_runtime_dirs!(env = ENV)
