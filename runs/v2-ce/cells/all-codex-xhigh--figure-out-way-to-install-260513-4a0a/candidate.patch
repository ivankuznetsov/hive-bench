+    body = File.read(PKGBUILD)
+
+    assert_includes body, "pkgname=hive-bin"
+    assert_includes body, "hive-v0.1.0-linux-x86_64-gnu.tar.gz"
+    assert_includes body, "depends=()"
+    refute_includes body, "ruby"
