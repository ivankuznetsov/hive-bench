+
+Actual binary builds require Tebako and the platform toolchain:
+
+```bash
+GITHUB_REF_NAME=v0.1.0 GITHUB_SHA=$(git rev-parse HEAD) ruby packaging/build/build_release.rb
+```
diff --git a/packaging/build/build_release.rb b/packaging/build/build_release.rb
new file mode 100755
index 00000000..0748a962
--- /dev/null
+++ b/packaging/build/build_release.rb
@@ -0,0 +1,181 @@
+#!/usr/bin/env ruby
+
+require "digest"
+require "fileutils"
+require "json"
+require "open3"
+require "rubygems"
+require "shellwords"
+require "time"
+
+module Hive
+  module Packaging
+    module BuildRelease
+      ROOT = File.expand_path("../..", __dir__)
+      DIST_DIR = File.join(ROOT, "dist")
+      BUILD_METADATA_PATH = File.join(ROOT, "lib", "hive", "build_metadata.rb")
+      ENTRYPOINT = "hive".freeze
+      RUBY_VERSION = "3.4.7".freeze
+      SUPPORTED_TARGETS = %w[
+        darwin-arm64
+        linux-x86_64-gnu
+      ].freeze
+      SEMVER_TAG = /\Av\d+\.\d+\.\d+(?:-[0-9A-Za-z.-]+)?(?:\+[0-9A-Za-z.-]+)?\z/.freeze
+
+      module_function
+
+      def semver_tag?(tag)
+        tag.to_s.match?(SEMVER_TAG)
+      end
+
+      def validate_semver_tag!(tag)
+        return tag if semver_tag?(tag)
+
+        raise ArgumentError, "release ref must be a semver tag like v0.1.0; got #{tag.inspect}"
+      end
+
+      def artifact_name(version:, target:)
+        validate_target!(target)
+        "hive-#{validate_semver_tag!(version)}-#{target}.tar.gz"
+      end
+
+      def checksum_name(version:, target:)
+        "#{artifact_name(version: version, target: target)}.sha256"
+      end
+
+      def checksums_name(version:)
+        "hive-#{validate_semver_tag!(version)}-checksums.txt"
+      end
+
+      def manifest_name(version:, target:)
+        validate_target!(target)
+        "hive-#{validate_semver_tag!(version)}-#{target}.json"
+      end
+
+      def manifest(version:, target:, commit:, built_at:, channel: nil)
+        validate_target!(target)
+        {
+          "schema" => "hive-release-artifact",
+          "schema_version" => 1,
+          "version" => validate_semver_tag!(version),
+          "commit" => commit,
+          "built_at" => built_at,
+          "target" => target,
+          "binary" => ENTRYPOINT,
+          "install_channel" => channel
+        }.compact
+      end
+
+      def build_all(version:, commit:, targets: SUPPORTED_TARGETS, dist_dir: DIST_DIR)
+        validate_semver_tag!(version)
+        targets.each { |target| build_one(version: version, commit: commit, target: target, dist_dir: dist_dir) }
+        write_checksums(version: version, dist_dir: dist_dir)
+      end
+
+      def build_one(version:, commit:, target:, dist_dir: DIST_DIR)
+        validate_target!(target)
+        build_root = File.join(dist_dir, "build", "#{version}-#{target}")
+        binary = File.join(build_root, ENTRYPOINT)
+        built_at = Time.now.utc.iso8601
+        FileUtils.rm_rf(build_root)
+        FileUtils.mkdir_p(build_root)
+
+        run_tebako!(binary: binary, version: version, commit: commit, built_at: built_at, target: target)
+        File.write(File.join(build_root, manifest_name(version: version, target: target)),
+                   JSON.pretty_generate(manifest(version: version, target: target, commit: commit,
+                                                 built_at: built_at)))
+        archive_path = File.join(dist_dir, artifact_name(version: version, target: target))
+        FileUtils.mkdir_p(dist_dir)
+        Dir.chdir(build_root) do
+          system!("tar", "-czf", archive_path, ENTRYPOINT, manifest_name(version: version, target: target))
+        end
+        write_checksum(archive_path)
+        archive_path
+      end
+
+      def run_tebako!(binary:, version:, commit:, built_at:, target:)
+        cmd = [
+          ENV.fetch("TEBAKO_BIN", "tebako"),
+          "press",
+          "--root", ROOT,
+          "--entry-point", "exe/hive",
+          "--output", binary,
+          "--Ruby", RUBY_VERSION,
+          "--mode", "bundle"
+        ]
+        with_build_metadata(version: version, commit: commit, built_at: built_at, target: target) do
+          system!(*cmd)
+        end
+      end
+
+      def with_build_metadata(version:, commit:, built_at:, target:)
+        original = File.exist?(BUILD_METADATA_PATH) ? File.read(BUILD_METADATA_PATH) : nil
+        File.write(BUILD_METADATA_PATH, render_build_metadata(version: version, commit: commit,
+                                                             built_at: built_at, target: target))
+        yield
+      ensure
+        if original.nil?
+          File.delete(BUILD_METADATA_PATH) if File.exist?(BUILD_METADATA_PATH)
+        else
+          File.write(BUILD_METADATA_PATH, original)
+        end
+      end
+
+      def render_build_metadata(version:, commit:, built_at:, target:)
+        release_version = validate_semver_tag!(version).delete_prefix("v")
+        <<~RUBY
+          module Hive
+            module BuildMetadata
+              VERSION = #{release_version.dump}.freeze
+              COMMIT = #{commit.to_s.dump}.freeze
+              BUILD_TIME = #{built_at.to_s.dump}.freeze
+              PLATFORM = #{validate_target!(target).dump}.freeze
+            end
+          end
+        RUBY
+      end
+
+      def write_checksum(path)
+        digest = Digest::SHA256.file(path).hexdigest
+        File.write("#{path}.sha256", "#{digest}  #{File.basename(path)}\n")
+        digest
+      end
+
+      def write_checksums(version:, dist_dir: DIST_DIR)
+        validate_semver_tag!(version)
+        files = Dir[File.join(dist_dir, "hive-#{version}-*.tar.gz")].sort
+        body = files.map { |path| "#{Digest::SHA256.file(path).hexdigest}  #{File.basename(path)}" }.join("\n")
+        body = "#{body}\n" unless body.empty?
+        File.write(File.join(dist_dir, checksums_name(version: version)), body)
+      end
+
+      def validate_target!(target)
+        return target if SUPPORTED_TARGETS.include?(target)
+
+        raise ArgumentError, "unsupported release target #{target.inspect}; expected #{SUPPORTED_TARGETS.join(', ')}"
+      end
+
+      def system!(*args)
+        env = args.first.is_a?(Hash) ? args.shift : {}
+        stdout, stderr, status = Open3.capture3(env, *args)
+        return true if status.success?
+
+        command = args.shelljoin
+        raise "command failed (#{status.exitstatus}): #{command}\n#{stdout}\n#{stderr}"
+      rescue Errno::ENOENT => e
+        raise "missing packaging tool for #{args.shelljoin}: #{e.message}"
+      end
+
+      def cli(argv)
+        version = ENV.fetch("GITHUB_REF_NAME", nil) || argv[0]
+        commit = ENV.fetch("GITHUB_SHA", nil) || `git -C #{ROOT.shellescape} rev-parse HEAD`.strip
+        targets = ENV.fetch("HIVE_RELEASE_TARGETS", "").split(",").map(&:strip).reject(&:empty?)
+        targets = SUPPORTED_TARGETS if targets.empty?
+        validate_semver_tag!(version)
+        build_all(version: version, commit: commit, targets: targets)
+      end
+    end
+  end
+end
+
+Hive::Packaging::BuildRelease.cli(ARGV) if $PROGRAM_NAME == __FILE__
diff --git a/packaging/build/smoke_release.rb b/packaging/build/smoke_release.rb
new file mode 100755
index 00000000..2594f9d6
--- /dev/null
+++ b/packaging/build/smoke_release.rb
@@ -0,0 +1,45 @@
+#!/usr/bin/env ruby
+
+require "fileutils"
+require "open3"
+require "tmpdir"
+
+module Hive
+  module Packaging
+    module SmokeRelease
+      module_function
+
+      def smoke!(artifact:, expected_version:)
+        Dir.mktmpdir("hive-release-smoke") do |dir|
+          system!("tar", "-xzf", artifact, "-C", dir)
+          binary = File.join(dir, "hive")
+          raise "#{artifact} did not unpack an executable hive binary" unless File.executable?(binary)
+
+          out, err, status = Open3.capture3(binary, "--version")
+          unless status.success? && out.strip == expected_version
+            raise "version smoke failed: status=#{status.exitstatus} stdout=#{out.inspect} stderr=#{err.inspect}"
+          end
+
+          help_out, help_err, help_status = Open3.capture3(binary, "daemon", "--help")
+          unless help_status.success? && help_out.include?("hive daemon")
+            raise "daemon help smoke failed: stdout=#{help_out.inspect} stderr=#{help_err.inspect}"
+          end
+        end
+      end
+
+      def system!(*cmd)
+        _out, err, status = Open3.capture3(*cmd)
+        return if status.success?
+
+        raise "command failed: #{cmd.join(' ')}\n#{err}"
+      end
+    end
+  end
+end
+
+if $PROGRAM_NAME == __FILE__
+  artifact, expected_version = ARGV
+  abort "usage: smoke_release.rb ARTIFACT EXPECTED_VERSION" unless artifact && expected_version
+
+  Hive::Packaging::SmokeRelease.smoke!(artifact: artifact, expected_version: expected_version)
+end
