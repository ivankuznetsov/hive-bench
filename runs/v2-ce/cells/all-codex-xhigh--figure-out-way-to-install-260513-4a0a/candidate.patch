+require "rbconfig"
+require "hive/service/launchd"
+require "hive/service/systemd_user"
+
+module Hive
+  module Service
+    module_function
+
+    def manager(platform: RbConfig::CONFIG.fetch("host_os"), binary_path: current_binary_path)
+      case platform
+      when /darwin/i
+        Hive::Service::Launchd.new(binary_path: binary_path)
+      when /linux/i
+        Hive::Service::SystemdUser.new(binary_path: binary_path)
+      else
+        Unsupported.new(platform: platform)
+      end
+    end
+
+    def current_binary_path
+      ENV.fetch("HIVE_BINARY", File.expand_path($PROGRAM_NAME))
+    end
+
+    class Unsupported
+      attr_reader :platform
+
+      def initialize(platform:)
+        @platform = platform
+      end
+
+      def supported?
+        false
+      end
+
+      def register
+        { supported: false, message: "service registration is unsupported on #{platform}" }
+      end
+
+      def enable_and_start
+        { supported: false, message: "service autostart is unsupported on #{platform}" }
+      end
+
+      def status
+        { supported: false, state: "unsupported", message: "service status is unsupported on #{platform}" }
+      end
+    end
+  end
+end
diff --git a/lib/hive/service/launchd.rb b/lib/hive/service/launchd.rb
new file mode 100644
index 00000000..31b39717
--- /dev/null
+++ b/lib/hive/service/launchd.rb
@@ -0,0 +1,58 @@
+require "erb"
+require "fileutils"
+require "open3"
+require "hive/paths"
+
+module Hive
+  module Service
+    class Launchd
+      LABEL = "org.hive.daemon".freeze
+
+      attr_reader :binary_path
+
+      def initialize(binary_path:, home: ENV.fetch("HOME", Dir.home))
+        @binary_path = binary_path
+        @home = home
+      end
+
+      def supported?
+        true
+      end
+
+      def service_path
+        if ENV["HIVE_HOME"]
+          File.join(ENV.fetch("HIVE_HOME"), "launchd", "#{LABEL}.plist")
+        else
+          File.join(@home, "Library", "LaunchAgents", "#{LABEL}.plist")
+        end
+      end
+
+      def register(run_at_load: false)
+        FileUtils.mkdir_p(File.dirname(service_path))
+        File.write(service_path, render(run_at_load: run_at_load))
+        { supported: true, path: service_path, autostarted: false }
+      end
+
+      def enable_and_start
+        register(run_at_load: true)
+        out, err, status = Open3.capture3("launchctl", "load", "-w", service_path)
+        { supported: true, ok: status.success?, stdout: out, stderr: err, path: service_path }
+      rescue Errno::ENOENT => e
+        { supported: true, ok: false, stderr: e.message, path: service_path }
+      end
+
+      def status
+        out, err, status = Open3.capture3("launchctl", "list", LABEL)
+        state = status.success? ? "registered" : "missing"
+        { supported: true, state: state, stdout: out, stderr: err, path: service_path }
+      rescue Errno::ENOENT => e
+        { supported: true, state: "unsupported", stderr: e.message, path: service_path }
+      end
+
+      def render(run_at_load: false)
+        template = File.read(File.expand_path("../../../templates/service/launchd.plist.erb", __dir__))
+        ERB.new(template, trim_mode: "-").result(binding)
+      end
+    end
+  end
+end
