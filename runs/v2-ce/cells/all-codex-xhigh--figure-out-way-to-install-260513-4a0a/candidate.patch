--- /dev/null
+++ b/lib/hive/install_receipt.rb
@@ -0,0 +1,63 @@
+require "yaml"
+require "hive/paths"
+
+module Hive
+  class InstallReceipt
+    DEFAULT_REPO = ENV.fetch("HIVE_RELEASE_REPO", "<org>/hive").freeze
+
+    attr_reader :path, :data
+
+    def initialize(path: Hive::Paths.install_receipt)
+      @path = path
+      @data = File.exist?(path) ? load(path) : {}
+    end
+
+    def channel
+      data["channel"]
+    end
+
+    def version
+      data["version"]
+    end
+
+    def binary_name
+      data["binary_name"] || "hive"
+    end
+
+    def artifact_url
+      data["artifact_url"]
+    end
+
+    def repo
+      data["repo"] || DEFAULT_REPO
+    end
+
+    def aur_helper
+      data["aur_helper"] || ENV.fetch("HIVE_AUR_HELPER", "yay")
+    end
+
+    def install_script_url
+      base = if artifact_url&.include?("/releases/download/")
+               artifact_url.sub(%r{/[^/]+\.tar\.gz\z}, "")
+      else
+               "https://github.com/#{repo}/releases/download/#{version || 'v0.1.0'}"
+      end
+      "#{base}/install.sh"
+    end
+
+    def script_binary_path
+      File.join(ENV.fetch("HIVE_INSTALL_BIN_DIR", File.join(Dir.home, ".local", "bin")), binary_name)
+    end
+
+    private
+
+    def load(path)
+      parsed = YAML.safe_load(File.read(path)) || {}
+      raise Hive::ConfigError, "install receipt at #{path} must be a hash" unless parsed.is_a?(Hash)
+
+      parsed
+    rescue Psych::Exception => e
+      raise Hive::ConfigError, "install receipt at #{path} is not valid YAML: #{e.message}"
+    end
+  end
+end
diff --git a/lib/hive/package_manager.rb b/lib/hive/package_manager.rb
