--- /dev/null
+++ b/test/release/artifact_contract_test.rb
@@ -0,0 +1,84 @@
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require_relative "../../packaging/build/build_release"
+
+class ReleaseArtifactContractTest < Minitest::Test
+  BuildRelease = Hive::Packaging::BuildRelease
+
+  def test_semver_tag_accepts_release_tag
+    assert BuildRelease.semver_tag?("v0.1.0")
+    assert BuildRelease.semver_tag?("v1.2.3-rc.1")
+  end
+
+  def test_semver_tag_rejects_non_release_refs
+    refute BuildRelease.semver_tag?("main")
+    refute BuildRelease.semver_tag?("0.1.0")
+    refute BuildRelease.semver_tag?("release/v0.1.0")
+  end
+
+  def test_artifact_names_are_deterministic
+    assert_equal "hive-v0.1.0-darwin-arm64.tar.gz",
+                 BuildRelease.artifact_name(version: "v0.1.0", target: "darwin-arm64")
+    assert_equal "hive-v0.1.0-linux-x86_64-gnu.tar.gz.sha256",
+                 BuildRelease.checksum_name(version: "v0.1.0", target: "linux-x86_64-gnu")
+    assert_equal "hive-v0.1.0-checksums.txt", BuildRelease.checksums_name(version: "v0.1.0")
+  end
+
+  def test_release_workflow_generates_combined_checksum_manifest_before_publish
+    workflow = File.read(File.expand_path("../../.github/workflows/release.yml", __dir__))
+
+    assert_includes workflow, "Create checksum manifest"
+    assert_includes workflow, "sha256sum hive-${{ github.ref_name }}-*.tar.gz > hive-${{ github.ref_name }}-checksums.txt"
+    assert_includes workflow, "files: dist/*"
+  end
+
+  def test_unsupported_target_is_rejected
+    err = assert_raises(ArgumentError) do
+      BuildRelease.artifact_name(version: "v0.1.0", target: "linux-musl")
+    end
+    assert_match(/unsupported release target/, err.message)
+  end
+
+  def test_manifest_includes_release_metadata_hooks
+    manifest = BuildRelease.manifest(
+      version: "v0.1.0",
+      target: "linux-x86_64-gnu",
+      commit: "abc123",
+      built_at: "2026-07-10T00:00:00Z",
+      channel: "script"
+    )
+
+    assert_equal "hive-release-artifact", manifest.fetch("schema")
+    assert_equal "v0.1.0", manifest.fetch("version")
+    assert_equal "abc123", manifest.fetch("commit")
+    assert_equal "linux-x86_64-gnu", manifest.fetch("target")
+    assert_equal "script", manifest.fetch("install_channel")
+  end
+
+  def test_render_build_metadata_embeds_release_values
+    body = BuildRelease.render_build_metadata(
+      version: "v1.2.3",
+      commit: "abc123",
+      built_at: "2026-07-10T00:00:00Z",
+      target: "linux-x86_64-gnu"
+    )
+
+    assert_includes body, 'VERSION = "1.2.3".freeze'
+    assert_includes body, 'COMMIT = "abc123".freeze'
+    assert_includes body, 'BUILD_TIME = "2026-07-10T00:00:00Z".freeze'
+    assert_includes body, 'PLATFORM = "linux-x86_64-gnu".freeze'
+  end
+
+  def test_write_checksum_uses_sha256_and_artifact_basename
+    Dir.mktmpdir("hive-artifact-contract") do |dir|
+      artifact = File.join(dir, "hive-v0.1.0-linux-x86_64-gnu.tar.gz")
+      File.write(artifact, "payload")
+
+      digest = BuildRelease.write_checksum(artifact)
+
+      assert_equal Digest::SHA256.hexdigest("payload"), digest
+      assert_equal "#{digest}  #{File.basename(artifact)}\n", File.read("#{artifact}.sha256")
+    end
+  end
+end
