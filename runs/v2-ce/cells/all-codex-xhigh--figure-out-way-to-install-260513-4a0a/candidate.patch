+  end
+
+  def test_install_message_explains_init_xdg_and_systemd_prompt
+    body = File.read(INSTALL)
+
+    assert_includes body, "~/.config/hive/config.yml"
+    assert_includes body, "systemd user unit"
+    assert_includes body, "prompts before enabling"
+  end
+
+  def test_renderer_stamps_pkgbuild_and_srcinfo_from_release_metadata
+    sha = "b" * 64
+    pkgbuild = Hive::Packaging::Aur::Renderer.render_pkgbuild(
+      version: "v1.2.3",
+      sha256: sha,
+      repo: "example/hive"
+    )
+    srcinfo = Hive::Packaging::Aur::Renderer.render_srcinfo(
+      version: "v1.2.3",
+      sha256: sha,
+      repo: "example/hive"
