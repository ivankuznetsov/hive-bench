@@ -0,0 +1,109 @@
+require "test_helper"
+require "hive/commands/uninstall"
+
+class HiveUninstallCommandTest < Minitest::Test
+  Receipt = Struct.new(:channel, :repo, :script_binary_path, keyword_init: true)
+  Service = Struct.new(:path) do
+    def register
+      { supported: true, path: path }
+    end
+  end
+
+  include HiveTestHelper
+
+  def tty_input(text)
+    input = StringIO.new(text)
+    input.define_singleton_method(:tty?) { true }
+    input
+  end
+
+  def test_uninstall_removes_service_and_script_binary_but_preserves_project_by_default
+    with_tmp_dir do |dir|
+      service_path = File.join(dir, "hive.service")
+      binary_path = File.join(dir, "hive")
+      project_hive = File.join(dir, "project", ".hive")
+      FileUtils.mkdir_p(project_hive)
+      File.write(service_path, "service")
+      File.write(binary_path, "binary")
+      out = StringIO.new
+      receipt = Receipt.new(channel: "script", script_binary_path: binary_path)
+
+      Hive::Commands::Uninstall.new(
+        project_root: File.join(dir, "project"),
+        receipt: receipt,
+        service: Service.new(service_path),
+        output: out
+      ).call
+
+      refute File.exist?(service_path)
+      refute File.exist?(binary_path)
+      assert File.directory?(project_hive), ".hive must be preserved by default"
+      assert_match(/preserving .*\.hive/, out.string)
+      assert_match(/skills are managed by agent marketplaces/, out.string)
+    end
+  end
+
+  def test_uninstall_purge_without_separate_confirmation_preserves_project_scaffold
+    with_tmp_dir do |dir|
+      project = File.join(dir, "project")
+      FileUtils.mkdir_p(File.join(project, ".hive"))
+      receipt = Receipt.new(channel: "homebrew", repo: "<org>/hive")
+      out = StringIO.new
+
+      Hive::Commands::Uninstall.new(
+        project_root: project,
+        purge: true,
+        receipt: receipt,
+        service: Service.new(File.join(dir, "missing.service")),
+        output: out
+      ).call
+
+      assert File.exist?(File.join(project, ".hive"))
+      assert_match(/brew uninstall <org>\/hive\/hive/, out.string)
+      assert_match(/preserving .*\.hive/, out.string)
+      assert_match(/preserving ~\/.local\/state\/hive/, out.string)
+    end
+  end
+
+  def test_uninstall_purge_yes_removes_project_scaffold
+    with_tmp_dir do |dir|
+      project = File.join(dir, "project")
+      FileUtils.mkdir_p(File.join(project, ".hive"))
+      receipt = Receipt.new(channel: "homebrew", repo: "<org>/hive")
+      out = StringIO.new
+
+      Hive::Commands::Uninstall.new(
+        project_root: project,
+        purge: true,
+        yes: true,
+        receipt: receipt,
+        service: Service.new(File.join(dir, "missing.service")),
+        output: out
+      ).call
+
+      refute File.exist?(File.join(project, ".hive"))
+      assert_match(/removed .*\.hive/, out.string)
+    end
+  end
+
+  def test_uninstall_purge_prompts_for_project_cleanup_on_tty
+    with_tmp_dir do |dir|
+      project = File.join(dir, "project")
+      FileUtils.mkdir_p(File.join(project, ".hive"))
+      receipt = Receipt.new(channel: "script", script_binary_path: File.join(dir, "missing-bin"))
+      out = StringIO.new
+
+      Hive::Commands::Uninstall.new(
+        project_root: project,
+        purge: true,
+        input: tty_input("yes\n"),
+        receipt: receipt,
+        service: Service.new(File.join(dir, "missing.service")),
+        output: out
+      ).call
+
+      refute File.exist?(File.join(project, ".hive"))
+      assert_match(/remove project \.hive\/ scaffold/, out.string)
+    end
+  end
+end
