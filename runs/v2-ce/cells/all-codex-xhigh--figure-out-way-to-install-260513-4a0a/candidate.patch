+
+class HiveUpdateCommandTest < Minitest::Test
+  Receipt = Struct.new(:channel, :repo, :aur_helper, :install_script_url, keyword_init: true)
+  Runner = Struct.new(:commands) do
+    def run(command, dry_run:, output:)
+      commands << [ command, dry_run, output.class.name ]
+      true
+    end
+  end
+
+  def test_homebrew_receipt_delegates_to_brew_upgrade
+    runner = Runner.new([])
+    out = StringIO.new
+    receipt = Receipt.new(channel: "homebrew", repo: "<org>/hive")
+
+    Hive::Commands::Update.new(receipt: receipt, runner: runner, output: out).call
+
+    assert_equal [ "brew", "upgrade", "<org>/hive/hive" ], runner.commands.first.first
+    assert_match(/brew upgrade/, out.string)
+  end
+
+  def test_aur_receipt_delegates_to_aur_helper
+    runner = Runner.new([])
+    receipt = Receipt.new(channel: "aur", repo: "<org>/hive", aur_helper: "paru")
+
+    Hive::Commands::Update.new(receipt: receipt, runner: runner, output: StringIO.new).call
+
+    assert_equal [ "paru", "-Syu", "hive-bin" ], runner.commands.first.first
+  end
+
+  def test_script_receipt_delegates_to_install_script
+    runner = Runner.new([])
+    receipt = Receipt.new(channel: "script", install_script_url: "https://example/install.sh")
+
+    Hive::Commands::Update.new(receipt: receipt, runner: runner, output: StringIO.new).call
+
+    assert_equal [ "bash", "-c", "curl -fsSL https://example/install.sh | bash" ], runner.commands.first.first
+  end
+
+  def test_unknown_channel_fails_safely
+    out = StringIO.new
+    receipt = Receipt.new(channel: "mystery")
+
+    err = assert_raises(Hive::Error) do
+      Hive::Commands::Update.new(receipt: receipt, output: out).call
+    end
+
+    assert_match(/install channel is unknown/, err.message)
+    assert_match(/install channel is unknown/, out.string)
+  end
+end
