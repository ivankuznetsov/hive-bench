diff --git a/lib/hive/dependency_check.rb b/lib/hive/dependency_check.rb
new file mode 100644
index 00000000..4a2e911a
--- /dev/null
+++ b/lib/hive/dependency_check.rb
@@ -0,0 +1,68 @@
+module Hive
+  class DependencyError < Error
+    def exit_code
+      ExitCodes::SOFTWARE
+    end
+  end
+
+  module DependencyCheck
+    Dependency = Struct.new(:name, :required, :present, :hint, keyword_init: true) do
+      def missing?
+        !present
+      end
+    end
+
+    HINTS = {
+      "git" => "Install git with your OS package manager, then rerun the command.",
+      "bash" => "Install bash or run from an environment where bash is on PATH.",
+      "claude" => "Install the Claude CLI through its official installer or marketplace.",
+      "gh" => "Install GitHub CLI from https://cli.github.com/ and authenticate with `gh auth login`.",
+      "jq" => "Install jq with your OS package manager when JSON filtering is needed."
+    }.freeze
+
+    module_function
+
+    def check(required: [], optional: [], env: ENV)
+      required.map { |name| dependency_for(name, required: true, env: env) } +
+        optional.map { |name| dependency_for(name, required: false, env: env) }
+    end
+
+    def verify!(required: [], optional: [], env: ENV, io: $stderr)
+      dependencies = check(required: required, optional: optional, env: env)
+      dependencies.select(&:missing?).each do |dep|
+        severity = dep.required ? "required" : "optional"
+        io.puts "hive: #{severity} dependency missing: #{dep.name}"
+        io.puts "      #{dep.hint}"
+      end
+
+      missing_required = dependencies.select { |dep| dep.required && dep.missing? }
+      return dependencies if missing_required.empty?
+
+      names = missing_required.map(&:name).join(", ")
+      raise DependencyError, "missing required #{pluralize('dependency', missing_required.size)}: #{names}"
+    end
+
+    def dependency_for(name, required:, env:)
+      Dependency.new(
+        name: name,
+        required: required,
+        present: executable_on_path?(name, env: env),
+        hint: HINTS.fetch(name, "Install #{name} and ensure it is on PATH.")
+      )
+    end
+
+    def executable_on_path?(name, env: ENV)
+      path = env.fetch("PATH", "")
+      path.split(File::PATH_SEPARATOR).any? do |dir|
+        next false if dir.nil? || dir.empty?
+
+        candidate = File.join(dir, name)
+        File.file?(candidate) && File.executable?(candidate)
+      end
+    end
+
+    def pluralize(word, count)
+      count == 1 ? word : "#{word}s"
+    end
+  end
+end
diff --git a/lib/hive/entrypoint.rb b/lib/hive/entrypoint.rb
new file mode 100644
index 00000000..a58edd6d
--- /dev/null
+++ b/lib/hive/entrypoint.rb
@@ -0,0 +1,41 @@
+module Hive
+  module Entrypoint
+    module_function
+
+    def run(argv = ARGV)
+      require "hive"
+      require "hive/cli"
+
+      args = argv.dup
+      if args == [ "--version" ] || args == [ "-v" ]
+        puts Hive::BuildInfo.version_string
+        return Hive::ExitCodes::SUCCESS
+      end
+
+      rewrite_help_flag!(args)
+      Hive::CLI.start(args)
+      Hive::ExitCodes::SUCCESS
+    rescue Hive::Error => e
+      warn "hive: #{e.message}"
+      e.respond_to?(:exit_code) ? e.exit_code : Hive::ExitCodes::GENERIC
+    end
+
+    # Thor only honours `--help` before the subcommand name
+    # (`hive help approve`); `hive approve --help` would be consumed as
+    # the TARGET positional. Intercept the help flag before Thor dispatch
+    # so the convention agents try first works.
+    def rewrite_help_flag!(argv)
+      return if argv.empty?
+
+      cmd_idx = argv.index { |a| !a.start_with?("-") }
+      return unless cmd_idx
+
+      help_idx = argv[(cmd_idx + 1)..]&.index { |a| a == "--help" || a == "-h" }
+      return unless help_idx
+
+      cmd = argv.delete_at(cmd_idx)
+      argv.delete_at(cmd_idx + help_idx)
+      argv.unshift("help", cmd)
+    end
+  end
+end
