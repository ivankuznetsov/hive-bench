+      original = <<~YAML
+        default_workflow: content
+        # agent choice stays put
+        plan:
+          agent: codex
+        budget_usd:
+          plan: 17
+        babysitter:
+          enabled: false
+        daemon:
+          enabled: false # setup enrollment only
+        review:
+          reviewers: [codex-native-review]
+      YAML
+      File.write(config_path, original)
+      ops = ExistingOps.new(false)
+
+      with_env("HIVE_HOME" => File.join(root, "hive-home")) do
+        result = Hive::Setup::ProjectEnrollment.new(
+          project,
+          git_ops_factory: ->(_path) { ops },
+          output: StringIO.new, error: StringIO.new
+        ).call
+
+        assert_equal "existing", result.outcome
+        assert ops.attached
+        registered = Hive::Config.find_project("demo")
+        assert_equal project, registered.fetch("path")
+      end
