+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-setup.v1.json",
+  "title": "hive setup output (v1)",
+  "description": "Stable two-phase local setup summary. A preflight failure guarantees completed is empty and no project/service/runtime mutation occurred; a mutation failure reports completed and pending repair steps for a safe retry.",
+  "type": "object",
+  "additionalProperties": false,
+  "required": [
+    "schema", "schema_version", "ok", "phase", "platform", "project_path",
+    "mode", "url", "message", "checks", "summary", "completed", "pending"
+  ],
+  "properties": {
+    "schema": { "const": "hive-setup" },
+    "schema_version": { "const": 1 },
+    "ok": { "type": "boolean" },
+    "phase": { "type": "string", "enum": [ "preflight", "mutation", "complete" ] },
+    "platform": { "type": "string", "enum": [ "linux", "macos", "unsupported" ] },
+    "project_path": { "type": "string", "minLength": 1 },
+    "mode": { "type": [ "string", "null" ], "enum": [ "managed", "foreground", null ] },
+    "url": { "type": [ "string", "null" ], "pattern": "^http://" },
+    "message": { "type": "string", "minLength": 1 },
+    "checks": {
+      "type": "array",
+      "items": { "$ref": "#/$defs/Check" }
+    },
+    "summary": {
+      "type": "object",
+      "additionalProperties": { "type": "integer", "minimum": 0 }
+    },
+    "completed": {
+      "type": "array",
+      "uniqueItems": true,
+      "items": { "$ref": "#/$defs/Step" }
+    },
+    "pending": {
+      "type": "array",
+      "uniqueItems": true,
+      "items": { "$ref": "#/$defs/Step" }
+    }
+  },
+  "$defs": {
+    "Step": {
+      "type": "string",
+      "enum": [ "qmd", "web-runtime", "project", "daemon", "web" ]
+    },
+    "Check": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [ "component", "status", "message", "remediation", "blocking" ],
+      "properties": {
+        "component": { "type": "string", "minLength": 1 },
+        "status": {
+          "type": "string",
+          "enum": [
+            "present", "repairable", "missing", "version_too_old", "unauthenticated",
+            "unsupported", "installed", "unchanged", "enrolled", "healthy", "failed"
+          ]
+        },
+        "message": { "type": "string" },
+        "remediation": { "type": [ "string", "null" ] },
+        "blocking": { "type": "boolean" }
+      }
+    }
+  }
+}
