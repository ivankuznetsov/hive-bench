diff --git a/test/unit/web/runtime_installer_test.rb b/test/unit/web/runtime_installer_test.rb
new file mode 100644
index 00000000..e76751c1
--- /dev/null
+++ b/test/unit/web/runtime_installer_test.rb
@@ -0,0 +1,222 @@
+require "test_helper"
+require "hive/web/runtime_installer"
+
+class WebRuntimeInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_install_provisions_only_xdg_paths_and_is_idempotent_until_the_lock_changes
+    with_app_and_xdg do |app_dir, roots|
+      calls = []
+      runner = lambda do |env, argv, chdir:|
+        calls << [ env, argv, chdir ]
+        true
+      end
+      installer = Hive::Web::RuntimeInstaller.new(app_dir: app_dir, version: "1.2.3", runner: runner)
+
+      installer.install!
+
+      assert installer.ready?
+      assert_equal [ "bundle", "bin/rails", "bin/rails" ], calls.map { |(_env, argv, _dir)| argv.first }
+      assert_equal [ "assets:precompile", "db:prepare" ], calls.drop(1).map { |(_env, argv, _dir)| argv[1] }
+      calls.each do |env, _argv, chdir|
+        assert_equal app_dir, chdir
+        writable_paths(env).each do |path|
+          refute path.start_with?(app_dir), "runtime path leaked into read-only app: #{path}"
+          assert roots.any? { |root| path.start_with?(root) }, "runtime path escaped XDG roots: #{path}"
+        end
+      end
+      assert File.file?(File.join(installer.public_dir, "favicon.ico"))
+
+      installer.install!
+      assert_equal 3, calls.length, "a matching manifest must make install idempotent"
+
+      File.write(File.join(app_dir, "Gemfile.lock"), "changed lock\n")
+      refute installer.ready?
+      installer.install!
+      assert_equal 6, calls.length
+      assert installer.ready?
+    end
+  end
+
+  def test_failed_step_is_typed_and_never_publishes_a_ready_manifest
+    with_app_and_xdg do |app_dir, _roots|
+      runner = lambda do |_env, argv, chdir:|
+        assert_equal app_dir, chdir
+        argv[1] != "assets:precompile"
+      end
+      installer = Hive::Web::RuntimeInstaller.new(app_dir: app_dir, version: "1.2.3", runner: runner)
+
+      error = assert_raises(Hive::Web::RuntimeInstaller::InstallError) { installer.install! }
+
+      assert_equal :assets, error.step
+      assert_match(/assets:precompile/, error.message)
+      refute installer.ready?
+      refute File.exist?(installer.manifest_path)
+    end
+  end
+
+  def test_failed_rebuild_removes_a_previously_published_manifest
+    with_app_and_xdg do |app_dir, _roots|
+      succeeds = ->(_env, _argv, chdir:) { chdir == app_dir }
+      installer = Hive::Web::RuntimeInstaller.new(app_dir: app_dir, version: "1.2.3", runner: succeeds)
+      installer.install!
+      FileUtils.rm_rf(installer.send(:bundle_path))
+      refute installer.ready?
+
+      fails = ->(_env, argv, chdir:) { chdir == app_dir && argv.first != "bundle" }
+      installer = Hive::Web::RuntimeInstaller.new(app_dir: app_dir, version: "1.2.3", runner: fails)
+      assert_raises(Hive::Web::RuntimeInstaller::InstallError) { installer.install! }
+
+      refute installer.ready?
+      refute File.exist?(installer.manifest_path), "a failed repair must not leave the old ready marker"
+    end
+  end
+
+  def test_discovery_prefers_override_then_source_checkout_then_packaged_gem
+    Dir.mktmpdir("hive-web-discovery") do |dir|
+      override = make_app(File.join(dir, "override"))
+      checkout_root = File.join(dir, "checkout")
+      source = make_app(File.join(checkout_root, "web"))
+      FileUtils.touch(File.join(checkout_root, ".git"))
+      gem_root = File.join(dir, "gem")
+      packaged = make_app(File.join(gem_root, "web"))
+
+      with_env("HIVEBOX_WEB_APP_DIR" => override) do
