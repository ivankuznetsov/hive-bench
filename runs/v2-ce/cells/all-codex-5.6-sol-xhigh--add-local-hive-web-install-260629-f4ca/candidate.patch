+require "test_helper"
+require "hive/commands/web/service_manager"
+
+class WebServiceManagerTest < Minitest::Test
+  include HiveTestHelper
+
+  def health(identity, reachable: true)
+    { reachable: reachable, identity: identity, status: reachable ? 200 : nil, payload: {} }
+  end
+
+  def manager(host_os: "linux", responses: {}, healths: [], runtime_ready: true,
+              manager_available: true, port_occupied: false)
+    calls = []
+    runner = lambda do |argv|
+      calls << argv
+      responses.fetch(argv, Hive::Commands::Web::ServiceManager::CommandResult.new(true, "", ""))
+    end
+    probe = lambda do |_url|
+      healths.length > 1 ? healths.shift : healths.first || health(:unreachable, reachable: false)
+    end
+    instance = Hive::Commands::Web::ServiceManager.new(
+      host_os: host_os,
+      runner: runner,
+      health_probe: probe,
+      port_probe: ->(_url) { port_occupied },
+      runtime_probe: -> { runtime_ready },
+      sleeper: ->(_seconds) { },
+      start_timeout: 0.01,
+      manager_available: manager_available,
+      unit_path: "/tmp/hive-web.service",
+      unit_exists: ->(_path) { true }
+    )
+    [ instance, calls ]
+  end
+
+  def test_status_reports_manager_unavailable_and_start_points_to_foreground
+    instance, = manager(
+      manager_available: false,
+      healths: [ health(:unreachable, reachable: false) ]
+    )
+
+    assert_equal "manager_unavailable",
+                 instance.status("http://127.0.0.1:4567").fetch("state")
+    error = assert_raises(Hive::WebServiceFailed) do
+      instance.start("http://127.0.0.1:4567")
+    end
+    assert_match(/bare `hive web`/, error.message)
+  end
+
+  def test_start_is_idempotent_for_matching_hive_web
+    instance, calls = manager(healths: [ health(:matching) ])
+
+    result = instance.start("http://127.0.0.1:4567")
+
+    assert_equal "unchanged", result.fetch("outcome")
+    refute_includes calls, %w[systemctl --user start hive-web]
+  end
+
+  def test_start_rejects_wrong_responder_without_touching_manager
+    instance, calls = manager(healths: [ health(:wrong) ])
+
+    error = assert_raises(Hive::WebPortCollision) do
+      instance.start("http://127.0.0.1:4567")
+    end
+
+    assert_match(/port 4567/i, error.message)
+    assert_match(/web\.port/, error.message)
+    assert_empty calls
+  end
+
+  def test_start_rejects_a_raw_tcp_listener_that_never_speaks_http
+    instance, calls = manager(
+      healths: [ health(:unreachable, reachable: false) ], port_occupied: true
+    )
+
+    error = assert_raises(Hive::WebPortCollision) do
+      instance.start("http://127.0.0.1:4567")
+    end
+
+    assert_match(/port 4567.*occupied/i, error.message)
+    assert_empty calls
+    assert_equal "listening",
+                 instance.status("http://127.0.0.1:4567").fetch("port_state")
+  end
+
+  def test_tcp_probe_uses_unbracketed_ipv6_hostname
+    seen = nil
+    fake_socket = Object.new
+    fake_socket.define_singleton_method(:close) { true }
+    with_replaced_singleton_method(Socket, :tcp, lambda { |host, port, connect_timeout:, &block|
+      seen = [ host, port, connect_timeout ]
+      block.call(fake_socket)
+    }) do
+      assert Hive::Commands::Web::ServiceManager::TcpProbe.new.call("http://[::1]:4567")
+    end
+
+    assert_equal [ "::1", 4567, 1 ], seen
+  end
+
+  def test_start_rejects_same_version_responder_with_wrong_auth_mode
+    mismatch = health(:misconfigured).merge(
+      payload: { "version" => Hive::VERSION, "auth_mode" => "unsafe" }
+    )
+    instance, calls = manager(healths: [ mismatch ])
+
+    error = assert_raises(Hive::WebServiceFailed) do
+      instance.start("http://127.0.0.1:4567")
+    end
+
+    assert_match(/managed configuration/, error.message)
+    assert_match(/auth_mode="unsafe"/, error.message)
+    assert_empty calls
+  end
+
+  def test_http_probe_requests_deep_health_and_includes_auth_in_identity
+    server = TCPServer.new("127.0.0.1", 0)
+    request_line = nil
+    responder = Thread.new do
+      socket = server.accept
+      request_line = socket.gets
+      while (line = socket.gets)
+        break if line == "\r\n"
+      end
+      body = JSON.generate(
+        "service" => "hive-web", "version" => Hive::VERSION,
+        "auth_mode" => "unsafe", "ok" => true
+      )
+      socket.write("HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: #{body.bytesize}\r\n\r\n#{body}")
+      socket.close
+    end
+    probe = Hive::Commands::Web::ServiceManager::HttpProbe.new(
+      expected_auth_mode: "local", deep: true
+    )
+
+    result = probe.call("http://127.0.0.1:#{server.local_address.ip_port}")
+
+    responder.join
+    assert_equal :misconfigured, result.fetch(:identity)
+    assert_match(%r{GET /health\?deep=1 HTTP/1\.1}, request_line)
+  ensure
+    server&.close
+    responder&.kill if responder&.alive?
+  end
+
+  def test_start_reports_stale_hive_responder_separately_from_port_collision
+    instance, calls = manager(healths: [ health(:stale) ])
+
+    error = assert_raises(Hive::WebServiceFailed) do
+      instance.start("http://127.0.0.1:4567")
+    end
+
+    assert_match(/stale Hive web responder/, error.message)
+    refute_kind_of Hive::WebPortCollision, error
+    assert_empty calls
+  end
+
+  def test_start_runs_array_argv_and_polls_until_identified
+    instance, calls = manager(healths: [
+      health(:unreachable, reachable: false),
+      health(:unreachable, reachable: false),
+      health(:matching)
+    ])
+
+    result = instance.start("http://127.0.0.1:4567")
+
+    assert_equal "started", result.fetch("outcome")
+    assert_includes calls, %w[systemctl --user daemon-reload]
+    assert_includes calls, %w[systemctl --user enable --now hive-web]
+  end
+
+  def test_status_distinguishes_stale_runtime_wrong_responder_and_failed_unit
+    active = Hive::Commands::Web::ServiceManager::CommandResult.new(true, "active\n", "")
+    failed = Hive::Commands::Web::ServiceManager::CommandResult.new(true, "failed\n", "")
+
+    stale, = manager(
+      responses: { %w[systemctl --user is-active hive-web] => active },
+      healths: [ health(:matching) ], runtime_ready: false
+    )
+    assert_equal "stale_runtime", stale.status("http://127.0.0.1:4567").fetch("state")
+
+    wrong, = manager(
+      responses: { %w[systemctl --user is-active hive-web] => active },
+      healths: [ health(:wrong) ]
+    )
+    wrong_status = wrong.status("http://127.0.0.1:4567")
+    assert_equal "wrong_responder", wrong_status.fetch("state")
+    assert_equal "listening", wrong_status.fetch("port_state")
+
+    failed_service, = manager(
+      responses: {
+        %w[systemctl --user is-active hive-web] => Hive::Commands::Web::ServiceManager::CommandResult.new(false, "inactive\n", ""),
+        %w[systemctl --user is-failed hive-web] => failed
+      }, healths: [ health(:unreachable, reachable: false) ]
+    )
+    assert_equal "failed", failed_service.status("http://127.0.0.1:4567").fetch("state")
+  end
+
+  def test_stop_restart_and_tail_only_target_web_service
+    instance, calls = manager(healths: [ health(:matching) ])
+
+    instance.stop
+    instance.restart("http://127.0.0.1:4567")
+    instance.tail
+
+    assert_includes calls, %w[systemctl --user stop hive-web]
+    assert_includes calls, %w[systemctl --user restart hive-web]
+    assert_includes calls, %w[journalctl --user -u hive-web -f]
+    refute calls.flatten.any? { |arg| arg.include?("daemon") }
+  end
+end
