diff --git a/web/test/e2e/local_mode_e2e.rb b/web/test/e2e/local_mode_e2e.rb
new file mode 100644
index 00000000..0c178a73
--- /dev/null
+++ b/web/test/e2e/local_mode_e2e.rb
@@ -0,0 +1,129 @@
+require "application_system_test_case"
+require "json"
+require "open3"
+
+# Local-mode parity at the real browser/filesystem/process boundary.
+# Deliberately explicit (not *_test.rb): CI runs it after installing the root
+# gem bundle. The Rails app, CLI, repository state, and daemon are real; only
+# the agent binary is the same deterministic fake used by golden_path_e2e.
+class LocalModeE2E < ApplicationSystemTestCase
+  REPO_ROOT = File.expand_path("../../..", __dir__)
+  SUPPORT = File.expand_path("support", __dir__)
+
+  setup do
+    speed_up_daemon!
+    @project = create_hive_project!("local-mode-app")
+    force_headless_claude!(@project)
+    StatusBroadcaster.start!
+  end
+
+  teardown do
+    if @daemon_pid
+      Process.kill("TERM", @daemon_pid)
+      Process.wait(@daemon_pid)
+    end
+    StatusBroadcaster.stop!
+  rescue Errno::ESRCH, Errno::ECHILD
+    StatusBroadcaster.stop!
+  end
+
+  test "CLI and local browser share tasks that the same daemon dispatches" do
+    with_web_auth_mode("local") do
+      cli_slug = create_task!(@project, "Created from the local CLI")
+
+      visit "/"
+      assert_selector ".topbar-session", text: "Local operator"
+      assert_no_selector ".session-login a", text: /GitHub/i
+      assert_selector ".task-row", text: "Created from the local CLI"
+
+      spawn_daemon!
+      wait_for_task_to_leave_inbox!(cli_slug)
+
+      fill_in "New idea", with: "Created from local web"
+      find(".composer select[name='project']").find("option[value='#{@project}']").select_option
+      click_button "Add idea"
+      assert_selector ".task-row", text: "Created from local web"
+
+      payload = status_payload
+      rows = payload.fetch("projects").find { |project| project.fetch("name") == @project }.fetch("tasks")
+      assert rows.any? { |row| row.fetch("slug") == cli_slug }
+      web_row = rows.find { |row| row.fetch("slug") != cli_slug }
+      refute_nil web_row, "web-created task must appear in the CLI status payload"
+
+      daemon_pid = @daemon_pid
+      wait_for_task_to_leave_inbox!(web_row.fetch("slug"))
+      assert_equal daemon_pid, @daemon_pid
+      assert Process.kill(0, @daemon_pid), "the same daemon must remain alive for both tasks"
+
+      registry = Hive::Config.registered_projects.find { |entry| entry.fetch("name") == @project }
+      assert_equal File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "repos", @project), registry.fetch("path")
+      assert_equal File.join(registry.fetch("path"), ".hive-state"), registry.fetch("hive_state_path")
+      refute registry.fetch("path").start_with?("/data/"), "local mode must not copy the project into Docker storage"
+    end
+  end
+
+  private
+
+  def status_payload
+    output, = capture_io { Hive::Commands::Status.new(json: true).call }
+    JSON.parse(output)
+  end
+
+  def speed_up_daemon!
+    path = File.join(ENV["HIVE_HOME"], "config.yml")
+    data = File.exist?(path) ? YAML.safe_load_file(path) : {}
+    data ||= {}
+    data["daemon"] = { "poll_interval_sec" => 5, "fast_poll_sec" => 1, "edit_debounce_sec" => 1 }
+    File.write(path, data.to_yaml)
+  end
+
+  def force_headless_claude!(project)
+    path = File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "repos", project,
+                     ".hive-state", "config.yml")
+    data = YAML.safe_load_file(path)
+    data["claude"] = (data["claude"] || {}).merge("mode" => "headless")
+    data["execute"] = (data["execute"] || {}).merge("agent" => "claude")
+    data["worktree_root"] = File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "worktrees")
+    File.write(path, data.to_yaml)
+  end
+
+  def spawn_daemon!
+    env = {
+      "HIVE_HOME" => ENV["HIVE_HOME"],
+      "HIVE_WORKTREE_BASE" => File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "worktrees"),
+      "PATH" => "#{SUPPORT}:#{ENV['PATH']}",
+      "BUNDLE_GEMFILE" => File.join(REPO_ROOT, "Gemfile"),
+      "BUNDLE_PATH" => ENV["GOLDEN_E2E_BUNDLE_PATH"],
+      "BUNDLE_APP_CONFIG" => nil, "BUNDLE_DEPLOYMENT" => nil, "BUNDLE_FROZEN" => nil,
+      "RUBYOPT" => nil, "RUBYLIB" => nil
+    }
+    probe_out, probe_err, probe = Open3.capture3(
+      env, "bundle", "exec", "ruby", "-Ilib", "bin/hive", "--version", chdir: REPO_ROOT
+    )
+    unless probe.success?
+      raise "daemon env probe failed (#{probe.exitstatus}): #{probe_err.strip}\n#{probe_out.strip}"
+    end
+
+    @daemon_log = File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "local-mode-daemon.log")
+    @daemon_pid = Process.spawn(
+      env, "bundle", "exec", "ruby", "-Ilib", "bin/hive", "daemon", "start", "--foreground",
+      chdir: REPO_ROOT, out: @daemon_log, err: @daemon_log
+    )
+  end
+
+  def wait_for_task_to_leave_inbox!(slug, timeout: 60)
+    stages = File.join(ENV.fetch("HIVE_TEST_HOME_ROOT"), "repos", @project,
+                       ".hive-state", "stages")
+    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + timeout
+    loop do
+      folders = Dir[File.join(stages, "*", slug)]
+      return if folders.any? && folders.none? { |path| path.include?("/1-inbox/") }
+
+      if Process.clock_gettime(Process::CLOCK_MONOTONIC) > deadline
+        daemon_output = File.exist?(@daemon_log) ? File.read(@daemon_log) : "(no daemon log)"
+        raise "daemon did not dispatch #{slug}:\n#{daemon_output}"
+      end
+      sleep 0.2
+    end
+  end
+end
