new file mode 100644
index 00000000..81e645d8
--- /dev/null
+++ b/test/unit/commands/setup_test.rb
@@ -0,0 +1,211 @@
+require "test_helper"
+require "json"
+require "stringio"
+require "hive/commands/setup"
+
+class SetupCommandTest < Minitest::Test
+  Row = Struct.new(:component, :status, :message, :remediation, :blocking_value, keyword_init: true) do
+    def blocking? = blocking_value
+    def to_h
+      { "component" => component, "status" => status, "message" => message,
+        "remediation" => remediation, "blocking" => blocking? }
+    end
+  end
+
+  FakeInstaller = Struct.new(:events, :name, :result) do
+    def install!
+      events << name
+      result
+    end
+  end
+
+  FakeEnrollment = Struct.new(:events, :result) do
+    def call
+      events << :project
+      result
+    end
+  end
+
+  class Operations
+    attr_reader :events
+
+    def initialize(events, fail_at: nil, manager: true)
+      @events = events
+      @fail_at = fail_at
+      @manager = manager
+    end
+
+    def ensure_daemon(binary_path:)
+      raise Hive::Error, "daemon broke" if @fail_at == :daemon
+      @events << [ :daemon, binary_path ]
+      { "outcome" => "unchanged", "running" => true, "identity_match" => true,
+        "service_installed" => true,
+        "service_enabled" => @manager, "fallback" => !@manager }
+    end
+
+    def ensure_web(binary_path:)
+      raise Hive::Error, "web broke" if @fail_at == :web
+      @events << [ :web, binary_path ]
+      if @manager
+        { "outcome" => "started", "mode" => "managed", "url" => "http://127.0.0.1:4567",
+          "status" => { "state" => "healthy", "http_identity" => "matching" } }
+      else
+        { "outcome" => "foreground", "mode" => "foreground", "url" => "http://127.0.0.1:4567",
+          "status" => { "state" => "manager_unavailable", "http_identity" => "unreachable" } }
+      end
+    end
+
+    def foreground_web
+      @events << :foreground_web
+      { "state" => "healthy", "http_identity" => "matching" }
+    end
+  end
+
+  EnrollmentResult = Struct.new(:outcome, :entry)
+  QmdResult = Struct.new(:status, :path, :messages)
+
+  def green_rows
+    [ Row.new(component: "ruby", status: "present", message: "3.4.2", remediation: nil,
+              blocking_value: false) ]
+  end
+
+  def build_command(rows:, events:, output: StringIO.new, json: true, fail_at: nil, manager: true)
+    runtime = Object.new
+    runtime.define_singleton_method(:install!) { events << :runtime; self }
+    runtime.define_singleton_method(:ready?) { true }
+    Hive::Commands::Setup.new(
+      "/projects/demo", json: json, output: output, error: StringIO.new,
+      dependency_checker: -> { rows },
+      qmd_installer: FakeInstaller.new(events, :qmd, QmdResult.new("installed", "/xdg/qmd/bin/qmd", [])),
+      runtime_installer: runtime,
+      project_enrollment: FakeEnrollment.new(events, EnrollmentResult.new("existing", { "name" => "demo" })),
+      operations: Operations.new(events, fail_at: fail_at, manager: manager),
+      invoked_binary: "/stable/bin/hive", host_os: "linux"
+    )
+  end
+
+  def test_green_setup_runs_mutations_only_after_preflight_in_deterministic_order
+    events = []
+    output = StringIO.new
+    payload = build_command(rows: green_rows, events: events, output: output).call
+
+    assert_equal [ :qmd, :runtime, :project, [ :daemon, "/stable/bin/hive" ], [ :web, "/stable/bin/hive" ] ], events
+    assert payload.fetch("ok")
+    assert_equal "complete", payload.fetch("phase")
+    assert_equal "managed", payload.fetch("mode")
+    assert_equal "http://127.0.0.1:4567", payload.fetch("url")
+    assert_equal payload, JSON.parse(output.string)
+  end
+
+  def test_external_preflight_failure_emits_exact_repairs_and_never_mutates
+    events = []
+    output = StringIO.new
+    row = Row.new(component: "gh-auth", status: "unauthenticated", message: "not logged in",
+                  remediation: "gh auth login", blocking_value: true)
+    command = build_command(rows: [ row ], events: events, output: output)
+
+    error = assert_raises(Hive::SetupPreflightFailed) { command.call }
+
+    assert_match(/no changes made/, error.message)
+    assert_empty events
+    payload = JSON.parse(output.string)
+    refute payload.fetch("ok")
+    assert_equal "preflight", payload.fetch("phase")
+    assert_equal "gh auth login", payload.fetch("checks").first.fetch("remediation")
+  end
+
+  def test_partial_failure_names_completed_and_pending_repairs_for_safe_retry
+    events = []
+    output = StringIO.new
+    command = build_command(rows: green_rows, events: events, output: output, fail_at: :daemon)
+
+    assert_raises(Hive::SetupFailed) { command.call }
+
+    payload = JSON.parse(output.string)
+    assert_equal %w[qmd web-runtime project], payload.fetch("completed")
+    assert_equal %w[daemon web], payload.fetch("pending")
+    assert_match(/daemon broke/, payload.fetch("message"))
+  end
+
+  def test_linux_without_systemd_user_keeps_breadcrumb_and_hands_off_to_foreground_web
+    events = []
+    output = StringIO.new
+    payload = build_command(rows: green_rows, events: events, output: output, json: false, manager: false).call
+
+    assert_includes events, :foreground_web
+    assert_equal "foreground", payload.fetch("mode")
+    assert payload.fetch("checks").any? { |row| row["component"] == "daemon" && row["status"] == "healthy" }
+    assert payload.fetch("checks").any? { |row| row["component"] == "web" && row["status"] == "healthy" }
+  end
+
+  def test_detached_daemon_fallback_is_idempotent_when_daemon_is_already_running
+    outcome = Hive::Commands::ServiceInstaller::Outcome.new(:autostart_unavailable)
+    installer = Object.new
+    installer.define_singleton_method(:install!) { |autostart:, force:| outcome }
+    installer.define_singleton_method(:target_path) { "/tmp/hive-daemon.service" }
+    installer.define_singleton_method(:messages) { [] }
+    starts = []
+    operations = Hive::Commands::Setup::Operations.new(
+      runtime_installer: nil,
+      host_os: "linux",
+      daemon_installer_factory: ->(_binary) { installer },
+      daemon_runner: ->(argv) { starts << argv; true },
+      daemon_status_probe: -> { { "running" => true, "identity_match" => true, "pid" => 42 } },
+      manager_probe: -> { false }
+    )
+
+    result = operations.ensure_daemon(binary_path: "/stable/bin/hive")
+
+    assert result.fetch("running")
+    assert result.fetch("fallback")
+    assert_empty starts, "repeat setup must not start a second detached daemon"
+  end
+
+  def test_daemon_setup_refuses_running_but_drifted_runtime_identity
+    outcome = Hive::Commands::ServiceInstaller::Outcome.new(:unchanged)
+    installer = Object.new
+    installer.define_singleton_method(:install!) { |autostart:, force:| outcome }
+    installer.define_singleton_method(:target_path) { "/tmp/hive-daemon.service" }
+    installer.define_singleton_method(:messages) { [] }
+    installer.define_singleton_method(:restart!) { true }
+    times = [ 0, 16 ]
+    operations = Hive::Commands::Setup::Operations.new(
+      runtime_installer: nil,
+      host_os: "linux",
+      daemon_installer_factory: ->(_binary) { installer },
+      daemon_status_probe: -> { { "running" => true, "identity_match" => false, "pid" => 42 } },
+      manager_probe: -> { true }, sleeper: ->(_seconds) { }, clock: -> { times.shift || 16 }
+    )
+
+    error = assert_raises(Hive::SetupFailed) do
+      operations.ensure_daemon(binary_path: "/stable/bin/hive")
+    end
+
+    assert_match(/matching runtime identity/, error.message)
+  end
+
+  def test_no_manager_repeat_setup_reuses_matching_deep_healthy_web
+    outcome = Hive::Commands::ServiceInstaller::Outcome.new(:unchanged)
+    installer = Object.new
+    installer.define_singleton_method(:install!) { |autostart:, force:| outcome }
+    installer.define_singleton_method(:target_path) { "/tmp/hive-web.service" }
+    installer.define_singleton_method(:messages) { [] }
+    starts = 0
+    manager = Object.new
+    manager.define_singleton_method(:status) do |_url|
+      { "state" => "healthy", "manager_state" => "unavailable",
+        "http_identity" => "matching" }
+    end
+    manager.define_singleton_method(:start) { |_url| starts += 1 }
+    operations = Hive::Commands::Setup::Operations.new(
+      runtime_installer: nil, host_os: "linux", web_manager: manager,
+      web_installer_factory: ->(*) { installer }, manager_probe: -> { false }
+    )
+
+    result = operations.ensure_web(binary_path: "/stable/bin/hive")
+
+    assert_equal "foreground", result.fetch("mode")
+    assert_equal false, result.fetch("handoff_required")
+    assert_equal 0, starts
+  end
+end
