new file mode 100644
index 00000000..cb80c4e2
--- /dev/null
+++ b/lib/hive/web/auth_policy.rb
@@ -0,0 +1,43 @@
+require "ipaddr"
+
+module Hive
+  module Web
+    # Resolves the single local-web authentication policy shared by foreground
+    # startup, managed-service installation, and the setup orchestrator.
+    module AuthPolicy
+      module_function
+
+      def resolve(bind:, configured_mode:, github_auth: false, unsafe_no_auth: false,
+                  local_auth: false)
+        if [ github_auth, unsafe_no_auth, local_auth ].count(true) > 1
+          raise Hive::InvalidTaskPath,
+                "hive web: choose only one of --github-auth, --unsafe-no-auth, or --local-auth"
+        end
+        return "github" if github_auth
+        return "unsafe" if unsafe_no_auth
+        if local_auth
+          unless literal_loopback?(bind)
+            raise Hive::ConfigError,
+                  "hive web: --local-auth is restricted to a literal loopback bind (127.0.0.0/8 or ::1)"
+          end
+          return "local"
+        end
+        return configured_mode unless configured_mode == "auto"
+        return "local" if literal_loopback?(bind)
+
+        raise Hive::ConfigError,
+              "hive web: web.auth=auto trusts only a literal loopback bind " \
+              "(127.0.0.0/8 or ::1); #{bind.inspect} requires --github-auth " \
+              "or the explicit --unsafe-no-auth override"
+      end
+
+      def literal_loopback?(bind)
+        return false if bind.to_s.include?("/")
+
+        IPAddr.new(bind.to_s).loopback?
+      rescue IPAddr::InvalidAddressError
+        false
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/daemon_control.rb b/lib/hive/web/daemon_control.rb
new file mode 100644
index 00000000..6079df83
--- /dev/null
+++ b/lib/hive/web/daemon_control.rb
@@ -0,0 +1,116 @@
+require "shellwords"
+require "hive"
+require "hive/daemon/runtime_status"
+require "hive/invoked_binary"
+
+module Hive
+  module Web
+    # Fixed, per-user daemon repair. The target wrapper and service identity
+    # are derived internally; the public action accepts no command/path/unit
+    # arguments and invokes the installer in process without a shell.
+    class DaemonControl
+      DEFAULT_TIMEOUT = 15
+
+      def initialize(env: ENV, installer_factory: nil, status_probe: nil,
+                     sleeper: ->(seconds) { sleep seconds },
+                     clock: -> { Process.clock_gettime(Process::CLOCK_MONOTONIC) },
+                     timeout: DEFAULT_TIMEOUT)
+        @env = env
+        @installer_factory = installer_factory || method(:build_installer)
+        @status_probe = status_probe
+        @sleeper = sleeper
+        @clock = clock
+        @timeout = timeout
+      end
+
+      def repair
+        binary = invoked_binary!
+        before = status_snapshot(binary)
+        installer = @installer_factory.call(binary)
+        outcome = installer.install!(autostart: true, force: true)
+        unless outcome.success? && !%i[autostart_unavailable unsupported].include?(outcome.kind)
+          detail = Array(installer.messages).join("; ")
+          detail = outcome.wire_outcome if detail.empty?
+          fail_repair!("daemon service repair failed: #{detail}", binary)
+        end
+
+        restarted = outcome.restarted
+        if before["running"] == true && before["identity_match"] != true && !outcome.restarted
+          unless installer.respond_to?(:restart!) && installer.restart!
+            detail = Array(installer.messages).join("; ")
+            fail_repair!("daemon unit was repaired but the drifted process could not restart: #{detail}", binary)
+          end
+          restarted = true
+        end
+
+        status = wait_for_match(binary)
+        unless matching?(status)
+          fail_repair!("daemon repair did not reach matching identity within #{@timeout}s", binary)
+        end
+
+        {
+          "outcome" => outcome.wire_outcome,
+          "unit_path" => installer.target_path,
+          "backup_path" => outcome.backup_path,
+          "restarted" => restarted,
+          "messages" => Array(installer.messages).dup,
+          "status" => status
+        }
+      rescue Hive::DaemonRepairFailed
+        raise
+      rescue StandardError => e
+        binary ||= Hive::InvokedBinary.path(program_name: "hive", env: @env)
+        fail_repair!("daemon repair failed: #{e.class}: #{e.message}", binary)
+      end
+
+      private
+
+      def invoked_binary!
+        binary = Hive::InvokedBinary.path(program_name: "hive", env: @env)
+        return binary if binary
+
+        fail_repair!(
+          "daemon repair requires the allowlisted stable wrapper exported in HIVE_INVOKED_BIN",
+          nil
+        )
+      end
+
+      def build_installer(binary)
+        require "hive/commands/daemon/service_installer"
+        Hive::Commands::Daemon::ServiceInstaller.new(binary_path: binary)
+      end
+
+      def wait_for_match(binary)
+        deadline = @clock.call + @timeout
+        loop do
+          status = status_snapshot(binary)
+          return status if matching?(status)
+          break if @clock.call >= deadline
+
+          @sleeper.call(0.1)
+        end
+        status_snapshot(binary)
+      end
+
+      def status_snapshot(binary)
+        status = if @status_probe
+          @status_probe.call
+        else
+          Hive::Daemon::RuntimeStatus.new(expected_binary: binary).call
+        end
+        status = status.to_h if !status.is_a?(Hash) && status.respond_to?(:to_h)
+        status.is_a?(Hash) ? status : {}
+      end
+
+      def matching?(status)
+        status["running"] == true && status["identity_match"] == true
+      end
+
+      def fail_repair!(message, binary)
+        command = binary ? Shellwords.escape(binary) : "hive"
+        raise Hive::DaemonRepairFailed,
+              "#{message}. CLI fallback: `#{command} daemon install --force`, then `#{command} daemon status --json`."
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/runtime_installer.rb b/lib/hive/web/runtime_installer.rb
new file mode 100644
index 00000000..67bc42f7
--- /dev/null
+++ b/lib/hive/web/runtime_installer.rb
@@ -0,0 +1,234 @@
+require "digest"
+require "fileutils"
+require "json"
+require "tempfile"
+require "timeout"
+require "hive/bounded_command"
+require "hive/paths"
+
+module Hive
+  module Web
+    # Provisions the separately bundled Rails dependencies and generated
+    # assets without ever writing into the installed gem. Source checkouts and
+    # the Docker image use their already-provisioned bundle; installed gems use
+    # a version/lock-digest keyed XDG runtime and an atomic readiness manifest.
+    class RuntimeInstaller
+      MANIFEST_SCHEMA = "hive-web-runtime.v1".freeze
+      COMMAND_TIMEOUT_SECONDS = 900
+
+      class InstallError < Hive::Error
+        attr_reader :step
+
+        def initialize(step, message)
+          @step = step
+          super("hive web runtime #{step} failed: #{message}")
+        end
+      end
+
+      attr_reader :app_dir, :manifest_path, :public_dir
+
+      def self.discover(checkout_root: File.expand_path("../../..", __dir__), gem_root: nil)
+        override = ENV["HIVEBOX_WEB_APP_DIR"]
+        return new(app_dir: override, managed: false) if rails_app?(override)
+
+        checkout_app = File.join(checkout_root, "web")
+        if File.exist?(File.join(checkout_root, ".git")) && rails_app?(checkout_app)
+          return new(app_dir: checkout_app, managed: false)
+        end
+
+        gem_root ||= Gem.loaded_specs["hive-cli"]&.full_gem_path || checkout_root
+        packaged_app = File.join(gem_root, "web")
+        return new(app_dir: packaged_app, managed: true) if rails_app?(packaged_app)
+
+        nil
+      end
+
+      def self.rails_app?(dir)
+        dir && File.file?(File.join(dir, "config", "application.rb"))
+      end
+      private_class_method :rails_app?
+
+      def initialize(app_dir:, version: Hive::VERSION, managed: true, runner: nil,
+                     command_timeout: COMMAND_TIMEOUT_SECONDS)
+        @app_dir = File.expand_path(app_dir)
+        @version = version.to_s
+        @managed = managed
+        @command_timeout = command_timeout
+        @runner = runner || lambda do |env, argv, chdir:|
+          Hive::BoundedCommand.run(
+            *argv, env: env, chdir: chdir, timeout: @command_timeout
+          )
+        end
+        @manifest_path = File.join(Hive::Paths.web_runtime_home, "manifest.json")
+        refresh_paths!
+      end
+
+      def managed?
+        @managed
+      end
+
+      def ready?
+        return true unless managed?
+        return false unless File.file?(manifest_path)
+
+        manifest = JSON.parse(File.read(manifest_path))
+        manifest == expected_manifest &&
+          File.directory?(bundle_path) && File.directory?(public_dir)
+      rescue JSON::ParserError, Errno::ENOENT, Errno::EACCES
+        false
+      end
+
+      def install!
+        return self unless managed?
+
+        refresh_paths!
+        return self if ready?
+
+        # An incomplete/corrupt same-key runtime must not regain ready status
+        # merely because mkdir recreated its missing directories. Both paths
+        # are derived Hive-owned artifacts; workflow state and databases live
+        # elsewhere under state_home and are never removed here.
+        FileUtils.rm_f(manifest_path)
+        FileUtils.rm_rf(@runtime_dir)
+        prepare_directories!
+        copy_public_files!
+        run_step(:bundle, [ bundle_executable, "install", "--jobs", "4", "--retry", "3" ])
+        run_step(:assets, [ "bin/rails", "assets:precompile" ])
+        run_step(:database, [ "bin/rails", "db:prepare" ])
+        publish_manifest!
+        self
+      rescue InstallError
+        raise
+      rescue SystemCallError => e
+        raise InstallError.new(:filesystem, "#{e.class}: #{e.message}; check XDG directory permissions and free disk space")
+      end
+
+      def environment
+        env = {
+          "BUNDLE_GEMFILE" => File.join(app_dir, "Gemfile"),
+          "BOOTSNAP_CACHE_DIR" => bootsnap_cache_dir,
+          "HIVEBOX_STORAGE_DIR" => Hive::Paths.web_storage_home,
+          "HIVEBOX_TMP_DIR" => File.join(Hive::Paths.web_state_home, "tmp"),
+          "HIVEBOX_LOG_PATH" => File.join(Hive::Paths.web_state_home, "log", "production.log"),
+          "PIDFILE" => File.join(Hive::Paths.web_state_home, "pids", "server.pid")
+        }
+        return env unless managed?
+
+        env.merge(
+          "BUNDLE_APP_CONFIG" => bundle_app_config,
+          "BUNDLE_PATH" => bundle_path,
+          "BUNDLE_USER_HOME" => bundler_user_home,
+          "BUNDLE_WITHOUT" => "development:test",
+          "BUNDLE_DEPLOYMENT" => "true",
+          "HIVEBOX_PUBLIC_DIR" => public_dir
+        )
+      end
+
+      def prepare_writable_directories!
+        paths = environment.values_at(
+          "BOOTSNAP_CACHE_DIR", "HIVEBOX_STORAGE_DIR", "HIVEBOX_TMP_DIR"
+        )
+        paths << File.dirname(environment.fetch("HIVEBOX_LOG_PATH"))
+        paths << File.dirname(environment.fetch("PIDFILE"))
+        paths << public_dir if managed?
+        FileUtils.mkdir_p(paths)
+      rescue SystemCallError => e
+        raise InstallError.new(:filesystem, "#{e.class}: #{e.message}; check XDG directory permissions and free disk space")
+      end
+
+      private
+
+      def refresh_paths!
+        digest = managed? ? lock_digest : ::Digest::SHA256.hexdigest(app_dir)
+        @runtime_key = "#{safe_version}-#{digest[0, 16]}"
+        @runtime_dir = File.join(Hive::Paths.web_runtime_home, "versions", @runtime_key)
+        @bundle_app_config = File.join(@runtime_dir, "bundle-config")
+        @bundle_path = File.join(@runtime_dir, "bundle")
+        @public_dir = File.join(@runtime_dir, "public")
+        @bootsnap_cache_dir = File.join(Hive::Paths.web_runtime_cache_home, @runtime_key, "bootsnap")
+        @bundler_user_home = File.join(Hive::Paths.web_runtime_cache_home, @runtime_key, "bundler")
+      end
+
+      def safe_version
+        @version.gsub(/[^0-9A-Za-z._-]/, "-")
+      end
+
+      def lock_digest
+        ::Digest::SHA256.file(File.join(app_dir, "Gemfile.lock")).hexdigest
+      rescue SystemCallError => e
+        raise InstallError.new(:discovery, "cannot read #{File.join(app_dir, "Gemfile.lock")}: #{e.message}")
+      end
+
+      def bundle_executable
+        value = ENV["BUNDLE_BIN"].to_s
+        value.empty? ? "bundle" : value
+      end
+
+      def bundle_app_config = @bundle_app_config
+      def bundle_path = @bundle_path
+      def bootsnap_cache_dir = @bootsnap_cache_dir
+      def bundler_user_home = @bundler_user_home
+
+      def prepare_directories!
+        FileUtils.mkdir_p([ bundle_app_config, bundle_path, public_dir, bootsnap_cache_dir, bundler_user_home ])
+        prepare_writable_directories!
+      end
+
+      def copy_public_files!
+        source = File.join(app_dir, "public")
+        return unless File.directory?(source)
+
+        entries = Dir.children(source).map { |entry| File.join(source, entry) }
+        FileUtils.cp_r(entries, public_dir, preserve: true) unless entries.empty?
+      end
+
+      def run_step(step, argv)
+        env = environment.merge(
+          "RAILS_ENV" => "production",
+          "SECRET_KEY_BASE" => "hive-assets-build"
+        )
+        return if @runner.call(env, argv, chdir: app_dir)
+
+        repair = case step
+        when :bundle then "ensure Ruby 3.4 and Bundler are available, then run `hive setup` again"
+        when :assets then "asset compilation did not complete; run `hive setup` again"
+        else "database preparation did not complete; check #{Hive::Paths.web_storage_home} is writable"
+        end
+        raise InstallError.new(step, "#{argv.join(" ")} exited unsuccessfully; #{repair}")
+      rescue InstallError
+        raise
+      rescue Timeout::Error
+        raise InstallError.new(
+          step,
+          "#{argv.join(' ')} timed out after #{@command_timeout}s; the child process group was terminated; " \
+          "run `hive setup` again after checking network, disk, and database locks"
+        )
+      rescue SystemCallError => e
+        raise InstallError.new(step, "could not execute #{argv.first}: #{e.message}")
+      end
+
+      def expected_manifest
+        {
+          "schema" => MANIFEST_SCHEMA,
+          "hive_version" => @version,
+          "lock_sha256" => lock_digest,
+          "runtime_key" => @runtime_key
+        }
+      end
+
+      def publish_manifest!
+        FileUtils.mkdir_p(File.dirname(manifest_path))
+        tmp = Tempfile.new([ ".manifest", ".tmp" ], File.dirname(manifest_path))
+        tmp.write("#{JSON.pretty_generate(expected_manifest)}\n")
+        tmp.flush
+        tmp.fsync
+        tmp.chmod(0o600)
+        tmp.close
+        File.rename(tmp.path, manifest_path)
+      ensure
+        tmp&.close
+        tmp&.unlink if tmp && File.exist?(tmp.path)
+      end
+    end
+  end
+end
