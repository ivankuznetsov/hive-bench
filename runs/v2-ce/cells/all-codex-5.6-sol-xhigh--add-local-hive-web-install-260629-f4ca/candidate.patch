index 00000000..9c05d15d
--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,462 @@
+require "json"
+require "rbconfig"
+require "stringio"
+require "hive"
+require "hive/config"
+require "hive/invoked_binary"
+require "hive/commands/daemon"
+require "hive/commands/daemon/service_installer"
+require "hive/commands/web"
+require "hive/commands/web/service_installer"
+require "hive/commands/web/service_manager"
+require "hive/setup/dependency_checker"
+require "hive/setup/project_enrollment"
+require "hive/setup/qmd_installer"
+require "hive/web/runtime_installer"
+require "hive/web/auth_policy"
+require "hive/bounded_command"
+
+module Hive
+  module Commands
+    # Two-phase local runtime orchestration. Phase one is strictly read-only;
+    # phase two owns only XDG runtime artifacts, project enrollment, and the
+    # two separate per-user services.
+    class Setup
+      STEPS = %w[qmd web-runtime project daemon web].freeze
+
+      # Real service boundary used by the command. Unit tests inject this
+      # object wholesale, keeping service managers, forks, HTTP, and ports out
+      # of the test process.
+      class Operations
+        DAEMON_START_TIMEOUT = 15
+
+        def initialize(runtime_installer:, host_os: RbConfig::CONFIG["host_os"],
+                       daemon_installer_factory: nil, web_installer_factory: nil,
+                       web_manager: nil, daemon_runner: nil,
+                       daemon_status_probe: nil, manager_probe: nil,
+                       sleeper: nil, clock: nil)
+          @runtime_installer = runtime_installer
+          @host_os = host_os.to_s
+          @daemon_installer_factory = daemon_installer_factory || lambda do |binary_path|
+            Hive::Commands::Daemon::ServiceInstaller.new(
+              binary_path: binary_path, host_os: @host_os,
+              systemctl_available: manager_available?
+            )
+          end
+          @web_installer_factory = web_installer_factory
+          @web_manager = web_manager
+          @daemon_runner = daemon_runner || ->(argv) { system(*argv, out: File::NULL, err: File::NULL) }
+          @daemon_status_probe = daemon_status_probe || method(:daemon_status_payload)
+          @manager_probe = manager_probe || method(:probe_manager)
+          @sleeper = sleeper || ->(seconds) { sleep seconds }
+          @clock = clock || -> { Process.clock_gettime(Process::CLOCK_MONOTONIC) }
+        end
+
+        def ensure_daemon(binary_path:)
+          installer = @daemon_installer_factory.call(binary_path)
+          outcome = installer.install!(autostart: true, force: true)
+          unless outcome.success?
+            raise Hive::SetupFailed,
+                  "daemon unit repair failed (#{outcome.wire_outcome}): #{installer.messages.join('; ')}"
+          end
+
+          fallback = outcome.kind == :autostart_unavailable
+          status = @daemon_status_probe.call
+          if fallback
+            # Repeat setup must not treat an already-running detached daemon
+            # as a failed start. Probe first; only launch when no verified PID
+            # is currently live.
+            unless matching_daemon?(status)
+              if status && status["running"]
+                stopped = @daemon_runner.call([ binary_path, "daemon", "stop" ])
+                raise Hive::SetupFailed, "detached daemon fallback failed to stop drifted runtime" unless stopped
+              end
+              ok = @daemon_runner.call([ binary_path, "daemon", "start", "--detach" ])
+              raise Hive::SetupFailed, "detached daemon fallback failed to start" unless ok
+            end
+          elsif status && status["running"] && status["identity_match"] != true && !outcome.restarted
+            unless installer.respond_to?(:restart!) && installer.restart!
+              raise Hive::SetupFailed,
+                    "daemon unit is current but the running identity is drifted and restart failed"
+            end
+          end
+
+          status = wait_for_daemon unless matching_daemon?(status)
+          unless matching_daemon?(status)
+            raise Hive::SetupFailed,
+                  "daemon did not publish a live verified PID with matching runtime identity " \
+                  "within #{DAEMON_START_TIMEOUT}s"
+          end
+
+          {
+            "outcome" => outcome.wire_outcome,
+            "running" => true,
+            "pid" => status["pid"],
+            "service_installed" => status["service_installed"],
+            "service_enabled" => status["service_enabled"],
+            "unit_path" => status["unit_path"] || installer.target_path,
+            "backup_path" => outcome.backup_path,
+            "fallback" => fallback,
+            "messages" => installer.messages.dup
+          }
+        end
+
+        def ensure_web(binary_path:)
+          cfg = Hive::Config.load_global_web
+          bind = cfg.fetch("bind")
+          port = cfg.fetch("port").to_i
+          auth_mode = Hive::Web::AuthPolicy.resolve(
+            bind: bind, configured_mode: cfg.fetch("auth")
+          )
+          installer = if @web_installer_factory
+            @web_installer_factory.call(binary_path, bind, port, auth_mode)
+          else
+            Hive::Commands::Web::ServiceInstaller.new(
+              binary_path: binary_path, host_os: @host_os,
+              bind: bind, port: port, auth_mode: auth_mode
+            )
+          end
+          outcome = installer.install!(autostart: false, force: true)
+          unless outcome.success?
+            raise Hive::SetupFailed,
+                  "web unit repair failed (#{outcome.wire_outcome}): #{installer.messages.join('; ')}"
+          end
+
+          manager = @web_manager || Hive::Commands::Web::ServiceManager.new(
+            host_os: @host_os,
+            expected_auth_mode: auth_mode,
+            deep_health: true,
+            runtime_probe: -> { !!@runtime_installer && @runtime_installer.ready? },
+            unit_path: installer.target_path,
+            manager_available: manager_available?
+          )
+          url = web_url(bind, port)
+          before = manager.status(url)
+          if before["manager_state"] == "unavailable"
+            already_running = before["http_identity"] == "matching" && before["state"] == "healthy"
+            return {
+              "outcome" => "foreground", "mode" => "foreground", "url" => url,
+              "handoff_required" => !already_running,
+              "unit_path" => installer.target_path, "backup_path" => outcome.backup_path,
+              "status" => before,
+              "messages" => installer.messages.dup +
+                [
+                  already_running ?
+                    "systemd-user is unavailable; an existing matching Hive web process remains in use" :
+                    "systemd-user is unavailable; the web unit remains as a breadcrumb " \
+                    "and bare `hive web` will run in the foreground"
+                ]
+            }
+          end
+
+          started = manager.start(url)
+          status = started.fetch("status") { manager.status(url) }
+          unless status["state"] == "healthy" && status["http_identity"] == "matching"
+            raise Hive::SetupFailed,
+                  "web service started but identified health is #{status['state']}/#{status['http_identity']}"
+          end
+
+          {
+            "outcome" => started.fetch("outcome"), "mode" => "managed", "url" => url,
+            "unit_path" => installer.target_path, "backup_path" => outcome.backup_path,
+            "status" => status, "messages" => installer.messages.dup
+          }
+        end
+
+        def foreground_web
+          Hive::Commands::Web.new.call
+        end
+
+        private
+
+        def wait_for_daemon
+          deadline = @clock.call + DAEMON_START_TIMEOUT
+          loop do
+            payload = @daemon_status_probe.call
+            return payload if matching_daemon?(payload)
+            break if @clock.call >= deadline
+
+            @sleeper.call(0.1)
+          end
+          @daemon_status_probe.call || { "running" => false }
+        end
+
+        def matching_daemon?(payload)
+          payload && payload["running"] == true && payload["identity_match"] == true
+        end
+
+        def daemon_status_payload
+          output = StringIO.new
+          command = Hive::Commands::Daemon.new("status", json: true, output: output, error: StringIO.new)
+          begin
+            command.call
+          rescue Hive::Error
+            # status intentionally raises when not running, after publishing
+            # its JSON payload. The payload is still the useful probe result.
+          end
+          JSON.parse(output.string)
+        rescue JSON::ParserError
+          { "running" => false }
+        end
+
+        def manager_available?
+          return @manager_available unless @manager_available.nil?
+
+          @manager_available = !!@manager_probe.call
+        rescue StandardError
+          @manager_available = false
+        end
+
+        def probe_manager
+          return true if @host_os.match?(/darwin/i)
+          return false unless @host_os.match?(/linux/i)
+
+          Hive::BoundedCommand.success?(
+            "systemctl", "--user", "show-environment", timeout: 5
+          )
+        rescue Errno::ENOENT
+          false
+        end
+
+        def web_url(bind, port)
+          host = bind.to_s.include?(":") ? "[#{bind}]" : bind
+          "http://#{host}:#{port}"
+        end
+      end
+
+      def initialize(project_path = Dir.pwd, json: false, output: $stdout, error: $stderr,
+                     dependency_checker: nil, qmd_installer: nil,
+                     runtime_installer: nil, project_enrollment: nil,
+                     operations: nil, invoked_binary: Hive::InvokedBinary.path,
+                     host_os: RbConfig::CONFIG["host_os"], prompts: nil)
+        @project_path = File.expand_path(project_path)
+        @json = json
+        @output = output
+        @error = error
+        @invoked_binary = invoked_binary
+        @host_os = host_os.to_s
+        @runtime_installer = runtime_installer || Hive::Web::RuntimeInstaller.discover
+        @dependency_checker = dependency_checker || Hive::Setup::DependencyChecker.new(
+          invoked_binary: @invoked_binary, host_os: @host_os,
+          runtime_probe: -> { @runtime_installer }
+        )
+        @qmd_installer = qmd_installer || Hive::Setup::QmdInstaller.new
+        enrollment_output = @json ? StringIO.new : @output
+        enrollment_error = @json ? StringIO.new : @error
+        @project_enrollment = project_enrollment || Hive::Setup::ProjectEnrollment.new(
+          @project_path, prompts: prompts, output: enrollment_output, error: enrollment_error
+        )
+        @operations = operations || Operations.new(
+          runtime_installer: @runtime_installer, host_os: @host_os
+        )
+      end
+
+      def call
+        checks = dependency_rows
+        blockers = checks.select { |row| row["blocking"] }
+        unless blockers.empty?
+          message = "external dependency preflight failed; no changes made"
+          payload = failure_payload(
+            phase: "preflight", message: message, checks: checks,
+            completed: [], pending: STEPS
+          )
+          emit(payload)
+          raise Hive::SetupPreflightFailed, "hive setup: #{message}"
+        end
+
+        completed = []
+        begin
+          qmd = @qmd_installer.install!
+          completed << "qmd"
+          checks << setup_row(
+            "qmd-provision", qmd.status,
+            "Hive-managed qmd is available at #{qmd.path}" + messages_suffix(qmd.messages)
+          )
+
+          raise Hive::SetupFailed, "packaged Rails runtime could not be discovered" unless @runtime_installer
+
+          @runtime_installer.install!
+          unless @runtime_installer.ready?
+            raise Hive::SetupFailed, "Rails runtime provisioning returned without a ready manifest"
+          end
+          completed << "web-runtime"
+          checks << setup_row("web-runtime-provision", "healthy", "Rails bundle, assets, and SQLite are ready")
+
+          enrollment = @project_enrollment.call
+          completed << "project"
+          checks << setup_row(
+            "project-enrollment", "enrolled",
+            "#{enrollment.entry.fetch('name')} is #{enrollment.outcome} and daemon-enabled"
+          )
+
+          daemon = @operations.ensure_daemon(binary_path: @invoked_binary)
+          completed << "daemon"
+          daemon_message = "daemon has a verified live PID"
+          daemon_message += "; using detached fallback because systemd-user is unavailable" if daemon["fallback"]
+          checks << setup_row("daemon", "healthy", daemon_message)
+
+          web = @operations.ensure_web(binary_path: @invoked_binary)
+          if web.fetch("mode") == "foreground" && web.fetch("handoff_required", true)
+            if @json
+              raise Hive::SetupFailed,
+                    "systemd-user is unavailable; rerun without --json to hand off to foreground `hive web`"
+            end
+            @error.puts "hive setup: systemd-user unavailable; the web unit was retained, " \
+                        "but web will stop when this foreground command exits"
+            status = @operations.foreground_web
+            unless status && status["state"] == "healthy" && status["http_identity"] == "matching"
+              raise Hive::SetupFailed, "foreground web handoff returned without identified healthy status"
+            end
+            web["status"] = status
+          end
+          completed << "web"
+          checks << setup_row(
+            "web", "healthy",
+            "#{web.fetch('mode')} web is identified and healthy at #{web.fetch('url')}"
+          )
+
+          payload = success_payload(checks: checks, completed: completed, web: web)
+          emit(payload)
+          payload
+        rescue SystemExit => e
+          fail_mutation!(checks, completed, "project initialization aborted (exit #{e.status})")
+        rescue Hive::SetupFailed => e
+          fail_mutation!(checks, completed, e.message)
+        rescue Hive::Error => e
+          fail_mutation!(checks, completed, "#{e.class.name.split('::').last}: #{e.message}")
+        rescue StandardError => e
+          fail_mutation!(checks, completed, "#{e.class}: #{e.message}")
+        end
+      end
+
+      private
+
+      def dependency_rows
+        raw = @dependency_checker.respond_to?(:call) ? @dependency_checker.call : @dependency_checker
+        Array(raw).map { |row| normalize_row(row) }
+      end
+
+      def normalize_row(row)
+        {
+          "component" => value_from(row, :component).to_s,
+          "status" => value_from(row, :status).to_s,
+          "message" => value_from(row, :message).to_s,
+          "remediation" => value_from(row, :remediation),
+          "blocking" => row.respond_to?(:blocking?) ? row.blocking? : !!value_from(row, :blocking)
+        }
+      end
+
+      def value_from(row, key)
+        return row.public_send(key) if row.respond_to?(key)
+        return row[key] if row.respond_to?(:key?) && row.key?(key)
+        return row[key.to_s] if row.respond_to?(:key?) && row.key?(key.to_s)
+
+        nil
+      end
+
+      def setup_row(component, status, message, remediation = nil)
+        {
+          "component" => component, "status" => status, "message" => message,
+          "remediation" => remediation, "blocking" => status == "failed"
+        }
+      end
+
+      def fail_mutation!(checks, completed, message)
+        pending = STEPS.drop(completed.length)
+        failed_component = pending.first || "setup"
+        checks << setup_row(
+          failed_component, "failed", message,
+          "Fix the reported issue and rerun `hive setup #{@project_path}`"
+        )
+        payload = failure_payload(
+          phase: "mutation", message: message, checks: checks,
+          completed: completed, pending: pending
+        )
+        emit(payload)
+        raise Hive::SetupFailed, "hive setup: #{message}"
+      end
+
+      def success_payload(checks:, completed:, web:)
+        {
+          "schema" => "hive-setup",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-setup"),
+          "ok" => true,
+          "phase" => "complete",
+          "platform" => platform,
+          "project_path" => @project_path,
+          "mode" => web.fetch("mode"),
+          "url" => web.fetch("url"),
+          "message" => "local Hive setup is healthy",
+          "checks" => checks,
+          "summary" => summary(checks),
+          "completed" => completed,
+          "pending" => []
+        }
+      end
+
+      def failure_payload(phase:, message:, checks:, completed:, pending:)
+        {
+          "schema" => "hive-setup",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-setup"),
+          "ok" => false,
+          "phase" => phase,
+          "platform" => platform,
+          "project_path" => @project_path,
+          "mode" => nil,
+          "url" => nil,
+          "message" => message,
+          "checks" => checks,
+          "summary" => summary(checks),
+          "completed" => completed,
+          "pending" => pending
+        }
+      end
+
+      def summary(checks)
+        checks.each_with_object(Hash.new(0)) { |row, counts| counts[row.fetch("status")] += 1 }.to_h
+      end
+
+      def messages_suffix(messages)
+        values = Array(messages)
+        values.empty? ? "" : "; #{values.join('; ')}"
+      end
+
+      def platform
+        return "macos" if @host_os.match?(/darwin/i)
+        return "linux" if @host_os.match?(/linux/i)
+
+        "unsupported"
+      end
+
+      def emit(payload)
+        if @json
+          @output.puts JSON.generate(payload)
+        else
+          render_human(payload)
+        end
+      rescue Errno::EPIPE
+        nil
+      end
+
+      def render_human(payload)
+        @output.puts "hive setup: #{payload.fetch('message')}"
+        payload.fetch("checks").each do |row|
+          marker = %w[present installed unchanged enrolled healthy].include?(row.fetch("status")) ? "✓" :
+            (row.fetch("status") == "repairable" ? "→" : "✗")
+          @output.puts format(
+            "  %s %-22s %-18s %s",
+            marker, row.fetch("component"), row.fetch("status"), row.fetch("message")
+          )
+          @output.puts "      fix: #{row['remediation']}" if row["remediation"]
+        end
+        unless payload.fetch("completed").empty?
+          @output.puts "  completed: #{payload.fetch('completed').join(', ')}"
+        end
+        unless payload.fetch("pending").empty?
+          @output.puts "  pending: #{payload.fetch('pending').join(', ')}"
+        end
+        @output.puts "  URL: #{payload['url']}" if payload["url"]
+      end
+    end
+  end
+end
