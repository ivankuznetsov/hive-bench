+<% content_for :title, "System · hivebox" %>
+
+<div class="system-heading">
+  <div>
+    <h1>System</h1>
+    <p class="muted">Runtime identity and per-user service health.</p>
+  </div>
+</div>
+
+<div class="system-grid">
+  <section class="card system-card" aria-labelledby="daemon-heading">
+    <div class="system-card-heading">
+      <h2 id="daemon-heading">Daemon</h2>
+      <span class="system-state system-state-<%= @daemon['identity_state'] %>"
+            data-daemon-identity><%= @daemon["identity_state"] %></span>
+    </div>
+
+    <dl class="system-facts">
+      <div><dt>Process</dt><dd><%= @daemon["running"] ? "running" : "stopped" %></dd></div>
+      <div><dt>PID</dt><dd><%= system_value(@daemon["pid"]) %></dd></div>
+      <div><dt>PID state</dt><dd><%= @daemon["pid_state"] %></dd></div>
+      <div><dt>Expected version</dt><dd><code><%= @daemon["expected_version"] %></code></dd></div>
+      <div><dt>Running version</dt><dd><code><%= system_value(@daemon["running_version"]) %></code></dd></div>
+      <div><dt>Expected wrapper</dt><dd><code><%= display_path(@daemon["expected_binary"]) %></code></dd></div>
+      <div><dt>Running wrapper</dt><dd><code><%= display_path(@daemon["running_binary"]) %></code></dd></div>
+      <div><dt>Service installed</dt><dd><%= system_value(@daemon["service_installed"]) %></dd></div>
+      <div><dt>Service active</dt><dd><%= system_value(@daemon["service_active"]) %></dd></div>
+      <div><dt>Unit</dt><dd><code><%= display_path(@daemon["unit_path"]) %></code></dd></div>
+    </dl>
+
+    <% unless @daemon["running"] && @daemon["identity_match"] == true %>
+      <div class="system-repair">
+        <p><%= @daemon["repair_hint"] %></p>
+        <%= button_to "Repair and restart daemon", repair_system_daemon_path,
+                      class: "btn", form_class: "inline-form" %>
+      </div>
+    <% end %>
+  </section>
+
+  <section class="card system-card" aria-labelledby="web-heading">
+    <div class="system-card-heading">
+      <h2 id="web-heading">Web</h2>
+      <span class="system-state system-state-matching" data-web-health>running</span>
+    </div>
+
+    <dl class="system-facts">
+      <div><dt>Version</dt><dd><code><%= @web["version"] %></code></dd></div>
+      <div><dt>Authentication</dt><dd><%= @web["auth_mode"] %></dd></div>
+      <div><dt>Invoked wrapper</dt><dd><code><%= display_path(@web["invoked_binary"]) %></code></dd></div>
+    </dl>
+  </section>
+</div>
