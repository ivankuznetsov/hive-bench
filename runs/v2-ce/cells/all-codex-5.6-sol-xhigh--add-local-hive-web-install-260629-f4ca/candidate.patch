diff --git a/lib/hive/daemon/runtime_status.rb b/lib/hive/daemon/runtime_status.rb
new file mode 100644
index 00000000..624a3ba4
--- /dev/null
+++ b/lib/hive/daemon/runtime_status.rb
@@ -0,0 +1,155 @@
+require "shellwords"
+require "hive"
+require "hive/invoked_binary"
+require "hive/paths"
+require "hive/pid_file"
+
+module Hive
+  module Daemon
+    # Side-effect-free snapshot of the resident daemon. PID ownership is
+    # verified before runtime identity is trusted; legacy payloads remain
+    # readable but can only produce an unknown identity.
+    class RuntimeStatus
+      include Hive::PidFile
+
+      def initialize(hive_home: Hive::Paths.state_home,
+                     expected_binary: Hive::InvokedBinary.path,
+                     expected_version: Hive::VERSION,
+                     service_probe: nil,
+                     process_alive: nil,
+                     ownership_probe: nil,
+                     clock: -> { Time.now })
+        @hive_home = hive_home
+        @expected_binary = expected_binary
+        @expected_version = expected_version
+        @service_probe = service_probe || method(:probe_service_state)
+        @process_alive = process_alive
+        @ownership_probe = ownership_probe
+        @clock = clock
+      end
+
+      def pid_file
+        File.join(@hive_home, ".daemon.pid")
+      end
+
+      def call
+        payload, pid_state, running = runtime_payload
+        pid = running ? payload["pid"] : nil
+        running_binary = running ? string_value(payload["binary_path"]) : nil
+        running_version = running ? string_value(payload["version"]) : nil
+        binary_match = match_value(@expected_binary, running_binary)
+        version_match = match_value(@expected_version, running_version)
+        identity_match = identity_match(binary_match, version_match)
+        service = safe_service_state
+
+        {
+          "running" => running,
+          "pid" => pid,
+          "uptime_sec" => running ? uptime_sec : nil,
+          "pid_state" => pid_state,
+          "expected_binary" => @expected_binary,
+          "expected_version" => @expected_version,
+          "running_binary" => running_binary,
+          "running_version" => running_version,
+          "binary_match" => binary_match,
+          "version_match" => version_match,
+          "identity_match" => identity_match,
+          "identity_state" => identity_state(identity_match),
+          "service_installed" => service["service_installed"],
+          "service_enabled" => service["service_enabled"],
+          "service_active" => service["service_active"],
+          "unit_path" => service["unit_path"],
+          "repair_hint" => identity_match == true ? nil : repair_hint
+        }
+      end
+
+      alias to_h call
+
+      def healthy?
+        snapshot = call
+        snapshot["running"] && snapshot["identity_match"] == true
+      end
+
+      private
+
+      def runtime_payload
+        return [ nil, "missing", false ] unless File.exist?(pid_file)
+
+        payload = read_pid_file_payload
+        return [ nil, "corrupt", false ] unless payload.is_a?(Hash)
+
+        pid = payload["pid"]
+        return [ payload, "corrupt", false ] unless pid.is_a?(Integer) && pid.positive?
+        alive = @process_alive ? @process_alive.call(pid) : pid_alive?(pid)
+        return [ payload, "stale", false ] unless alive
+
+        ownership = @ownership_probe ? @ownership_probe.call(payload, pid) : pid_ownership(payload, pid)
+        case ownership
+        when :verified, :legacy then [ payload, "running", true ]
+        when :reused then [ payload, "reused", false ]
+        else [ payload, "unverified", false ]
+        end
+      rescue SystemCallError, IOError
+        [ nil, "unreadable", false ]
+      end
+
+      def uptime_sec
+        [ (@clock.call - File.stat(pid_file).mtime).to_i, 0 ].max
+      rescue SystemCallError, TypeError
+        nil
+      end
+
+      def match_value(expected, running)
+        return nil if expected.nil? || running.nil?
+
+        expected == running
+      end
+
+      def identity_match(binary_match, version_match)
+        return false if binary_match == false || version_match == false
+        return true if binary_match == true && version_match == true
+
+        nil
+      end
+
+      def identity_state(identity_match)
+        return "matching" if identity_match == true
+        return "drifted" if identity_match == false
+
+        "unknown"
+      end
+
+      def string_value(value)
+        value.is_a?(String) && !value.empty? ? value : nil
+      end
+
+      def repair_hint
+        binary = @expected_binary ? Shellwords.escape(@expected_binary) : "hive"
+        "Run `#{binary} daemon install --force` to back up, repair, restart, and verify the daemon."
+      end
+
+      def safe_service_state
+        state = @service_probe.call
+        state = state.to_h if !state.is_a?(Hash) && state.respond_to?(:to_h)
+        state = {} unless state.is_a?(Hash)
+        {
+          "service_installed" => state["service_installed"],
+          "service_enabled" => state["service_enabled"],
+          "service_active" => state["service_active"],
+          "unit_path" => state["unit_path"]
+        }
+      rescue StandardError
+        {
+          "service_installed" => nil, "service_enabled" => nil,
+          "service_active" => nil, "unit_path" => nil
+        }
+      end
+
+      def probe_service_state
+        require "hive/commands/daemon/service_installer"
+        installer = Hive::Commands::Daemon::ServiceInstaller.new
+        installer.service_state.merge("service_active" => installer.service_active?)
+      end
+    end
+  end
+end
