diff --git a/schemas/hive-daemon-status.v2.json b/schemas/hive-daemon-status.v2.json
new file mode 100644
index 00000000..4e25d0f2
--- /dev/null
+++ b/schemas/hive-daemon-status.v2.json
@@ -0,0 +1,100 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://github.com/ivankuznetsov/hive/blob/main/schemas/hive-daemon-status.v2.json",
+  "title": "hive daemon status output (v2)",
+  "description": "Stable contract emitted by `hive daemon status --json`. Adds ownership-verified expected-versus-running wrapper/version identity and read-only active service state. Exit code remains 0 when a verified daemon process is running and 1 otherwise; callers that require current code must also require identity_match=true.",
+  "oneOf": [
+    { "$ref": "#/$defs/SuccessPayload" }
+  ],
+  "$defs": {
+    "SuccessPayload": {
+      "type": "object",
+      "additionalProperties": false,
+      "required": [
+        "schema",
+        "schema_version",
+        "ok",
+        "running",
+        "pid",
+        "uptime_sec",
+        "pid_file",
+        "log_file",
+        "pid_state",
+        "service_installed",
+        "service_enabled",
+        "service_active",
+        "unit_path",
+        "current_version",
+        "update_nudge",
+        "expected_binary",
+        "expected_version",
+        "running_binary",
+        "running_version",
+        "binary_match",
+        "version_match",
+        "identity_match",
+        "identity_state",
+        "repair_hint"
+      ],
+      "properties": {
+        "schema": { "const": "hive-daemon-status" },
+        "schema_version": { "const": 2 },
+        "ok": { "const": true },
+        "running": {
+          "type": "boolean",
+          "description": "Whether a live daemon process still owns the PID payload by PID plus process start time (or is a readable legacy scalar payload)."
+        },
+        "pid": { "type": ["integer", "null"] },
+        "uptime_sec": { "type": ["integer", "null"], "minimum": 0 },
+        "pid_file": { "type": "string" },
+        "log_file": { "type": "string" },
+        "pid_state": {
+          "enum": ["missing", "corrupt", "stale", "reused", "unverified", "unreadable", "running"],
+          "description": "Read-only classification of the PID payload and ownership check."
+        },
+        "service_installed": { "type": ["boolean", "null"] },
+        "service_enabled": { "type": ["boolean", "null"] },
+        "service_active": {
+          "type": ["boolean", "null"],
+          "description": "Whether systemd-user/launchd currently reports hive-daemon active/loaded; null when the probe failed."
+        },
+        "unit_path": { "type": ["string", "null"] },
+        "current_version": {
+          "type": "string",
+          "description": "Compatibility alias for expected_version (the querying CLI version), retained from v1."
+        },
+        "update_nudge": {
+          "type": ["object", "null"],
+          "additionalProperties": false,
+          "required": ["latest", "channel", "command"],
+          "properties": {
+            "latest": { "type": "string" },
+            "channel": { "type": "string" },
+            "command": { "type": "string" }
+          }
+        },
+        "expected_binary": {
+          "type": ["string", "null"],
+          "description": "Allowlisted stable hive/hv wrapper resolved by the querying CLI."
+        },
+        "expected_version": { "type": "string" },
+        "running_binary": {
+          "type": ["string", "null"],
+          "description": "Wrapper recorded by the ownership-verified resident daemon; null for legacy/unknown identity."
+        },
+        "running_version": {
+          "type": ["string", "null"],
+          "description": "Hive version loaded by the ownership-verified resident daemon; null for legacy/unknown identity."
+        },
+        "binary_match": { "type": ["boolean", "null"] },
+        "version_match": { "type": ["boolean", "null"] },
+        "identity_match": {
+          "type": ["boolean", "null"],
+          "description": "True only when both wrapper and version match, false for known drift, null when either side is unknown."
+        },
+        "identity_state": { "enum": ["matching", "drifted", "unknown"] },
+        "repair_hint": { "type": ["string", "null"] }
+      }
+    }
+  }
+}
