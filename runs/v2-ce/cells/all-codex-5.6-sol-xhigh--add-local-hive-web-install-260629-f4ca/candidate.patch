diff --git a/lib/hive/commands/web/managed_config.rb b/lib/hive/commands/web/managed_config.rb
new file mode 100644
index 00000000..42faf891
--- /dev/null
+++ b/lib/hive/commands/web/managed_config.rb
@@ -0,0 +1,73 @@
+require "fileutils"
+require "json"
+require "tempfile"
+require "hive/paths"
+
+module Hive
+  module Commands
+    class Web
+      # Durable source of truth for the endpoint actually rendered into the
+      # managed hive-web unit. Global config may change after installation;
+      # start/status/restart must continue to address and verify the installed
+      # endpoint until the operator deliberately runs `web install` again.
+      class ManagedConfig
+        SCHEMA = "hive-web-managed-config.v1".freeze
+        AUTH_MODES = %w[local github unsafe].freeze
+
+        attr_reader :path
+
+        def initialize(path: Hive::Paths.web_service_config_path)
+          @path = path
+        end
+
+        def write!(bind:, port:, auth_mode:)
+          payload = validate!(
+            "schema" => SCHEMA,
+            "bind" => bind.to_s,
+            "port" => Integer(port),
+            "auth_mode" => auth_mode.to_s
+          )
+          FileUtils.mkdir_p(File.dirname(path))
+          tmp = Tempfile.new([ ".service", ".json" ], File.dirname(path))
+          tmp.write("#{JSON.pretty_generate(payload)}\n")
+          tmp.flush
+          tmp.fsync
+          tmp.chmod(0o600)
+          tmp.close
+          File.rename(tmp.path, path)
+          payload
+        ensure
+          tmp&.close
+          tmp&.unlink if tmp && File.exist?(tmp.path)
+        end
+
+        def load!
+          validate!(JSON.parse(File.read(path)))
+        rescue Errno::ENOENT
+          raise Hive::WebServiceFailed,
+                "hive web: managed service configuration is missing; run `hive web install --force`"
+        rescue JSON::ParserError, TypeError, ArgumentError, SystemCallError, IOError => e
+          raise Hive::WebServiceFailed,
+                "hive web: managed service configuration at #{path} is invalid (#{e.message}); " \
+                "run `hive web install --force`"
+        end
+
+        private
+
+        def validate!(payload)
+          raise ArgumentError, "expected an object" unless payload.is_a?(Hash)
+          raise ArgumentError, "unsupported schema" unless payload["schema"] == SCHEMA
+          raise ArgumentError, "bind is missing" if payload["bind"].to_s.empty?
+
+          port = Integer(payload["port"])
+          raise ArgumentError, "port is outside 1..65535" unless (1..65_535).cover?(port)
+          unless AUTH_MODES.include?(payload["auth_mode"])
+            raise ArgumentError, "auth_mode is not one of #{AUTH_MODES.join(', ')}"
+          end
+
+          payload.merge("port" => port)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/web/service_installer.rb b/lib/hive/commands/web/service_installer.rb
new file mode 100644
index 00000000..7e816043
--- /dev/null
+++ b/lib/hive/commands/web/service_installer.rb
@@ -0,0 +1,93 @@
+require "cgi"
+require "shellwords"
+require "hive/commands/service_installer/base"
+
+module Hive
+  module Commands
+    class Web
+      # Per-user installer for the managed Rails process. The shared base owns
+      # drift detection, timestamped backups, atomic writes, and platform
+      # registration; this subclass owns only web identity and rendering.
+      class ServiceInstaller < Hive::Commands::ServiceInstaller::Base
+        def initialize(bind:, port:, auth_mode:, environment: ENV, **kwargs)
+          @bind = bind.to_s
+          @port = Integer(port)
+          @auth_mode = auth_mode.to_s
+          super(environment: environment, **kwargs)
+        end
+
+        def service_name = "hive-web"
+        def cli_label = "web"
+        def service_noun = "web service"
+        def unit_noun = "web unit"
+
+        def manual_start_command = "bare `hive web`"
+
+        def target_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/local.hive-web.plist")
+          when :linux then File.join(@home, ".config/systemd/user/hive-web.service")
+          end
+        end
+
+        def install!(autostart:, force: false)
+          outcome = super
+          if %i[written upgraded unchanged autostart_unavailable].include?(outcome.kind)
+            require "hive/commands/web/managed_config"
+            Hive::Commands::Web::ManagedConfig.new(path: managed_config_path).write!(
+              bind: @bind, port: @port, auth_mode: @auth_mode
+            )
+          end
+          outcome
+        end
+
+        private
+
+        def managed_config_path
+          File.join(xdg_paths.fetch("XDG_STATE_HOME"), "hive", "web", "service.json")
+        end
+
+        def render_systemd
+          template = File.read(File.expand_path("../../../../examples/systemd/hive-web.service", __dir__))
+          escaped_binary = Shellwords.escape(resolved_binary)
+          argv = [ escaped_binary, "web", "--bind", Shellwords.escape(@bind), "--port", @port.to_s ]
+          argv << auth_flag if auth_flag
+
+          rendered = template
+            .sub(/^ExecStart=.*$/, "ExecStart=#{argv.join(' ')}")
+            .sub(/^Environment=HIVE_BIN=.*$/, "Environment=HIVE_BIN=#{escaped_binary}")
+            .sub(/^Environment=PATH=.*$/, build_path_line)
+          render_systemd_xdg(rendered)
+        end
+
+        def render_launchd
+          template = File.read(File.expand_path("../../../../examples/launchd/hive-web.plist", __dir__))
+          binary = resolved_binary
+          {
+            "__HIVE_BINARY__" => binary,
+            "__HIVE_BINARY_DIR__" => File.dirname(binary),
+            "__HOME__" => @home,
+            "__WEB_BIND__" => @bind,
+            "__WEB_PORT__" => @port.to_s,
+            "__WEB_AUTH_ARGUMENT__" => auth_flag.to_s
+          }.each do |placeholder, value|
+            template = template.gsub(placeholder, CGI.escapeHTML(value))
+          end
+          template = render_launchd_xdg(template)
+          # Local mode has no extra auth argv. Remove the empty placeholder
+          # element instead of leaving an empty argument for Thor to parse.
+          template.gsub!(%r{\s*<string></string>\s*<!-- optional auth -->}, "")
+          template
+        end
+
+        def auth_flag
+          case @auth_mode
+          when "local" then "--local-auth"
+          when "github" then "--github-auth"
+          when "unsafe" then "--unsafe-no-auth"
+          end
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/web/service_manager.rb b/lib/hive/commands/web/service_manager.rb
new file mode 100644
index 00000000..972ec0c8
--- /dev/null
+++ b/lib/hive/commands/web/service_manager.rb
@@ -0,0 +1,364 @@
+require "json"
+require "net/http"
+require "open3"
+require "rbconfig"
+require "socket"
+require "uri"
+
+module Hive
+  module Commands
+    class Web
+      # Runtime lifecycle for the distinct hive-web unit. Every process launch
+      # receives an argv array; tests inject runners and probes without shelling
+      # out or binding a real port.
+      class ServiceManager
+        CommandResult = Struct.new(:success, :stdout, :stderr) do
+          def success? = !!success
+        end
+
+        class HttpProbe
+          def initialize(expected_auth_mode: nil, deep: false)
+            @expected_auth_mode = expected_auth_mode
+            @deep = deep
+          end
+
+          def call(url)
+            uri = URI.join(url.end_with?("/") ? url : "#{url}/", "health")
+            uri.query = "deep=1" if @deep
+            response = Net::HTTP.start(uri.hostname, uri.port, open_timeout: 1, read_timeout: 1) do |http|
+              http.get(uri.request_uri, { "Accept" => "application/json" })
+            end
+            payload = JSON.parse(response.body)
+            identity =
+              if payload["service"] != "hive-web"
+                :wrong
+              elsif payload["version"] != Hive::VERSION
+                :stale
+              elsif @expected_auth_mode && payload["auth_mode"] != @expected_auth_mode
+                :misconfigured
+              elsif !response.is_a?(Net::HTTPSuccess) || payload["ok"] != true
+                :unhealthy
+              else
+                :matching
+              end
+            { reachable: true, identity: identity, status: response.code.to_i, payload: payload }
+          rescue JSON::ParserError
+            { reachable: true, identity: :wrong, status: response&.code&.to_i, payload: nil }
+          rescue IOError, SystemCallError, SocketError, Timeout::Error, URI::InvalidURIError
+            { reachable: false, identity: :unreachable, status: nil, payload: nil }
+          end
+        end
+
+        class TcpProbe
+          def call(url)
+            uri = URI(url)
+            Socket.tcp(uri.hostname, uri.port, connect_timeout: 1) { |socket| socket.close }
+            true
+          rescue IOError, SystemCallError, SocketError, Timeout::Error, URI::InvalidURIError
+            false
+          end
+        end
+
+        def initialize(host_os: RbConfig::CONFIG["host_os"], home: nil, runner: nil,
+                       stream_runner: nil, health_probe: nil, runtime_probe: nil,
+                       port_probe: nil, expected_auth_mode: nil, deep_health: false,
+                       sleeper: nil, clock: nil, start_timeout: 15,
+                       unit_path: nil, unit_exists: nil, manager_available: nil)
+          @host_os = host_os
+          @home = File.expand_path(home || ENV["HOME"] || Dir.home)
+          @runner = runner || method(:capture_command)
+          @stream_runner = stream_runner || (runner ? @runner : method(:stream_command))
+          @health_probe = health_probe || HttpProbe.new(
+            expected_auth_mode: expected_auth_mode, deep: deep_health
+          )
+          @port_probe = port_probe || TcpProbe.new
+          @runtime_probe = runtime_probe || method(:runtime_ready?)
+          @sleeper = sleeper || ->(seconds) { sleep seconds }
+          @clock = clock || -> { Process.clock_gettime(Process::CLOCK_MONOTONIC) }
+          @start_timeout = start_timeout
+          @unit_path = unit_path || default_unit_path
+          @unit_exists = unit_exists || ->(path) { path && File.file?(path) }
+          @manager_available = if manager_available.nil?
+            runner ? true : manager_command_available?
+          else
+            manager_available
+          end
+        end
+
+        def start(url)
+          ensure_runtime_ready!
+          initial = probe(url)
+          return { "outcome" => "unchanged", "status" => status(url, health: initial) } if matching?(initial)
+          raise_stale_responder!(url) if initial[:identity].to_s == "stale"
+          raise_configuration_drift!(url, initial) if configuration_drift?(initial)
+          raise_port_collision!(url) if occupied_by_other?(initial, url)
+
+          ensure_installed!
+          run_action!("start")
+          { "outcome" => "started", "status" => wait_for_health!(url) }
+        end
+
+        def stop
+          ensure_installed!
+          run_action!("stop")
+          { "outcome" => "stopped" }
+        end
+
+        def restart(url)
+          ensure_runtime_ready!
+          ensure_installed!
+          run_action!("restart")
+          { "outcome" => "restarted", "status" => wait_for_health!(url) }
+        end
+
+        def tail
+          ensure_installed!
+          argv = platform == :macos ? [ "tail", "-F", launchd_stdout, launchd_stderr ] :
+            [ "journalctl", "--user", "-u", "hive-web", "-f" ]
+          result = normalize_result(@stream_runner.call(argv))
+          raise Hive::WebServiceFailed, "hive web: log tail failed: #{result.stderr}" unless result.success?
+
+          { "outcome" => "tailed" }
+        rescue Interrupt
+          { "outcome" => "tailed" }
+        end
+
+        def status(url, health: nil)
+          installed = !!@unit_exists.call(@unit_path)
+          manager = manager_state(installed)
+          runtime_ready = !!@runtime_probe.call
+          health ||= probe(url)
+          port_occupied = health[:reachable] || port_occupied?(url)
+          identity = health.fetch(:identity, :unreachable).to_s
+          state =
+            if !installed
+              "uninstalled"
+            elsif manager == "failed"
+              "failed"
+            elsif !runtime_ready || identity == "stale"
+              "stale_runtime"
+            elsif identity == "misconfigured"
+              "configuration_drift"
+            elsif identity == "unhealthy"
+              "unhealthy"
+            elsif identity == "wrong"
+              "wrong_responder"
+            elsif identity == "matching"
+              "healthy"
+            elsif manager == "unavailable"
+              "manager_unavailable"
+            elsif manager == "active"
+              "active_unreachable"
+            else
+              "stopped"
+            end
+          {
+            "state" => state,
+            "platform" => envelope_platform,
+            "unit_path" => @unit_path,
+            "unit_installed" => installed,
+            "manager_state" => manager,
+            "runtime_ready" => runtime_ready,
+            "url" => url,
+            "port_state" => port_occupied ? "listening" : "free",
+            "http_identity" => identity,
+            "http_status" => health[:status],
+            "web_version" => health.dig(:payload, "version"),
+            "auth_mode" => health.dig(:payload, "auth_mode")
+          }
+        end
+
+        private
+
+        def capture_command(argv)
+          stdout, stderr, process = Open3.capture3(*argv)
+          CommandResult.new(process.success?, stdout, stderr)
+        rescue SystemCallError => e
+          CommandResult.new(false, "", "#{e.class}: #{e.message}")
+        end
+
+        def stream_command(argv)
+          CommandResult.new(system(*argv), "", "")
+        rescue SystemCallError => e
+          CommandResult.new(false, "", "#{e.class}: #{e.message}")
+        end
+
+        def normalize_result(value)
+          return value if value.respond_to?(:success?) && value.respond_to?(:stdout)
+          return CommandResult.new(value[0], value[1].to_s, value[2].to_s) if value.is_a?(Array)
+
+          CommandResult.new(!!value, value.is_a?(String) ? value : "", "")
+        end
+
+        def run_action!(action)
+          unless @manager_available
+            raise Hive::WebServiceFailed,
+                  "hive web: no usable user service manager is available; run bare `hive web` in the foreground"
+          end
+
+          if platform == :linux && action == "start"
+            reload = normalize_result(@runner.call(%w[systemctl --user daemon-reload]))
+            unless reload.success?
+              raise Hive::WebServiceFailed,
+                    "hive web: systemd user daemon-reload failed: #{reload.stderr.to_s.strip}"
+            end
+          end
+
+          argv =
+            case platform
+            when :linux
+              action == "start" ? %w[systemctl --user enable --now hive-web] :
+                [ "systemctl", "--user", action, "hive-web" ]
+            when :macos
+              case action
+              when "start" then [ "launchctl", "load", @unit_path ]
+              when "stop" then [ "launchctl", "unload", @unit_path ]
+              when "restart"
+                # An unloaded-but-installed job is still restartable; load is
+                # the authoritative operation and reports a real failure.
+                normalize_result(@runner.call([ "launchctl", "unload", @unit_path ]))
+                [ "launchctl", "load", @unit_path ]
+              end
+            else
+              raise Hive::WebServiceFailed,
+                    "hive web: managed services are unsupported on this platform; run bare `hive web`"
+            end
+          result = normalize_result(@runner.call(argv))
+          return if result.success?
+
+          detail = result.stderr.to_s.strip
+          detail = "service manager returned non-zero" if detail.empty?
+          raise Hive::WebServiceFailed, "hive web: could not #{action} hive-web: #{detail}"
+        end
+
+        def manager_state(installed)
+          return "unsupported" if platform == :unsupported
+          return "uninstalled" unless installed
+          return "unavailable" unless @manager_available
+
+          if platform == :macos
+            result = normalize_result(@runner.call(%w[launchctl list local.hive-web]))
+            return result.success? ? "active" : "inactive"
+          end
+
+          active = normalize_result(@runner.call(%w[systemctl --user is-active hive-web]))
+          return "active" if active.success?
+
+          failed = normalize_result(@runner.call(%w[systemctl --user is-failed hive-web]))
+          failed.success? ? "failed" : "inactive"
+        end
+
+        def wait_for_health!(url)
+          deadline = @clock.call + @start_timeout
+          loop do
+            health = probe(url)
+            return status(url, health: health) if matching?(health)
+            raise_stale_responder!(url) if health[:identity].to_s == "stale"
+            raise_configuration_drift!(url, health) if configuration_drift?(health)
+            raise_port_collision!(url) if occupied_by_other?(health, url)
+            break if @clock.call >= deadline
+
+            @sleeper.call(0.1)
+          end
+          raise Hive::WebServiceFailed,
+                "hive web: managed service did not identify itself at #{url}/health within #{@start_timeout}s; " \
+                "run `hive web tail` and check the unit status"
+        end
+
+        def probe(url)
+          @health_probe.call(url)
+        rescue StandardError
+          { reachable: false, identity: :unreachable, status: nil, payload: nil }
+        end
+
+        def matching?(health) = health[:identity].to_s == "matching"
+
+        def occupied_by_other?(health, url)
+          return true if health[:reachable] && health[:identity].to_s == "wrong"
+
+          !health[:reachable] && port_occupied?(url)
+        end
+
+        def configuration_drift?(health)
+          %w[misconfigured unhealthy].include?(health[:identity].to_s)
+        end
+
+        def port_occupied?(url)
+          !!@port_probe.call(url)
+        rescue StandardError
+          false
+        end
+
+        def raise_stale_responder!(url)
+          raise Hive::WebServiceFailed,
+                "hive web: stale Hive web responder at #{url}; stop the old process, then run `hive web restart`"
+        end
+
+        def raise_port_collision!(url)
+          port = URI(url).port
+          raise Hive::WebPortCollision,
+                "hive web: port #{port} is occupied by a non-matching responder; stop it or set web.port " \
+                "in #{Hive::Config.global_config_path}, then run `hive web install --force`"
+        rescue URI::InvalidURIError
+          raise Hive::WebPortCollision, "hive web: configured URL #{url.inspect} is occupied by a non-matching responder"
+        end
+
+        def raise_configuration_drift!(url, health)
+          auth = health.dig(:payload, "auth_mode")
+          detail = auth ? " (responder auth_mode=#{auth.inspect})" : ""
+          raise Hive::WebServiceFailed,
+                "hive web: Hive web at #{url} does not match the installed managed configuration#{detail}; " \
+                "run `hive web install --force`, then `hive web restart`"
+        end
+
+        def ensure_installed!
+          return if @unit_exists.call(@unit_path)
+
+          raise Hive::InvalidTaskPath, "hive web: managed service is not installed; run `hive web install` first"
+        end
+
+        def ensure_runtime_ready!
+          return if @runtime_probe.call
+
+          raise Hive::WebServiceFailed,
+                "hive web: installed runtime is missing or stale; run `hive web install --force`"
+        end
+
+        def runtime_ready?
+          runtime = Hive::Web::RuntimeInstaller.discover
+          !!runtime && runtime.ready?
+        end
+
+        def platform
+          case @host_os
+          when /darwin/i then :macos
+          when /linux/i then :linux
+          else :unsupported
+          end
+        end
+
+        def envelope_platform = platform.to_s
+
+        def manager_command_available?
+          command = platform == :macos ? "launchctl" : "systemctl"
+          return false if platform == :unsupported
+
+          ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? do |dir|
+            path = File.join(dir, command)
+            File.file?(path) && File.executable?(path)
+          end
+        end
+
+        def default_unit_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/local.hive-web.plist")
+          when :linux then File.join(@home, ".config/systemd/user/hive-web.service")
+          end
+        end
+
+        def launchd_stdout = File.join(@home, "Library/Logs/hive-web.out.log")
+        def launchd_stderr = File.join(@home, "Library/Logs/hive-web.err.log")
+      end
+    end
+  end
+end
