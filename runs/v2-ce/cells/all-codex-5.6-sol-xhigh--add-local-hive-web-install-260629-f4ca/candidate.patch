+require "test_helper"
+require "hive/setup/project_enrollment"
+
+class SetupProjectEnrollmentTest < Minitest::Test
+  FakeGitOps = Struct.new(:existing, :attached) do
+    def hive_state_branch_exists? = existing
+    def ensure_hive_state_worktree_attached = self.attached = true
+  end
+
+  FakeRegistry = Struct.new(:entries) do
+    def register_project(name:, path:)
+      entry = { "name" => name, "path" => path, "hive_state_path" => File.join(path, ".hive-state") }
+      entries << entry
+      entry
+    end
+  end
+
+  def test_existing_project_is_only_reattached_registered_and_daemon_enrolled
+    Dir.mktmpdir("hive-project") do |project|
+      init_calls = []
+      enroll_calls = []
+      ops = FakeGitOps.new(true, false)
+      registry = FakeRegistry.new([])
+      result = Hive::Setup::ProjectEnrollment.new(
+        project,
+        git_ops_factory: ->(_path) { ops },
+        init_factory: ->(*) { init_calls << :called },
+        registry: registry,
+        daemon_enroller: ->(name) { enroll_calls << name }
+      ).call
+
+      assert_equal "existing", result.outcome
+      assert ops.attached
+      assert_empty init_calls
+      assert_equal [ File.basename(project) ], enroll_calls
+      assert_equal project, registry.entries.first.fetch("path")
+    end
+  end
+
+  def test_fresh_project_delegates_to_init_then_forces_daemon_enrollment
+    Dir.mktmpdir("hive-project") do |project|
+      events = []
+      init = Object.new
+      init.define_singleton_method(:call) { events << :init }
+      registry = FakeRegistry.new([])
+      result = Hive::Setup::ProjectEnrollment.new(
+        project,
+        git_ops_factory: ->(_path) { FakeGitOps.new(false, false) },
+        init_factory: ->(_path) { init },
+        registry: registry,
+        daemon_enroller: ->(name) { events << [ :daemon, name ] }
+      ).call
+
+      assert_equal "initialized", result.outcome
+      assert_equal [ :init, [ :daemon, File.basename(project) ] ], events
+      assert_equal project, result.entry.fetch("path")
+    end
+  end
+end
