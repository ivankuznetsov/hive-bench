diff --git a/lib/hive/setup/dependency_checker.rb b/lib/hive/setup/dependency_checker.rb
new file mode 100644
index 00000000..7f40b169
--- /dev/null
+++ b/lib/hive/setup/dependency_checker.rb
@@ -0,0 +1,300 @@
+require "rbconfig"
+require "timeout"
+require "hive/bounded_command"
+require "rubygems"
+require "hive"
+require "hive/invoked_binary"
+require "hive/web/runtime_installer"
+
+module Hive
+  module Setup
+    # Read-only phase-one diagnostics for `hive setup`. Every subprocess is
+    # bounded and argv-based. Rows distinguish operator-owned blockers from
+    # Hive-owned runtime repairs so callers can enforce the no-mutation
+    # preflight boundary.
+    class DependencyChecker
+      TIMEOUT_SECONDS = 15
+      MIN_RUBY_VERSION = Gem::Version.new("3.4.0")
+
+      CommandResult = Struct.new(:success, :stdout, :stderr) do
+        def success? = !!success
+      end
+
+      Check = Data.define(:component, :status, :message, :remediation, :blocking) do
+        def blocking? = !!blocking
+      end
+
+      def initialize(invoked_binary: Hive::InvokedBinary.path,
+                     host_os: RbConfig::CONFIG["host_os"],
+                     which: nil, runner: nil, runtime_probe: nil,
+                     timeout: TIMEOUT_SECONDS,
+                     arch_linux: File.file?("/etc/arch-release"))
+        @invoked_binary = invoked_binary
+        @host_os = host_os.to_s
+        @which = which || method(:find_executable)
+        @runner = runner || method(:capture)
+        @runtime_probe = runtime_probe || -> { Hive::Web::RuntimeInstaller.discover }
+        @timeout = timeout
+        @arch_linux = arch_linux
+      end
+
+      def call
+        return [ unsupported_platform ] unless supported_platform?
+
+        rows = []
+        rows << check_invoked_hive
+        rows << check_ruby
+        rows << check_tool("bundler", "bundle", %w[--version], bundler_install_command)
+        rows << check_tool("git", "git", %w[--version], package_install_command("git"))
+        rows << check_tool("tmux", "tmux", %w[-V], package_install_command("tmux"))
+        rows << check_tool("gh", "gh", %w[--version], gh_install_command)
+        rows.concat(check_tool_with_auth(
+                      "gh", auth_component: "gh-auth", auth_argv: %w[auth status],
+                      login_command: "gh auth login"
+                    ))
+        rows << check_tool("claude", "claude", %w[--version], "npm install --global @anthropic-ai/claude-code")
+        rows.concat(check_auth(
+                      "claude", "claude-auth", %w[auth status], "claude auth login"
+                    ))
+        rows << check_tool("codex", "codex", %w[--version], "npm install --global @openai/codex")
+        rows.concat(check_auth(
+                      "codex", "codex-auth", %w[login status], "codex login"
+                    ))
+        rows << check_tool("node", "node", %w[--version], node_install_command)
+        rows << check_tool("npm", "npm", %w[--version], node_install_command)
+        rows << check_qmd
+        rows.concat(check_web_runtime)
+        rows
+      end
+
+      private
+
+      def supported_platform?
+        @host_os.match?(/linux|darwin/i)
+      end
+
+      def platform
+        @host_os.match?(/darwin/i) ? :macos : :linux
+      end
+
+      def unsupported_platform
+        Check.new(
+          component: "platform", status: "unsupported",
+          message: "unsupported operating system #{@host_os.inspect}; local setup supports Linux and macOS",
+          remediation: "Run Hive in Docker/hivebox on this host",
+          blocking: true
+        )
+      end
+
+      def check_invoked_hive
+        path = @invoked_binary.to_s
+        unless !path.empty? && Hive::InvokedBinary::VALID_NAMES.include?(File.basename(path))
+          return missing(
+            "hive", "could not resolve the stable Hive wrapper used for this invocation",
+            "Re-run setup with an installed wrapper: `hive setup`"
+          )
+        end
+
+        result = run([ path, "--version" ])
+        return present("hive", [ path, result.stdout.to_s.strip ].reject(&:empty?).join(" ")) if result.success?
+
+        failed(
+          "hive", "Hive wrapper #{path} could not execute: #{diagnostic(result)}",
+          "Reinstall Hive, then run `#{path} setup`"
+        )
+      end
+
+      def check_ruby
+        path = @which.call("ruby")
+        return missing("ruby", "Ruby is not installed", ruby_install_command) unless path
+
+        result = run([ path, "-e", "print RUBY_VERSION" ])
+        unless result.success?
+          return failed(
+            "ruby", "Ruby at #{path} could not execute: #{diagnostic(result)}", ruby_install_command
+          )
+        end
+
+        raw = result.stdout.to_s.strip
+        version = Gem::Version.new(raw)
+        if version < MIN_RUBY_VERSION
+          return Check.new(
+            component: "ruby", status: "version_too_old",
+            message: "Ruby #{raw} is too old; Hive web requires Ruby >= 3.4",
+            remediation: ruby_install_command, blocking: true
+          )
+        end
+
+        present("ruby", raw)
+      rescue ArgumentError
+        failed("ruby", "Ruby at #{path} returned an unparseable version #{raw.inspect}", ruby_install_command)
+      end
+
+      def check_tool(component, binary, version_argv, remediation)
+        path = @which.call(binary)
+        return missing(component, "#{binary} is not installed", remediation) unless path
+
+        result = run([ path, *version_argv ])
+        return present(component, [ path, first_line(result.stdout) ].reject(&:empty?).join(" ")) if result.success?
+
+        failed(component, "#{binary} at #{path} could not execute: #{diagnostic(result)}", remediation)
+      end
+
+      # gh's presence row is already emitted before this helper; retain a
+      # separate auth row so automation can branch install vs login exactly.
+      def check_tool_with_auth(binary, auth_component:, auth_argv:, login_command:)
+        check_auth(binary, auth_component, auth_argv, login_command)
+      end
+
+      def check_auth(binary, component, argv, login_command)
+        path = @which.call(binary)
+        return [] unless path
+
+        result = run([ path, *argv ])
+        row = if result.success?
+          present(component, "authenticated")
+        else
+          Check.new(
+            component: component, status: "unauthenticated",
+            message: "#{binary} is installed but not authenticated: #{diagnostic(result)}",
+            remediation: login_command, blocking: true
+          )
+        end
+        [ row ]
+      end
+
+      def check_qmd
+        path = @which.call("qmd")
+        unless path
+          return repairable(
+            "qmd", "qmd is missing and will be installed in Hive's XDG data prefix",
+            managed_qmd_command
+          )
+        end
+
+        result = run([ path, "--version" ])
+        return present("qmd", [ path, first_line(result.stdout) ].reject(&:empty?).join(" ")) if result.success?
+
+        repairable(
+          "qmd", "qmd at #{path} is broken and Hive will repair its managed copy: #{diagnostic(result)}",
+          managed_qmd_command
+        )
+      end
+
+      def check_web_runtime
+        runtime = @runtime_probe.call
+        unless runtime
+          return [ Check.new(
+            component: "web", status: "missing",
+            message: "the packaged Rails application is missing",
+            remediation: "Reinstall Hive, then run `hive setup`", blocking: true
+          ), Check.new(
+            component: "sqlite", status: "missing",
+            message: "SQLite readiness cannot be checked without the packaged Rails application",
+            remediation: "Reinstall Hive, then run `hive setup`", blocking: true
+          ) ]
+        end
+
+        if runtime.ready?
+          [ present("web", runtime.managed? ? "managed Rails runtime is ready" : "Rails source runtime is available"),
+            present("sqlite", "Rails SQLite runtime is ready") ]
+        else
+          [ repairable("web", "Rails bundle/assets are missing or stale and will be provisioned", "hive setup"),
+            repairable(
+              "sqlite", "Rails SQLite databases will be opened and migrated during provisioning", "hive setup"
+            ) ]
+        end
+      rescue Hive::Error, SystemCallError => e
+        [ repairable("web", "Rails runtime needs repair: #{e.message}", "hive setup"),
+          repairable("sqlite", "SQLite readiness will be retried after Rails repair", "hive setup") ]
+      end
+
+      def present(component, message)
+        Check.new(component: component, status: "present", message: message,
+                  remediation: nil, blocking: false)
+      end
+
+      def repairable(component, message, remediation)
+        Check.new(component: component, status: "repairable", message: message,
+                  remediation: remediation, blocking: false)
+      end
+
+      def missing(component, message, remediation)
+        Check.new(component: component, status: "missing", message: message,
+                  remediation: remediation, blocking: true)
+      end
+
+      def failed(component, message, remediation)
+        Check.new(component: component, status: "missing", message: message,
+                  remediation: remediation, blocking: true)
+      end
+
+      def run(argv)
+        normalize_result(@runner.call(argv, timeout: @timeout))
+      rescue Timeout::Error
+        CommandResult.new(false, "", "timed out after #{@timeout}s")
+      rescue SystemCallError => e
+        CommandResult.new(false, "", "#{e.class}: #{e.message}")
+      end
+
+      def capture(argv, timeout:)
+        stdout, stderr, status = Hive::BoundedCommand.capture(*argv, timeout: timeout)
+        CommandResult.new(status.success?, stdout, stderr)
+      end
+
+      def normalize_result(value)
+        return value if value.respond_to?(:success?) && value.respond_to?(:stdout)
+        return CommandResult.new(value[0], value[1].to_s, value[2].to_s) if value.is_a?(Array)
+
+        CommandResult.new(!!value, "", "")
+      end
+
+      def diagnostic(result)
+        [ result.stderr, result.stdout ].join("\n").lines.map(&:strip).find { |line| !line.empty? }.to_s
+          .then { |line| line.empty? ? "command returned non-zero" : line }
+      end
+
+      def first_line(value)
+        value.to_s.lines.first.to_s.strip
+      end
+
+      def find_executable(name)
+        ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, name)
+          return path if File.file?(path) && File.executable?(path)
+        end
+        nil
+      end
+
+      def package_install_command(package)
+        return "brew install #{package}" if platform == :macos
+        return "sudo pacman -S #{package}" if @arch_linux
+
+        "sudo apt install #{package}"
+      end
+
+      def ruby_install_command
+        platform == :macos ? "brew install ruby" :
+          "curl https://mise.run | sh && ~/.local/bin/mise use --global ruby@3.4"
+      end
+
+      def bundler_install_command = "gem install bundler"
+      def node_install_command
+        return "brew install node" if platform == :macos
+        return "sudo pacman -S nodejs npm" if @arch_linux
+
+        "sudo apt install nodejs npm"
+      end
+      def gh_install_command
+        return "brew install gh" if platform == :macos
+        return "sudo pacman -S github-cli" if @arch_linux
+
+        "sudo apt install gh"
+      end
+
+      def managed_qmd_command
+        'npm install --global --prefix "${XDG_DATA_HOME:-$HOME/.local/share}/hive/qmd" @tobilu/qmd'
+      end
+    end
+  end
+end
diff --git a/lib/hive/setup/project_enrollment.rb b/lib/hive/setup/project_enrollment.rb
new file mode 100644
index 00000000..2be7f448
--- /dev/null
+++ b/lib/hive/setup/project_enrollment.rb
@@ -0,0 +1,54 @@
+require "hive/config"
+require "hive/git_ops"
+require "hive/commands/init"
+require "hive/commands/daemon"
+
+module Hive
+  module Setup
+    # Reuses Init for a fresh repository and takes the narrow repair path for
+    # an existing one: attach its hive/state worktree, refresh the global
+    # registry entry, and surgically force daemon.enabled through the daemon
+    # command. Existing workflow/agent/budget/comment ordering is otherwise
+    # untouched.
+    class ProjectEnrollment
+      Result = Data.define(:outcome, :entry)
+
+      def initialize(project_path, prompts: nil, output: $stdout, error: $stderr,
+                     git_ops_factory: nil, init_factory: nil,
+                     registry: Hive::Config, daemon_enroller: nil)
+        @project_path = File.expand_path(project_path)
+        @prompts = prompts
+        @output = output
+        @error = error
+        @git_ops_factory = git_ops_factory || ->(path) { Hive::GitOps.new(path) }
+        @init_factory = init_factory || lambda do |path|
+          Hive::Commands::Init.new(path, prompts: @prompts, output: @output, error: @error)
+        end
+        @registry = registry
+        @daemon_enroller = daemon_enroller || lambda do |name|
+          Hive::Commands::Daemon.new("enable", name, output: @output, error: @error).call
+        end
+      end
+
+      def call
+        ops = @git_ops_factory.call(@project_path)
+        existing = ops.hive_state_branch_exists?
+        if existing
+          ops.ensure_hive_state_worktree_attached
+        else
+          init = @init_factory.call(@project_path)
+          unless init.respond_to?(:call)
+            raise Hive::InternalError, "setup init factory did not return a callable Init operation"
+          end
+          init.call
+        end
+
+        # Register again even after Init: Config.register_project is an
+        # idempotent replace and repairs a stale path/real_path entry.
+        entry = @registry.register_project(name: File.basename(@project_path), path: @project_path)
+        @daemon_enroller.call(entry.fetch("name"))
+        Result.new(outcome: existing ? "existing" : "initialized", entry: entry)
+      end
+    end
+  end
+end
diff --git a/lib/hive/setup/qmd_installer.rb b/lib/hive/setup/qmd_installer.rb
new file mode 100644
index 00000000..49a628cf
--- /dev/null
+++ b/lib/hive/setup/qmd_installer.rb
@@ -0,0 +1,160 @@
+require "fileutils"
+require "timeout"
+require "hive/bounded_command"
+require "hive"
+require "hive/paths"
+
+module Hive
+  module Setup
+    # Installs Hive's qmd copy under the XDG data tree. It never writes into a
+    # user's npm prefix and never replaces an existing user-owned qmd link.
+    class QmdInstaller
+      DEFAULT_PACKAGE = "@tobilu/qmd".freeze
+      TIMEOUT_SECONDS = 120
+
+      CommandResult = Struct.new(:success, :stdout, :stderr) do
+        def success? = !!success
+      end
+
+      Result = Data.define(:status, :path, :messages)
+
+      class InstallError < Hive::Error; end
+
+      attr_reader :prefix, :managed_binary, :link_path
+
+      def initialize(prefix: File.join(Hive::Paths.data_home, "qmd"),
+                     bin_home: Hive::Paths.bin_home,
+                     package: ENV.fetch("HIVE_QMD_NPM_PACKAGE", DEFAULT_PACKAGE),
+                     runner: nil, which: nil, timeout: TIMEOUT_SECONDS)
+        @prefix = File.expand_path(prefix)
+        @managed_binary = File.join(@prefix, "bin", "qmd")
+        @link_path = File.join(File.expand_path(bin_home), "qmd")
+        @package = package
+        @runner = runner || method(:capture)
+        @which = which || method(:find_executable)
+        @timeout = timeout
+      end
+
+      def install!
+        messages = []
+        unless managed_healthy?
+          FileUtils.mkdir_p(prefix)
+          install = run([ "npm", "install", "--global", "--prefix", prefix,
+                          "--no-audit", "--no-fund", @package ])
+          unless install.success?
+            raise InstallError,
+                  "qmd npm install failed: #{diagnostic(install)}; retry with `#{repair_command}`"
+          end
+
+          rebuild = run([ "npm", "rebuild", "--global", "--prefix", prefix, "better-sqlite3" ])
+          unless rebuild.success?
+            messages << "qmd native rebuild returned non-zero; " \
+                        "the executable probe will decide readiness"
+          end
+          verify_managed_binary!
+          status = "installed"
+        else
+          status = "unchanged"
+        end
+
+        publish_link(messages)
+        report_active_path_mismatch(messages)
+        Result.new(status: status, path: managed_binary, messages: messages.freeze)
+      rescue InstallError
+        raise
+      rescue Timeout::Error => e
+        raise InstallError, "qmd repair timed out after #{@timeout}s: #{e.message}; retry with `#{repair_command}`"
+      rescue SystemCallError => e
+        raise InstallError, "qmd repair failed: #{e.class}: #{e.message}; retry with `#{repair_command}`"
+      end
+
+      private
+
+      def managed_healthy?
+        return false unless File.file?(managed_binary) && File.executable?(managed_binary)
+
+        run([ managed_binary, "--version" ]).success?
+      end
+
+      def verify_managed_binary!
+        unless File.file?(managed_binary) && File.executable?(managed_binary)
+          raise InstallError,
+                "qmd npm install completed but no executable was found at #{managed_binary}; " \
+                "retry with `#{repair_command}`"
+        end
+
+        result = run([ managed_binary, "--version" ])
+        return if result.success?
+
+        raise InstallError,
+              "qmd installed at #{managed_binary} but failed to start: #{diagnostic(result)}; " \
+              "retry with `#{repair_command}`"
+      end
+
+      def publish_link(messages)
+        FileUtils.mkdir_p(File.dirname(link_path))
+        if File.exist?(link_path) || File.symlink?(link_path)
+          if canonical(link_path) != canonical(managed_binary)
+            messages << "existing qmd at #{link_path}; leaving it unchanged " \
+                        "(Hive-managed qmd is #{managed_binary})"
+            return
+          end
+        end
+
+        FileUtils.ln_sf(managed_binary, link_path)
+      end
+
+      def report_active_path_mismatch(messages)
+        active = @which.call("qmd")
+        return unless active
+        return if canonical(active) == canonical(managed_binary)
+
+        messages << "PATH resolves qmd to #{active}, not Hive-managed #{managed_binary}; " \
+                    "wiki refreshes may use the earlier binary"
+      end
+
+      def run(argv)
+        normalize_result(@runner.call(argv, timeout: @timeout))
+      rescue Timeout::Error
+        CommandResult.new(false, "", "timed out after #{@timeout}s")
+      rescue SystemCallError => e
+        CommandResult.new(false, "", "#{e.class}: #{e.message}")
+      end
+
+      def capture(argv, timeout:)
+        stdout, stderr, status = Hive::BoundedCommand.capture(*argv, timeout: timeout)
+        CommandResult.new(status.success?, stdout, stderr)
+      end
+
+      def normalize_result(value)
+        return value if value.respond_to?(:success?) && value.respond_to?(:stdout)
+        return CommandResult.new(value[0], value[1].to_s, value[2].to_s) if value.is_a?(Array)
+
+        CommandResult.new(!!value, "", "")
+      end
+
+      def diagnostic(result)
+        line = [ result.stderr, result.stdout ].join("\n").lines.map(&:strip).find { |item| !item.empty? }
+        line || "command returned non-zero"
+      end
+
+      def repair_command
+        "npm install --global --prefix #{prefix} #{@package}"
+      end
+
+      def canonical(path)
+        File.realpath(path)
+      rescue SystemCallError
+        File.expand_path(path)
+      end
+
+      def find_executable(name)
+        ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, name)
+          return path if File.file?(path) && File.executable?(path)
+        end
+        nil
+      end
+    end
+  end
+end
