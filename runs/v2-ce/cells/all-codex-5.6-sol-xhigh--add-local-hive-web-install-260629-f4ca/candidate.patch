@@ -0,0 +1,121 @@
+require "test_helper"
+require "hive/pid_file"
+
+class SystemTest < ActionDispatch::IntegrationTest
+  include Hive::PidFile
+
+  def pid_file
+    File.join(Hive::Paths.state_home, ".daemon.pid")
+  end
+
+  def with_wrapper
+    wrapper = File.expand_path("../../../bin/hive", __dir__)
+    previous = ENV["HIVE_INVOKED_BIN"]
+    ENV["HIVE_INVOKED_BIN"] = wrapper
+    yield wrapper
+  ensure
+    previous.nil? ? ENV.delete("HIVE_INVOKED_BIN") : ENV["HIVE_INVOKED_BIN"] = previous
+    FileUtils.rm_f(pid_file)
+  end
+
+  def with_control(fake)
+    original = Hive::Web::DaemonControl.method(:new)
+    Hive::Web::DaemonControl.define_singleton_method(:new) { fake }
+    yield
+  ensure
+    Hive::Web::DaemonControl.define_singleton_method(:new, original)
+  end
+
+  test "system page shows matching daemon and web health without repair action" do
+    with_web_auth_mode("local") do
+      with_wrapper do |wrapper|
+        FileUtils.mkdir_p(File.dirname(pid_file))
+        File.write(
+          pid_file,
+          pid_file_payload(Process.pid).merge(
+            "binary_path" => wrapper, "version" => Hive::VERSION
+          ).to_yaml
+        )
+
+        get "/system"
+
+        assert_response :success
+        assert_select "a", text: "System"
+        assert_select "[data-daemon-identity]", text: /matching/i
+        assert_select "[data-web-health]", text: /running/i
+        assert_select "form[action='/system/daemon/repair']", count: 0
+      end
+    end
+  end
+
+  test "legacy identity renders unknown with exactly one fixed repair action" do
+    with_web_auth_mode("local") do
+      with_wrapper do
+        FileUtils.mkdir_p(File.dirname(pid_file))
+        File.write(pid_file, Process.pid.to_s)
+
+        get "/system"
+
+        assert_response :success
+        assert_select "[data-daemon-identity]", text: /unknown/i
+        assert_select "form[action='/system/daemon/repair']", count: 1
+        assert_select "input[name='command'], input[name='path'], input[name='service']", count: 0
+      end
+    end
+  end
+
+  test "repair POST ignores command path and service params and reports verified success" do
+    fake = Object.new
+    calls = 0
+    fake.define_singleton_method(:repair) do
+      calls += 1
+      {
+        "outcome" => "upgraded", "backup_path" => "/tmp/unit.bak", "restarted" => true,
+        "status" => { "running" => true, "identity_match" => true }
+      }
+    end
+
+    with_web_auth_mode("local") do
+      with_wrapper do
+        with_control(fake) do
+          post "/system/daemon/repair",
+               params: { command: "rm -rf /", path: "/tmp/other", service: "other" }
+        end
+      end
+    end
+
+    assert_equal 1, calls
+    assert_redirected_to "/system"
+    follow_redirect!
+    assert_select ".flash-notice", text: /verified/i
+  end
+
+  test "repair failure is a typed 422 with exact CLI fallback" do
+    fake = Object.new
+    fake.define_singleton_method(:repair) do
+      raise Hive::DaemonRepairFailed,
+            "manager failed. CLI fallback: `hive daemon install --force`."
+    end
+
+    with_web_auth_mode("local") do
+      with_wrapper do
+        with_control(fake) { post "/system/daemon/repair" }
+      end
+    end
+
+    assert_response :unprocessable_entity
+    assert_select "h1", text: "Action failed"
+    assert_includes response.body, "hive daemon install --force"
+  end
+
+  test "repair POST remains CSRF protected in local mode" do
+    previous = ActionController::Base.allow_forgery_protection
+    ActionController::Base.allow_forgery_protection = true
+    with_web_auth_mode("local") do
+      post "/system/daemon/repair"
+      assert_response :unprocessable_entity
+    end
+  ensure
+    ActionController::Base.allow_forgery_protection = previous
+  end
+end
