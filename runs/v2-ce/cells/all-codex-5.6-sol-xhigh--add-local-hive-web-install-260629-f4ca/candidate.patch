index 00000000..7cbbe153
--- /dev/null
+++ b/test/unit/commands/daemon_install_repair_test.rb
@@ -0,0 +1,86 @@
+require "test_helper"
+require "hive/commands/daemon"
+require "hive/commands/daemon/service_installer"
+
+class HiveCommandsDaemonInstallRepairTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeInstaller = Struct.new(:target_path, :last_backup_path, :last_restart_invoked,
+                             :envelope_platform, :messages, keyword_init: true)
+
+  def setup
+    @home = Dir.mktmpdir("hive-daemon-install-repair")
+  end
+
+  def teardown
+    FileUtils.rm_rf(@home)
+  end
+
+  def daemon(**kwargs)
+    Hive::Commands::Daemon.new("install", **{ hive_home: @home }.merge(kwargs))
+  end
+
+  def test_force_install_restarts_and_verifies_an_unchanged_drifted_runtime
+    command = daemon(force: true)
+    installer = FakeInstaller.new(
+      target_path: "/tmp/hive-daemon.service", last_backup_path: nil,
+      last_restart_invoked: false, envelope_platform: "linux", messages: []
+    )
+    unchanged = Hive::Commands::ServiceInstaller::Outcome.new(:unchanged)
+    installer.define_singleton_method(:install!) do |autostart:, force:|
+      unchanged
+    end
+    restarts = 0
+    installer.define_singleton_method(:restart!) { restarts += 1; true }
+    statuses = [
+      { "running" => true, "identity_match" => false },
+      { "running" => true, "identity_match" => true }
+    ]
+    command.define_singleton_method(:daemon_runtime_snapshot) do |_binary|
+      statuses.shift || { "running" => true, "identity_match" => true }
+    end
+
+    with_replaced_singleton_method(
+      Hive::Commands::Daemon::ServiceInstaller, :new, ->(**_kwargs) { installer }
+    ) do
+      capture_io { command.call }
+    end
+
+    assert_equal 1, restarts
+  end
+
+  def test_force_install_repairs_drifted_detached_daemon_without_service_manager
+    repair_calls = []
+    command = daemon(
+      force: true, repair_runner: ->(argv) { repair_calls << argv; true }
+    )
+    wrapper = "/stable/bin/hive"
+    installer = FakeInstaller.new(
+      target_path: "/tmp/hive-daemon.service", last_backup_path: nil,
+      last_restart_invoked: false, envelope_platform: "linux", messages: []
+    )
+    installer.define_singleton_method(:install!) do |autostart:, force:|
+      Hive::Commands::ServiceInstaller::Outcome.new(:autostart_unavailable)
+    end
+    statuses = [
+      { "running" => true, "pid" => 123, "identity_match" => false },
+      { "running" => false, "pid" => nil, "identity_match" => nil },
+      { "running" => true, "pid" => 456, "identity_match" => true }
+    ]
+    command.define_singleton_method(:current_binary_path) { wrapper }
+    command.define_singleton_method(:daemon_runtime_snapshot) do |_binary|
+      statuses.shift || { "running" => true, "identity_match" => true }
+    end
+
+    with_replaced_singleton_method(
+      Hive::Commands::Daemon::ServiceInstaller, :new, ->(**_kwargs) { installer }
+    ) do
+      capture_io { command.call }
+    end
+
+    assert_equal(
+      [ [ wrapper, "daemon", "stop" ], [ wrapper, "daemon", "start", "--detach" ] ],
+      repair_calls
+    )
+  end
+end
