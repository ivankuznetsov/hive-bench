new file mode 100644
index 00000000..9637780b
--- /dev/null
+++ b/test/unit/daemon/runtime_status_test.rb
@@ -0,0 +1,123 @@
+require "test_helper"
+require "hive/daemon/runtime_status"
+
+class DaemonRuntimeStatusTest < Minitest::Test
+  def setup
+    @home = Dir.mktmpdir("hive-runtime-status")
+    @pid_file = File.join(@home, ".daemon.pid")
+    @expected_binary = "/stable/bin/hive"
+  end
+
+  def teardown
+    FileUtils.rm_rf(@home)
+  end
+
+  def write_payload(payload)
+    File.write(@pid_file, payload.is_a?(String) ? payload : payload.to_yaml)
+  end
+
+  def status(live: true, live_start: "start-42", service_state: {})
+    probe = Hive::Daemon::RuntimeStatus.new(
+      hive_home: @home,
+      expected_binary: @expected_binary,
+      expected_version: Hive::VERSION,
+      service_probe: -> { service_state }
+    )
+    probe.define_singleton_method(:pid_alive?) { |_pid| live }
+    probe.define_singleton_method(:pid_ownership) do |payload, _pid|
+      return :legacy if payload["_legacy"]
+      return :unverified if payload["process_start_time"].nil? || live_start.nil?
+
+      payload["process_start_time"] == live_start ? :verified : :reused
+    end
+    probe.call
+  end
+
+  def matching_payload(binary: @expected_binary, version: Hive::VERSION)
+    {
+      "pid" => 42,
+      "process_start_time" => "start-42",
+      "started_at" => Time.now.utc.iso8601,
+      "binary_path" => binary,
+      "version" => version
+    }
+  end
+
+  def test_matching_runtime_reports_exact_expected_and_running_identity
+    write_payload(matching_payload)
+
+    result = status(
+      service_state: {
+        "service_installed" => true, "service_enabled" => true,
+        "service_active" => true, "unit_path" => "/home/u/.config/systemd/user/hive-daemon.service"
+      }
+    )
+
+    assert result.fetch("running")
+    assert_equal @expected_binary, result.fetch("expected_binary")
+    assert_equal @expected_binary, result.fetch("running_binary")
+    assert_equal Hive::VERSION, result.fetch("expected_version")
+    assert_equal Hive::VERSION, result.fetch("running_version")
+    assert_equal true, result.fetch("binary_match")
+    assert_equal true, result.fetch("version_match")
+    assert_equal true, result.fetch("identity_match")
+    assert_equal "matching", result.fetch("identity_state")
+    assert_equal true, result.fetch("service_active")
+  end
+
+  def test_binary_or_version_drift_is_never_healthy
+    [
+      [ "/old/bin/hive", Hive::VERSION ],
+      [ @expected_binary, "0.0.1" ],
+      [ "/old/bin/hive", "0.0.1" ]
+    ].each do |binary, version|
+      write_payload(matching_payload(binary: binary, version: version))
+
+      result = status
+
+      assert_equal false, result.fetch("identity_match")
+      assert_equal "drifted", result.fetch("identity_state")
+      assert_match(/daemon install --force/, result.fetch("repair_hint"))
+    end
+  end
+
+  def test_legacy_scalar_and_yaml_payloads_are_running_but_identity_unknown
+    [
+      "42\n",
+      {
+        "pid" => 42,
+        "process_start_time" => "start-42",
+        "started_at" => Time.now.utc.iso8601
+      }
+    ].each do |payload|
+      write_payload(payload)
+
+      result = status
+
+      assert_equal true, result.fetch("running")
+      assert_nil result.fetch("identity_match")
+      assert_equal "unknown", result.fetch("identity_state")
+      assert_nil result.fetch("running_binary")
+      assert_nil result.fetch("running_version")
+    end
+  end
+
+  def test_stopped_stale_reused_and_corrupt_payloads_are_unknown_and_not_running
+    write_payload(matching_payload)
+    assert_equal false, status(live: false).fetch("running")
+
+    write_payload(matching_payload)
+    assert_equal false, status(live_start: "replacement-start").fetch("running")
+
+    write_payload("not yaml: [")
+    corrupt = status
+    assert_equal false, corrupt.fetch("running")
+    assert_equal "unknown", corrupt.fetch("identity_state")
+    assert_nil corrupt.fetch("identity_match")
+
+    FileUtils.rm_f(@pid_file)
+    stopped = status
+    assert_equal false, stopped.fetch("running")
+    assert_nil stopped.fetch("pid")
+  end
+end
