+require "test_helper"
+require "hive/commands/web/managed_config"
+
+class WebManagedConfigTest < Minitest::Test
+  def test_round_trips_the_effective_installed_endpoint_atomically
+    Dir.mktmpdir("hive-web-managed-config") do |dir|
+      path = File.join(dir, "nested", "service.json")
+      config = Hive::Commands::Web::ManagedConfig.new(path: path)
+
+      config.write!(bind: "::1", port: 9123, auth_mode: "local")
+
+      assert_equal(
+        { "schema" => "hive-web-managed-config.v1", "bind" => "::1",
+          "port" => 9123, "auth_mode" => "local" },
+        config.load!
+      )
+      assert_equal 0o600, File.stat(path).mode & 0o777
+      assert_empty Dir["#{path}.tmp*"]
+    end
+  end
+
+  def test_missing_or_corrupt_config_has_reinstall_guidance
+    Dir.mktmpdir("hive-web-managed-config") do |dir|
+      path = File.join(dir, "service.json")
+      config = Hive::Commands::Web::ManagedConfig.new(path: path)
+      error = assert_raises(Hive::WebServiceFailed) { config.load! }
+      assert_match(/web install --force/, error.message)
+
+      File.write(path, JSON.generate("schema" => "wrong", "bind" => "", "port" => 0))
+      error = assert_raises(Hive::WebServiceFailed) { config.load! }
+      assert_match(/invalid/, error.message)
+    end
+  end
+
+  def test_unreadable_config_is_wrapped_as_a_web_service_failure
+    Dir.mktmpdir("hive-web-managed-config") do |dir|
+      config = Hive::Commands::Web::ManagedConfig.new(path: dir)
+
+      error = assert_raises(Hive::WebServiceFailed) { config.load! }
+
+      assert_match(/managed service configuration/, error.message)
+      assert_match(/web install --force/, error.message)
+    end
+  end
+end
