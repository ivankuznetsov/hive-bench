+require "test_helper"
+require "hive/setup/qmd_installer"
+
+class SetupQmdInstallerTest < Minitest::Test
+  def command_result(success = true, stdout = "", stderr = "")
+    Hive::Setup::QmdInstaller::CommandResult.new(success, stdout, stderr)
+  end
+
+  def test_installs_and_rebuilds_qmd_in_hive_prefix_then_links_without_shell
+    Dir.mktmpdir("hive-qmd") do |dir|
+      prefix = File.join(dir, "data", "qmd")
+      bin_home = File.join(dir, "bin")
+      calls = []
+      runner = lambda do |argv, timeout:|
+        calls << [ argv, timeout ]
+        if argv[0, 3] == %w[npm install --global]
+          FileUtils.mkdir_p(File.join(prefix, "bin"))
+          File.write(File.join(prefix, "bin", "qmd"), "#!/bin/sh\n")
+          FileUtils.chmod(0o755, File.join(prefix, "bin", "qmd"))
+        end
+        command_result(true, argv.first == File.join(prefix, "bin", "qmd") ? "qmd 2.0\n" : "")
+      end
+
+      result = Hive::Setup::QmdInstaller.new(
+        prefix: prefix, bin_home: bin_home, runner: runner, which: ->(_name) { nil }
+      ).install!
+
+      assert_equal "installed", result.status
+      assert_equal File.join(prefix, "bin", "qmd"), File.realpath(File.join(bin_home, "qmd"))
+      assert_includes calls.map(&:first),
+                      [ "npm", "install", "--global", "--prefix", prefix, "--no-audit", "--no-fund", "@tobilu/qmd" ]
+      assert_includes calls.map(&:first),
+                      [ "npm", "rebuild", "--global", "--prefix", prefix, "better-sqlite3" ]
+      assert calls.all? { |_argv, timeout| timeout == 120 }
+    end
+  end
+
+  def test_preserves_user_owned_link_and_reports_active_path_mismatch
+    Dir.mktmpdir("hive-qmd") do |dir|
+      prefix = File.join(dir, "managed")
+      bin_home = File.join(dir, "bin")
+      user_qmd = File.join(dir, "user", "qmd")
+      FileUtils.mkdir_p(File.dirname(user_qmd))
+      File.write(user_qmd, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, user_qmd)
+      FileUtils.mkdir_p(bin_home)
+      File.symlink(user_qmd, File.join(bin_home, "qmd"))
+      runner = lambda do |argv, timeout:|
+        _ = timeout
+        if argv[0, 3] == %w[npm install --global]
+          FileUtils.mkdir_p(File.join(prefix, "bin"))
+          File.write(File.join(prefix, "bin", "qmd"), "#!/bin/sh\n")
+          FileUtils.chmod(0o755, File.join(prefix, "bin", "qmd"))
+        end
+        command_result(true, "qmd 2.0\n")
+      end
+
+      result = Hive::Setup::QmdInstaller.new(
+        prefix: prefix, bin_home: bin_home, runner: runner, which: ->(_name) { user_qmd }
+      ).install!
+
+      assert_equal user_qmd, File.realpath(File.join(bin_home, "qmd"))
+      assert result.messages.any? { |message| message.include?("leaving it unchanged") }
+      assert result.messages.any? { |message| message.include?("PATH resolves qmd") }
+    end
+  end
+
+  def test_failed_install_is_typed_and_does_not_publish_a_link
+    Dir.mktmpdir("hive-qmd") do |dir|
+      installer = Hive::Setup::QmdInstaller.new(
+        prefix: File.join(dir, "qmd"), bin_home: File.join(dir, "bin"),
+        runner: ->(_argv, timeout:) { _ = timeout; command_result(false, "", "offline") },
+        which: ->(_name) { nil }
+      )
+
+      error = assert_raises(Hive::Setup::QmdInstaller::InstallError) { installer.install! }
+
+      assert_match(/npm install/, error.message)
+      assert_match(/offline/, error.message)
+      refute File.exist?(File.join(dir, "bin", "qmd"))
+    end
+  end
+end
