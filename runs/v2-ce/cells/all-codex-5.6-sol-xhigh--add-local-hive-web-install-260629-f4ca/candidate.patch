diff --git a/lib/hive/bounded_command.rb b/lib/hive/bounded_command.rb
new file mode 100644
index 00000000..a42015db
--- /dev/null
+++ b/lib/hive/bounded_command.rb
@@ -0,0 +1,132 @@
+require "timeout"
+
+module Hive
+  # Runs child commands in their own process group and enforces a wall-clock
+  # deadline. Timeout always terminates and reaps the whole group, so a helper
+  # that forks or holds a capture pipe open cannot outlive its caller.
+  module BoundedCommand
+    TERM_GRACE_SECONDS = 1.0
+    POLL_SECONDS = 0.05
+
+    module_function
+
+    def capture(*argv, env: {}, chdir: nil, timeout:)
+      deadline = monotonic_time + timeout
+      stdout_r, stdout_w = IO.pipe
+      stderr_r, stderr_w = IO.pipe
+      options = { in: File::NULL, out: stdout_w, err: stderr_w, pgroup: true }
+      options[:chdir] = chdir if chdir
+      pid = Process.spawn(env, *argv, **options)
+      stdout_w.close
+      stderr_w.close
+      stdout_reader = Thread.new { stdout_r.read }
+      stderr_reader = Thread.new { stderr_r.read }
+      status = wait(pid, timeout, deadline: deadline, pgid: pid)
+      wait_for_group_exit!(pid, deadline, timeout)
+      wait_for_readers!([ stdout_reader, stderr_reader ], pid, deadline, timeout)
+      [ stdout_reader.value, stderr_reader.value, status ]
+    ensure
+      stdout_w&.close unless stdout_w&.closed?
+      stderr_w&.close unless stderr_w&.closed?
+      stdout_r&.close unless stdout_r&.closed?
+      stderr_r&.close unless stderr_r&.closed?
+      stdout_reader&.kill if stdout_reader&.alive?
+      stderr_reader&.kill if stderr_reader&.alive?
+    end
+
+    def run(*argv, env: {}, chdir: nil, timeout:)
+      deadline = monotonic_time + timeout
+      options = { pgroup: true }
+      options[:chdir] = chdir if chdir
+      pid = Process.spawn(env, *argv, **options)
+      status = wait(pid, timeout, deadline: deadline, pgid: pid)
+      wait_for_group_exit!(pid, deadline, timeout)
+      status.success?
+    end
+
+    def success?(*argv, timeout:)
+      _stdout, _stderr, status = capture(*argv, timeout: timeout)
+      status.success?
+    rescue Timeout::Error, SystemCallError
+      false
+    end
+
+    def wait(pid, timeout, deadline: monotonic_time + timeout, pgid: pid)
+      loop do
+        _waited, status = Process.wait2(pid, Process::WNOHANG)
+        return status if status
+        if monotonic_time >= deadline
+          terminate(pid, pgid: pgid)
+          raise Timeout::Error, "timed out after #{timeout}s"
+        end
+
+        sleep POLL_SECONDS
+      end
+    rescue Interrupt
+      terminate(pid, pgid: pgid)
+      raise
+    end
+
+    def wait_for_readers!(readers, pid, deadline, timeout)
+      while readers.any?(&:alive?)
+        if monotonic_time >= deadline
+          terminate(pid, pgid: pid)
+          raise Timeout::Error, "timed out after #{timeout}s"
+        end
+        sleep POLL_SECONDS
+      end
+    rescue Interrupt
+      terminate(pid, pgid: pid)
+      raise
+    end
+
+    def wait_for_group_exit!(pid, deadline, timeout)
+      while process_group_alive?(pid)
+        if monotonic_time >= deadline
+          terminate(pid, pgid: pid)
+          raise Timeout::Error, "timed out after #{timeout}s"
+        end
+        sleep POLL_SECONDS
+      end
+    rescue Interrupt
+      terminate(pid, pgid: pid)
+      raise
+    end
+
+    def terminate(pid, pgid: nil)
+      pgid ||= Process.getpgid(pid)
+      Process.kill("TERM", -pgid)
+      deadline = monotonic_time + TERM_GRACE_SECONDS
+      loop do
+        begin
+          Process.wait(pid, Process::WNOHANG)
+        rescue Errno::ECHILD
+          nil
+        end
+        break unless process_group_alive?(pgid)
+        break if monotonic_time >= deadline
+
+        sleep POLL_SECONDS
+      end
+      Process.kill("KILL", -pgid) if process_group_alive?(pgid)
+      Process.wait(pid)
+    rescue Errno::ESRCH, Errno::ECHILD
+      nil
+    rescue Errno::EPERM
+      Process.wait(pid)
+    end
+
+    def process_group_alive?(pgid)
+      Process.kill(0, -pgid)
+      true
+    rescue Errno::ESRCH, Errno::ECHILD
+      false
+    rescue Errno::EPERM
+      true
+    end
+
+    def monotonic_time
+      Process.clock_gettime(Process::CLOCK_MONOTONIC)
+    end
+  end
+end
