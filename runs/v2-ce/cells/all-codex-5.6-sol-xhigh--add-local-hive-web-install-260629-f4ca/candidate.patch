+require "yaml"
+
+# Installed-artifact boundaries for local mode. The first test keeps a fast
+# injected orchestration seam; the acceptance test provisions the real Rails
+# runtime and launches daemon/web from rendered units through a portable
+# systemctl-compatible shim. Both load the gem installed into the sandbox,
+# never the source checkout.
+class LocalWebSetupE2ETest < Minitest::Test
+  include HiveTestHelper
+
+  ROOT = File.expand_path("../..", __dir__)
+
+  def test_installed_gem_setup_uses_one_registry_project_and_queue_tree
+    skip "gem executable unavailable" unless executable_available?("gem")
+
+    with_tmp_dir do |dir|
+      gem_path = File.join(dir, "hive-cli.gem")
+      gem_home = File.join(dir, "gem-home")
+      project = File.join(dir, "project")
+      home = File.join(dir, "home")
+      xdg = %w[config data state cache].to_h { |name| [ name, File.join(dir, "xdg", name) ] }
+      FileUtils.mkdir_p([ project, home ])
+
+      build_and_install_gem(gem_path, gem_home)
+
+      gem_root = Dir[File.join(gem_home, "gems", "hive-cli-*")].fetch(0)
+      assert File.file?(File.join(gem_root, "web", "config", "application.rb"))
+      assert File.file?(File.join(gem_root, "web", "Gemfile.lock"))
+
+      env = {
+        "HOME" => home,
+        "HIVE_HOME" => nil,
+        "XDG_CONFIG_HOME" => xdg.fetch("config"),
+        "XDG_DATA_HOME" => xdg.fetch("data"),
+        "XDG_STATE_HOME" => xdg.fetch("state"),
+        "XDG_CACHE_HOME" => xdg.fetch("cache"),
+        "GEM_HOME" => gem_home,
+        "GEM_PATH" => [ gem_home, *Gem.path ].uniq.join(File::PATH_SEPARATOR)
+      }
+      strip_ruby_bundle_environment!(env)
+      stdout, stderr, status = Open3.capture3(
+        env, RbConfig.ruby, "-I", File.join(gem_root, "lib"), "-e", installed_setup_script,
+        gem_root, project
+      )
+      assert status.success?, "installed setup probe failed:\n#{stdout}\n#{stderr}"
+
+      result = JSON.parse(stdout)
+      assert result.fetch("loaded_hive").start_with?(gem_root), result.fetch("loaded_hive")
+      assert_equal true, result.dig("setup", "ok")
+      assert_equal %w[qmd web-runtime project daemon web], result.dig("setup", "completed")
+      assert_equal File.realpath(project), File.realpath(result.fetch("registered_path"))
+      assert_equal File.join(project, ".hive-state"), result.fetch("project_state")
+      assert result.fetch("manifest").start_with?(xdg.fetch("data"))
+      assert result.fetch("web_storage").start_with?(xdg.fetch("state"))
+      assert result.fetch("queue").start_with?(xdg.fetch("state"))
+      %w[registered_path project_state manifest web_storage queue].each do |key|
+        refute result.fetch(key).start_with?("/data/"), "#{key} unexpectedly used Docker storage"
+      end
+    end
+  end
+
+  def test_installed_cli_setup_runs_real_daemon_web_health_and_tui_state_boundaries
+    skip "gem executable unavailable" unless executable_available?("gem")
+    skip "git executable unavailable" unless executable_available?("git")
+    unless File.file?("/usr/include/yaml.h") ||
+           system("pkg-config", "--exists", "yaml-0.1", out: File::NULL, err: File::NULL)
+      message = "native Rails bundle build prerequisites unavailable (libyaml headers)"
+      flunk message if ENV["CI"]
+      skip message
+    end
+
+    with_tmp_dir do |dir|
+      gem_path = File.join(dir, "hive-cli.gem")
+      gem_home = File.join(dir, "gem-home")
+      project = File.join(dir, "project")
+      home = File.join(dir, "home")
+      fake_bin = File.join(dir, "fake-bin")
+      manager_state = File.join(dir, "manager")
+      xdg = %w[config data state cache bin].to_h { |name| [ name, File.join(dir, "xdg", name) ] }
+      FileUtils.mkdir_p([ project, home, fake_bin, manager_state, *xdg.values ])
+      initialize_git_project(project)
+      build_and_install_gem(gem_path, gem_home)
+      hive_bin = File.join(gem_home, "bin", "hive")
+      write_tool_shims(fake_bin)
+      write_systemctl_shim(fake_bin)
+      write_managed_qmd(xdg.fetch("data"))
+      port = available_port
+      env = installed_env(
+        home: home, xdg: xdg, gem_home: gem_home, fake_bin: fake_bin,
+        manager_state: manager_state, hive_bin: hive_bin, port: port
+      )
+      probe_script = <<~'RUBY'
+        require "json"
+        require "hive"
+        require "hive/web/runtime_installer"
+        runtime = Hive::Web::RuntimeInstaller.discover
+        loaded = $LOADED_FEATURES.find { |path| path.end_with?("/lib/hive.rb") }
+        puts JSON.generate("loaded" => loaded, "app_dir" => runtime&.app_dir, "managed" => runtime&.managed?)
+      RUBY
+      probe_out, probe_err, probe_status = Open3.capture3(env, RbConfig.ruby, "-e", probe_script)
+      assert probe_status.success?, "installed load probe failed:\n#{probe_out}\n#{probe_err}"
+      probe = JSON.parse(probe_out)
+      assert probe.fetch("loaded").start_with?(File.join(gem_home, "gems", "hive-cli-")), probe.inspect
+      assert_equal true, probe.fetch("managed"), probe.inspect
+
+      init_out, init_err, init_status = Open3.capture3(env, hive_bin, "init", project, "--json")
+      assert init_status.success?, "installed init failed:\n#{init_out}\n#{init_err}"
+      assert_equal File.realpath(project), File.realpath(JSON.parse(init_out).fetch("path"))
+      configure_web_port(env, port)
+
+      setup_out, setup_err, setup_status = Open3.capture3(env, hive_bin, "setup", project)
+      assert setup_status.success?, "installed setup failed:\n#{setup_out}\n#{setup_err}\n#{manager_logs(manager_state)}"
+      deep = wait_for_deep_health(port)
+      assert_equal "hive-web", deep.fetch("service")
+      assert_equal "local", deep.fetch("auth_mode")
+      assert_equal true, deep.dig("daemon", "identity_match")
+      attacker = Net::HTTP::Get.new("/")
+      attacker["Host"] = "rebound-attacker.example"
+      attacker_response = Net::HTTP.start("127.0.0.1", port) { |http| http.request(attacker) }
+      assert_equal "403", attacker_response.code
+
+      project_name = File.basename(project)
+      new_out, new_err, new_status = Open3.capture3(
+        env, hive_bin, "new", project_name, "installed boundary task", "--json"
+      )
+      assert new_status.success?, "installed new failed:\n#{new_out}\n#{new_err}"
+      slug = JSON.parse(new_out).fetch("slug")
+
+      status_out, status_err, status_status = Open3.capture3(env, hive_bin, "status", "--json")
+      assert status_status.success?, "installed status failed:\n#{status_out}\n#{status_err}"
+      assert_includes status_out, slug
+
+      tui_script = <<~'RUBY'
+        require "json"
+        require "hive/tui/state_source"
+        snapshot = Hive::Tui::StateSource.new(poll_interval_seconds: 60).refresh_now
+        puts JSON.generate(snapshot.rows.map(&:slug))
+      RUBY
+      tui_out, tui_err, tui_status = Open3.capture3(env, RbConfig.ruby, "-e", tui_script)
+      assert tui_status.success?, "installed TUI state source failed:\n#{tui_out}\n#{tui_err}"
+      assert_includes JSON.parse(tui_out), slug
+      exercise_installed_tui!(env, hive_bin, "installed boundary task")
+
+      page = Net::HTTP.get(URI("http://127.0.0.1:#{port}/"))
+      assert_includes page, "installed boundary task"
+
+      repeat_out, repeat_err, repeat_status = Open3.capture3(env, hive_bin, "setup", project)
+      assert repeat_status.success?, "repeat installed setup failed:\n#{repeat_out}\n#{repeat_err}"
+      assert_equal true, wait_for_deep_health(port).fetch("ok")
+    ensure
+      stop_manager_children(manager_state) if manager_state
+    end
+  end
+
+  private
+
+  def installed_setup_script
+    <<~'RUBY'
+      require "json"
+      require "fileutils"
+      require "stringio"
+      require "hive/commands/setup"
+
+      gem_root, project = ARGV
+      runtime = Hive::Web::RuntimeInstaller.new(
+        app_dir: File.join(gem_root, "web"),
+        runner: ->(_env, _argv, chdir:) { chdir == File.join(gem_root, "web") }
+      )
+
+      qmd_result = Struct.new(:status, :path, :messages).new(
+        "installed", File.join(Hive::Paths.data_home, "qmd", "bin", "qmd"), []
+      )
+      qmd = Object.new
+      qmd.define_singleton_method(:install!) { qmd_result }
+
+      enrollment = Object.new
+      enrollment.define_singleton_method(:call) do
+        project_state = File.join(project, ".hive-state")
+        FileUtils.mkdir_p(File.join(project_state, "stages", "1-inbox"))
+        entry = Hive::Config.register_project(name: File.basename(project), path: project)
+        Struct.new(:outcome, :entry).new("initialized", entry)
+      end
+
+      operations = Object.new
+      operations.define_singleton_method(:ensure_daemon) do |binary_path:|
+        { "running" => true, "pid" => 123, "fallback" => false,
+          "unit_path" => "fixture-daemon", "binary_path" => binary_path }
+      end
+      operations.define_singleton_method(:ensure_web) do |binary_path:|
+        { "outcome" => "started", "mode" => "managed", "url" => "http://127.0.0.1:4567",
+          "unit_path" => "fixture-web", "binary_path" => binary_path,
+          "status" => { "state" => "healthy", "http_identity" => "matching" } }
+      end
+
+      output = StringIO.new
+      payload = Hive::Commands::Setup.new(
+        project, json: true, output: output, error: StringIO.new,
+        dependency_checker: [], qmd_installer: qmd, runtime_installer: runtime,
+        project_enrollment: enrollment, operations: operations,
+        invoked_binary: "/fixture/bin/hive", host_os: "linux"
+      ).call
+
+      queue = File.join(Hive::Paths.state_home, "dispatch_requests", "fixture.json")
+      FileUtils.mkdir_p(File.dirname(queue))
+      File.write(queue, "{}\n")
+      registered = Hive::Config.registered_projects.fetch(0)
+      loaded_hive = $LOADED_FEATURES.find { |path| path.end_with?("/lib/hive.rb") }
+      puts JSON.generate(
+        "loaded_hive" => loaded_hive,
+        "setup" => payload,
+        "registered_path" => registered.fetch("path"),
+        "project_state" => registered.fetch("hive_state_path"),
+        "manifest" => runtime.manifest_path,
+        "web_storage" => Hive::Paths.web_storage_home,
+        "queue" => queue
+      )
+    RUBY
+  end
+
+  def executable_available?(name)
+    ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? do |dir|
+      path = File.join(dir, name)
+      File.file?(path) && File.executable?(path)
+    end
+  end
+
+  def build_and_install_gem(gem_path, gem_home)
+    build_out, build_err, build_status = Open3.capture3(
+      "gem", "build", File.join(ROOT, "hive.gemspec"), "--output", gem_path, chdir: ROOT
+    )
+    assert build_status.success?, "gem build failed:\n#{build_out}\n#{build_err}"
+    install_out, install_err, install_status = Open3.capture3(
+      "gem", "install", gem_path, "--install-dir", gem_home,
+      "--bindir", File.join(gem_home, "bin"), "--ignore-dependencies", "--no-document"
+    )
+    assert install_status.success?, "gem install failed:\n#{install_out}\n#{install_err}"
+  end
+
+  def initialize_git_project(project)
+    run_command!(%w[git init -b main], chdir: project)
+    run_command!(%w[git config user.email hive-e2e@example.test], chdir: project)
+    run_command!([ "git", "config", "user.name", "Hive E2E" ], chdir: project)
+    File.write(File.join(project, "README.md"), "# installed setup e2e\n")
+    run_command!(%w[git add README.md], chdir: project)
+    run_command!(%w[git commit -m initial], chdir: project)
+  end
+
+  def run_command!(argv, chdir: nil)
+    out, err, status = Open3.capture3(*argv, chdir: chdir)
+    assert status.success?, "#{argv.join(' ')} failed:\n#{out}\n#{err}"
+  end
+
+  def write_tool_shims(dir)
+    script = File.join(dir, "tool-shim")
+    File.write(script, <<~'SH')
+      #!/bin/sh
+      case "$(basename "$0"):$*" in
+        gh:*|claude:*|codex:*|tmux:*|node:*|npm:*) echo "smoke 99.0.0"; exit 0 ;;
+      esac
+      exit 0
+    SH
+    FileUtils.chmod(0o755, script)
+    %w[gh claude codex tmux node npm].each do |name|
+      FileUtils.ln_s(script, File.join(dir, name))
+    end
+  end
+
+  def write_managed_qmd(xdg_data)
+    path = File.join(xdg_data, "hive", "qmd", "bin", "qmd")
+    FileUtils.mkdir_p(File.dirname(path))
+    File.write(path, "#!/bin/sh\necho qmd-smoke\n")
+    FileUtils.chmod(0o755, path)
+  end
+
+  def write_systemctl_shim(dir)
+    path = File.join(dir, "systemctl")
+    File.write(path, <<~'SH')
+      #!/bin/sh
+      set -eu
+      state="$HIVE_E2E_MANAGER_STATE"
+      service_pid() { printf '%s/%s.pid' "$state" "$1"; }
+      active() {
+        file="$(service_pid "$1")"
+        [ -s "$file" ] || return 1
+        kill -0 "$(cat "$file")" 2>/dev/null
+      }
+      stop_service() {
+        file="$(service_pid "$1")"
+        [ -s "$file" ] || return 0
+        pid="$(cat "$file")"
+        kill -TERM "$pid" 2>/dev/null || true
+        i=0
+        while kill -0 "$pid" 2>/dev/null && [ "$i" -lt 100 ]; do i=$((i + 1)); sleep 0.05; done
+        kill -KILL "$pid" 2>/dev/null || true
+        rm -f "$file"
+      }
+      start_service() {
+        service="$1"
+        active "$service" && return 0
+        unit="$HOME/.config/systemd/user/$service.service"
+        [ -s "$unit" ] || { echo "missing rendered unit: $unit" >&2; return 1; }
+        while IFS= read -r assignment; do
+          assignment="${assignment#Environment=}"
+          assignment="$(printf '%s' "$assignment" | sed "s|%h|$HOME|g")"
+          eval "export $assignment"
+        done <<EOF
+      $(sed -n 's/^Environment=/Environment=/p' "$unit")
+      EOF
+        command="$(sed -n 's/^ExecStart=//p' "$unit")"
+        [ -n "$command" ] || { echo "missing ExecStart in $unit" >&2; return 1; }
+        eval "nohup $command >>\"$state/$service.log\" 2>&1 &"
+        echo "$!" >"$(service_pid "$service")"
+      }
+      [ "${1:-}" = "--user" ] && shift
+      case "${1:-}" in
+        show-environment|daemon-reload) exit 0 ;;
+        is-enabled) exit 0 ;;
+        is-active) active "$2" ;;
+        is-failed) exit 1 ;;
+        enable) [ "${2:-}" = "--now" ] && start_service "$3" ;;
+        start) start_service "$2" ;;
+        restart) stop_service "$2"; start_service "$2" ;;
+        stop) stop_service "$2" ;;
+        disable) [ "${2:-}" = "--now" ] && stop_service "$3" ;;
+        *) exit 0 ;;
+      esac
+    SH
+    FileUtils.chmod(0o755, path)
+  end
+
+  def installed_env(home:, xdg:, gem_home:, fake_bin:, manager_state:, hive_bin:, port:)
+    env = {
+      "HOME" => home, "HIVE_HOME" => nil,
+      "XDG_CONFIG_HOME" => xdg.fetch("config"),
+      "XDG_DATA_HOME" => xdg.fetch("data"),
+      "XDG_STATE_HOME" => xdg.fetch("state"),
+      "XDG_CACHE_HOME" => xdg.fetch("cache"),
+      "XDG_BIN_HOME" => xdg.fetch("bin"),
+      "GEM_HOME" => gem_home,
+      "GEM_PATH" => [ gem_home, *Gem.path ].uniq.join(File::PATH_SEPARATOR),
+      "PATH" => [ fake_bin, File.join(gem_home, "bin"), ENV.fetch("PATH", "") ].join(File::PATH_SEPARATOR),
+      "HIVE_INVOKED_BIN" => hive_bin,
+      "HIVE_E2E_HIVE_BIN" => hive_bin,
+      "HIVE_E2E_MANAGER_STATE" => manager_state,
+      "HIVE_E2E_PORT" => port.to_s
+    }
+    strip_ruby_bundle_environment!(env)
+  end
+
+  def strip_ruby_bundle_environment!(env)
+    ENV.each_key do |key|
+      env[key] = nil if key.start_with?("BUNDLE", "BUNDLER_")
+    end
+    %w[RUBYOPT RUBYLIB RUBYGEMS_GEMDEPS].each { |key| env[key] = nil }
+    env
+  end
+
+  def configure_web_port(env, port)
+    path = File.join(env.fetch("XDG_CONFIG_HOME"), "hive", "config.yml")
+    config = YAML.safe_load_file(path)
+    config["web"] = {
+      "bind" => "127.0.0.1", "port" => port, "auth" => "auto",
+      "origin" => "http://127.0.0.1:#{port}"
+    }
+    File.write(path, config.to_yaml)
+  end
+
+  def available_port
+    server = TCPServer.new("127.0.0.1", 0)
+    server.local_address.ip_port
+  ensure
+    server&.close
+  end
+
+  def wait_for_deep_health(port)
+    deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + 30
+    loop do
+      response = Net::HTTP.get_response(URI("http://127.0.0.1:#{port}/health?deep=1"))
+      return JSON.parse(response.body) if response.is_a?(Net::HTTPSuccess)
+    rescue SystemCallError, Timeout::Error, JSON::ParserError
+      raise if Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline
+      sleep 0.1
+    else
+      raise "deep health remained #{response.code}: #{response.body}" if
+        Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline
+      sleep 0.1
+    end
+  end
+
+  def exercise_installed_tui!(env, hive_bin, expected_text)
+    PTY.spawn(env, hive_bin, "tui") do |reader, writer, pid|
+      reader.winsize = [ 30, 120 ]
+      deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + 10
+      buffer = +""
+      until buffer.include?(expected_text) || Process.clock_gettime(Process::CLOCK_MONOTONIC) >= deadline
+        ready, = IO.select([ reader ], nil, nil, 0.05)
+        next unless ready
+
+        begin
+          buffer << reader.read_nonblock(4096)
+        rescue IO::WaitReadable
+          next
+        rescue EOFError, Errno::EIO
+          break
+        end
+      end
+      assert_includes buffer, expected_text, "installed `hive tui` did not render the created task"
+
+      writer.write("q")
+      writer.flush
+      exit_deadline = Process.clock_gettime(Process::CLOCK_MONOTONIC) + 2
+      loop do
+        reaped, status = Process.waitpid2(pid, Process::WNOHANG)
+        if reaped
+          assert_equal 0, status.exitstatus, "installed `hive tui` did not exit cleanly"
+          pid = nil
+          break
+        end
+        flunk "installed `hive tui` did not exit after q" if
+          Process.clock_gettime(Process::CLOCK_MONOTONIC) >= exit_deadline
+        sleep 0.05
+      end
+    ensure
+      begin
+        Process.kill("TERM", pid) if pid
+      rescue Errno::ESRCH, Errno::ECHILD
+        nil
+      end
+    end
+  end
+
+  def manager_logs(state)
+    %w[hive-daemon.log hive-web.log].filter_map do |name|
+      path = File.join(state, name)
+      "#{name}:\n#{File.read(path)}" if File.file?(path)
+    end.join("\n")
+  end
+
+  def stop_manager_children(state)
+    Dir[File.join(state, "*.pid")].each do |path|
+      pid = Integer(File.read(path), exception: false)
+      next unless pid && pid > 1
+
+      Process.kill("TERM", pid)
+    rescue Errno::ESRCH, Errno::EPERM
+      nil
+    end
+  end
+end
