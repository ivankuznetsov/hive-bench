+# status grid. This avoids a live OAuth dependency while retaining CSRF,
+# encrypted cookies, owner persistence, and production routing.
+docker exec "$NAME" ruby /app/packaging/docker/smoke_auth.rb smoke-owner >/dev/null || {
+  echo "FAIL authenticated owner claim/golden path"
+  docker logs "$NAME" 2>&1 | tail -50
+  exit 1
+}
+
+# Recreate the container against the SAME named volume. Ownership, the explicit
+# sentinel, daemon registry, and Rails state must survive image-process churn.
+docker rm -f "$NAME" >/dev/null
+start_box
+wait_for_health
+assert_deep_health
+docker exec "$NAME" test -s /data/.hivebox-smoke || {
+  echo "FAIL /data sentinel did not survive container recreation"
+  exit 1
+}
+docker exec "$NAME" ruby /app/packaging/docker/smoke_auth.rb smoke-owner --require-existing-owner >/dev/null || {
+  echo "FAIL persisted owner could not authenticate after recreation"
+  exit 1
+}
+
 echo "PASS hivebox image smoke ($IMAGE)"
diff --git a/packaging/docker/smoke_auth.rb b/packaging/docker/smoke_auth.rb
new file mode 100644
index 00000000..2a578af2
--- /dev/null
+++ b/packaging/docker/smoke_auth.rb
@@ -0,0 +1,77 @@
+# frozen_string_literal: true
+
+require "hive/config"
+require "hive/paths"
+require "hive/web/session_secret"
+
+ENV["RAILS_ENV"] = "production"
+ENV["HIVEBOX_AUTH_MODE"] = "github"
+ENV["HIVEBOX_STORAGE_DIR"] ||= Hive::Paths.web_storage_home
+web_config = Hive::Config.load_global_web
+ENV["SECRET_KEY_BASE"] ||= Hive::Web::SessionSecret.load_or_create(
+  web_config.fetch("session_secret_file")
+)
+
+require "/app/web/config/environment"
+require "action_dispatch/testing/integration"
+require "cgi"
+require "json"
+
+login = ARGV.fetch(0)
+require_existing_owner = ARGV.include?("--require-existing-owner")
+if require_existing_owner
+  owner = Hive::Config.load_global_web.dig("github", "owner")
+  raise "persisted owner missing before authentication: #{owner.inspect}" unless owner == login
+end
+
+class SmokeGithubHttp
+  def initialize(login)
+    @login = login
+  end
+
+  def start(host, _port, **_options)
+    @host = host
+    yield self
+  end
+
+  def request(request)
+    body = if @host == "api.github.com"
+      JSON.generate("login" => @login)
+    elsif request.path.include?("/login/device/code")
+      JSON.generate(
+        "device_code" => "smoke-device", "user_code" => "SMOKE-CODE",
+        "verification_uri" => "https://github.com/login/device",
+        "expires_in" => 900, "interval" => 0
+      )
+    else
+      JSON.generate("access_token" => "gho_smoke")
+    end
+    response = Net::HTTPOK.new("1.1", "200", "OK")
+    response.instance_variable_set(:@read, true)
+    response.define_singleton_method(:body) { body }
+    response
+  end
+end
+
+SessionsController.http_client = SmokeGithubHttp.new(login)
+browser = ActionDispatch::Integration::Session.new(Rails.application)
+browser.host! "127.0.0.1"
+browser.get "/login"
+raise "login page failed: #{browser.response.status}" unless browser.response.status == 200
+
+token = CGI.unescapeHTML(
+  browser.response.body[/name="authenticity_token" value="([^"]+)"/, 1].to_s
+)
+raise "login page did not contain a CSRF token" if token.empty?
+
+browser.post "/auth/github", params: { "authenticity_token" => token }
+raise "device flow did not redirect" unless browser.response.redirect?
+browser.follow_redirect!
+raise "device grant did not redirect" unless browser.response.redirect?
+browser.follow_redirect!
+raise "authenticated golden path failed: #{browser.response.status}" unless browser.response.status == 200
+
+owner = Hive::Config.load_global_web.dig("github", "owner")
+raise "owner claim mismatch: #{owner.inspect}" unless owner == login
+
+puts JSON.generate("login" => login, "owner" => owner, "root_status" => browser.response.status)
