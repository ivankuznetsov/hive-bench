@@ -0,0 +1,117 @@
+require "test_helper"
+require "hive/setup/dependency_checker"
+
+class SetupDependencyCheckerTest < Minitest::Test
+  FakeRuntime = Struct.new(:managed_value, :ready_value) do
+    def managed? = managed_value
+    def ready? = ready_value
+  end
+
+  def result(success: true, stdout: "ok\n", stderr: "")
+    Hive::Setup::DependencyChecker::CommandResult.new(success, stdout, stderr)
+  end
+
+  def checker(missing: [], failures: {}, outputs: {}, host_os: "linux", runtime: FakeRuntime.new(true, true))
+    paths = Hash.new { |_hash, name| "/tools/#{name}" }
+    missing.each { |name| paths[name] = nil }
+    calls = []
+    runner = lambda do |argv, timeout:|
+      calls << [ argv, timeout ]
+      key = argv.join(" ")
+      failures.key?(key) ? result(success: false, stderr: failures.fetch(key)) :
+        result(stdout: outputs.fetch(key, "ok\n"))
+    end
+    instance = Hive::Setup::DependencyChecker.new(
+      invoked_binary: "/tools/hive",
+      host_os: host_os,
+      arch_linux: false,
+      which: ->(name) { paths[name] },
+      runner: runner,
+      runtime_probe: -> { runtime }
+    )
+    [ instance, calls ]
+  end
+
+  def test_green_preflight_checks_every_required_external_dependency_and_auth
+    instance, calls = checker(outputs: {
+      "/tools/hive --version" => Hive::VERSION,
+      "/tools/ruby -e print RUBY_VERSION" => "3.4.2",
+      "/tools/gh auth status" => "github.com",
+      "/tools/claude auth status" => "logged in",
+      "/tools/codex login status" => "Logged in"
+    })
+
+    rows = instance.call
+
+    assert rows.none?(&:blocking?), rows.map(&:to_h).inspect
+    %w[hive ruby bundler git tmux gh claude codex node npm qmd web sqlite].each do |name|
+      assert_includes rows.map(&:component), name
+    end
+    assert_includes calls.map { |argv, _timeout| argv }, %w[/tools/gh auth status]
+    assert calls.all? { |_argv, timeout| timeout == 15 }, "all subprocess probes must be bounded"
+  end
+
+  def test_missing_and_unauthenticated_external_tools_have_exact_non_mutating_repairs
+    instance, calls = checker(
+      missing: %w[tmux claude],
+      failures: {
+        "/tools/gh auth status" => "not logged in",
+        "/tools/codex login status" => "not logged in"
+      }
+    )
+
+    rows = instance.call
+
+    tmux = rows.find { |row| row.component == "tmux" }
+    claude = rows.find { |row| row.component == "claude" }
+    gh = rows.find { |row| row.component == "gh-auth" }
+    codex = rows.find { |row| row.component == "codex-auth" }
+    assert_equal "sudo apt install tmux", tmux.remediation
+    assert_equal "npm install --global @anthropic-ai/claude-code", claude.remediation
+    assert_equal "gh auth login", gh.remediation
+    assert_equal "codex login", codex.remediation
+    assert [ tmux, claude, gh, codex ].all?(&:blocking?)
+    refute calls.any? { |argv, _| argv.include?("install") || argv.include?("login") && argv.last != "status" },
+           "preflight must never execute an install or login command"
+  end
+
+  def test_old_ruby_and_unsupported_os_block_before_repairable_hive_owned_rows
+    instance, = checker(outputs: { "/tools/ruby -e print RUBY_VERSION" => "3.3.9" })
+    ruby = instance.call.find { |row| row.component == "ruby" }
+    assert_equal "version_too_old", ruby.status
+    assert ruby.blocking?
+    assert_includes ruby.remediation, "ruby@3.4"
+
+    unsupported, calls = checker(host_os: "freebsd")
+    rows = unsupported.call
+    assert_equal [ "platform" ], rows.map(&:component)
+    assert_equal "unsupported", rows.first.status
+    assert rows.first.blocking?
+    assert_empty calls
+  end
+
+  def test_missing_qmd_and_stale_web_runtime_are_repairable_not_external_blockers
+    instance, = checker(missing: %w[qmd], runtime: FakeRuntime.new(true, false))
+
+    rows = instance.call
+
+    assert_equal "repairable", rows.find { |row| row.component == "qmd" }.status
+    assert_equal "repairable", rows.find { |row| row.component == "web" }.status
+    assert_equal "repairable", rows.find { |row| row.component == "sqlite" }.status
+    refute rows.find { |row| row.component == "qmd" }.blocking?
+  end
+
+  def test_arch_missing_github_cli_uses_pacman_package_name
+    paths = Hash.new { |_hash, name| name == "gh" ? nil : "/tools/#{name}" }
+    checker = Hive::Setup::DependencyChecker.new(
+      invoked_binary: "/tools/hive", host_os: "linux", arch_linux: true,
+      which: ->(name) { paths[name] },
+      runner: ->(_argv, timeout:) { result },
+      runtime_probe: -> { FakeRuntime.new(true, true) }
+    )
+
+    gh = checker.call.find { |row| row.component == "gh" }
+
+    assert_equal "sudo pacman -S github-cli", gh.remediation
+  end
+end
