+require "test_helper"
+require "hive/commands/web/service_installer"
+
+class WebServiceInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_linux_unit_uses_distinct_web_identity_and_foreground_argv
+    Dir.mktmpdir("hive-web-service") do |home|
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "linux", home: home, binary_path: "/opt/Hive CLI/bin/hv",
+        bind: "127.0.0.1", port: 4567, auth_mode: "local",
+        systemctl_available: true, runner: ->(_argv) { true }
+      )
+
+      unit = installer.send(:render_systemd)
+
+      assert_includes unit, "Description=Hive web UI"
+      assert_includes unit,
+                      "ExecStart=/opt/Hive\\ CLI/bin/hv web --bind 127.0.0.1 --port 4567 --local-auth"
+      assert_includes unit, "Environment=XDG_STATE_HOME=#{home}/.local/state"
+      assert_includes unit, "StartLimitBurst=3"
+      assert_includes unit, "Restart=on-failure"
+      refute_includes unit, " daemon "
+      refute_includes unit, "hive-daemon"
+    end
+  end
+
+  def test_macos_unit_has_safe_keepalive_and_persists_unsafe_auth
+    Dir.mktmpdir("hive-web-service") do |home|
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "darwin", home: home, binary_path: "/Applications/Hive & Co/hv",
+        bind: "0.0.0.0", port: 9123, auth_mode: "unsafe",
+        launchctl_available: true, runner: ->(_argv) { true }
+      )
+
+      plist = installer.send(:render_launchd)
+
+      assert_includes plist, "<string>local.hive-web</string>"
+      assert_includes plist, "<key>SuccessfulExit</key>"
+      assert_match(/<key>SuccessfulExit<\/key>\s*<false\/>/, plist)
+      assert_includes plist, "[ -x &quot;$0&quot; ] || exit 0; exec &quot;$0&quot; &quot;$@&quot;"
+      assert_includes plist, "<string>/Applications/Hive &amp; Co/hv</string>"
+      assert_includes plist, "<string>--unsafe-no-auth</string>"
+      assert_includes plist, "<string>9123</string>"
+      refute_includes plist, "hive-daemon"
+    end
+  end
+
+  def test_install_is_drift_safe_and_force_backs_up
+    Dir.mktmpdir("hive-web-service") do |home|
+      calls = []
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "linux", home: home, binary_path: "/usr/local/bin/hive",
+        bind: "127.0.0.1", port: 4567, auth_mode: "local",
+        systemctl_available: true, runner: ->(argv) { calls << argv; true }
+      )
+      FileUtils.mkdir_p(File.dirname(installer.target_path))
+      File.write(installer.target_path, "operator customization\n")
+
+      drift = installer.install!(autostart: true)
+      assert_equal :drifted, drift.kind
+      assert_equal "operator customization\n", File.read(installer.target_path)
+      assert_empty calls
+
+      upgraded = installer.install!(autostart: false, force: true)
+      assert_equal :upgraded, upgraded.kind
+      assert File.file?(upgraded.backup_path)
+      assert_equal "operator customization\n", File.read(upgraded.backup_path)
+      refute upgraded.restarted
+      assert_empty calls, "install only writes/registers the unit; start owns manager activation"
+      config_path = File.join(home, ".local/state/hive/web/service.json")
+      assert_equal(
+        { "schema" => "hive-web-managed-config.v1", "bind" => "127.0.0.1",
+          "port" => 4567, "auth_mode" => "local" },
+        JSON.parse(File.read(config_path))
+      )
+    end
+  end
+
+  def test_manager_unavailable_keeps_unit_and_points_to_bare_foreground_fallback
+    Dir.mktmpdir("hive-web-service") do |home|
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "linux", home: home, binary_path: "/usr/local/bin/hive",
+        bind: "127.0.0.1", port: 4567, auth_mode: "local",
+        systemctl_available: false, runner: ->(_argv) { flunk "manager must not run" }
+      )
+
+      outcome = installer.install!(autostart: true)
+
+      assert_equal :autostart_unavailable, outcome.kind
+      assert File.file?(installer.target_path)
+      assert installer.messages.any? { |message| message.include?("run bare `hive web`") }
+    end
+  end
+end
