+class SystemController < ApplicationController
+  def show
+    @daemon = daemon_runtime_status
+    @web = {
+      "running" => true,
+      "version" => Hive::VERSION,
+      "auth_mode" => web_auth_mode,
+      "invoked_binary" => ENV[Hive::InvokedBinary::ENV_KEY]
+    }
+  end
+
+  def repair_daemon
+    result = Hive::Web::DaemonControl.new.repair
+    notice = "Daemon repaired and verified"
+    notice += " (backup: #{display_path(result['backup_path'])})" if result["backup_path"]
+    redirect_to system_path, notice: notice
+  end
+
+  helper_method :display_path, :system_value
+
+  private
+
+  def daemon_runtime_status
+    Hive::Daemon::RuntimeStatus.new.call
+  end
+
+  def display_path(path)
+    return "unknown" if path.blank?
+
+    value = File.expand_path(path.to_s)
+    home = File.expand_path(ENV["HOME"] || Dir.home)
+    value.sub(/\A#{Regexp.escape(home)}(?=\/|\z)/, "~")
+  end
+
+  def system_value(value)
+    return "unknown" if value.nil?
+
+    value == true ? "yes" : value == false ? "no" : value.to_s
+  end
+end
