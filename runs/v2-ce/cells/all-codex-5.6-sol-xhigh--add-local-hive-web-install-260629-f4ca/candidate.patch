diff --git a/test/unit/web/daemon_control_test.rb b/test/unit/web/daemon_control_test.rb
new file mode 100644
index 00000000..f957b512
--- /dev/null
+++ b/test/unit/web/daemon_control_test.rb
@@ -0,0 +1,122 @@
+require "test_helper"
+require "hive/web/daemon_control"
+require "hive/commands/service_installer/outcome"
+
+class WebDaemonControlTest < Minitest::Test
+  FakeInstaller = Struct.new(:outcome, :messages, :target_path, :calls, keyword_init: true) do
+    def install!(autostart:, force:)
+      calls << [ autostart, force ]
+      outcome
+    end
+
+    def restart!
+      calls << :restart
+      true
+    end
+  end
+
+  def setup
+    @dir = Dir.mktmpdir("hive-daemon-control")
+    @wrapper = File.join(@dir, "hive")
+    File.write(@wrapper, "#!/bin/sh\n")
+    FileUtils.chmod(0o755, @wrapper)
+  end
+
+  def teardown
+    FileUtils.rm_rf(@dir)
+  end
+
+  def outcome(kind, backup_path: nil, restarted: false)
+    Hive::Commands::ServiceInstaller::Outcome.new(
+      kind, backup_path: backup_path, restarted: restarted
+    )
+  end
+
+  def test_repair_derives_exported_wrapper_force_installs_and_waits_for_match
+    calls = []
+    installer = FakeInstaller.new(
+      outcome: outcome(:upgraded, backup_path: "/tmp/unit.bak", restarted: true),
+      messages: [ "backed up" ], target_path: "/tmp/hive-daemon.service", calls: []
+    )
+    statuses = [
+      { "running" => true, "identity_match" => false },
+      { "running" => true, "identity_match" => true, "identity_state" => "matching" }
+    ]
+    control = Hive::Web::DaemonControl.new(
+      env: { "HIVE_INVOKED_BIN" => @wrapper, "PATH" => "" },
+      installer_factory: ->(binary) { calls << binary; installer },
+      status_probe: -> { statuses.shift || statuses.last },
+      sleeper: ->(_seconds) {}, clock: -> { 0.0 }
+    )
+
+    result = control.repair
+
+    assert_equal [ @wrapper ], calls
+    assert_equal [ [ true, true ] ], installer.calls
+    assert_equal "upgraded", result.fetch("outcome")
+    assert_equal "/tmp/unit.bak", result.fetch("backup_path")
+    assert_equal true, result.fetch("restarted")
+    assert_equal true, result.dig("status", "identity_match")
+  end
+
+  def test_repair_rejects_missing_wrapper_and_installer_failures_with_exact_fallback
+    missing = Hive::Web::DaemonControl.new(
+      env: { "HIVE_INVOKED_BIN" => "/tmp/not-hive", "PATH" => "" }
+    )
+    error = assert_raises(Hive::DaemonRepairFailed) { missing.repair }
+    assert_match(/HIVE_INVOKED_BIN/, error.message)
+    assert_match(/hive daemon install --force/, error.message)
+
+    installer = FakeInstaller.new(
+      outcome: outcome(:failed), messages: [ "manager rejected restart" ],
+      target_path: "/tmp/unit", calls: []
+    )
+    failed = Hive::Web::DaemonControl.new(
+      env: { "HIVE_INVOKED_BIN" => @wrapper, "PATH" => "" },
+      installer_factory: ->(_binary) { installer },
+      status_probe: -> { { "running" => false, "identity_match" => nil } }
+    )
+    error = assert_raises(Hive::DaemonRepairFailed) { failed.repair }
+    assert_match(/manager rejected restart/, error.message)
+    assert_match(/hive daemon install --force/, error.message)
+  end
+
+  def test_repair_times_out_on_post_install_mismatch_and_accepts_no_parameters
+    installer = FakeInstaller.new(
+      outcome: outcome(:unchanged), messages: [], target_path: "/tmp/unit", calls: []
+    )
+    times = [ 0.0, 1.0, 2.0 ]
+    control = Hive::Web::DaemonControl.new(
+      env: { "HIVE_INVOKED_BIN" => @wrapper, "PATH" => "" },
+      installer_factory: ->(_binary) { installer },
+      status_probe: -> { { "running" => true, "identity_match" => false } },
+      sleeper: ->(_seconds) {}, clock: -> { times.shift || 2.0 }, timeout: 1
+    )
+
+    error = assert_raises(Hive::DaemonRepairFailed) { control.repair }
+    assert_match(/did not reach matching identity/, error.message)
+    assert_raises(ArgumentError) { control.repair(command: "rm -rf", service: "other") }
+  end
+
+  def test_unchanged_unit_restarts_a_running_legacy_or_drifted_process
+    installer = FakeInstaller.new(
+      outcome: outcome(:unchanged), messages: [], target_path: "/tmp/unit", calls: []
+    )
+    statuses = [
+      { "running" => true, "identity_match" => nil },
+      { "running" => true, "identity_match" => true }
+    ]
+    control = Hive::Web::DaemonControl.new(
+      env: { "HIVE_INVOKED_BIN" => @wrapper, "PATH" => "" },
+      installer_factory: ->(_binary) { installer },
+      status_probe: -> { statuses.shift || { "running" => true, "identity_match" => true } },
+      sleeper: ->(_seconds) {}, clock: -> { 0.0 }
+    )
+
+    result = control.repair
+
+    assert_equal [ [ true, true ], :restart ], installer.calls
+    assert_equal true, result.fetch("restarted")
+    assert_equal "unchanged", result.fetch("outcome")
+  end
+end
