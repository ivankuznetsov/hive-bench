+          # Gem::Package.build prints "Successfully built RubyGem…" via
+          # Gem.ui.say and a homepage_uri/source_code_uri warning via
+          # Gem.ui.alert_warning to stdout/stderr; route both through a
+          # SilentUI so the test output stays clean (the assertions below
+          # are the deliberate signal).
+          Gem::DefaultUserInteraction.use_ui(Gem::SilentUI.new) do
