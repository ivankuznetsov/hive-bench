@@ -708,6 +708,79 @@ class RunReviewTest < Minitest::Test
     end
   end
 
+  # Acceptance A (U6/R9): a tmux review-fix pass exits cleanly with a diff
+  # to commit, but the Stop hook never signals — the launcher's tolerant
+  # fallback returns {status: :ok, fallback: true}. The review stage must
+  # NOT stamp REVIEW_ERROR; the normal post-fix flow auto-commits the diff
+  # and the task reaches REVIEW_COMPLETE.
+  def test_review_fix_stop_hook_fallback_reaches_review_complete
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        folder = setup_review_task(dir)
+        worktree = YAML.safe_load(File.read(File.join(folder, "worktree.yml")))["path"]
+        FileUtils.mkdir_p(File.join(folder, "reviews"))
+        File.write(File.join(folder, "reviews", "local-reviewer-01.md"),
+                   "## High\n- [x] apply a fix\n")
+        Hive::Markers.set(File.join(folder, "task.md"), :review_waiting, pass: 1, escalations: 1)
+
+        # Stand in for the launcher on a stop-hook race: the fix agent
+        # finished (dirty worktree), .done never landed, and the tolerant
+        # fallback accepted it → {status: :ok, fallback: true}.
+        fallback_stub = lambda do |_task, _cfg, ctx, accepted:|
+          dirty = File.join(ctx.worktree_path, "test", "fallback-fix.txt")
+          FileUtils.mkdir_p(File.dirname(dirty))
+          File.write(dirty, "recovered\n")
+          { status: :ok, fallback: true, fallback_evidence: { sentinel_missing: true } }
+        end
+
+        with_replaced_singleton_method(Hive::Stages::Review, :spawn_fix_agent, fallback_stub) do
+          _out, _err, status = with_captured_exit { Hive::Commands::Run.new(folder).call }
+          assert_equal 0, status
+        end
+
+        marker = Hive::Markers.current(File.join(folder, "task.md"))
+        assert_equal :review_complete, marker.name,
+                     "a clean-exit fallback must reach SUCCESS, not REVIEW_ERROR " \
+                     "(got #{marker.name} attrs=#{marker.attrs.inspect})"
+        assert_equal "", `git -C #{worktree} status --porcelain`,
+                     "the fallback pass's diff must be auto-committed by the normal flow"
+        assert_includes `git -C #{worktree} log -1 --pretty=%B`,
+                        "fix(review): apply pass 01 findings"
+      end
+    end
+  end
+
+  # Acceptance B (U6/R4/R9): a genuine stop-hook timeout with NO fallback
+  # (the launcher could not prove completion) must stay strict — the fix
+  # phase stamps REVIEW_ERROR phase=fix reason=fix_failed with the
+  # historical "did not signal completion" message.
+  def test_review_fix_genuine_timeout_stays_review_error
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        folder = setup_review_task(dir)
+        FileUtils.mkdir_p(File.join(folder, "reviews"))
+        File.write(File.join(folder, "reviews", "local-reviewer-01.md"),
+                   "## High\n- [x] apply a fix\n")
+        Hive::Markers.set(File.join(folder, "task.md"), :review_waiting, pass: 1, escalations: 1)
+
+        timeout_stub = lambda do |_task, _cfg, _ctx, accepted:|
+          { status: :timeout, error_message: "claude stop hook did not signal completion" }
+        end
+
+        with_replaced_singleton_method(Hive::Stages::Review, :spawn_fix_agent, timeout_stub) do
+          _out, _err, status = with_captured_exit { Hive::Commands::Run.new(folder).call }
+          assert_equal Hive::ExitCodes::TASK_IN_ERROR, status
+        end
+
+        marker = Hive::Markers.current(File.join(folder, "task.md"))
+        assert_equal :review_error, marker.name
+        assert_equal "fix", marker.attrs["phase"]
+        assert_equal "fix_failed", marker.attrs["reason"]
+        assert_includes marker.attrs["message"].to_s, "did not signal completion"
+      end
+    end
+  end
+
