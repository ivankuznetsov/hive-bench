diff --git a/test/unit/stages/review/fix_completion_fallback_test.rb b/test/unit/stages/review/fix_completion_fallback_test.rb
new file mode 100644
index 00000000..5a1a5595
--- /dev/null
+++ b/test/unit/stages/review/fix_completion_fallback_test.rb
@@ -0,0 +1,85 @@
+require "test_helper"
+require "hive/stages/review"
+
+# U4/R9: the tmux review-fix tolerant-completion predicate. It is consulted
+# only at the stop-hook sentinel-missing deadline AFTER the launcher has
+# confirmed a clean exit. It must accept a genuinely-completed fix pass
+# (readable worktree + this pass's escalations + a dirty worktree with a fix
+# diff pending commit) and stay strict otherwise, so the
+# "did not signal completion" / REVIEW_ERROR path survives for real failures.
+class HiveStagesReviewFixCompletionFallbackTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeTask = Struct.new(:folder, :slug, keyword_init: true)
+
+  def setup
+    @root = Dir.mktmpdir("hive-review-fallback")
+    @worktree = File.join(@root, "worktree")
+    @task_folder = File.join(@root, "task")
+    FileUtils.mkdir_p(@worktree)
+    FileUtils.mkdir_p(File.join(@task_folder, "reviews"))
+    @task = FakeTask.new(folder: @task_folder, slug: "demo-260711-aaaa")
+    @ctx = Hive::Stages::Review::Context.new(
+      worktree_path: @worktree,
+      task_folder: @task_folder,
+      default_branch: "main",
+      pass: 1
+    )
+  end
+
+  def teardown
+    FileUtils.rm_rf(@root) if @root
+  end
+
+  def write_escalations
+    File.write(File.join(@task_folder, "reviews", "escalations-01.md"), "### Q1.\n")
+  end
+
+  def predicate
+    Hive::Stages::Review.send(:fix_completion_fallback, @task, @ctx, "hive-6-review-fix-pass1-demo")
+  end
+
+  def call(status:)
+    with_replaced_singleton_method(Hive::Stages::Review, :worktree_status, ->(_p) { status }) do
+      predicate.call({ launcher_clean: true, sentinel_missing: true }, @task)
+    end
+  end
+
+  # Happy path: escalations exist, worktree dirty with a fix diff → accept
+  # with an audit payload the launcher packs into claude_completion_fallback.
+  def test_accepts_clean_exit_with_escalations_and_dirty_worktree
+    write_escalations
+    payload = call(status: :dirty)
+
+    refute_nil payload
+    assert_equal "fix", payload[:phase]
+    assert_equal 1, payload[:pass]
+    assert_equal "6-review", payload[:stage]
+    assert_equal "fix-pass-01", payload[:agent]
+    assert_equal "worktree_changes_pending_commit", payload[:evidence]
+    assert_equal "reviews/escalations-01.md", payload[:artifacts]
+    assert_equal "review-fix-pass01", payload[:log_label]
+  end
+
+  # No diff to commit → the pass produced nothing; stay strict (nil) so the
+  # launcher drains to the timeout / REVIEW_ERROR path.
+  def test_rejects_when_worktree_clean
+    write_escalations
+    assert_nil call(status: :clean),
+               "a clean worktree at fix time means no fix was produced — must stay strict"
+  end
+
+  # No escalations for the pass → no real fix input; stay strict.
+  def test_rejects_when_escalations_missing
+    assert_nil call(status: :dirty),
+               "without this pass's escalations the predicate cannot prove a fix ran"
+  end
+
+  # Unreadable/missing worktree → strict (never launder a vanished worktree).
+  def test_rejects_when_worktree_missing
+    write_escalations
+    FileUtils.rm_rf(@worktree)
+
+    assert_nil predicate.call({ launcher_clean: true }, @task)
+  end
+end
