+    # Sentinel-missing tolerant completion. Only invoked at the
+    # exit_code_only deadline when a caller supplied a `completion_fallback`
+    # predicate. Gathers launcher-owned evidence (the sentinel is missing,
+    # whether the tmux pane exited cleanly vs crashed/unreadable) and defers
+    # the accept/reject decision to the caller's predicate, which inspects
+    # phase-specific artifacts. Returns an `:ok` envelope tagged
+    # `fallback: true` on accept (and emits a `claude_completion_fallback`
+    # audit event), or nil to fall through to the strict `:timeout`.
+    def try_completion_fallback(task, runner, completion_fallback)
+      evidence = collect_completion_evidence(task, runner)
+      # A crashed / unreadable pane is a genuine failure, not a stop-hook
+      # race — never let a stale predicate launder it into success.
+      return nil unless evidence[:launcher_clean]
+
+      payload = completion_fallback.call(evidence, task)
+      return nil unless payload
+
+      payload = {} unless payload.is_a?(Hash)
+      emit_completion_fallback_event(task, evidence, payload)
+      {
+        status: :ok,
+        fallback: true,
+        fallback_evidence: evidence.merge(payload),
+        log_label: payload[:log_label]
+      }
+    rescue StandardError => e
+      # A predicate that raises must not be treated as success — fall
+      # through to the strict timeout so genuine failures stay strict.
+      warn "[hive] completion fallback predicate raised: #{e.class}: #{e.message}"
+      nil
+    end
+
+    # Launcher-owned completion evidence gathered at the exit_code_only
+    # deadline. `launcher_clean` is the launcher's own gate: the tmux pane
+    # must be readable and its session (when the runner tracks one) present,
+    # so a crashed Claude or an unreadable pane is never mistaken for a
+    # clean-exit-but-sentinel-missing race. A nil runner (unit harness)
+    # counts as clean so the predicate is still consulted.
+    def collect_completion_evidence(task, runner)
+      session_alive = completion_session_alive?(runner)
+      pane_readable, pane_tail = completion_pane_state(runner)
+      {
+        sentinel_missing: true,
+        sentinel_path: done_path(task),
+        result_path: result_path(task),
+        session_alive: session_alive,
+        pane_readable: pane_readable,
+        pane_tail: pane_tail,
+        # Whether Claude has returned to its idle prompt (turn finished).
+        # A positive signal for the predicate; not a hard launcher gate
+        # because the ready-prompt detector is Claude-Code-version sensitive
+        # (see recent tmux ready-prompt detection fixes) and a nil runner in
+        # the unit harness has no pane to inspect.
+        ready_prompt: pane_readable && claude_ready_prompt?(pane_tail),
+        missing_signal_reason: "stop_hook_sentinel_missing",
+        launcher_clean: pane_readable && session_alive
+      }
+    end
+
+    # True when the runner either doesn't track a session (nil runner in the
+    # unit harness, or a runner without `session_exists?`) or reports the
+    # session present. A session that has vanished at the deadline is
+    # abnormal for the exit_code_only spawn (Claude idles at its prompt
+    # after finishing a single request) and is treated as not-clean.
+    def completion_session_alive?(runner)
+      return true unless runner.respond_to?(:session_exists?)
+
+      runner.session_exists?
+    rescue Hive::TmuxError
+      false
+    end
+
+    def completion_pane_state(runner)
+      return [ true, "" ] unless runner.respond_to?(:capture_pane_tail)
+
+      [ true, runner.capture_pane_tail(bytes: SENTINEL_CAPTURE_BYTES) ]
+    rescue Hive::TmuxError
+      [ false, "" ]
+    end
+
+    # Emit the non-error `claude_completion_fallback` audit event so a
+    # sentinel-missing acceptance is recorded in events.jsonl. WARN-level is
+    # semantic (events.jsonl has no severity field). Launcher-owned fields
+    # (sentinel path, missing-signal reason) are always present; the
+    # predicate supplies phase/pass/artifact/commit context. Best-effort —
+    # an events failure must not flip the accepted result to a failure.
+    def emit_completion_fallback_event(task, evidence, payload)
+      pairs = {
+        phase: payload[:phase],
+        pass: payload[:pass],
+        pid: read_claude_pid(task),
+        session: payload[:session],
+        sentinel: evidence[:sentinel_path],
+        reason: evidence[:missing_signal_reason],
+        artifacts: payload[:artifacts],
+        evidence: payload[:evidence],
+        slug: task.respond_to?(:slug) ? task.slug : nil
+      }
+      message = pairs.compact.map { |k, v| "#{k}=#{v}" }.join(" ")
+      Hive::Events.emit(
+        task_folder: task.folder,
+        slug: task.respond_to?(:slug) ? task.slug : nil,
+        stage: payload[:stage] || "6-review", # coding-scoped: default stage for the review-fix fallback caller
+        event_type: :claude_completion_fallback,
+        agent: payload[:agent],
+        message: message
+      )
+    rescue StandardError => e
+      warn "[hive] could not emit claude_completion_fallback event: #{e.class}: #{e.message}"
+      nil
+    end
+
+    # The claude pane pid is stashed on the task lock by
+    # `record_claude_pid`. Best-effort read for the audit event payload —
+    # a missing/unparseable lock just omits the pid.
+    def read_claude_pid(task)
+      lock_path = File.join(task.folder, ".lock")
+      return nil unless File.exist?(lock_path)
+
+      data = YAML.safe_load(File.read(lock_path))
+      return nil unless data.is_a?(Hash)
+
+      pid = data["claude_pid"]
+      pid.nil? ? nil : pid.to_s[0, 32]
+    rescue SystemCallError, IOError, Psych::SyntaxError
+      nil
+    end
+
     # Read `result.json` (if present) and translate `status` into the
     # caller's symbol vocabulary. Unknown / unparseable shapes return
     # nil so the caller can fall through to its default success path.
