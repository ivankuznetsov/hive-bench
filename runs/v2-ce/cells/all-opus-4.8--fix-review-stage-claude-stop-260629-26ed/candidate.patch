       with_tmp_git_repo do |dir|
diff --git a/test/unit/claude_launcher_test.rb b/test/unit/claude_launcher_test.rb
index 1d6b2589..c149b45b 100644
--- a/test/unit/claude_launcher_test.rb
+++ b/test/unit/claude_launcher_test.rb
@@ -1227,6 +1227,160 @@ class ClaudeLauncherTest < Minitest::Test
     end
   end
 
+  # --- U2/U3: tolerant completion fallback -------------------------------
+
+  def clean_exit_runner(tail = "")
+    Struct.new(:tail) do
+      def session_exists? = true
+      def capture_pane_tail(bytes:) = tail
+    end.new(tail)
+  end
+
+  def read_events(task)
+    path = File.join(task.folder, "events.jsonl")
+    return [] unless File.exist?(path)
+
+    File.readlines(path).map { |l| JSON.parse(l) }
+  end
+
+  # Sentinel missing + a predicate that proves completion + a clean tmux
+  # exit → accept as success (fallback: true) and emit a
+  # claude_completion_fallback audit event. This is the whole point of the
+  # seam: a stop-hook race must not strand completed work.
+  def test_wait_for_done_signal_fallback_accepts_clean_exit
+    with_tmp_task do |task|
+      runner = clean_exit_runner
+      predicate = lambda do |evidence, cb_task|
+        assert evidence[:sentinel_missing]
+        assert evidence[:launcher_clean]
+        assert_equal task.folder, cb_task.folder
+        { phase: "fix", pass: 1, stage: "6-review",
+          agent: "fix-pass-01", evidence: "worktree_changes_pending_commit",
+          artifacts: "reviews/escalations-01.md", log_label: "ci" }
+      end
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, runner, 0, "ci", completion_fallback: predicate
+      )
+
+      assert_equal :ok, result.fetch(:status)
+      assert result.fetch(:fallback)
+      assert_equal "ci", result.fetch(:log_label)
+      refute_match(/stop hook did not signal/, result[:error_message].to_s)
+
+      events = read_events(task)
+      fallback = events.find { |e| e["event_type"] == "claude_completion_fallback" }
+      refute_nil fallback
+      assert_match(/phase=fix/, fallback["message"])
+      assert_match(/pass=1/, fallback["message"])
+      assert_match(%r{sentinel=#{Regexp.escape(Hive::ClaudeLauncher.done_path(task))}}, fallback["message"])
+      assert_match(/reason=stop_hook_sentinel_missing/, fallback["message"])
+      assert_match(/evidence=worktree_changes_pending_commit/, fallback["message"])
+    end
+  end
+
+  # No predicate supplied → historical behavior byte-for-byte: the strict
+  # timeout with the exact "did not signal completion" message. Protects
+  # every exit_code_only caller that hasn't opted in (R4/R9).
+  def test_wait_for_done_signal_without_predicate_times_out_strictly
+    with_tmp_task do |task|
+      result = Hive::ClaudeLauncher.wait_for_done_signal(task, clean_exit_runner, 0, "ci")
+
+      assert_equal :timeout, result.fetch(:status)
+      assert_match(/stop hook did not signal completion/, result.fetch(:error_message))
+      assert_empty read_events(task)
+    end
+  end
+
+  # Predicate returns nil (cannot prove completion) → strict timeout kept.
+  def test_wait_for_done_signal_fallback_rejects_when_predicate_false
+    with_tmp_task do |task|
+      predicate = ->(_evidence, _task) { nil }
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, clean_exit_runner, 0, "ci", completion_fallback: predicate
+      )
+
+      assert_equal :timeout, result.fetch(:status)
+      assert_match(/stop hook did not signal completion/, result.fetch(:error_message))
+      assert_empty read_events(task)
+    end
+  end
+
+  # An unreadable pane is a genuine failure (crash / tmux gone), not a
+  # stop-hook race — the predicate must not even be consulted, so a stale
+  # predicate cannot launder a crash into success (strict, R4).
+  def test_wait_for_done_signal_fallback_skips_predicate_on_unreadable_pane
+    with_tmp_task do |task|
+      unreadable = Struct.new(:x) do
+        def session_exists? = true
+        def capture_pane_tail(bytes:) = raise(Hive::TmuxError, "pane gone")
+      end.new(nil)
+      consulted = false
+      predicate = ->(_evidence, _task) { consulted = true; { phase: "fix" } }
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, unreadable, 0, "ci", completion_fallback: predicate
+      )
+
+      assert_equal :timeout, result.fetch(:status)
+      refute consulted, "predicate must not be consulted when the pane is unreadable"
+      assert_empty read_events(task)
+    end
+  end
+
+  # A vanished session at the deadline is abnormal for the single-request
+  # exit_code_only spawn (Claude idles after finishing) → strict.
+  def test_wait_for_done_signal_fallback_skips_predicate_on_vanished_session
+    with_tmp_task do |task|
+      vanished = Struct.new(:x) do
+        def session_exists? = false
+        def capture_pane_tail(bytes:) = ""
+      end.new(nil)
+      consulted = false
+      predicate = ->(_evidence, _task) { consulted = true; { phase: "fix" } }
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, vanished, 0, "ci", completion_fallback: predicate
+      )
+
+      assert_equal :timeout, result.fetch(:status)
+      refute consulted
+    end
+  end
+
+  # A predicate that raises must never be treated as success — fall through
+  # to the strict timeout so genuine failures stay strict.
+  def test_wait_for_done_signal_fallback_swallows_predicate_error
+    with_tmp_task do |task|
+      predicate = ->(_evidence, _task) { raise "boom" }
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, clean_exit_runner, 0, "ci", completion_fallback: predicate
+      )
+
+      assert_equal :timeout, result.fetch(:status)
+      assert_match(/stop hook did not signal completion/, result.fetch(:error_message))
+    end
+  end
+
+  # Sentinel present short-circuits before the fallback is ever considered:
+  # a supplied predicate does not change the happy path.
+  def test_wait_for_done_signal_fallback_not_reached_when_sentinel_present
+    with_tmp_task do |task|
+      File.write(Hive::ClaudeLauncher.done_path(task), "done")
+      consulted = false
+      predicate = ->(_e, _t) { consulted = true; { phase: "fix" } }
+
+      result = Hive::ClaudeLauncher.wait_for_done_signal(
+        task, clean_exit_runner, 1, "ci", completion_fallback: predicate
+      )
+
+      assert_equal({ status: :ok, log_label: "ci" }, result)
+      refute consulted
+    end
+  end
+
