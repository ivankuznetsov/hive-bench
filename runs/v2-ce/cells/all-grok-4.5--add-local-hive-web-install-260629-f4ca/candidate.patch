+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/local_preflight"
+
+class LocalPreflightTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_dependency_rows_include_web_and_daemon
+    which = ->(name) { "/bin/#{name}" }
+    rows = Hive::LocalPreflight.dependency_rows(which: which)
+    names = rows.map { |r| r[:name] }
+    assert_includes names, "ruby"
+    assert_includes names, "sqlite3"
+    assert_includes names, "web_app"
+    assert_includes names, "daemon_binary"
+    assert_includes names, "claude"
+  end
+
+  def test_sqlite3_row_reports_loadable_or_fix
+    row = Hive::LocalPreflight.sqlite3_row
+    assert_equal "sqlite3", row[:name]
+    assert_includes %i[ok missing warn], row[:status]
+    if row[:status] == :missing
+      assert_match(/libsqlite3-dev|sqlite/, row[:fix])
+    end
+  end
+
+  def test_platform_windows_unsupported
+    msg = Hive::LocalPreflight.platform_message(host_os: "mingw32")
+    assert_equal :fail, msg[:status]
+    assert_match(/hivebox|Docker/i, msg[:message])
+  end
+
+  def test_daemon_binary_row_warns_on_version_skew
+    require "hive/daemon/binary_consistency"
+    require "hive/commands/daemon/service_installer"
+    original_probe = Hive::Daemon::BinaryConsistency.method(:probe)
+    original_new = Hive::Commands::Daemon::ServiceInstaller.method(:new)
+    Hive::Daemon::BinaryConsistency.define_singleton_method(:probe) do |**_|
+      {
+        "binary_matches_cli" => true,
+        "version_matches_cli" => false,
+        "repair_hint" => "Daemon unit binary reports version \"0.0.1\" but CLI is newer",
+        "repair_command" => "hive daemon install --force",
+        "unit_binary_path" => "/tmp/hive",
+        "cli_binary_path" => "/tmp/hive"
+      }
+    end
+    Hive::Commands::Daemon::ServiceInstaller.define_singleton_method(:new) do |**_|
+      Object.new.tap do |obj|
+        def obj.service_state
+          {
+            "service_installed" => true,
+            "unit_path" => "/tmp/hive-daemon.service"
+          }
+        end
+      end
+    end
+
+    begin
+      row = Hive::LocalPreflight.daemon_binary_row
+      assert_equal :warn, row[:status]
+      assert_match(/version|install --force/i, row[:message])
+      assert_equal "hive daemon install --force", row[:fix]
+    ensure
+      Hive::Daemon::BinaryConsistency.define_singleton_method(:probe, original_probe)
+      Hive::Commands::Daemon::ServiceInstaller.define_singleton_method(:new, original_new)
+    end
+  end
+end
