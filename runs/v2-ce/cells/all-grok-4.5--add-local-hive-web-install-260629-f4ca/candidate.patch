+    <dt>CLI binary</dt>
+    <dd><code><%= @daemon["binary_path"] || "—" %></code></dd>
+    <dt>Unit binary</dt>
+    <dd><code><%= @daemon["unit_binary_path"] || "—" %></code></dd>
+    <dt>Binary matches CLI</dt>
+    <dd><%= @daemon["binary_matches_cli"].inspect %></dd>
+    <dt>CLI version</dt>
+    <dd><code><%= @daemon["cli_version"] || "—" %></code></dd>
+    <dt>Unit binary version</dt>
+    <dd><code><%= @daemon["unit_version"] || "—" %></code></dd>
+    <dt>Version matches CLI</dt>
+    <dd><%= @daemon["version_matches_cli"].inspect %></dd>
+  </dl>
+
+  <% if @daemon["repair_hint"] %>
+    <div class="flash flash-alert" role="alert"><%= @daemon["repair_hint"] %></div>
+  <% end %>
+
+  <div class="btn-row">
+    <%= button_to "Restart service",
+          restart_daemon_path,
+          method: :post,
+          class: "btn-secondary btn-sm",
+          data: { turbo_confirm: "Restart the hive-daemon service?" } %>
+    <%= button_to "Repair install",
