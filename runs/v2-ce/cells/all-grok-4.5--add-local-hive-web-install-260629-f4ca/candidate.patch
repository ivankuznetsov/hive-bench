diff --git a/lib/hive/daemon/binary_consistency.rb b/lib/hive/daemon/binary_consistency.rb
new file mode 100644
index 00000000..7d67c315
--- /dev/null
+++ b/lib/hive/daemon/binary_consistency.rb
@@ -0,0 +1,243 @@
+# frozen_string_literal: true
+
+require "cgi"
+require "open3"
+require "yaml"
+require "hive"
+require "hive/invoked_binary"
+
+module Hive
+  module Daemon
+    # Compares the CLI's Hive binary/version with the managed unit file
+    # (and optional running process path) so setup/doctor/web repair can
+    # detect drift to a stale `/usr/bin/hive` or an outdated unit.
+    module BinaryConsistency
+      module_function
+
+      # @return [Hash] wire-friendly consistency report
+      # pid_file: path to probe, nil = default state-home pidfile, false = skip
+      def probe(cli_path: nil, unit_path: nil, unit_body: nil, pid_file: nil)
+        cli = cli_path || Hive::InvokedBinary.path
+        unit_binary = extract_binary_from_unit(unit_path: unit_path, unit_body: unit_body)
+        cli_version = Hive::VERSION
+        unit_matches =
+          if cli.nil? || unit_binary.nil?
+            nil
+          else
+            File.expand_path(cli) == File.expand_path(unit_binary)
+          end
+
+        # Plan U5: when a live daemon pidfile is present, compare the
+        # running process CLI path too. A unit file that matches is not
+        # enough if the live process still points at a different binary.
+        running_binary =
+          if pid_file == false
+            nil
+          else
+            probe_running_binary_path(pid_file: pid_file)
+          end
+        running_matches =
+          if cli.nil? || running_binary.nil?
+            nil
+          else
+            paths_equal?(cli, running_binary)
+          end
+
+        matches =
+          if running_matches == false
+            false
+          else
+            unit_matches
+          end
+
+        unit_version = probe_binary_version(unit_binary)
+        version_matches =
+          if unit_binary.nil? || unit_version.nil?
+            nil
+          else
+            unit_version == cli_version
+          end
+
+        collision = apache_hive_collision?(cli) || apache_hive_collision?(unit_binary)
+
+        {
+          "cli_binary_path" => cli,
+          "unit_binary_path" => unit_binary,
+          "running_binary_path" => running_binary,
+          "binary_matches_cli" => matches,
+          "cli_version" => cli_version,
+          "unit_version" => unit_version,
+          "version_matches_cli" => version_matches,
+          "apache_hive_collision" => collision,
+          "repair_command" => "hive daemon install --force",
+          "repair_hint" => repair_hint(
+            matches: matches,
+            version_matches: version_matches,
+            collision: collision,
+            cli: cli,
+            unit_binary: unit_binary,
+            running_binary: running_binary,
+            running_matches: running_matches,
+            cli_version: cli_version,
+            unit_version: unit_version
+          )
+        }
+      end
+
+      def extract_binary_from_unit(unit_path: nil, unit_body: nil)
+        body = unit_body
+        if body.nil? && unit_path && File.file?(unit_path)
+          body = File.read(unit_path)
+        end
+        return nil if body.nil? || body.empty?
+
+        # systemd: ExecStart=/path/to/hive daemon start
+        #          Environment=HIVE_BIN=/path/to/hive
+        if (m = body.match(/^Environment=HIVE_BIN=(.+)$/))
+          return unshell(m[1].strip)
+        end
+        if (m = body.match(/^ExecStart=(\S+)/))
+          return unshell(m[1])
+        end
+
+        # launchd plist: <string>/path/to/hive</string> after ProgramArguments
+        if (m = body.match(%r{<string>([^<]*/(?:hive|hv))</string>}))
+          return CGI.unescapeHTML(m[1])
+        end
+
+        nil
+      rescue StandardError
+        nil
+      end
+
+      def unshell(value)
+        # Shellwords.escape leaves path alone if no special chars; strip
+        # surrounding single quotes that Shellwords.escape may add.
+        require "shellwords"
+        Shellwords.split(value).first || value
+      rescue ArgumentError
+        value.delete_prefix("'").delete_suffix("'")
+      end
+
+      def apache_hive_collision?(path)
+        return false if path.nil? || path.empty?
+
+        # Classic collision: distro package installs Apache Hive CLI at
+        # /usr/bin/hive which is not this project.
+        return true if path == "/usr/bin/hive" && !hive_cli_version_ok?(path)
+
+        false
+      end
+
+      def hive_cli_version_ok?(path)
+        !probe_binary_version(path).nil?
+      rescue StandardError
+        false
+      end
+
+      # Run `<binary> --version` and extract a semver-ish token.
+      # Returns nil when the binary is missing, fails, or is not Hive.
+      def probe_binary_version(path)
+        return nil if path.nil? || path.empty?
+        return nil unless File.file?(path) && File.executable?(path)
+
+        out, _err, status = Open3.capture3(path, "--version")
+        return nil unless status.success?
+
+        m = out.to_s.match(/(\d+\.\d+\.\d+(?:[-+][0-9A-Za-z.-]+)?)/)
+        m && m[1]
+      rescue StandardError
+        nil
+      end
+
+      def repair_hint(matches:, version_matches:, collision:, cli:, unit_binary:,
+                      cli_version:, unit_version:, running_binary: nil,
+                      running_matches: nil)
+        if collision
+          return "Possible Apache Hive collision at #{unit_binary || cli}. " \
+                 "Install this project's CLI as `hv` or a user-local path, " \
+                 "then run `hive daemon install --force`."
+        end
+        if running_matches == false
+          return "Running daemon process binary #{running_binary.inspect} differs " \
+                 "from CLI #{cli.inspect} (unit may still match). " \
+                 "Run `hive daemon install --force` to repair and restart."
+        end
+        if matches == false
+          return "Daemon unit binary #{unit_binary.inspect} differs from CLI " \
+                 "#{cli.inspect}. Run `hive daemon install --force` to repair."
+        end
+        if version_matches == false
+          return "Daemon unit binary reports version #{unit_version.inspect} " \
+                 "but CLI is #{cli_version.inspect} (same path after upgrade). " \
+                 "Run `hive daemon install --force` to refresh the unit."
+        end
+
+        nil
+      end
+
+      # Resolve the live daemon CLI path from the pidfile when available.
+      # Linux: prefer /proc/<pid>/cmdline (Ruby shebang CLIs show the script
+      # path there; /proc/<pid>/exe points at the interpreter). Fall back to
+      # exe only when cmdline has no hive/hv path. Other platforms: nil.
+      def probe_running_binary_path(pid_file: nil)
+        path = pid_file || default_daemon_pid_file
+        return nil if path.nil? || !File.file?(path)
+
+        pid = read_daemon_pid(path)
+        return nil if pid.nil? || pid <= 0
+
+        from_cmdline = running_path_from_cmdline(pid)
+        return from_cmdline if from_cmdline
+
+        exe_link = "/proc/#{pid}/exe"
+        return nil unless File.exist?(exe_link) || File.symlink?(exe_link)
+
+        File.readlink(exe_link)
+      rescue StandardError
+        nil
+      end
+
+      def running_path_from_cmdline(pid)
+        raw = File.read("/proc/#{pid}/cmdline")
+        return nil if raw.nil? || raw.empty?
+
+        args = raw.split("\0").reject(&:empty?)
+        args.find do |arg|
+          base = File.basename(arg.to_s)
+          (base == "hive" || base == "hv") && (arg.start_with?("/") ? File.exist?(arg) : true)
+        end
+      rescue StandardError
+        nil
+      end
+
+      def default_daemon_pid_file
+        require "hive/paths"
+        File.join(Hive::Paths.state_home, ".daemon.pid")
+      rescue StandardError
+        nil
+      end
+
+      def read_daemon_pid(path)
+        raw = File.read(path)
+        parsed = begin
+          YAML.safe_load(raw, permitted_classes: [ Time ])
+        rescue StandardError
+          nil
+        end
+        return parsed["pid"].to_i if parsed.is_a?(Hash) && parsed["pid"]
+
+        return raw.strip.to_i if raw.strip =~ /\A\d+\z/
+
+        nil
+      end
+
+      def paths_equal?(a, b)
+        # /proc/<pid>/exe may append " (deleted)" after an in-place replace.
+        left = a.to_s.sub(/ \(deleted\)\z/, "")
+        right = b.to_s.sub(/ \(deleted\)\z/, "")
+        File.expand_path(left) == File.expand_path(right)
+      end
+    end
+  end
+end
diff --git a/lib/hive/local_preflight.rb b/lib/hive/local_preflight.rb
new file mode 100644
index 00000000..d7ec6bf2
--- /dev/null
+++ b/lib/hive/local_preflight.rb
@@ -0,0 +1,239 @@
+# frozen_string_literal: true
+
+require "open3"
+require "rbconfig"
+require "hive"
+require "hive/web/app_locator"
+require "hive/daemon/binary_consistency"
+
+module Hive
+  # Shared dependency / local-web probes used by `hive setup` and
+  # `hive doctor` so the two surfaces cannot drift.
+  module LocalPreflight
+    module_function
+
+    # @return [Array<Hash>] probe rows with keys:
+    #   name, status (:ok/:missing/:warn/:fail), message, fix (optional), severity (:blocker/:warning)
+    def dependency_rows(which: method(:default_which))
+      rows = []
+      rows << ruby_row
+      rows << command_row("git", which: which, fix: "Install git (apt/brew/pacman)")
+      rows << command_row("tmux", which: which, fix: "Install tmux (apt/brew/pacman)")
+      rows << command_row("node", which: which, fix: "Install Node.js 18+ (https://nodejs.org or nvm/mise)")
+      rows << command_row("npm", which: which, fix: "Install npm (ships with Node.js)")
+      rows << agent_row("gh", which: which, auth_check: ->(path) { auth_ok?(path, "auth", "status") },
+                        fix: "Install GitHub CLI (https://cli.github.com) then run `gh auth login`")
+      rows << agent_row("claude", which: which, auth_check: nil,
+                        fix: "Install Claude Code CLI, then run `claude` once to authenticate")
+      rows << agent_row("codex", which: which, auth_check: nil,
+                        fix: "Install OpenAI Codex CLI, then run `codex login`")
+      rows << qmd_row(which: which)
+      rows << sqlite3_row
+      rows << web_app_row
+      rows << daemon_binary_row
+      rows
+    end
+
+    def platform_supported?(host_os: RbConfig::CONFIG["host_os"])
+      !!(host_os =~ /linux|darwin/i)
+    end
+
+    def platform_message(host_os: RbConfig::CONFIG["host_os"])
+      if platform_supported?(host_os: host_os)
+        { status: :ok, message: "platform #{host_os} supported for local web" }
+      else
+        {
+          status: :fail,
+          message: "local web mode supports Linux and macOS only (detected #{host_os}). " \
+                   "On Windows use Docker/hivebox: see packaging/docker/install-box.ps1"
+        }
+      end
+    end
+
+    def ruby_row
+      ver = RUBY_VERSION
+      ok = Gem::Version.new(ver) >= Gem::Version.new("3.4.0")
+      {
+        name: "ruby",
+        status: ok ? :ok : :fail,
+        severity: ok ? :warning : :blocker,
+        message: "Ruby #{ver}",
+        fix: ok ? nil : "Install Ruby >= 3.4 (mise/rbenv/apt/brew)"
+      }
+    end
+
+    # Cheap native-gem readiness probe so setup does not exit 0 only to
+    # fail at first `db:prepare` on hosts missing libsqlite3 headers.
+    def sqlite3_row
+      require "sqlite3"
+      ver = defined?(SQLite3::VERSION) ? SQLite3::VERSION : "loaded"
+      {
+        name: "sqlite3",
+        status: :ok,
+        severity: :blocker,
+        message: "sqlite3 gem loadable (#{ver})",
+        fix: nil
+      }
+    rescue LoadError
+      {
+        name: "sqlite3",
+        status: :missing,
+        severity: :blocker,
+        message: "sqlite3 gem not loadable (native extension / build deps missing)",
+        fix: "Install SQLite dev headers then re-install the gem: " \
+             "apt: sudo apt install libsqlite3-dev && gem install sqlite3; " \
+             "brew: brew install sqlite && gem install sqlite3; " \
+             "fedora/rhel: sudo dnf install sqlite-devel && gem install sqlite3"
+      }
+    rescue StandardError => e
+      {
+        name: "sqlite3",
+        status: :warn,
+        severity: :blocker,
+        message: "sqlite3 probe failed (#{e.class}: #{e.message})",
+        fix: "Install libsqlite3-dev / sqlite (brew) then `gem install sqlite3`"
+      }
+    end
+
+
+    def command_row(name, which:, fix:)
+      path = which.call(name)
+      if path
+        { name: name, status: :ok, severity: :warning, message: path, fix: nil }
+      else
+        severity = %w[git].include?(name) ? :blocker : :warning
+        { name: name, status: :missing, severity: severity, message: "#{name} not found on PATH", fix: fix }
+      end
+    end
+
+    def agent_row(name, which:, auth_check:, fix:)
+      path = which.call(name)
+      unless path
+        return {
+          name: name,
+          status: :missing,
+          severity: :warning,
+          message: "#{name} not found on PATH",
+          fix: fix
+        }
+      end
+
+      if auth_check
+        unless auth_check.call(path)
+          return {
+            name: name,
+            status: :warn,
+            severity: :warning,
+            message: "#{path} present but not authenticated",
+            fix: fix
+          }
+        end
+      end
+
+      { name: name, status: :ok, severity: :warning, message: path, fix: nil }
+    end
+
+    def qmd_row(which:)
+      path = find_qmd(which: which)
+      if path
+        { name: "qmd", status: :ok, severity: :warning, message: path, fix: nil }
+      else
+        {
+          name: "qmd",
+          status: :missing,
+          severity: :warning,
+          message: "qmd not installed",
+          fix: "npm install --global --prefix \"${XDG_DATA_HOME:-$HOME/.local/share}/hive/qmd\" @tobilu/qmd"
+        }
+      end
+    end
+
+    def web_app_row
+      dir = Hive::Web::AppLocator.locate
+      if dir
+        ver = Hive::Web::AppLocator.recorded_version(dir)
+        msg = ver ? "#{dir} (version #{ver})" : dir
+        { name: "web_app", status: :ok, severity: :blocker, message: msg, fix: nil }
+      else
+        {
+          name: "web_app",
+          status: :missing,
+          severity: :blocker,
+          message: "Rails web app not found",
+          fix: "hive setup  # or hive web install"
+        }
+      end
+    end
+
+    def daemon_binary_row
+      require "hive/commands/daemon/service_installer"
+      state = Hive::Commands::Daemon::ServiceInstaller.new.service_state
+      report = Hive::Daemon::BinaryConsistency.probe(unit_path: state["unit_path"])
+      # Path mismatch and same-path version skew both need force reinstall —
+      # treat either like a repair-needed warn (plan U5 / doctor consumers).
+      if report["binary_matches_cli"] == false || report["version_matches_cli"] == false
+        {
+          name: "daemon_binary",
+          status: :warn,
+          severity: :blocker,
+          message: report["repair_hint"] || "daemon unit binary differs from CLI",
+          fix: report["repair_command"] || "hive daemon install --force"
+        }
+      elsif !state["service_installed"]
+        {
+          name: "daemon_binary",
+          status: :missing,
+          severity: :blocker,
+          message: "daemon unit not installed",
+          fix: "hive daemon install"
+        }
+      else
+        {
+          name: "daemon_binary",
+          status: :ok,
+          severity: :blocker,
+          message: report["unit_binary_path"] || report["cli_binary_path"] || "installed",
+          fix: nil
+        }
+      end
+    rescue StandardError => e
+      {
+        name: "daemon_binary",
+        status: :warn,
+        severity: :warning,
+        message: "could not probe daemon unit (#{e.class}: #{e.message})",
+        fix: "hive daemon install --force"
+      }
+    end
+
+    def find_qmd(which:)
+      env_qmd = ENV["HIVE_QMD_BIN"].to_s
+      return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+      path_qmd = which.call("qmd")
+      return path_qmd if path_qmd
+
+      data_home = ENV["XDG_DATA_HOME"].to_s.empty? ? File.expand_path("~/.local/share") : ENV["XDG_DATA_HOME"]
+      candidates = [
+        File.join(data_home, "hive", "qmd", "bin", "qmd"),
+        File.expand_path("~/.local/share/hive/qmd/bin/qmd")
+      ]
+      candidates.find { |c| File.file?(c) && File.executable?(c) }
+    end
+
+    def auth_ok?(path, *args)
+      _out, _err, status = Open3.capture3(path, *args)
+      status.success?
+    rescue StandardError
+      false
+    end
+
+    def default_which(name)
+      ENV["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+        path = File.join(dir, name)
+        return path if File.file?(path) && File.executable?(path)
+      end
+      nil
+    end
+  end
+end
