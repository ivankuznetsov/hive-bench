+      File.write(hive, "#!/bin/sh\n")
+      FileUtils.chmod(0o755, hive)
+
+      calls = []
+      control = Hive::Web::DaemonControl.new(
+        home: home,
+        runner: ->(argv) { calls << argv; true }
+      )
+      # Point InvokedBinary at our hive for the installer's binary_path
+      with_env("HIVE_INVOKED_BIN" => hive) do
+        result = control.repair!
+        assert_equal true, result["ok"]
+        assert_equal "repair", result["action"]
+        unit = File.join(home, ".config/systemd/user/hive-daemon.service")
+        # On Linux hosts the unit is written under home.
+        if File.exist?(unit)
+          assert_includes File.read(unit), "daemon start"
+        end
+      end
+    end
+  end
+end
