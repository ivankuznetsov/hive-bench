diff --git a/packaging/build-web-archive.sh b/packaging/build-web-archive.sh
new file mode 100755
index 00000000..8bf7ae46
--- /dev/null
+++ b/packaging/build-web-archive.sh
@@ -0,0 +1,37 @@
+#!/usr/bin/env bash
+# Build the runtime hive-web-<version>.tar.gz asset attached to each release.
+# Contents: the Rails app under web/ minus test/tmp/log/storage/vendor/bundle.
+# Usage: packaging/build-web-archive.sh [version] [output-dir]
+set -euo pipefail
+
+root="$(cd "$(dirname "$0")/.." && pwd)"
+version="${1:-}"
+if [[ -z "$version" ]]; then
+  version="$(ruby -e 'require_relative "lib/hive"; puts Hive::VERSION' -C "$root")"
+fi
+outdir="${2:-"$root/dist"}"
+mkdir -p "$outdir"
+
+archive_name="hive-web-${version}.tar.gz"
+staging="$(mktemp -d)"
+trap 'rm -rf "$staging"' EXIT
+
+mkdir -p "$staging/web"
+# Runtime payload only — exclude test suite, ephemeral dirs, and local bundles.
+rsync -a \
+  --exclude 'test/' \
+  --exclude 'tmp/' \
+  --exclude 'log/' \
+  --exclude 'storage/' \
+  --exclude 'vendor/bundle/' \
+  --exclude '.git/' \
+  "$root/web/" "$staging/web/"
+
+# Ensure empty runtime dirs exist for first boot.
+# Do NOT bake .hive-web-version here — AppProvisioner writes that sidecar
+# only after a successful `bundle install` so half-provisioned trees never
+# look healthy. (copy_runtime_tree also strips any pre-baked sidecar.)
+mkdir -p "$staging/web/tmp/pids" "$staging/web/log" "$staging/web/storage"
+
+tar -czf "$outdir/$archive_name" -C "$staging" web
+echo "wrote $outdir/$archive_name ($(wc -c < "$outdir/$archive_name") bytes)"
