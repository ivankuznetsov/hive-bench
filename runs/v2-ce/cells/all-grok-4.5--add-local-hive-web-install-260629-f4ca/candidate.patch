+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/daemon/binary_consistency"
+
+class DaemonBinaryConsistencyTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_matching_binary_reports_true
+    with_tmp_dir do |dir|
+      hive = File.join(dir, "hive")
+      File.write(hive, "#!/bin/sh\necho #{Hive::VERSION}\n")
+      FileUtils.chmod(0o755, hive)
+      unit = File.join(dir, "hive-daemon.service")
+      File.write(unit, "ExecStart=#{hive} daemon start\nEnvironment=HIVE_BIN=#{hive}\n")
+
+      # pid_file: false isolates from a live host daemon during unit tests.
+      report = Hive::Daemon::BinaryConsistency.probe(
+        cli_path: hive, unit_path: unit, pid_file: false
+      )
+      assert_equal true, report["binary_matches_cli"]
+      assert_equal true, report["version_matches_cli"]
+      assert_equal Hive::VERSION, report["unit_version"]
+      assert_equal hive, report["cli_binary_path"]
+      assert_equal hive, report["unit_binary_path"]
+      assert_nil report["repair_hint"]
+    end
+  end
+
+  def test_mismatched_unit_reports_false_with_repair
+    with_tmp_dir do |dir|
+      cli = File.join(dir, "cli-hive")
+      unit_bin = File.join(dir, "old-hive")
+      File.write(cli, "#!/bin/sh\necho #{Hive::VERSION}\n")
+      File.write(unit_bin, "#!/bin/sh\necho 0.0.1\n")
+      FileUtils.chmod(0o755, cli)
+      FileUtils.chmod(0o755, unit_bin)
+      unit = File.join(dir, "hive-daemon.service")
+      File.write(unit, "ExecStart=#{unit_bin} daemon start\nEnvironment=HIVE_BIN=#{unit_bin}\n")
+
+      report = Hive::Daemon::BinaryConsistency.probe(
+        cli_path: cli, unit_path: unit, pid_file: false
+      )
+      assert_equal false, report["binary_matches_cli"]
+      assert_equal false, report["version_matches_cli"]
+      assert_match(/install --force/, report["repair_hint"])
+      assert_match(/install --force/, report["repair_command"])
+    end
+  end
+
+  def test_same_path_version_skew_after_upgrade
+    with_tmp_dir do |dir|
+      hive = File.join(dir, "hive")
+      # Same path as CLI, but binary still reports an older version (in-place
+      # upgrade where the unit was not refreshed / process not restarted).
+      File.write(hive, "#!/bin/sh\necho 0.0.1\n")
+      FileUtils.chmod(0o755, hive)
+      unit = File.join(dir, "hive-daemon.service")
+      File.write(unit, "ExecStart=#{hive} daemon start\nEnvironment=HIVE_BIN=#{hive}\n")
+
+      report = Hive::Daemon::BinaryConsistency.probe(
+        cli_path: hive, unit_path: unit, pid_file: false
+      )
+      assert_equal true, report["binary_matches_cli"]
+      assert_equal false, report["version_matches_cli"]
+      assert_equal "0.0.1", report["unit_version"]
+      assert_match(/reports version/, report["repair_hint"])
+    end
+  end
+
+  def test_launchd_plist_extraction
+    body = <<~XML
+      <string>/Users/me/.local/bin/hive</string>
+      <string>daemon</string>
+      <string>start</string>
+    XML
+    path = Hive::Daemon::BinaryConsistency.extract_binary_from_unit(unit_body: body)
+    assert_equal "/Users/me/.local/bin/hive", path
+  end
+
+  def test_running_cmdline_mismatch_reports_false
+    skip "requires /proc/<pid>/cmdline" unless File.file?("/proc/#{Process.pid}/cmdline")
+
+    with_tmp_dir do |dir|
+      hive = File.join(dir, "hive")
+      other = File.join(dir, "other-hive")
+      File.write(hive, "#!/bin/sh\necho #{Hive::VERSION}\n")
+      File.write(other, "#!/bin/sh\necho #{Hive::VERSION}\n")
+      FileUtils.chmod(0o755, hive)
+      FileUtils.chmod(0o755, other)
+      unit = File.join(dir, "hive-daemon.service")
+      # Unit matches CLI path...
+      File.write(unit, "ExecStart=#{hive} daemon start\nEnvironment=HIVE_BIN=#{hive}\n")
+      pid_file = File.join(dir, ".daemon.pid")
+      File.write(pid_file, "#{Process.pid}\n")
+
+      # ...but stub cmdline to pretend the live process is `other-hive`.
+      original = Hive::Daemon::BinaryConsistency.method(:running_path_from_cmdline)
+      Hive::Daemon::BinaryConsistency.define_singleton_method(:running_path_from_cmdline) do |_pid|
+        other
+      end
+      begin
+        report = Hive::Daemon::BinaryConsistency.probe(
+          cli_path: hive,
+          unit_path: unit,
+          pid_file: pid_file
+        )
+        assert_equal false, report["binary_matches_cli"]
+        assert_equal other, report["running_binary_path"]
+        assert_match(/Running daemon process binary/, report["repair_hint"])
+      ensure
+        Hive::Daemon::BinaryConsistency.define_singleton_method(:running_path_from_cmdline, original)
+      end
+    end
+  end
+end
