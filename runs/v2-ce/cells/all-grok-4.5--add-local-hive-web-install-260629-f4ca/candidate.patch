diff --git a/test/unit/commands/setup_test.rb b/test/unit/commands/setup_test.rb
new file mode 100644
index 00000000..b36d13d5
--- /dev/null
+++ b/test/unit/commands/setup_test.rb
@@ -0,0 +1,185 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "stringio"
+require "json"
+require "hive/commands/setup"
+
+class HiveCommandsSetupTest < Minitest::Test
+  include HiveTestHelper
+
+  def which_all_present
+    lambda do |name|
+      case name
+      when "git", "tmux", "node", "npm", "gh", "claude", "codex", "qmd"
+        "/usr/bin/#{name}"
+      end
+    end
+  end
+
+  def test_happy_path_with_stubs
+    with_tmp_global_config_and_home do |home|
+      # Stub rails app as source so provision finds it via HIVEBOX_WEB_APP_DIR.
+      web = File.join(home, "web")
+      FileUtils.mkdir_p(File.join(web, "config"))
+      File.write(File.join(web, "config", "application.rb"), "# rails")
+      File.write(File.join(web, "Gemfile"), "source 'https://rubygems.org'\n")
+
+      runner_calls = []
+      runner = lambda { |argv, **_kw|
+        runner_calls << argv
+        true
+      }
+
+      out = StringIO.new
+      with_env("HIVEBOX_WEB_APP_DIR" => web) do
+        code = Hive::Commands::Setup.new(
+          json: true,
+          project_path: home,
+          output: out,
+          runner: runner,
+          which: which_all_present
+        ).call
+        assert_equal 0, code, out.string
+        doc = JSON.parse(out.string)
+        assert_equal "hive-setup", doc["schema"]
+        assert_equal true, doc["ok"]
+        assert_match(%r{http://127\.0\.0\.1:4567}, doc["url"])
+        assert doc["phases"].any? { |p| p["name"] == "web_app" && p["status"] == "ok" }
+        assert doc["phases"].any? { |p| p["name"] == "daemon" }
+      end
+    end
+  end
+
+  def test_missing_claude_is_warning_not_blocker
+    with_tmp_global_config_and_home do |home|
+      web = File.join(home, "web")
+      FileUtils.mkdir_p(File.join(web, "config"))
+      File.write(File.join(web, "config", "application.rb"), "# rails")
+
+      which = lambda do |name|
+        return nil if name == "claude"
+        "/usr/bin/#{name}"
+      end
+
+      out = StringIO.new
+      with_env("HIVEBOX_WEB_APP_DIR" => web) do
+        code = Hive::Commands::Setup.new(
+          json: true,
+          project_path: home,
+          output: out,
+          runner: ->(*) { true },
+          which: which
+        ).call
+        assert_equal 0, code
+        doc = JSON.parse(out.string)
+        assert doc["warnings"].any? { |w| w["name"] == "claude" }
+        assert doc["warnings"].any? { |w| w["fix"].to_s.include?("claude") }
+      end
+    end
+  end
+
+  def test_unsupported_os_fails
+    original = Hive::LocalPreflight.method(:platform_message)
+    Hive::LocalPreflight.define_singleton_method(:platform_message) do |**_|
+      { status: :fail, message: "local web mode supports Linux and macOS only" }
+    end
+    begin
+      out = StringIO.new
+      code = Hive::Commands::Setup.new(
+        json: true,
+        output: out,
+        runner: ->(*) { true },
+        which: which_all_present
+      ).call
+      assert_equal Hive::Commands::Setup::EXIT_UNSUPPORTED, code
+      doc = JSON.parse(out.string)
+      assert_equal false, doc["ok"]
+    ensure
+      Hive::LocalPreflight.define_singleton_method(:platform_message, original)
+    end
+  end
+
+  def test_strict_treats_warnings_as_failure
+    with_tmp_global_config_and_home do |home|
+      web = File.join(home, "web")
+      FileUtils.mkdir_p(File.join(web, "config"))
+      File.write(File.join(web, "config", "application.rb"), "# rails")
+
+      which = lambda do |name|
+        return nil if name == "codex"
+        "/usr/bin/#{name}"
+      end
+
+      out = StringIO.new
+      with_env("HIVEBOX_WEB_APP_DIR" => web) do
+        code = Hive::Commands::Setup.new(
+          json: true,
+          strict: true,
+          project_path: home,
+          output: out,
+          runner: ->(*) { true },
+          which: which
+        ).call
+        assert_equal Hive::Commands::Setup::EXIT_BLOCKER, code
+      end
+    end
+  end
+
+  def test_ensure_daemon_restarts_when_unit_already_installed
+    with_tmp_global_config_and_home do |home|
+      web = File.join(home, "web")
+      FileUtils.mkdir_p(File.join(web, "config"))
+      File.write(File.join(web, "config", "application.rb"), "# rails")
+      File.write(File.join(web, "Gemfile"), "source 'https://rubygems.org'\n")
+
+      # Pre-install a matching unit so install! returns :unchanged without restart.
+      hive = File.join(home, "bin", "hive")
+      FileUtils.mkdir_p(File.dirname(hive))
+      File.write(hive, "#!/bin/sh\necho #{Hive::VERSION}\n")
+      FileUtils.chmod(0o755, hive)
+      unit_dir = File.join(home, ".config/systemd/user")
+      FileUtils.mkdir_p(unit_dir)
+      unit = File.join(unit_dir, "hive-daemon.service")
+      # Minimal unit that matches what ServiceInstaller would write is hard;
+      # instead let install write once, then re-run setup and assert restart.
+      runner_calls = []
+      runner = lambda { |argv, **_kw|
+        runner_calls << argv
+        true
+      }
+
+      out = StringIO.new
+      with_env("HIVEBOX_WEB_APP_DIR" => web, "HIVE_INVOKED_BIN" => hive, "HOME" => home) do
+        # First setup installs the unit.
+        Hive::Commands::Setup.new(
+          json: true,
+          project_path: home,
+          output: StringIO.new,
+          runner: runner,
+          which: which_all_present
+        ).call
+        runner_calls.clear
+
+        # Second setup: unit matches → install! :unchanged, must still restart.
+        code = Hive::Commands::Setup.new(
+          json: true,
+          project_path: home,
+          output: out,
+          runner: runner,
+          which: which_all_present
+        ).call
+        assert_equal 0, code, out.string
+        doc = JSON.parse(out.string)
+        daemon_phase = doc["phases"].find { |p| p["name"] == "daemon" }
+        assert daemon_phase, "expected daemon phase"
+        # On Linux hosts, expect an explicit restart invocation.
+        if RbConfig::CONFIG["host_os"] =~ /linux/i
+          assert runner_calls.any? { |a| a == %w[systemctl --user restart hive-daemon] },
+                 "same-path re-setup must restart live daemon, got: #{runner_calls.inspect}"
+          assert_match(/restart/, daemon_phase["message"])
+        end
+      end
+    end
+  end
+end
