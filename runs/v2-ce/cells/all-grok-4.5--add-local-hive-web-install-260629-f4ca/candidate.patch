+                name: "daemon",
+                message: "daemon unit unchanged after upgrade; restart failed",
+                fix: "hive daemon install --force"
+              }
+              record_phase(
+                "daemon",
+                :fail,
+                "install outcome=#{outcome.wire_outcome} but restart failed; " \
+                "binary=#{Hive::InvokedBinary.path}"
+              )
+              return
+            end
+            record_phase(
+              "daemon",
+              :ok,
+              "install outcome=#{outcome.wire_outcome}+restarted " \
+              "binary=#{Hive::InvokedBinary.path}"
+            )
+          else
+            record_phase(
+              "daemon",
+              outcome.success? ? :ok : :fail,
+              "install outcome=#{outcome.wire_outcome} binary=#{Hive::InvokedBinary.path}"
+            )
+          end
+          unless outcome.success?
+            @blockers << {
+              name: "daemon",
+              message: "daemon install #{outcome.wire_outcome}",
+              fix: "hive daemon install --force"
+            }
+          end
+        rescue StandardError => e
+          @blockers << { name: "daemon", message: e.message, fix: "hive daemon install --force" }
+          record_phase("daemon", :fail, e.message)
+        end
+      end
+
+      # Restart the managed daemon unit so an in-place CLI upgrade loads new
+      # code. Mirrors DaemonControl#restart! without the web dependency.
+      def restart_daemon_service(installer)
+        runner = installer.runner
+        case installer.envelope_platform
+        when "linux"
+          runner.call(%w[systemctl --user restart hive-daemon])
+        when "macos"
+          path = installer.target_path
+          return false unless path && File.exist?(path)
