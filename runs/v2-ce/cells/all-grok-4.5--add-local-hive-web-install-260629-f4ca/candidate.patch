+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/web/daemon_control"
+
+class WebDaemonControlTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_summary_reports_not_running_without_pidfile
+    with_tmp_global_config_and_home do
+      summary = Hive::Web::DaemonControl.new(runner: ->(*) { true }).summary
+      assert_equal false, summary["running"]
+      assert_equal false, summary["healthy"]
+    end
+  end
+
+  def test_healthy_requires_explicit_binary_match_true
+    with_tmp_global_config_and_home do |home|
+      # Live pid but unknown binary match (no unit) must not green-banner.
+      pid_file = File.join(Hive::Paths.state_home, ".daemon.pid")
+      FileUtils.mkdir_p(File.dirname(pid_file))
+      File.write(pid_file, "#{Process.pid}\n")
+      summary = Hive::Web::DaemonControl.new(home: home, runner: ->(*) { true }).summary
+      assert_equal true, summary["running"]
+      assert_nil summary["binary_matches_cli"]
+      assert_equal false, summary["healthy"],
