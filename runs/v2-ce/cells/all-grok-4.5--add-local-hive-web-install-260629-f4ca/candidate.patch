--- /dev/null
+++ b/web/app/controllers/daemon_controller.rb
@@ -0,0 +1,35 @@
+# frozen_string_literal: true
+
+class DaemonController < ApplicationController
+  before_action :require_operator_session
+
+  def show
+    @daemon = Hive::Web::DaemonControl.new.summary
+  end
+
+  def restart
+    result = Hive::Web::DaemonControl.new.restart!
+    redirect_to daemon_path, notice: "Daemon restart requested (#{result['action']})."
+  rescue Hive::Error => e
+    redirect_to daemon_path, alert: e.message
+  end
+
+  def repair
+    result = Hive::Web::DaemonControl.new.repair!
+    redirect_to daemon_path, notice: "Daemon repair complete (#{result['outcome']})."
+  rescue Hive::Error => e
+    redirect_to daemon_path, alert: e.message
+  end
+
+  private
+
+  # Loopback unauthenticated single-user is OK; non-loopback without a
+  # login must not hit repair/restart.
+  def require_operator_session
+    web_cfg = Hive::Config.load_global_web
+    return unless Hive::Web::AuthPolicy.require_login?(env: ENV, config: web_cfg)
+    return if current_login
+
+    redirect_to login_path, alert: "Sign in to manage the daemon."
+  end
+end
