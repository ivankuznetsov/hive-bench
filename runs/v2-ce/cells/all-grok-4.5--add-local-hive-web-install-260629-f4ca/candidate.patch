+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/web/app_locator"
+
+class WebAppLocatorTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_prefers_env_override
+    Dir.mktmpdir("hive-web-loc") do |dir|
+      FileUtils.mkdir_p(File.join(dir, "config"))
+      File.write(File.join(dir, "config", "application.rb"), "# rails")
+      with_env("HIVEBOX_WEB_APP_DIR" => dir) do
+        assert_equal dir, Hive::Web::AppLocator.locate
+      end
+    end
+  end
+
+  def test_falls_back_to_source_checkout_when_env_missing
+    with_env("HIVEBOX_WEB_APP_DIR" => nil) do
+      located = Hive::Web::AppLocator.locate
+      # This test runs from the monorepo checkout which has web/.
+      assert Hive::Web::AppLocator.rails_app?(located),
+             "expected a rails app, got #{located.inspect}"
+      assert_equal Hive::Web::AppLocator.source_checkout_web, located
+    end
+  end
+
+  def test_managed_path_used_when_checkout_and_env_absent
+    with_tmp_dir do |home|
+      managed = File.join(home, "share", "hive", "web-app")
+      FileUtils.mkdir_p(File.join(managed, "config"))
+      File.write(File.join(managed, "config", "application.rb"), "# rails")
+      with_env(
+        "HOME" => home,
+        "XDG_DATA_HOME" => File.join(home, "share"),
+        "HIVEBOX_WEB_APP_DIR" => nil,
+        "HIVE_HOME" => nil
+      ) do
+        # Stub source checkout so it does not resolve to the real monorepo web/.
+        original = Hive::Web::AppLocator.method(:source_checkout_web)
+        Hive::Web::AppLocator.define_singleton_method(:source_checkout_web) { File.join(home, "no-checkout") }
+        begin
+          assert_equal managed, Hive::Web::AppLocator.locate
+        ensure
+          Hive::Web::AppLocator.define_singleton_method(:source_checkout_web, original)
+        end
+      end
+    end
+  end
+
+  def test_missing_app_returns_nil
+    with_tmp_dir do |home|
+      with_env(
+        "HOME" => home,
+        "XDG_DATA_HOME" => File.join(home, "share"),
+        "HIVEBOX_WEB_APP_DIR" => File.join(home, "missing"),
+        "HIVE_HOME" => nil
+      ) do
+        original = Hive::Web::AppLocator.method(:source_checkout_web)
+        Hive::Web::AppLocator.define_singleton_method(:source_checkout_web) { File.join(home, "no-checkout") }
+        begin
+          assert_nil Hive::Web::AppLocator.locate
+        ensure
+          Hive::Web::AppLocator.define_singleton_method(:source_checkout_web, original)
+        end
+      end
+    end
+  end
+
+  def test_missing_app_guidance_names_setup
+    msg = Hive::Web::AppLocator.missing_app_guidance
+    assert_match(/hive setup/, msg)
+    assert_match(/hive web install/, msg)
+  end
+
+  def test_recorded_version_reads_sidecar
+    Dir.mktmpdir("hive-web-ver") do |dir|
+      File.write(File.join(dir, ".hive-web-version"), "9.9.9\n")
+      assert_equal "9.9.9", Hive::Web::AppLocator.recorded_version(dir)
+    end
+  end
+end
diff --git a/test/unit/web/app_provisioner_test.rb b/test/unit/web/app_provisioner_test.rb
new file mode 100644
index 00000000..ea7ddcf1
--- /dev/null
+++ b/test/unit/web/app_provisioner_test.rb
@@ -0,0 +1,289 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "digest"
+require "hive/web/app_provisioner"
+require "hive/web/app_locator"
+
+class WebAppProvisionerTest < Minitest::Test
+  include HiveTestHelper
+
+  def with_managed_home
+    with_tmp_dir do |home|
+      data = File.join(home, "share")
+      with_env(
+        "HOME" => home,
+        "XDG_DATA_HOME" => data,
+        "HIVE_HOME" => nil,
+        "HIVEBOX_WEB_APP_DIR" => nil
+      ) do
+        yield home, File.join(data, "hive", "web-app")
+      end
+    end
+  end
+
+  def make_source_app(dir)
+    FileUtils.mkdir_p(File.join(dir, "config"))
+    FileUtils.mkdir_p(File.join(dir, "bin"))
+    File.write(File.join(dir, "config", "application.rb"), "# rails app")
+    File.write(File.join(dir, "Gemfile"), "source 'https://rubygems.org'\n")
+    File.write(File.join(dir, "bin", "rails"), "#!/bin/sh\n")
+    FileUtils.chmod(0o755, File.join(dir, "bin", "rails"))
+    # Cruft that must not be copied into managed installs.
+    FileUtils.mkdir_p(File.join(dir, "test"))
+    File.write(File.join(dir, "test", "x_test.rb"), "omit")
+    FileUtils.mkdir_p(File.join(dir, "tmp"))
+    File.write(File.join(dir, "tmp", "junk"), "omit")
+  end
+
+  def test_idempotent_when_version_matches
+    with_managed_home do |_home, managed|
+      make_source_app(managed)
+      File.write(File.join(managed, ".hive-web-version"), "#{Hive::VERSION}\n")
+
+      runner_calls = []
+      provisioner = Hive::Web::AppProvisioner.new(
+        version: Hive::VERSION,
+        source_dir: File.join(Dir.tmpdir, "nope-#{$$}"),
+        runner: ->(argv, **_kw) { runner_calls << argv; true }
+      )
+      result = provisioner.provision!
+      assert_equal :unchanged, result.kind
+      assert_equal managed, result.app_dir
+      assert_empty runner_calls, "matching version must not re-run bundle/tar"
+    end
+  end
+
+  def test_reprovisions_on_version_mismatch_from_source
+    with_managed_home do |_home, managed|
+      make_source_app(managed)
+      File.write(File.join(managed, ".hive-web-version"), "0.0.1\n")
+
+      Dir.mktmpdir("hive-src-web") do |src|
+        make_source_app(src)
+        runner_calls = []
+        provisioner = Hive::Web::AppProvisioner.new(
+          version: "1.2.3",
+          source_dir: src,
+          runner: ->(argv, **_kw) { runner_calls << argv; true }
+        )
+        result = provisioner.provision!
+        assert_includes %i[installed updated], result.kind
+        assert_equal "1.2.3", Hive::Web::AppLocator.recorded_version(managed)
+        assert File.file?(File.join(managed, "config", "application.rb"))
+        refute File.exist?(File.join(managed, "test", "x_test.rb")),
+               "managed install must exclude test/"
+        assert runner_calls.any? { |a| a[0] == "bundle" }, "must run bundle install"
+      end
+    end
+  end
+
+  def test_offline_empty_managed_tree_fails_with_guidance
+    with_managed_home do |_home, managed|
+      provisioner = Hive::Web::AppProvisioner.new(
+        version: "9.9.9",
+        source_dir: File.join(Dir.tmpdir, "missing-web-#{$$}"),
+        http: ->(_url) { nil },
+        runner: ->(*) { true }
+      )
+      error = assert_raises(Hive::Error) { provisioner.provision! }
+      assert_match(/failed to download/, error.message)
+      assert_match(/source checkout|HIVEBOX_WEB_APP_DIR|offline/i, error.message)
+      refute Hive::Web::AppLocator.rails_app?(managed)
+    end
+  end
+
+  def test_download_archive_and_extract
+    with_managed_home do |_home, managed|
+      Dir.mktmpdir("hive-web-arch") do |src_root|
+        web = File.join(src_root, "web")
+        make_source_app(web)
+        tarball = File.join(src_root, "hive-web-2.0.0.tar.gz")
+        system("tar", "-czf", tarball, "-C", src_root, "web")
+        body = File.binread(tarball)
+        digest = Digest::SHA256.hexdigest(body)
+        sums = "#{digest}  hive-web-2.0.0.tar.gz\n"
+
+        provisioner = Hive::Web::AppProvisioner.new(
+          version: "2.0.0",
+          source_dir: File.join(Dir.tmpdir, "no-src-#{$$}"),
+          http: lambda { |url|
+            url.to_s.include?("SHA256SUMS") ? sums : body
+          },
+          runner: lambda { |argv, **_kw|
+            if argv[0] == "tar"
+              system(*argv)
+            else
+              true
+            end
+          }
+        )
+        result = provisioner.provision!
+        assert_equal :installed, result.kind
+        assert_equal "2.0.0", Hive::Web::AppLocator.recorded_version(managed)
+        assert File.file?(File.join(managed, "config", "application.rb"))
+      end
+    end
+  end
+
+  def test_download_rejects_sha256_mismatch
+    with_managed_home do |_home, _managed|
+      body = "not-a-real-tarball"
+      provisioner = Hive::Web::AppProvisioner.new(
+        version: "2.0.0",
+        source_dir: File.join(Dir.tmpdir, "no-src-#{$$}"),
+        http: lambda { |url|
+          if url.to_s.include?("SHA256SUMS")
+            "0" * 64 + "  hive-web-2.0.0.tar.gz\n"
+          else
+            body
+          end
+        },
+        runner: ->(*) { true }
+      )
+      error = assert_raises(Hive::Error) { provisioner.provision! }
+      assert_match(/SHA256 mismatch/, error.message)
+    end
+  end
+
+  def test_bundle_failure_does_not_seal_version_sidecar
+    with_managed_home do |_home, managed|
+      Dir.mktmpdir("hive-src-web") do |src|
+        make_source_app(src)
+        provisioner = Hive::Web::AppProvisioner.new(
+          version: "3.0.0",
+          source_dir: src,
+          runner: lambda { |argv, **_kw|
+            argv[0] == "bundle" ? false : true
+          }
+        )
+        error = assert_raises(Hive::Error) { provisioner.provision! }
+        assert_match(/bundle install failed/, error.message)
+        refute File.exist?(File.join(managed, ".hive-web-version")),
+               "failed provision must not leave a version sidecar"
+        refute Hive::Web::AppLocator.rails_app?(managed),
+               "failed provision must remove the incomplete managed tree"
+      end
+    end
+  end
+
+  # Release archives used to bake .hive-web-version into the tarball. If
+  # that pre-seal is copied before bundle and bundle fails/interrupts, the
+  # managed tree looks healthy. Regression: strip pre-baked sidecar and
+  # never leave a sealed incomplete tree.
+  def test_archive_prebaked_sidecar_stripped_on_bundle_failure
+    with_managed_home do |_home, managed|
+      Dir.mktmpdir("hive-web-arch") do |src_root|
+        web = File.join(src_root, "web")
+        make_source_app(web)
+        # Simulate a release archive that pre-sealed the version sidecar.
+        File.write(File.join(web, ".hive-web-version"), "2.0.0\n")
+        tarball = File.join(src_root, "hive-web-2.0.0.tar.gz")
+        system("tar", "-czf", tarball, "-C", src_root, "web")
+        body = File.binread(tarball)
+        digest = Digest::SHA256.hexdigest(body)
+        sums = "#{digest}  hive-web-2.0.0.tar.gz\n"
+
+        provisioner = Hive::Web::AppProvisioner.new(
+          version: "2.0.0",
+          source_dir: File.join(Dir.tmpdir, "no-src-#{$$}"),
+          http: lambda { |url|
+            url.to_s.include?("SHA256SUMS") ? sums : body
+          },
+          runner: lambda { |argv, **_kw|
+            if argv[0] == "tar"
+              system(*argv)
+            elsif argv[0] == "bundle"
+              false
+            else
+              true
+            end
+          }
+        )
+        error = assert_raises(Hive::Error) { provisioner.provision! }
+        assert_match(/bundle install failed/, error.message)
+        refute File.exist?(File.join(managed, ".hive-web-version")),
+               "pre-baked archive sidecar must not survive a failed bundle"
+        refute Hive::Web::AppLocator.rails_app?(managed),
+               "failed provision must remove the incomplete managed tree"
+
+        # Re-provision with a working bundle must succeed (no sticky half state).
+        provisioner2 = Hive::Web::AppProvisioner.new(
+          version: "2.0.0",
+          source_dir: File.join(Dir.tmpdir, "no-src-#{$$}"),
+          http: lambda { |url|
+            url.to_s.include?("SHA256SUMS") ? sums : body
+          },
+          runner: lambda { |argv, **_kw|
+            if argv[0] == "tar"
+              system(*argv)
+            else
+              true
+            end
+          }
+        )
+        result = provisioner2.provision!
+        assert_equal :installed, result.kind
+        assert_equal "2.0.0", Hive::Web::AppLocator.recorded_version(managed)
+      end
+    end
+  end
+
+  def test_source_prebaked_sidecar_not_copied_before_bundle
+    with_managed_home do |_home, managed|
+      Dir.mktmpdir("hive-src-web") do |src|
+        make_source_app(src)
+        File.write(File.join(src, ".hive-web-version"), "9.9.9\n")
+        saw_sidecar_during_bundle = nil
+        provisioner = Hive::Web::AppProvisioner.new(
+          version: "1.2.3",
+          source_dir: src,
+          runner: lambda { |argv, **_kw|
+            if argv[0] == "bundle"
+              saw_sidecar_during_bundle =
+                File.exist?(File.join(managed, ".hive-web-version"))
+              true
+            else
+              true
+            end
+          }
+        )
+        result = provisioner.provision!
+        assert_equal :installed, result.kind
+        assert_equal false, saw_sidecar_during_bundle,
+                     "source .hive-web-version must be stripped before bundle"
+        assert_equal "1.2.3", Hive::Web::AppLocator.recorded_version(managed),
+                     "sidecar must be sealed only after successful bundle"
+      end
+    end
+  end
+
+  def test_ensure_app_uses_existing_locator_hit
+    Dir.mktmpdir("hive-web-exist") do |dir|
+      make_source_app(dir)
+      with_env("HIVEBOX_WEB_APP_DIR" => dir) do
+        provisioner = Hive::Web::AppProvisioner.new(
+          runner: ->(*) { flunk "should not provision when app exists" }
+        )
+        result = provisioner.ensure_app!
+        assert_equal :unchanged, result.kind
+        assert_equal dir, result.app_dir
+      end
+    end
+  end
+
+  def test_ensure_app_bundles_when_requested
+    Dir.mktmpdir("hive-web-exist") do |dir|
+      make_source_app(dir)
+      with_env("HIVEBOX_WEB_APP_DIR" => dir) do
+        calls = []
+        provisioner = Hive::Web::AppProvisioner.new(
+          runner: ->(argv, **_kw) { calls << argv; true }
+        )
+        result = provisioner.ensure_app!(bundle: true)
+        assert_equal :unchanged, result.kind
+        assert calls.any? { |a| a[0] == "bundle" }, "bundle: true must run bundle install"
+      end
+    end
+  end
+end
