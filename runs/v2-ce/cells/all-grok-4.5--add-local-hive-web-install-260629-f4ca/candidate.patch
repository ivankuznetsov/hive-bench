diff --git a/lib/hive/web/app_locator.rb b/lib/hive/web/app_locator.rb
new file mode 100644
index 00000000..0b841469
--- /dev/null
+++ b/lib/hive/web/app_locator.rb
@@ -0,0 +1,72 @@
+# frozen_string_literal: true
+
+require "hive/paths"
+
+module Hive
+  module Web
+    # Resolves the Rails app root for `hive web` / local setup.
+    #
+    # Resolution order (first hit wins):
+    #   1. HIVEBOX_WEB_APP_DIR when it contains config/application.rb
+    #   2. Source checkout: <repo>/web next to lib/hive/
+    #   3. Managed install: Paths.data_home/web-app
+    #
+    # Docker/hivebox continues to set HIVEBOX_WEB_APP_DIR=/app/web.
+    module AppLocator
+      APPLICATION_RB = File.join("config", "application.rb").freeze
+      VERSION_SIDECAR = ".hive-web-version".freeze
+
+      module_function
+
+      # @return [String, nil] absolute path to a Rails root, or nil when none found
+      def locate(env: ENV)
+        candidates(env: env).find { |dir| rails_app?(dir) }
+      end
+
+      # Ordered candidate directories (may or may not exist / be valid).
+      def candidates(env: ENV)
+        list = []
+        override = env["HIVEBOX_WEB_APP_DIR"]
+        list << File.expand_path(override) if override && !override.empty?
+        list << source_checkout_web
+        list << managed_web_home
+        list.uniq
+      end
+
+      def source_checkout_web
+        # lib/hive/web/app_locator.rb → repo root is ../../..
+        File.expand_path("../../../web", __dir__)
+      end
+
+      def managed_web_home
+        Hive::Paths.web_app_home
+      end
+
+      def rails_app?(dir)
+        return false if dir.nil? || dir.empty?
+
+        File.file?(File.join(dir, APPLICATION_RB))
+      end
+
+      def version_sidecar_path(app_dir = managed_web_home)
+        File.join(app_dir, VERSION_SIDECAR)
+      end
+
+      def recorded_version(app_dir = managed_web_home)
+        path = version_sidecar_path(app_dir)
+        return nil unless File.file?(path)
+
+        File.read(path).to_s.strip
+      rescue StandardError
+        nil
+      end
+
+      def missing_app_guidance
+        "hive web: the Rails web app was not found. " \
+          "Run `hive setup` (or `hive web install`) to provision it under " \
+          "#{managed_web_home}, use a source checkout, or set HIVEBOX_WEB_APP_DIR " \
+          "to a directory containing config/application.rb."
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/app_provisioner.rb b/lib/hive/web/app_provisioner.rb
new file mode 100644
index 00000000..8241f55a
--- /dev/null
+++ b/lib/hive/web/app_provisioner.rb
@@ -0,0 +1,363 @@
+# frozen_string_literal: true
+
+require "digest"
+require "fileutils"
+require "net/http"
+require "tmpdir"
+require "uri"
+require "hive"
+require "hive/paths"
+require "hive/web/app_locator"
+
+module Hive
+  module Web
+    # Installs or updates the managed Rails web tree under
+    # `Paths.data_home/web-app` and runs `bundle install`.
+    #
+    # Primary payload: versioned GitHub release archive
+    # `hive-web-<version>.tar.gz`. When a source checkout `web/` exists
+    # next to the gem lib tree, that tree is preferred as the copy source
+    # (no network). Already-provisioned matching versions are no-ops.
+    #
+    # The `.hive-web-version` sidecar is written only after a successful
+    # `bundle install`, so a failed provision never looks "healthy" to
+    # `already_provisioned?` / `ensure_app!`.
+    class AppProvisioner
+      ARCHIVE_NAME = "hive-web-%<version>s.tar.gz"
+      CHECKSUMS_NAME = "SHA256SUMS"
+      DEFAULT_RELEASE_ASSET_URL =
+        "https://github.com/#{Hive::REPO_OWNER}/#{Hive::REPO_NAME}/releases/download/v%<version>s/%<archive>s"
+
+      # Exclude test/dev cruft from managed installs (matches release archive).
+      # Also strip any pre-baked `.hive-web-version` — the sidecar is the
+      # post-bundle seal and must never arrive from the archive/source tree
+      # before gems install successfully.
+      EXCLUDE_BASENAMES = %w[test tmp log storage .git .hive-web-version].freeze
+
+      Result = Data.define(:kind, :app_dir, :version, :messages) do
+        def provisioned?
+          %i[installed updated unchanged].include?(kind)
+        end
+      end
+
+      attr_reader :messages
+
+      def initialize(version: Hive::VERSION, http: nil, runner: nil, source_dir: nil)
+        @version = version.to_s
+        @http = http
+        @runner = runner || method(:default_runner)
+        @source_dir = source_dir
+        @messages = []
+      end
+
+      # Idempotent: returns :unchanged when managed tree already matches
+      # `@version` and looks like a Rails app. Re-provisions on mismatch.
+      def provision!(force: false)
+        target = AppLocator.managed_web_home
+        had_app = AppLocator.rails_app?(target)
+
+        if !force && already_provisioned?(target)
+          return Result.new(kind: :unchanged, app_dir: target, version: @version, messages: @messages.dup)
+        end
+
+        materialize_into!(target)
+        # Seal only after gems install so half-provisioned trees never
+        # satisfy already_provisioned? / setup's "web_app ok" path.
+        # Use ensure so Interrupt/SIGINT and any StandardError also drop
+        # the incomplete tree (not only Hive::Error).
+        sealed = false
+        begin
+          bundle_install!(target)
+          write_version_sidecar(target)
+          sealed = true
+        ensure
+          FileUtils.rm_rf(target) unless sealed
+        end
+
+        kind =
+          if had_app
+            :updated
+          else
+            :installed
+          end
+        Result.new(kind: kind, app_dir: target, version: @version, messages: @messages.dup)
+      end
+
+      # Ensure a bootable app exists via locator (env/checkout/managed) or provision.
+      # `bundle: true` runs `bundle install` for already-located trees (setup).
+      def ensure_app!(bundle: false)
+        existing = AppLocator.locate
+        if existing
+          if managed_incomplete?(existing)
+            return provision!(force: true)
+          end
+
+          bundle_install!(existing) if bundle
+          return Result.new(
+            kind: :unchanged,
+            app_dir: existing,
+            version: AppLocator.recorded_version(existing) || @version,
+            messages: @messages.dup
+          )
+        end
+
+        provision!
+      end
+
+      def already_provisioned?(target = AppLocator.managed_web_home)
+        AppLocator.rails_app?(target) && AppLocator.recorded_version(target) == @version
+      end
+
+      private
+
+      def managed_incomplete?(dir)
+        managed = File.expand_path(AppLocator.managed_web_home)
+        return false unless File.expand_path(dir) == managed
+        return true unless AppLocator.rails_app?(dir)
+
+        AppLocator.recorded_version(dir) != @version
+      end
+
+      def materialize_into!(target)
+        checkout = @source_dir || AppLocator.source_checkout_web
+        if AppLocator.rails_app?(checkout)
+          @messages << "using source checkout web app at #{checkout}"
+          stage_into(target, checkout)
+          return
+        end
+
+        download_and_stage!(target)
+      end
+
+      def download_and_stage!(target)
+        archive_name = format(ARCHIVE_NAME, version: @version)
+        url = archive_url(archive_name)
+        @messages << "downloading #{url}"
+
+        body = fetch_bytes(url)
+        if body.nil? || body.empty?
+          raise Hive::Error,
+                "hive web: failed to download #{archive_name} for Hive #{@version}. " \
+                "Check network access to GitHub releases, or set HIVEBOX_WEB_APP_DIR / " \
+                "run from a source checkout. Offline hosts with an empty managed tree " \
+                "cannot provision; re-run once online or copy a pre-built web tree to " \
+                "#{AppLocator.managed_web_home}."
+        end
+
+        verify_archive_sha256!(body, archive_name)
+
+        Dir.mktmpdir("hive-web-extract") do |tmp|
+          tarball = File.join(tmp, archive_name)
+          File.binwrite(tarball, body)
+          out = File.join(tmp, "out")
+          FileUtils.mkdir_p(out)
+          ok = invoke_runner([ "tar", "-xzf", tarball, "-C", out ])
+          unless ok
+            raise Hive::Error, "hive web: failed to extract #{archive_name}"
+          end
+
+          source = rails_root_in(out)
+          unless source
+            raise Hive::Error,
+                  "hive web: archive #{archive_name} did not contain config/application.rb"
+          end
+
+          stage_into(target, source)
+        end
+      end
+
+      def rails_root_in(dir)
+        return dir if AppLocator.rails_app?(dir)
+
+        Dir.children(dir).each do |name|
+          candidate = File.join(dir, name)
+          return candidate if AppLocator.rails_app?(candidate)
+        end
+        nil
+      end
+
+      def archive_url(archive_name)
+        override = ENV["HIVE_WEB_ARCHIVE_URL"].to_s
+        return override unless override.empty?
+
+        base = ENV["HIVE_WEB_RELEASE_BASE_URL"].to_s
+        unless base.empty?
+          return File.join(base.sub(%r{/\z}, ""), archive_name)
+        end
+
+        format(DEFAULT_RELEASE_ASSET_URL, version: @version, archive: archive_name)
+      end
+
+      def checksums_url
+        override = ENV["HIVE_WEB_SHA256SUMS_URL"].to_s
+        return override unless override.empty?
+
+        archive_name = format(ARCHIVE_NAME, version: @version)
+        arch = archive_url(archive_name)
+        # Sibling of the archive on the same release / mirror.
+        arch.sub(%r{[^/]+\z}, CHECKSUMS_NAME)
+      end
+
+      def verify_archive_sha256!(body, archive_name)
+        sums_url = checksums_url
+        @messages << "verifying #{archive_name} against #{sums_url}"
+        sums = fetch_bytes(sums_url)
+        if sums.nil? || sums.empty?
+          raise Hive::Error,
+                "hive web: failed to download #{CHECKSUMS_NAME} for integrity check " \
+                "(#{sums_url}). Refusing to install an unverified web archive. " \
+                "Set HIVE_WEB_SHA256SUMS_URL when using a custom HIVE_WEB_ARCHIVE_URL."
+        end
+
+        expected = expected_sha256_from_sums(sums, archive_name)
+        unless expected
+          raise Hive::Error,
+                "hive web: #{CHECKSUMS_NAME} does not list #{archive_name}; " \
+                "refusing to install an unverified web archive."
+        end
+
+        actual = Digest::SHA256.hexdigest(body)
+        return if actual.casecmp?(expected)
+
+        raise Hive::Error,
+              "hive web: SHA256 mismatch for #{archive_name} " \
+              "(expected #{expected}, got #{actual}). " \
+              "The download may be corrupt or tampered; re-run once online or " \
+              "pin a trusted HIVE_WEB_ARCHIVE_URL + HIVE_WEB_SHA256SUMS_URL pair."
+      end
+
+      def expected_sha256_from_sums(sums_body, archive_name)
+        # Strict: optional ./ prefix, two-space separator (sha256sum -c style).
+        pattern = %r{\A([a-fA-F0-9]{64})  (?:\./)?#{Regexp.escape(archive_name)}\s*\z}
+        sums_body.each_line do |line|
+          if (m = line.match(pattern))
+            return m[1].downcase
+          end
+        end
+        nil
+      end
+
+      def fetch_bytes(url, redirects: 5)
+        if @http
+          return @http.call(url)
+        end
+
+        uri = URI(url)
+        Net::HTTP.start(uri.host, uri.port, use_ssl: uri.scheme == "https",
+                        open_timeout: 30, read_timeout: 120) do |http|
+          req = Net::HTTP::Get.new(uri)
+          req["User-Agent"] = "hive-web-provisioner/#{Hive::VERSION}"
+          req["Accept"] = "application/octet-stream"
+          res = http.request(req)
+          return res.body if res.is_a?(Net::HTTPSuccess)
+
+          if res.is_a?(Net::HTTPRedirection) && res["location"] && redirects.positive?
+            return fetch_bytes(res["location"], redirects: redirects - 1)
+          end
+
+          nil
+        end
+      rescue StandardError => e
+        @messages << "download failed: #{e.class}: #{e.message}"
+        nil
+      end
+
+      def stage_into(target, source)
+        FileUtils.mkdir_p(File.dirname(target))
+        staging = "#{target}.staging-#{Process.pid}"
+        FileUtils.rm_rf(staging)
+        FileUtils.mkdir_p(staging)
+        copy_runtime_tree(source, staging)
+        FileUtils.rm_rf(target)
+        FileUtils.mv(staging, target)
+        @messages << "installed web app at #{target}"
+      ensure
+        FileUtils.rm_rf(staging) if defined?(staging) && staging && File.exist?(staging)
+      end
+
+      def copy_runtime_tree(source, dest)
+        Dir.children(source).each do |name|
+          next if EXCLUDE_BASENAMES.include?(name)
+          next if name == "vendor" && File.directory?(File.join(source, name, "bundle"))
+
+          src = File.join(source, name)
+          FileUtils.cp_r(src, File.join(dest, name))
+        end
+        %w[tmp log storage tmp/pids].each do |rel|
+          FileUtils.mkdir_p(File.join(dest, rel))
+        end
+      end
+
+      def write_version_sidecar(target)
+        File.write(AppLocator.version_sidecar_path(target), "#{@version}\n")
+      end
+
+      def bundle_install!(app_dir)
+        gemfile = File.join(app_dir, "Gemfile")
+        unless File.file?(gemfile)
+          @messages << "no Gemfile at #{app_dir}; skipping bundle install"
+          return
+        end
+
+        env = ENV.to_h.merge(
+          "BUNDLE_GEMFILE" => gemfile,
+          "BUNDLE_WITHOUT" => "development:test",
+          "RAILS_ENV" => ENV.fetch("RAILS_ENV", "production")
+        )
+        ok = invoke_runner(
+          [ "bundle", "install", "--gemfile", gemfile, "--without", "development", "test" ],
+          env: env,
+          chdir: app_dir
+        )
+        unless ok
+          detail = captured_runner_output
+          raise Hive::Error,
+                "hive web: bundle install failed in #{app_dir}. " \
+                "Install Ruby 3.4+ with bundler, ensure sqlite3 build deps " \
+                "(libsqlite3-dev / sqlite-devel) are present, then re-run " \
+                "`cd #{app_dir} && bundle install --without development test`." \
+                "#{detail.empty? ? '' : "\n#{detail}"}"
+        end
+        @messages << "bundle install ok in #{app_dir}"
+      end
+
+      def captured_runner_output
+        parts = []
+        parts << @last_runner_stdout.to_s.strip unless @last_runner_stdout.to_s.strip.empty?
+        parts << @last_runner_stderr.to_s.strip unless @last_runner_stderr.to_s.strip.empty?
+        parts.join("\n")
+      end
+
+      def invoke_runner(argv, env: nil, chdir: nil)
+        @last_runner_stdout = nil
+        @last_runner_stderr = nil
+        if @runner.arity == 1
+          @runner.call(argv)
+        else
+          @runner.call(argv, env: env, chdir: chdir)
+        end
+      end
+
+      # Capture stdout/stderr so native-extension (sqlite3) build failures
+      # surface the compiler log instead of being discarded to /dev/null.
+      def default_runner(argv, env: nil, chdir: nil)
+        require "open3"
+        opts = {}
+        opts[:chdir] = chdir if chdir
+        if env
+          out, err, status = Open3.capture3(env, *argv, **opts)
+        else
+          out, err, status = Open3.capture3(*argv, **opts)
+        end
+        @last_runner_stdout = out
+        @last_runner_stderr = err
+        unless status.success?
+          @messages << "command failed: #{argv.join(' ')}"
+          @messages << err.strip unless err.to_s.strip.empty?
+          @messages << out.strip unless out.to_s.strip.empty?
+        end
+        status.success?
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/auth_policy.rb b/lib/hive/web/auth_policy.rb
new file mode 100644
index 00000000..43212eca
--- /dev/null
+++ b/lib/hive/web/auth_policy.rb
@@ -0,0 +1,107 @@
+# frozen_string_literal: true
+
+module Hive
+  module Web
+    # Local bind + auth policy shared by the CLI (`hive web`) and the Rails
+    # app. Defaults keep single-user loopback open (no GitHub login) while
+    # refusing unauthenticated non-loopback binds unless the operator
+    # explicitly opts into github mode or `--auth none --unsafe`.
+    #
+    # Modes (`web.auth`):
+    #   auto   (default) — no auth on loopback; require GitHub on non-loopback
+    #                      (`--unsafe` only unblocks the CLI boot gate; login
+    #                      remains required — see auth_required?)
+    #   github           — always require GitHub owner flow
+    #   none             — never require login (loopback only, unless unsafe)
+    module AuthPolicy
+      MODES = %w[auto github none].freeze
+      LOOPBACK_BINDS = %w[127.0.0.1 ::1 localhost].freeze
+
+      module_function
+
+      def normalize_mode(mode)
+        value = mode.to_s.strip
+        value = "auto" if value.empty?
+        value
+      end
+
+      def loopback_bind?(bind)
+        host = bind.to_s.strip.downcase
+        return true if LOOPBACK_BINDS.include?(host)
+        return true if host == "[::1]"
+
+        false
+      end
+
+      # Whether unauthenticated browser sessions are refused for this bind.
+      # Note: for mode=auto, allow_insecure_public does NOT open the bind —
+      # only mode=none honors unsafe as "no login".
+      def auth_required?(bind:, mode: "auto", allow_insecure_public: false)
+        case normalize_mode(mode)
+        when "github"
+          true
+        when "none"
+          # none is only "open" when loopback or explicit unsafe.
+          !(loopback_bind?(bind) || allow_insecure_public)
+        else # auto
+          !loopback_bind?(bind)
+        end
+      end
+
+      # CLI pre-boot gate. Raises Hive::Error when the combination of bind +
+      # mode + unsafe is refused. `--unsafe` / allow_insecure_public lets
+      # auto mode *boot* on a public bind, but Rails still requires GitHub
+      # login unless mode is none (or github is chosen explicitly).
+      def assert_boot_allowed!(bind:, mode: "auto", allow_insecure_public: false, unsafe: false)
+        mode = normalize_mode(mode)
+        insecure = allow_insecure_public || unsafe
+
+        if mode == "none" && !loopback_bind?(bind) && !insecure
+          raise Hive::Error,
+                "hive web: web.auth=none is only allowed on loopback " \
+                "(127.0.0.1 / ::1 / localhost) or with --unsafe / " \
+                "web.allow_insecure_public: true. Refusing bind=#{bind}."
+        end
+
+        return if loopback_bind?(bind)
+        return if mode == "github"
+        return if insecure
+
+        raise Hive::Error,
+              "hive web: refusing non-loopback bind #{bind.inspect} without auth. " \
+              "Use web.auth: github (or --auth github), or pass --auth none --unsafe / " \
+              "set web.allow_insecure_public: true for an explicitly open public bind."
+      end
+
+      # Env keys the CLI exports so Rails can evaluate the same policy
+      # without re-reading host-only CLI flags.
+      def export_env(bind:, mode:, allow_insecure_public:)
+        {
+          "HIVE_WEB_BIND" => bind.to_s,
+          "HIVE_WEB_AUTH" => normalize_mode(mode),
+          "HIVE_WEB_ALLOW_INSECURE_PUBLIC" => allow_insecure_public ? "1" : "0"
+        }
+      end
+
+      def truthy_env?(value)
+        %w[1 true yes].include?(value.to_s.downcase)
+      end
+
+      def non_empty(value)
+        s = value.to_s
+        s.empty? ? nil : s
+      end
+
+      # Rails-side: should require_login enforce GitHub?
+      def require_login?(env: ENV, config: nil)
+        cfg = config || {}
+        bind = non_empty(env["HIVE_WEB_BIND"]) || cfg["bind"] || "127.0.0.1"
+        mode = normalize_mode(non_empty(env["HIVE_WEB_AUTH"]) || cfg["auth"] || "auto")
+        insecure =
+          truthy_env?(env["HIVE_WEB_ALLOW_INSECURE_PUBLIC"]) ||
+          cfg["allow_insecure_public"] == true
+        auth_required?(bind: bind, mode: mode, allow_insecure_public: insecure)
+      end
+    end
+  end
+end
diff --git a/lib/hive/web/daemon_control.rb b/lib/hive/web/daemon_control.rb
new file mode 100644
index 00000000..f11258c6
--- /dev/null
+++ b/lib/hive/web/daemon_control.rb
@@ -0,0 +1,94 @@
+# frozen_string_literal: true
+
+require "hive"
+require "hive/paths"
+require "hive/pid_file"
+require "hive/invoked_binary"
+require "hive/daemon/binary_consistency"
+
+module Hive
+  module Web
+    # Thin, in-process control surface for the separate daemon service.
+    # Never embeds the dispatcher — only probes status and invokes the
+    # existing ServiceInstaller / systemctl / launchctl paths.
+    class DaemonControl
+      include Hive::PidFile
+
+      def initialize(runner: nil, home: nil)
+        @runner = runner
+        @home = home
+      end
+
+      def pid_file
+        File.join(Hive::Paths.state_home, ".daemon.pid")
+      end
+
+      def summary
+        pid = read_live_pid
+        require "hive/commands/daemon/service_installer"
+        installer = build_installer
+        state = installer.service_state
+        binary = Hive::Daemon::BinaryConsistency.probe(unit_path: state["unit_path"])
+        {
+          "running" => !pid.nil?,
+          "pid" => pid,
+          "service_installed" => state["service_installed"],
+          "service_enabled" => state["service_enabled"],
+          "unit_path" => state["unit_path"],
+          "binary_path" => binary["cli_binary_path"],
+          "unit_binary_path" => binary["unit_binary_path"],
+          "binary_matches_cli" => binary["binary_matches_cli"],
+          "version_matches_cli" => binary["version_matches_cli"],
+          "cli_version" => binary["cli_version"],
+          "unit_version" => binary["unit_version"],
+          "repair_hint" => binary["repair_hint"],
+          # Require an explicit true path match and no version skew —
+          # nil/unknown and same-path version drift must not green-banner.
+          "healthy" => !pid.nil? &&
+            binary["binary_matches_cli"] == true &&
+            binary["version_matches_cli"] != false
+        }
+      end
+
+      def restart!
+        installer = build_installer
+        runner = @runner || installer.runner
+        case installer.envelope_platform
+        when "linux"
+          ok = runner.call(%w[systemctl --user restart hive-daemon])
+          raise Hive::Error, "systemctl --user restart hive-daemon failed" unless ok
+        when "macos"
+          path = installer.target_path
+          raise Hive::Error, "daemon unit not installed" unless path && File.exist?(path)
+
+          runner.call([ "launchctl", "unload", path ])
+          ok = runner.call([ "launchctl", "load", path ])
+          raise Hive::Error, "launchctl load failed for #{path}" unless ok
+        else
+          raise Hive::Error, "restart not supported on this platform; run `hive daemon start`"
+        end
+        { "ok" => true, "action" => "restart" }
+      end
+
+      def repair!
+        installer = build_installer
+        outcome = installer.install!(autostart: true, force: true)
+        unless outcome.success?
+          raise Hive::Error, "daemon repair failed (#{outcome.wire_outcome}): #{installer.messages.join('; ')}"
+        end
+
+        { "ok" => true, "action" => "repair", "outcome" => outcome.wire_outcome }
+      end
+
+      private
+
+      def build_installer
+        require "hive/commands/daemon/service_installer"
+        opts = { binary_path: Hive::InvokedBinary.path }
+        opts[:runner] = @runner if @runner
+        opts[:home] = @home if @home
+        Hive::Commands::Daemon::ServiceInstaller.new(**opts)
+      end
+    end
+  end
+end
