+          runner.call([ "launchctl", "unload", path ])
+          runner.call([ "launchctl", "load", path ])
+        else
+          true
+        end
+      end
+
+      def enroll_project
+        return record_phase("project", :ok, "skipped (not a git repo)") unless git_repo?(@project_path)
+
+        hive_state = File.join(@project_path, ".hive-state")
