+        begin
+          outcome = installer.install!(autostart: true, force: false)
+          if outcome.drifted?
+            outcome = installer.install!(autostart: true, force: true)
+          end
+          record_phase(
+            "web_service",
+            outcome.success? ? :ok : :warn,
+            "web service #{outcome.wire_outcome}; open #{url}"
+          )
+        rescue StandardError => e
+          @warnings << { name: "web_service", message: e.message, fix: "hive web" }
+          record_phase("web_service", :warn, "managed web unavailable (#{e.message}); run `hive web` → #{url}")
+        end
+      end
+
+      def git_repo?(path)
+        File.directory?(File.join(path, ".git")) ||
+          system("git", "-C", path, "rev-parse", "--is-inside-work-tree", out: File::NULL, err: File::NULL)
+      end
+
+      def record_phase(name, status, message, fix: nil)
+        @phases << {
+          "name" => name.to_s,
+          "status" => status.to_s,
+          "message" => message.to_s,
+          "fix" => fix
+        }
+      end
+
+      def finish(exit_code)
+        url = begin
+          cfg = Hive::Config.load_global_web
+          "http://#{cfg.fetch('bind')}:#{cfg.fetch('port')}"
+        rescue StandardError
+          "http://127.0.0.1:4567"
+        end
+
+        payload = {
+          "schema" => "hive-setup",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-setup"),
+          "ok" => exit_code == EXIT_SUCCESS,
+          "exit_code" => exit_code,
+          "url" => url,
+          "cli_binary" => Hive::InvokedBinary.path,
+          "cli_version" => Hive::VERSION,
+          "phases" => @phases,
+          "blockers" => @blockers.map { |b| stringify_row(b) },
+          "warnings" => @warnings.map { |w| stringify_row(w) }
+        }
+
+        if @json
+          @output.puts JSON.generate(payload)
+        else
+          render_human(payload)
+        end
+        exit_code
+      end
+
+      def stringify_row(row)
+        {
+          "name" => (row[:name] || row["name"]).to_s,
+          "message" => (row[:message] || row["message"]).to_s,
+          "fix" => row[:fix] || row["fix"]
+        }
+      end
+
+      def render_human(payload)
+        @output.puts "hive setup"
+        @output.puts "  URL: #{payload['url']}"
+        @output.puts "  CLI: #{payload['cli_binary']} (v#{payload['cli_version']})"
+        @output.puts
+        @output.puts "Phases:"
+        payload["phases"].each do |p|
+          @output.puts "  [#{p['status']}] #{p['name']}: #{p['message']}"
+          @output.puts "         fix: #{p['fix']}" if p["fix"]
+        end
+        if payload["warnings"].any?
+          @output.puts
+          @output.puts "Warnings:"
+          payload["warnings"].each do |w|
+            @output.puts "  - #{w['name']}: #{w['message']}"
+            @output.puts "    fix: #{w['fix']}" if w["fix"]
+          end
+        end
+        if payload["blockers"].any?
+          @output.puts
+          @output.puts "Blockers:"
+          payload["blockers"].each do |b|
+            @output.puts "  - #{b['name']}: #{b['message']}"
+            @output.puts "    fix: #{b['fix']}" if b["fix"]
+          end
+        end
+        # Happy "new local project" path: make the single copy-paste init
+        # line impossible to miss even when setup otherwise succeeds.
+        init_fix = payload["warnings"].find { |w| w["name"] == "project" && w["fix"].to_s.include?("hive init") }
+        if init_fix && payload["ok"]
+          @output.puts
+          @output.puts "Next step (copy-paste):"
+          @output.puts "  #{init_fix['fix']}"
+        end
+        @output.puts
+        @output.puts(payload["ok"] ? "Setup complete." : "Setup finished with errors.")
+      end
+
+      def default_runner(argv, env: nil, chdir: nil)
+        kwargs = {}
+        kwargs[:chdir] = chdir if chdir
+        if env
+          system(env, *argv, **kwargs)
+        else
+          system(*argv, **kwargs)
+        end
+      end
+    end
+  end
+end
