--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,395 @@
+# frozen_string_literal: true
+
+require "json"
+require "open3"
+require "rbconfig"
+require "hive"
+require "hive/local_preflight"
+require "hive/web/app_locator"
+require "hive/web/app_provisioner"
+require "hive/invoked_binary"
+require "hive/config"
+require "hive/paths"
+
+module Hive
+  module Commands
+    # `hive setup` — one command for the local (non-Docker) product path.
+    # Provisions Hive-owned deps (web app, optional qmd), installs/repairs
+    # the daemon unit to the current CLI binary, enrolls the cwd project
+    # when it is a git repo, and starts managed web when possible.
+    class Setup
+      EXIT_SUCCESS = 0
+      EXIT_BLOCKER = 1
+      EXIT_UNSUPPORTED = 78
+
+      def initialize(json: false, strict: false, yes: true, project_path: Dir.pwd,
+                     output: $stdout, runner: nil, which: nil)
+        @json = json
+        @strict = strict
+        @yes = yes
+        @project_path = File.expand_path(project_path)
+        @output = output
+        @runner = runner || method(:default_runner)
+        @which = which || Hive::LocalPreflight.method(:default_which)
+        @phases = []
+        @warnings = []
+        @blockers = []
+      end
+
+      def call
+        platform = Hive::LocalPreflight.platform_message
+        record_phase("platform", platform[:status], platform[:message])
+        if platform[:status] == :fail
+          return finish(EXIT_UNSUPPORTED)
+        end
+
+        probe_deps
+        bootstrap_hive_owned
+        ensure_daemon
+        enroll_project
+        ensure_web_service
+
+        exit_code =
+          if @blockers.any?
+            EXIT_BLOCKER
+          elsif @strict && @warnings.any?
+            EXIT_BLOCKER
+          else
+            EXIT_SUCCESS
+          end
+        finish(exit_code)
+      end
+
+      private
+
+      def probe_deps
+        rows = Hive::LocalPreflight.dependency_rows(which: @which)
+        rows.each do |row|
+          # Skip web_app / daemon_binary here — later phases install them.
+          next if %w[web_app daemon_binary].include?(row[:name])
+
+          status = row[:status]
+          if status == :fail || (status == :missing && row[:severity] == :blocker)
+            @blockers << row
+          elsif status != :ok
+            @warnings << row
+          end
+          record_phase("dep:#{row[:name]}", status, row[:message], fix: row[:fix])
+        end
+      end
+
+      def bootstrap_hive_owned
+        # qmd: only when npm is available; never silent-fail agents.
+        ensure_qmd
+        provision_web
+      end
+
+      def ensure_qmd
+        existing = Hive::LocalPreflight.find_qmd(which: @which)
+        if existing
+          record_phase("qmd", :ok, existing)
+          return
+        end
+
+        npm = @which.call("npm")
+        unless npm
+          @warnings << { name: "qmd", message: "npm missing; skip qmd bootstrap", fix: "install Node/npm then re-run hive setup" }
+          record_phase("qmd", :warn, "skipped (npm missing)")
+          return
+        end
+
+        prefix = File.join(Hive::Paths.data_home, "qmd")
+        FileUtils.mkdir_p(prefix)
+        ok = @runner.call(
+          [ npm, "install", "--global", "--prefix", prefix, "@tobilu/qmd" ]
+        )
+        if ok
+          record_phase("qmd", :ok, "installed under #{prefix}")
+        else
+          @warnings << { name: "qmd", message: "npm install qmd failed", fix: "npm install --global --prefix \"#{prefix}\" @tobilu/qmd" }
+          record_phase("qmd", :warn, "install failed")
+        end
+      end
+
+      def provision_web
+        provisioner = Hive::Web::AppProvisioner.new(runner: @runner)
+        # Plan U4: always bootstrap the web bundle — source checkout /
+        # env-located / half-managed trees previously skipped gem install.
+        result = provisioner.ensure_app!(bundle: true)
+        provisioner.messages.each { |m| record_phase("web_msg", :ok, m) }
+        record_phase("web_app", :ok, "#{result.app_dir} (#{result.kind})")
+      rescue Hive::Error => e
+        @blockers << { name: "web_app", message: e.message, fix: "hive setup / hive web install" }
+        record_phase("web_app", :fail, e.message)
+      end
+
+      def ensure_daemon
+        require "hive/commands/daemon/service_installer"
+        require "hive/daemon/binary_consistency"
+        installer = Hive::Commands::Daemon::ServiceInstaller.new(
+          binary_path: Hive::InvokedBinary.path,
+          runner: @runner
+        )
+        state = installer.service_state
+        report = Hive::Daemon::BinaryConsistency.probe(unit_path: state["unit_path"])
+        already_installed = state["service_installed"]
+        # Path mismatch OR same-path version skew after gem upgrade both need
+        # force/restart so the live process matches this CLI session (R9/U5).
+        force = already_installed && (
+          report["binary_matches_cli"] == false ||
+          report["version_matches_cli"] == false
+        )
+
+        begin
+          outcome = installer.install!(autostart: true, force: force)
+          if outcome.drifted?
+            outcome = installer.install!(autostart: true, force: true)
+          end
+
+          # install! only restarts when the unit file was rewritten
+          # (:upgraded). Same-path gem upgrades leave the unit unchanged, so
+          # enable --now is a no-op and the old process keeps running. Restart
+          # whenever a prior unit existed and install did not already restart.
+          if outcome.success? && already_installed && !outcome.restarted
+            unless restart_daemon_service(installer)
