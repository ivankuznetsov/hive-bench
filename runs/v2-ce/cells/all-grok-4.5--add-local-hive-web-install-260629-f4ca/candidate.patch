+<div class="card">
+  <p class="agent-state">
+    <span class="status-dot <%= healthy ? "status-dot-running" : "status-dot-idle" %>"></span>
+    <% if @daemon["running"] %>
+      Running (pid <%= @daemon["pid"] %>)
+    <% else %>
+      Not running
+    <% end %>
+  </p>
+  <dl class="meta-list">
+    <dt>Service installed</dt>
+    <dd><%= @daemon["service_installed"].inspect %></dd>
+    <dt>Service enabled</dt>
+    <dd><%= @daemon["service_enabled"].inspect %></dd>
+    <dt>Unit path</dt>
