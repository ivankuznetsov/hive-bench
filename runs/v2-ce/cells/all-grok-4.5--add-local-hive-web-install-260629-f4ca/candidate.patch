+          raise Hive::WebInstallFailed,
+                "web service install reported a failure; see messages above"
+        end
+      end
+
+      def install_envelope(installer, outcome)
+        {
+          "schema" => "hive-web-install",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-web-install"),
+          "ok" => true,
+          "outcome" => outcome.wire_outcome,
+          "platform" => installer.envelope_platform,
+          "target_path" => installer.target_path,
+          "backup_path" => outcome.backup_path,
+          "restarted" => outcome.restarted,
+          "messages" => installer.messages.dup
+        }
+      end
+
+      def install_emit_error_envelope(installer, outcome:)
+        error_class = outcome == "drifted" ? "WebInstallDriftError" : "WebInstallFailed"
+        exit_code = outcome == "drifted" ? Hive::ExitCodes::USAGE : Hive::ExitCodes::SOFTWARE
+        message =
+          if outcome == "drifted"
+            "web unit at #{installer.target_path} differs from the current template; retry with --force."
+          else
+            "web service install reported a failure; see messages"
+          end
+        puts JSON.generate(
+          "schema" => "hive-web-install",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-web-install"),
+          "ok" => false,
+          "error_class" => error_class,
+          "error_kind" => outcome,
+          "exit_code" => exit_code,
+          "message" => message,
+          "outcome" => outcome,
+          "platform" => installer.envelope_platform,
+          "target_path" => installer.target_path,
+          "messages" => installer.messages.dup
+        )
+      end
+
+      def install_emit_exception_envelope(installer, error)
+        puts JSON.generate(
+          "schema" => "hive-web-install",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-web-install"),
+          "ok" => false,
+          "error_class" => "WebInstallFailed",
+          "error_kind" => "failed",
+          "exit_code" => Hive::ExitCodes::SOFTWARE,
+          "message" => "web service install failed: #{error.class}: #{error.message}",
+          "outcome" => "failed",
+          "platform" => (installer.envelope_platform rescue "unsupported"),
+          "target_path" => (installer.target_path rescue nil),
+          "messages" => (installer.messages.dup rescue [])
+        )
+      end
+
+      def stop_web
+        require "hive/commands/web/service_installer"
+        installer = Hive::Commands::Web::ServiceInstaller.new
+        runner = installer.runner
+        stopped = false
+        message =
+          case installer.platform
+          when :linux
+            if installer.service_state["service_installed"]
+              stopped = !!runner.call(%w[systemctl --user stop hive-web])
+              stopped ? "hive web: stopped hive-web" : "hive web: stop failed (is the unit installed?)"
+            else
+              "hive web: no managed unit installed; nothing to stop"
+            end
+          when :macos
+            path = installer.target_path
+            if path && File.exist?(path)
+              stopped = !!runner.call([ "launchctl", "unload", path ])
+              stopped ? "hive web: unloaded #{path}" : "hive web: unload failed for #{path}"
+            else
+              "hive web: no managed unit installed; nothing to stop"
+            end
+          else
+            "hive web: stop not supported on this platform"
+          end
+
+        payload = {
+          "schema" => "hive-web-stop",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-web-stop"),
+          "ok" => true,
+          "stopped" => stopped,
+          "message" => message
+        }
+        @json ? puts_json(payload) : puts(message)
+      end
+
+      def status_web
+        payload = status_payload
+        if @json
+          puts_json(payload)
+        else
+          puts "hive web: #{payload['url']} (auth=#{payload['auth']})"
+          puts "  app: #{payload['app_dir'] || '(missing — run hive setup)'}"
+          puts "  service: installed=#{payload['service_installed']} enabled=#{payload['service_enabled']}"
+          puts "  unit: #{payload['unit_path']}" if payload["unit_path"]
+        end
+      end
+
+      def status_payload
+        cfg = Hive::Config.load_global_web
+        bind = @bind || cfg.fetch("bind")
+        port = (@port || cfg.fetch("port")).to_i
+        service_state = probe_service_state
+        app_dir = rails_app_dir
+        {
+          "schema" => "hive-web-status",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-web-status"),
+          "ok" => true,
+          "service_installed" => service_state["service_installed"],
+          "service_enabled" => service_state["service_enabled"],
+          "unit_path" => service_state["unit_path"],
+          "bind" => bind,
+          "port" => port,
+          "url" => "http://#{bind}:#{port}",
+          "auth" => (@auth || cfg["auth"] || "auto").to_s,
+          "app_dir" => app_dir,
+          "app_version" => app_dir ? Hive::Web::AppLocator.recorded_version(app_dir) : nil
+        }
+      end
+
+      def probe_service_state
+        require "hive/commands/web/service_installer"
+        Hive::Commands::Web::ServiceInstaller.new.service_state
+      rescue StandardError
+        { "service_installed" => nil, "service_enabled" => nil, "unit_path" => nil }
+      end
+
+      def current_binary_path
+        require "hive/invoked_binary"
+        Hive::InvokedBinary.path
+      end
+
+      def puts_json(payload)
+        puts JSON.generate(payload)
+      end
     end
   end
 end
diff --git a/lib/hive/commands/web/service_installer.rb b/lib/hive/commands/web/service_installer.rb
new file mode 100644
index 00000000..26be050b
--- /dev/null
+++ b/lib/hive/commands/web/service_installer.rb
@@ -0,0 +1,62 @@
+# frozen_string_literal: true
+
+require "cgi"
+require "shellwords"
+require "hive/commands/service_installer/base"
+
+module Hive
+  module Commands
+    class Web
+      # Per-user autostart installer for the Rails web UI. Mirrors the bot
+      # installer (no TimeoutStopSec drain). Never starts the daemon —
+      # daemon and web stay separate services.
+      class ServiceInstaller < Hive::Commands::ServiceInstaller::Base
+        def service_name
+          "hive-web"
+        end
+
+        def cli_label
+          "web"
+        end
+
+        def service_noun
+          "web service"
+        end
+
+        def unit_noun
+          "web unit"
+        end
+
+        def target_path
+          case platform
+          when :macos then File.join(@home, "Library/LaunchAgents/local.hive-web.plist")
+          when :linux then File.join(@home, ".config/systemd/user/hive-web.service")
+          end
+        end
+
+        private
+
+        def render_systemd
+          template = File.read(File.expand_path("../../../../examples/systemd/hive-web.service", __dir__))
+          escaped = Shellwords.escape(resolved_binary)
+          template
+            .sub(/^ExecStart=.*$/, "ExecStart=#{escaped} web start --foreground")
+            .sub(/^Environment=PATH=.*$/, build_path_line)
+        end
+
+        def render_launchd
+          template = File.read(File.expand_path("../../../../examples/launchd/hive-web.plist", __dir__))
+          binary = resolved_binary
+          binary_dir = File.dirname(binary)
+          escaped_binary = CGI.escapeHTML(binary)
+          escaped_binary_dir = CGI.escapeHTML(binary_dir)
+          escaped_home = CGI.escapeHTML(@home)
+          template
+            .gsub(%r{<string>/Users/YOU/\.local/bin/hive</string>}, "<string>#{escaped_binary}</string>")
+            .gsub("/Users/YOU/Library/Logs", "#{escaped_home}/Library/Logs")
+            .gsub("/Users/YOU/.local/bin", escaped_binary_dir)
+        end
+      end
+    end
+  end
+end
