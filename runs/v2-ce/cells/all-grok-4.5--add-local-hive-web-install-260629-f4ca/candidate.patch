diff --git a/test/integration/local_setup_smoke_test.rb b/test/integration/local_setup_smoke_test.rb
new file mode 100644
index 00000000..040e54bf
--- /dev/null
+++ b/test/integration/local_setup_smoke_test.rb
@@ -0,0 +1,121 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "json"
+require "stringio"
+require "hive/commands/setup"
+require "hive/commands/web"
+require "hive/web/app_locator"
+require "hive/web/auth_policy"
+require "hive/daemon/binary_consistency"
+require "hive/commands/new"
+
+# Sandboxed acceptance smoke for local web mode (no real agent APIs).
+class LocalSetupSmokeTest < Minitest::Test
+  include HiveTestHelper
+
+  def which_stub
+    lambda do |name|
+      case name
+      when "git", "tmux", "node", "npm", "gh", "claude", "codex", "qmd"
+        "/usr/bin/#{name}"
+      end
+    end
+  end
+
+  def test_setup_provisions_web_and_daemon_unit_with_cli_binary
+    with_tmp_global_config_and_home do |home|
+      hive = File.join(home, "bin", "hive")
+      FileUtils.mkdir_p(File.dirname(hive))
+      File.write(hive, "#!/bin/sh\necho 0.0.0\n")
+      FileUtils.chmod(0o755, hive)
+
+      web = File.join(home, "src-web")
+      FileUtils.mkdir_p(File.join(web, "config"))
+      File.write(File.join(web, "config", "application.rb"), "# rails")
+      File.write(File.join(web, "Gemfile"), "source 'https://rubygems.org'\n")
+
+      runner = ->(*) { true }
+      out = StringIO.new
+      with_env("HIVEBOX_WEB_APP_DIR" => web, "HIVE_INVOKED_BIN" => hive) do
+        code = Hive::Commands::Setup.new(
+          json: true,
+          project_path: home,
+          output: out,
+          runner: runner,
+          which: which_stub
+        ).call
+        assert_equal 0, code, out.string
+        doc = JSON.parse(out.string)
+        assert_equal true, doc["ok"]
+        assert_equal "http://127.0.0.1:4567", doc["url"]
+        assert_equal hive, doc["cli_binary"]
+
+        # Managed unit content points at CLI binary.
+        unit = File.join(home, ".config/systemd/user/hive-daemon.service")
+        if File.exist?(unit)
+          body = File.read(unit)
+          assert_includes body, hive
+          report = Hive::Daemon::BinaryConsistency.probe(cli_path: hive, unit_path: unit)
+          assert_equal true, report["binary_matches_cli"]
+        end
+
+        web_unit = File.join(home, ".config/systemd/user/hive-web.service")
+        if File.exist?(web_unit)
+          assert_includes File.read(web_unit), "web start --foreground"
+          refute_includes File.read(web_unit), "daemon start"
+        end
+
+        assert Hive::Web::AppLocator.locate
+      end
+    end
+  end
+
+  def test_loopback_default_allows_unauthenticated_policy
+    refute Hive::Web::AuthPolicy.auth_required?(bind: "127.0.0.1", mode: "auto")
+    assert_raises(Hive::Error) do
+      Hive::Web::AuthPolicy.assert_boot_allowed!(bind: "0.0.0.0", mode: "auto")
+    end
+  end
+
+  def test_web_status_json_envelope
+    with_tmp_global_config do
+      out, = capture_io do
+        Hive::Commands::Web.new("status", json: true).call
+      end
+      doc = JSON.parse(out)
