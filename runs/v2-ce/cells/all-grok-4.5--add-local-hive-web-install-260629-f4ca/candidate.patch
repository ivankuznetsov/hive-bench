+              message: ".hive-state present but project not in global registry",
+              fix: init_cmd
+            }
+            record_phase(
+              "project",
+              :warn,
+              "not registered globally — next step: #{init_cmd}",
+              fix: init_cmd
+            )
+          end
+        rescue StandardError => e
+          @warnings << { name: "project", message: e.message, fix: "hive daemon enable <name>" }
+          record_phase("project", :warn, "enable failed: #{e.message}")
+        end
+      end
+
+      def ensure_web_service
+        cfg = begin
+          Hive::Config.load_global_web
+        rescue StandardError
+          { "bind" => "127.0.0.1", "port" => 4567 }
+        end
+        bind = cfg["bind"] || "127.0.0.1"
+        port = (cfg["port"] || 4567).to_i
+        url = "http://#{bind}:#{port}"
+
+        require "hive/commands/web/service_installer"
+        installer = Hive::Commands::Web::ServiceInstaller.new(
+          binary_path: Hive::InvokedBinary.path,
+          runner: @runner
+        )
+        if installer.envelope_platform == "unsupported"
+          record_phase("web_service", :ok, "run `hive web` then open #{url}")
+          return
+        end
