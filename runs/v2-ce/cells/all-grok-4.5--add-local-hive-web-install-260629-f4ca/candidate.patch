+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/web/auth_policy"
+
+class WebAuthPolicyTest < Minitest::Test
+  def test_loopback_binds
+    assert Hive::Web::AuthPolicy.loopback_bind?("127.0.0.1")
+    assert Hive::Web::AuthPolicy.loopback_bind?("::1")
+    assert Hive::Web::AuthPolicy.loopback_bind?("localhost")
+    refute Hive::Web::AuthPolicy.loopback_bind?("0.0.0.0")
+    refute Hive::Web::AuthPolicy.loopback_bind?("192.168.1.1")
+  end
+
+  def test_auto_mode_auth_required_matrix
+    refute Hive::Web::AuthPolicy.auth_required?(bind: "127.0.0.1", mode: "auto")
+    assert Hive::Web::AuthPolicy.auth_required?(bind: "0.0.0.0", mode: "auto")
+  end
+
+  def test_github_mode_always_requires_auth
+    assert Hive::Web::AuthPolicy.auth_required?(bind: "127.0.0.1", mode: "github")
+    assert Hive::Web::AuthPolicy.auth_required?(bind: "0.0.0.0", mode: "github")
+  end
+
+  def test_none_mode_open_on_loopback_only
+    refute Hive::Web::AuthPolicy.auth_required?(bind: "127.0.0.1", mode: "none")
+    assert Hive::Web::AuthPolicy.auth_required?(bind: "0.0.0.0", mode: "none")
+    refute Hive::Web::AuthPolicy.auth_required?(
+      bind: "0.0.0.0", mode: "none", allow_insecure_public: true
+    )
+  end
+
+  def test_assert_boot_refuses_public_without_auth_or_unsafe
+    error = assert_raises(Hive::Error) do
+      Hive::Web::AuthPolicy.assert_boot_allowed!(bind: "0.0.0.0", mode: "auto")
+    end
+    assert_match(/refusing non-loopback/, error.message)
+  end
+
+  def test_assert_boot_allows_public_with_github
+    Hive::Web::AuthPolicy.assert_boot_allowed!(bind: "0.0.0.0", mode: "github")
+  end
+
+  def test_assert_boot_allows_public_with_unsafe
+    Hive::Web::AuthPolicy.assert_boot_allowed!(bind: "0.0.0.0", mode: "auto", unsafe: true)
+  end
+
+  def test_assert_boot_allows_loopback_default
+    Hive::Web::AuthPolicy.assert_boot_allowed!(bind: "127.0.0.1", mode: "auto")
+  end
+
+  def test_require_login_from_env_and_config
+    refute Hive::Web::AuthPolicy.require_login?(
+      env: { "HIVE_WEB_BIND" => "127.0.0.1", "HIVE_WEB_AUTH" => "auto" },
+      config: {}
+    )
+    assert Hive::Web::AuthPolicy.require_login?(
+      env: { "HIVE_WEB_BIND" => "0.0.0.0", "HIVE_WEB_AUTH" => "auto" },
+      config: {}
+    )
+    assert Hive::Web::AuthPolicy.require_login?(
+      env: { "HIVE_WEB_BIND" => "127.0.0.1", "HIVE_WEB_AUTH" => "github" },
+      config: {}
+    )
+  end
+end
