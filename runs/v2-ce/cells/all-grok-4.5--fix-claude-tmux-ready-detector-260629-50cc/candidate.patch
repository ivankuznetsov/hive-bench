diff --git a/test/unit/gem_package_scripts_test.rb b/test/unit/gem_package_scripts_test.rb
new file mode 100644
index 00000000..a4649dbe
--- /dev/null
+++ b/test/unit/gem_package_scripts_test.rb
@@ -0,0 +1,74 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/claude_launcher"
+require "rubygems/package"
+require "fileutils"
+
+# Built-gem packaging guard: a clean `gem build` must include every shell
+# script path ClaudeLauncher references at runtime, plus every on-disk
+# script under lib/hive/scripts/ (e.g. stop_hook.sh). Without this, a
+# gemspec regression that drops the lib/hive/scripts/**/*.sh glob only
+# surfaces after install as bash-missing-file / claude_launch_failed.
+class GemPackageScriptsTest < Minitest::Test
+  REPO_ROOT = File.expand_path("../..", __dir__)
+  GEMSPEC_PATH = File.join(REPO_ROOT, "hive.gemspec")
+  SCRIPTS_DIR = File.join(REPO_ROOT, "lib/hive/scripts")
+
+  def test_built_gem_contains_every_claude_launcher_script
+    skip "gem binary not available" unless system("gem", "env", out: File::NULL, err: File::NULL)
+
+    relpaths = Hive::ClaudeLauncher.referenced_script_relpaths
+    refute_empty relpaths, "ClaudeLauncher must enumerate at least one script"
+
+    # WRAPPER_SCRIPT must stay on the same list the packaging guard uses
+    # (TS1.4 future-proofing — not a hard-coded path only in this test).
+    assert_includes Hive::ClaudeLauncher.referenced_script_paths,
+                    Hive::ClaudeLauncher::WRAPPER_SCRIPT
+
+    # Every on-disk shell script under lib/hive/scripts/ must ship even if
+    # ClaudeLauncher does not list it (stop_hook.sh and future neighbors).
+    # gemspec_test checks spec.files; this asserts the built .gem contents.
+    on_disk_scripts = Dir[File.join(SCRIPTS_DIR, "**", "*.sh")].map { |path|
+      path.delete_prefix("#{REPO_ROOT}/")
+    }.sort
+    refute_empty on_disk_scripts, "expected shell scripts under lib/hive/scripts/"
+
+    Dir.mktmpdir("hive-gem-package-") do |tmpdir|
+      gem_path = build_gem_in!(tmpdir)
+      package_files = gem_contents(gem_path)
+
+      relpaths.each do |rel|
+        assert_includes package_files, rel,
+                        "built gem must contain #{rel} (ClaudeLauncher.referenced_script_relpaths)"
+      end
+
+      on_disk_scripts.each do |rel|
+        assert_includes package_files, rel,
+                        "built gem must contain on-disk script #{rel}"
+      end
+    end
+  end
+
+  private
+
+  def build_gem_in!(tmpdir)
+    # gem build writes the .gem next to the gemspec by default; run from a
+    # copy of the gemspec context so we never litter the repo root.
+    # Building from REPO_ROOT is fine if we move the artifact into tmpdir.
+    output = Dir.chdir(REPO_ROOT) do
+      IO.popen([ "gem", "build", GEMSPEC_PATH, "--output", File.join(tmpdir, "hive-cli-test.gem") ],
+               err: [ :child, :out ], &:read)
+    end
+    gem_path = File.join(tmpdir, "hive-cli-test.gem")
+    assert File.file?(gem_path),
+           "gem build failed to produce #{gem_path}:\n#{output}"
+    gem_path
+  end
+
+  def gem_contents(gem_path)
+    files = []
+    Gem::Package.new(gem_path).contents.each { |entry| files << entry }
+    files
+  end
+end
