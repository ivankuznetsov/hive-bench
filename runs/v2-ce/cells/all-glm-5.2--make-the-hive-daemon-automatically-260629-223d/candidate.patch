diff --git a/lib/hive/daemon/auto_retry.rb b/lib/hive/daemon/auto_retry.rb
new file mode 100644
index 00000000..f2ddd053
--- /dev/null
+++ b/lib/hive/daemon/auto_retry.rb
@@ -0,0 +1,81 @@
+# frozen_string_literal: true
+
+module Hive
+  module Daemon
+    # Auto-retry layer for parked terminal `ERROR` markers whose underlying
+    # dependency has recovered. A sibling to {StaleAgentHealer}: the healer
+    # auto-clears a narrow *environmental* subset of markers (agent loss,
+    # limits cooldown, unpushed commits, side-effect-safe timeout, fix-phase
+    # auto-commit hiccups); this layer adds *dependency-recovery* for the two
+    # v1 reasons whose failure is external to the task and whose retry is
+    # safe once the dependency is healthy again:
+    #
+    #   - `ERROR reason=implementer_failed` on 4-execute when the stage log
+    #     carries a Codex auth-401 signature (not a business-logic failure).
+    #   - `ERROR reason=claude_launch_failed` on a tmux-mode stage whose
+    #     launcher readiness probe now passes.
+    #
+    # Both share the dispatcher tick, the {Hive::Markers.clear_current}
+    # primitive, and the audit surfaces. The layer is shipped behind a
+    # global kill-switch `daemon.auto_retry.enabled` (default `true` for the
+    # v1 allowlisted reasons only). See the plan in
+    # `docs/plans/.../plan.md` for the full design.
+    module AutoRetry
+      # The fixed v1 allowlist of recoverable marker reasons. Everything
+      # else stays parked for manual `hive markers clear`.
+      RECOVERABLE_REASONS = %w[implementer_failed claude_launch_failed].freeze
+
+      # Codex auth-401 signature: matched against the execute stage's newest
+      # agent log. The auth-specific phrases (`Missing bearer`, `Missing
+      # basic`, `bearer/basic auth`) anchor the match so a log that happens
+      # to contain `401` in unrelated output is not misclassified.
+      CODEX_AUTH_401_RE = /401|Missing bearer|Missing basic|bearer\/basic auth/i
+
+      # Probe timeouts (seconds). Short-bounded; a hang degrades to
+      # `:timeout`, never `:green`.
+      LOGIN_STATUS_TIMEOUT_SEC = 10
+      CODEX_EXEC_SMOKE_TIMEOUT_SEC = 30
+      BINARY_VERSION_TIMEOUT_SEC = 10
+
+      # Per-tick cache + signal-change gating.
+      FALLBACK_PROBE_INTERVAL_SEC = 5 * 60
+
+      # Retry budget + backoff. Max 2 auto-retries per task/reason; immediate
+      # backoff after the first attempt, then 30 min after the second.
+      MAX_AUTO_RETRIES = 2
+      BACKOFF_AFTER_FIRST = 0
+      BACKOFF_AFTER_SECOND = 30 * 60
+      BACKOFFS = [ BACKOFF_AFTER_FIRST, BACKOFF_AFTER_SECOND ].freeze
+
+      # Captured probe stdout/stderr truncation for audit logs.
+      CAPTURE_BYTES = 2_048
+      TRUNCATION_SUFFIX = "…[truncated]".freeze
+
+      # Byte-aware truncation shared by Probes and Auditor so the captured-
+      # output cap cannot drift between the two. Accounts for the suffix
+      # byte budget (mirrors `Hive::Events.truncate_message`) so the full
+      # result never exceeds `CAPTURE_BYTES`, and scrubs to a valid UTF-8
+      # boundary so a later JSON encode never sees a split character.
+      def self.truncate_capture(text)
+        text = text.to_s
+        return text if text.bytesize <= CAPTURE_BYTES
+
+        budget = CAPTURE_BYTES - TRUNCATION_SUFFIX.bytesize
+        trimmed = text.byteslice(0, budget).to_s
+        trimmed.scrub!("")
+        "#{trimmed}#{TRUNCATION_SUFFIX}"
+      end
+    end
+  end
+end
+
+require "hive/daemon/auto_retry/classifier"
+require "hive/daemon/auto_retry/probes"
+require "hive/daemon/auto_retry/signal_fingerprint"
+require "hive/daemon/auto_retry/probe_cache"
+require "hive/daemon/auto_retry/budget"
+require "hive/daemon/auto_retry/state_store"
+require "hive/daemon/auto_retry/safety_guard"
+require "hive/daemon/auto_retry/retry_executor"
+require "hive/daemon/auto_retry/auditor"
+require "hive/daemon/auto_retry/coordinator"
diff --git a/lib/hive/daemon/auto_retry/auditor.rb b/lib/hive/daemon/auto_retry/auditor.rb
new file mode 100644
index 00000000..8eeabbe8
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/auditor.rb
@@ -0,0 +1,197 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/events"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Audit & observability. Records auto-retry decisions on both the task
+      # `events.jsonl` (Hive::Events.emit) and the daemon log (Logger.event),
+      # with the required fields. Negative decisions are throttled: per-
+      # `(project, slug, reason)` dedup of the rationale signature so a
+      # persistently-red marker logs `not_retried: <rationale>` once per
+      # distinct rationale per process, re-logging only when the rationale
+      # changes; capped to one task-log negative line per `(slug, reason)`
+      # per AutoRetry::FALLBACK_PROBE_INTERVAL_SEC.
+      #
+      # Cleared retries get a full daemon-log event + a task events.jsonl
+      # line. Exhaustion is logged once per key per process (dedup).
+      class Auditor
+        attr_reader :logger
+
+        def initialize(logger:)
+          @logger = logger
+          @seen_rationales = {}        # [project, slug, reason] => last rationale
+          @last_negative_task_log = {} # [slug, reason] => last emit Time
+          @logged_exhausted = {}       # [project, slug, reason] => true
+          @seen_evaluated = {}         # [project, slug, reason] => last budget_status
+        end
+
+        # Daemon-log-only per-row evaluation breadcrumb (every recoverable
+        # row the layer touches in a tick). Structured but lightweight.
+        # Throttled per (project, slug, reason) by budget_status signature —
+        # re-logged only when the status changes — so a project with many
+        # persistently-parked rows does not bloat daemon.log with N identical
+        # `evaluated` lines per tick (mirrors the not_retried rationale dedup).
+        def evaluated(row, classifier_result:, fingerprint:, budget_status:)
+          reason = classifier_result.is_a?(Hash) ? classifier_result[:reason] : nil
+          key = [ row.project.to_s, row.slug.to_s, reason.to_s ]
+          if @seen_evaluated[key] == budget_status
+            # Throttled: same budget_status as last log for this key — skip
+            # the daemon-log repeat (re-log only when the status changes).
+            return
+          end
+          @seen_evaluated[key] = budget_status
+
+          @logger.event(:auto_retry_evaluated,
+                        project: row.project, slug: row.slug, stage: row.stage,
+                        marker_id: marker_id(row),
+                        reason: reason,
+                        classifier_signature: classifier_result.is_a?(Hash) ? classifier_result[:signature] : nil,
+                        signal_fingerprint: fingerprint,
+                        budget_status: budget_status)
+        end
+
+        # A cleared retry: full daemon-log event + one task events.jsonl line.
+        def cleared(row, classifier_result:, probe_results:, fingerprint:, attempt:, rationale:)
+          @logger.event(:auto_retry_cleared,
+                        project: row.project, slug: row.slug, stage: row.stage,
+                        marker_id: marker_id(row),
+                        reason: classifier_result[:reason],
+                        classifier_signature: classifier_result[:signature],
+                        probe_results: serialize_probes(probe_results),
+                        signal_fingerprint: fingerprint,
+                        auto_retry_attempt: attempt,
+                        action: "cleared",
+                        rationale: rationale)
+          emit_task_event(row, "cleared reason=#{classifier_result[:reason]} " \
+                               "probe=#{classifier_result[:signature]} attempt=#{attempt}")
+        end
+
+        # A not-retried negative decision. Daemon-log throttled per rationale;
+        # task-log line capped per (slug, reason) per fallback interval.
+        def not_retried(row, classifier_result:, rationale:, fingerprint:, now: Time.now, doctor_rows: nil)
+          key = [ row.project.to_s, row.slug.to_s, rationale_reason(row, classifier_result) ]
+          if @seen_rationales[key] == rationale
+            # Throttled: same rationale as last log for this key — skip the
+            # daemon-log repeat (re-log only when the rationale changes).
+            return
+          end
+          @seen_rationales[key] = rationale
+
+          @logger.event(:auto_retry_not_retried,
+                        project: row.project, slug: row.slug, stage: row.stage,
+                        marker_id: marker_id(row),
+                        reason: classifier_result.is_a?(Hash) ? classifier_result[:reason] : nil,
+                        classifier_signature: classifier_result.is_a?(Hash) ? classifier_result[:signature] : nil,
+                        signal_fingerprint: fingerprint,
+                        action: "not_retried",
+                        rationale: rationale,
+                        doctor_rows: doctor_summary(doctor_rows))
+
+          task_key = [ row.slug.to_s, rationale_reason(row, classifier_result) ]
+          last = @last_negative_task_log[task_key]
+          return if last && (now - last) < AutoRetry::FALLBACK_PROBE_INTERVAL_SEC
+
+          @last_negative_task_log[task_key] = now
+          emit_task_event(row, "not_retried reason=#{rationale_reason(row, classifier_result)} #{rationale}")
+        end
+
+        # Exhaustion: logged once per key per process (dedup), with the
+        # manual reset gesture.
+        def exhausted(row, classifier_result:, fingerprint:, attempts:, now: Time.now)
+          key = [ row.project.to_s, row.slug.to_s, classifier_result[:reason] ]
+          return if @logged_exhausted[key]
+
+          @logged_exhausted[key] = true
+          remediation = "hive markers clear #{row.project} #{row.slug} --stage #{row.stage} " \
+                        "(or run the stage verb manually)"
+          @logger.event(:auto_retry_exhausted,
+                        project: row.project, slug: row.slug, stage: row.stage,
+                        marker_id: marker_id(row),
+                        reason: classifier_result[:reason],
+                        classifier_signature: classifier_result[:signature],
+                        signal_fingerprint: fingerprint,
+                        auto_retry_attempt: attempts,
+                        max_attempts: AutoRetry::MAX_AUTO_RETRIES,
+                        budget_scope: "persisted",
+                        action: "exhausted",
+                        suggested_next_action: "manual_fix",
+                        remediation: remediation)
+          emit_task_event(row, "exhausted reason=#{classifier_result[:reason]} attempts=#{attempts}; " \
+                               "run `hive markers clear` to reset")
+        end
+
+        # The marker cleared but the requeue write failed — the marker is
+        # gone, so this must carry the manual remediation command.
+        def requeue_failed(row, classifier_result:, error:, remediation:)
+          @logger.event(:auto_retry_requeue_failed,
+                        project: row.project, slug: row.slug, stage: row.stage,
+                        marker_id: marker_id(row),
+                        reason: classifier_result[:reason],
+                        classifier_signature: classifier_result[:signature],
+                        action: "requeue_failed",
+                        error: error,
+                        remediation: remediation)
+          emit_task_event(row, "requeue_failed reason=#{classifier_result[:reason]}; run `#{remediation}`")
+        end
+
+        # Kill-switch off: one daemon-log line per process noting the layer
+        # is disabled (observability — otherwise the layer being off is
+        # indistinguishable from a quiet tick).
+        def disabled_once
+          return if @disabled_logged
+          @disabled_logged = true
+          @logger.event(:auto_retry_disabled, message: "auto_retry layer disabled by daemon.auto_retry.enabled=false")
+        end
+
+        private
+
+        def emit_task_event(row, message)
+          Hive::Events.emit(task_folder: row.folder, slug: row.slug, stage: row.stage.to_s,
+                            event_type: :auto_retry, message: message)
+        rescue StandardError
+          nil
+        end
+
+        def serialize_probes(probe_results)
+          Array(probe_results).each_with_object({}) do |r, acc|
+            next unless r.respond_to?(:name) && r.respond_to?(:status)
+
+            entry = { "status" => r.status.to_s }
+            if r.respond_to?(:stdout) && !r.stdout.to_s.empty?
+              entry["stdout"] = truncate(r.stdout.to_s)
+            end
+            if r.respond_to?(:stderr) && !r.stderr.to_s.empty?
+              entry["stderr"] = truncate(r.stderr.to_s)
+            end
+            entry["detail"] = r.detail.to_s if r.respond_to?(:detail) && !r.detail.to_s.empty?
+            acc[r.name.to_s] = entry
+          end
+        end
+
+        def doctor_summary(doctor_rows)
+          return nil unless doctor_rows.is_a?(Array)
+
+          doctor_rows.map { |r| "#{r[:label]}=#{r[:status]}" }.join(",")
+        end
+
+        def rationale_reason(row, classifier_result)
+          classifier_result.is_a?(Hash) ? classifier_result[:reason].to_s : row.respond_to?(:marker_attrs) ? row.marker_attrs["reason"].to_s : ""
+        end
+
+        def marker_id(row)
+          attrs = row.respond_to?(:marker_attrs) ? row.marker_attrs : nil
+          return nil unless attrs.is_a?(Hash)
+
+          attrs["marker_id"]
+        end
+
+        def truncate(text)
+          AutoRetry.truncate_capture(text)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/budget.rb b/lib/hive/daemon/auto_retry/budget.rb
new file mode 100644
index 00000000..7cbc1323
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/budget.rb
@@ -0,0 +1,82 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/daemon/auto_retry/state_store"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Retry budget + backoff. Max 2 auto-retries per task/reason; a changed
+      # health signal since the last failed attempt is required (the
+      # unchanged-signal gate); immediate backoff after the first attempt,
+      # then 30 min after the second; exhaust ⇒ permanent park for manual
+      # `hive markers clear`.
+      #
+      # The store persists attempt counts so a daemon restart does not
+      # circumvent the 2-retry cap. `Budget.allow?` is a pure read; the
+      # caller calls `record_attempt!` ONLY after a successful clear so a
+      # raced/no-op clear does not consume budget, and `record_probe!`
+      # after every probe run (green or red) to stamp the fingerprint that
+      # backs the unchanged-signal gate.
+      module Budget
+        module_function
+
+        # Returns one of :allow, :exhausted, :unchanged_signal, :in_backoff.
+        # `map` is the in-memory record map (loaded from StateStore + mutated
+        # in place by record_attempt!). `key` is [project, slug, reason].
+        def allow?(map, key, now:, fingerprint:)
+          rec = map[key] || empty_record
+
+          if rec.fetch(:attempts) >= AutoRetry::MAX_AUTO_RETRIES
+            return :exhausted
+          end
+
+          last_fp = rec.fetch(:last_fingerprint).to_s
+          if !last_fp.empty? && last_fp == fingerprint
+            return :unchanged_signal
+          end
+
+          last_attempt = rec[:last_attempt_at]
+          if last_attempt && (now - last_attempt) < backoff_for(rec.fetch(:attempts))
+            return :in_backoff
+          end
+
+          :allow
+        end
+
+        # Record a successful retry attempt. Mutates `map` in place and
+        # returns the new attempt count.
+        def record_attempt!(map, key, now:, fingerprint:)
+          rec = map[key] || empty_record
+          rec[:attempts] = rec.fetch(:attempts) + 1
+          rec[:last_fingerprint] = fingerprint
+          rec[:last_attempt_at] = now
+          map[key] = rec
+          rec.fetch(:attempts)
+        end
+
+        # Stamp the probed fingerprint so the `:unchanged_signal` gate
+        # fires on the next tick while the signal is still the same — this
+        # is what stops a parked red marker from re-spawning the expensive
+        # probes every poll (U2/U3). The caller passes the fingerprint it
+        # actually probed under; a changed signal next tick re-opens `:allow`.
+        def record_probe!(map, key, now:, fingerprint:)
+          rec = map[key] || empty_record
+          rec[:last_probed_at] = now
+          rec[:last_fingerprint] = fingerprint
+          map[key] = rec
+        end
+
+        def backoff_for(attempts)
+          idx = attempts - 1
+          return 0 if idx.negative?
+          AutoRetry::BACKOFFS.fetch(idx, 0)
+        end
+
+        def empty_record
+          { attempts: 0, last_fingerprint: "", last_attempt_at: nil, last_probed_at: nil }
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/classifier.rb b/lib/hive/daemon/auto_retry/classifier.rb
new file mode 100644
index 00000000..0996fcb8
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/classifier.rb
@@ -0,0 +1,122 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/workflows"
+require "hive/config"
+require "hive/agent_limit"
+require "hive/diagnostic_helpers"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Pure classifier: decide, from a parked `ERROR` row's marker attrs +
+      # on-disk diagnostics/logs, whether it is one of the two v1
+      # recoverable reasons with a *recognized signature*, or `:unknown`
+      # (stay parked). No probe execution here — pure/deterministic, takes a
+      # `row` (a `StatusConsumer::Row`) + `cfg`; easy to unit-test without
+      # forking.
+      #
+      # Returns one of:
+      #   { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" } # not-a-stage-ref: docstring example
+      #   { reason: "claude_launch_failed", signature: "launcher_failure", stage: <stage> }
+      #   :unknown
+      module Classifier
+        module_function
+
+        # Signature label for the Codex auth-401 path.
+        CODEX_AUTH_401 = "codex_auth_401".freeze
+        # Signature label for the Claude launcher-failure path.
+        LAUNCHER_FAILURE = "launcher_failure".freeze
+
+        def classify(row, cfg:)
+          reason = marker_reason(row)
+          return :unknown unless AutoRetry::RECOVERABLE_REASONS.include?(reason)
+
+          case reason
+          when "implementer_failed"
+            classify_implementer_failed(row, cfg:)
+          when "claude_launch_failed"
+            classify_claude_launch_failed(row, cfg:)
+          else
+            :unknown
+          end
+        rescue StandardError
+          # Any unexpected error (a torn log read that escaped the bounded
+          # helpers, etc.) degrades to :unknown — never retry on a
+          # classification we cannot make confidently.
+          :unknown
+        end
+
+        def classify_implementer_failed(row, cfg:)
+          return :unknown unless Hive::Workflows.coding_row?(row)
+          return :unknown unless row.stage.to_s == "4-execute" # coding-scoped: codex auth recovery is execute-only
+
+          tail = newest_execute_log_tail(row)
+          return :unknown if tail.to_s.strip.empty?
+
+          return :unknown unless tail.match?(AutoRetry::CODEX_AUTH_401_RE)
+
+          # A limits_reached-classified implementer_failed is already owned
+          # by the existing StaleAgentHealer; do not double-handle it.
+          return :unknown if Hive::AgentLimit.limit_reached?(tail)
+
+          { reason: "implementer_failed", signature: CODEX_AUTH_401, stage: "4-execute" } # coding-scoped: codex auth recovery result
+        end
+
+        def classify_claude_launch_failed(row, cfg:)
+          # The marker is only written by `spawn_claude_with_tmux_marker!`
+          # in tmux mode; a headless-mode claude_launch_failed is unknown.
+          return :unknown unless Hive::Config.claude_mode(cfg) == :tmux
+
+          { reason: "claude_launch_failed", signature: LAUNCHER_FAILURE, stage: row.stage.to_s }
+        end
+
+        # The marker's own `reason=` attribute. Returns "" for a row without
+        # marker_attrs (older payloads / test doubles).
+        def marker_reason(row)
+          attrs = row.respond_to?(:marker_attrs) ? row.marker_attrs : nil
+          return "" unless attrs.is_a?(Hash)
+
+          attrs["reason"].to_s
+        end
+
+        # Read the newest agent log under the task's log_dir, bounded via
+        # DiagnosticHelpers.tail_file. Degrades to "" (→ :unknown) on a
+        # missing/garbage/oversized log so classification never wedges or
+        # raises.
+        def newest_execute_log_tail(row)
+          log_dir = resolve_log_dir(row)
+          return "" unless log_dir && File.directory?(log_dir)
+
+          newest = Dir.glob(File.join(log_dir, "*.log")).max_by { |p| File.mtime(p) }
+          return "" unless newest
+
+          Hive::DiagnosticHelpers.tail_file(newest)
+        rescue SystemCallError, IOError, Encoding::CompatibilityError
+          ""
+        end
+
+        # Derive `<hive_state>/logs/<slug>` from the row's folder path via
+        # the same shape Hive::Task::PATH_RE encodes, WITHOUT constructing a
+        # full Hive::Task (which loads project config + workflows — too
+        # heavy and requires a fully-initialised project). Returns nil when
+        # the folder does not match the canonical task-path shape, so an
+        # arbitrary tmpdir degrades to :unknown rather than raising.
+        TASK_PATH_RE = %r{\A(.+)/([^/]+)/stages/(\d+)-([a-z][a-z0-9-]*)/([a-z][a-z0-9-]{0,62}[a-z0-9])/?\z}
+
+        def resolve_log_dir(row)
+          folder = row.respond_to?(:folder) ? row.folder : nil
+          return nil if folder.to_s.empty?
+
+          match = TASK_PATH_RE.match(folder)
+          return nil unless match
+
+          root = match[1]
+          state_dir = match[2]
+          slug = match[5]
+          File.join(root, state_dir, "logs", slug)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/coordinator.rb b/lib/hive/daemon/auto_retry/coordinator.rb
new file mode 100644
index 00000000..0b58b6f5
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/coordinator.rb
@@ -0,0 +1,288 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/daemon/auto_retry/classifier"
+require "hive/daemon/auto_retry/probes"
+require "hive/daemon/auto_retry/signal_fingerprint"
+require "hive/daemon/auto_retry/probe_cache"
+require "hive/daemon/auto_retry/budget"
+require "hive/daemon/auto_retry/state_store"
+require "hive/daemon/auto_retry/safety_guard"
+require "hive/daemon/auto_retry/retry_executor"
+require "hive/daemon/auto_retry/auditor"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Tick entry point: compose U1–U7. The coordinator owns no policy of its
+      # own — given `rows`, `now`, `cfg`, the probe cache, budget/state,
+      # auditor, and the same skip guards the existing healer uses, it iterates
+      # recoverable `ERROR` rows and drives
+      # classifier→(cache)→probes→signal→budget→safety→execute→audit.
+      #
+      # Runs in the dispatcher tick AFTER StaleAgentHealer (so environmental
+      # clears are not re-handled) and BEFORE per-row dispatch, wrapped in the
+      # same defensive rescue so an auto-retry bug cannot crash the tick or
+      # trip StartLimitBurst.
+      class Coordinator
+        attr_reader :auditor, :budget, :state_store
+
+        def initialize(logger:, controller:, request_queue: Hive::Daemon::DispatchRequestQueue,
+                       state_home: nil, dispatch_request_state_home: nil,
+                       agent_profiles: Hive::AgentProfiles,
+                       probes: Probes, classifier: Classifier, safety_guard: SafetyGuard,
+                       retry_executor: RetryExecutor)
+          @logger = logger
+          @controller = controller
+          @request_queue = request_queue
+          @auditor = Auditor.new(logger: @logger)
+          @state_path = state_home ? File.join(state_home, "daemon_auto_retry_state.json") : StateStore.default_path
+          @state = StateStore.load(@state_path)
+          @agent_profiles = agent_profiles
+          @probes = probes
+          @classifier = classifier
+          @safety_guard = safety_guard
+          @retry_executor = retry_executor
+          # Honor the dispatcher's dispatch-request sandbox so auto-retry's
+          # re-enqueue writes to the same queue home the dispatcher reads —
+          # production passes nil (both resolve `Hive::Paths.state_home`),
+          # tests inject a sandbox for isolation.
+          @dispatch_request_state_home = dispatch_request_state_home || Hive::Paths.state_home
+          @probe_cache = ProbeCache.build
+          @disabled_logged = false
+        end
+
+        # `rows`: the status row set. `now:` one frozen tick time.
+        # `config_loader`: callable(project_name) => merged project cfg.
+        # `legacy_layout_projects`: Set/Hash of project names with a
+        # half-migrated layout (skip). `enabled:` the kill-switch.
+        def tick(rows, now:, config_loader:, legacy_layout_projects: {}, enabled: true)
+          return disable_once if enabled == false
+
+          @probe_cache.clear
+
+          rows.each do |row|
+            next unless row.marker.to_s == "error"
+            next if legacy_layout_projects.include?(row.project)
+            next if @controller.running_task?(project: row.project, slug: row.slug)
+            next if row.live_task_lock == true
+
+            handle_row(row, now: now, cfg: config_loader.call(row.project))
+          end
+
+          persist_state!
+        end
+
+        def handle_row(row, now:, cfg:)
+          classifier_result = @classifier.classify(row, cfg: cfg)
+          reason = classifier_result.is_a?(Hash) ? classifier_result[:reason] : nil
+
+          # Doctor is the cheap in-process universal precondition; run it
+          # FIRST so its rows feed the signal fingerprint (U3) and so
+          # expensive probes can short-circuit on a non-green doctor.
+          doctor = run_doctor(row, cfg: cfg)
+          doctor_rows = doctor.respond_to?(:rows) ? doctor.rows : nil
+
+          observations = gather_observations(row, cfg: cfg, doctor_rows: doctor_rows)
+          fingerprint = SignalFingerprint.for(row, cfg: cfg, observations: observations)
+          key = [ row.project.to_s, row.slug.to_s, reason || "unknown" ]
+
+          budget_status = Budget.allow?(@state, key, now: now, fingerprint: fingerprint)
+          @auditor.evaluated(row, classifier_result: classifier_result,
+                             fingerprint: fingerprint, budget_status: budget_status)
+
+          if classifier_result == :unknown
+            @auditor.not_retried(row, classifier_result: classifier_result, rationale: "unknown_reason",
+                                 fingerprint: fingerprint, now: now, doctor_rows: doctor_rows)
+            return
+          end
+
+          case budget_status
+          when :exhausted
+            @auditor.exhausted(row, classifier_result: classifier_result, fingerprint: fingerprint,
+                               attempts: (@state[key] || Budget.empty_record)[:attempts], now: now)
+            return
+          when :unchanged_signal
+            # Low-frequency fallback (U3): if no signal changed but the
+            # fallback interval has elapsed, re-run the CHEAP probes for
+            # observability and stamp last_probed_at. Expensive probes
+            # (codex_exec_smoke, binary_version_match) are exempt — they
+            # only run on a true signal change — so a fallback alone can
+            # never green-light a retry (the required expensive probe did
+            # not run); the row stays parked as unchanged_signal.
+            if fallback_due?(@state, key, now: now)
+              run_fallback_probes(row, reason: reason, cfg: cfg, doctor: doctor)
+              Budget.record_probe!(@state, key, now: now, fingerprint: fingerprint)
+            end
+            @auditor.not_retried(row, classifier_result: classifier_result, rationale: "unchanged_signal",
+                                 fingerprint: fingerprint, now: now, doctor_rows: doctor_rows)
+            return
+          end
+
+          # budget_status == :allow — run the probes (via the per-tick cache).
+          probes = run_probes(row, reason: reason, cfg: cfg, doctor: doctor)
+          Budget.record_probe!(@state, key, now: now, fingerprint: fingerprint)
+
+          all_green = probes.values.all?(&:green?)
+          unless all_green
+            rationale = not_green_rationale(probes.values.find { |p| !p.green? })
+            @auditor.not_retried(row, classifier_result: classifier_result, rationale: rationale,
+                                 fingerprint: fingerprint, now: now, doctor_rows: doctor_rows)
+            return
+          end
+
+          safety = @safety_guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+          unless safety.safe
+            @auditor.not_retried(row, classifier_result: classifier_result, rationale: "safety_guard:#{safety.reason}",
+                                 fingerprint: fingerprint, now: now, doctor_rows: doctor_rows)
+            return
+          end
+
+          # All gates green — clear + re-enqueue.
+          executor_result = @retry_executor.execute(row, classifier_result: classifier_result, cfg: cfg,
+                                                  logger: @logger, request_queue: @request_queue,
+                                                  controller: @controller,
+                                                  state_home: @dispatch_request_state_home)
+          case executor_result.status
+          when :clear_failed
+            @auditor.not_retried(row, classifier_result: classifier_result, rationale: "marker_raced",
+                                 fingerprint: fingerprint, now: now, doctor_rows: doctor_rows)
+          when :requeue_failed
+            @auditor.requeue_failed(row, classifier_result: classifier_result,
+                                    error: executor_result.error, remediation: executor_result.remediation)
+          when :cleared
+            attempt = Budget.record_attempt!(@state, key, now: now, fingerprint: fingerprint)
+            @auditor.cleared(row, classifier_result: classifier_result, probe_results: probes.values,
+                             fingerprint: fingerprint, attempt: attempt, rationale: "probes_green+safety_ok")
+          end
+        end
+
+        # Gather the cheap (no-spawn) health-signal observations that feed
+        # the fingerprint so a dependency recovery (auth re-appearing, login
+        # flipping, wrapper reinstalled, a doctor row flipping) is a signal
+        # change. `doctor_rows` come from the shared doctor_pass result run
+        # before the fingerprint (U3).
+        def gather_observations(row, cfg:, doctor_rows: nil)
+          {
+            codex_logged_in: @agent_profiles.logged_in?(:codex),
+            auth_mtime: safe_mtime(File.join(Dir.home, ".codex", "auth.json")),
+            wrapper_mtime: safe_mtime(@probes.respond_to?(:default_wrapper_path) ? @probes.default_wrapper_path : Probes.default_wrapper_path),
+            doctor_rows: doctor_rows
+          }
+        end
+
+        def safe_mtime(path)
+          File.mtime(path)
+        rescue Errno::ENOENT, SystemCallError
+          nil
+        end
+
+        # Run the shared `doctor_pass` through the per-tick cache, keyed by
+        # project — doctor is project-specific (`verify_skill(project_root:)`,
+        # `.llm-wiki`, `.hive-state/config.yml`), so two parked rows in
+        # DIFFERENT projects must not share one project's doctor result.
+        def run_doctor(row, cfg:)
+          ProbeCache.fetch(@probe_cache, [ row.project.to_s, "doctor" ]) do
+            @probes.doctor_pass(cfg: cfg, row: row)
+          end
+        end
+
+        # Run the per-reason probes through the per-tick cache so multiple
+        # parked markers of the same reason reuse one spawn per tick.
+        # Expensive probes (codex_exec_smoke, binary_version_match) short-
+        # circuit when the universal doctor precondition is not green — a
+        # red doctor already explains the not-retry, so spawning the CLIs
+        # would only waste a process.
+        def run_probes(row, reason:, cfg:, doctor:)
+          case reason
+          when "implementer_failed"
+            probes = { doctor_pass: doctor }
+            probes[:codex_login_status] = ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "login" ]) {
+              @probes.codex_login_status(cfg: cfg, row: row, agent_profiles: @agent_profiles)
+            }
+            if doctor_green?(doctor)
+              probes[:codex_exec_smoke] = ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "smoke" ]) {
+                @probes.codex_exec_smoke(cfg: cfg, row: row)
+              }
+            end
+            # Short-circuit: a non-green doctor already explains the not-retry,
+            # so the expensive codex_exec_smoke spawn is skipped entirely.
+            probes
+          when "claude_launch_failed"
+            probes = { doctor_pass: doctor }
+            probes[:wrapper_exists] = ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "wrapper" ]) {
+              @probes.wrapper_exists(cfg: cfg, row: row)
+            }
+            probes[:ready_detector] = ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "ready" ]) {
+              @probes.ready_detector(cfg: cfg, row: row)
+            }
+            if doctor_green?(doctor)
+              probes[:binary_version_match] = ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "version" ]) {
+                @probes.binary_version_match(cfg: cfg, row: row)
+              }
+            end
+            # Short-circuit: a non-green doctor already explains the not-retry,
+            # so the expensive binary_version_match spawn is skipped entirely.
+            probes
+          else
+            { doctor_pass: doctor }
+          end
+        end
+
+        # Fallback re-probe (U3): run only the CHEAP in-process probes for
+        # observability when the signal is unchanged but the fallback
+        # interval has elapsed. Expensive probes are deliberately omitted
+        # (they only run on a true signal change).
+        def run_fallback_probes(row, reason:, cfg:, doctor:)
+          case reason
+          when "implementer_failed"
+            ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "login" ]) {
+              @probes.codex_login_status(cfg: cfg, row: row, agent_profiles: @agent_profiles)
+            }
+          when "claude_launch_failed"
+            ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "wrapper" ]) {
+              @probes.wrapper_exists(cfg: cfg, row: row)
+            }
+            ProbeCache.fetch(@probe_cache, [ row.project.to_s, reason, "ready" ]) {
+              @probes.ready_detector(cfg: cfg, row: row)
+            }
+          end
+        end
+
+        def doctor_green?(doctor)
+          doctor.respond_to?(:green?) && doctor.green?
+        end
+
+        def fallback_due?(map, key, now:)
+          rec = map[key]
+          return true unless rec && rec[:last_probed_at]
+
+          (now - rec[:last_probed_at]) >= AutoRetry::FALLBACK_PROBE_INTERVAL_SEC
+        end
+
+        def not_green_rationale(probe)
+          return "probe_red" unless probe.respond_to?(:name) && probe.respond_to?(:status)
+
+          case probe.status
+          when :timeout then "probe_timeout:#{probe.name}"
+          when :error then "probe_error:#{probe.name}"
+          when :red
+            probe.name == "doctor_pass" ? "doctor_red" : "probe_red:#{probe.name}"
+          else
+            "probe_red:#{probe.name}"
+          end
+        end
+
+        def persist_state!
+          StateStore.write(@state, @state_path)
+        rescue StandardError
+          nil
+        end
+
+        def disable_once
+          @auditor.disabled_once
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/probe_cache.rb b/lib/hive/daemon/auto_retry/probe_cache.rb
new file mode 100644
index 00000000..26ec06f0
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/probe_cache.rb
@@ -0,0 +1,38 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Per-daemon-tick cache that memoizes probe results keyed by
+      # `(reason, fingerprint)` so multiple parked markers of the same reason
+      # sharing the same fingerprint reuse one `codex login status` / one
+      # `doctor_pass` per tick. Cleared at the start of each tick by the
+      # coordinator.
+      #
+      # Cheap probes (`doctor_pass`, the in-process `codex_login_status`
+      # precheck) may be re-run on the low-frequency fallback; expensive probes
+      # (`codex_exec_smoke`, `binary_version_match`) only run on a true signal
+      # change — so the cache exposes the key the probe ran under so the
+      # caller can tell whether a cached result was a fallback or a real
+      # signal change.
+      module ProbeCache
+        module_function
+
+        def build
+          {}
+        end
+
+        # Fetch a cached result or run the probe block and cache it. `cache`
+        # is mutated in place. Returns the result (whatever the block
+        # returned). The probe block runs at most once per `key` per tick.
+        def fetch(cache, key)
+          return cache[key] if cache.key?(key)
+
+          cache[key] = yield
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/probes.rb b/lib/hive/daemon/auto_retry/probes.rb
new file mode 100644
index 00000000..59edf4aa
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/probes.rb
@@ -0,0 +1,397 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "open3"
+require "timeout"
+require "fileutils"
+require "hive/agent_profiles"
+require "hive/commands/doctor"
+require "hive/claude_launcher"
+require "hive/config"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Health probes whose green result is a precondition for retry. Each
+      # probe returns a typed {Result} capturing name/status/stdout/stderr/
+      # duration/detail; a timeout or error is never `:green`. Shell-outs run
+      # under `Timeout.timeout` with a child kill so a hung CLI cannot wedge
+      # the daemon tick. Probes do not self-cache — the per-tick {ProbeCache}
+      # (U3) wraps them.
+      module Probes
+        # A typed probe result. `status` is one of :green, :red, :timeout,
+        # :error. stdout/stderr are truncated to AutoRetry::CAPTURE_BYTES for
+        # audit. `detail` carries a short human-readable note.
+        Result = Struct.new(:name, :status, :stdout, :stderr, :duration_sec, :detail,
+                           :rows, keyword_init: true) do
+          def green?
+            status == :green
+          end
+        end
+
+        module_function
+
+        # Run `hive doctor` in-process; green iff no row is `:missing` or
+        # `:version_too_old` (warnings about optional tools do not block —
+        # the brainstorm rationale is "the failing stage's skills are
+        # healthy"). A `kind: "warning"` row (e.g. a billing-auth advisory
+        # from `tmux_runtime_warnings`) never blocks retry — it is
+        # unrelated to the failing stage's skills, and doctor's own
+        # `failing_status?` already excludes `"warning"`. `doctor:` is
+        # injectable for tests (any object responding to `#call` and
+        # exposing `#rows`).
+        def doctor_pass(cfg:, row:, doctor: nil, project_root: nil)
+          started = monotonic
+          doc = doctor || Hive::Commands::Doctor.new(
+            config: cfg, project_root: project_root || derive_project_root(row), json: true
+          )
+          doc.call
+          rows = doc.rows.to_a
+          green = rows.empty? || rows.all? { |r| green_row?(r[:status].to_s) }
+          Result.new(
+            name: "doctor_pass", status: green ? :green : :red,
+            stdout: "", stderr: "",
+            duration_sec: monotonic - started,
+            detail: green ? "all rows healthy" : "rows: #{summarize_rows(rows)}",
+            rows: rows
+          )
+        rescue StandardError => e
+          result_for_error("doctor_pass", e, started)
+        end
+
+        def green_row?(status)
+          # `"warning"` rows are advisory (billing-auth, optional tools) and
+          # do not indicate a missing/unhealthy skill, so they must not
+          # block retry — mirrors doctor's own `failing_status?`.
+          status == "present" || status == "not_applicable" || status == "warning"
+        end
+
+        # Codex auth recovery probe #1: cheap in-process credential precheck
+        # (no spawn) then shell out `codex login status` with a 10s timeout.
+        # Green iff exit 0 and stdout indicates logged in.
+        def codex_login_status(cfg:, row:, runner: default_runner, now: Time.now, agent_profiles: Hive::AgentProfiles)
+          started = monotonic
+          unless agent_profiles.logged_in?(:codex)
+            return Result.new(name: "codex_login_status", status: :red, stdout: "", stderr: "",
+                              duration_sec: monotonic - started,
+                              detail: "no ~/.codex/auth.json credential (in-process precheck)")
+          end
+
+          bin = resolve_bin(:codex, cfg)
+          run = runner.call(cmd: [ bin, "login", "status" ], env: spawn_env(:codex, cfg, row: row),
+                            timeout: AutoRetry::LOGIN_STATUS_TIMEOUT_SEC, cwd: Dir.pwd)
+          status = if run[:timed_out]
+                     :timeout
+                   elsif run[:error]
+                     :error
+                   elsif success?(run[:status]) && login_logged_in?(run[:stdout].to_s)
+                     :green
+                   else
+                     :red
+                   end
+          Result.new(name: "codex_login_status", status: status,
+                     stdout: truncate(run[:stdout]), stderr: truncate(run[:stderr]),
+                     duration_sec: monotonic - started,
+                     detail: status == :green ? "logged in" : "exit=#{exit_code(run[:status])}")
+        end
+
+        # Codex auth recovery probe #2: shell out a tiny `codex exec --json`
+        # smoke with a 30s timeout in the same env the daemon will use.
+        # Green iff exit 0 and the smoke output parses.
+        def codex_exec_smoke(cfg:, row:, runner: default_runner, now: Time.now)
+          started = monotonic
+          bin = resolve_bin(:codex, cfg)
+          run = runner.call(cmd: [ bin, "exec", "--json", "echo ok" ], env: spawn_env(:codex, cfg, row: row),
+                            timeout: AutoRetry::CODEX_EXEC_SMOKE_TIMEOUT_SEC, cwd: Dir.pwd)
+          status = if run[:timed_out]
+                     :timeout
+                   elsif run[:error]
+                     :error
+                   elsif success?(run[:status]) && smoke_parses?(run[:stdout].to_s)
+                     :green
+                   else
+                     :red
+                   end
+          Result.new(name: "codex_exec_smoke", status: status,
+                     stdout: truncate(run[:stdout]), stderr: truncate(run[:stderr]),
+                     duration_sec: monotonic - started,
+                     detail: status == :green ? "smoke ok" : "exit=#{exit_code(run[:status])}")
+        end
+
+        # Claude launcher recovery probe #1: in-process wrapper path exists
+        # under the active install; record its mtime for the signal
+        # fingerprint (U3).
+        def wrapper_exists(cfg:, row:, wrapper_path: nil)
+          started = monotonic
+          path = wrapper_path || default_wrapper_path
+          exists = File.exist?(path)
+          mtime = exists ? File.mtime(path) : nil
+          Result.new(name: "wrapper_exists", status: exists ? :green : :red,
+                     stdout: "", stderr: "", duration_sec: monotonic - started,
+                     detail: exists ? "path=#{path} mtime=#{mtime&.to_i}" : "missing: #{path}")
+        rescue StandardError => e
+          result_for_error("wrapper_exists", e, started)
+        end
+
+        def default_wrapper_path
+          File.expand_path("scripts/interactive_claude_wrapper.sh",
+                           File.join(__dir__, "..", ".."))
+        end
+
+        # Claude launcher recovery probe #2: confirm the readiness detector
+        # loads and matches a known-ready fixture (the readiness code is
+        # reachable, not that a live tmux pane is up — that is the launcher's
+        # own job on re-dispatch).
+        def ready_detector(cfg:, row:, fixture_text: nil)
+          started = monotonic
+          text = fixture_text || default_ready_fixture
+          matched = Hive::ClaudeLauncher.claude_ready_prompt?(text)
+          Result.new(name: "ready_detector", status: matched ? :green : :red,
+                     stdout: "", stderr: "", duration_sec: monotonic - started,
+                     detail: matched ? "ready fixture matched" : "ready fixture did not match")
+        rescue StandardError => e
+          result_for_error("ready_detector", e, started)
+        end
+
+        # Claude launcher recovery probe #3: shell out `claude --version`
+        # with a 10s timeout and compare against the configured min_version.
+        # Green iff installed >= min AND the binary path that answered is the
+        # one the daemon will spawn.
+        def binary_version_match(cfg:, row:, runner: default_runner, now: Time.now)
+          started = monotonic
+          bin = resolve_bin(:claude, cfg)
+          min_version = min_version_for(:claude, cfg)
+          run = runner.call(cmd: [ bin, "--version" ], env: spawn_env(:claude, cfg, row: row),
+                            timeout: AutoRetry::BINARY_VERSION_TIMEOUT_SEC, cwd: Dir.pwd)
+          return timeout_result("binary_version_match", started) if run[:timed_out]
+          return Result.new(name: "binary_version_match", status: :error, stdout: "",
+                            stderr: truncate(run[:stderr]), duration_sec: monotonic - started,
+                            detail: "spawn error") if run[:error]
+
+          unless success?(run[:status])
+            return Result.new(name: "binary_version_match", status: :red,
+                              stdout: truncate(run[:stdout]), stderr: truncate(run[:stderr]),
+                              duration_sec: monotonic - started,
+                              detail: "claude --version exited #{exit_code(run[:status])}")
+          end
+
+          version = run[:stdout].to_s[/\d+\.\d+\.\d+/]
+          ok = version && (min_version.nil? || version_meets?(version, min_version))
+          Result.new(name: "binary_version_match", status: ok ? :green : :red,
+                     stdout: truncate(run[:stdout]), stderr: truncate(run[:stderr]),
+                     duration_sec: monotonic - started,
+                     detail: ok ? "version=#{version} >= min=#{min_version}" :
+                                  "version=#{version.inspect} below min=#{min_version.inspect}")
+        end
+
+        # ---- helpers ----
+
+        # Default bounded runner using Process.spawn with a child kill on
+        # timeout. Returns { status: (Process::Status|nil), stdout:, stderr:,
+        # timed_out: }. On a spawn error (e.g. ENOENT missing binary) returns
+        # timed_out: false, status: nil, stderr: the error message.
+        def default_runner
+          lambda do |cmd:, env:, timeout:, cwd:|
+            run_bounded(cmd: cmd, env: env, timeout: timeout, cwd: cwd)
+          end
+        end
+
+        def run_bounded(cmd:, env:, timeout:, cwd:)
+          stdout_r, stdout_w = IO.pipe
+          stderr_r, stderr_w = IO.pipe
+          pid = nil
+          begin
+            pid = Process.spawn(env, *cmd, out: stdout_w, err: stderr_w, chdir: cwd, pgroup: true)
+          rescue Errno::ENOENT, SystemCallError => e
+            stdout_w.close; stderr_w.close
+            stdout_r.close; stderr_r.close
+            return { status: nil, stdout: "", stderr: "#{e.class}: #{e.message}", timed_out: false, error: true }
+          end
+          stdout_w.close; stderr_w.close
+          timed_out = false
+          status = nil
+          begin
+            Timeout.timeout(timeout) do
+              _, status = Process.wait2(pid)
+            end
+          rescue Timeout::Error
+            timed_out = true
+            kill_process_group(pid)
+            _, status = Process.wait2(pid)
+          end
+          out = read_io_nonblock(stdout_r)
+          err = read_io_nonblock(stderr_r)
+          { status: status, stdout: out, stderr: err, timed_out: timed_out, error: false }
+        rescue StandardError => e
+          { status: nil, stdout: "", stderr: "#{e.class}: #{e.message}", timed_out: false, error: true }
+        ensure
+          [ stdout_r, stderr_r ].each { |io| io.close unless io.closed? }
+        end
+
+        def kill_process_group(pid)
+          # Spawned with pgroup: true, so the child is its own process group
+          # leader (pgid == pid). Kill the whole group so any grandchildren
+          # (e.g. a codex subprocess tree) die too, not just the shell.
+          Process.kill("TERM", -pid)
+          sleep 0.05
+          Process.kill("KILL", -pid)
+        rescue Errno::ESRCH, Errno::EPERM
+          nil
+        end
+
+        def read_io_nonblock(io)
+          return "" if io.closed?
+
+          io.read_nonblock(64_000)
+        rescue IO::WaitReadable
+          IO.select([ io ], nil, nil, 0.5)
+          retry
+        rescue EOFError, IOError
+          ""
+        end
+
+        def resolve_bin(name, cfg)
+          Hive::AgentProfiles.lookup(name, cfg: cfg).bin
+        rescue StandardError
+          name.to_s
+        end
+
+        def min_version_for(name, cfg)
+          profile = Hive::AgentProfiles.lookup(name, cfg: cfg)
+          profile.respond_to?(:min_version) ? profile.min_version : cfg.dig("agents", name.to_s, "min_version")
+        rescue StandardError
+          cfg.dig("agents", name.to_s, "min_version")
+        end
+
+        def spawn_env(name, cfg, row: nil)
+          # Forward the daemon environment so HIVE_*_BIN the daemon uses
+          # are honored by the probe's spawn, AND resolve CODEX_HOME to the
+          # task's repo root (the seed report's `CODEX_HOME=<REPO_ROOT>`
+          # codex exec smoke) so the probe runs in the same environment the
+          # execute stage will use — otherwise the smoke can pass while the
+          # real stage still fails (or vice versa). The agent profile's
+          # bin-override env var is forwarded explicitly so a configured
+          # `agents.<name>.env_override` is honored by the spawn.
+          env = ENV.to_h.dup
+
+          if name == :codex
+            root = derive_project_root(row) if row
+            env["CODEX_HOME"] = root if root && !root.empty?
+          end
+
+          override_key = begin
+            profile = Hive::AgentProfiles.lookup(name, cfg: cfg)
+            profile.respond_to?(:env_bin_override_key) ? profile.env_bin_override_key : nil
+          rescue StandardError
+            nil
+          end
+          if override_key && ENV.key?(override_key)
+            env[override_key] = ENV[override_key]
+          end
+
+          env
+        end
+
+        def version_meets?(version, min_version)
+          v = Hive::ClaudeLauncher.version_tuple(version)
+          m = Hive::ClaudeLauncher.version_tuple(min_version)
+          (v <=> m) >= 0
+        rescue StandardError
+          false
+        end
+
+        def success?(status)
+          return false if status.nil?
+          return status.success? if status.respond_to?(:success?)
+          return status.to_i.zero? if status.respond_to?(:to_i)
+
+          false
+        end
+
+        def exit_code(status)
+          return nil if status.nil?
+          return status.exitstatus if status.respond_to?(:exitstatus)
+          return status.to_i if status.respond_to?(:to_i)
+
+          nil
+        end
+
+        def login_logged_in?(stdout)
+          /logged in|Logged in/i.match?(stdout)
+        end
+
+        # The codex `exec --json "echo ok"` smoke emits JSON stream records.
+        # Green iff stdout is non-empty and contains a JSON-ish record or an
+        # "ok"/echo marker. Conservative: empty/garbage => not green.
+        def smoke_parses?(stdout)
+          text = stdout.to_s
+          return false if text.strip.empty?
+
+          text.include?("ok") || /\{.*\}/m.match?(text)
+        end
+
+        # A captured pane fixture the readiness detector treats as a
+        # ready prompt (verified against the same `claude_ready_prompt?`
+        # regex the launcher's own readiness wait uses, exercised in
+        # `claude_launcher_test.rb`). The probe confirms the detector
+        # MATCHES a known-ready fixture — not that a live tmux pane is up
+        # (that is the launcher's own job on re-dispatch). Keeping this in
+        # sync with the launcher's ready-prompt shape is intentional: a
+        # drift here would silently wedge the `claude_launch_failed`
+        # recovery path on `:red`.
+        READY_FIXTURE = <<~PANE.freeze
+          Claude Code v2.1.133
+          Tip: try refactor
+
+          ❯ Try "refactor <filepath>"
+        PANE
+
+        def default_ready_fixture
+          READY_FIXTURE
+        end
+
+        # Derive the task's project root from its folder path via the same
+        # canonical task-path shape the classifier's `TASK_PATH_RE` encodes
+        # — `<root>/<state_dir>/stages/<stage>/<slug>` — WITHOUT hardcoding
+        # the `.hive-state` dirname, so a project with a custom
+        # `hive_state_path` name (configurable per Hive::Config) still
+        # resolves `CODEX_HOME` to the repo root (plan U2). Returns nil
+        # when the folder does not match the canonical shape so an
+        # arbitrary tmpdir degrades to the default codex home rather than
+        # raising.
+        TASK_PATH_RE = %r{\A(.+)/([^/]+)/stages/(\d+)-([a-z][a-z0-9-]*)/([a-z][a-z0-9-]{0,62}[a-z0-9])/?\z}
+
+        def derive_project_root(row)
+          return nil unless row.respond_to?(:folder)
+
+          match = TASK_PATH_RE.match(row.folder.to_s)
+          return nil unless match
+
+          match[1]
+        end
+
+        def summarize_rows(rows)
+          rows.map { |r| "#{r[:label]}=#{r[:status]}" }.join(",").to_s[0, 200]
+        end
+
+        def truncate(text)
+          AutoRetry.truncate_capture(text)
+        end
+
+        def result_for_error(name, error, started)
+          Result.new(name: name, status: :error, stdout: "", stderr: truncate(error.message),
+                     duration_sec: monotonic - started, detail: "#{error.class}: #{error.message}")
+        end
+
+        def timeout_result(name, started)
+          Result.new(name: name, status: :timeout, stdout: "", stderr: "",
+                     duration_sec: monotonic - started, detail: "timed out")
+        end
+
+        def monotonic
+          Process.clock_gettime(Process::CLOCK_MONOTONIC)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/retry_executor.rb b/lib/hive/daemon/auto_retry/retry_executor.rb
new file mode 100644
index 00000000..ec0b56d8
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/retry_executor.rb
@@ -0,0 +1,109 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/markers"
+require "hive/daemon/dispatch_request_queue"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Retry mechanics: make auto-retry mechanically equivalent to
+      # `hive markers clear` + re-enqueue/run the same stage from the start.
+      # No resume path — the stage re-runs from the start, exactly like a
+      # manual clear + `hive run`. The rest of the pipeline sees the same
+      # state transitions/markers.
+      #
+      # On a green probe + budget :allow + safety safe:
+      #   1. `Hive::Markers.clear_current` with `reason` + `marker_id`
+      #      match-attrs (identical guard to `hive markers clear
+      #      --match-attr marker_id=...`). A false return is a silent
+      #      no-op (the marker raced to a newer one); no budget consumed.
+      #   2. Re-enqueue via `DispatchRequestQueue.write_request!` with the
+      #      stage-appropriate verb, `requestor: "auto_retry"`,
+      #      `trigger: "dependency_recovered"`.
+      #   3. Observe the pre-clear state-file mtime so the cleared row takes
+      #      the edit-resume path instead of stranding as first-sight.
+      #
+      # The dispatch request still flows through the normal queue gates
+      # (allowlist, expiry, per-slug in-flight, capacity, cooldown,
+      # quarantine) — auto-retry does not bypass them.
+      module RetryExecutor
+        Result = Struct.new(:status, :request_id, :error, :remediation, keyword_init: true)
+
+        module_function
+
+        # Returns { status: :cleared/:clear_failed/:requeue_failed,
+        # request_id:, error:, remediation: }. The caller records a budget
+        # attempt ONLY on :cleared.
+        def execute(row, classifier_result:, cfg:, logger:, request_queue: Hive::Daemon::DispatchRequestQueue, controller:,
+                    state_home: Hive::Paths.state_home)
+          reason = classifier_result.fetch(:reason)
+          marker_id = marker_id_of(row)
+          match_attrs = { "reason" => reason }
+          match_attrs["marker_id"] = marker_id unless marker_id.empty?
+
+          # clear_current evaluates match-attrs under the markers lock, so a
+          # stale row cannot clear a newer marker. A false return is an
+          # intentional, silent no-op — the marker raced to a newer one; no
+          # budget is consumed.
+          cleared = Hive::Markers.clear_current(
+            row.state_file, expected_name: :error, match_attrs: match_attrs
+          )
+          return Result.new(status: :clear_failed) unless cleared
+
+          observe_pre_clear_mtime(row, controller:, logger:)
+
+          argv = requeue_argv(row, classifier_result)
+          begin
+            request_id = request_queue.write_request!(
+              project: row.project, slug: row.slug, argv: argv,
+              requestor: "auto_retry", trigger: "dependency_recovered",
+              state_home: state_home
+            )
+            Result.new(status: :cleared, request_id: request_id)
+          rescue StandardError => e
+            # The marker is ALREADY gone at this point — this executor can
+            # never re-match the row, so a failed requeue must carry the
+            # manual remediation command (mirrors heal_requeue_failed).
+            Result.new(status: :requeue_failed, error: "#{e.class}: #{e.message}",
+                       remediation: manual_remediation(row, classifier_result))
+          end
+        end
+
+        def requeue_argv(row, classifier_result)
+          stage = classifier_result.fetch(:stage).to_s
+          case stage
+          when "4-execute" # coding-scoped: coding execute requeue verb
+            [ "hive", "run", row.slug, "--project", row.project, "--stage", "4-execute" ] # coding-scoped: coding execute requeue argv
+          when "2-brainstorm" # coding-scoped: coding brainstorm requeue verb
+            [ "hive", "brainstorm", row.slug, "--project", row.project ]
+          when "3-plan" # coding-scoped: coding plan re-runs from its own stage
+            [ "hive", "plan", row.slug, "--project", row.project, "--from", "3-plan" ] # coding-scoped: coding plan re-runs from its own stage
+          else
+            [ "hive", "run", row.slug, "--project", row.project, "--stage", stage ]
+          end
+        end
+
+        def manual_remediation(row, classifier_result)
+          argv = requeue_argv(row, classifier_result).drop(1).join(" ")
+          "hive #{argv}"
+        end
+
+        def observe_pre_clear_mtime(row, controller:, logger:)
+          return unless controller.respond_to?(:observe_state_file_mtime)
+
+          controller.observe_state_file_mtime(
+            project: row.project, slug: row.slug, mtime: row.state_file_mtime
+          )
+        end
+
+        def marker_id_of(row)
+          attrs = row.respond_to?(:marker_attrs) ? row.marker_attrs : nil
+          return "" unless attrs.is_a?(Hash)
+
+          attrs["marker_id"].to_s
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/safety_guard.rb b/lib/hive/daemon/auto_retry/safety_guard.rb
new file mode 100644
index 00000000..a7b3fb49
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/safety_guard.rb
@@ -0,0 +1,222 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "hive/markers"
+require "hive/brainstorm_parser"
+require "hive/worktree"
+require "hive/git_ops"
+require "hive/stages/auto_commit"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Safety guard: block retry when the failed stage produced terminal
+      # success output, when the work area is dirty/ambiguous, or when
+      # answered user content would be overwritten. When uncertain, do NOT
+      # retry. Pure filesystem reads only — no side effects.
+      module SafetyGuard
+        Result = Struct.new(:safe, :reason, keyword_init: true)
+
+        module_function
+
+        # Returns { safe:, reason: }. `classifier_result` is the Classifier
+        # output (a Hash for a recoverable reason, or :unknown).
+        def safe_to_retry?(row, classifier_result, cfg:, git_factory: default_git_factory, parser: Hive::BrainstormParser)
+          return Result.new(safe: false, reason: "unknown_reason") if classifier_result == :unknown
+          return Result.new(safe: false, reason: "unknown_reason") unless classifier_result.is_a?(Hash)
+
+          reason = classifier_result[:reason]
+          case reason
+          when "implementer_failed"
+            safe_to_retry_execute?(row, cfg:, git_factory:)
+          when "claude_launch_failed"
+            safe_to_retry_launcher?(row, cfg:, parser:)
+          else
+            Result.new(safe: false, reason: "unhandled_reason")
+          end
+        rescue StandardError => e
+          # Any parse/IO error, ambiguous partial output, or unclear
+          # ownership ⇒ not safe (uncertain ⇒ do not retry).
+          Result.new(safe: false, reason: "guard_error:#{e.class}")
+        end
+
+        # 4-execute worktree cleanliness + no committed stage output.
+        def safe_to_retry_execute?(row, cfg:, git_factory:)
+          # No terminal success output: the current marker is ERROR
+          # reason=implementer_failed (not EXECUTE_COMPLETE). Verify no
+          # EXECUTE_COMPLETE marker exists earlier in the state file — the
+          # file accumulates content with last-marker-wins, so an earlier
+          # terminal marker would mean a prior successful run whose output
+          # a re-run could clobber.
+          if terminal_success_in_state_file?(row)
+            return Result.new(safe: false, reason: "terminal_success_present")
+          end
+
+          worktree_path = resolve_worktree_path(row)
+          return Result.new(safe: false, reason: "no_worktree") if worktree_path.to_s.empty?
+          return Result.new(safe: false, reason: "missing_worktree") unless File.directory?(worktree_path)
+
+          # The worktree's HEAD must still be the branch the run started on
+          # (plan U5): a branch that advanced with committed stage output
+          # (but no EXECUTE_COMPLETE marker) would be clobbered by a
+          # from-start rerun. Mirrors Stages::Execute#expected_worktree_branch
+          # — the pointer's `branch` + `execute_base_head` are the baseline.
+          branch_check = verify_worktree_branch(row, worktree_path, git_factory: git_factory)
+          return branch_check unless branch_check.nil?
+
+          porcelain = begin
+            git_factory.call(worktree_path).status_short
+          rescue StandardError
+            return Result.new(safe: false, reason: "git_status_failed")
+          end
+
+          return Result.new(safe: true, reason: "clean_worktree") if porcelain.to_s.strip.empty?
+
+          paths = porcelain_paths(porcelain)
+          violations = Hive::Stages::AutoCommit.auto_commit_scope_violations(cfg, paths)
+          if violations.empty?
+            Result.new(safe: true, reason: "agent_scoped_residue")
+          else
+            Result.new(safe: false, reason: "dirty_worktree:#{violations.first.path}")
+          end
+        end
+
+        # Brainstorm/plan launcher failures: no answered user content would
+        # be overwritten.
+        def safe_to_retry_launcher?(row, cfg:, parser: Hive::BrainstormParser)
+          stage = row.respond_to?(:stage) ? row.stage.to_s : ""
+          state_file = row.respond_to?(:state_file) ? row.state_file : nil
+
+          case stage
+          when "2-brainstorm" # coding-scoped: brainstorm launcher failure
+            brainstorm_safe?(state_file, parser:)
+          when "3-plan" # coding-scoped: plan launcher failure
+            plan_safe?(state_file)
+          else
+            # Other tmux stages whose launcher failed: there is no
+            # answered-user-content surface to clobber, so a clean
+            # worktree is not required at this stage — the launcher never
+            # ran. Permit unless we cannot read the stage state.
+            Result.new(safe: true, reason: "launcher_stage_no_user_content")
+          end
+        end
+
+        def brainstorm_safe?(state_file, parser:)
+          return Result.new(safe: true, reason: "seed_only") if state_file.to_s.empty? || !File.exist?(state_file)
+
+          questions = parser.parse(state_file)
+          if questions.any?(&:answered?)
+            Result.new(safe: false, reason: "answered_user_content")
+          else
+            Result.new(safe: true, reason: "no_answered_questions")
+          end
+        end
+
+        def plan_safe?(state_file)
+          return Result.new(safe: true, reason: "empty_plan") if state_file.to_s.empty? || !File.exist?(state_file)
+
+          body = File.read(state_file, encoding: "UTF-8").scrub
+          stripped = strip_markers_and_whitespace(body)
+          return Result.new(safe: true, reason: "seed_only_plan") if stripped.empty?
+
+          # Non-trivial plan content from a prior partial run would be
+          # overwritten by a from-start rerun; treat as not safe.
+          Result.new(safe: false, reason: "non_seed_plan_content")
+        end
+
+        def terminal_success_in_state_file?(row)
+          state_file = row.respond_to?(:state_file) ? row.state_file : nil
+          return false if state_file.to_s.empty? || !File.exist?(state_file)
+
+          body = File.read(state_file, encoding: "UTF-8").scrub
+          # An earlier EXECUTE_COMPLETE marker in the accumulated body.
+          body.match?(/<!--\s*EXECUTE_COMPLETE\b/)
+        rescue StandardError
+          false
+        end
+
+        def resolve_worktree_path(row)
+          folder = row.respond_to?(:folder) ? row.folder : nil
+          return nil if folder.to_s.empty?
+
+          pointer = Hive::Worktree.read_pointer(folder)
+          return nil unless pointer.is_a?(Hash)
+
+          pointer["path"]
+        end
+
+        # Verify the worktree's HEAD is still the branch the run started on
+        # (plan U5). Returns a not-safe Result when the branch diverged or
+        # the check could not be performed; returns nil when the branch is
+        # unchanged (or the pointer carries no baseline to compare against,
+        # preserving pre-U5 behavior for worktrees created before the guard
+        # existed). `execute_base_head` is the HEAD recorded when the execute
+        # stage created the worktree; a current HEAD that differs means
+        # committed stage output a from-start rerun would reset/clobber.
+        def verify_worktree_branch(row, worktree_path, git_factory:)
+          pointer = Hive::Worktree.read_pointer(row.respond_to?(:folder) ? row.folder : nil) || {}
+          expected_branch = pointer["branch"]
+          base_head = pointer["execute_base_head"]
+
+          # No baseline recorded — cannot verify; defer to the other checks
+          # rather than blocking retry on legacy worktrees.
+          return nil if expected_branch.nil? && base_head.nil?
+
+          git = begin
+            git_factory.call(worktree_path)
+          rescue StandardError
+            return Result.new(safe: false, reason: "worktree_branch_unverified")
+          end
+
+          current_branch = begin
+            git.current_branch
+          rescue StandardError
+            return Result.new(safe: false, reason: "worktree_branch_unverified")
+          end
+          if expected_branch && current_branch != expected_branch
+            return Result.new(safe: false, reason: "worktree_branch_mismatch")
+          end
+
+          if base_head
+            current_head = begin
+              git.head_sha
+            rescue StandardError
+              return Result.new(safe: false, reason: "worktree_branch_unverified")
+            end
+            if current_head != base_head
+              return Result.new(safe: false, reason: "worktree_head_advanced")
+            end
+          end
+
+          nil
+        end
+
+        # Parse `git status --porcelain` lines into relative paths. Handles
+        # the 2-char status prefix; ignores rename sources (R/LC lines emit
+        # "path\tpath"; take only the destination). Quoted paths (CRLF/core.
+        # quotepath) are stripped of surrounding quotes.
+        def porcelain_paths(porcelain)
+          porcelain.to_s.each_line.filter_map do |line|
+            next if line.strip.empty?
+
+            # 2 status chars + space, then path (possibly quoted, with \t for renames)
+            raw = line[3..].to_s.chomp
+            raw = raw.split("\t").last if raw.include?("\t") # rename -> take destination
+            raw = raw[1..-2] if raw.start_with?('"') && raw.end_with?('"')
+            next if raw.nil? || raw.empty?
+
+            raw
+          end
+        end
+
+        def strip_markers_and_whitespace(body)
+          body.gsub(/<!--.*?-->/m, "").strip
+        end
+
+        def default_git_factory
+          ->(path) { Hive::GitOps.new(path) }
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/signal_fingerprint.rb b/lib/hive/daemon/auto_retry/signal_fingerprint.rb
new file mode 100644
index 00000000..e24b3055
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/signal_fingerprint.rb
@@ -0,0 +1,85 @@
+# frozen_string_literal: true
+
+require "hive/daemon/auto_retry"
+require "digest"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Pure signal-change gate. Computes a stable digest of the inputs that,
+      # if changed since the last failed attempt, justify re-probing. The
+      # inputs are deliberately coarse (path/mtime/boolean/version-string,
+      # not high-cardinality) so a flapping input cannot churn the cache.
+      #
+      # The "changed health signal since the last failed attempt"
+      # requirement is implemented as fingerprint inequality: a retry is only
+      # allowed when `current_fingerprint != last_attempt_fingerprint`.
+      #
+      # Pure: takes a `row` + `cfg` + an `observations:` hash gathered by the
+      # coordinator (doctor rows, wrapper mtime, codex login state, auth.json
+      # mtime). No I/O side effects — easy to unit-test.
+      module SignalFingerprint
+        module_function
+
+        # observations keys (all optional):
+        #   doctor_rows:        Array of {label:,status:} (from doctor_pass)
+        #   wrapper_mtime:      Time|nil (from wrapper_exists)
+        #   codex_logged_in:    true|false|nil (from AgentProfiles)
+        #   auth_mtime:         Time|nil (~/.codex/auth.json mtime)
+        # The row's marker_id + state_file mtime carry the manual
+        # marker-clear/retry event (a fresh marker_id after a clear is a
+        # distinct signal).
+        def for(row, cfg:, observations: {})
+          parts = []
+          parts << "claude_mode=#{Hive::Config.claude_mode(cfg)}"
+
+          %i[claude codex].each do |name|
+            parts << "#{name}_bin=#{safe_bin(name, cfg)}"
+            parts << "#{name}_min=#{cfg.dig("agents", name.to_s, "min_version").to_s}"
+          end
+
+          %w[CODEX_HOME HIVE_CLAUDE_BIN HIVE_CODEX_BIN HIVE_TMUX_BIN].each do |env_key|
+            parts << "#{env_key}=#{ENV.fetch(env_key, "")}"
+          end
+
+          parts << "codex_logged_in=#{observations[:codex_logged_in].inspect}"
+          parts << "auth_mtime=#{ts(observations[:auth_mtime])}"
+          parts << "wrapper_mtime=#{ts(observations[:wrapper_mtime])}"
+
+          doctor = observations[:doctor_rows]
+          if doctor.is_a?(Array)
+            parts << "doctor=#{doctor.map { |r| "#{r[:label]}=#{r[:status]}" }.join(",")}"
+          end
+
+          parts << "marker_id=#{marker_id_of(row)}"
+          parts << "state_mtime=#{ts(state_mtime_of(row))}"
+          parts << "stage=#{row.respond_to?(:stage) ? row.stage.to_s : ""}"
+          parts << "slug=#{row.respond_to?(:slug) ? row.slug.to_s : ""}"
+
+          ::Digest::SHA256.hexdigest(parts.join("\n"))
+        end
+
+        def safe_bin(name, cfg)
+          Hive::AgentProfiles.lookup(name, cfg: cfg).bin
+        rescue StandardError
+          name.to_s
+        end
+
+        def marker_id_of(row)
+          attrs = row.respond_to?(:marker_attrs) ? row.marker_attrs : nil
+          return "" unless attrs.is_a?(Hash)
+
+          attrs["marker_id"].to_s
+        end
+
+        def state_mtime_of(row)
+          row.respond_to?(:state_file_mtime) ? row.state_file_mtime : nil
+        end
+
+        def ts(time)
+          time.respond_to?(:to_i) ? time.to_i.to_s : ""
+        end
+      end
+    end
+  end
+end
