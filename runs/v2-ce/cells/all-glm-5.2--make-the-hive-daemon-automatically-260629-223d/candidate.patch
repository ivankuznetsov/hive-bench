+  # A fake spawn runner. Calls return a hash shaped like run_bounded.
+  class FakeRunner
+    def initialize
+      @calls = []
+      @responses = []
+    end
+
+    attr_reader :calls
+
+    def respond(status: 0, stdout: "", stderr: "", timed_out: false, error: false)
+      @responses << { status: status, stdout: stdout, stderr: stderr,
+                      timed_out: timed_out, error: error }
+    end
+
+    def call(cmd:, env:, timeout:, cwd:)
+      @calls << { cmd: cmd, env: env, timeout: timeout, cwd: cwd }
+      @responses.shift || { status: 0, stdout: "", stderr: "", timed_out: false, error: false }
+    end
+  end
+
+  class FakeDoctor
+    attr_reader :rows, :called
+    def initialize(rows)
+      @rows = rows
+      @called = 0
+    end
+    def call
+      @called += 1
+      0
+    end
+  end
+
+  class FakeAgentProfiles
