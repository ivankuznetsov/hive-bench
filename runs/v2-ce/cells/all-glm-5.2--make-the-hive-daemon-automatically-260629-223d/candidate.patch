+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "digest"
+require "hive/daemon/auto_retry/signal_fingerprint"
+require "hive/daemon/auto_retry/probe_cache"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetrySignalFingerprintTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  FP = Hive::Daemon::AutoRetry::SignalFingerprint
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  def make_row(marker_id: "abc12345", state_mtime: NOW - 1000, stage: "4-execute",
+               slug: "auto-retry-test-260629-aaaa")
+    dir = Dir.mktmpdir
+    folder = File.join(dir, ".hive-state", "stages", stage, slug)
+    FileUtils.mkdir_p(folder)
+    Row.new(project: "myproj", slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => "implementer_failed", "marker_id" => marker_id },
+           folder: folder, state_file: File.join(folder, "task.md"),
+           state_file_mtime: state_mtime, action: "error", suggested_command: nil,
+           claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil)
+  end
+
+  def cfg(claude_mode: "tmux")
+    { "claude" => { "mode" => claude_mode }, "agents" => {} }
+  end
+
+  def with_env(overrides)
+    saved = overrides.keys.to_h { |k| [ k, ENV[k] ] }
+    overrides.each { |k, v| v.nil? ? ENV.delete(k) : (ENV[k] = v) }
+    yield
+  ensure
+    saved.each { |k, v| v.nil? ? ENV.delete(k) : (ENV[k] = v) }
+  end
+
+  def baseline
+    make_row
+  end
+
+  def observations
+    { doctor_rows: [ { label: "tmux", status: "present" } ],
+      wrapper_mtime: Time.utc(2026, 6, 1), codex_logged_in: true,
+      auth_mtime: Time.utc(2026, 6, 2) }
+  end
+
+  def test_stable_across_ticks_when_nothing_changes
+    with_env("CODEX_HOME" => "/x", "HIVE_CODEX_BIN" => "codex") do
+      a = FP.for(baseline, cfg: cfg, observations: observations)
+      b = FP.for(baseline, cfg: cfg, observations: observations)
+      assert_equal a, b
+    end
+  end
+
+  def test_changes_when_claude_mode_flips
+    a = FP.for(baseline, cfg: cfg(claude_mode: "tmux"), observations: observations)
+    b = FP.for(baseline, cfg: cfg(claude_mode: "headless"), observations: observations)
+    refute_equal a, b
+  end
+
+  def test_changes_when_codex_env_changes
+    a = with_env("HIVE_CODEX_BIN" => "codex") { FP.for(baseline, cfg: cfg, observations: observations) }
+    b = with_env("HIVE_CODEX_BIN" => "/opt/codex") { FP.for(baseline, cfg: cfg, observations: observations) }
+    refute_equal a, b
+  end
+
+  def test_changes_when_codex_home_changes
+    a = with_env("CODEX_HOME" => "/home/a/.codex") { FP.for(baseline, cfg: cfg, observations: observations) }
+    b = with_env("CODEX_HOME" => "/home/b/.codex") { FP.for(baseline, cfg: cfg, observations: observations) }
+    refute_equal a, b
+  end
+
+  def test_changes_when_auth_mtime_changes
+    obs_a = observations.merge(auth_mtime: Time.utc(2026, 6, 2))
+    obs_b = observations.merge(auth_mtime: Time.utc(2026, 6, 3))
+    a = FP.for(baseline, cfg: cfg, observations: obs_a)
+    b = FP.for(baseline, cfg: cfg, observations: obs_b)
+    refute_equal a, b
+  end
+
+  def test_changes_when_wrapper_mtime_changes
+    obs_a = observations.merge(wrapper_mtime: Time.utc(2026, 6, 1))
+    obs_b = observations.merge(wrapper_mtime: Time.utc(2026, 6, 5))
+    a = FP.for(baseline, cfg: cfg, observations: obs_a)
+    b = FP.for(baseline, cfg: cfg, observations: obs_b)
+    refute_equal a, b
+  end
+
+  def test_changes_when_a_doctor_row_status_flips
+    obs_a = observations.merge(doctor_rows: [ { label: "tmux", status: "present" } ])
+    obs_b = observations.merge(doctor_rows: [ { label: "tmux", status: "missing" } ])
+    a = FP.for(baseline, cfg: cfg, observations: obs_a)
+    b = FP.for(baseline, cfg: cfg, observations: obs_b)
+    refute_equal a, b
+  end
+
+  def test_changes_when_marker_id_changes
+    a = FP.for(make_row(marker_id: "abc12345"), cfg: cfg, observations: observations)
+    b = FP.for(make_row(marker_id: "def67890"), cfg: cfg, observations: observations)
+    refute_equal a, b
+  end
+
+  def test_returns_hex_digest
+    with_env("CODEX_HOME" => nil) do
+      digest = FP.for(baseline, cfg: cfg, observations: observations)
+      assert_match(/\A[0-9a-f]{64}\z/, digest)
+    end
+  end
+end
+
+class HiveDaemonAutoRetryProbeCacheTest < Minitest::Test
+  Cache = Hive::Daemon::AutoRetry::ProbeCache
+
+  def test_cache_runs_block_once_per_key
+    cache = Cache.build
+    calls = []
+    2.times do
+      Cache.fetch(cache, "k1") { calls << 1; :result }
+    end
+    assert_equal 1, calls.size
+    assert_equal :result, Cache.fetch(cache, "k1") { :other }
+  end
+
+  def test_cache_distinguishes_keys
+    cache = Cache.build
+    a = Cache.fetch(cache, "k1") { :a }
+    b = Cache.fetch(cache, "k2") { :b }
+    assert_equal :a, a
+    assert_equal :b, b
+    assert_equal :a, Cache.fetch(cache, "k1") { :x }
+  end
+
+  def test_cache_is_cleared_between_ticks
+    cache = Cache.build
+    Cache.fetch(cache, "k1") { :v }
+    cache.clear
+    refute cache.key?("k1")
+    new_val = Cache.fetch(cache, "k1") { :fresh }
+    assert_equal :fresh, new_val
+  end
+end
