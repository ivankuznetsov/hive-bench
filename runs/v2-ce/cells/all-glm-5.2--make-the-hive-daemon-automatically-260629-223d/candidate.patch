new file mode 100644
index 00000000..bb9871ed
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/state_store.rb
@@ -0,0 +1,129 @@
+# frozen_string_literal: true
+
+require "json"
+require "fileutils"
+require "time"
+require "hive/daemon/auto_retry"
+require "hive/paths"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Small persisted JSON store for the per-`(project, slug, reason)` attempt
+      # record: `attempts`, `last_fingerprint`, `last_attempt_at`,
+      # `last_probed_at`. Atomic write (tempfile + fsync + rename + dir fsync),
+      # fail-closed load (a corrupt/torn file degrades to empty rather than
+      # raising — a state file must never block daemon boot).
+      #
+      # Unlike the existing StaleAgentHealer's in-memory budget, this store
+      # PERSISTS retry counts so a daemon restart does not silently re-clear a
+      # repeatedly-failing dependency marker 2 more times (dependency markers
+      # can fail identically for hours). The exhausted audit event flags
+      # `budget_scope: "persisted"` and names `hive markers clear` as the reset
+      # gesture.
+      module StateStore
+        SCHEMA_VERSION = 1
+        STALE_TMP_SEC = 60
+
+        module_function
+
+        def default_path
+          File.join(Hive::Paths.state_home, "daemon_auto_retry_state.json")
+        end
+
+        # Load the persisted records as { key => {attempts:, last_fingerprint:,
+        # last_attempt_at:, last_probed_at:} }. Fail-closed: any error returns {}.
+        def load(path = default_path)
+          return {} unless path && File.exist?(path)
+
+          parsed = JSON.parse(File.read(path))
+          return {} unless parsed.is_a?(Hash)
+
+          version = parsed["schema_version"]
+          return {} unless version.is_a?(Integer)
+
+          records = parsed["records"]
+          return {} unless records.is_a?(Array)
+
+          records.each_with_object({}) do |entry, acc|
+            next unless entry.is_a?(Hash)
+
+            key = entry_key(entry)
+            next unless key
+
+            acc[key] = {
+              attempts: Integer(entry["attempts"] || 0, exception: false) || 0,
+              last_fingerprint: entry["last_fingerprint"].to_s,
+              last_attempt_at: parse_time(entry["last_attempt_at"]),
+              last_probed_at: parse_time(entry["last_probed_at"])
+            }
+          end
+        rescue JSON::ParserError, TypeError, SystemCallError, IOError
+          {}
+        end
+
+        # Persist the whole record map atomically. No-op without a path or
+        # when the map is empty AND the file does not already exist (avoids
+        # creating a spurious file on a tick with no auto-retry activity).
+        def write(map, path = default_path)
+          return unless path
+          FileUtils.mkdir_p(File.dirname(path))
+          tmp_path = File.join(File.dirname(path),
+                               ".#{File.basename(path)}.#{$$}.#{Thread.current.object_id}.tmp")
+          File.open(tmp_path, "w") do |f|
+            f.write(JSON.generate(envelope(map)))
+            f.fsync
+          end
+          File.rename(tmp_path, path)
+          fsync_dir(File.dirname(path))
+        rescue SystemCallError, IOError
+          nil
+        ensure
+          FileUtils.rm_f(tmp_path) if defined?(tmp_path) && tmp_path && File.exist?(tmp_path)
+        end
+
+        def entry_key(entry)
+          project = entry["project"].to_s
+          slug = entry["slug"].to_s
+          reason = entry["reason"].to_s
+          return nil if project.empty? || slug.empty? || reason.empty?
+
+          [ project, slug, reason ]
+        end
+
+        def envelope(map)
+          {
+            "schema_version" => SCHEMA_VERSION,
+            "records" => map.map do |(project, slug, reason), rec|
+              {
+                "project" => project, "slug" => slug, "reason" => reason,
+                "attempts" => rec.fetch(:attempts, 0),
+                "last_fingerprint" => rec.fetch(:last_fingerprint, "").to_s,
+                "last_attempt_at" => serialize_time(rec[:last_attempt_at]),
+                "last_probed_at" => serialize_time(rec[:last_probed_at])
+              }
+            end
+          }
+        end
+
+        def parse_time(value)
+          return nil if value.nil? || value.to_s.empty?
+
+          Time.iso8601(value.to_s)
+        rescue ArgumentError, TypeError
+          nil
+        end
+
+        def serialize_time(time)
+          time.respond_to?(:iso8601) ? time.utc.iso8601(6) : nil
+        end
+
+        def fsync_dir(dir)
+          File.open(dir) { |f| f.fsync }
+        rescue StandardError
+          nil
+        end
+      end
+    end
+  end
+end
