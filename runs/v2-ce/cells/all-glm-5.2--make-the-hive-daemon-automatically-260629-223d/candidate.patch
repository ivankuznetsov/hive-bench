+++ b/test/unit/daemon/auto_retry/retry_executor_test.rb
@@ -0,0 +1,174 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/retry_executor"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetryRetryExecutorTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Executor = Hive::Daemon::AutoRetry::RetryExecutor
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  class FakeRequestQueue
+    attr_reader :requests
+    def initialize(raise_on_write: false)
+      @requests = []
+      @raise_on_write = raise_on_write
+    end
+    def write_request!(**kwargs)
+      raise "simulated queue write failure" if @raise_on_write
+
+      @requests << kwargs
+      "req-#{@requests.size}"
+    end
+  end
+
+  class FakeController
+    attr_reader :observed_mtimes
+    def initialize
+      @observed_mtimes = []
+    end
+    def observe_state_file_mtime(project:, slug:, mtime:)
+      @observed_mtimes << { project: project, slug: slug, mtime: mtime }
+    end
+  end
+
+  class FakeLogger
+    attr_reader :events
+    def initialize
+      @events = []
+    end
+    def event(name, **attrs)
+      @events << [ name, attrs ]
+    end
+  end
+
+  def with_error_state(reason: "implementer_failed", marker_id: "abc12345", stage: "4-execute", slug: "auto-retry-test-260629-aaaa")
+    Dir.mktmpdir do |dir|
+      folder = File.join(dir, ".hive-state", "stages", stage, slug)
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "task.md")
+      File.write(state_file, "# task\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} -->\n")
+      yield folder, state_file, slug
+    end
+  end
+
+  def make_row(folder, state_file, slug, stage: "4-execute", reason: "implementer_failed", marker_id: "abc12345")
+    Row.new(project: "myproj", slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => reason, "marker_id" => marker_id }, folder: folder,
+           state_file: state_file, state_file_mtime: NOW - 1000, action: "error",
+           suggested_command: nil, claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil)
+  end
+
+  def classifier_result(reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute")
+    { reason: reason, signature: signature, stage: stage }
+  end
+
+  def cfg
+    { "claude" => { "mode" => "tmux" }, "agents" => {} }
+  end
+
+  def setup
+    @controller = FakeController.new
+    @logger = FakeLogger.new
+  end
+
+  def test_green_path_clears_marker_and_writes_one_request
+    with_error_state do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug)
+      queue = FakeRequestQueue.new
+      result = Executor.execute(row, classifier_result: classifier_result, cfg: cfg,
+                                logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :cleared, result.status
+      assert_equal "req-1", result.request_id
+      assert_equal 1, queue.requests.size
+      req = queue.requests.first
+      assert_equal "auto_retry", req[:requestor]
+      assert_equal "dependency_recovered", req[:trigger]
+      assert_equal [ "hive", "run", slug, "--project", "myproj", "--stage", "4-execute" ], req[:argv]
+      assert_equal :none, Hive::Markers.current(state_file).name
+      assert_equal 1, @controller.observed_mtimes.size
+    end
+  end
+
+  def test_raced_marker_clear_failed_no_request_no_budget
+    with_error_state(marker_id: "oldid") do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug, marker_id: "staleid")
+      queue = FakeRequestQueue.new
+      result = Executor.execute(row, classifier_result: classifier_result, cfg: cfg,
+                                logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :clear_failed, result.status
+      assert_empty queue.requests
+      # The original marker remains.
+      assert_equal :error, Hive::Markers.current(state_file).name
+    end
+  end
+
+  def test_dispatch_queue_write_failure_after_clear_is_requeue_failed
+    with_error_state do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug)
+      queue = FakeRequestQueue.new(raise_on_write: true)
+      result = Executor.execute(row, classifier_result: classifier_result, cfg: cfg,
+                                logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :requeue_failed, result.status
+      assert_match(/simulated queue write failure/, result.error)
+      assert_match(/hive run #{slug} --project myproj --stage 4-execute/, result.remediation)
+      # marker is already gone
+      assert_equal :none, Hive::Markers.current(state_file).name
+    end
+  end
+
+  def test_3_plan_requeue_uses_from_argv
+    with_error_state(reason: "claude_launch_failed", stage: "3-plan") do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug, stage: "3-plan", reason: "claude_launch_failed")
+      queue = FakeRequestQueue.new
+      result = Executor.execute(row, classifier_result: classifier_result(reason: "claude_launch_failed",
+                                                                            signature: "launcher_failure",
+                                                                            stage: "3-plan"),
+                                cfg: cfg, logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :cleared, result.status
+      assert_equal [ "hive", "plan", slug, "--project", "myproj", "--from", "3-plan" ], queue.requests.first[:argv]
+    end
+  end
+
+  def test_2_brainstorm_requeue_uses_brainstorm_verb
+    with_error_state(reason: "claude_launch_failed", stage: "2-brainstorm") do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug, stage: "2-brainstorm", reason: "claude_launch_failed")
+      queue = FakeRequestQueue.new
+      result = Executor.execute(row, classifier_result: classifier_result(reason: "claude_launch_failed",
+                                                                            signature: "launcher_failure",
+                                                                            stage: "2-brainstorm"),
+                                cfg: cfg, logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :cleared, result.status
+      assert_equal [ "hive", "brainstorm", slug, "--project", "myproj" ], queue.requests.first[:argv]
+    end
+  end
+
+  def test_other_stage_requeue_uses_run_stage
+    with_error_state(reason: "claude_launch_failed", stage: "7-artifacts") do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug, stage: "7-artifacts", reason: "claude_launch_failed")
+      queue = FakeRequestQueue.new
+      result = Executor.execute(row, classifier_result: classifier_result(reason: "claude_launch_failed",
+                                                                            signature: "launcher_failure",
+                                                                            stage: "7-artifacts"),
+                                cfg: cfg, logger: @logger, request_queue: queue, controller: @controller)
+      assert_equal :cleared, result.status
+      assert_equal [ "hive", "run", slug, "--project", "myproj", "--stage", "7-artifacts" ], queue.requests.first[:argv]
+    end
+  end
+
+  def test_pre_clear_mtime_observed_on_controller
+    with_error_state do |folder, state_file, slug|
+      row = make_row(folder, state_file, slug)
+      queue = FakeRequestQueue.new
+      Executor.execute(row, classifier_result: classifier_result, cfg: cfg,
+                       logger: @logger, request_queue: queue, controller: @controller)
+      obs = @controller.observed_mtimes.first
+      assert_equal "myproj", obs[:project]
+      assert_equal slug, obs[:slug]
+      assert_equal row.state_file_mtime, obs[:mtime]
+    end
+  end
+end
diff --git a/test/unit/daemon/auto_retry/safety_guard_test.rb b/test/unit/daemon/auto_retry/safety_guard_test.rb
new file mode 100644
index 00000000..798a408a
--- /dev/null
+++ b/test/unit/daemon/auto_retry/safety_guard_test.rb
@@ -0,0 +1,303 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/safety_guard"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetrySafetyGuardTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Guard = Hive::Daemon::AutoRetry::SafetyGuard
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  def make_git_repo
+    Dir.mktmpdir do |root|
+      system("git", "-C", root, "init", "-q", out: "/dev/null", err: "/dev/null")
+      system("git", "-C", root, "config", "user.email", "t@t", out: "/dev/null")
+      system("git", "-C", root, "config", "user.name", "t", out: "/dev/null")
+      File.write(File.join(root, "README.md"), "# r\n")
+      system("git", "-C", root, "add", ".", out: "/dev/null")
+      system("git", "-C", root, "commit", "-q", "-m", "init", out: "/dev/null", err: "/dev/null")
+      yield root
+    end
+  end
+
+  def make_row(folder, stage: "4-execute", reason: "implementer_failed", marker: "error",
+               state_file_content: "<!-- ERROR reason=#{reason} marker_id=abc12345 -->\n")
+    state_file = File.join(folder, "task.md")
+    File.write(state_file, state_file_content)
+    Row.new(project: "myproj", slug: "auto-retry-test-260629-aaaa", stage: stage, workflow: nil,
+           marker: marker, marker_attrs: { "reason" => reason, "marker_id" => "abc12345" },
+           folder: folder, state_file: state_file, state_file_mtime: NOW - 1000,
+           action: "error", suggested_command: nil, claude_pid_alive: nil,
+           live_task_lock: nil, diagnostic: nil)
+  end
+
+  def classifier_result(reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute")
+    { reason: reason, signature: signature, stage: stage }
+  end
+
+  def cfg
+    { "claude" => { "mode" => "tmux" }, "agents" => {},
+      "review" => { "fix" => { "auto_commit" => { "scope_check" => { "enabled" => true, "allowed_paths" => ["**"] } } } } }
+  end
+
+  def write_worktree_yml(folder, worktree_path, branch: nil, execute_base_head: nil)
+    data = { "path" => worktree_path }
+    # Default to the worktree's actual branch + HEAD so the U5 branch/base
+    # check passes for repos that haven't diverged; callers can override to
+    # simulate a mismatch.
+    if branch.nil? || execute_base_head.nil?
+      begin
+        git = Hive::GitOps.new(worktree_path)
+        data["branch"] = branch || git.current_branch
+        data["execute_base_head"] = execute_base_head || git.head_sha
+      rescue StandardError
+        # not a git repo — leave the baseline unset so the guard defers
+        data["branch"] = branch
+        data["execute_base_head"] = execute_base_head
+      end
+    else
+      data["branch"] = branch
+      data["execute_base_head"] = execute_base_head
+    end
+    File.write(File.join(folder, "worktree.yml"), data.to_yaml)
+  end
+
+  def test_clean_worktree_agent_scoped_residue_is_safe
+    make_git_repo do |root|
+      Dir.mktmpdir do |task_root|
+        folder = File.join(task_root, "task")
+        FileUtils.mkdir_p(folder)
+        # add a tracked file to the worktree (in-scope residue)
+        File.write(File.join(root, "agent_out.txt"), "x")
+        git = Guard.default_git_factory.call(root)
+        git_status = git.status_short
+        row = make_row(folder)
+        write_worktree_yml(folder, root)
+        result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+        assert result.safe, "clean-ish in-scope residue should be safe; status=#{git_status.inspect}"
+      end
+    end
+  end
+
+  def test_dirty_worktree_out_of_scope_file_not_safe
+    make_git_repo do |root|
+      Dir.mktmpdir do |task_root|
+        folder = File.join(task_root, "task")
+        FileUtils.mkdir_p(folder)
+        # Untracked file with a deny-all scope config
+        File.write(File.join(root, "user_edit.txt"), "user")
+        write_worktree_yml(folder, root)
+        row = make_row(folder)
+        deny_cfg = cfg.merge(
+          "review" => { "fix" => { "auto_commit" => {
+            "scope_check" => { "enabled" => true, "allowed_paths" => [] }
+          } } }
+        )
+        result = Guard.safe_to_retry?(row, classifier_result, cfg: deny_cfg)
+        refute result.safe, "out-of-scope residue should not be safe"
+        assert_match(/dirty_worktree/, result.reason)
+      end
+    end
+  end
+
+  def test_no_worktree_yml_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      row = make_row(folder)
+      result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+      refute result.safe
+      assert_match(/no_worktree/, result.reason)
+    end
+  end
+
+  def test_missing_worktree_dir_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      write_worktree_yml(folder, "/nonexistent/worktree-path-#{rand(10_000)}")
+      row = make_row(folder)
+      result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+      refute result.safe
+      assert_match(/missing_worktree/, result.reason)
+    end
+  end
+
+  def test_execute_complete_in_state_file_not_safe
+    make_git_repo do |root|
+      Dir.mktmpdir do |task_root|
+        folder = File.join(task_root, "task")
+        FileUtils.mkdir_p(folder)
+        write_worktree_yml(folder, root)
+        content = "<!-- EXECUTE_COMPLETE head=abc -->\n<!-- ERROR reason=implementer_failed marker_id=abc12345 -->\n"
+        row = make_row(folder, state_file_content: content)
+        result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+        refute result.safe
+        assert_match(/terminal_success_present/, result.reason)
+      end
+    end
+  end
+
+  def test_worktree_head_advanced_not_safe
+    make_git_repo do |root|
+      Dir.mktmpdir do |task_root|
+        folder = File.join(task_root, "task")
+        FileUtils.mkdir_p(folder)
+        git = Hive::GitOps.new(root)
+        base = git.head_sha
+        # Commit new stage output so HEAD advances past the recorded base.
+        File.write(File.join(root, "stage_output.txt"), "done")
+        system("git", "-C", root, "add", ".", out: "/dev/null", err: "/dev/null")
+        system("git", "-C", root, "commit", "-q", "-m", "stage output", out: "/dev/null", err: "/dev/null")
+        refute_equal base, git.head_sha
+        # Pointer records the pre-advance base — a from-start rerun would reset it.
+        write_worktree_yml(folder, root, execute_base_head: base)
+        row = make_row(folder)
+        result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+        refute result.safe, "an advanced HEAD with committed stage output must not be retried"
+        assert_match(/worktree_head_advanced/, result.reason)
+      end
+    end
+  end
+
+  def test_worktree_branch_mismatch_not_safe
+    make_git_repo do |root|
+      Dir.mktmpdir do |task_root|
+        folder = File.join(task_root, "task")
+        FileUtils.mkdir_p(folder)
+        # Pointer claims a different branch than the worktree is on.
+        write_worktree_yml(folder, root, branch: "some-other-branch")
+        row = make_row(folder)
+        result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+        refute result.safe
+        assert_match(/worktree_branch_mismatch/, result.reason)
+      end
+    end
+  end
+
+  def test_brainstorm_with_answered_content_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "brainstorm.md")
+      File.write(state_file, <<~MD)
+        <!-- ERROR reason=claude_launch_failed marker_id=abc12345 -->
+
+        ## Round 1
+
+        ### Q1. What should we build?
+
+        ### A1.
+
+        A user-provided answer that must not be overwritten.
+      MD
+      row = make_row(folder, stage: "2-brainstorm", reason: "claude_launch_failed",
+                     state_file_content: File.read(state_file))
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "2-brainstorm"), cfg: cfg)
+      refute result.safe
+      assert_match(/answered_user_content/, result.reason)
+    end
+  end
+
+  def test_brainstorm_seed_only_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "brainstorm.md")
+      File.write(state_file, "<!-- ERROR reason=claude_launch_failed marker_id=abc12345 -->\n\n## Round 1\n\n### Q1. What?\n")
+      row = make_row(folder, stage: "2-brainstorm", reason: "claude_launch_failed",
+                     state_file_content: File.read(state_file))
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "2-brainstorm"), cfg: cfg)
+      assert result.safe, "seed-only brainstorm (no answered A blocks) should be safe; reason=#{result.reason}"
+    end
+  end
+
+  def test_brainstorm_missing_state_file_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      row = make_row(folder, stage: "2-brainstorm", reason: "claude_launch_failed",
+                     state_file_content: "<!-- ERROR reason=claude_launch_failed -->\n")
+      row = Row.new(row.to_h.merge(state_file: File.join(folder, "brainstorm.md")))
+      File.write(row.state_file, "<!-- ERROR reason=claude_launch_failed -->\n")
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "2-brainstorm"), cfg: cfg)
+      assert result.safe
+    end
+  end
+
+  def test_plan_seed_only_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "plan.md")
+      File.write(state_file, "<!-- ERROR reason=claude_launch_failed marker_id=abc12345 -->\n")
+      row = make_row(folder, stage: "3-plan", reason: "claude_launch_failed",
+                     state_file_content: File.read(state_file))
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "3-plan"), cfg: cfg)
+      assert result.safe
+    end
+  end
+
+  def test_plan_with_content_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "plan.md")
+      File.write(state_file, "<!-- ERROR reason=claude_launch_failed marker_id=abc12345 -->\n\n# Plan\n\nReal prior plan content.\n")
+      row = make_row(folder, stage: "3-plan", reason: "claude_launch_failed",
+                     state_file_content: File.read(state_file))
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "3-plan"), cfg: cfg)
+      refute result.safe
+      assert_match(/non_seed_plan_content/, result.reason)
+    end
+  end
+
+  def test_unknown_classifier_result_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      row = make_row(folder)
+      result = Guard.safe_to_retry?(row, :unknown, cfg: cfg)
+      refute result.safe
+      assert_equal "unknown_reason", result.reason
+    end
+  end
+
+  def test_git_status_failure_not_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      write_worktree_yml(folder, task_root) # not a git repo
+      row = make_row(folder)
+      result = Guard.safe_to_retry?(row, classifier_result, cfg: cfg)
+      refute result.safe
+      assert_match(/git_status_failed|dirty_worktree/, result.reason)
+    end
+  end
+
+  def test_other_tmux_launcher_stage_safe
+    Dir.mktmpdir do |task_root|
+      folder = File.join(task_root, "task")
+      FileUtils.mkdir_p(folder)
+      row = make_row(folder, stage: "7-artifacts", reason: "claude_launch_failed",
+                     state_file_content: "<!-- ERROR reason=claude_launch_failed -->\n")
+      result = Guard.safe_to_retry?(row, classifier_result(reason: "claude_launch_failed",
+                                                            signature: "launcher_failure",
+                                                            stage: "7-artifacts"), cfg: cfg)
+      assert result.safe, "non-brainstorm/plan launcher stage has no user-content surface; reason=#{result.reason}"
+    end
+  end
+end
