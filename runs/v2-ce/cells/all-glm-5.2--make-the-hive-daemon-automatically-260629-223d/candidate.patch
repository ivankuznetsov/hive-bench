diff --git a/test/integration/daemon_auto_retry_e2e_test.rb b/test/integration/daemon_auto_retry_e2e_test.rb
new file mode 100644
index 00000000..e5739f4b
--- /dev/null
+++ b/test/integration/daemon_auto_retry_e2e_test.rb
@@ -0,0 +1,363 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "json"
+require "hive/daemon/auto_retry/coordinator"
+require "hive/daemon/auto_retry/probes"
+require "hive/daemon/status_consumer"
+require "hive/daemon/logger"
+
+# End-to-end acceptance: drive the real AutoRetry::Coordinator with the
+# REAL Classifier, SafetyGuard, RetryExecutor, Markers, and a persisted
+# StateStore (tmpdir), against stubbed probes (no real codex/claude) and
+# a sandbox dispatch-request queue. Pins the brainstorm's acceptance
+# examples (Task-58 Codex auth recovery, Task-287 Claude launcher
+# recovery, unknown stays parked, retry limits/backoff, unchanged signal,
+# dirty worktree, probe hang, kill-switch off).
+class DaemonAutoRetryE2ETest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Coordinator = Hive::Daemon::AutoRetry::Coordinator
+  AutoRetry = Hive::Daemon::AutoRetry
+  Result = AutoRetry::Probes::Result
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+    def initialize
+      @events = []
+    end
+
+    def event(name, **attrs)
+      unless Hive::Daemon::Logger::EVENTS.include?(name)
+        raise ArgumentError, "FakeLogger rejected #{name.inspect}; add it to Logger::EVENTS"
+      end
+      @events << [ name, attrs ]
+    end
+  end
+
+  class FakeRequestQueue
+    attr_reader :requests
+    def initialize
+      @requests = []
+    end
+    def write_request!(**kwargs)
+      @requests << kwargs
+      "req-#{@requests.size}"
+    end
+  end
+
+  class FakeAgentProfiles
+    def logged_in?(_name)
+      true
+    end
+  end
+
+  # Stubbed probe module: returns configurable Result objects so the e2e
+  # scenarios need no real codex/claude binaries.
+  class StubProbes
+    def self.default_wrapper_path
+      "/x/wrapper"
+    end
+
+    def initialize(doctor: :green, login: :green, smoke: :green,
+                   wrapper: :green, ready: :green, version: :green)
+      @results = {
+        doctor_pass: doctor, codex_login_status: login, codex_exec_smoke: smoke,
+        wrapper_exists: wrapper, ready_detector: ready, binary_version_match: version
+      }
+    end
+
+    def doctor_pass(cfg:, row:)
+      mk(:doctor_pass, @results[:doctor_pass])
+    end
+
+    def codex_login_status(cfg:, row:, agent_profiles: nil)
+      mk(:codex_login_status, @results[:codex_login_status])
+    end
+
+    def codex_exec_smoke(cfg:, row:)
+      mk(:codex_exec_smoke, @results[:codex_exec_smoke])
+    end
+
+    def wrapper_exists(cfg:, row:)
+      mk(:wrapper_exists, @results[:wrapper_exists])
+    end
+
+    def ready_detector(cfg:, row:)
+      mk(:ready_detector, @results[:ready_detector])
+    end
+
+    def binary_version_match(cfg:, row:)
+      mk(:binary_version_match, @results[:binary_version_match])
+    end
+
+    def mk(name, status)
+      Result.new(name: name, status: status, stdout: "", stderr: "", duration_sec: 0.0, detail: status.to_s)
+    end
+  end
+
+  def with_project(slug: "auto-retry-e2e-260629-aaaa", stage: "4-execute")
+    Dir.mktmpdir do |root|
+      project_root = File.join(root, "myproj")
+      state_home = File.join(project_root, ".hive-state")
+      stages = File.join(state_home, "stages")
+      folder = File.join(stages, stage, slug)
+      FileUtils.mkdir_p(folder)
+      log_dir = File.join(state_home, "logs", slug)
+      FileUtils.mkdir_p(log_dir)
+      state_file = File.join(folder, "task.md")
+      yield root, project_root, state_home, folder, state_file, log_dir, slug
+    end
+  end
+
+  def make_git_worktree(worktree_root)
+    system("git", "init", "-q", worktree_root, out: "/dev/null", err: "/dev/null")
+    system("git", "-C", worktree_root, "config", "user.email", "t@t", out: "/dev/null")
+    system("git", "-C", worktree_root, "config", "user.name", "t", out: "/dev/null")
+    File.write(File.join(worktree_root, "README.md"), "# r\n")
+    system("git", "-C", worktree_root, "add", ".", out: "/dev/null")
+    system("git", "-C", worktree_root, "commit", "-q", "-m", "init", out: "/dev/null", err: "/dev/null")
+  end
+
+  # Write a worktree.yml pointer whose branch + execute_base_head match the
+  # real worktree, so the U5 safety guard's branch/HEAD verification passes
+  # for repos that haven't diverged (mirrors what Stages::Execute writes).
+  def write_worktree_pointer(folder, worktree)
+    git = Hive::GitOps.new(worktree)
+    File.write(File.join(folder, "worktree.yml"),
+               { "path" => worktree, "branch" => git.current_branch,
+                 "execute_base_head" => git.head_sha }.to_yaml)
+  end
+
+  def stamp_error(state_file, reason:, marker_id: "abc12345")
+    File.write(state_file, "# task\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} -->\n")
+  end
+
+  def write_log(log_dir, content, name: "agent.log", mtime: NOW)
+    path = File.join(log_dir, name)
+    File.write(path, content)
+    File.utime(mtime, mtime, path)
+    path
+  end
+
+  def make_row(folder, state_file, slug, stage: "4-execute", reason: "implementer_failed", marker_id: "abc12345",
+               mtime: NOW - 1000)
+    Row.new(project: "myproj", slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => reason, "marker_id" => marker_id }, folder: folder,
+           state_file: state_file, state_file_mtime: mtime, action: "error",
+           suggested_command: nil, claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil)
+  end
+
+  def build_coord(state_home:, queue:, logger: FakeLogger.new, probes: StubProbes.new)
+    controller = Object.new
+    controller.define_singleton_method(:running_task?) { |**| false }
+    observed = []
+    controller.define_singleton_method(:observe_state_file_mtime) { |**k| observed << k }
+    controller.define_singleton_method(:observed_mtimes) { observed }
+    coord = Coordinator.new(logger: logger, controller: controller, request_queue: queue,
+                            state_home: state_home, agent_profiles: FakeAgentProfiles.new,
+                            probes: probes)
+    cfg_loader = ->(_project) do
+      { "claude" => { "mode" => "tmux" }, "agents" => {},
+        "review" => { "fix" => { "auto_commit" => { "scope_check" => {
+          "enabled" => true, "allowed_paths" => ["**"]
+        } } } } }
+    end
+    [ coord, logger, controller, cfg_loader ]
+  end
+
+  # Scenario 1: Task-58 Codex auth recovery
+  def test_codex_auth_recovery_auto_clears_and_requeues
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "Error: 401 Missing bearer/basic auth\n")
+      stamp_error(state_file, reason: "implementer_failed")
+      # clean git worktree so the safety guard passes
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+
+      assert_equal :none, Hive::Markers.current(state_file).name
+      assert_equal 1, queue.requests.size
+      assert_equal [ "hive", "run", slug, "--project", "myproj", "--stage", "4-execute" ], queue.requests.first[:argv]
+      assert(logger.events.any? { |n, _| n == :auto_retry_cleared })
+      # task events.jsonl line emitted
+      assert File.exist?(File.join(folder, "events.jsonl"))
+    end
+  end
+
+  # Scenario 2: Task-287 Claude launcher recovery
+  def test_claude_launcher_recovery_auto_clears
+    with_project(slug: "auto-retry-e2e-260629-bbbb", stage: "2-brainstorm") do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      stamp_error(state_file, reason: "claude_launch_failed")
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug, stage: "2-brainstorm", reason: "claude_launch_failed")
+      coord.tick([ row ], now: NOW, config_loader: loader)
+
+      assert_equal :none, Hive::Markers.current(state_file).name
+      assert_equal 1, queue.requests.size
+      assert_equal [ "hive", "brainstorm", slug, "--project", "myproj" ], queue.requests.first[:argv]
+      assert(logger.events.any? { |n, _| n == :auto_retry_cleared })
+    end
+  end
+
+  # Scenario 3: Unknown implementer_failed (no 401 signature) stays parked
+  def test_unknown_implementer_failed_stays_parked
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "Traceback: exit_code=1 generic failure\n")
+      stamp_error(state_file, reason: "implementer_failed")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "unknown_reason" })
+    end
+  end
+
+  # Scenario 4: Retry limits — second healthy changed signal clears; third exhausts
+  def test_retry_limits_then_exhaust
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "401 Missing bearer\n")
+      stamp_error(state_file, reason: "implementer_failed", marker_id: "m1")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug, marker_id: "m1")
+      # Tick 1: clears (attempt 1)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_equal 1, queue.requests.size
+
+      # Re-fail with a DIFFERENT signal (new marker_id => new fingerprint)
+      stamp_error(state_file, reason: "implementer_failed", marker_id: "m2")
+      row2 = make_row(folder, state_file, slug, marker_id: "m2", mtime: NOW - 10)
+      # Touch the worktree so its mtime/inode reads fresh; also bump log mtime
+      write_log(log_dir, "401 Missing bearer\n", name: "agent2.log", mtime: NOW + 1)
+      coord.tick([ row2 ], now: NOW + 60, config_loader: loader)
+      assert_equal 2, queue.requests.size, "second healthy changed signal clears again"
+
+      # Third healthy signal => exhausted (max 2)
+      stamp_error(state_file, reason: "implementer_failed", marker_id: "m3")
+      row3 = make_row(folder, state_file, slug, marker_id: "m3", mtime: NOW + 10)
+      write_log(log_dir, "401 Missing bearer\n", name: "agent3.log", mtime: NOW + 2)
+      coord.tick([ row3 ], now: NOW + 120, config_loader: loader)
+      assert_equal 2, queue.requests.size, "third attempt is exhausted"
+      assert(logger.events.any? { |n, _| n == :auto_retry_exhausted })
+    end
+  end
+
+  # Scenario 5: Unchanged signal ⇒ not_retried unchanged_signal
+  def test_unchanged_signal_not_retried
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "401 Missing bearer\n")
+      stamp_error(state_file, reason: "implementer_failed", marker_id: "same")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug, marker_id: "same")
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_equal 1, queue.requests.size
+
+      # Re-stamp the SAME marker (same fingerprint) — unchanged_signal
+      stamp_error(state_file, reason: "implementer_failed", marker_id: "same")
+      row2 = make_row(folder, state_file, slug, marker_id: "same", mtime: NOW - 1000)
+      coord.tick([ row2 ], now: NOW + 60, config_loader: loader)
+      assert_equal 1, queue.requests.size, "unchanged signal must NOT retry"
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "unchanged_signal" })
+    end
+  end
+
+  # Scenario 6: Dirty worktree / ambiguous partial output ⇒ safety guard blocks
+  def test_dirty_worktree_blocks_retry
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "401 Missing bearer\n")
+      stamp_error(state_file, reason: "implementer_failed")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+      # Out-of-scope residue (deny-all scope)
+      File.write(File.join(worktree, "user_edit.txt"), "user")
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug)
+      # deny-all scope config
+      deny_loader = ->(_p) do
+        { "claude" => { "mode" => "tmux" }, "agents" => {},
+          "review" => { "fix" => { "auto_commit" => { "scope_check" => { "enabled" => true, "allowed_paths" => [] } } } } }
+      end
+      coord.tick([ row ], now: NOW, config_loader: deny_loader)
+
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale].to_s.start_with?("safety_guard:") })
+    end
+  end
+
+  # Scenario 7: Probe hang/timeout ⇒ not_retried probe_timeout, no clear
+  def test_probe_timeout_not_retried
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "401 Missing bearer\n")
+      stamp_error(state_file, reason: "implementer_failed")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      probes = StubProbes.new(smoke: :timeout)
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue, probes: probes)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "probe_timeout:codex_exec_smoke" })
+    end
+  end
+
+  # Scenario 8: Kill-switch off ⇒ nothing
+  def test_kill_switch_off_does_nothing
+    with_project do |root, project_root, state_home, folder, state_file, log_dir, slug|
+      write_log(log_dir, "401 Missing bearer\n")
+      stamp_error(state_file, reason: "implementer_failed")
+      worktree = File.join(root, "wt")
+      FileUtils.mkdir_p(worktree)
+      make_git_worktree(worktree)
+      write_worktree_pointer(folder, worktree)
+
+      queue = FakeRequestQueue.new
+      coord, logger, _ctrl, loader = build_coord(state_home: state_home, queue: queue)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader, enabled: false)
+
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, _| n == :auto_retry_disabled })
+    end
+  end
+end
diff --git a/test/unit/daemon/auto_retry/auditor_test.rb b/test/unit/daemon/auto_retry/auditor_test.rb
