--- /dev/null
+++ b/test/unit/daemon/auto_retry/probe_cache_test.rb
@@ -0,0 +1,303 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/probe_cache"
+require "hive/daemon/auto_retry/coordinator"
+require "hive/daemon/auto_retry/probes"
+require "hive/daemon/status_consumer"
+
+# Plan U3 explicitly lists `test/unit/daemon/auto_retry/probe_cache_test.rb`
+# with 5 scenarios (cache reuse, cross-tick clear, fallback gating, and
+# cross-project isolation). ProbeCache itself is a thin memo; these tests
+# exercise it through the Coordinator's key construction so the per-tick
+# cache + the project-keyed doctor cache + the low-frequency fallback are
+# pinned at the contract the plan specifies.
+class HiveDaemonAutoRetryProbeCacheContractTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Cache = Hive::Daemon::AutoRetry::ProbeCache
+  Coordinator = Hive::Daemon::AutoRetry::Coordinator
+  AutoRetry = Hive::Daemon::AutoRetry
+  Result = AutoRetry::Probes::Result
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+    def initialize
+      @events = []
+    end
+    def event(name, **attrs)
+      @events << [ name, attrs ]
+    end
+  end
+
+  class FakeController
+    def running_task?(project:, slug:)
+      false
+    end
+    def observe_state_file_mtime(project:, slug:, mtime:)
+      # no-op
+    end
+  end
+
+  class FakeRequestQueue
+    attr_reader :requests
+    def initialize
+      @requests = []
+    end
+    def write_request!(**kwargs)
+      @requests << kwargs
+      "req-#{@requests.size}"
+    end
+  end
+
+  # A counting probe module: records every call so the cache contract can
+  # assert a probe ran exactly once per (project, reason, kind) per tick.
+  class CountingProbes
+    attr_reader :calls
+
+    def self.default_wrapper_path = "/x/wrapper"
+
+    def initialize(overrides = {})
+      @overrides = overrides
+      @calls = []
+    end
+
+    def doctor_pass(cfg:, row:)
+      @calls << [ :doctor_pass, row.project ]
+      @overrides[:doctor_pass] || green(:doctor_pass, rows: [ { label: "tmux", status: "present" } ])
+    end
+
+    def codex_login_status(cfg:, row:, agent_profiles: nil)
+      @calls << [ :codex_login_status, row.project ]
+      @overrides[:codex_login_status] || green(:codex_login_status)
+    end
+
+    def codex_exec_smoke(cfg:, row:)
+      @calls << [ :codex_exec_smoke, row.project ]
+      @overrides[:codex_exec_smoke] || green(:codex_exec_smoke)
+    end
+
+    def wrapper_exists(cfg:, row:)
+      @calls << [ :wrapper_exists, row.project ]
+      @overrides[:wrapper_exists] || green(:wrapper_exists)
+    end
+
+    def ready_detector(cfg:, row:)
+      @calls << [ :ready_detector, row.project ]
+      @overrides[:ready_detector] || green(:ready_detector)
+    end
+
+    def binary_version_match(cfg:, row:)
+      @calls << [ :binary_version_match, row.project ]
+      @overrides[:binary_version_match] || green(:binary_version_match)
+    end
+
+    private
+
+    def green(name, rows: nil)
+      Result.new(name: name.to_s, status: :green, stdout: "", stderr: "", duration_sec: 0.0, detail: "ok", rows: rows)
+    end
+  end
+
+  class FakeClassifier
+    def initialize(result)
+      @result = result
+    end
+    def classify(row, cfg:)
+      @result
+    end
+  end
+
+  class FakeSafety
+    def safe_to_retry?(row, classifier_result, cfg:)
+      AutoRetry::SafetyGuard::Result.new(safe: true, reason: "clean")
+    end
+  end
+
+  class FakeExecutor
+    def execute(row, classifier_result:, cfg:, logger:, request_queue:, controller:, state_home: nil)
+      # Actually clear so record_attempt! runs and a second tick with the same
+      # fingerprint lands on :unchanged_signal (the fallback path under test).
+      Hive::Markers.clear_current(row.state_file, expected_name: :error,
+                                  match_attrs: { "reason" => classifier_result[:reason],
+                                                  "marker_id" => row.marker_attrs["marker_id"] })
+      AutoRetry::RetryExecutor::Result.new(status: :cleared, request_id: "req-1")
+    end
+  end
+
+  def with_task(project: "myproj", reason: "implementer_failed", marker_id: "abc12345",
+                stage: "4-execute", slug: "auto-retry-test-260629-aaaa")
+    Dir.mktmpdir do |state_home|
+      project_root = File.join(state_home, project)
+      folder = File.join(project_root, ".hive-state", "stages", stage, slug)
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "task.md")
+      File.write(state_file, "# task\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} -->\n")
+      yield state_home, folder, state_file, slug, project_root
+    end
+  end
+
+  def make_row(project, folder, state_file, slug, stage: "4-execute", reason: "implementer_failed", marker_id: "abc12345")
+    Row.new(project: project, slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => reason, "marker_id" => marker_id }, folder: folder,
+           state_file: state_file, state_file_mtime: NOW - 1000, action: "error",
+           suggested_command: nil, claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil)
+  end
+
+  def build(state_home:, probes:, classifier_result:)
+    logger = FakeLogger.new
+    controller = FakeController.new
+    queue = FakeRequestQueue.new
+    agent_profiles = Object.new.tap { |o| o.define_singleton_method(:logged_in?) { |*| true } }
+    coord = Coordinator.new(logger: logger, controller: controller, request_queue: queue,
+                           state_home: state_home, agent_profiles: agent_profiles,
+                           probes: probes, classifier: FakeClassifier.new(classifier_result),
+                           safety_guard: FakeSafety.new, retry_executor: FakeExecutor.new)
+    loader = ->(_p) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+    [ coord, logger, queue, loader ]
+  end
+
+  # Scenario 1 (reuse): two rows of the same reason+project in one tick
+  # reuse one doctor + one per-reason probe; each underlying probe runs once.
+  def test_cache_reuses_probe_result_within_a_tick
+    probes = CountingProbes.new
+    with_task(slug: "slug-a") do |state_home, folder_a, sf_a, slug_a, _root|
+      with_task(slug: "slug-b") do |_, folder_b, sf_b, slug_b, _|
+        coord, = build(state_home: state_home, probes: probes,
+                       classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" })
+        row_a = make_row("myproj", folder_a, sf_a, slug_a)
+        row_b = make_row("myproj", folder_b, sf_b, slug_b)
+        coord.tick([ row_a, row_b ], now: NOW, config_loader: ->(_) { { "claude" => { "mode" => "tmux" }, "agents" => {} } })
+        doctor_calls = probes.calls.count { |n, _| n == :doctor_pass }
+        smoke_calls = probes.calls.count { |n, _| n == :codex_exec_smoke }
+        assert_equal 1, doctor_calls, "doctor_pass must be cached per project within a tick"
+        assert_equal 1, smoke_calls, "codex_exec_smoke must be cached per (project, reason) within a tick"
+      end
+    end
+  end
+
+  # Scenario 2 (cross-tick clear): a probe re-runs on the next tick because
+  # the per-tick cache is cleared at the start of each tick.
+  def test_cache_cleared_between_ticks
+    probes = CountingProbes.new
+    with_task do |state_home, folder, sf, slug, _root|
+      coord, = build(state_home: state_home, probes: probes,
+                     classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" })
+      loader = ->(_) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+      row1 = make_row("myproj", folder, sf, slug)
+      # First tick clears the marker; re-stamp it for the second tick.
+      coord.tick([ row1 ], now: NOW, config_loader: loader)
+      File.write(sf, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=abc12345 -->\n")
+      row2 = make_row("myproj", folder, sf, slug)
+      coord.tick([ row2 ], now: NOW + 60, config_loader: loader)
+      # doctor ran once per tick (cache cleared between ticks)
+      assert_equal 2, probes.calls.count { |n, _| n == :doctor_pass }
+    end
+  end
+
+  # Scenario 3 (cross-project isolation): two parked rows of the SAME reason
+  # in DIFFERENT projects within one tick must NOT share a doctor result —
+  # doctor is project-specific. (This is the cross-project cache-key bug.)
+  def test_doctor_cache_is_project_scoped
+    probes = CountingProbes.new
+    Dir.mktmpdir do |state_home|
+      folder_a = File.join(state_home, "projA", ".hive-state", "stages", "4-execute", "slug-a")
+      folder_b = File.join(state_home, "projB", ".hive-state", "stages", "4-execute", "slug-b")
+      [ folder_a, folder_b ].each { |f| FileUtils.mkdir_p(f) }
+      sf_a = File.join(folder_a, "task.md"); sf_b = File.join(folder_b, "task.md")
+      File.write(sf_a, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=aaa -->\n")
+      File.write(sf_b, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=bbb -->\n")
+      coord, = build(state_home: state_home, probes: probes,
+                     classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" })
+      row_a = make_row("projA", folder_a, sf_a, "slug-a")
+      row_b = make_row("projB", folder_b, sf_b, "slug-b")
+      coord.tick([ row_a, row_b ], now: NOW, config_loader: ->(_) { { "claude" => { "mode" => "tmux" }, "agents" => {} } })
+      doctor_projects = probes.calls.select { |n, _| n == :doctor_pass }.map { |_, p| p }
+      assert_equal %w[projA projB], doctor_projects.sort,
+                   "doctor must run once per project, not shared across projects"
+    end
+  end
+
+  # Scenario 4 (fallback gating — not before): an unchanged signal with a
+  # recent last_probed_at does NOT trigger a fallback re-probe.
+  def test_fallback_reprobe_not_allowed_before_interval
+    probes = CountingProbes.new
+    with_task do |state_home, folder, sf, slug, _root|
+      coord, = build(state_home: state_home, probes: probes,
+                     classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" })
+      loader = ->(_) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+      row1 = make_row("myproj", folder, sf, slug)
+      coord.tick([ row1 ], now: NOW, config_loader: loader) # clears + records last_probed_at
+      # Re-stamp the SAME marker (unchanged fingerprint) within the interval.
+      File.write(sf, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=abc12345 -->\n")
+      row2 = make_row("myproj", folder, sf, slug)
+      calls_before = probes.calls.size
+      coord.tick([ row2 ], now: NOW + 60, config_loader: loader) # 60s < 5min
+      # No fallback re-probe: only the doctor (run before the budget gate)
+      # may have run; no codex_login_status fallback spawn.
+      login_calls = probes.calls.count { |n, _| n == :codex_login_status }
+      assert_equal 1, login_calls, "no fallback re-probe before the interval (login ran only on tick 1)"
+    end
+  end
+
+  # Scenario 5 (fallback gating — after + expensive exempt): an unchanged
+  # signal past the fallback interval re-runs the CHEAP probes, but the
+  # expensive probes are NEVER triggered by the fallback alone.
+  def test_fallback_reprobe_allowed_after_interval_but_expensive_exempt
+    probes = CountingProbes.new
+    with_task do |state_home, folder, sf, slug, _root|
+      coord, = build(state_home: state_home, probes: probes,
+                     classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" })
+      loader = ->(_) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+      row1 = make_row("myproj", folder, sf, slug)
+      coord.tick([ row1 ], now: NOW, config_loader: loader) # clears + records last_probed_at
+      # Re-stamp the SAME marker (unchanged fingerprint) AFTER the interval.
+      File.write(sf, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=abc12345 -->\n")
+      row2 = make_row("myproj", folder, sf, slug)
+      smoke_before = probes.calls.count { |n, _| n == :codex_exec_smoke }
+      coord.tick([ row2 ], now: NOW + AutoRetry::FALLBACK_PROBE_INTERVAL_SEC + 1, config_loader: loader)
+      # The fallback ran the cheap codex_login_status probe again...
+      login_calls = probes.calls.count { |n, _| n == :codex_login_status }
+      assert_equal 2, login_calls, "fallback re-probe must re-run the cheap login probe after the interval"
+      # ...but the expensive codex_exec_smoke was NOT triggered by the fallback.
+      smoke_calls = probes.calls.count { |n, _| n == :codex_exec_smoke }
+      assert_equal smoke_before, smoke_calls, "expensive probes must never be triggered by fallback alone"
+    end
+  end
+end
