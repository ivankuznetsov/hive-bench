+    result = Probes.binary_version_match(cfg: cfg, row: row, runner: runner)
+    assert_equal :timeout, result.status
+  end
+
+  def test_binary_version_match_error_on_spawn_failure
+    runner = FakeRunner.new
+    runner.respond(status: nil, stderr: "Errno::ENOENT", error: true)
+    row = make_row
+    result = Probes.binary_version_match(cfg: cfg, row: row, runner: runner)
+    assert_equal :error, result.status
+  end
+
+  def test_probe_results_carry_stdout_stderr_and_duration
+    runner = FakeRunner.new
+    runner.respond(status: 0, stdout: "ok\n")
+    row = make_row
+    result = Probes.codex_exec_smoke(cfg: cfg, row: row, runner: runner)
+    assert result.stdout.is_a?(String)
+    assert result.stderr.is_a?(String)
+    assert result.duration_sec.is_a?(Float)
+  end
+
+  def test_no_probe_returns_green_on_raised_path
+    # doctor_pass with a doctor that raises => :error, never :green
+    doctor = Object.new
+    doctor.define_singleton_method(:call) { raise "boom" }
+    doctor.define_singleton_method(:rows) { [] }
+    row = make_row
+    result = Probes.doctor_pass(cfg: cfg, row: row, doctor: doctor)
+    refute_equal :green, result.status
+    assert_equal :error, result.status
+  end
+end
