index 00000000..3d9cbe19
--- /dev/null
+++ b/test/unit/daemon/auto_retry/budget_test.rb
@@ -0,0 +1,160 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "json"
+require "hive/daemon/auto_retry/budget"
+require "hive/daemon/auto_retry/state_store"
+
+class HiveDaemonAutoRetryBudgetTest < Minitest::Test
+  Budget = Hive::Daemon::AutoRetry::Budget
+  AutoRetry = Hive::Daemon::AutoRetry
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+  KEY = [ "p", "s", "implementer_failed" ].freeze
+  FP_A = "fingerprint-a"
+  FP_B = "fingerprint-b"
+  FP_C = "fingerprint-c"
+
+  def fresh_map
+    {}
+  end
+
+  def test_first_attempt_with_changed_signal_allows
+    m = fresh_map
+    assert_equal :allow, Budget.allow?(m, KEY, now: NOW, fingerprint: FP_A)
+  end
+
+  def test_second_attempt_with_changed_signal_allows_immediate
+    m = fresh_map
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    # immediate (BACKOFF_AFTER_FIRST = 0)
+    assert_equal :allow, Budget.allow?(m, KEY, now: NOW, fingerprint: FP_B)
+  end
+
+  def test_third_attempt_exhausts
+    m = fresh_map
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    Budget.record_attempt!(m, KEY, now: NOW + 60, fingerprint: FP_B)
+    assert_equal :exhausted, Budget.allow?(m, KEY, now: NOW + 120, fingerprint: FP_C)
+  end
+
+  def test_unchanged_signal_blocks
+    m = fresh_map
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    assert_equal :unchanged_signal, Budget.allow?(m, KEY, now: NOW + 1, fingerprint: FP_A)
+  end
+
+  def test_backoff_after_second_attempt
+    m = fresh_map
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_B)
+    # within 30 min => :exhausted? No — at 2 attempts already exhausted.
+    assert_equal :exhausted, Budget.allow?(m, KEY, now: NOW + 60, fingerprint: FP_C)
+  end
+
+  def test_backoff_after_first_blocks_second_without_changed_signal_within_window
+    m = fresh_map
+    Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    # same fingerprint => unchanged_signal regardless of window
+    assert_equal :unchanged_signal, Budget.allow?(m, KEY, now: NOW + 1, fingerprint: FP_A)
+  end
+
+  def test_record_attempt_returns_count
+    m = fresh_map
+    assert_equal 1, Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_A)
+    assert_equal 2, Budget.record_attempt!(m, KEY, now: NOW, fingerprint: FP_B)
+  end
+
+  def test_record_probe_does_not_consume_budget
+    m = fresh_map
+    Budget.record_probe!(m, KEY, now: NOW, fingerprint: FP_A)
+    rec = m[KEY]
+    assert_equal NOW, rec[:last_probed_at]
+    assert_equal FP_A, rec[:last_fingerprint]
+    assert_equal 0, rec[:attempts]
+    # Stamping the fingerprint parks the row as unchanged_signal until the
+    # signal changes — the probe-storm fix (U2/U3): a red probe must not
+    # re-spawn every tick while the signal is stable.
+    assert_equal :unchanged_signal, Budget.allow?(m, KEY, now: NOW, fingerprint: FP_A)
+    assert_equal :allow, Budget.allow?(m, KEY, now: NOW, fingerprint: FP_B)
+  end
+
+  def test_backoff_constants
+    assert_equal 2, AutoRetry::MAX_AUTO_RETRIES
+    assert_equal 0, AutoRetry::BACKOFF_AFTER_FIRST
+    assert_equal 30 * 60, AutoRetry::BACKOFF_AFTER_SECOND
+    assert_equal 0, Budget.backoff_for(0)
+    assert_equal 0, Budget.backoff_for(1)
+    assert_equal 30 * 60, Budget.backoff_for(2)
+    assert_equal 0, Budget.backoff_for(99)
+  end
+end
+
+class HiveDaemonAutoRetryStateStoreTest < Minitest::Test
+  Store = Hive::Daemon::AutoRetry::StateStore
+
+  KEY = [ "p", "s", "implementer_failed" ].freeze
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  def with_tmp_path
+    Dir.mktmpdir do |dir|
+      path = File.join(dir, "auto_retry_state.json")
+      yield path
+    end
+  end
+
+  def sample_map
+    { KEY => { attempts: 1, last_fingerprint: "fp", last_attempt_at: NOW,
+               last_probed_at: NOW } }
+  end
+
+  def test_write_then_load_round_trips
+    with_tmp_path do |path|
+      Store.write(sample_map, path)
+      loaded = Store.load(path)
+      assert loaded.key?(KEY)
+      rec = loaded[KEY]
+      assert_equal 1, rec[:attempts]
+      assert_equal "fp", rec[:last_fingerprint]
+      assert_kind_of Time, rec[:last_attempt_at]
+      assert_kind_of Time, rec[:last_probed_at]
+    end
+  end
+
+  def test_load_missing_file_returns_empty
+    with_tmp_path do |path|
+      assert_equal({}, Store.load(path))
+    end
+  end
+
+  def test_corrupt_file_degrades_to_empty
+    with_tmp_path do |path|
+      File.write(path, "{not valid json")
+      assert_equal({}, Store.load(path))
+    end
+  end
+
+  def test_non_array_records_degrades_to_empty
+    with_tmp_path do |path|
+      File.write(path, JSON.generate("schema_version" => 1, "records" => {}))
+      assert_equal({}, Store.load(path))
+    end
+  end
+
+  def test_load_drops_entries_missing_keys
+    with_tmp_path do |path|
+      Store.write({ KEY => sample_map[KEY], [ nil, "s", "r" ] => { attempts: 1 } }, path)
+      loaded = Store.load(path)
+      assert loaded.key?(KEY)
+      refute loaded.key?([ nil, "s", "r" ])
+    end
+  end
+
+  def test_write_handles_unwritable_dir_gracefully
+    path = "/nonexistent-dir-#{rand(10_000)}/auto_retry_state.json"
+    # Should not raise
+    Store.write(sample_map, path)
+    refute File.exist?(path)
+  end
+end
diff --git a/test/unit/daemon/auto_retry/classifier_test.rb b/test/unit/daemon/auto_retry/classifier_test.rb
