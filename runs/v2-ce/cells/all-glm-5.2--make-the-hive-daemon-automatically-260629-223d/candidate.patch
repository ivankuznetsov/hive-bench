index 00000000..0ae80458
--- /dev/null
+++ b/test/unit/daemon/auto_retry/classifier_test.rb
@@ -0,0 +1,171 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/classifier"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetryClassifierTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Classifier = Hive::Daemon::AutoRetry::Classifier
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  # Build a tmp project tree matching the canonical task-path shape:
+  #   <root>/myproj/.hive-state/stages/4-execute/<slug>/
+  # with the matching log dir at <root>/myproj/.hive-state/logs/<slug>/.
+  def with_project_tree(slug: "auto-retry-test-260629-aaaa", stage: "4-execute")
+    Dir.mktmpdir do |root|
+      project = File.join(root, "myproj")
+      stages = File.join(project, ".hive-state", "stages")
+      stage_dir = File.join(stages, stage)
+      folder = File.join(stage_dir, slug)
+      FileUtils.mkdir_p(folder)
+      log_dir = File.join(project, ".hive-state", "logs", slug)
+      FileUtils.mkdir_p(log_dir)
+      yield root, project, folder, log_dir, slug
+    end
+  end
+
+  def write_log(log_dir, content, name: "agent.log", mtime: NOW)
+    path = File.join(log_dir, name)
+    File.write(path, content)
+    File.utime(mtime, mtime, path) if mtime
+    path
+  end
+
+  def make_row(folder, reason:, stage: "4-execute", marker: "error",
+               marker_attrs: nil, workflow: nil, slug: nil)
+    attrs = marker_attrs || { "reason" => reason }
+    Row.new(
+      project: "myproj", slug: slug || "auto-retry-test-260629-aaaa", stage: stage,
+      workflow: workflow, marker: marker, marker_attrs: attrs, folder: folder,
+      state_file: File.join(folder, "task.md"), state_file_mtime: NOW - 1000,
+      action: "error", suggested_command: nil, claude_pid_alive: nil,
+      live_task_lock: nil, diagnostic: nil
+    )
+  end
+
+  def cfg(claude_mode: "tmux")
+    { "claude" => { "mode" => claude_mode }, "agents" => {} }
+  end
+
+  def test_implementer_failed_with_codex_auth_401_signature_is_recoverable
+    with_project_tree do |_root, _project, folder, log_dir|
+      write_log(log_dir, "Error: 401 Missing bearer/basic auth from upstream\n")
+      row = make_row(folder, reason: "implementer_failed")
+      result = Classifier.classify(row, cfg: cfg)
+      assert_equal({ reason: "implementer_failed",
+                     signature: "codex_auth_401",
+                     stage: "4-execute" }, result)
+    end
+  end
+
+  def test_implementer_failed_with_only_generic_exit_code_is_unknown
+    with_project_tree do |_root, _project, folder, log_dir|
+      write_log(log_dir, "Traceback: test failure stack\nexit_code=1\n")
+      row = make_row(folder, reason: "implementer_failed")
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg)
+    end
+  end
+
+  def test_implementer_failed_with_limits_reached_text_is_unknown
+    with_project_tree do |_root, _project, folder, log_dir|
+      # The 401 signature co-occurs with a limits_reached banner — limits path
+      # (the existing healer) owns it, so this must NOT be classified recoverable.
+      write_log(log_dir, "401 Missing bearer\nYou've hit your usage limit. Plan limit reached.\n")
+      row = make_row(folder, reason: "implementer_failed")
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg)
+    end
+  end
+
+  def test_implementer_failed_on_non_execute_stage_is_unknown
+    with_project_tree(stage: "3-plan") do |_root, _project, folder, log_dir|
+      write_log(log_dir, "401 Missing bearer/basic auth\n")
+      row = make_row(folder, reason: "implementer_failed", stage: "3-plan")
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg)
+    end
+  end
+
+  def test_claude_launch_failed_under_tmux_is_recoverable
+    with_project_tree(stage: "2-brainstorm") do |_root, _project, folder, _log_dir, slug|
+      row = make_row(folder, reason: "claude_launch_failed", stage: "2-brainstorm",
+                     slug: slug)
+      result = Classifier.classify(row, cfg: cfg)
+      assert_equal({ reason: "claude_launch_failed",
+                     signature: "launcher_failure",
+                     stage: "2-brainstorm" }, result)
+    end
+  end
+
+  def test_claude_launch_failed_under_headless_is_unknown
+    with_project_tree(stage: "2-brainstorm") do |_root, _project, folder, _log_dir, slug|
+      row = make_row(folder, reason: "claude_launch_failed", stage: "2-brainstorm",
+                     slug: slug)
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg(claude_mode: "headless"))
+    end
+  end
+
+  def test_unknown_reasons_are_unknown
+    with_project_tree do |_root, _project, folder, _log_dir|
+      %w[dirty_worktree tmux_unavailable].each do |reason|
+        row = make_row(folder, reason: reason)
+        assert_equal :unknown, Classifier.classify(row, cfg: cfg),
+                     "expected :unknown for reason=#{reason}"
+      end
+      # exit_code=143 and a blank reason
+      assert_equal :unknown, Classifier.classify(
+        make_row(folder, reason: ""), cfg: cfg
+      )
+    end
+  end
+
+  def test_execute_waiting_dirty_worktree_is_unknown
+    with_project_tree do |_root, _project, folder, _log_dir|
+      row = make_row(folder, reason: "dirty_worktree", marker: "execute_waiting")
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg)
+    end
+  end
+
+  def test_missing_log_file_degrades_to_unknown_without_raising
+    with_project_tree do |_root, _project, folder, log_dir|
+      # No log written
+      FileUtils.rm_rf(log_dir)
+      row = make_row(folder, reason: "implementer_failed")
+      assert_equal :unknown, Classifier.classify(row, cfg: cfg)
+    end
+  end
+
+  def test_non_utf8_log_degrades_to_unknown_without_raising
+    with_project_tree do |_root, _project, folder, log_dir|
+      # Write invalid UTF-8 bytes
+      File.binwrite(File.join(log_dir, "agent.log"), "\xFF\xFE401 Missing bearer\n")
+      row = make_row(folder, reason: "implementer_failed")
+      # tail_file scrubs invalid bytes — the 401 signature still parses, so
+      # this is recoverable (scrub does not raise). The contract is "no raise".
+      result = Classifier.classify(row, cfg: cfg)
+      assert_includes [:unknown, Hash], result.class
+    end
+  end
+
+  def test_oversized_log_is_bounded_and_still_classifies
+    with_project_tree do |_root, _project, folder, log_dir|
+      # A log larger than TAIL_BYTES whose tail carries the signature.
+      padding = "x" * (Hive::DiagnosticHelpers::TAIL_BYTES + 2_000)
+      write_log(log_dir, "#{padding}\n401 Missing bearer/basic auth\n")
+      row = make_row(folder, reason: "implementer_failed")
+      result = Classifier.classify(row, cfg: cfg)
+      # The signature lives in the tail window, so it is found.
+      assert_equal "codex_auth_401", result.is_a?(Hash) ? result[:signature] : nil
+    end
+  end
+
+  def test_newest_log_is_used_when_multiple_exist
+    with_project_tree do |_root, _project, folder, log_dir|
+      write_log(log_dir, "exit_code=1 generic failure\n", name: "older.log", mtime: NOW - 100)
+      write_log(log_dir, "401 Missing bearer\n", name: "newer.log", mtime: NOW)
+      row = make_row(folder, reason: "implementer_failed")
+      assert_equal "codex_auth_401", Classifier.classify(row, cfg: cfg)[:signature]
+    end
+  end
+end
