+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/coordinator"
+require "hive/daemon/auto_retry/probes"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetryCoordinatorTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Coordinator = Hive::Daemon::AutoRetry::Coordinator
+  AutoRetry = Hive::Daemon::AutoRetry
+  Result = AutoRetry::Probes::Result
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+    def initialize
+      @events = []
+    end
+    def event(name, **attrs)
+      @events << [ name, attrs ]
+    end
+  end
+
+  class FakeController
+    attr_reader :observed_mtimes, :running
+    def initialize(running: [])
+      @running = running
+      @observed_mtimes = []
+    end
+    def running_task?(project:, slug:)
+      @running.include?([ project, slug ])
+    end
+    def observe_state_file_mtime(project:, slug:, mtime:)
+      @observed_mtimes << { project: project, slug: slug, mtime: mtime }
+    end
+  end
+
+  class FakeRequestQueue
+    attr_reader :requests
+    def initialize
+      @requests = []
+    end
+    def write_request!(**kwargs)
+      @requests << kwargs
+      "req-#{@requests.size}"
+    end
+  end
+
+  # A fake probe module returning configurable results.
+  class FakeProbes
+    def self.default_wrapper_path = "/x/wrapper"
+    def initialize(overrides = {})
+      @overrides = overrides
+    end
+    def doctor_pass(cfg:, row:) = result(:doctor_pass)
+    def codex_login_status(cfg:, row:, agent_profiles: nil) = result(:codex_login_status)
+    def codex_exec_smoke(cfg:, row:) = result(:codex_exec_smoke)
+    def wrapper_exists(cfg:, row:) = result(:wrapper_exists)
+    def ready_detector(cfg:, row:) = result(:ready_detector)
+    def binary_version_match(cfg:, row:) = result(:binary_version_match)
+
+    private
+    def result(name)
+      @overrides[name] || Result.new(name: name.to_s, status: :green, stdout: "", stderr: "", duration_sec: 0.0, detail: "ok")
+    end
+  end
+
+  def green(name) = Result.new(name: name, status: :green, stdout: "", stderr: "", duration_sec: 0.0, detail: "ok")
+  def red(name) = Result.new(name: name, status: :red, stdout: "", stderr: "", duration_sec: 0.0, detail: "nope")
+  def timeout(name) = Result.new(name: name, status: :timeout, stdout: "", stderr: "", duration_sec: 0.0, detail: "t/o")
+
+  class FakeClassifier
+    def initialize(result)
+      @result = result
+    end
+    def classify(row, cfg:)
+      @result
+    end
+  end
+
+  class FakeSafety
+    def initialize(safe:, reason: "clean_worktree")
+      @safe = safe
+      @reason = reason
+    end
+    def safe_to_retry?(row, classifier_result, cfg:)
+      AutoRetry::SafetyGuard::Result.new(safe: @safe, reason: @reason)
+    end
+  end
+
+  class FakeExecutor
+    def initialize(status: :cleared)
+      @status = status
+    end
+    def execute(row, classifier_result:, cfg:, logger:, request_queue:, controller:, state_home: nil)
+      if @status == :cleared
+        # actually clear the marker via the real primitive so the test can assert state
+        Hive::Markers.clear_current(row.state_file, expected_name: :error,
+                                    match_attrs: { "reason" => classifier_result[:reason], "marker_id" => row.marker_attrs["marker_id"] })
+        controller.observe_state_file_mtime(project: row.project, slug: row.slug, mtime: row.state_file_mtime)
+        AutoRetry::RetryExecutor::Result.new(status: :cleared, request_id: "req-1")
+      else
+        AutoRetry::RetryExecutor::Result.new(status: @status, error: "boom", remediation: "hive run ...")
+      end
+    end
+  end
+
+  def with_task(reason: "implementer_failed", marker_id: "abc12345", stage: "4-execute",
+               slug: "auto-retry-test-260629-aaaa")
+    Dir.mktmpdir do |state_home|
+      project_root = File.join(state_home, "myproj")
+      folder = File.join(project_root, ".hive-state", "stages", stage, slug)
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "task.md")
+      File.write(state_file, "# task\n\n<!-- ERROR reason=#{reason} marker_id=#{marker_id} -->\n")
+      yield state_home, folder, state_file, slug, project_root
+    end
+  end
+
+  def make_row(folder, state_file, slug, stage: "4-execute", reason: "implementer_failed", marker_id: "abc12345")
+    Row.new(project: "myproj", slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => reason, "marker_id" => marker_id }, folder: folder,
+           state_file: state_file, state_file_mtime: NOW - 1000, action: "error",
+           suggested_command: nil, claude_pid_alive: nil, live_task_lock: nil, diagnostic: nil)
+  end
+
+  def classifier_result(reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute")
+    { reason: reason, signature: signature, stage: stage }
+  end
+
+  def build(state_home:, probes: FakeProbes.new, classifier_result: { reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute" },
+            safety: FakeSafety.new(safe: true), executor: Hive::Daemon::AutoRetry::RetryExecutor,
+            agent_profiles: Object.new.tap { |o| o.define_singleton_method(:logged_in?) { |*| true } })
+    logger = FakeLogger.new
+    controller = FakeController.new
+    queue = FakeRequestQueue.new
+    coord = Coordinator.new(logger: logger, controller: controller, request_queue: queue,
+                           state_home: state_home, agent_profiles: agent_profiles,
+                           probes: probes, classifier: FakeClassifier.new(classifier_result),
+                           safety_guard: safety, retry_executor: executor)
+    cfg_loader = ->(_project) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+    [ coord, logger, controller, queue, cfg_loader ]
+  end
+
+  def test_kill_switch_off_is_noop
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, controller, queue, loader = build(state_home: state_home)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader, enabled: false)
+      assert_empty queue.requests
+      assert_equal :error, Hive::Markers.current(state_file).name
+      # one disabled log line
+      assert(logger.events.any? { |n, _| n == :auto_retry_disabled })
+    end
+  end
+
+  def test_unknown_reason_stays_parked
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home, classifier_result: :unknown)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "unknown_reason" })
+    end
+  end
+
+  def test_green_probes_safe_budget_allow_clears_and_requeues
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_equal :none, Hive::Markers.current(state_file).name
+      assert_equal 1, queue.requests.size
+      req = queue.requests.first
+      assert_equal "auto_retry", req[:requestor]
+      assert_equal [ "hive", "run", slug, "--project", "myproj", "--stage", "4-execute" ], req[:argv]
+      assert(logger.events.any? { |n, _| n == :auto_retry_cleared })
+    end
+  end
+
+  def test_probe_red_not_retried
+    with_task do |state_home, folder, state_file, slug|
+      probes = FakeProbes.new(codex_exec_smoke: red(:codex_exec_smoke))
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home, probes: probes)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "probe_red:codex_exec_smoke" })
+    end
+  end
+
+  def test_red_probe_across_multiple_ticks_does_not_storm
+    # U2/U3: a parked marker whose probe stays red must NOT re-spawn the
+    # expensive probe every tick while the health signal is unchanged.
+    # The first tick probes (red) and stamps the fingerprint; subsequent
+    # ticks with the same signal hit the :unchanged_signal gate and skip
+    # the expensive spawn entirely.
+    with_task do |state_home, folder, state_file, slug|
+      smoke_calls = 0
+      red_smoke = red(:codex_exec_smoke)
+      probes = FakeProbes.new
+      probes.define_singleton_method(:codex_exec_smoke) do |cfg:, row:|
+        smoke_calls += 1
+        red_smoke
+      end
+      coord, _logger, _ctrl, queue, loader = build(state_home: state_home, probes: probes)
+      row = make_row(folder, state_file, slug)
+
+      6.times do |i|
+        coord.tick([ row ], now: NOW + i * 30, config_loader: loader)
+      end
+
+      assert_empty queue.requests, "red probe must never requeue"
+      assert_equal :error, Hive::Markers.current(state_file).name
+      # Exactly one expensive spawn across 6 ticks — the first. The
+      # unchanged-signal gate parks every subsequent tick.
+      assert_equal 1, smoke_calls,
+                   "expected exactly one codex_exec_smoke spawn across 6 stable-red ticks, got #{smoke_calls}"
+    end
+  end
+
+  def test_probe_timeout_not_retried
+    with_task do |state_home, folder, state_file, slug|
+      probes = FakeProbes.new(codex_exec_smoke: timeout(:codex_exec_smoke))
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home, probes: probes)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "probe_timeout:codex_exec_smoke" })
+    end
+  end
+
+  def test_safety_guard_blocks_not_retried
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home, safety: FakeSafety.new(safe: false, reason: "dirty_worktree:foo"))
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert_equal :error, Hive::Markers.current(state_file).name
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "safety_guard:dirty_worktree:foo" })
+    end
+  end
+
+  def test_unchanged_signal_blocks_retry_after_first_clear
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home)
+      row = make_row(folder, state_file, slug)
+      # First tick clears
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_equal 1, queue.requests.size
+      # Re-stamp the marker (simulating a re-fail with the SAME fingerprint)
+      File.write(state_file, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=abc12345 -->\n")
+      row2 = make_row(folder, state_file, slug)
+      coord.tick([ row2 ], now: NOW + 60, config_loader: loader)
+      assert_equal 1, queue.requests.size, "unchanged signal should NOT retry"
+      assert(logger.events.any? { |n, a| n == :auto_retry_not_retried && a[:rationale] == "unchanged_signal" })
+    end
+  end
+
+  def test_exhausted_after_two_attempts
+    with_task do |state_home, folder, state_file, slug|
+      coord, logger, _ctrl, queue, loader = build(state_home: state_home)
+      key = [ "myproj", slug, "implementer_failed" ]
+      # Simulate two prior cleared attempts (same fingerprint as current)
+      state = { key => { attempts: 2, last_fingerprint: "x", last_attempt_at: NOW, last_probed_at: nil } }
+      coord.instance_variable_set(:@state, state)
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert(logger.events.any? { |n, _| n == :auto_retry_exhausted })
+    end
+  end
+
+  def test_skip_running_task
+    with_task do |state_home, folder, state_file, slug|
+      controller = FakeController.new(running: [ [ "myproj", slug ] ])
+      logger = FakeLogger.new
+      queue = FakeRequestQueue.new
+      coord = Coordinator.new(logger: logger, controller: controller, request_queue: queue,
+                              state_home: state_home,
+                              agent_profiles: Object.new.tap { |o| o.define_singleton_method(:logged_in?) { |*| true } },
+                              probes: FakeProbes.new, classifier: FakeClassifier.new(classifier_result),
+                              safety_guard: FakeSafety.new(safe: true), retry_executor: FakeExecutor.new)
+      loader = ->(_p) { { "claude" => { "mode" => "tmux" }, "agents" => {} } }
+      row = make_row(folder, state_file, slug)
+      coord.tick([ row ], now: NOW, config_loader: loader)
+      assert_empty queue.requests
+      assert_equal :error, Hive::Markers.current(state_file).name
+    end
+  end
+end
diff --git a/test/unit/daemon/auto_retry/probe_cache_test.rb b/test/unit/daemon/auto_retry/probe_cache_test.rb
