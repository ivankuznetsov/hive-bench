index 00000000..463ab950
--- /dev/null
+++ b/test/unit/daemon/auto_retry/auditor_test.rb
@@ -0,0 +1,143 @@
+# frozen_string_literal: true
+require "test_helper"
+require "tmpdir"
+require "time"
+require "hive/daemon/auto_retry/auditor"
+require "hive/daemon/status_consumer"
+
+class HiveDaemonAutoRetryAuditorTest < Minitest::Test
+  Row = Hive::Daemon::StatusConsumer::Row
+  Auditor = Hive::Daemon::AutoRetry::Auditor
+
+  NOW = Time.utc(2026, 6, 29, 10, 0, 0)
+
+  class FakeLogger
+    attr_reader :events
+    def initialize
+      @events = []
+    end
+    def event(name, **attrs)
+      @events << [ name, attrs ]
+    end
+  end
+
+  def make_row(stage: "4-execute", reason: "implementer_failed", slug: "auto-retry-test-260629-aaaa")
+    dir = Dir.mktmpdir
+    folder = File.join(dir, ".hive-state", "stages", stage, slug)
+    FileUtils.mkdir_p(folder)
+    Row.new(project: "myproj", slug: slug, stage: stage, workflow: nil, marker: "error",
+           marker_attrs: { "reason" => reason, "marker_id" => "abc12345" }, folder: folder,
+           state_file: File.join(folder, "task.md"), state_file_mtime: NOW - 1000,
+           action: "error", suggested_command: nil, claude_pid_alive: nil,
+           live_task_lock: nil, diagnostic: nil)
+  end
+
+  def classifier_result(reason: "implementer_failed", signature: "codex_auth_401", stage: "4-execute")
+    { reason: reason, signature: signature, stage: stage }
+  end
+
+  def probe_results(statuses = { "doctor_pass" => :green, "codex_login_status" => :green, "codex_exec_smoke" => :green })
+    statuses.map do |name, status|
+      Hive::Daemon::AutoRetry::Probes::Result.new(name: name, status: status,
+                                                  stdout: status == :red ? "err" : "", stderr: "",
+                                                  duration_sec: 0.1, detail: "d")
+    end
+  end
+
+  def setup
+    @logger = FakeLogger.new
+    @auditor = Auditor.new(logger: @logger)
+  end
+
+  def test_cleared_emits_one_daemon_log_event_and_one_task_event
+    row = make_row
+    @auditor.cleared(row, classifier_result: classifier_result, probe_results: probe_results,
+                     fingerprint: "fp", attempt: 1, rationale: "probes_green")
+    cleared = @logger.events.find { |n, _| n == :auto_retry_cleared }
+    assert cleared, "expected auto_retry_cleared event"
+    attrs = cleared[1]
+    assert_equal "cleared", attrs[:action]
+    assert_equal "codex_auth_401", attrs[:classifier_signature]
+    assert_equal 1, attrs[:auto_retry_attempt]
+    assert_equal "fp", attrs[:signal_fingerprint]
+    assert attrs[:probe_results].is_a?(Hash)
+    assert_equal "green", attrs[:probe_results]["doctor_pass"]["status"]
+    # task events.jsonl line
+    events_path = File.join(row.folder, "events.jsonl")
+    assert File.exist?(events_path), "expected events.jsonl written"
+    line = File.readlines(events_path).last
+    parsed = JSON.parse(line)
+    assert_equal "auto_retry", parsed.fetch("event_type")
+    assert_match(/cleared reason=implementer_failed/, parsed.fetch("message"))
+  end
+
+  def test_not_retried_same_rationale_logged_once_until_rationale_changes
+    row = make_row
+    3.times do
+      @auditor.not_retried(row, classifier_result: classifier_result, rationale: "probe_red:codex_exec_smoke",
+                           fingerprint: "fp", now: NOW)
+    end
+    not_retried = @logger.events.select { |n, _| n == :auto_retry_not_retried }
+    assert_equal 1, not_retried.size, "same rationale should be deduped"
+
+    @auditor.not_retried(row, classifier_result: classifier_result, rationale: "probe_red:codex_login_status",
+                        fingerprint: "fp", now: NOW + 10)
+    not_retried = @logger.events.select { |n, _| n == :auto_retry_not_retried }
+    assert_equal 2, not_retried.size, "a changed rationale re-logs"
+  end
+
+  def test_not_retried_task_log_capped_per_fallback_interval
+    row = make_row
+    @auditor.not_retried(row, classifier_result: classifier_result, rationale: "probe_red:codex_exec_smoke",
+                         fingerprint: "fp", now: NOW)
+    # second emit within the interval — should NOT write another task line
+    events_path = File.join(row.folder, "events.jsonl")
+    first_count = File.exist?(events_path) ? File.readlines(events_path).size : 0
+    @auditor.not_retried(row, classifier_result: classifier_result, rationale: "probe_red:codex_login_status",
+                         fingerprint: "fp", now: NOW + 10)
+    second_count = File.exist?(events_path) ? File.readlines(events_path).size : 0
+    assert_equal first_count, second_count, "task-log negative line capped per fallback interval"
+  end
+
+  def test_exhausted_logged_once_per_key_with_remediation
+    row = make_row
+    3.times do
+      @auditor.exhausted(row, classifier_result: classifier_result, fingerprint: "fp", attempts: 2, now: NOW)
+    end
+    exhausted = @logger.events.select { |n, _| n == :auto_retry_exhausted }
+    assert_equal 1, exhausted.size
+    attrs = exhausted.first[1]
+    assert_equal "persisted", attrs[:budget_scope]
+    assert_equal "manual_fix", attrs[:suggested_next_action]
+    assert_match(/hive markers clear/, attrs[:remediation])
+  end
+
+  def test_requeue_failed_carries_manual_remediation
+    row = make_row
+    @auditor.requeue_failed(row, classifier_result: classifier_result,
+                            error: "RuntimeError: boom",
+                            remediation: "hive run #{row.slug} --project myproj --stage 4-execute")
+    rf = @logger.events.find { |n, _| n == :auto_retry_requeue_failed }
+    assert rf
+    assert_match(/boom/, rf[1][:error])
+    assert_match(/hive run/, rf[1][:remediation])
+    # task event too
+    line = File.readlines(File.join(row.folder, "events.jsonl")).last
+    assert_match(/requeue_failed/, JSON.parse(line).fetch("message"))
+  end
+
+  def test_kill_switch_disabled_logged_once
+    @auditor.disabled_once
+    @auditor.disabled_once
+    disabled = @logger.events.select { |n, _| n == :auto_retry_disabled }
+    assert_equal 1, disabled.size
+  end
+
+  def test_evaluated_logs_per_row
+    row = make_row
+    @auditor.evaluated(row, classifier_result: classifier_result, fingerprint: "fp", budget_status: :allow)
+    ev = @logger.events.find { |n, _| n == :auto_retry_evaluated }
+    assert ev
+    assert_equal :allow, ev[1][:budget_status]
+  end
+end
diff --git a/test/unit/daemon/auto_retry/budget_test.rb b/test/unit/daemon/auto_retry/budget_test.rb
