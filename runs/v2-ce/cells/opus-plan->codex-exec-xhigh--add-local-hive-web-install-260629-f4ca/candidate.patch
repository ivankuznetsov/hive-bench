+    end
+
+    doc = JSON.parse(out)
+    assert_equal "hive-web-status", doc.fetch("schema")
+    assert_equal true, doc.fetch("service_installed")
+    assert_equal false, doc.fetch("service_enabled")
+    assert_equal true, doc.dig("health", "ok")
+
+    schema = JSONSchemer.schema(JSON.parse(File.read(Hive::Schemas.schema_path("hive-web-status"))))
