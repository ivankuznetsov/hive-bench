diff --git a/lib/hive/setup/preflight.rb b/lib/hive/setup/preflight.rb
new file mode 100644
index 00000000..42945ea6
--- /dev/null
+++ b/lib/hive/setup/preflight.rb
@@ -0,0 +1,207 @@
+require "fileutils"
+require "open3"
+require "rbconfig"
+require "rubygems"
+
+module Hive
+  module Setup
+    class Preflight
+      QMD_FIX_COMMAND = 'npm install --global --prefix "${XDG_DATA_HOME:-$HOME/.local/share}/hive/qmd" @tobilu/qmd'.freeze
+
+      Row = Struct.new(:label, :status, :message, :fix_command, keyword_init: true) do
+        def to_h
+          {
+            "label" => label,
+            "status" => status,
+            "message" => message,
+            "fix_command" => fix_command
+          }
+        end
+
+        def blocking?
+          %w[missing unauthenticated failed].include?(status)
+        end
+      end
+
+      attr_reader :rows
+
+      def initialize(project_root: Dir.pwd, runner: nil, env: ENV)
+        @project_root = File.expand_path(project_root)
+        @runner = runner || method(:capture)
+        @env = env
+        @rows = []
+      end
+
+      def run(bootstrap: false)
+        @rows = [
+          check_ruby,
+          check_command("git", "Install git (for example: brew install git, apt install git, or xcode-select --install)"),
+          check_command("tmux", "Install tmux (for example: brew install tmux or apt install tmux)"),
+          check_node,
+          check_command("npm", "Install Node.js/npm from https://nodejs.org/ or your OS package manager"),
+          check_qmd(bootstrap: bootstrap),
+          check_external_cli("gh", auth_command: %w[gh auth status], fix_command: "gh auth login"),
+          check_external_cli("claude", auth_command: nil, fix_command: "claude login"),
+          check_external_cli("codex", auth_command: nil, fix_command: "codex login"),
+          check_web_app,
+          check_web_bundle(bootstrap: bootstrap),
+          check_sqlite
+        ]
+      end
+
+      def ok?
+        @rows.none?(&:blocking?)
+      end
+
+      private
+
+      def check_ruby
+        current = Gem::Version.new(RUBY_VERSION)
+        required = Gem::Version.new("3.4.0")
+        return ok("ruby", "Ruby #{RUBY_VERSION}") if current >= required
+
+        missing("ruby", "Ruby #{RUBY_VERSION} is too old; Hive local web requires Ruby >= 3.4",
+                "Install Ruby 3.4+ with mise, rbenv, asdf, Homebrew, or your OS package manager")
+      end
+
+      def check_node
+        check_command("node", "Install Node.js/npm from https://nodejs.org/ or your OS package manager")
+      end
+
+      def check_command(name, fix_command)
+        path = which(name)
+        path ? ok(name, path) : missing(name, "#{name} was not found on PATH", fix_command)
+      end
+
+      def check_external_cli(name, auth_command:, fix_command:)
+        path = which(name)
+        return missing(name, "#{name} was not found on PATH", "Install #{name}, then run `#{fix_command}`") unless path
+        return ok(name, path) unless auth_command
+
+        _out, err, status = @runner.call(auth_command, chdir: @project_root, env: @env.to_h)
+        return ok(name, "#{path}; authenticated") if status.success?
+
+        Row.new(
+          label: name,
+          status: "unauthenticated",
+          message: first_line(err) || "#{name} is installed but not authenticated",
+          fix_command: fix_command
+        )
+      rescue SystemCallError => e
+        missing(name, "#{name} auth probe failed: #{e.message}", fix_command)
+      end
+
+      def check_qmd(bootstrap:)
+        path = qmd_path
+        return ok("qmd", path) if path
+        return bootstrap_qmd if bootstrap
+
+        bootstrappable("qmd", "qmd was not found", QMD_FIX_COMMAND)
+      end
+
+      def bootstrap_qmd
+        _out, err, status = @runner.call(%w[npm install --global --prefix] + [ qmd_prefix, "@tobilu/qmd" ],
+                                         chdir: @project_root, env: @env.to_h)
+        return ok("qmd", "installed with #{QMD_FIX_COMMAND}") if status.success?
+
+        Row.new(label: "qmd", status: "failed", message: first_line(err) || "qmd install failed",
+                fix_command: QMD_FIX_COMMAND)
+      rescue SystemCallError => e
+        Row.new(label: "qmd", status: "failed", message: e.message, fix_command: QMD_FIX_COMMAND)
+      end
+
+      def check_web_app
+        web_app_dir ? ok("web app", web_app_dir) : missing("web app", "web/ Rails app was not found",
+                                                           "Run from a Hive source checkout or set HIVEBOX_WEB_APP_DIR")
+      end
+
+      def check_web_bundle(bootstrap:)
+        app = web_app_dir
+        return missing("web bundle", "web/ Rails app was not found",
+                       "Run from a Hive source checkout or set HIVEBOX_WEB_APP_DIR") unless app
+
+        env = @env.to_h.merge("BUNDLE_GEMFILE" => File.join(app, "Gemfile"))
+        _out, _err, status = @runner.call(%w[bundle check], chdir: app, env: env)
+        return ok("web bundle", "bundle check passed") if status.success?
+        return bootstrap_web_bundle(app, env) if bootstrap
+
+        bootstrappable("web bundle", "web bundle is not installed", "cd #{app} && bundle install")
+      rescue SystemCallError => e
+        missing("web bundle", e.message, "cd #{app} && bundle install")
+      end
+
+      def bootstrap_web_bundle(app, env)
+        _out, err, status = @runner.call(%w[bundle install], chdir: app, env: env)
+        return ok("web bundle", "installed with cd #{app} && bundle install") if status.success?
+
+        Row.new(label: "web bundle", status: "failed", message: first_line(err) || "bundle install failed",
+                fix_command: "cd #{app} && bundle install")
+      end
+
+      def check_sqlite
+        app = web_app_dir
+        env = @env.to_h
+        env = env.merge("BUNDLE_GEMFILE" => File.join(app, "Gemfile")) if app
+        _out, err, status = @runner.call([ "bundle", "exec", "ruby", "-e", "require 'sqlite3'" ],
+                                         chdir: app || @project_root, env: env)
+        return ok("sqlite", "sqlite3 gem is loadable") if status.success?
+
+        missing("sqlite", first_line(err) || "sqlite3 gem is not loadable",
+                app ? "cd #{app} && bundle install" : "Install SQLite development headers and the sqlite3 gem")
+      rescue SystemCallError => e
+        missing("sqlite", e.message, "Install SQLite development headers and the sqlite3 gem")
+      end
+
+      def web_app_dir
+        candidates = [
+          @env["HIVEBOX_WEB_APP_DIR"],
+          File.join(@project_root, "web"),
+          File.expand_path("../../../web", __dir__)
+        ].compact
+        candidates.find { |dir| File.file?(File.join(dir, "config", "application.rb")) }
+      end
+
+      def qmd_path
+        env_qmd = @env["HIVE_QMD_BIN"].to_s
+        return env_qmd if !env_qmd.empty? && File.executable?(env_qmd)
+
+        which("qmd") || [ File.join(qmd_prefix, "bin", "qmd"),
+                          File.expand_path("~/.local/share/hive/qmd/bin/qmd") ].find { |path| File.executable?(path) }
+      end
+
+      def qmd_prefix
+        data_home = @env["XDG_DATA_HOME"].to_s.empty? ? File.expand_path("~/.local/share") : @env["XDG_DATA_HOME"]
+        File.join(data_home, "hive", "qmd")
+      end
+
+      def which(name)
+        @env["PATH"].to_s.split(File::PATH_SEPARATOR).each do |dir|
+          path = File.join(dir, name)
+          return path if File.file?(path) && File.executable?(path)
+        end
+        nil
+      end
+
+      def capture(argv, chdir:, env:)
+        out, err, status = Open3.capture3(env, *argv, chdir: chdir)
+        [ out, err, status ]
+      end
+
+      def first_line(text)
+        text.to_s.lines.map(&:strip).find { |line| !line.empty? }
+      end
+
+      def ok(label, message)
+        Row.new(label: label, status: "ok", message: message, fix_command: nil)
+      end
+
+      def missing(label, message, fix_command)
+        Row.new(label: label, status: "missing", message: message, fix_command: fix_command)
+      end
+
+      def bootstrappable(label, message, fix_command)
+        Row.new(label: label, status: "bootstrappable", message: message, fix_command: fix_command)
+      end
+    end
+  end
+end
