+          "ok" => response.is_a?(Net::HTTPSuccess),
+          "url" => url,
+          "status" => response.code.to_i,
+          "error" => nil
+        }
+      rescue StandardError => e
+        {
+          "ok" => false,
+          "url" => url,
+          "status" => nil,
+          "error" => "#{e.class}: #{e.message}"
+        }
+      end
+
+      def health_host(bind)
+        case bind.to_s
+        when "", "0.0.0.0", "::", "[::]" then "127.0.0.1"
+        when "localhost" then "127.0.0.1"
+        else bind.to_s.delete_prefix("[").delete_suffix("]")
+        end
+      end
+
+      def current_binary_path
+        Hive::InvokedBinary.path
+      end
+
+      def safe_install_platform(installer)
+        installer.envelope_platform
+      rescue StandardError
+        "unsupported"
+      end
+
