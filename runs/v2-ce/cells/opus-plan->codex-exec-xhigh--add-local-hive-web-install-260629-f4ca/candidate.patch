@@ -0,0 +1,137 @@
+require "test_helper"
+require "hive/commands/web/service_installer"
+
+class WebServiceInstallerTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_linux_writes_systemd_unit_with_resolved_binary_and_web_app_dir
+    with_tmp_dir do |dir|
+      commands = []
+      hive = File.join(dir, "bin", "hive")
+      app = File.join(dir, "src", "web")
+      FileUtils.mkdir_p(File.dirname(hive))
+      FileUtils.mkdir_p(app)
+      File.write(hive, "#!/bin/sh\n")
+      FileUtils.chmod(0755, hive)
+
+      with_env("HIVEBOX_WEB_APP_DIR" => app) do
+        installer = Hive::Commands::Web::ServiceInstaller.new(
+          host_os: "linux-gnu",
+          home: dir,
+          binary_path: hive,
+          systemctl_available: true,
+          runner: ->(argv) { commands << argv; true }
+        )
+
+        result = installer.install!(autostart: false)
+        unit = File.join(dir, ".config/systemd/user/hive-web.service")
+        body = File.read(unit)
+        assert_equal :written, result.kind
+        assert_includes body, "ExecStart=#{hive} web run"
+        assert_includes body, "Environment=HIVE_BIN=#{hive}"
+        assert_includes body, "Environment=HIVEBOX_WEB_APP_DIR=#{app}"
+        assert_includes body, "Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin"
+        assert_empty commands
+      end
+    end
+  end
+
+  def test_linux_path_line_includes_detected_ruby_shim
+    with_tmp_dir do |dir|
+      mise_ruby = File.join(dir, ".local/share/mise/installs/ruby/3.4.0/bin/ruby")
+      fake_bin = File.join(dir, "fake-bin")
+      FileUtils.mkdir_p(File.dirname(mise_ruby))
+      FileUtils.mkdir_p(fake_bin)
+      File.write(mise_ruby, "#!/bin/sh\n")
+      FileUtils.chmod(0755, mise_ruby)
+      FileUtils.ln_s(mise_ruby, File.join(fake_bin, "ruby"))
+
+      with_env("PATH" => [ fake_bin, ENV.fetch("PATH", "") ].join(File::PATH_SEPARATOR)) do
+        installer = Hive::Commands::Web::ServiceInstaller.new(
+          host_os: "linux",
+          home: dir,
+          binary_path: "/tmp/hive",
+          systemctl_available: false
+        )
+
+        installer.install!(autostart: false)
+        unit = File.join(dir, ".config/systemd/user/hive-web.service")
+        assert_includes File.read(unit), "Environment=PATH=%h/.local/bin:%h/.local/share/mise/shims:/usr/local/bin:/usr/bin:/bin"
+      end
+    end
+  end
+
+  def test_macos_writes_launchd_plist
+    with_tmp_dir do |dir|
+      commands = []
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "darwin23",
+        home: dir,
+        binary_path: "/opt/hive/bin/hive",
+        runner: ->(argv) { commands << argv; true }
+      )
+
+      result = installer.install!(autostart: true)
+      plist = File.join(dir, "Library/LaunchAgents/local.hive-web.plist")
+      body = File.read(plist)
+      assert_equal :written, result.kind
+      assert_includes body, "<string>local.hive-web</string>"
+      assert_includes body, "<string>/opt/hive/bin/hive</string>"
+      assert_includes body, "<string>web</string>"
+      assert_includes body, "<string>run</string>"
+      assert_equal [ [ "launchctl", "load", plist ] ], commands
+    end
+  end
+
+  def test_unsupported_host_reports_friendly_message
+    with_tmp_dir do |dir|
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "freebsd14",
+        home: dir,
+        binary_path: "/tmp/hive"
+      )
+
+      result = installer.install!(autostart: true)
+      assert_equal :unsupported, result.kind
+      assert installer.messages.any? { |msg| msg.include?("web autostart not supported") }
+    end
+  end
+
+  def test_drift_without_force_leaves_unit_untouched
+    with_tmp_dir do |dir|
+      unit = File.join(dir, ".config/systemd/user/hive-web.service")
+      FileUtils.mkdir_p(File.dirname(unit))
+      File.write(unit, "custom\n")
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "linux",
+        home: dir,
+        binary_path: "/tmp/hive",
+        systemctl_available: false
+      )
+
+      result = installer.install!(autostart: false)
+      assert_equal :drifted, result.kind
+      assert_equal "custom\n", File.read(unit)
+    end
+  end
+
+  def test_force_backs_up_and_overwrites_drifted_unit
+    with_tmp_dir do |dir|
+      unit = File.join(dir, ".config/systemd/user/hive-web.service")
+      FileUtils.mkdir_p(File.dirname(unit))
+      File.write(unit, "custom\n")
+      installer = Hive::Commands::Web::ServiceInstaller.new(
+        host_os: "linux",
+        home: dir,
+        binary_path: "/tmp/hive",
+        systemctl_available: false
+      )
+
+      result = installer.install!(autostart: false, force: true)
+      assert_equal :upgraded, result.kind
+      assert_match(/\.bak-\d{8}T\d{6}Z\z/, result.backup_path)
+      assert_equal "custom\n", File.read(result.backup_path)
+      assert_includes File.read(unit), "ExecStart=/tmp/hive web run"
+    end
+  end
+end
