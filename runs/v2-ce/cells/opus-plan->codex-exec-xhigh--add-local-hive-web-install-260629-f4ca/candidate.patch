@@ -0,0 +1,132 @@
+require "test_helper"
+require "hive/commands/web"
+require "hive/commands/web/service_installer"
+require "json_schemer"
+
+class WebCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeInstaller = Struct.new(:target_path, :envelope_platform, :messages, keyword_init: true) do
+    attr_accessor :state, :outcome
+
+    def install!(autostart:, force:)
+      @install_args = { autostart: autostart, force: force }
+      outcome
+    end
+
+    def install_args
+      @install_args
+    end
+
+    def service_state
+      state
+    end
+  end
+
+  def fake_outcome(kind, backup_path: nil, restarted: false)
+    Hive::Commands::ServiceInstaller::Outcome.new(kind, backup_path: backup_path, restarted: restarted)
+  end
+
+  def test_bare_web_dispatches_to_foreground_run
+    command = Hive::Commands::Web.new
+    called = false
+    command.define_singleton_method(:run_foreground) { called = true }
+
+    command.call
+
+    assert called, "bare hive web must preserve the foreground server path"
+  end
+
+  def test_run_rejects_json_like_the_legacy_foreground_command
+    command = Hive::Commands::Web.new("run", json: true)
+
+    out, _err = capture_io do
+      assert_raises(Hive::InvalidTaskPath) { command.call }
+    end
+
+    doc = JSON.parse(out)
+    assert_equal false, doc.fetch("ok")
+    assert_equal Hive::ExitCodes::USAGE, doc.fetch("exit_code")
+  end
+
