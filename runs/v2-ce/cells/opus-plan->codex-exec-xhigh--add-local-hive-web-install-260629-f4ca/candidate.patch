diff --git a/test/unit/commands/setup_test.rb b/test/unit/commands/setup_test.rb
new file mode 100644
index 00000000..6bdc3921
--- /dev/null
+++ b/test/unit/commands/setup_test.rb
@@ -0,0 +1,116 @@
+require "test_helper"
+require "hive/commands/setup"
+require "json_schemer"
+
+class SetupCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeRow = Struct.new(:label, :status, :message, :fix_command, keyword_init: true) do
+    def to_h
+      { "label" => label, "status" => status, "message" => message, "fix_command" => fix_command }
+    end
+
+    def blocking?
+      status != "ok" && status != "bootstrappable"
+    end
+  end
+
+  FakePreflight = Struct.new(:rows, :ok_value, :calls, keyword_init: true) do
+    def run(bootstrap:)
+      calls << [ :run, bootstrap ]
+      rows
+    end
+
+    def ok?
+      ok_value
+    end
+  end
+
+  FakePrompt = Struct.new(:selected) do
+    def collect
+      selected
+    end
+  end
+
+  FakeCommand = Struct.new(:calls, :name) do
+    def call
+      calls << name
+    end
+  end
+
+  def test_setup_json_happy_path_with_service_validates_schema
+    with_tmp_global_config do |home|
+      project = File.join(home, "project")
+      FileUtils.mkdir_p(project)
+      data = YAML.safe_load(File.read(File.join(home, "config.yml")))
+      data["registered_projects"] = [
+        { "name" => "project", "path" => project, "hive_state_path" => File.join(project, ".hive-state") }
+      ]
+      File.write(File.join(home, "config.yml"), data.to_yaml)
+
+      preflight = FakePreflight.new(
+        rows: [ FakeRow.new(label: "ruby", status: "ok", message: "Ruby", fix_command: nil) ],
+        ok_value: true,
+        calls: []
+      )
+      calls = []
+      daemon_factory = lambda do |subcommand, target: nil, force: false, json: false|
+        FakeCommand.new(calls, [ :daemon, subcommand, target, force, json ])
+      end
+      web_factory = lambda do |subcommand, force: false, json: false|
+        FakeCommand.new(calls, [ :web, subcommand, force, json ])
+      end
+      out = StringIO.new
+
+      Hive::Commands::Setup.new(
+        project_root: project,
+        json: true,
+        service: true,
+        preflight: preflight,
+        backend_prompt: FakePrompt.new(%w[claude]),
+        daemon_factory: daemon_factory,
+        web_factory: web_factory,
+        output: out
+      ).call
+
+      doc = JSON.parse(out.string)
+      assert_equal true, doc.fetch("ok")
+      assert_equal %w[deps backends daemon enroll web], doc.fetch("steps").map { |step| step.fetch("name") }
+      assert_equal [ [ :run, true ] ], preflight.calls
+      assert_includes calls, [ :daemon, "install", nil, true, false ]
+      assert_includes calls, [ :daemon, "enable", "project", false, false ]
+      assert_includes calls, [ :web, "install", true, false ]
+      assert_includes calls, [ :web, "start", false, false ]
+
+      schema = JSONSchemer.schema(JSON.parse(File.read(Hive::Schemas.schema_path("hive-setup"))))
+      assert_empty schema.validate(doc).map { |error| error["error"] }
+    end
+  end
+
+  def test_setup_stops_on_missing_required_dependency
+    preflight = FakePreflight.new(
+      rows: [ FakeRow.new(label: "gh", status: "missing", message: "missing gh", fix_command: "install gh") ],
+      ok_value: false,
+      calls: []
+    )
+    calls = []
+    out = StringIO.new
+
+    error = assert_raises(Hive::Error) do
+      Hive::Commands::Setup.new(
+        json: true,
+        preflight: preflight,
+        backend_prompt: FakePrompt.new(%w[claude]),
+        daemon_factory: ->(*_args, **_kwargs) { calls << :daemon },
+        web_factory: ->(*_args, **_kwargs) { calls << :web },
+        output: out
+      ).call
+    end
+
+    assert_equal "fix required dependencies and re-run", error.message
+    doc = JSON.parse(out.string)
+    assert_equal false, doc.fetch("ok")
+    assert_equal [ "deps" ], doc.fetch("steps").map { |step| step.fetch("name") }
+    assert_empty calls
+  end
+end
