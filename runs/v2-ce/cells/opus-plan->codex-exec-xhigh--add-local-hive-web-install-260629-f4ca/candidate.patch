new file mode 100644
index 00000000..ffe8fcc5
--- /dev/null
+++ b/lib/hive/commands/setup.rb
@@ -0,0 +1,180 @@
+require "json"
+require "stringio"
+require "hive/config"
+require "hive/commands/daemon"
+require "hive/commands/setup/backend_prompt"
+require "hive/commands/web"
+require "hive/setup/preflight"
+
+module Hive
+  module Commands
+    class Setup
+      def initialize(project_root: Dir.pwd, json: false, yes: false, service: false, launch: true,
+                     preflight: nil, backend_prompt: nil, daemon_factory: nil, web_factory: nil,
+                     output: $stdout, input: $stdin)
+        @project_root = File.expand_path(project_root)
+        @json = json
+        @yes = yes
+        @service = service
+        @launch = launch
+        @preflight = preflight
+        @backend_prompt = backend_prompt
+        @daemon_factory = daemon_factory || method(:build_daemon_command)
+        @web_factory = web_factory || method(:build_web_command)
+        @output = output
+        @input = input
+        @steps = []
+      end
+
+      def call
+        run_preflight
+        return finish unless ok_so_far?
+
+        run_backends
+        return finish unless ok_so_far?
+
+        run_daemon
+        return finish unless ok_so_far?
+
+        run_enroll
+        return finish unless ok_so_far?
+
+        run_web
+        finish
+      end
+
+      private
+
+      def run_preflight
+        preflight = @preflight || Hive::Setup::Preflight.new(project_root: @project_root)
+        rows = preflight.run(bootstrap: true)
+        status = preflight.ok? ? "ok" : "failed"
+        add_step("deps", status, rows: rows.map(&:to_h),
+                                 message: status == "ok" ? "local dependencies ready" : "fix required dependencies and re-run")
+      end
+
+      def run_backends
+        prompt = @backend_prompt || Hive::Commands::Setup::BackendPrompt.new(input: @input, output: $stderr, summary_io: @output)
+        selected = prompt.collect
+        Hive::Config.write_global_agents!(selected)
+        add_step("backends", "ok", selected: selected, message: "configured #{selected.join(', ')}")
+      rescue Hive::Commands::Setup::BackendPrompt::Aborted => e
+        add_step("backends", "failed", message: e.message)
+      end
+
+      def run_daemon
+        run_command(@daemon_factory.call("install", force: true, json: false))
+        add_step("daemon", "ok", message: "daemon service installed with current hive binary")
+      rescue Hive::Error => e
+        add_step("daemon", "failed", message: e.message, fix_command: "hive daemon install --force")
+      end
+
+      def run_enroll
+        entry = current_project_entry
+        unless entry
+          add_step("enroll", "failed",
+                   message: "current checkout is not registered with Hive",
+                   fix_command: "hive init && hive daemon enable #{File.basename(@project_root)}")
+          return
+        end
+
+        run_command(@daemon_factory.call("enable", target: entry.fetch("name"), json: false))
+        add_step("enroll", "ok", project: entry.fetch("name"), message: "daemon dispatch enabled")
+      rescue Hive::Error => e
+        add_step("enroll", "failed", message: e.message, fix_command: "hive daemon enable PROJECT")
+      end
+
+      def run_web
+        if @service
+          run_command(@web_factory.call("install", force: true, json: false))
+          run_command(@web_factory.call("start", json: false))
+          add_step("web", "ok", mode: "service", message: "web service installed and start requested")
+        elsif @launch && !@json
+          add_step("web", "ok", mode: "foreground", message: "launching foreground web server")
+          @web_factory.call("run", json: false).call
+        else
+          add_step("web", "ok", mode: "foreground", message: "run `hive web` to launch the foreground web server")
+        end
+      rescue Hive::Error => e
+        fix = @service ? "hive web install --force && hive web start" : "hive web"
+        add_step("web", "failed", message: e.message, fix_command: fix)
+      end
+
+      def run_command(command)
+        if @json
+          silence_stdout { command.call }
+        else
+          command.call
+        end
+      end
+
+      def finish
+        payload = {
+          "schema" => "hive-setup",
+          "schema_version" => Hive::Schemas::SCHEMA_VERSIONS.fetch("hive-setup"),
+          "ok" => ok_so_far?,
+          "service" => @service,
+          "yes" => @yes,
+          "project_root" => @project_root,
+          "steps" => @steps
+        }
+        if @json
+          @output.puts JSON.generate(payload)
+        else
+          render_text(payload)
+        end
+        raise Hive::Error, first_failure_message unless payload.fetch("ok")
+
+        payload
+      end
+
+      def render_text(payload)
+        @output.puts "hive setup:"
+        payload.fetch("steps").each do |step|
+          marker = step.fetch("status") == "ok" ? "ok" : "failed"
+          @output.puts "  #{marker} #{step.fetch("name")}: #{step["message"]}"
+          @output.puts "      fix: #{step["fix_command"]}" if step["fix_command"]
+        end
+      end
+
+      def ok_so_far?
+        @steps.none? { |step| step.fetch("status") == "failed" }
+      end
+
+      def first_failure_message
+        failed = @steps.find { |step| step.fetch("status") == "failed" }
+        failed ? failed.fetch("message") : "setup failed"
+      end
+
+      def add_step(name, status, **fields)
+        @steps << { "name" => name, "status" => status }.merge(stringify_keys(fields))
+      end
+
+      def stringify_keys(hash)
+        hash.to_h { |key, value| [ key.to_s, value ] }
+      end
+
+      def current_project_entry
+        Hive::Config.registered_projects.find do |entry|
+          File.expand_path(entry.fetch("path")) == @project_root
+        end
+      end
+
+      def build_daemon_command(subcommand, target: nil, force: false, json: false)
+        Hive::Commands::Daemon.new(subcommand, target, force: force, json: json)
+      end
+
+      def build_web_command(subcommand, force: false, json: false)
+        Hive::Commands::Web.new(subcommand, force: force, json: json)
+      end
+
+      def silence_stdout
+        old_stdout = $stdout
+        $stdout = StringIO.new
+        yield
+      ensure
+        $stdout = old_stdout
+      end
+    end
+  end
+end
