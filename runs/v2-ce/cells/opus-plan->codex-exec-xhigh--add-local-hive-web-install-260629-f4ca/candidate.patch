+      def daemon_consistency(running:, pid_payload:, service_state:)
+        cli_binary = current_binary_path
+        cli_version = Hive::VERSION
+        running_binary = running ? pid_payload&.fetch("hive_binary", nil) : nil
+        running_version = running ? pid_payload&.fetch("hive_version", nil) : nil
+        unit_binary = unit_binary_from(service_state["unit_path"])
+
+        binary_matches =
+          if unit_binary && cli_binary
+            same_path?(unit_binary, cli_binary)
+          else
+            unit_binary.nil?
+          end
+        running_matches =
+          if running
+            same_path?(running_binary, cli_binary) && running_version == cli_version
+          else
+            true
+          end
+        consistent = binary_matches && running_matches
+
+        {
+          "binary_consistent" => consistent,
+          "running_binary" => running_binary,
+          "running_version" => running_version,
+          "cli_binary" => cli_binary,
+          "cli_version" => cli_version,
+          "unit_binary" => unit_binary,
+          "repair_command" => consistent ? nil : "hive daemon install --force"
+        }
+      rescue StandardError
+        {
+          "binary_consistent" => false,
+          "running_binary" => nil,
+          "running_version" => nil,
+          "cli_binary" => current_binary_path,
+          "cli_version" => Hive::VERSION,
+          "unit_binary" => nil,
+          "repair_command" => "hive daemon install --force"
+        }
+      end
+
+      def unit_binary_from(unit_path)
+        return nil unless unit_path && File.file?(unit_path)
+
+        text = File.read(unit_path)
+        hive_bin = text.lines.find { |line| line.start_with?("Environment=HIVE_BIN=") }
+        return Shellwords.split(hive_bin.delete_prefix("Environment=HIVE_BIN=").strip).first if hive_bin
+
+        exec = text.lines.find { |line| line.start_with?("ExecStart=") }
+        return Shellwords.split(exec.split("=", 2).last.to_s.strip).first if exec
+
+        text.scan(%r{<string>([^<]+)</string>})
+            .map { |match| CGI.unescapeHTML(match.first) }
+            .find { |value| value.include?(File::SEPARATOR) && %w[hive hv].include?(File.basename(value)) }
+      rescue ArgumentError
+        nil
+      end
+
+      def same_path?(left, right)
+        return false if left.to_s.empty? || right.to_s.empty?
+
+        normalize_path(left) == normalize_path(right)
+      end
+
+      def normalize_path(path)
+        expanded = File.expand_path(path.to_s)
+        File.exist?(expanded) ? File.realpath(expanded) : expanded
+      end
