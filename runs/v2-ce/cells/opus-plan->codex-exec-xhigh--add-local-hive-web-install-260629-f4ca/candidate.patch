+    with_replaced_singleton_method(Hive::Commands::Web::ServiceInstaller, :new, ->(**_kwargs) { installer }) do
+      out, _err = capture_io { command.call }
+      assert_includes out, "start requested"
+    end
+
+    assert_equal [ %w[systemctl --user start hive-web] ], commands
+  end
+
+  def test_unknown_subcommand_exits_usage_with_json_guidance
+    command = Hive::Commands::Web.new("bogus", json: true)
+
+    out, _err = capture_io do
+      assert_raises(Hive::InvalidTaskPath) { command.call }
+    end
+
+    doc = JSON.parse(out)
+    assert_equal "unknown_subcommand", doc.fetch("error_kind")
+    assert_equal Hive::ExitCodes::USAGE, doc.fetch("exit_code")
+  end
+end
