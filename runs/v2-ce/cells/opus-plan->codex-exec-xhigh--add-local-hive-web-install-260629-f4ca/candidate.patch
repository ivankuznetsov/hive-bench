@@ -0,0 +1,60 @@
+require "test_helper"
+require "hive/commands/web"
+
+class WebBindGuardTest < Minitest::Test
+  def config(client_id: nil, unsafe: false)
+    {
+      "origin" => "http://127.0.0.1:4567",
+      "allow_public_unsafe" => unsafe,
+      "github" => { "client_id" => client_id, "owner" => nil }
+    }
+  end
+
+  def test_loopback_bind_does_not_require_auth
+    command = Hive::Commands::Web.new
+
+    command.send(:guard_bind!, "127.0.0.1", config)
+    command.send(:guard_bind!, "127.12.3.4", config)
+    command.send(:guard_bind!, "::1", config)
+    command.send(:guard_bind!, "localhost", config)
+  end
+
+  def test_public_bind_without_auth_is_refused
+    command = Hive::Commands::Web.new
+
+    error = assert_raises(Hive::InvalidTaskPath) do
+      command.send(:guard_bind!, "0.0.0.0", config)
+    end
+
+    assert_match(/refusing to bind/, error.message)
+    assert_match(/web\.github\.client_id/, error.message)
+    assert_match(/--unsafe/, error.message)
+    assert_match(/web\.allow_public_unsafe/, error.message)
+  end
+
+  def test_public_bind_with_unsafe_warns_and_proceeds
+    command = Hive::Commands::Web.new(unsafe: true)
+
+    _out, err = capture_io do
+      command.send(:guard_bind!, "0.0.0.0", config)
+    end
+
+    assert_match(/WARNING binding 0\.0\.0\.0/, err)
+  end
+
+  def test_public_bind_with_config_unsafe_warns_and_proceeds
+    command = Hive::Commands::Web.new
+
+    _out, err = capture_io do
+      command.send(:guard_bind!, "::", config(unsafe: true))
+    end
+
+    assert_match(/WARNING binding ::/, err)
+  end
+
+  def test_public_bind_with_github_auth_configured_proceeds
+    command = Hive::Commands::Web.new
+
+    command.send(:guard_bind!, "0.0.0.0", config(client_id: "cid"))
+  end
+end
