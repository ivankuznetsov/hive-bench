+    installer = FakeInstaller.new(target_path: "/tmp/hive-web.service", envelope_platform: "linux", messages: [])
+    installer.state = {
+      "platform" => "linux",
+      "service_installed" => true,
+      "service_enabled" => false,
+      "unit_path" => "/tmp/hive-web.service"
+    }
+    command = Hive::Commands::Web.new("status", json: true)
+    command.define_singleton_method(:web_health) do |_cfg|
+      { "ok" => true, "url" => "http://127.0.0.1:4567/health", "status" => 200, "error" => nil }
+    end
+
+    out, _err = with_replaced_singleton_method(
+      Hive::Commands::Web::ServiceInstaller,
+      :new,
+      ->(**_kwargs) { installer }
+    ) do
