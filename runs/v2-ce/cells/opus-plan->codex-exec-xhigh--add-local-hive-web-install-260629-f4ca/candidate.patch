diff --git a/test/unit/setup/preflight_test.rb b/test/unit/setup/preflight_test.rb
new file mode 100644
index 00000000..33e63817
--- /dev/null
+++ b/test/unit/setup/preflight_test.rb
@@ -0,0 +1,119 @@
+require "test_helper"
+require "hive/setup/preflight"
+
+class SetupPreflightTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeStatus = Struct.new(:ok) do
+    def success?
+      ok
+    end
+  end
+
+  def executable(dir, name)
+    path = File.join(dir, name)
+    File.write(path, "#!/bin/sh\n")
+    FileUtils.chmod(0755, path)
+    path
+  end
+
+  def web_app(dir)
+    app = File.join(dir, "web")
+    FileUtils.mkdir_p(File.join(app, "config"))
+    File.write(File.join(app, "config", "application.rb"), "# app\n")
+    File.write(File.join(app, "Gemfile"), "source 'https://rubygems.org'\n")
+    app
+  end
+
+  def test_qmd_absent_is_bootstrappable_without_running_install
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "bin")
+      FileUtils.mkdir_p(bin)
+      %w[git tmux node npm gh claude codex bundle].each { |name| executable(bin, name) }
+      web_app(dir)
+      calls = []
+      runner = lambda do |argv, chdir:, env:|
+        calls << argv
+        ok = argv == %w[gh auth status] || argv == %w[bundle check] || argv.include?("sqlite3")
+        [ "", "", FakeStatus.new(ok) ]
+      end
+
+      preflight = Hive::Setup::Preflight.new(project_root: dir, runner: runner, env: { "PATH" => bin })
+      rows = preflight.run(bootstrap: false)
+
+      qmd = rows.find { |row| row.label == "qmd" }
+      assert_equal "bootstrappable", qmd.status
+      assert_includes qmd.fix_command, "@tobilu/qmd"
+      refute calls.any? { |argv| argv.include?("@tobilu/qmd") }
+    end
+  end
+
+  def test_bootstrap_qmd_invokes_documented_npm_install
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "bin")
+      data = File.join(dir, "data")
+      FileUtils.mkdir_p(bin)
+      %w[git tmux node npm gh claude codex bundle].each { |name| executable(bin, name) }
+      web_app(dir)
+      calls = []
+      runner = lambda do |argv, chdir:, env:|
+        calls << argv
+        [ "", "", FakeStatus.new(true) ]
+      end
+
+      preflight = Hive::Setup::Preflight.new(
+        project_root: dir,
+        runner: runner,
+        env: { "PATH" => bin, "XDG_DATA_HOME" => data }
+      )
+      rows = preflight.run(bootstrap: true)
+
+      qmd = rows.find { |row| row.label == "qmd" }
+      assert_equal "ok", qmd.status
+      assert calls.any? { |argv| argv == [ "npm", "install", "--global", "--prefix", File.join(data, "hive", "qmd"), "@tobilu/qmd" ] }
+    end
+  end
+
+  def test_gh_present_but_unauthenticated_is_diagnose_only
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "bin")
+      FileUtils.mkdir_p(bin)
+      %w[git tmux node npm gh claude codex bundle qmd].each { |name| executable(bin, name) }
+      web_app(dir)
+      calls = []
+      runner = lambda do |argv, chdir:, env:|
+        calls << argv
+        ok = argv != %w[gh auth status]
+        [ "", "not logged in\n", FakeStatus.new(ok) ]
+      end
+
+      preflight = Hive::Setup::Preflight.new(project_root: dir, runner: runner, env: { "PATH" => bin })
+      rows = preflight.run(bootstrap: false)
+
+      gh = rows.find { |row| row.label == "gh" }
+      assert_equal "unauthenticated", gh.status
+      assert_equal "gh auth login", gh.fix_command
+      assert_equal [ %w[gh auth status], %w[bundle check], [ "bundle", "exec", "ruby", "-e", "require 'sqlite3'" ] ], calls
+    end
+  end
+
+  def test_missing_web_bundle_is_bootstrappable
+    with_tmp_dir do |dir|
+      bin = File.join(dir, "bin")
+      FileUtils.mkdir_p(bin)
+      %w[git tmux node npm gh claude codex bundle qmd].each { |name| executable(bin, name) }
+      app = web_app(dir)
+      runner = lambda do |argv, chdir:, env:|
+        ok = argv != %w[bundle check]
+        [ "", "bundle missing\n", FakeStatus.new(ok) ]
+      end
+
+      preflight = Hive::Setup::Preflight.new(project_root: dir, runner: runner, env: { "PATH" => bin })
+      rows = preflight.run(bootstrap: false)
+
+      bundle = rows.find { |row| row.label == "web bundle" }
+      assert_equal "bootstrappable", bundle.status
+      assert_equal "cd #{app} && bundle install", bundle.fix_command
+    end
+  end
+end
