--- /dev/null
+++ b/examples/systemd/hive-web.service
@@ -0,0 +1,26 @@
+# Sample systemd-user unit for `hive web` (Linux).
+#
+# Install:
+#   hive web install
+#   systemctl --user status hive-web
+#
+# This unit runs the Rails web server in the foreground. systemd is the
+# supervisor; Restart=on-failure brings the server back if it crashes.
+
+[Unit]
+Description=Hive local web UI
+After=default.target
+StartLimitBurst=3
+StartLimitIntervalSec=300
+
+[Service]
+Type=simple
+Environment=HIVE_BIN=%h/.local/bin/hive
+Environment=HIVEBOX_WEB_APP_DIR=%h/Dev/hive/web
+Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
+ExecStart=%h/.local/bin/hive web run
+Restart=on-failure
+RestartSec=30s
+
+[Install]
+WantedBy=default.target
