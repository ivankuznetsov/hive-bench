+    desc "update", "Upgrade hive via the detected install channel's native updater"
+    long_desc <<~DESC
+      Detects how hive was installed (Homebrew / AUR / curl|bash one-liner)
+      and shells out to that channel's NATIVE updater. Never swaps the
+      binary in place — brew/pacman/your shell own the path.
+
+      Channels:
+        brew  → `brew upgrade hive`
+        aur   → `yay -Syu hive-bin` (or `paru` if `yay` is absent)
+        bash  → re-run the pinned curl|bash one-liner for the latest tag
+        unknown → print help, exit non-zero
+
+      `--check` queries the GitHub Releases API for the latest tag vs.
+      the installed version WITHOUT upgrading.
+
+      Exit codes: 0 success / up-to-date; 1 unknown channel or native
+      updater failed; 70 internal error.
+    DESC
+    option :check, type: :boolean, default: false, desc: "print latest vs. installed without upgrading"
+    def update
+      require "hive/commands/update"
+      cmd = Hive::Commands::Update.new(json: options[:json])
+      exit options[:check] ? cmd.check : cmd.call
+    end
+
+    desc "uninstall", "Remove hive via the detected channel's native uninstaller (preserves user work)"
+    long_desc <<~DESC
+      Detects how hive was installed and runs that channel's native
+      uninstaller (brew uninstall hive / yay -Rns hive-bin / install.sh
+      --uninstall). Prompts (TTY) before touching operator-scoped content.
+
+      Scope matrix:
+        binary + daemon registration → channel-native uninstall always
+        global config (~/.config/hive) → --purge OR (TTY + yes)
+        global state/cache             → TTY + yes ONLY (never --purge)
+        per-project .hive-state/      → NEVER (user work)
+        ~/.claude/ ~/.codex/ ~/.pi/    → NEVER (skills via marketplace)
+
+      `--purge` (non-interactive, CI): removes binary + daemon registration
+      + global config; STILL preserves project .hive-state/ and accumulated
+      pipeline state.
+
+      Exit codes: 0 success; 1 unknown channel or native uninstaller failed.
+    DESC
+    option :purge, type: :boolean, default: false, desc: "non-interactive: binary + registration + global config only"
+    option :yes, type: :boolean, default: false, aliases: %w[y], desc: "assume yes to all TTY prompts"
+    def uninstall
+      require "hive/commands/uninstall"
+      exit Hive::Commands::Uninstall.new(
+        purge: options[:purge], yes: options[:yes], json: options[:json]
+      ).call
+    end
+
     desc "init [PROJECT_PATH]", "Bootstrap .hive-state (orphan hive/state branch); TTY-prompts for agents + limits"
     long_desc <<~DESC
       Initialises hive in PROJECT_PATH (defaults to the current directory):
@@ -160,8 +213,15 @@ module Hive
         hive doctor                       # tabular output
         hive doctor --json                # machine-readable envelope
