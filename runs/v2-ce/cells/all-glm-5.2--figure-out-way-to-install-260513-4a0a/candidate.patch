+        DEFAULT_AGENT = "claude".freeze
+        DEFAULT_MODEL = "claude-sonnet-4".freeze
+        AGENT_CHOICES = %w[claude codex pi].freeze
+
+        def initialize(input: $stdin, output: $stderr, summary_io: $stdout,
