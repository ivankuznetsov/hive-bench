@@ -0,0 +1,167 @@
+require "test_helper"
+require "stringio"
+require "hive/install_channel"
+require "hive/commands/update"
+
+class HiveInstallChannelTest < Minitest::Test
+  include HiveTestHelper
+
+  # Fake shell: a callable returning [stdout, stderr, status] keyed by
+  # the joined argv string. Lets tests assert detection without brew/pacman
+  # being installed.
+  class FakeShell
+    def initialize(responses)
+      @responses = responses
+    end
+
+    def call(argv)
+      key = argv.join(" ")
+      entry = @responses[key]
+      return [ "", "command not found", FakeStatus.new(false) ] unless entry
+
+      [ entry[:out].to_s, entry[:err].to_s, FakeStatus.new(entry[:ok]) ]
+    end
+  end
+
+  class FakeStatus
+    def initialize(ok); @ok = ok; end
+    def success?; @ok; end
+  end
+
+  def shell_with(responses)
+    FakeShell.new(responses)
+  end
+
+  def test_detect_bash_via_marker
+    with_tmp_dir do |dir|
+      marker = File.join(dir, "CHANNEL")
+      FileUtils.mkdir_p(File.dirname(marker))
+      File.write(marker, "bash\n")
+      assert_equal :bash, Hive::InstallChannel.detect(
+        shell: shell_with({}), marker_file: marker
+      )
+    end
+  end
+
+  def test_detect_brew_when_brew_list_succeeds
+    shell = shell_with("brew list --versions hive" => { out: "hive 0.1.0", ok: true })
+    assert_equal :brew, Hive::InstallChannel.detect(shell: shell, marker_file: "/nonexistent")
+  end
+
+  def test_detect_aur_when_pacman_query_succeeds
+    shell = shell_with("pacman -Q hive-bin" => { out: "hive-bin 0.1.0-1", ok: true })
+    assert_equal :aur, Hive::InstallChannel.detect(shell: shell, marker_file: "/nonexistent")
+  end
+
+  def test_detect_unknown_when_nothing_matches
+    assert_equal :unknown, Hive::InstallChannel.detect(
+      shell: shell_with({}), marker_file: "/nonexistent"
+    )
+  end
+
+  def test_bash_marker_ignored_when_content_wrong
+    with_tmp_dir do |dir|
+      marker = File.join(dir, "CHANNEL")
+      File.write(marker, "something-else\n")
+      assert_equal :unknown, Hive::InstallChannel.detect(
+        shell: shell_with({}), marker_file: marker
+      )
+    end
+  end
+
+  def test_name_human_readable_for_each_channel
+    assert_match(/Homebrew/, Hive::InstallChannel.name(:brew))
+    assert_match(/AUR/, Hive::InstallChannel.name(:aur))
+    assert_match(/one-liner/, Hive::InstallChannel.name(:bash))
+    assert_match(/unknown/, Hive::InstallChannel.name(:unknown))
+  end
+end
+
+class HiveCommandsUpdateTest < Minitest::Test
+  include HiveTestHelper
+
+  def fake_shell(responses)
+    HiveInstallChannelTest::FakeShell.new(responses)
+  end
+
+  def recorded_runner
+    runs = []
+    runner = ->(argv) { runs << argv; true }
+    [ runner, runs ]
+  end
+
+  def test_brew_channel_dispatches_brew_upgrade
+    runner, runs = recorded_runner
+    cmd = Hive::Commands::Update.new(channel: :brew, shell: fake_shell({}), runner: runner, output: StringIO.new)
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a[0..2] == %w[brew upgrade hive] },
+           "must dispatch brew upgrade hive; got #{runs.inspect}")
+  end
+
+  def test_aur_channel_dispatches_yay_syU
+    runner, runs = recorded_runner
+    shell = fake_shell("which yay" => { out: "/usr/bin/yay", ok: true })
+    cmd = Hive::Commands::Update.new(channel: :aur, shell: shell, runner: runner, output: StringIO.new)
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a[0] == "yay" && a[1] == "-Syu" && a[2] == "hive-bin" },
+           "must dispatch yay -Syu hive-bin; got #{runs.inspect}")
+  end
+
+  def test_aur_falls_back_to_paru_when_yay_absent
+    runner, runs = recorded_runner
+    shell = fake_shell(
+      "which yay" => { out: "", ok: false },
+      "which paru" => { out: "/usr/bin/paru", ok: true }
+    )
+    cmd = Hive::Commands::Update.new(channel: :aur, shell: shell, runner: runner, output: StringIO.new)
+    cmd.call
+    assert(runs.any? { |a| a[0] == "paru" }, "must fall back to paru; got #{runs.inspect}")
+  end
+
+  def test_bash_channel_dispatches_one_liner
+    runner, runs = recorded_runner
+    cmd = Hive::Commands::Update.new(channel: :bash, shell: fake_shell({}), runner: runner, output: StringIO.new)
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a[0] == "bash" }, "must dispatch bash one-liner; got #{runs.inspect}")
+  end
+
+  def test_unknown_channel_prints_help_and_exits_nonzero
+    out = StringIO.new
+    cmd = Hive::Commands::Update.new(channel: :unknown, shell: fake_shell({}), runner: ->(_) { flunk }, output: out)
+    assert_equal 1, cmd.call
+    assert_match(/could not detect the install channel/, out.string)
+  end
+
+  def test_dispatch_uses_install_channel_detect_when_channel_not_injected
+    with_tmp_dir do |dir|
+      marker = File.join(dir, "CHANNEL")
+      FileUtils.mkdir_p(File.dirname(marker))
+      File.write(marker, "bash\n")
+      runner, runs = recorded_runner
+      cmd = Hive::Commands::Update.new(
+        shell: fake_shell({}), marker_file: marker, runner: runner, output: StringIO.new
+      )
+      cmd.call
+      assert(runs.any? { |a| a[0] == "bash" }, "detected :bash must dispatch the one-liner; got #{runs.inspect}")
+    end
+  end
+
+  def test_unknown_channel_json_envelope
+    out = StringIO.new
+    cmd = Hive::Commands::Update.new(channel: :unknown, shell: fake_shell({}), runner: ->(_) { flunk },
+                                     json: true, output: out)
+    assert_equal 1, cmd.call
+    payload = JSON.parse(out.string)
+    assert_equal "unknown", payload["channel"]
+    assert_equal "unknown_channel", payload["result"]
+    refute payload["ok"]
+  end
+
+  def test_compare_versions
+    cmd = Hive::Commands::Update.new(channel: :brew, runner: ->(_) {})
+    assert_equal :up_to_date, cmd.send(:compare_versions, "0.1.0", "0.1.0")
+    assert_equal :behind, cmd.send(:compare_versions, "0.1.0", "0.2.0")
+    assert_equal :ahead, cmd.send(:compare_versions, "0.2.0", "0.1.0")
+    assert_equal :behind, cmd.send(:compare_versions, "0.1.0", "v0.1.1")
+  end
+end
