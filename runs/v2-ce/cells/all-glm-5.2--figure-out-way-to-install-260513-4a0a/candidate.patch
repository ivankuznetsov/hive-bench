 end
+
+# U9: first-run GLOBAL config prompts (Hive::Commands::Init::GlobalPrompts).
+# Runs only on the very first `hive init` on a machine (global config
+# absent). Collects a default agent + model into a `defaults:` block.
+class InitGlobalPromptsTest < Minitest::Test
+  include HiveTestHelper
+
+  def make_global_prompts(input_text, tty: true)
+    input = StringIO.new(input_text)
+    input.define_singleton_method(:tty?) { true } if tty
+    output = StringIO.new
+    summary_io = StringIO.new
+    [
+      Hive::Commands::Init::GlobalPrompts.new(input: input, output: output, summary_io: summary_io),
+      output, summary_io
+    ]
+  end
+
+  def with_isolated_home(home_env: nil)
+    Dir.mktmpdir("hive-gp") do |home|
+      old_home = ENV["HOME"]
+      old_hive = ENV["HIVE_HOME"]
+      ENV["HOME"] = home
+      home_env ? ENV["HIVE_HOME"] = home_env : ENV.delete("HIVE_HOME")
+      yield home
+    ensure
+      ENV["HOME"] = old_home
+      old_hive.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old_hive
+    end
+  end
+
+  def test_non_tty_writes_defaults_and_summary
+    prompts, _output, summary_io = make_global_prompts("", tty: false)
+    answers = prompts.collect
+    assert_equal "claude", answers["agent"]
+    assert_equal "claude-sonnet-4", answers["model"]
+    assert_match(/hive: global defaults — agent=claude, model=claude-sonnet-4/, summary_io.string)
+  end
+
+  def test_interactive_all_defaults
+    prompts, _output, _summary_io = make_global_prompts("\n\n")
+    answers = prompts.collect
+    assert_equal "claude", answers["agent"]
+    assert_equal "claude-sonnet-4", answers["model"]
+  end
+
+  def test_interactive_agent_by_name_and_custom_model
+    prompts, _output, _summary_io = make_global_prompts("codex\ngpt-5\n")
+    answers = prompts.collect
+    assert_equal "codex", answers["agent"]
+    assert_equal "gpt-5", answers["model"]
+  end
+
+  def test_interactive_agent_by_index
+    prompts, _output, _summary_io = make_global_prompts("2\n\n")
+    answers = prompts.collect
+    assert_equal "codex", answers["agent"]
+  end
+
+  def test_interactive_unknown_agent_reprompts
+    prompts, _output, _summary_io = make_global_prompts("bogus\npi\n\n")
+    answers = prompts.collect
+    assert_equal "pi", answers["agent"]
+  end
+
+  def test_eof_mid_prompt_raises_aborted
+    prompts, _output, _summary_io = make_global_prompts("")
+    # TTY input with no data → first read_line gets nil → Aborted.
+    input = StringIO.new
+    input.define_singleton_method(:tty?) { true }
+    prompts = Hive::Commands::Init::GlobalPrompts.new(
+      input: input, output: StringIO.new, summary_io: StringIO.new
+    )
+    assert_raises(Hive::Commands::Init::Prompts::Aborted) { prompts.collect }
+  end
+
+  def test_first_run_true_when_xdg_absent_and_no_legacy
+    with_isolated_home do
+      assert Hive::Commands::Init::GlobalPrompts.first_run?(
+        Hive::Config.global_config_path
+      )
+    end
+  end
+
+  def test_first_run_false_when_xdg_exists
+    with_isolated_home do |home|
+      FileUtils.mkdir_p(File.join(home, ".config", "hive"))
+      File.write(Hive::Config.global_config_path, { "registered_projects" => [] }.to_yaml)
+      refute Hive::Commands::Init::GlobalPrompts.first_run?(
+        Hive::Config.global_config_path
+      )
+    end
+  end
+
+  def test_first_run_false_when_legacy_dev_config_exists
+    with_isolated_home do |home|
+      legacy = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy)
+      File.write(File.join(legacy, "config.yml"), { "registered_projects" => [] }.to_yaml)
+      refute Hive::Commands::Init::GlobalPrompts.first_run?(
+        Hive::Config.global_config_path
+      )
+    end
+  end
+
+  def test_first_run_false_when_hive_home_override_set
+    with_isolated_home(home_env: "/custom/hive") do
+      refute Hive::Commands::Init::GlobalPrompts.first_run?(
+        Hive::Config.global_config_path
+      )
+    end
+  end
+
+  def test_write_first_run_global_config_writes_defaults_block
+    with_isolated_home do |home|
+      Hive::Config.write_first_run_global_config!(agent: "codex", model: "gpt-5")
+      path = Hive::Config.global_config_path
+      assert File.exist?(path)
+      data = YAML.safe_load(File.read(path))
+      assert_equal "codex", data.dig("defaults", "agent")
+      assert_equal "gpt-5", data.dig("defaults", "model")
+      assert_equal [], data["registered_projects"]
+    end
+  end
+end
