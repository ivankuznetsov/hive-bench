--- a/Rakefile
+++ b/Rakefile
@@ -1,4 +1,7 @@
 require "rake/testtask"
+require "shellwords"
+require "fileutils"
+require "hive"
 
 # Default suite — everything under test/{unit,integration}. Self-contained,
 # uses fake-claude / fake-gh, no network or paid API calls.
@@ -45,4 +48,57 @@ task :e2e do
   ruby "bin/hive-e2e", "run"
 end
 
+# --- Packaging (U1 of the install plan) ---
+# Build a self-contained, vendored-Ruby binary per tier-1 target via Tebako,
+# tar it with the share/ assets, compute SHA256, and (in CI) upload to the
+# GitHub Release created from the tag. The Tebako feasibility spike for
+# the bubbletea/lipgloss FFI native libs (install-plan Risk #1) MUST pass
+# before these tasks are wired into the release workflow's `build` job.
+TIER1_TARGETS = %w[macos-arm64 linux-x86_64 linux-aarch64].freeze
+
+namespace :package do
+  desc "Build a Tebako binary for TARGET (e.g. rake package:tebako[linux-x86_64])"
+  task :tebako, [:target] do |_t, args|
+    target = args[:target] || ENV.fetch("HIVE_PACKAGE_TARGET", "linux-x86_64")
+    require "fileutils"
+    version = Hive::VERSION
+    stage = File.expand_path("dist/#{target}", Dir.pwd)
+    FileUtils.rm_rf(stage)
+    FileUtils.mkdir_p(stage)
+    # Tebako packages Ruby 3.4 + locked Gemfile.lock gems + bin/hive into
+    # one binary. The entry point is a generated wrapper that execs the
+    # bundled bin/hive. See packaging/tebako/README.md for the full recipe
+    # + the FFI native-lib spike.
+    sh "packaging/tebako/build.sh #{target} #{version} #{stage.shellescape}"
+    # Bundle the shared assets (templates/ schemas/ examples/) so a packaged
+    # install finds them via Hive::Paths.resolve_asset without a checkout.
+    FileUtils.cp_r("templates", File.join(stage, "share", "templates"))
+    FileUtils.cp_r("schemas",   File.join(stage, "share", "schemas"))
+    File.write(File.join(stage, "README.install"),
+               "Hive #{version} (#{target})\nSee packaging/install.sh.\n")
+    tarball = "hive-#{version}-#{target.tr('_', '-')}.tar.gz"
+    Dir.chdir("dist") { sh "tar -czf #{tarball} -C #{target} hive share README.install" }
+    puts "built dist/#{tarball}"
+  end
+
+  desc "Build all tier-1 targets (macos-arm64 linux-x86_64 linux-aarch64)"
+  task tier1: TIER1_TARGETS.map { |t| ["tebako", t] } do
+    Rake::Task["package:checksums"].invoke
+  end
+
+  desc "Compute sha256sums.txt for every tarball under dist/"
+  task :checksums do
+    sh "packaging/checksums.sh dist"
+  end
+
+  desc "Smoke-test a built binary in a clean docker (no system Ruby)"
+  task :smoke, [:target] do |_t, args|
+    target = args[:target] || "linux-x86_64"
+    version = Hive::VERSION
+    tarball = "hive-#{version}-#{target.tr('_', '-')}.tar.gz"
+    sh "docker run --rm -v \"#{Dir.pwd}/dist:/dist\" ubuntu:22.04 " \
+       "bash -c 'tar -xzf /dist/#{tarball} -C /tmp && /tmp/hive --version && /tmp/hive doctor --deps'"
+  end
+end
+
 task default: :test
