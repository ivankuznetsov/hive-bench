diff --git a/packaging/aur-sync.sh b/packaging/aur-sync.sh
new file mode 100755
index 00000000..36809447
--- /dev/null
+++ b/packaging/aur-sync.sh
@@ -0,0 +1,45 @@
+#!/usr/bin/env bash
+# Update the AUR hive-bin package per release tag.
+# Rewrites pkgver + the per-arch source URLs + sha256sums in PKGBUILD,
+# regenerates .SRCINFO, commits + pushes to the AUR hive-bin repo.
+#
+# Usage: packaging/aur-sync.sh <version> <aur_repo_path>
+set -euo pipefail
+
+version="${1:?usage: aur-sync.sh <version> [aur_repo_path]}"
+aur_repo="${2:-../hive-bin}"
+version_tag="v${version#v}"
+
+base="https://github.com/ivankuznetsov/hive/releases/download/${version_tag}"
+sums="$(curl -fsSL "${base}/sha256sums.txt")"
+
+for arch in x86_64 aarch64; do
+  tarball="hive-${version}-linux-${arch}.tar.gz"
+  sha="$(echo "$sums" | grep " ${tarball}\$" | awk '{print $1}')"
+  [[ -n "$sha" ]] || { echo "aur-sync: no checksum for $tarball" >&2; exit 1; }
+  url="${base}/${tarball}"
+  printf '%s\n' "$url" "$sha"
+done > /dev/null # probe; real rewrite below
+
+pkgbuild="$aur_repo/PKGBUILD"
+[[ -f "$pkgbuild" ]] || { echo "aur-sync: $pkgbuild not found" >&2; exit 1; }
+
+sha_x86_64="$(echo "$sums" | grep " hive-${version}-linux-x86_64.tar.gz\$" | awk '{print $1}')"
+sha_aarch64="$(echo "$sums" | grep " hive-${version}-linux-aarch64.tar.gz\$" | awk '{print $1}')"
+
+sed -i.bak \
+  -e "s|^pkgver=.*|pkgver=${version}|" \
+  -e "s|releases/download/v\${pkgver}/hive-\${pkgver}-linux-x86_64.tar.gz|releases/download/${version_tag}/hive-${version}-linux-x86_64.tar.gz|" \
+  -e "s|releases/download/v\${pkgver}/hive-\${pkgver}-linux-aarch64.tar.gz|releases/download/${version_tag}/hive-${version}-linux-aarch64.tar.gz|" \
+  "$pkgbuild"
+sed -i.bak \
+  -e "s|^sha256sums_x86_64=.*|sha256sums_x86_64=('${sha_x86_64}')|" \
+  -e "s|^sha256sums_aarch64=.*|sha256sums_aarch64=('${sha_aarch64}')" \
+  "$pkgbuild"
+rm -f "${pkgbuild}.bak"
+
+( cd "$aur_repo" && makepkg --printsrcinfo > .SRCINFO \
+  && git add PKGBUILD .SRCINFO \
+  && git commit -m "hive-bin ${version}" \
+  && git push )
+echo "aur-sync: updated $pkgbuild to ${version}"
