+require "test_helper"
+require "fileutils"
+require "hive/paths"
+require "hive/config"
+
+class HivePathsTest < Minitest::Test
+  include HiveTestHelper
+
+  def with_isolated_home(home_env: nil, xdg: {})
+    Dir.mktmpdir("hive-paths") do |home|
+      old_home = ENV["HOME"]
+      old_hive_home = ENV["HIVE_HOME"]
+      old_xcfg = ENV["XDG_CONFIG_HOME"]
+      old_xstate = ENV["XDG_STATE_HOME"]
+      old_xcache = ENV["XDG_CACHE_HOME"]
+      old_xdata = ENV["XDG_DATA_HOME"]
+      ENV["HOME"] = home
+      if home_env
+        ENV["HIVE_HOME"] = home_env
+      else
+        ENV.delete("HIVE_HOME")
+      end
+      xdg.each { |k, v| ENV[k] = v }
+      yield home
+    ensure
+      ENV["HOME"] = old_home
+      old_hive_home.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old_hive_home
+      old_xcfg.nil? ? ENV.delete("XDG_CONFIG_HOME") : ENV["XDG_CONFIG_HOME"] = old_xcfg
+      old_xstate.nil? ? ENV.delete("XDG_STATE_HOME") : ENV["XDG_STATE_HOME"] = old_xstate
+      old_xcache.nil? ? ENV.delete("XDG_CACHE_HOME") : ENV["XDG_CACHE_HOME"] = old_xcache
+      old_xdata.nil? ? ENV.delete("XDG_DATA_HOME") : ENV["XDG_DATA_HOME"] = old_xdata
+    end
+  end
+
+  def test_hive_home_override_wins_over_xdg
+    with_isolated_home(home_env: "/custom/hive") do
+      assert_equal "/custom/hive", Hive::Paths.config_dir
+      assert_equal "/custom/hive", Hive::Paths.state_dir
+      assert_equal "/custom/hive", Hive::Paths.share_dir
+      assert Hive::Paths.hive_home_override?
+    end
+  end
+
+  def test_xdg_defaults_when_hive_home_unset
+    with_isolated_home do |home|
+      refute Hive::Paths.hive_home_override?
+      assert_equal File.join(home, ".config", "hive"), Hive::Paths.config_dir
+      assert_equal File.join(home, ".local", "state", "hive"), Hive::Paths.state_dir
+      assert_equal File.join(home, ".cache", "hive"), Hive::Paths.cache_dir
+      assert_equal File.join(home, ".local", "share", "hive"), Hive::Paths.share_dir
+    end
+  end
+
+  def test_xdg_env_vars_honoured
+    with_isolated_home(xdg: { "XDG_CONFIG_HOME" => "/cfg",
+                              "XDG_STATE_HOME" => "/st",
+                              "XDG_CACHE_HOME" => "/ca",
+                              "XDG_DATA_HOME" => "/da" }) do
+      assert_equal "/cfg/hive", Hive::Paths.config_dir
+      assert_equal "/st/hive", Hive::Paths.state_dir
+      assert_equal "/ca/hive", Hive::Paths.cache_dir
+      assert_equal "/da/hive", Hive::Paths.share_dir
+    end
+  end
+
+  def test_daemon_and_bot_pid_log_paths_use_state_dir
+    with_isolated_home do |home|
+      assert_equal File.join(home, ".local", "state", "hive", ".daemon.pid"),
+                   Hive::Paths.daemon_pid_file
+      assert_equal File.join(home, ".local", "state", "hive", "logs", "daemon.log"),
+                   Hive::Paths.daemon_log_file
+      assert_equal File.join(home, ".local", "state", "hive", ".bot.pid"),
+                   Hive::Paths.bot_pid_file
+      assert_equal File.join(home, ".local", "state", "hive", "logs", "bot.log"),
+                   Hive::Paths.bot_log_file
+    end
+  end
+
+  def test_runtime_home_equals_state_dir_without_hive_home
+    with_isolated_home do |home|
+      assert_equal Hive::Paths.state_dir, Hive::Paths.runtime_home
+    end
+  end
+
+  def test_runtime_home_equals_hive_home_when_override_set
+    with_isolated_home(home_env: "/custom/hive") do
+      assert_equal "/custom/hive", Hive::Paths.runtime_home
+    end
+  end
+
+  def test_resolve_asset_finds_in_repo_template_fallback
+    with_isolated_home do
+      path = Hive::Paths.resolve_asset("templates/idea.md.erb")
+      assert File.exist?(path), "expected fallback in-repo template to exist at #{path}"
+      assert_match(/idea\.md\.erb\z/, path)
+    end
+  end
+
+  def test_resolve_asset_prefers_share_dir_when_present
+    with_isolated_home do |home|
+      share = File.join(home, ".local", "share", "hive")
+      FileUtils.mkdir_p(File.join(share, "templates"))
+      File.write(File.join(share, "templates", "idea.md.erb"), "PACKAGED\n")
+      path = Hive::Paths.resolve_asset("templates/idea.md.erb")
+      assert_equal File.join(share, "templates", "idea.md.erb"), path
+    end
+  end
+
+  # --- Hive::Config integration ---
+
+  def test_global_config_path_uses_hive_home_when_set
+    with_tmp_dir do |dir|
+      old = ENV["HIVE_HOME"]
+      ENV["HIVE_HOME"] = dir
+      begin
+        assert_equal File.join(dir, "config.yml"), Hive::Config.global_config_path
+        assert_equal File.join(dir, "config.yml"), Hive::Config.global_config_read_path
+      ensure
+        old.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old
+      end
+    end
+  end
+
+  def test_global_config_read_path_falls_back_to_legacy_dev_checkout
+    with_isolated_home do |home|
+      # No HIVE_HOME, no XDG config — legacy ~/Dev/hive/config.yml exists.
+      legacy = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy)
+      File.write(File.join(legacy, "config.yml"), { "registered_projects" => [] }.to_yaml)
+
+      assert_equal File.join(home, ".config", "hive", "config.yml"),
+                   Hive::Config.global_config_path
+      assert_equal File.join(home, "Dev", "hive", "config.yml"),
+                   Hive::Config.global_config_read_path
+    end
+  end
+
+  def test_registered_projects_reads_legacy_when_xdg_absent
+    with_isolated_home do |home|
+      legacy = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy)
+      File.write(File.join(legacy, "config.yml"), {
+        "registered_projects" => [
+          { "name" => "demo", "path" => home, "hive_state_path" => File.join(home, ".hive-state") }
+        ]
+      }.to_yaml)
+
+      projects = Hive::Config.registered_projects
+      assert(projects.any? { |p| p["name"] == "demo" },
+             "legacy ~/Dev/hive/config.yml must be read transparently when XDG config absent")
+    end
+  end
+
+  def test_register_project_migrates_legacy_to_xdg_on_first_write
+    with_isolated_home do |home|
+      legacy = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy)
+      legacy_cfg = File.join(legacy, "config.yml")
+      File.write(legacy_cfg, {
+        "registered_projects" => [
+          { "name" => "existing", "path" => File.join(home, "existing"), "hive_state_path" => "x" }
+        ]
+      }.to_yaml)
+
+      # Register a NEW project. This read-modify-writes via the read path
+      # (legacy) and writes to the XDG target → the legacy registry content
+      # is migrated, the new entry is added, and the legacy file is left
+      # intact so a rollback remains possible.
+      Hive::Config.register_project(name: "fresh", path: File.join(home, "fresh"))
+
+      xdg_cfg = File.join(home, ".config", "hive", "config.yml")
+      assert File.exist?(xdg_cfg), "XDG config must be written on first register"
+
+      migrated = YAML.safe_load(File.read(xdg_cfg))
+      names = Array(migrated["registered_projects"]).map { |p| p["name"] }
+      assert_includes names, "existing", "legacy entries must migrate on first write"
+      assert_includes names, "fresh", "new registration must land in the XDG config"
+
+      # Legacy file untouched (rollback safety).
+      legacy_still = YAML.safe_load(File.read(legacy_cfg))
+      assert_equal ["existing"], Array(legacy_still["registered_projects"]).map { |p| p["name"] }
+    end
+  end
+
+  def test_write_global_config_mkdir_p_xdg_dir
+    with_isolated_home do |home|
+      Hive::Config.write_global_config!("registered_projects" => [])
+      xdg_cfg = File.join(home, ".config", "hive", "config.yml")
+      assert File.exist?(xdg_cfg), "write_global_config! must mkdir_p + write the XDG path"
+    end
+  end
+
+  def test_global_bot_defaults_use_state_dir_without_hive_home
+    with_isolated_home do |home|
+      bot = Hive::Config.global_bot_defaults
+      assert_equal File.join(home, ".local", "state", "hive", ".bot.pid"), bot["pid_file"]
+      assert_equal File.join(home, ".local", "state", "hive", "logs", "bot.log"), bot["log_file"]
+      assert_equal File.join(home, ".local", "state", "hive", ".bot.last_seen_update_id"),
+                   bot["last_seen_state_file"]
+    end
+  end
+
+  def test_global_bot_defaults_use_hive_home_when_override_set
+    with_isolated_home(home_env: "/custom/hive") do
+      bot = Hive::Config.global_bot_defaults
+      assert_equal "/custom/hive/.bot.pid", bot["pid_file"]
+      assert_equal "/custom/hive/logs/bot.log", bot["log_file"]
+      assert_equal "/custom/hive/.bot.last_seen_update_id", bot["last_seen_state_file"]
+    end
+  end
+end
diff --git a/test/unit/service_registration_test.rb b/test/unit/service_registration_test.rb
new file mode 100644
index 00000000..738ebf56
--- /dev/null
+++ b/test/unit/service_registration_test.rb
@@ -0,0 +1,136 @@
+require "test_helper"
+require "fileutils"
+require "stringio"
+require "hive/commands/init"
+require "hive/service"
+
+class HiveServiceRegistrationTest < Minitest::Test
+  include HiveTestHelper
+
+  # Fake service module: records calls and writes to a tempdir so the
+  # prompt-gate logic in Init#register_service! can be asserted without
+  # touching real ~/Library or ~/.config, and without invoking
+  # launchctl/systemctl. install_unit! returns the written path; the
+  # init code only calls enable_and_start! when tty? + yes.
+  FakeService = Struct.new(:agents_dir, :unit_path, :enabled) do
+    def initialize(agents_dir:, unit_path: "hive-daemon.service")
+      @agents_dir = agents_dir
+      @unit_path = unit_path
+      @enabled = false
+      @installed_called = 0
+      @enable_called = 0
+    end
+
+    attr_reader :installed_called, :enable_called, :agents_dir
+
+    def install_unit!
+      @installed_called += 1
+      FileUtils.mkdir_p(@agents_dir)
+      path = File.join(@agents_dir, @unit_path)
+      File.write(path, "FAKE UNIT\n")
+      path
+    end
+
+    def enable_and_start!
+      @enable_called += 1
+      @enabled = true
+      true
+    end
+  end
+
+  def setup
+    # The suite-wide escape hatch is set in test_helper; lift it for the
+    # U8 scenarios so register_service! actually runs against the fake.
+    @prev_disable = ENV.delete("HIVE_DISABLE_SERVICE_REGISTER")
+  end
+
+  def teardown
+    ENV["HIVE_DISABLE_SERVICE_REGISTER"] = @prev_disable if @prev_disable
+  end
+
+  def init_with(dir, stdin: StringIO.new, service:, **opts)
+    # Build the Init instance with an injected prompts + service_module so
+    # the interactive flow is deterministic and no real launchctl/systemctl
+    # fires. tty? is driven by the injected stdin's tty? flag.
+    Hive::Commands::Init.new(dir, service_module: service, **opts)
+  end
+
+  def test_non_tty_writes_unit_but_does_not_load
+    with_tmp_global_config do
+      with_tmp_git_repo do |dir|
+        svc = FakeService.new(agents_dir: File.join(dir, "agents"))
+        out, err = capture_io do
+          init_with(dir, stdin: StringIO.new, service: svc).call
+        end
+        assert_equal 1, svc.installed_called, "install_unit! must run on non-TTY"
+        assert_equal 0, svc.enable_called, "enable_and_start! must NOT run on non-TTY"
+        assert_match(/daemon service unit written to/, err)
+        assert_match(/hive daemon start/, err)
+      end
+    end
+  end
+
+  # --- Hive::Service unit-level tests ---
+
+  def test_render_plist_contains_binary_path_and_log_paths
+    plist = Hive::Service.render_plist(
+      bin_path: "/usr/local/bin/hive",
+      state_dir: "/var/lib/hive"
+    )
+    assert_match(%r{/usr/local/bin/hive}, plist)
+    assert_match(%r{<string>daemon</string>}, plist)
+    assert_match(%r{<string>start</string>}, plist)
+    assert_match(%r{/var/lib/hive/logs/hive-daemon\.out\.log}, plist)
+    assert_match(%r{/var/lib/hive/logs/hive-daemon\.err\.log}, plist)
+    assert_match(/local\.hive-daemon/, plist)
+  end
+
+  def test_render_unit_contains_execstart_and_restart
+    unit = Hive::Service.render_unit(
+      bin_path: "/usr/local/bin/hive",
+      state_dir: "/var/lib/hive"
+    )
+    assert_match(/^ExecStart=\/usr\/local\/bin\/hive daemon start/, unit)
+    assert_match(/^Restart=on-failure/, unit)
+    assert_match(/^KillMode=mixed/, unit)
+    assert_match(/StartLimitBurst=3/, unit)
+  end
+
+  def test_install_unit_writes_unit_to_injected_agents_dir_on_linux
+    skip "host is not linux" unless Hive::Service.linux?
+
+    Dir.mktmpdir("hive-svc") do |agents|
+      bin = File.join(agents, "hive")
+      File.write(bin, "#!/bin/sh\nexit 0\n")
+      File.chmod(0o755, bin)
+      state = File.join(agents, "state")
+      path = Hive::Service.install_unit!(
+        agents_dir: agents, state_dir: state, bin_path: bin
+      )
+      assert_equal File.join(agents, "hive-daemon.service"), path
+      assert File.exist?(path)
+      content = File.read(path)
+      assert_match(/ExecStart=/, content)
+      assert_match(%r{#{bin}}, content)
+    end
+  end
+
+  def test_install_unit_returns_nil_when_agents_dir_nil
+    # Simulate an unsupported platform by overriding agents_dir for the
+    # duration of this test only.
+    orig = Hive::Service.method(:agents_dir)
+    Hive::Service.singleton_class.send(:define_method, :agents_dir) { nil }
+    assert_nil Hive::Service.install_unit!
+  ensure
+    Hive::Service.singleton_class.send(:define_method, :agents_dir) { |*a| orig.call(*a) }
+  end
+
+  def test_resolved_binary_path_falls_back_to_local_bin_when_not_executable
+    # $0 in a test is the test file path, so bin_dir resolves to the test
+    # dir; there's no `hive` executable there. The fallback chain should
+    # still return a plausible path (which hive | ~/.local/bin/hive).
+    path = Hive::Service.resolved_binary_path
+    assert path.is_a?(String)
+    assert(!path.empty?, "resolved_binary_path must return a non-empty path")
+  end
+end
