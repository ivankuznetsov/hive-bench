index 00000000..8d471b8a
--- /dev/null
+++ b/.github/workflows/release.yml
@@ -0,0 +1,106 @@
+name: release
+
+# U1 of the install plan — on a pushed `v*` tag, build a self-contained
+# Tebako binary per tier-1 target, tar it with the share/ assets, compute
+# SHA256, and upload to the GitHub Release created from the tag. The `build`
+# job is gated on `rake test` passing first. The bubbletea/lipgloss FFI
+# feasibility spike (packaging/tebako/README.md, Risk #1) MUST pass before
+# this workflow is enabled on a real tag.
+on:
+  push:
+    tags:
+      - "v*"
+  workflow_dispatch:
+    inputs:
+      version:
+        description: "Release version (without leading v)"
+        required: true
+
+permissions:
+  contents: write
+
+jobs:
+  test:
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - run: bundle exec rake test
+
+  build:
+    needs: test
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          - target: macos-arm64
+            runner: macos-14
+          - target: linux-x86_64
+            runner: ubuntu-22.04
+          - target: linux-aarch64
+            runner: ubuntu-22.04
+    runs-on: ${{ matrix.runner }}
+    steps:
+      - uses: actions/checkout@v4
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+
+      # Tebako + native build deps. macOS needs Xcode CLT; Linux needs
+      # build-essential + the glibc portability toolchain (Risk #8).
+      - name: Install build deps (Linux)
+        if: runner.os == 'Linux'
+        run: |
+          sudo apt-get update
+          sudo apt-get install -y build-essential patchelf
+
+      - name: Install tebako
+        run: gem install tebako --no-document
+
+      - name: Build + package binary
+        run: rake "package:tebako[${{ matrix.target }}]"
+
+      - name: Upload tarball artifact
+        uses: actions/upload-artifact@v4
+        with:
+          name: hive-${{ matrix.target }}
+          path: dist/*.tar.gz
+
+  release:
+    needs: build
+    runs-on: ubuntu-latest
+    steps:
+      - uses: actions/checkout@v4
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+
+      - name: Download all tarball artifacts
+        uses: actions/download-artifact@v4
+        with:
+          pattern: hive-*
+          merge-multiple: true
+          path: dist
+
+      - name: Compute checksums
+        run: rake package:checksums
+
+      # Binary smoke: the produced Linux binary must print --version and
+      # `hive doctor --deps` in a clean Ubuntu 22.04 container with no
+      # system Ruby (Risk #8 + the "no system Ruby" goal).
+      - name: Smoke-test linux-x86_64 binary in clean docker
+        run: rake "package:smoke[linux-x86_64]"
+
+      - name: Upload release assets
+        uses: softprops/action-gh-release@v2
+        with:
+          files: |
+            dist/*.tar.gz
+            dist/sha256sums.txt
+            packaging/install.sh
+          generate_release_notes: true
