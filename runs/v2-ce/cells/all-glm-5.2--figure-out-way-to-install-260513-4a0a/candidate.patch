+++ b/test/unit/commands/uninstall_test.rb
@@ -0,0 +1,207 @@
+require "test_helper"
+require "stringio"
+require "fileutils"
+require "json"
+require "hive/commands/uninstall"
+
+class HiveCommandsUninstallTest < Minitest::Test
+  include HiveTestHelper
+
+  # Self-contained fake shell (same shape as update_test's) so this file
+  # can run standalone.
+  class FakeShell
+    def initialize(responses); @responses = responses; end
+
+    def call(argv)
+      key = argv.join(" ")
+      entry = @responses[key]
+      return [ "", "command not found", FakeStatus.new(false) ] unless entry
+
+      [ entry[:out].to_s, entry[:err].to_s, FakeStatus.new(entry[:ok]) ]
+    end
+  end
+
+  class FakeStatus
+    def initialize(ok); @ok = ok; end
+    def success?; @ok; end
+  end
+
+  def recorded_runner
+    runs = []
+    runner = ->(argv) { runs << argv; true }
+    [ runner, runs ]
+  end
+
+  def fake_service(removed: [])
+    Module.new.tap do |m|
+      m.define_singleton_method(:uninstall_unit!) { removed << :unit; true }
+    end
+  end
+
+  def test_brew_channel_dispatches_brew_uninstall
+    runner, runs = recorded_runner
+    svc = fake_service
+    cmd = Hive::Commands::Uninstall.new(
+      purge: true, channel: :brew, shell: FakeShell.new({}),
+      runner: runner, service_module: svc, io: StringIO.new
+    )
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a[0..2] == %w[brew uninstall hive] }, runs.inspect)
+  end
+
+  def test_aur_channel_dispatches_yay_Rns
+    runner, runs = recorded_runner
+    shell = FakeShell.new("which yay" => { out: "/usr/bin/yay", ok: true })
+    cmd = Hive::Commands::Uninstall.new(
+      purge: true, channel: :aur, shell: shell,
+      runner: runner, service_module: fake_service, io: StringIO.new
+    )
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a == %w[yay -Rns hive-bin] }, runs.inspect)
+  end
+
+  def test_bash_channel_dispatches_one_liner_uninstall
+    runner, runs = recorded_runner
+    cmd = Hive::Commands::Uninstall.new(
+      purge: true, channel: :bash, shell: FakeShell.new({}),
+      runner: runner, service_module: fake_service, io: StringIO.new
+    )
+    assert_equal 0, cmd.call
+    assert(runs.any? { |a| a[0] == "bash" && a[1] == "-c" && a[2].include?("--uninstall") },
+           "bash one-liner must pass --uninstall; got #{runs.inspect}")
+  end
+
+  def test_unknown_channel_prints_help_and_exits_nonzero
+    runner, runs = recorded_runner
+    out = StringIO.new
+    cmd = Hive::Commands::Uninstall.new(
+      channel: :unknown, shell: FakeShell.new({}),
+      runner: runner, service_module: fake_service, io: out
+    )
+    assert_equal 1, cmd.call
+    assert_match(/could not detect the install channel/, out.string)
+    assert(runs.empty?, "unknown channel must NOT run any native uninstaller; got #{runs.inspect}")
+  end
+
+  def test_purge_removes_global_config_but_preserves_state_and_project_work
+    with_isolated_home do |home|
+      # Seed global config, global state, project .hive-state.
+      FileUtils.mkdir_p(File.join(home, ".config", "hive"))
+      File.write(Hive::Config.global_config_path, { "registered_projects" => [] }.to_yaml)
+      state_dir = Hive::Paths.state_dir
+      FileUtils.mkdir_p(state_dir)
+      File.write(File.join(state_dir, "bot.pid"), "12345")
+      proj_state = File.join(home, "myproj", ".hive-state", "stages", "4-execute")
+      FileUtils.mkdir_p(File.join(proj_state, "task-1"))
+      File.write(File.join(proj_state, "task-1", "work.md"), "user work")
+
+      runner, _runs = recorded_runner
+      out = StringIO.new
+      cmd = Hive::Commands::Uninstall.new(
+        purge: true, channel: :bash, shell: FakeShell.new({}),
+        runner: runner, service_module: fake_service, io: out
+      )
+      assert_equal 0, cmd.call
+
+      refute File.exist?(Hive::Config.global_config_path), "global config must be removed under --purge"
+      # State/cache preserved under --purge.
+      assert File.exist?(File.join(state_dir, "bot.pid")), "accumulated state must survive --purge"
+      # Project .hive-state/ preserved.
+      assert File.exist?(File.join(proj_state, "task-1", "work.md")),
+             "project .hive-state/ work must survive --purge"
+    end
+  end
+
+  def test_purge_removes_service_registration
+    runner, _runs = recorded_runner
+    removed = []
+    svc = Module.new
+    svc.define_singleton_method(:uninstall_unit!) { removed << :unit; true }
+    cmd = Hive::Commands::Uninstall.new(
+      purge: true, channel: :brew, shell: FakeShell.new({}),
+      runner: runner, service_module: svc, io: StringIO.new
+    )
+    cmd.call
+    assert_equal [:unit], removed, "--purge must remove service registration"
+  end
+
+  def test_non_tty_without_purge_runs_native_uninstall_only
+    with_isolated_home do |home|
+      FileUtils.mkdir_p(File.join(home, ".config", "hive"))
+      File.write(Hive::Config.global_config_path, { "registered_projects" => [] }.to_yaml)
+      runner, _runs = recorded_runner
+      out = StringIO.new
+      cmd = Hive::Commands::Uninstall.new(
+        purge: false, channel: :brew, shell: FakeShell.new({}),
+        runner: runner, service_module: fake_service, io: out
+      )
+      # Non-TTY, no --purge, no --yes → destructive scopes declined.
+      assert_equal 0, cmd.call
+      assert File.exist?(Hive::Config.global_config_path),
+             "global config must be preserved when not prompted yes / not purge"
+    end
+  end
+
+  def test_yes_flag_assumes_yes_to_all_prompts
+    with_isolated_home do |home|
+      FileUtils.mkdir_p(File.join(home, ".config", "hive"))
+      File.write(Hive::Config.global_config_path, { "registered_projects" => [] }.to_yaml)
+      state_dir = Hive::Paths.state_dir
+      FileUtils.mkdir_p(state_dir)
+      File.write(File.join(state_dir, "daemon.log"), "log")
+
+      runner, _runs = recorded_runner
+      cmd = Hive::Commands::Uninstall.new(
+        purge: false, yes: true, channel: :brew, shell: FakeShell.new({}),
+        runner: runner, service_module: fake_service, io: StringIO.new
+      )
+      assert_equal 0, cmd.call
+      refute File.exist?(Hive::Config.global_config_path), "--yes must remove global config"
+      refute File.exist?(File.join(state_dir, "daemon.log")), "--yes must remove state/cache"
+    end
+  end
+
+  def test_never_touches_agent_skill_dirs
+    with_isolated_home do |home|
+      claude_dir = File.join(home, ".claude", "commands")
+      FileUtils.mkdir_p(claude_dir)
+      File.write(File.join(claude_dir, "plan.md"), "skill")
+      runner, _runs = recorded_runner
+      cmd = Hive::Commands::Uninstall.new(
+        purge: true, yes: true, channel: :brew, shell: FakeShell.new({}),
+        runner: runner, service_module: fake_service, io: StringIO.new
+      )
+      cmd.call
+      assert File.exist?(File.join(claude_dir, "plan.md")),
+             "~/.claude/ skill dirs must NEVER be touched by hive uninstall"
+    end
+  end
+
+  def test_json_summary_envelope_shape
+    runner, _runs = recorded_runner
+    out = StringIO.new
+    cmd = Hive::Commands::Uninstall.new(
+      purge: true, channel: :brew, shell: FakeShell.new({}),
+      runner: runner, service_module: fake_service, io: out, json: true
+    )
+    assert_equal 0, cmd.call
+    payload = JSON.parse(out.string)
+    assert_equal "brew", payload["channel"]
+    assert(payload["ok"], "envelope ok must be true for a known channel")
+    assert_equal false, payload["removed"]["project_hive_state"]
+    assert_equal false, payload["removed"]["agent_skill_dirs"]
+  end
+
+  def with_isolated_home(home_env: nil)
+    Dir.mktmpdir("hive-uninst") do |home|
+      old_home = ENV["HOME"]
+      old_hive = ENV["HIVE_HOME"]
+      ENV["HOME"] = home
+      home_env ? ENV["HIVE_HOME"] = home_env : ENV.delete("HIVE_HOME")
+      yield home
+    ensure
+      ENV["HOME"] = old_home
+      old_hive.nil? ? ENV.delete("HIVE_HOME") : ENV["HIVE_HOME"] = old_hive
+    end
+  end
+end
