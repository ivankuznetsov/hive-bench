index 00000000..bc590e9b
--- /dev/null
+++ b/lib/hive/commands/uninstall.rb
@@ -0,0 +1,208 @@
+require "fileutils"
+require "json"
+require "open3"
+require "hive"
+require "hive/config"
+require "hive/install_channel"
+require "hive/paths"
+
+module Hive
+  module Commands
+    # `hive uninstall` (U7 of the install plan) — removes the hive binary
+    # and daemon registration via the detected channel's NATIVE uninstaller,
+    # prompts before touching any operator-scoped content, and NEVER deletes
+    # user work or completed pipeline state — even with --purge. Skills are
+    # removed via each agent's marketplace, not here.
+    #
+    # Scope matrix:
+    #   binary + daemon registration   → channel-native uninstall always
+    #                                     (or --purge removes registration)
+    #   global config (~/.config/hive) → --purge OR (TTY + yes)
+    #   global state/cache             → TTY + yes ONLY (never --purge:
+    #                                     preserves accumulated pipeline output)
+    #   per-project .hive-state/      → NEVER (user work)
+    #   legacy ~/Dev/hive checkout     → NEVER (user's source)
+    #   ~/.claude/ ~/.codex/ ~/.pi/    → NEVER (skills removed via marketplace)
+    #
+    # Exit codes: 0 success; 1 unknown channel or native uninstaller failed.
+    class Uninstall
+      def initialize(purge: false, yes: false, channel: nil,
+                     shell: default_shell, marker_file: Hive::InstallChannel.default_marker_file,
+                     runner: nil, service_module: nil, io: $stdout, json: false)
+        @purge = purge
+        @yes = yes
+        @channel = channel
+        @shell = shell
+        @marker_file = marker_file
+        @runner = runner || method(:run_command)
+        @service_module = service_module
+        @io = io
+        @json = json
+      end
+
+      def call
+        channel = @channel || Hive::InstallChannel.detect(shell: @shell, marker_file: @marker_file)
+
+        if channel == :unknown
+          emit_unknown_help
+          return 1
+        end
+
+        # 1. Channel-native binary uninstall (inverse of the install channel).
+        native_ok = dispatch_channel_uninstall(channel)
+
+        # 2. Daemon service registration removal.
+        removed_registration = remove_service_registration(@purge || prompt?("Remove the hive daemon service registration?"))
+
+        # 3. Global config removal.
+        remove_config = @purge || prompt?("Remove the global hive config (~/.config/hive)?")
+        removed_config = remove_global_config! if remove_config
+
+        # 4. Global state/cache removal — TTY prompt only, NEVER --purge
+        #    (preserve accumulated pipeline output even under --purge).
+        removed_state = false
+        if !@purge && prompt?("Remove global hive state + cache (~/.local/state/hive, ~/.cache/hive)?")
+          removed_state = remove_state_and_cache!
+        end
+
+        emit_summary(channel: channel, native_ok: native_ok,
+                     removed_registration: removed_registration,
+                     removed_config: removed_config,
+                     removed_state: removed_state)
+        0
+      end
+
+      private
+
+      def dispatch_channel_uninstall(channel)
+        argv = case channel
+               when :brew then %w[brew uninstall hive]
+               when :aur  then aur_uninstall_argv
+               when :bash then ["bash", "-c",
+                               "curl -fsSL https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh | bash -s -- --uninstall"]
+               end
+        @runner.call(argv)
+      end
+
+      def aur_uninstall_argv
+        _out, _err, status = @shell.call(["which", "yay"])
+        return %w[yay -Rns hive-bin] if status.success?
+
+        _out, _err, status = @shell.call(["which", "paru"])
+        return %w[paru -Rns hive-bin] if status.success?
+
+        %w[yay -Rns hive-bin]
+      end
+
+      def remove_service_registration(should)
+        return false unless should
+
+        require "hive/service" unless @service_module
+        svc = @service_module || Hive::Service
+        svc.uninstall_unit!
+        true
+      rescue StandardError
+        false
+      end
+
+      def remove_global_config!
+        cfg = Hive::Config.global_config_path
+        return false unless File.exist?(cfg)
+
+        File.delete(cfg)
+        true
+      rescue StandardError
+        false
+      end
+
+      def remove_state_and_cache!
+        removed = false
+        [Hive::Paths.state_dir, Hive::Paths.cache_dir].each do |dir|
+          next unless File.directory?(dir)
+          # NEVER touch per-project .hive-state/. These XDG dirs are global
+          # runtime files only (daemon/bot pid+logs, last-seen, caches).
+          FileUtils.rm_rf(dir)
+          removed = true
+        end
+        removed
+      rescue StandardError
+        false
+      end
+
+      def prompt?(message)
+        return @yes if @yes
+        return false unless tty?
+
+        $stderr.print "#{message} [y/N]: "
+        $stderr.flush
+        answer = $stdin.gets
+        return false if answer.nil?
+
+        answer = answer.chomp.strip.downcase
+        answer == "y" || answer == "yes"
+      end
+
+      def tty?
+        $stdin.respond_to?(:tty?) && $stdin.tty?
+      end
+
+      def emit_unknown_help
+        msg = <<~MSG
+          hive: could not detect the install channel, so the native uninstaller can't run.
+            Homebrew:   brew uninstall hive
+            AUR:        yay -Rns hive-bin
+            One-liner:  re-run packaging/install.sh --uninstall
+            The daemon service unit (~/.config/systemd/user/hive-daemon.service or
+            ~/Library/LaunchAgents/local.hive-daemon.plist) and ~/.config/hive/config.yml
+            can be removed manually.
+            Skills installed via agent marketplaces are removed through those marketplaces.
+        MSG
+        @json ? emit_json_unknown : @io.puts(msg)
+      end
+
+      def emit_json_unknown
+        @io.puts JSON.generate("ok" => false, "channel" => "unknown", "result" => "unknown_channel")
+      end
+
+      def emit_summary(channel:, native_ok:, removed_registration:, removed_config:, removed_state:)
+        if @json
+          payload = {
+            "ok" => true,
+            "channel" => channel.to_s,
+            "native_uninstall" => native_ok ? "ran" : "failed",
+            "removed" => {
+              "service_registration" => removed_registration,
+              "global_config" => removed_config,
+              "global_state_cache" => removed_state,
+              "project_hive_state" => false,
+              "agent_skill_dirs" => false
+            }
+          }
+          @io.puts JSON.generate(payload)
+          return
+        end
+
+        @io.puts "hive: uninstall via #{Hive::InstallChannel.name(channel)} (#{native_ok ? 'ok' : 'native uninstaller reported failure'})"
+        @io.puts "  removed:"
+        @io.puts "    binary (channel-native)"
+        @io.puts "    daemon service registration" if removed_registration
+        @io.puts "    global config (~/.config/hive)" if removed_config
+        @io.puts "    global state + cache" if removed_state
+        @io.puts "  preserved (user work):"
+        @io.puts "    per-project .hive-state/ — never touched"
+        @io.puts "    accumulated pipeline state (~/.local/state/hive) #{'— preserved under --purge' if @purge}"
+        @io.puts "    legacy ~/Dev/hive checkout"
+        @io.puts "    ~/.claude/ ~/.codex/ ~/.pi/ — skills removed via each agent's marketplace"
+        @io.puts "  next: remove hive skills through each agent's marketplace add/remove command."
+      end
+
+      def default_shell
+        ->(argv) { Open3.capture3(*argv) }
+      end
+
+      def run_command(argv)
+        system(*argv, out: $stdout, err: $stderr)
+      end
+    end
+  end
+end
