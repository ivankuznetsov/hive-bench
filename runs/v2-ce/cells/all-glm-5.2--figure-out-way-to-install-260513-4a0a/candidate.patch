index 00000000..0de585f4
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,190 @@
+require "open3"
+require "json"
+require "net/http"
+require "uri"
+require "hive"
+require "hive/install_channel"
+
+module Hive
+  module Commands
+    # `hive update` (U6 of the install plan) — detects the install channel
+    # and shells out to that channel's NATIVE updater. Never swaps the
+    # binary in place (an in-place swap is fragile across channels and
+    # bypasses the package manager's bookkeeping). After the native updater
+    # finishes, re-prints `hive --version` for confirmation.
+    #
+    # `--check` prints the latest available GitHub release tag vs. the
+    # installed version WITHOUT upgrading (queries the GitHub Releases API).
+    #
+    # Exit codes: 0 success / up-to-date; 1 the channel is unknown or the
+    # native updater failed; 70 internal error (e.g. network).
+    class Update
+      REPO = "ivankuznetsov/hive".freeze
+      RELEASES_API = "https://api.github.com/repos/#{REPO}/releases/latest".freeze
+
+      def initialize(channel: nil, shell: default_shell, marker_file: Hive::InstallChannel.default_marker_file,
+                   json: false, output: $stdout, runner: nil)
+        @channel = channel
+        @shell = shell
+        @marker_file = marker_file
+        @json = json
+        @output = output
+        @runner = runner || method(:run_command)
+      end
+
+      def call
+        channel = @channel || Hive::InstallChannel.detect(shell: @shell, marker_file: @marker_file)
+
+        if channel == :unknown
+          emit_unknown_help
+          return 1
+        end
+
+        if @json
+          emit_json(channel: channel, action: "update", result: "dispatched")
+        else
+          @output.puts "hive: detected install channel — #{Hive::InstallChannel.name(channel)}"
+        end
+        dispatch(channel)
+        0
+      end
+
+      # `--check`: query the GitHub Releases API for the latest tag and
+      # compare against Hive::VERSION. No upgrade is performed. Returns 0
+      # (prints the comparison) — never exits non-zero on a network error
+      # so an agent caller can fall back to `hive update` directly; the
+      # error surfaces in the printed message.
+      def check
+        latest = fetch_latest_tag
+        if latest.nil?
+          @output.puts "hive: could not reach GitHub Releases API to check for updates; " \
+                       "see https://github.com/#{REPO}/releases"
+          return 1
+        end
+        installed = Hive::VERSION
+        cmp = compare_versions(installed, latest)
+        if @json
+          emit_json(channel: @channel || Hive::InstallChannel.detect(shell: @shell, marker_file: @marker_file),
+                    action: "check", result: cmp, latest: latest, installed: installed)
+        elsif cmp == :up_to_date
+          @output.puts "hive: up to date (#{installed})"
+        else
+          @output.puts "hive: #{cmp} — installed #{installed}, latest #{latest}"
+        end
+        0
+      end
+
+      private
+
+      def dispatch(channel)
+        case channel
+        when :brew
+          @runner.call(["brew", "upgrade", "hive"])
+        when :aur
+          updater = aur_updater
+          @runner.call([updater, "-Syu", "hive-bin"])
+        when :bash
+          @runner.call(bash_update_argv)
+        end
+        re_print_version
+      end
+
+      def aur_updater
+        _out, _err, status = @shell.call(["which", "yay"])
+        return "yay" if status.success?
+
+        _out, _err, status = @shell.call(["which", "paru"])
+        return "paru" if status.success?
+
+        "yay"
+      end
+
+      # The bash one-liner channel re-runs the pinned install.sh for the
+      # latest release tag. The install URL is fixed per release; the
+      # updater just re-downloads + re-verifies, which upgrades in place
+      # (the native-updater path for this channel, per the plan).
+      def bash_update_argv
+        ["bash", "-c",
+         "curl -fsSL https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh | bash"]
+      end
+
+      def re_print_version
+        @output.puts "hive: now at #{`hive --version`.strip}"
+      rescue StandardError
+        # `hive --version` may not be on PATH if the updater moved the
+        # binary; don't crash the update itself.
+        nil
+      end
+
+      def emit_unknown_help
+        msg = <<~MSG
+          hive: could not detect the install channel.
+            If you installed via Homebrew:        brew upgrade hive
+            If you installed via AUR:            yay -Syu hive-bin
+            If you installed via the one-liner:  re-run the curl|bash installer
+            Otherwise reinstall from https://github.com/#{REPO}/releases
+        MSG
+        if @json
+          emit_json(channel: :unknown, action: "update", result: "unknown_channel")
+        else
+          @output.puts msg
+        end
+      end
+
+      def emit_json(channel:, action:, result:, latest: nil, installed: nil)
+        payload = {
+          "ok" => result != "unknown_channel",
+          "channel" => channel.to_s,
+          "action" => action,
+          "result" => result.to_s,
+          "installed" => installed || Hive::VERSION
+        }
+        payload["latest"] = latest if latest
+        @output.puts JSON.generate(payload)
+      end
+
+      def fetch_latest_tag
+        uri = URI(RELEASES_API)
+        req = Net::HTTP::Get.new(uri)
+        req["Accept"] = "application/vnd.github+json"
+        req["User-Agent"] = "hive/#{Hive::VERSION}"
+        http = Net::HTTP.new(uri.hostname, uri.port)
+        http.use_ssl = uri.scheme == "https"
+        http.read_timeout = 10
+        http.open_timeout = 10
+        response = http.request(req)
+        return nil unless response.is_a?(Net::HTTPSuccess)
+
+        data = JSON.parse(response.body)
+        tag = data["tag_name"]
+        tag&.sub(/\Av/i, "")
+      rescue StandardError
+        nil
+      end
+
+      # Returns :up_to_date, :behind, or :ahead.
+      def compare_versions(installed, latest)
+        i = version_tuple(installed)
+        l = version_tuple(latest)
+        cmp = (i <=> l) || 0
+        return :up_to_date if cmp == 0
+        return :ahead if cmp.positive?
+
+        :behind
+      end
+
+      def version_tuple(v)
+        v.to_s.sub(/\Av/i, "").split(".").map { |part| part.to_i }
+      end
+
+      def default_shell
+        ->(argv) { Open3.capture3(*argv) }
+      end
+
+      def run_command(argv)
+        # Real subprocess dispatch for production. Tests inject @runner.
+        system(*argv, out: $stdout, err: $stderr)
+      end
+    end
+  end
+end
