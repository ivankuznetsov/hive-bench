diff --git a/lib/hive/install_channel.rb b/lib/hive/install_channel.rb
new file mode 100644
index 00000000..408344c0
--- /dev/null
+++ b/lib/hive/install_channel.rb
@@ -0,0 +1,76 @@
+require "open3"
+
+module Hive
+  # `Hive::InstallChannel` — detects how hive was installed so `hive update`
+  # (U6) and `hive uninstall` (U7) can shell out to the channel-native
+  # updater/uninstaller instead of swapping the binary in place.
+  #
+  # Detection order (first match wins):
+  #   1. :bash  — a marker file written by packaging/install.sh at
+  #               ~/.local/share/hive/CHANNEL (content: "bash"). The
+  #               curl|bash one-liner is the only channel that needs a
+  #               durable marker; brew/pacman own their DB rows.
+  #   2. :brew  — `brew list --versions hive` succeeds.
+  #   3. :aur   — `pacman -Q hive-bin` succeeds.
+  #   4. :unknown — nothing matched; `hive update`/`uninstall` print a
+  #               help message and exit non-zero rather than guess.
+  #
+  # All subprocess probes are injectable via `shell:` (a callable returning
+  # [stdout, stderr, status] for a given argv Array) so unit tests don't
+  # depend on brew/pacman being installed. The marker path is injectable
+  # via `marker_file:` for the same reason.
+  module InstallChannel
+    BASH_MARKER_CONTENT = "bash".freeze
+    MARKER_RELATIVE_PATH = File.join(".local", "share", "hive", "CHANNEL").freeze
+
+    module_function
+
+    def default_marker_file
+      File.expand_path("~/#{MARKER_RELATIVE_PATH}")
+    end
+
+    # Returns :brew, :aur, :bash, or :unknown.
+    def detect(shell: default_shell, marker_file: default_marker_file)
+      return :bash if bash_marker?(marker_file)
+
+      return :brew if brew_installed?(shell)
+      return :aur  if aur_installed?(shell)
+
+      :unknown
+    end
+
+    # Human-readable channel name for help text.
+    def name(channel)
+      case channel
+      when :brew    then "Homebrew (brew install <org>/hive/hive)"
+      when :aur     then "AUR (yay -S hive-bin)"
+      when :bash    then "curl|bash one-liner (packaging/install.sh)"
+      when :unknown then "unknown (not via brew / AUR / the official one-liner)"
+      end
+    end
+
+    def bash_marker?(marker_file = default_marker_file)
+      return false unless File.exist?(marker_file)
+
+      File.read(marker_file).strip == BASH_MARKER_CONTENT
+    end
+
+    def brew_installed?(shell = default_shell)
+      out, _err, status = shell.call(["brew", "list", "--versions", "hive"])
+      status.success? && !out.to_s.strip.empty?
+    rescue StandardError
+      false
+    end
+
+    def aur_installed?(shell = default_shell)
+      _out, _err, status = shell.call(["pacman", "-Q", "hive-bin"])
+      status.success?
+    rescue StandardError
+      false
+    end
+
+    def default_shell
+      ->(argv) { Open3.capture3(*argv) }
+    end
+  end
+end
diff --git a/lib/hive/paths.rb b/lib/hive/paths.rb
new file mode 100644
index 00000000..c30694d5
--- /dev/null
+++ b/lib/hive/paths.rb
@@ -0,0 +1,190 @@
+require "fileutils"
+
+module Hive
+  # `Hive::Paths` — centralised on-disk location resolver for an installable
+  # Hive package.
+  #
+  # Historically every global path was hardcoded under `~/Dev/hive/` (the
+  # git-clone install root, surfaced via `Hive::Config.hive_home` / the
+  # `HIVE_HOME` env var). That model breaks the moment Hive ships as a
+  # packaged binary (Tebako / Homebrew / AUR / `curl|bash`): there is no
+  # `~/Dev/hive` checkout on a packaged install, so the global config, the
+  # daemon/bot PID + log files, the bot's last-seen-update-id pointer, and
+  # the shared asset tree (templates/ schemas/ examples/) all need XDG
+  # homes instead.
+  #
+  # Resolution rules (U2 of the install plan):
+  #
+  #   * `HIVE_HOME` is honoured as an override for development checkouts.
+  #     When set, every Paths method that has a legacy `~/Dev/hive`
+  #     meaning returns the HIVE_HOME-rooted path instead. This keeps the
+  #     maintainer's checkout, the test suite (which sets HIVE_HOME to a
+  #     tmpdir), and any existing operator who pinned HIVE_HOME working
+  #     byte-for-byte as before.
+  #
+  #   * When HIVE_HOME is unset, the canonical XDG locations apply:
+  #       config_dir    ~ XDG_CONFIG_HOME/hive  (default ~/.config/hive)
+  #       state_dir     ~ XDG_STATE_HOME/hive   (default ~/.local/state/hive)
+  #       cache_dir     ~ XDG_CACHE_HOME/hive   (default ~/.cache/hive)
+  #       share_dir     ~ XDG_DATA_HOME/hive    (default ~/.local/share/hive)
+  #
+  #   * Shared assets (templates/ schemas/ examples/) resolve in order:
+  #       (1) alongside the running binary (<bindir>/../share/hive/) — the
+  #           Tebako / Homebrew / AUR install layout;
+  #       (2) Hive::Paths.share_dir — the `curl|bash` install layout;
+  #       (3) ~/Dev/hive/ (or $HIVE_HOME) — the dev checkout;
+  #       (4) lib/../templates/ — the in-repo fallback, which is what
+  #           every existing test and the dev checkout actually hit.
+  #
+  # The legacy `~/Dev/hive/config.yml` is read transparently when the XDG
+  # config is absent (see `Hive::Config.global_config_read_path`); the
+  # first write lazily migrates it to the XDG location. See
+  # [[modules/paths]] and the U2 plan unit.
+  module Paths
+    module_function
+
+    # The legacy dev-checkout root. `HIVE_HOME` overrides this for
+    # maintainers who keep the clone somewhere other than `~/Dev/hive`.
+    # Returns nil-ish sentinel via `hive_home` when neither is set so
+    # callers can branch (legacy read-back-compat vs. XDG write target).
+    def legacy_dev_root
+      File.expand_path("~/Dev/hive")
+    end
+
+    # True when HIVE_HOME is explicitly set (non-empty). Every Paths method
+    # that has a legacy ~/Dev/hive meaning honours HIVE_HOME first when
+    # this is true, preserving the dev-checkout + test-suite behaviour.
+    def hive_home_override?
+      env = ENV["HIVE_HOME"]
+      !env.nil? && !env.empty?
+    end
+
+    # The HIVE_HOME override, or the legacy `~/Dev/hive` default. Returns
+    # the same value `Hive::Config.hive_home` always returned — kept here
+    # as the single source of truth for the legacy/dev root so config.rb
+    # and paths.rb agree. Callers that need the "XDG-or-HIVE_HOME" choice
+    # branch on `hive_home_override?` and read this for the override value.
+    def hive_home
+      ENV["HIVE_HOME"].nil? || ENV["HIVE_HOME"].empty? ? legacy_dev_root : ENV["HIVE_HOME"]
+    end
+
+    def xdg_config_home
+      ENV["XDG_CONFIG_HOME"].nil? || ENV["XDG_CONFIG_HOME"].empty? ? File.expand_path("~/.config") : ENV["XDG_CONFIG_HOME"]
+    end
+
+    def xdg_state_home
+      ENV["XDG_STATE_HOME"].nil? || ENV["XDG_STATE_HOME"].empty? ? File.expand_path("~/.local/state") : ENV["XDG_STATE_HOME"]
+    end
+
+    def xdg_cache_home
+      ENV["XDG_CACHE_HOME"].nil? || ENV["XDG_CACHE_HOME"].empty? ? File.expand_path("~/.cache") : ENV["XDG_CACHE_HOME"]
+    end
+
+    def xdg_data_home
+      ENV["XDG_DATA_HOME"].nil? || ENV["XDG_DATA_HOME"].empty? ? File.expand_path("~/.local/share") : ENV["XDG_DATA_HOME"]
+    end
+
+    # Global config directory. When HIVE_HOME is set (dev / tests / pinned
+    # operator), returns HIVE_HOME so the existing `~/Dev/hive/config.yml`
+    # read/write path keeps working. Otherwise the XDG config home.
+    def config_dir
+      hive_home_override? ? hive_home : File.join(xdg_config_home, "hive")
+    end
+
+    # State directory — daemon/bot PID files, logs, and the bot's
+    # last-seen-update-id pointer live here on a packaged install. HIVE_HOME
+    # override honoured so the daemon/bot tests (which point HIVE_HOME at a
+    # tmpdir) keep writing PID/log files exactly where they always did.
+    def state_dir
+      hive_home_override? ? hive_home : File.join(xdg_state_home, "hive")
+    end
+
+    def cache_dir
+      hive_home_override? ? File.join(hive_home, "cache") : File.join(xdg_cache_home, "hive")
+    end
+
+    # Shared, read-only assets (templates/, schemas/, examples/). On a
+    # packaged install this is the XDG data home; on a dev checkout it's
+    # the HIVE_HOME root (so `~/Dev/hive/templates/...` keeps resolving).
+    def share_dir
+      hive_home_override? ? hive_home : File.join(xdg_data_home, "hive")
+    end
+
+    # The directory containing the running `hive` binary. Used to locate
+    # the `<bindir>/../share/hive/` asset layout shipped by the Tebako /
+    # Homebrew / AUR packages. Resolved from `$0` when it looks like a
+    # real file path; falls back to `~/.local/bin` (the `curl|bash`
+    # install target) so the share-dir probe has a sane default.
+    def bin_dir
+      exe = $0
+      if exe && !exe.empty? && !exe.start_with?("(") && File.exist?(exe)
+        File.dirname(File.expand_path(exe))
+      else
+        File.expand_path("~/.local/bin")
+      end
+    end
+
+    # Daemon PID + log paths. HIVE_HOME honoured (tests + dev); otherwise
+    # the XDG state dir. Centralised so `Hive::Commands::Daemon` and any
+    # future caller agree on the same location.
+    def daemon_pid_file
+      File.join(state_dir, ".daemon.pid")
+    end
+
+    def daemon_log_file
+      File.join(state_dir, "logs", "daemon.log")
+    end
+
+    def bot_pid_file
+      File.join(state_dir, ".bot.pid")
+    end
+
+    def bot_log_file
+      File.join(state_dir, "logs", "bot.log")
+    end
+
+    def bot_last_seen_state_file
+      File.join(state_dir, ".bot.last_seen_update_id")
+    end
+
+    # Runtime home for the daemon/bot commands — the directory under
+    # which PID/log/last-seen files are rooted. HIVE_HOME honoured so the
+    # daemon/bot test isolation (which sets HIVE_HOME to a tmpdir) keeps
+    # working without touching real ~/.local/state. Identical to
+    # `Hive::Config.hive_home` when HIVE_HOME is set; otherwise the XDG
+    # state dir.
+    def runtime_home
+      state_dir
+    end
+
+    # Resolve a shared asset (e.g. `templates/project_config.yml.erb`,
+    # `schemas/hive-status.v2.json`) to an absolute path. Probes
+    # candidates in install-layout order and returns the first existing
+    # one; if none exist, returns the last candidate (the in-repo
+    # `lib/../<name>` fallback) so the caller's `File.read` raises the
+    # usual Errno::ENOENT — matching the pre-Paths behaviour for missing
+    # built-in templates.
+    #
+    # `name` is relative to the asset root: pass `templates/foo.md.erb`
+    # or `schemas/bar.json`, not a bare basename.
+    def resolve_asset(name)
+      candidates = asset_candidates(name)
+      candidates.find { |p| File.exist?(p) } || candidates.last
+    end
+
+    # Ordered candidate roots for `resolve_asset`. Exposed for tests so
+    # the probe order is assertable without poking the filesystem.
+    def asset_roots
+      [
+        File.join(bin_dir, "..", "share", "hive"),
+        share_dir,
+        (hive_home_override? ? hive_home : legacy_dev_root),
+        File.expand_path("../../", __dir__)
+      ]
+    end
+
+    def asset_candidates(name)
+      asset_roots.map { |root| File.expand_path(name, root) }
+    end
+  end
+end
diff --git a/lib/hive/service.rb b/lib/hive/service.rb
new file mode 100644
index 00000000..6505c369
--- /dev/null
+++ b/lib/hive/service.rb
@@ -0,0 +1,207 @@
+require "erb"
+require "fileutils"
+require "open3"
+require "rbconfig"
+require "hive"
+
+module Hive
+  # `Hive::Service` — daemon service registration (launchd on macOS,
+  # systemd --user on Linux) for `hive init` (U8 of the install plan).
+  #
+  # `hive init` calls `Service.register` after the existing init steps.
+  # The plist/unit is rendered to the per-user agents directory using the
+  # actually-installed binary path (resolved via `Hive::Paths.bin_dir`),
+  # NOT a hardcoded `~/Dev/hive/bin/hive`. Then the operator is prompted
+  # (TTY only) whether to enable + start it now — never silent autostart,
+  # never install-disabled-by-default. On non-TTY the unit file is written
+  # but NOT loaded/enabled, matching the existing `Init::Prompts` non-TTY
+  # contract (a one-line hint is printed).
+  #
+  # The existing `hive daemon start/stop/status` verbs continue to work
+  # for manual control; this module only adds optional OS-level
+  # supervision so the daemon survives logout/reboot.
+  #
+  # See [[commands/init]], [[commands/daemon]], ADR-024.
+  module Service
+    module_function
+
+    LABEL = "local.hive-daemon".freeze
+    UNIT_NAME = "hive-daemon".freeze
+
+    # The platform-appropriate per-user agents directory. macOS:
+    # ~/Library/LaunchAgents. Linux: ~/.config/systemd/user. Returns nil
+    # on any other platform (service registration is a no-op there).
+    def agents_dir
+      case RbConfig::CONFIG["host_os"]
+      when /darwin/i then File.expand_path("~/Library/LaunchAgents")
+      when /linux/i  then File.expand_path("~/.config/systemd/user")
+      else nil
+      end
+    end
+
+    def macos?
+      RbConfig::CONFIG["host_os"].match?(/darwin/i)
+    end
+
+    def linux?
+      RbConfig::CONFIG["host_os"].match?(/linux/i)
+    end
+
+    # Absolute path to the `hive` binary that the service should invoke.
+    # Resolved from `Hive::Paths.bin_dir` (which honours $0 when it's a
+    # real file) and verified executable; falls back to a `which hive`
+    # lookup; final fallback is `~/.local/bin/hive` (the curl|bash
+    # install target) so the rendered unit at least names a plausible
+    # path the operator can edit. Never returns a `~/Dev/hive/bin/hive`
+    # default — that path doesn't exist on a packaged install.
+    def resolved_binary_path
+      candidate = File.join(Hive::Paths.bin_dir, "hive")
+      return candidate if File.executable?(candidate)
+
+      which = begin
+        out, _err, status = Open3.capture3("which", "hive")
+        status.success? && !out.strip.empty? ? out.strip : nil
+      rescue StandardError
+        nil
+      end
+      return which if which && File.executable?(which)
+
+      File.expand_path("~/.local/bin/hive")
+    end
+
+    # Render + write the plist/unit file for the current platform.
+    # Returns the written file path, or nil when the platform is
+    # unsupported (agents_dir nil). Does NOT load/enable — that's the
+    # prompt-gated step in `enable_and_start!`.
+    #
+    # `state_dir:` / `bin_path:` are injectable for tests so a test can
+    # point the plist at a tempdir without touching real ~/Library or
+    # $PATH.
+    def install_unit!(agents_dir: nil, state_dir: nil, bin_path: nil)
+      dir = agents_dir || Service.agents_dir
+      return nil unless dir
+
+      bin = bin_path || resolved_binary_path
+      state = state_dir || Hive::Paths.state_dir
+      FileUtils.mkdir_p(dir)
+      if macos?
+        path = File.join(dir, "local.hive-daemon.plist")
+        File.write(path, render_plist(bin_path: bin, state_dir: state))
+      else
+        path = File.join(dir, "hive-daemon.service")
+        File.write(path, render_unit(bin_path: bin, state_dir: state))
+      end
+      path
+    end
+
+    # Load + enable + start the just-written unit. Only call after
+    # `install_unit!` and only when the operator answered yes (TTY) —
+    # this is the "option c" prompt gate from the plan. Non-TTY callers
+    # MUST NOT call this (they call `install_unit!` only and print the
+    # `hive daemon start` hint). Returns true if the supervisor command
+    # was actually invoked (regardless of exit status), false when the
+    # platform is unsupported.
+    def enable_and_start!
+      return false unless macos? || linux?
+
+      if macos?
+        # launchctl load registers + starts (RunAtLoad=true). Best-effort:
+        # a non-zero launchctl exit surfaces as a falsey return but does
+        # NOT raise — the daemon can still be started manually via
+        # `hive daemon start`.
+        _out, _err, status = Open3.capture3("launchctl", "load", plist_path)
+        status.success?
+      else
+        _out, _err, status = Open3.capture3(
+          "systemctl", "--user", "daemon-reload"
+        )
+        _out, _err, status = Open3.capture3(
+          "systemctl", "--user", "enable", "--now", UNIT_NAME
+        )
+        status.success?
+      end
+    end
+
+    def plist_path
+      File.join(File.expand_path("~/Library/LaunchAgents"), "local.hive-daemon.plist")
+    end
+
+    def unit_path
+      File.join(File.expand_path("~/.config/systemd/user"), "hive-daemon.service")
+    end
+
+    # Inverse of install_unit!: best-effort unload/stop the service and
+    # delete the rendered plist/unit file. Used by `hive uninstall` (U7).
+    # Never raises — a missing file or a failed launchctl/systemctl is
+    # logged by the caller, not fatal (the file removal is the guarantee).
+    def uninstall_unit!
+      if macos?
+        path = plist_path
+        _out, _err, _status = Open3.capture3("launchctl", "unload", path)
+      elsif linux?
+        path = unit_path
+        _out, _err, _status = Open3.capture3("systemctl", "--user", "disable", "--now", UNIT_NAME)
+      else
+        return nil
+      end
+      File.delete(path) if path && File.exist?(path)
+      path
+    rescue StandardError
+      nil
+    end
+
+    # --- renderers ---
+
+    def render_plist(bin_path:, state_dir:)
+      template = File.read(Hive::Paths.resolve_asset("templates/service/hive-daemon.plist.erb"))
+      binding = PlistBinding.new(bin_path: bin_path, state_dir: state_dir, log_dir: File.join(state_dir, "logs"))
+      ERB.new(template, trim_mode: "-").result(binding.binding_for_erb)
+    end
+
+    def render_unit(bin_path:, state_dir:)
+      template = File.read(Hive::Paths.resolve_asset("templates/service/hive-daemon.service.erb"))
+      binding = UnitBinding.new(bin_path: bin_path, state_dir: state_dir, log_dir: File.join(state_dir, "logs"))
+      ERB.new(template, trim_mode: "-").result(binding.binding_for_erb)
+    end
+
+    class PlistBinding
+      def initialize(bin_path:, state_dir:, log_dir:)
+        @bin_path = bin_path
+        @state_dir = state_dir
+        @log_dir = log_dir
+        @label = Hive::Service::LABEL
+        @version = Hive::VERSION
+        @path = [ bin_path, File.dirname(bin_path), "/usr/local/bin", "/usr/bin", "/bin" ].uniq.join(":")
+      end
+
+      attr_reader :bin_path, :state_dir, :log_dir, :label, :version, :path
+
+      def out_log
+        File.join(@log_dir, "hive-daemon.out.log")
+      end
+
+      def err_log
+        File.join(@log_dir, "hive-daemon.err.log")
+      end
+
+      def binding_for_erb
+        binding
+      end
+    end
+
+    class UnitBinding
+      def initialize(bin_path:, state_dir:, log_dir:)
+        @bin_path = bin_path
+        @state_dir = state_dir
+        @log_dir = log_dir
+        @version = Hive::VERSION
+      end
+
+      attr_reader :bin_path, :state_dir, :log_dir, :version
+
+      def binding_for_erb
+        binding
+      end
+    end
+  end
+end
