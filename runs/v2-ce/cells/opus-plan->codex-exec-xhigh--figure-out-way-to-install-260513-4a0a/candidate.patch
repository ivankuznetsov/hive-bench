new file mode 100644
index 00000000..6845107d
--- /dev/null
+++ b/test/unit/commands/uninstall_test.rb
@@ -0,0 +1,206 @@
+require "test_helper"
+require "stringio"
+require "hive/commands/uninstall"
+
+class HiveCommandsUninstallTest < Minitest::Test
+  include HiveTestHelper
+
+  def tty_input(text)
+    io = StringIO.new(text)
+    io.define_singleton_method(:tty?) { true }
+    io
+  end
+
+  def test_brew_channel_shells_out_to_brew_uninstall
+    calls = []
+
+    Hive::Commands::Uninstall.new(
+      channel: "brew",
+      executor: ->(*cmd) { calls << cmd; true },
+      output: StringIO.new
+    ).call
+
+    assert_equal [ [ "brew", "uninstall", "ivankuznetsov/hive/hive" ] ], calls
+  end
+
+  def test_bash_channel_removes_recorded_bin_link_and_preserves_state_dir
+    with_tmp_global_config do |home|
+      bin_dir = File.join(home, "bin")
+      bundle_dir = File.join(home, "bundle")
+      FileUtils.mkdir_p([ bin_dir, bundle_dir ])
+      target = File.join(bundle_dir, "hive")
+      link = File.join(bin_dir, "hive")
+      File.write(target, "#!/usr/bin/env bash\n")
+      File.chmod(0o755, target)
+      File.symlink(target, link)
+      File.write(File.join(home, "install-channel"), "bash\n")
+      File.write(File.join(home, "install-bin"), "#{link}\n")
+      state_file = File.join(Hive::Config.state_dir, "kept-work")
+      File.write(state_file, "do not remove")
+
+      Hive::Commands::Uninstall.new(
+        executor: ->(*_cmd) { raise "unexpected shell-out" },
+        output: StringIO.new
+      ).call
+
+      refute File.exist?(link)
+      assert File.exist?(state_file), "uninstall must preserve accumulated state/work artifacts"
+      refute File.exist?(File.join(home, "install-channel"))
+      refute File.exist?(File.join(home, "install-bin"))
+    end
+  end
+
+  def test_bash_channel_without_marker_only_removes_symlink_defaults
+    with_tmp_global_config do |home|
+      local_bin = File.join(home, ".local", "bin")
+      FileUtils.mkdir_p(local_bin)
+      # An unrelated, non-symlink user script that merely mentions "hive"
+      # must NOT be content-sniffed and deleted.
+      user_script = File.join(local_bin, "hive")
+      File.write(user_script, "#!/usr/bin/env bash\n# my own hive helper\n")
+      File.chmod(0o755, user_script)
+
+      with_env("HOME" => home) do
+        Hive::Commands::Uninstall.new(
+          channel: "bash",
+          executor: ->(*_cmd) { raise "unexpected shell-out" },
+          output: StringIO.new
+        ).call
+      end
+
+      assert File.exist?(user_script), "must not delete an arbitrary non-symlink user script"
+    end
+  end
+
+  def test_bash_channel_removes_recorded_non_symlink_hardcopy
+    with_tmp_global_config do |home|
+      bin_dir = File.join(home, "bin")
+      FileUtils.mkdir_p(bin_dir)
+      # A de-referenced launcher hardcopy whose first line has no "hive".
+      hardcopy = File.join(bin_dir, "hive")
+      File.write(hardcopy, "#!/usr/bin/env bash\nexec ruby\n")
+      File.chmod(0o755, hardcopy)
+      File.write(File.join(home, "install-channel"), "bash\n")
+      File.write(File.join(home, "install-bin"), "#{hardcopy}\n")
+
+      Hive::Commands::Uninstall.new(
+        executor: ->(*_cmd) { raise "unexpected shell-out" },
+        output: StringIO.new
+      ).call
+
+      refute File.exist?(hardcopy), "recorded install-bin path must be removed regardless of type"
+    end
+  end
+
+  def test_reads_channel_from_bundle_root_marker
+    with_tmp_global_config do |home|
+      bundle_root = File.join(home, "bundle")
+      FileUtils.mkdir_p(bundle_root)
+      File.write(File.join(bundle_root, "INSTALL-CHANNEL"), "brew\n")
+      calls = []
+
+      with_env("HIVE_BUNDLE_ROOT" => bundle_root) do
+        Hive::Commands::Uninstall.new(
+          executor: ->(*cmd) { calls << cmd; true },
+          output: StringIO.new
+        ).call
+      end
+
+      assert_equal [ [ "brew", "uninstall", "ivankuznetsov/hive/hive" ] ], calls
+    end
+  end
+
