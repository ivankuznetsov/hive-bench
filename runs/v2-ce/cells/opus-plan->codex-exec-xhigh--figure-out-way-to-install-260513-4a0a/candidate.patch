diff --git a/lib/hive/commands/uninstall.rb b/lib/hive/commands/uninstall.rb
new file mode 100644
index 00000000..4dc6982d
--- /dev/null
+++ b/lib/hive/commands/uninstall.rb
@@ -0,0 +1,138 @@
+require "fileutils"
+require "hive/config"
+require "hive/service"
+require "hive/commands/update"
+
+module Hive
+  module Commands
+    class Uninstall
+      BREW_FORMULA = Hive::Commands::Update::BREW_FORMULA
+      AUR_PACKAGE = Hive::Commands::Update::AUR_PACKAGE
+      KNOWN_CHANNELS = Hive::Commands::Update::KNOWN_CHANNELS
+
+      def initialize(purge: false, channel: nil, executor: nil, input: $stdin, output: $stdout)
+        @purge = purge
+        @channel = channel
+        @executor = executor || method(:system)
+        @input = input
+        @output = output
+      end
+
+      def call
+        teardown_service
+        remove_project_dot_hive
+        uninstall_channel
+      end
+
+      private
+
+      def install_channel
+        return normalize_channel(@channel) unless @channel.nil? || @channel.to_s.empty?
+
+        path = Hive::Config.install_channel_path
+        return normalize_channel(File.read(path)) if File.exist?(path)
+
+        # brew/aur (and the bash installer) write the channel into the
+        # bundle-root INSTALL-CHANNEL, reachable at runtime via
+        # HIVE_BUNDLE_ROOT. Mirror update.rb so packaged uninstalls detect
+        # the channel even when the XDG marker is absent or points at a
+        # legacy data dir.
+        bundle_marker = ENV["HIVE_BUNDLE_ROOT"] && File.join(ENV["HIVE_BUNDLE_ROOT"], "INSTALL-CHANNEL")
+        return normalize_channel(File.read(bundle_marker)) if bundle_marker && File.exist?(bundle_marker)
+
+        "source"
+      end
+
+      def normalize_channel(value)
+        channel = value.to_s.strip
+        KNOWN_CHANNELS.include?(channel) ? channel : "source"
+      end
+
+      def uninstall_channel
+        case install_channel
+        when "brew"
+          run!("brew", "uninstall", BREW_FORMULA)
+        when "aur"
+          run!("yay", "-Rns", AUR_PACKAGE)
+        when "bash"
+          remove_bash_link
+          remove_install_markers
+        else
+          @output.puts "hive uninstall: source checkout detected; remove the checkout manually if desired"
+        end
+      end
+
+      def remove_bash_link
+        recorded = read_marker(Hive::Config.install_bin_path)
+        if recorded
+          # The recorded path is exactly what install.sh created, so we own
+          # it and remove it regardless of whether it is a symlink or a
+          # de-referenced hardcopy of the launcher.
+          remove_entry(recorded)
+        else
+          # No marker: fall back to the default install locations, but only
+          # touch symlinks. Never content-sniff and delete an arbitrary
+          # regular file a user may have placed on PATH themselves.
+          [ File.expand_path("~/.local/bin/hive"), File.expand_path("~/.local/bin/hv") ].each do |candidate|
+            remove_entry(candidate) if File.symlink?(candidate)
+          end
+        end
+      end
+
+      def remove_entry(path)
+        return unless File.symlink?(path) || File.file?(path)
+
+        FileUtils.rm_f(path)
+        if File.exist?(path)
+          @output.puts "warning: could not remove #{path}"
+        else
+          @output.puts "removed #{path}"
+        end
+      end
+
+      def remove_install_markers
+        FileUtils.rm_f(Hive::Config.install_channel_path)
+        FileUtils.rm_f(Hive::Config.install_bin_path)
+      end
+
+      def remove_project_dot_hive
+        path = File.join(Dir.pwd, ".hive")
+        return unless File.directory?(path)
+
+        if @purge || confirm?("Remove project .hive directory at #{path}? [y/N] ")
+          FileUtils.rm_rf(path)
+          @output.puts "removed #{path}"
+        else
+          @output.puts "kept #{path}"
+        end
+      end
+
+      def confirm?(prompt)
+        return false unless @input.respond_to?(:tty?) && @input.tty?
+
+        @output.print(prompt)
+        @output.flush if @output.respond_to?(:flush)
+        answer = @input.gets.to_s.strip.downcase
+        answer == "y" || answer == "yes"
+      end
+
+      def teardown_service
+        # Gate on Service.supported? rather than swallowing LoadError — a
+        # packaging regression that drops hive/service should surface, not
+        # silently skip daemon teardown and orphan a registered unit.
+        return unless Hive::Service.supported?
+
+        Hive::Service.teardown(output: @output)
+      end
+
+      def read_marker(path)
+        File.exist?(path) ? File.read(path).strip : nil
+      end
+
+      def run!(*cmd)
+        ok = @executor.call(*cmd)
+        raise Hive::Error, "uninstall command failed: #{cmd.join(' ')}" unless ok
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/update.rb b/lib/hive/commands/update.rb
new file mode 100644
index 00000000..00638bc0
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,63 @@
+require "fileutils"
+require "hive/config"
+
+module Hive
+  module Commands
+    class Update
+      BREW_FORMULA = "ivankuznetsov/hive/hive".freeze
+      AUR_PACKAGE = "hive-bin".freeze
+      INSTALLER_URL = "https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh".freeze
+      # The complete set of channel markers the installers ever write. A
+      # value outside this set (corrupted/stale marker) is treated as
+      # "source" rather than silently driving `brew`/`yay`.
+      KNOWN_CHANNELS = %w[brew aur bash source].freeze
+
+      def initialize(channel: nil, executor: nil, output: $stdout)
+        @channel = channel
+        @executor = executor || method(:system)
+        @output = output
+      end
+
+      def call
+        case install_channel
+        when "brew"
+          run!("brew", "upgrade", BREW_FORMULA)
+        when "aur"
+          run!("yay", "-Syu", AUR_PACKAGE)
+        when "bash"
+          # `set -o pipefail` so a failed curl (404, truncated, network
+          # down) fails the pipeline instead of being masked by bash's
+          # exit code and reported as a successful no-op update.
+          run!("bash", "-c", "set -o pipefail; curl -fsSL #{INSTALLER_URL} | bash")
+        else
+          @output.puts "hive update: source checkout or unknown install channel"
+          @output.puts "  next: git -C #{Hive::Config.app_root} pull --ff-only && bundle install"
+        end
+      end
+
+      private
+
+      def install_channel
+        return normalize_channel(@channel) unless @channel.nil? || @channel.to_s.empty?
+
+        path = Hive::Config.install_channel_path
+        return normalize_channel(File.read(path)) if File.exist?(path)
+
+        bundle_marker = ENV["HIVE_BUNDLE_ROOT"] && File.join(ENV["HIVE_BUNDLE_ROOT"], "INSTALL-CHANNEL")
+        return normalize_channel(File.read(bundle_marker)) if bundle_marker && File.exist?(bundle_marker)
+
+        "source"
+      end
+
+      def normalize_channel(value)
+        channel = value.to_s.strip
+        KNOWN_CHANNELS.include?(channel) ? channel : "source"
+      end
+
+      def run!(*cmd)
+        ok = @executor.call(*cmd)
+        raise Hive::Error, "update command failed: #{cmd.join(' ')}" unless ok
+      end
+    end
+  end
+end
