diff --git a/lib/hive/runtime_deps.rb b/lib/hive/runtime_deps.rb
new file mode 100644
index 00000000..cf1db5d0
--- /dev/null
+++ b/lib/hive/runtime_deps.rb
@@ -0,0 +1,127 @@
+require "open3"
+require "rbconfig"
+require "rubygems"
+
+require "hive"
+
+module Hive
+  module RuntimeDeps
+    Dep = Struct.new(:name, :command, :args, :min_version, :version_pattern, keyword_init: true)
+
+    DEPS = [
+      Dep.new(name: "git", command: "git", args: [ "--version" ],
+              min_version: Hive::MIN_GIT_VERSION, version_pattern: /(\d+(?:\.\d+)+)/),
+      Dep.new(name: "bash", command: "bash", args: [ "--version" ],
+              min_version: Hive::MIN_BASH_VERSION, version_pattern: /version\s+(\d+(?:\.\d+)+)/i),
+      Dep.new(name: "claude", command: "claude", args: [ "--version" ],
+              min_version: Hive::MIN_CLAUDE_VERSION, version_pattern: /(\d+(?:\.\d+)+)/),
+      Dep.new(name: "gh", command: "gh", args: [ "--version" ],
+              min_version: nil, version_pattern: /(\d+(?:\.\d+)+)/),
+      Dep.new(name: "jq", command: "jq", args: [ "--version" ],
+              min_version: nil, version_pattern: /(\d+(?:\.\d+)+)/)
+    ].freeze
+
+    module_function
+
+    def check_all(env: ENV.to_h)
+      DEPS.map { |dep| check(dep, env: env) }
+    end
+
+    def check(dep, env:)
+      out, err, status = Open3.capture3(env, dep.command, *dep.args)
+      unless status.success?
+        return row(dep, status: "missing", version: nil,
+                        message: "#{dep.command} is not runnable. #{install_hint(dep.name)}")
+      end
+
+      version = parse_version(out, dep.version_pattern)
+      # Only flag "version_too_old" when we actually parsed a version that
+      # is below the minimum. An unparseable `--version` string (the tool
+      # ran fine but its output didn't match our regex) is reported as
+      # present/unknown, not as too-old.
+      if dep.min_version && version && version_too_old?(version, dep.min_version)
+        return row(dep, status: "version_too_old", version: version,
+                        message: "#{dep.name} #{version} is older than #{dep.min_version}. " \
+                                 "#{install_hint(dep.name)}")
+      end
+
+      row(dep, status: "present", version: version, message: "#{dep.name} #{version || 'present'}")
+    rescue Errno::ENOENT
+      row(dep, status: "missing", version: nil, message: "#{dep.command} not found. #{install_hint(dep.name)}")
+    rescue StandardError => e
+      # Distinct from "missing": the tool may well be installed — our
+      # checker itself hit an unexpected error. Conflating this with
+      # "missing" turns a checker bug into a spurious hard failure.
+      row(dep, status: "check_error", version: nil,
+              message: "#{dep.command} check failed: #{e.message}. #{install_hint(dep.name)}")
+    end
+
+    def row(dep, status:, version:, message:)
+      {
+        kind: "runtime_dependency",
+        stage: "runtime",
+        label: "runtime/#{dep.name}",
+        agent: "host",
+        configured_skill: dep.min_version ? "#{dep.name} >= #{dep.min_version}" : dep.name,
+        skill: dep.command,
+        dependency: dep.name,
+        min_version: dep.min_version,
+        version: version,
+        status: status,
+        message: message
+      }
+    end
+
+    def parse_version(output, pattern)
+      match = output.to_s.match(pattern)
+      match && match[1]
+    end
+
+    def version_too_old?(version, min_version)
+      Gem::Version.new(version) < Gem::Version.new(min_version)
+    rescue ArgumentError
+      # Unparseable version string: treat as present/unknown rather than
+      # asserting it is too old (which would mislabel a working tool).
+      false
+    end
+
+    def install_hint(name)
+      hints = {
+        "git" => {
+          macos: "Install with `brew install git`.",
+          arch: "Install with `sudo pacman -S git`.",
+          debian: "Install with `sudo apt install git`."
+        },
+        "bash" => {
+          macos: "Install with `brew install bash`.",
+          arch: "Install with `sudo pacman -S bash`.",
+          debian: "Install with `sudo apt install bash`."
+        },
+        "claude" => {
+          macos: "Install Claude Code from Anthropic's official instructions.",
+          arch: "Install Claude Code from Anthropic's official instructions.",
+          debian: "Install Claude Code from Anthropic's official instructions."
+        },
+        "gh" => {
+          macos: "Install with `brew install gh`.",
+          arch: "Install with `sudo pacman -S github-cli`.",
+          debian: "Install with `sudo apt install gh`."
+        },
+        "jq" => {
+          macos: "Install with `brew install jq`.",
+          arch: "Install with `sudo pacman -S jq`.",
+          debian: "Install with `sudo apt install jq`."
+        }
+      }
+      hints.fetch(name).fetch(os_family)
+    end
+
+    def os_family
+      host = RbConfig::CONFIG.fetch("host_os")
+      return :macos if host.match?(/darwin/)
+      return :arch if File.exist?("/etc/arch-release")
+
+      :debian
+    end
+  end
+end
diff --git a/lib/hive/service.rb b/lib/hive/service.rb
new file mode 100644
index 00000000..5e0294b3
--- /dev/null
+++ b/lib/hive/service.rb
@@ -0,0 +1,188 @@
+require "erb"
+require "fileutils"
+require "open3"
+require "rbconfig"
+require "shellwords"
+
+require "hive/config"
+
+module Hive
+  module Service
+    SYSTEMD_UNIT = "hive-daemon.service".freeze
+    LAUNCHD_LABEL = "com.hive.daemon".freeze
+    LAUNCHD_PLIST = "#{LAUNCHD_LABEL}.plist".freeze
+
+    module_function
+
+    def supported?
+      platform != :unsupported
+    end
+
+    def platform
+      host_os = RbConfig::CONFIG.fetch("host_os")
+      return :macos if host_os.match?(/darwin/)
+      return :linux if host_os.match?(/linux/)
+
+      :unsupported
+    end
+
+    def install(project_root:, hive_bin: default_hive_bin, enable_now: false, output: $stdout, executor: method(:system))
+      case platform
+      when :macos
+        path = write_launchd_plist(project_root: project_root, hive_bin: hive_bin, enable_now: enable_now)
+        output.puts "hive service: registered launchd agent at #{path}"
+        enable(path: path, executor: executor) if enable_now
+        path
+      when :linux
+        path = write_systemd_unit(project_root: project_root, hive_bin: hive_bin)
+        output.puts "hive service: registered systemd user unit at #{path}"
+        enable(path: path, executor: executor) if enable_now
+        path
+      else
+        output.puts "hive service: automatic service registration is not supported on this platform"
+        nil
+      end
+    end
+
+    def enable(path: nil, executor: method(:system))
+      case platform
+      when :macos then enable_launchd(path || launchd_plist_path, executor)
+      when :linux then enable_systemd(executor)
+      end
+    end
+
+    def teardown(output: $stdout, executor: method(:system))
+      case platform
+      when :macos
+        path = launchd_plist_path
+        return unless File.exist?(path)
+
+        # Best-effort removal: even if bootout fails we still delete the
+        # plist, but surface the failure so a still-running daemon isn't
+        # silently reported as "removed".
+        ok = executor.call("launchctl", "bootout", "gui/#{Process.uid}", path)
+        output.puts "hive service: warning: 'launchctl bootout' failed; the daemon may still be running" unless ok
+        FileUtils.rm_f(path)
+        output.puts "hive service: removed launchd agent #{path}"
+      when :linux
+        path = systemd_unit_path
+        return unless File.exist?(path)
+
+        ok = executor.call("systemctl", "--user", "disable", "--now", SYSTEMD_UNIT)
+        output.puts "hive service: warning: 'systemctl --user disable --now' failed; the daemon may still be running" unless ok
+        FileUtils.rm_f(path)
+        executor.call("systemctl", "--user", "daemon-reload")
+        output.puts "hive service: removed systemd user unit #{path}"
+      end
+    end
+
+    def status(executor: Open3.method(:capture3))
+      case platform
+      when :macos
+        out, _err, status = executor.call("launchctl", "print", "gui/#{Process.uid}/#{LAUNCHD_LABEL}")
+        { manager: "launchd", installed: File.exist?(launchd_plist_path), active: status.success?, detail: out.lines.first.to_s.strip }
+      when :linux
+        out, _err, status = executor.call("systemctl", "--user", "is-enabled", SYSTEMD_UNIT)
+        active_out, _active_err, active_status = executor.call("systemctl", "--user", "is-active", SYSTEMD_UNIT)
+        {
+          manager: "systemd",
+          installed: File.exist?(systemd_unit_path),
+          enabled: status.success?,
+          active: active_status.success?,
+          detail: "#{out.strip} #{active_out.strip}".strip
+        }
+      else
+        { manager: "none", installed: false, active: false, detail: "unsupported platform" }
+      end
+    rescue Errno::ENOENT => e
+      { manager: platform.to_s, installed: service_file_installed?, active: false, detail: e.message }
+    end
+
+    def render_systemd(project_root:, hive_bin: default_hive_bin)
+      render_template("hive-daemon.service.erb", binding)
+    end
+
+    def render_launchd(project_root:, hive_bin: default_hive_bin, enable_now: false)
+      render_template("com.hive.daemon.plist.erb", binding)
+    end
+
+    def systemd_unit_path
+      File.join(Dir.home, ".config", "systemd", "user", SYSTEMD_UNIT)
+    end
+
+    def launchd_plist_path
+      File.join(Dir.home, "Library", "LaunchAgents", LAUNCHD_PLIST)
+    end
+
+    def default_hive_bin
+      ENV["HIVE_BIN"] || File.expand_path("../../bin/hive", __dir__)
+    end
+
+    def shell_escape(value)
+      value.to_s.shellescape
+    end
+
+    # systemd does its own command-line parsing and does NOT run ExecStart
+    # through a shell, so shell-style backslash escaping breaks a path with
+    # spaces. Use systemd's own double-quote quoting instead: wrap in "…"
+    # and escape only `"` and `\` inside. Values without whitespace or
+    # quote/backslash characters are emitted bare.
+    def systemd_quote(value)
+      str = value.to_s
+      return str unless str.match?(/[\s"'\\]/)
+
+      inner = str.gsub(/(["\\])/) { "\\#{Regexp.last_match(1)}" }
+      "\"#{inner}\""
+    end
+
+    def xml_escape(value)
+      value.to_s
+           .gsub("&", "&amp;")
+           .gsub("<", "&lt;")
+           .gsub(">", "&gt;")
+           .gsub("\"", "&quot;")
+           .gsub("'", "&apos;")
+    end
+
+    def service_file_installed?
+      case platform
+      when :macos then File.exist?(launchd_plist_path)
+      when :linux then File.exist?(systemd_unit_path)
+      else false
+      end
+    end
+
+    def write_systemd_unit(project_root:, hive_bin:)
+      path = systemd_unit_path
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, render_systemd(project_root: project_root, hive_bin: hive_bin))
+      path
+    end
+
+    def write_launchd_plist(project_root:, hive_bin:, enable_now: false)
+      path = launchd_plist_path
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, render_launchd(project_root: project_root, hive_bin: hive_bin, enable_now: enable_now))
+      path
+    end
+
+    def enable_systemd(executor)
+      run!(executor, "systemctl", "--user", "daemon-reload")
+      run!(executor, "systemctl", "--user", "enable", "--now", SYSTEMD_UNIT)
+    end
+
+    def enable_launchd(path, executor)
+      run!(executor, "launchctl", "bootstrap", "gui/#{Process.uid}", path)
+    end
+
+    def run!(executor, *cmd)
+      ok = executor.call(*cmd)
+      raise Hive::Error, "service command failed: #{cmd.join(' ')}" unless ok
+    end
+
+    def render_template(name, bind)
+      path = File.expand_path("../../packaging/#{name.start_with?('com.') ? 'launchd' : 'systemd'}/#{name}", __dir__)
+      ERB.new(File.read(path), trim_mode: "-").result(bind)
+    end
+  end
+end
