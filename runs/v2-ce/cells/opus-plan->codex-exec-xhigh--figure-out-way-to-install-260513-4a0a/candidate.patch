+++ b/test/unit/runtime_deps_test.rb
@@ -0,0 +1,130 @@
+require "test_helper"
+require "open3"
+require "hive/runtime_deps"
+
+class RuntimeDepsTest < Minitest::Test
+  include HiveTestHelper
+
+  def write_executable(dir, name, output)
+    path = File.join(dir, name)
+    File.write(path, <<~SH)
+      #!/bin/sh
+      echo #{output.shellescape}
+    SH
+    File.chmod(0o755, path)
+  end
+
+  def fake_runtime_bin(versions = {})
+    dir = Dir.mktmpdir("hive-runtime-bin")
+    versions.each { |name, output| write_executable(dir, name, output) }
+    dir
+  end
+
+  def test_all_present_reports_versions
+    bin = fake_runtime_bin(
+      "git" => "git version 2.45.0",
+      "bash" => "GNU bash, version 5.2.0",
+      "claude" => "2.1.118",
+      "gh" => "gh version 2.50.0",
+      "jq" => "jq-1.7"
+    )
+
+    rows = Hive::RuntimeDeps.check_all(env: { "PATH" => bin })
+
+    assert_equal %w[present], rows.map { |r| r[:status] }.uniq
+    assert_equal "2.45.0", rows.find { |r| r[:dependency] == "git" }[:version]
+    assert_equal "2.1.118", rows.find { |r| r[:dependency] == "claude" }[:version]
+  ensure
+    FileUtils.rm_rf(bin) if bin
+  end
+
+  def test_missing_dependency_reports_hint
+    bin = fake_runtime_bin(
+      "git" => "git version 2.45.0",
+      "bash" => "GNU bash, version 5.2.0",
+      "claude" => "2.1.118",
+      "gh" => "gh version 2.50.0"
+    )
+
+    rows = Hive::RuntimeDeps.check_all(env: { "PATH" => bin })
+    jq = rows.find { |r| r[:dependency] == "jq" }
+
+    assert_equal "missing", jq[:status]
+    assert_match(/jq not found|jq is not runnable/, jq[:message])
+    assert_match(/Install/, jq[:message])
+  ensure
+    FileUtils.rm_rf(bin) if bin
+  end
+
+  def test_bash_version_pattern_matches_real_output
+    bin = fake_runtime_bin(
+      "git" => "git version 2.45.0",
+      "bash" => "GNU bash, version 5.2.0(1)-release",
+      "claude" => "2.1.118",
+      "gh" => "gh version 2.50.0",
+      "jq" => "jq-1.7"
+    )
+
+    rows = Hive::RuntimeDeps.check_all(env: { "PATH" => bin })
+    bash = rows.find { |r| r[:dependency] == "bash" }
+
+    assert_equal "present", bash[:status]
+    assert_equal "5.2.0", bash[:version]
+  ensure
+    FileUtils.rm_rf(bin) if bin
+  end
+
+  def test_unparseable_version_reports_present_not_too_old
+    bin = fake_runtime_bin(
+      "git" => "git without a version number",
+      "bash" => "GNU bash, version 5.2.0",
+      "claude" => "2.1.118",
+      "gh" => "gh version 2.50.0",
+      "jq" => "jq-1.7"
+    )
+
+    rows = Hive::RuntimeDeps.check_all(env: { "PATH" => bin })
+    git = rows.find { |r| r[:dependency] == "git" }
+
+    assert_equal "present", git[:status]
+    assert_nil git[:version]
+  ensure
+    FileUtils.rm_rf(bin) if bin
+  end
+
+  def test_version_too_old_helper_treats_unparseable_as_not_too_old
+    refute Hive::RuntimeDeps.version_too_old?("not-a-version", "2.40.0")
+  end
+
+  def test_checker_error_reports_check_error_status
+    dep = Hive::RuntimeDeps::DEPS.find { |d| d.name == "git" }
+    Open3.singleton_class.send(:alias_method, :__orig_capture3, :capture3)
+    Open3.define_singleton_method(:capture3) { |*_a| raise "boom" }
+    begin
+      row = Hive::RuntimeDeps.check(dep, env: {})
+      assert_equal "check_error", row[:status]
+      assert_match(/check failed/, row[:message])
+    ensure
+      Open3.singleton_class.send(:alias_method, :capture3, :__orig_capture3)
+      Open3.singleton_class.send(:remove_method, :__orig_capture3)
+    end
+  end
+
+  def test_version_too_old_reports_minimum
+    bin = fake_runtime_bin(
+      "git" => "git version 2.39.0",
+      "bash" => "GNU bash, version 5.2.0",
+      "claude" => "2.1.118",
+      "gh" => "gh version 2.50.0",
+      "jq" => "jq-1.7"
+    )
+
+    rows = Hive::RuntimeDeps.check_all(env: { "PATH" => bin })
+    git = rows.find { |r| r[:dependency] == "git" }
+
+    assert_equal "version_too_old", git[:status]
+    assert_equal Hive::MIN_GIT_VERSION, git[:min_version]
+  ensure
+    FileUtils.rm_rf(bin) if bin
+  end
+end
