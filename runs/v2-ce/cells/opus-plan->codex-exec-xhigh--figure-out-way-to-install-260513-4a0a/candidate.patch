+name: Release
+
+on:
+  push:
+    tags:
+      - "v*.*.*"
+
+permissions:
+  contents: write
+
+jobs:
+  build:
+    name: bundle ${{ matrix.triple }}
+    runs-on: ${{ matrix.runner }}
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          - triple: macos-arm64
+            runner: macos-14
+          - triple: ubuntu-x86_64
+            runner: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Assert tag matches version
+        run: bundle exec rake package:assert_tag_version
+      - name: Build runtime bundle
+        run: bundle exec rake package
+        env:
+          HIVE_PACKAGE_TRIPLE: ${{ matrix.triple }}
+      - uses: actions/upload-artifact@v4
+        with:
+          name: hive-${{ matrix.triple }}
+          path: |
+            dist/*.tar.gz
+            dist/*.sha256
+
+  build-arch:
+    name: bundle arch-x86_64
+    runs-on: ubuntu-22.04
+    container: archlinux:latest
+    steps:
+      - name: Install build tools
+        run: pacman -Syu --noconfirm base-devel git tar
+      - uses: actions/checkout@v6
+      # setup-ruby installs a self-contained, relocatable Ruby prefix into
+      # the toolcache. We copy THAT into the bundle (via HIVE_RUBY_PREFIX)
+      # rather than the distro's /usr Ruby — copy_ruby_prefix refuses /usr,
+      # and /usr is not relocatable anyway.
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Resolve portable Ruby prefix
+        run: echo "HIVE_RUBY_PREFIX=$(ruby -rrbconfig -e 'print RbConfig::CONFIG[%q(prefix)]')" >> "$GITHUB_ENV"
+      - name: Assert tag matches version
+        run: bundle exec rake package:assert_tag_version
+      - name: Build runtime bundle
+        run: bundle exec rake package
+        env:
+          HIVE_PACKAGE_TRIPLE: arch-x86_64
+      - uses: actions/upload-artifact@v4
+        with:
+          name: hive-arch-x86_64
+          path: |
+            dist/*.tar.gz
+            dist/*.sha256
+
+  smoke:
+    name: no-ruby smoke ${{ matrix.triple }}
+    needs: [build, build-arch]
+    runs-on: ubuntu-22.04
+    container: ${{ matrix.image }}
+    strategy:
+      fail-fast: false
+      matrix:
+        include:
+          - triple: ubuntu-x86_64
+            image: ubuntu:22.04
+          - triple: arch-x86_64
+            image: archlinux:latest
+    steps:
+      - uses: actions/download-artifact@v4
+        with:
+          name: hive-${{ matrix.triple }}
+          path: dist
+      # Plan U1 verification: the bundle must run on a box with NO Ruby
+      # installed. Assert ruby is absent, then run the vendored launcher.
+      - name: Extract and run without system Ruby
+        run: |
+          set -euo pipefail
+          if command -v ruby >/dev/null 2>&1; then
+            echo "ruby unexpectedly present on smoke image; test is not exercising the no-ruby path" >&2
+            exit 1
+          fi
+          mkdir -p /opt/hive-smoke
+          tar -xzf dist/hive-*-${{ matrix.triple }}.tar.gz -C /opt/hive-smoke
+          bundle_dir="$(find /opt/hive-smoke -maxdepth 1 -type d -name 'hive-*' | head -n1)"
+          "$bundle_dir/bin/hive" --version
+          "$bundle_dir/bin/hive" doctor --json || true
+
+  publish:
+    name: publish GitHub Release
+    runs-on: ubuntu-22.04
+    needs: [build, build-arch, smoke]
+    steps:
+      - uses: actions/checkout@v6
+      - uses: actions/download-artifact@v4
+        with:
+          path: dist
+          merge-multiple: true
+      - name: Add installer asset
+        run: |
+          cp packaging/install.sh dist/install.sh
+          cp install.md dist/install.md
+      - uses: softprops/action-gh-release@v2
+        with:
+          files: |
+            dist/*.tar.gz
+            dist/*.sha256
+            dist/install.sh
+            dist/install.md
