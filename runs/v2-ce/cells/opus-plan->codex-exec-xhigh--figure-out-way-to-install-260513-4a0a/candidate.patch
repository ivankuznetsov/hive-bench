+require "test_helper"
+require "hive/service"
+
+class HiveServiceTest < Minitest::Test
+  include HiveTestHelper
+
+  def test_render_systemd_unit_uses_project_root_and_hive_binary
+    unit = Hive::Service.render_systemd(project_root: "/tmp/my project", hive_bin: "/opt/hive/bin/hive")
+
+    assert_includes unit, "WorkingDirectory=/tmp/my project"
+    assert_includes unit, "ExecStart=/opt/hive/bin/hive daemon start"
+    assert_includes unit, "Restart=on-failure"
+  end
+
+  def test_render_launchd_plist_uses_project_root_and_hive_binary
+    plist = Hive::Service.render_launchd(project_root: "/tmp/my project", hive_bin: "/opt/hive/bin/hive")
+
+    assert_includes plist, "<string>com.hive.daemon</string>"
+    assert_includes plist, "<key>WorkingDirectory</key>"
+    assert_includes plist, "<string>/tmp/my project</string>"
+    assert_includes plist, "<string>/opt/hive/bin/hive</string>"
+  end
+
+  def test_install_writes_service_file_without_enabling
+    skip "service registration unsupported on this platform" unless Hive::Service.supported?
+
+    with_tmp_dir do |home|
+      with_env("HOME" => home) do
+        out = StringIO.new
+        calls = []
+
+        path = Hive::Service.install(
+          project_root: "/tmp/project",
+          hive_bin: "/tmp/hive",
+          output: out,
+          executor: ->(*cmd) { calls << cmd; true }
+        )
+
+        assert File.exist?(path)
+        assert_empty calls
+        assert_match(/registered/, out.string)
+      end
+    end
+  end
+
+  def test_render_launchd_run_at_load_reflects_enable_choice
+    disabled = Hive::Service.render_launchd(project_root: "/tmp/p", hive_bin: "/opt/hive/bin/hive", enable_now: false)
+    enabled = Hive::Service.render_launchd(project_root: "/tmp/p", hive_bin: "/opt/hive/bin/hive", enable_now: true)
+
+    assert_match(%r{<key>RunAtLoad</key>\s*<false/>}, disabled)
+    assert_match(%r{<key>RunAtLoad</key>\s*<true/>}, enabled)
+  end
+
+  def test_render_systemd_quotes_paths_with_spaces
+    unit = Hive::Service.render_systemd(project_root: "/tmp/p", hive_bin: "/opt/my hive/bin/hive")
+
+    assert_includes unit, 'ExecStart="/opt/my hive/bin/hive" daemon start'
+  end
+
+  def test_teardown_disables_and_removes_unit
+    skip "service registration unsupported on this platform" unless Hive::Service.supported?
+
+    with_tmp_dir do |home|
+      with_env("HOME" => home) do
+        calls = []
+        path = Hive::Service.install(
+          project_root: "/tmp/project",
+          hive_bin: "/tmp/hive",
+          output: StringIO.new,
+          executor: ->(*cmd) { calls << cmd; true }
+        )
+        assert File.exist?(path)
+
+        out = StringIO.new
+        Hive::Service.teardown(output: out, executor: ->(*cmd) { calls << cmd; true })
+
+        refute File.exist?(path)
+        assert_match(/removed/, out.string)
+        if Hive::Service.platform == :linux
+          assert_includes calls, [ "systemctl", "--user", "disable", "--now", "hive-daemon.service" ]
+        else
+          assert(calls.any? { |cmd| cmd[0, 2] == [ "launchctl", "bootout" ] })
+        end
+      end
+    end
+  end
+
+  def test_teardown_warns_when_executor_fails_but_still_removes
+    skip "service registration unsupported on this platform" unless Hive::Service.supported?
+
+    with_tmp_dir do |home|
+      with_env("HOME" => home) do
+        path = Hive::Service.install(
+          project_root: "/tmp/project",
+          hive_bin: "/tmp/hive",
+          output: StringIO.new,
+          executor: ->(*_cmd) { true }
+        )
+
+        out = StringIO.new
+        Hive::Service.teardown(output: out, executor: ->(*_cmd) { false })
+
+        refute File.exist?(path)
