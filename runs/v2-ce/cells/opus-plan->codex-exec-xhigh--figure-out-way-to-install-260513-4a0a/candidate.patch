+class Hive < Formula
+  desc "Folder-as-agent meta-pipeline for coding agents"
+  homepage "https://github.com/ivankuznetsov/hive"
+  version "<%= version %>"
+  license "MIT"
+
+  on_macos do
+    if Hardware::CPU.arm?
+      url "https://github.com/ivankuznetsov/hive/releases/download/v<%= version %>/hive-<%= version %>-macos-arm64.tar.gz"
+      sha256 "<%= sha256_macos_arm64 %>"
+    else
+      # Intel macOS is tier-2 and not part of the release build matrix, so
+      # there is no macos-x86_64 asset to fetch. Fail cleanly as unsupported
+      # rather than 404ing on a nonexistent download.
+      odie "hive: Intel (x86_64) macOS is not supported; only Apple Silicon (arm64) bundles are published."
+    end
+  end
+
+  def install
+    libexec.install Dir["*"]
+    (libexec/"INSTALL-CHANNEL").write "brew\n"
+    bin.install_symlink libexec/"bin/hive" => "hive"
+  end
+
+  def caveats
+    <<~EOS
+      Run `hive init` from a project checkout to create .hive-state and register
+      the project. If another `hive` command is already on PATH, install through
+      the release install.sh script to get the `hv` fallback name.
+    EOS
+  end
+
+  test do
+    assert_match version.to_s, shell_output("#{bin}/hive --version")
+  end
+end
diff --git a/packaging/install.sh b/packaging/install.sh
new file mode 100755
index 00000000..65a7bf67
--- /dev/null
+++ b/packaging/install.sh
@@ -0,0 +1,197 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+HIVE_OWNER="${HIVE_OWNER:-ivankuznetsov}"
+HIVE_REPO="${HIVE_REPO:-hive}"
+HIVE_INSTALL_ROOT="${HIVE_INSTALL_ROOT:-${HIVE_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/hive}}"
+HIVE_BIN_DIR="${HIVE_BIN_DIR:-$HOME/.local/bin}"
+HIVE_VERSION="${HIVE_VERSION:-}"
+
+log() {
+  printf '%s\n' "$*"
+}
+
+fail() {
+  printf 'hive install: %s\n' "$*" >&2
+  exit 1
+}
+
+os_family() {
+  case "$(uname -s)" in
+    Darwin) printf 'macos' ;;
+    Linux)
+      if [ -f /etc/arch-release ]; then
+        printf 'arch'
+      else
+        printf 'ubuntu'
+      fi
+      ;;
+    *) fail "unsupported OS: $(uname -s)" ;;
+  esac
+}
+
+arch_name() {
+  case "$(uname -m)" in
+    arm64|aarch64) printf 'arm64' ;;
+    x86_64|amd64) printf 'x86_64' ;;
+    *) fail "unsupported architecture: $(uname -m)" ;;
+  esac
+}
+
+triple() {
+  printf '%s-%s' "$(os_family)" "$(arch_name)"
+}
+
+hint_for() {
+  dep="$1"
+  os="$(os_family)"
+  case "$dep:$os" in
+    git:macos) printf 'brew install git' ;;
+    git:arch) printf 'sudo pacman -S git' ;;
+    git:*) printf 'sudo apt install git' ;;
+    bash:macos) printf 'brew install bash' ;;
+    bash:arch) printf 'sudo pacman -S bash' ;;
+    bash:*) printf 'sudo apt install bash' ;;
+    gh:macos) printf 'brew install gh' ;;
+    gh:arch) printf 'sudo pacman -S github-cli' ;;
+    gh:*) printf 'sudo apt install gh' ;;
+    jq:macos) printf 'brew install jq' ;;
+    jq:arch) printf 'sudo pacman -S jq' ;;
+    jq:*) printf 'sudo apt install jq' ;;
+    claude:*) printf 'install Claude Code from Anthropic official instructions' ;;
+    curl:macos) printf 'curl ships with macOS, or install with brew install curl' ;;
+    curl:arch) printf 'sudo pacman -S curl' ;;
+    curl:*) printf 'sudo apt install curl' ;;
+    tar:macos) printf 'tar ships with macOS' ;;
+    tar:arch) printf 'sudo pacman -S tar' ;;
+    tar:*) printf 'sudo apt install tar' ;;
+  esac
+}
+
+check_dep() {
+  dep="$1"
+  required="$2"
+  if command -v "$dep" >/dev/null 2>&1; then
+    return 0
+  fi
+  if [ "$required" = "required" ]; then
+    fail "missing required dependency '$dep'. Install with: $(hint_for "$dep")"
+  fi
+  log "warning: missing optional dependency '$dep'. Install with: $(hint_for "$dep")"
+}
+
+preflight_deps() {
+  check_dep curl required
+  check_dep tar required
+  check_dep git required
+  check_dep bash required
+  check_dep claude optional
+  check_dep gh optional
+  check_dep jq optional
+}
+
+latest_version() {
+  if [ -n "$HIVE_VERSION" ]; then
+    printf '%s' "${HIVE_VERSION#v}"
+    return
+  fi
+  url="$(curl -fsSLI -o /dev/null -w '%{url_effective}' "https://github.com/${HIVE_OWNER}/${HIVE_REPO}/releases/latest")"
+  tag="${url##*/}"
+  # Validate the resolved segment looks like a version tag. If GitHub
+  # redirects /releases/latest to /releases (no releases yet), the segment
+  # would be a non-version word that flows into a 404ing download URL.
+  case "$tag" in
+    v[0-9]*|[0-9]*) : ;;
+    *) fail "could not resolve latest release (unexpected tag '$tag')" ;;
+  esac
+  printf '%s' "${tag#v}"
+}
+
+download() {
+  version="$1"
+  asset_triple="$2"
+  base="https://github.com/${HIVE_OWNER}/${HIVE_REPO}/releases/download/v${version}"
+  tarball="hive-${version}-${asset_triple}.tar.gz"
+  curl -fsSLO "${base}/${tarball}"
+  curl -fsSLO "${base}/${tarball}.sha256"
+}
+
+# Trust assumption: the tarball and its .sha256 are fetched from the same
+# GitHub release origin over TLS, so the checksum guards against a
+# corrupted/truncated download, not a compromised release. There is no
+# pinned known-good hash. A mismatch — or the absence of any checksum tool
+# — aborts the install rather than proceeding unverified.
+verify_checksum() {
+  checksum_file="$1"
+  target="${checksum_file%.sha256}"
+  if command -v sha256sum >/dev/null 2>&1; then
+    sha256sum -c "$checksum_file" || fail "checksum verification failed for $target"
+  elif command -v shasum >/dev/null 2>&1; then
+    shasum -a 256 -c "$checksum_file" || fail "checksum verification failed for $target"
+  else
+    fail "no checksum tool found (need sha256sum or shasum); refusing to install '$target' unverified"
+  fi
+  log "verified checksum for $target"
+}
+
+choose_command_name() {
+  existing="$(command -v hive || true)"
+  target_hive="${HIVE_BIN_DIR}/hive"
+  if [ -n "$existing" ] && [ "$existing" != "$target_hive" ]; then
+    printf 'hv'
+  else
+    printf 'hive'
+  fi
+}
+
+install_bundle() {
+  version="$1"
+  asset_triple="$2"
+  tmp="$(mktemp -d)"
+  trap 'rm -rf "$tmp"' EXIT
+  cd "$tmp" || fail "could not enter temp dir $tmp"
+
+  download "$version" "$asset_triple"
+  verify_checksum "hive-${version}-${asset_triple}.tar.gz.sha256"
+
+  mkdir -p "$HIVE_INSTALL_ROOT"
+  tar -xzf "hive-${version}-${asset_triple}.tar.gz" -C "$HIVE_INSTALL_ROOT"
+  ln -sfn "$HIVE_INSTALL_ROOT/hive-${version}-${asset_triple}" "$HIVE_INSTALL_ROOT/current"
+  # Two channel markers, mirroring the brew/aur installers:
+  #   * bundle-root uppercase INSTALL-CHANNEL — read at runtime via
+  #     HIVE_BUNDLE_ROOT (reliable even when the XDG data dir differs from
+  #     this install root, e.g. a legacy ~/Dev/hive is present). Overwrites
+  #     the "source" value baked into the bundle at build time.
+  #   * data-dir lowercase install-channel — read via
+  #     Hive::Config.install_channel_path.
+  printf 'bash\n' > "$HIVE_INSTALL_ROOT/current/INSTALL-CHANNEL"
+  printf 'bash\n' > "$HIVE_INSTALL_ROOT/install-channel"
+
+  mkdir -p "$HIVE_BIN_DIR"
+  cmd_name="$(choose_command_name)"
+  ln -sfn "$HIVE_INSTALL_ROOT/current/bin/hive" "$HIVE_BIN_DIR/$cmd_name"
+  printf '%s\n' "$HIVE_BIN_DIR/$cmd_name" > "$HIVE_INSTALL_ROOT/install-bin"
+
+  log "installed hive ${version} to $HIVE_INSTALL_ROOT/current"
+  if [ "$cmd_name" = "hv" ]; then
+    log "installed command as 'hv' because another 'hive' is already on PATH"
+  fi
+  log "next: $cmd_name init"
+
+  # Post-install self-check (U5). Non-fatal — missing agent skills are
+  # resolved later by `hive init` — but the result is surfaced, not
+  # discarded, so runtime-dependency gaps (missing/too-old git, bash, jq…)
+  # are visible right after install.
+  if ! "$HIVE_BIN_DIR/$cmd_name" doctor --json; then
+    log "warning: post-install self-check ('$cmd_name doctor') reported issues above; review them before running '$cmd_name init'"
+  fi
+}
+
+main() {
+  preflight_deps
+  asset_triple="$(triple)"
+  version="$(latest_version)"
+  install_bundle "$version" "$asset_triple"
+}
+
+main "$@"
