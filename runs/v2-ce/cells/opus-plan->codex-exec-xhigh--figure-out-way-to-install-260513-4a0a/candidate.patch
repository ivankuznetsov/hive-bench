--- /dev/null
+++ b/packaging/bundle/README.md
@@ -0,0 +1,12 @@
+# Hive Runtime Bundle
+
+Release assets are relocatable runtime bundles, not single-file binaries. Each
+bundle contains:
+
+- `ruby/` — the Ruby prefix for the target platform
+- `vendor/bundle/` — gems installed for that platform, including native Charm gems
+- `app/` — the Hive source, templates, schemas, and lockfile
+- `bin/hive` — a launcher that pins Bundler to the bundled app and gems
+
+The bundle may be unpacked anywhere. Install channels symlink `bin/hive` (or
+`hv` when the `hive` command name is already taken) onto PATH.
diff --git a/packaging/bundle/hive b/packaging/bundle/hive
new file mode 100644
index 00000000..e94bc9a5
--- /dev/null
+++ b/packaging/bundle/hive
@@ -0,0 +1,28 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+self="${BASH_SOURCE[0]}"
+while [ -L "$self" ]; do
+  dir="$(cd -P "$(dirname "$self")" >/dev/null 2>&1 && pwd)"
+  target="$(readlink "$self")"
+  case "$target" in
+    /*) self="$target" ;;
+    *) self="$dir/$target" ;;
+  esac
+done
+
+root="$(cd -P "$(dirname "$self")/.." >/dev/null 2>&1 && pwd)"
+app="$root/app"
+ruby="$root/ruby/bin/ruby"
+
+export BUNDLE_GEMFILE="$app/Gemfile"
+export BUNDLE_PATH="$root/vendor/bundle"
+export BUNDLE_WITHOUT="development:test"
+export HIVE_BUNDLE_ROOT="$root"
+export HIVE_APP_ROOT="$app"
+# Generated launchd/systemd units must exec this bundle launcher (which
+# sets BUNDLE_GEMFILE/BUNDLE_PATH and the vendored Ruby), NOT the raw
+# app/bin/hive Thor script, which would require a system Ruby + gems.
+export HIVE_BIN="$root/bin/hive"
+
+exec "$ruby" -rbundler/setup "$app/bin/hive" "$@"
