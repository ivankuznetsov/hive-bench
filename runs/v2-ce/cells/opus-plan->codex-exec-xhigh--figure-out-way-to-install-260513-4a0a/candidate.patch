diff --git a/tasks/package.rake b/tasks/package.rake
new file mode 100644
index 00000000..44d11f4c
--- /dev/null
+++ b/tasks/package.rake
@@ -0,0 +1,166 @@
+require "digest"
+require "etc"
+require "fileutils"
+require "rbconfig"
+require "shellwords"
+require "tmpdir"
+
+require_relative "../lib/hive"
+
+namespace :package do
+  desc "Build a relocatable runtime bundle into dist/"
+  task :build do
+    Hive::Package.build
+  end
+
+  desc "Verify Hive::VERSION matches the current git tag"
+  task :assert_tag_version do
+    tag = ENV.fetch("GITHUB_REF_NAME", "").sub(/\Av/, "")
+    abort "GITHUB_REF_NAME is required for release packaging" if tag.empty?
+    abort "tag v#{tag} does not match Hive::VERSION #{Hive::VERSION}" unless tag == Hive::VERSION
+  end
+end
+
+desc "Build a relocatable runtime bundle into dist/"
+task package: "package:build"
+
+module Hive
+  module Package
+    module_function
+
+    # `packaging` ships with the bundle because Hive::Service renders the
+    # launchd/systemd unit templates from `<app>/packaging/{launchd,systemd}/`
+    # at `hive init` time; without it a packaged install's service
+    # registration raises Errno::ENOENT.
+    COPY_ENTRIES = %w[
+      bin
+      config
+      lib
+      packaging
+      schemas
+      templates
+      Gemfile
+      Gemfile.lock
+      LICENSE
+      README.md
+      config.example.yml
+    ].freeze
+
+    def build
+      root = File.expand_path("..", __dir__)
+      version = ENV.fetch("HIVE_PACKAGE_VERSION", Hive::VERSION)
+      triple = ENV.fetch("HIVE_PACKAGE_TRIPLE", detect_triple)
+      dist = File.join(root, "dist")
+      package_name = "hive-#{version}-#{triple}"
+      package_dir = File.join(dist, package_name)
+      app_dir = File.join(package_dir, "app")
+
+      FileUtils.rm_rf(package_dir)
+      FileUtils.mkdir_p(app_dir)
+      copy_app(root, app_dir)
+      copy_ruby_prefix(package_dir)
+      install_bundle(app_dir, package_dir)
+      install_launcher(package_dir)
+      write_metadata(package_dir, version, triple)
+      archive(dist, package_name)
+    end
+
+    def detect_triple
+      os = case RbConfig::CONFIG.fetch("host_os")
+      when /darwin/ then "macos"
+      when /linux/ then linux_flavor
+      else RbConfig::CONFIG.fetch("host_os").split(/[^\w]+/).first
+      end
+      arch = case RbConfig::CONFIG.fetch("host_cpu")
+      when "arm64", "aarch64" then "arm64"
+      when "x86_64", "amd64" then "x86_64"
+      else RbConfig::CONFIG.fetch("host_cpu")
+      end
+      "#{os}-#{arch}"
+    end
+
+    def linux_flavor
+      return "arch" if File.exist?("/etc/arch-release")
+
+      "ubuntu"
+    end
+
+    def copy_app(root, app_dir)
+      COPY_ENTRIES.each do |entry|
+        src = File.join(root, entry)
+        next unless File.exist?(src)
+
+        FileUtils.cp_r(src, File.join(app_dir, entry))
+      end
+    end
+
+    def copy_ruby_prefix(package_dir)
+      src = File.expand_path(ENV.fetch("HIVE_RUBY_PREFIX", RbConfig::CONFIG.fetch("prefix")))
+      if src == "/usr" && ENV["HIVE_RUBY_PREFIX"].to_s.empty?
+        abort "refusing to copy /usr as the Ruby prefix; set HIVE_RUBY_PREFIX to a portable Ruby install"
+      end
+
+      dest = File.join(package_dir, "ruby")
+      FileUtils.rm_rf(dest)
+      FileUtils.mkdir_p(File.dirname(dest))
+      FileUtils.cp_r(src, dest, preserve: true)
+    end
+
+    def install_bundle(app_dir, package_dir)
+      env = {
+        "BUNDLE_GEMFILE" => File.join(app_dir, "Gemfile"),
+        "BUNDLE_PATH" => File.join(package_dir, "vendor", "bundle"),
+        "BUNDLE_WITHOUT" => "development:test",
+        "BUNDLE_DEPLOYMENT" => "true"
+      }
+      run!(env, "bundle", "install", "--jobs", Etc.nprocessors.to_s, chdir: app_dir)
+      run!(env, "bundle", "clean", chdir: app_dir)
+    end
+
+    def install_launcher(package_dir)
+      FileUtils.mkdir_p(File.join(package_dir, "bin"))
+      launcher = File.join(package_dir, "bin", "hive")
+      FileUtils.cp(File.expand_path("../packaging/bundle/hive", __dir__), launcher)
+      FileUtils.chmod(0o755, launcher)
+    end
+
+    def write_metadata(package_dir, version, triple)
+      File.write(File.join(package_dir, "VERSION"), "#{version}\n")
+      # Two markers name the install channel, on purpose:
+      #   * bundle-root uppercase `INSTALL-CHANNEL` (this file) — travels
+      #     inside the tarball and is read at runtime via HIVE_BUNDLE_ROOT.
+      #     Baked as "source"; brew/aur/bash installers overwrite it with
+      #     their own channel name.
+      #   * data-dir lowercase `install-channel` (written by
+      #     packaging/install.sh) — the XDG-located marker read via
+      #     Hive::Config.install_channel_path.
+      # `hive update`/`uninstall` consult the data-dir marker first, then
+      # fall back to the bundle-root marker.
+      File.write(File.join(package_dir, "INSTALL-CHANNEL"), "source\n")
+      File.write(File.join(package_dir, "README.bundle.md"), <<~README)
+        # Hive #{version} runtime bundle
+
+        This bundle targets `#{triple}` and contains a Ruby runtime, the Hive
+        application, and a Bundler vendor directory with platform-specific
+        native gems. Run `bin/hive --version` from this directory, or symlink
+        `bin/hive` onto PATH.
+      README
+    end
+
+    def archive(dist, package_name)
+      tarball = File.join(dist, "#{package_name}.tar.gz")
+      FileUtils.rm_f(tarball)
+      run!({}, "tar", "-C", dist, "-czf", tarball, package_name)
+      File.write("#{tarball}.sha256", "#{Digest::SHA256.file(tarball).hexdigest}  #{File.basename(tarball)}\n")
+      puts "built #{tarball}"
+    end
+
+    def run!(env, *cmd, chdir: nil)
+      display = cmd.shelljoin
+      display = "cd #{chdir.shellescape} && #{display}" if chdir
+      puts display
+      ok = system(env, *cmd, chdir: chdir)
+      abort "command failed: #{display}" unless ok
+    end
+  end
+end
