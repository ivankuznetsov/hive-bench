index 00000000..4cec8d28
--- /dev/null
+++ b/share/hive/services/launchd/hive-daemon.plist
@@ -0,0 +1,94 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<!--
+  Sample launchd plist for `hive daemon` (macOS).
+
+  Install:
+    mkdir -p ~/Library/LaunchAgents
+    cp examples/launchd/hive-daemon.plist ~/Library/LaunchAgents/
+    $EDITOR ~/Library/LaunchAgents/hive-daemon.plist   # confirm absolute paths
+    launchctl load ~/Library/LaunchAgents/hive-daemon.plist
+
+  Verify it actually started (catches a wrong binary path before the
+  circuit-breaker silently throttles):
+    launchctl list | grep hive-daemon
+    cat ~/Library/Logs/hive-daemon.err.log
+
+  View logs:
+    tail -f ~/Library/Logs/hive-daemon.{out,err}.log    # launchd capture
+    hive daemon tail                                    # daemon's JSON-line log
+
+  Stop / restart:
+    launchctl unload ~/Library/LaunchAgents/hive-daemon.plist
+    launchctl load   ~/Library/LaunchAgents/hive-daemon.plist
+
+  Note the absolute-path requirement: launchd doesn't read your shell's
+  rc files, so the `hive` binary must be invoked at its real location.
+  Replace `/Users/YOU/.local/bin/hive` with the path on your machine
+  (run `which hive` to find it). If installed via rbenv / asdf / mise,
+  point at the corresponding shim.
+
+  RESPAWN-LOOP CIRCUIT-BREAKER: launchd has no native equivalent of
+  systemd's StartLimitBurst. With KeepAlive { SuccessfulExit: false }
+  and a wrong ProgramArguments path, launchd would respawn every 30 s
+  forever, filling ~/Library/Logs/hive-daemon.err.log with `command not
+  found`. The /bin/sh wrapper below converts "binary not executable"
+  into a clean exit 0 — which KeepAlive { SuccessfulExit: false } then
+  respects (no respawn). A real daemon crash still exits non-zero
+  through `exec` and respawns normally per ThrottleInterval. The check
+  is `[ -x "$0" ]` so a missing OR non-executable hive binary stops the
+  loop after one attempt, while a working binary that crashes keeps
+  the auto-restart contract.
+-->
+<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
+  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+<plist version="1.0">
+<dict>
+  <!-- launchd Labels are conventionally reverse-DNS strings owned by
+       the publisher. Apple's `local.*` namespace is reserved for
+       per-user plists with no DNS-backed identity, so it's the right
+       neutral default for a sample. Customise to your own reverse-DNS
+       (e.g., `com.example.hive-daemon`) if you want clear ownership. -->
+  <key>Label</key>
+  <string>local.hive-daemon</string>
+
+  <!-- ProgramArguments wraps the real invocation in a tiny /bin/sh
+       precheck. If the binary path passed as $0 is missing or not
+       executable, the wrapper exits 0 (clean) so KeepAlive's
+       SuccessfulExit:false STOPS respawning. If it IS executable, exec
+       hands the process tree to hive and a real crash will re-trigger
+       respawn through KeepAlive normally. See the RESPAWN-LOOP
+       CIRCUIT-BREAKER note above for the rationale. -->
+  <key>ProgramArguments</key>
+  <array>
+    <string>/bin/sh</string>
+    <string>-c</string>
+    <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+    <string>/Users/YOU/.local/bin/hive</string>
+    <string>daemon</string>
+    <string>start</string>
+  </array>
+
+  <key>RunAtLoad</key>
+  <true/>
+
+  <key>KeepAlive</key>
+  <dict>
+    <key>SuccessfulExit</key>
+    <false/>
+  </dict>
+
+  <key>ThrottleInterval</key>
+  <integer>30</integer>
+
+  <key>StandardOutPath</key>
+  <string>/Users/YOU/Library/Logs/hive-daemon.out.log</string>
+  <key>StandardErrorPath</key>
+  <string>/Users/YOU/Library/Logs/hive-daemon.err.log</string>
+
+  <key>EnvironmentVariables</key>
+  <dict>
+    <key>PATH</key>
+    <string>/Users/YOU/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
+  </dict>
+</dict>
+</plist>
