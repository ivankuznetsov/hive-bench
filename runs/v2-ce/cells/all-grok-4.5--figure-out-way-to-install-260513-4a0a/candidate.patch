index 00000000..a0d04898
--- /dev/null
+++ b/lib/hive/preflight.rb
@@ -0,0 +1,118 @@
+# frozen_string_literal: true
+
+module Hive
+  # Shared runtime dependency matrix for installers and `hive doctor`.
+  # Soft checks only: report missing tools with install hints; never
+  # auto-install.
+  module Preflight
+    Dependency = Struct.new(:name, :required_for_install, :hint_linux, :hint_macos, :hint_arch, keyword_init: true)
+
+    DEPS = [
+      Dependency.new(
+        name: "git",
+        required_for_install: false,
+        hint_linux: "sudo apt install git",
+        hint_macos: "xcode-select --install  # or: brew install git",
+        hint_arch: "sudo pacman -S git"
+      ),
+      Dependency.new(
+        name: "bash",
+        required_for_install: false,
+        hint_linux: "sudo apt install bash",
+        hint_macos: "brew install bash",
+        hint_arch: "sudo pacman -S bash"
+      ),
+      Dependency.new(
+        name: "gh",
+        required_for_install: false,
+        hint_linux: "See https://cli.github.com/ — then: gh auth login",
+        hint_macos: "brew install gh && gh auth login",
+        hint_arch: "sudo pacman -S github-cli && gh auth login"
+      ),
+      Dependency.new(
+        name: "jq",
+        required_for_install: false,
+        hint_linux: "sudo apt install jq",
+        hint_macos: "brew install jq",
+        hint_arch: "sudo pacman -S jq"
+      ),
+      Dependency.new(
+        name: "claude",
+        required_for_install: false,
+        hint_linux: "Install Claude Code: https://docs.anthropic.com/en/docs/claude-code",
+        hint_macos: "Install Claude Code: https://docs.anthropic.com/en/docs/claude-code",
+        hint_arch: "Install Claude Code: https://docs.anthropic.com/en/docs/claude-code"
+      ),
+      Dependency.new(
+        name: "curl",
+        required_for_install: true,
+        hint_linux: "sudo apt install curl",
+        hint_macos: "curl ships with macOS",
+        hint_arch: "sudo pacman -S curl"
+      ),
+      Dependency.new(
+        name: "tar",
+        required_for_install: true,
+        hint_linux: "sudo apt install tar",
+        hint_macos: "tar ships with macOS",
+        hint_arch: "sudo pacman -S tar"
+      )
+    ].freeze
+
+    # Optional agent CLIs checked by doctor in addition to DEPS.
+    OPTIONAL_AGENTS = %w[codex pi].freeze
+
+    module_function
+
+    def os_family
+      if RUBY_PLATFORM.include?("darwin")
+        :macos
+      elsif File.exist?("/etc/arch-release")
+        :arch
+      else
+        :linux
+      end
+    end
+
+    def hint_for(dep)
+      case os_family
+      when :macos then dep.hint_macos
+      when :arch then dep.hint_arch
+      else dep.hint_linux
+      end
+    end
+
+    def present?(name)
+      # `command` is a shell builtin, not an argv executable — walk PATH.
+      ENV.fetch("PATH", "").split(File::PATH_SEPARATOR).any? do |dir|
+        next if dir.empty?
+
+        path = File.join(dir, name)
+        File.file?(path) && File.executable?(path)
+      end
+    end
+
+    # Returns array of hashes: { name:, status: "present"|"missing", hint:, required_for_install: }
+    def check_cli_deps(include_optional_agents: true)
+      rows = DEPS.map do |dep|
+        {
+          name: dep.name,
+          status: present?(dep.name) ? "present" : "missing",
+          hint: hint_for(dep),
+          required_for_install: dep.required_for_install
+        }
+      end
+      if include_optional_agents
+        OPTIONAL_AGENTS.each do |name|
+          rows << {
+            name: name,
+            status: present?(name) ? "present" : "missing",
+            hint: "install the #{name} CLI if you use it as a stage agent",
+            required_for_install: false
+          }
+        end
+      end
+      rows
+    end
+  end
+end
diff --git a/lib/hive/service_installer.rb b/lib/hive/service_installer.rb
new file mode 100644
index 00000000..805f8cec
--- /dev/null
+++ b/lib/hive/service_installer.rb
@@ -0,0 +1,332 @@
+# frozen_string_literal: true
+
+require "erb"
+require "fileutils"
+require "hive/paths"
+
+module Hive
+  # Install / remove user-level systemd or launchd units for `hive daemon`.
+  # Unit bodies are rendered from share/hive/services templates when present
+  # so packaged examples and runtime install stay in sync.
+  class ServiceInstaller
+    SYSTEMD_UNIT = "hive-daemon.service"
+    LAUNCHD_LABEL = "local.hive-daemon"
+    LAUNCHD_PLIST = "#{LAUNCHD_LABEL}.plist"
+
+    Result = Struct.new(:kind, :path, :action, :enabled, :removed, keyword_init: true)
+
+    def initialize(binary_path: nil, dry_run: false, output: $stdout)
+      @binary_path = binary_path || resolve_hive_binary!
+      @dry_run = dry_run
+      @output = output
+    end
+
+    # mode: :enable_start | :register_only | :skip
+    def install(mode:)
+      return Result.new(kind: "none", action: "skip", removed: false) if mode == :skip
+
+      if darwin?
+        install_launchd(enable: mode == :enable_start)
+      else
+        install_systemd(enable: mode == :enable_start)
+      end
+    end
+
+    def uninstall
+      if darwin?
+        uninstall_launchd
+      else
+        uninstall_systemd
+      end
+    end
+
+    def self.prompt_mode(input: $stdin, output: $stderr)
+      return :skip unless input.respond_to?(:tty?) && input.tty?
+
+      output.puts
+      output.puts "Register hive daemon as a user service?"
+      output.puts "  [1] Yes — register and enable+start now (default)"
+      output.puts "  [2] Register but leave stopped"
+      output.puts "  [3] Skip"
+      output.print "Choice [1]: "
+      ans = input.gets.to_s.strip
+      case ans
+      when "", "1", "y", "Y", "yes" then :enable_start
+      when "2" then :register_only
+      else :skip
+      end
+    end
+
+    private
+
+    def darwin?
+      RUBY_PLATFORM.include?("darwin")
+    end
+
+    def resolve_hive_binary!
+      candidates = []
+      candidates << File.expand_path($PROGRAM_NAME) if $PROGRAM_NAME
+      found = `command -v hive 2>/dev/null`.to_s.strip
+      candidates << found unless found.empty?
+      found_hv = `command -v hv 2>/dev/null`.to_s.strip
+      candidates << found_hv unless found_hv.empty?
+      candidates << File.join(Paths.source_root, "bin", "hive")
+
+      candidates.each do |c|
+        next if c.nil? || c.empty?
+        return File.realpath(c) if File.executable?(c)
+        return File.expand_path(c) if File.exist?(c)
+      end
+
+      raise Hive::Error, "could not resolve absolute path to hive binary for service install"
+    end
+
+    def install_systemd(enable:)
+      unit_dir = File.expand_path("~/.config/systemd/user")
+      path = File.join(unit_dir, SYSTEMD_UNIT)
+      content = render_systemd
+      write_file(path, content)
+      unless @dry_run
+        run_cmd!("systemctl", "--user", "daemon-reload")
+        if enable
+          run_cmd!("systemctl", "--user", "enable", "--now", SYSTEMD_UNIT)
+        end
+      end
+      @output.puts "hive: wrote systemd user unit #{path}"
+      @output.puts "hive: enable later with: systemctl --user enable --now #{SYSTEMD_UNIT}" unless enable
+      Result.new(kind: "systemd", path: path, action: enable ? "enable_start" : "register_only",
+                 enabled: enable, removed: false)
+    end
+
+    def install_launchd(enable:)
+      unit_dir = File.expand_path("~/Library/LaunchAgents")
+      path = File.join(unit_dir, LAUNCHD_PLIST)
+      content = render_launchd(enable: enable)
+      write_file(path, content)
+      unless @dry_run
+        launchd_bootout(path)
+        if enable
+          launchd_bootstrap(path)
+        end
+      end
+      @output.puts "hive: wrote launchd agent #{path}"
+      unless enable
+        uid = launchd_uid
+        @output.puts "hive: registered but left stopped (RunAtLoad=false, Disabled=true)"
+        @output.puts "hive: enable later with:"
+        @output.puts "  launchctl enable gui/#{uid}/#{LAUNCHD_LABEL}"
+        @output.puts "  launchctl bootstrap gui/#{uid} #{path}"
+        @output.puts "  # legacy: launchctl load #{path}"
+      end
+      Result.new(kind: "launchd", path: path, action: enable ? "enable_start" : "register_only",
+                 enabled: enable, removed: false)
+    end
+
+    def uninstall_systemd
+      path = File.expand_path("~/.config/systemd/user/#{SYSTEMD_UNIT}")
+      removed = false
+      unless @dry_run
+        system("systemctl", "--user", "disable", "--now", SYSTEMD_UNIT, out: File::NULL, err: File::NULL)
+        if File.exist?(path)
+          FileUtils.rm_f(path)
+          removed = true
+        end
+        system("systemctl", "--user", "daemon-reload", out: File::NULL, err: File::NULL)
+      end
+      Result.new(kind: "systemd", path: path, action: "uninstall", removed: removed, enabled: false)
+    end
+
+    def uninstall_launchd
+      path = File.expand_path("~/Library/LaunchAgents/#{LAUNCHD_PLIST}")
+      removed = false
+      unless @dry_run
+        launchd_bootout(path) if File.exist?(path)
+        if File.exist?(path)
+          FileUtils.rm_f(path)
+          removed = true
+        end
+      end
+      Result.new(kind: "launchd", path: path, action: "uninstall", removed: removed, enabled: false)
+    end
+
+    def write_file(path, content)
+      if @dry_run
+        @output.puts "hive: dry-run would write #{path}"
+        return
+      end
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, content)
+    end
+
+    def launchd_uid
+      Process.uid
+    end
+
+    def launchd_domain
+      "gui/#{launchd_uid}"
+    end
+
+    def launchctl_supports_bootstrap?
+      # Modern macOS prefers bootstrap/bootout over load/unload.
+      out = `launchctl help 2>&1`.to_s
+      out.include?("bootstrap") || out.include?("bootout")
+    rescue StandardError
+      false
+    end
+
+    def launchd_bootout(path)
+      if launchctl_supports_bootstrap?
+        # Ignore failure when the job is not loaded yet.
+        system("launchctl", "bootout", launchd_domain, path,
+               out: File::NULL, err: File::NULL)
+        system("launchctl", "bootout", "#{launchd_domain}/#{LAUNCHD_LABEL}",
+               out: File::NULL, err: File::NULL)
+      else
+        system("launchctl", "unload", path, out: File::NULL, err: File::NULL) if File.exist?(path)
+      end
+    end
+
+    def launchd_bootstrap(path)
+      if launchctl_supports_bootstrap?
+        run_cmd!("launchctl", "bootstrap", launchd_domain, path)
+        # Ensure the job is enabled (Disabled=false may still need enable).
+        system("launchctl", "enable", "#{launchd_domain}/#{LAUNCHD_LABEL}",
+               out: File::NULL, err: File::NULL)
+        # Kickstart so RunAtLoad-equivalent start happens immediately.
+        system("launchctl", "kickstart", "-k", "#{launchd_domain}/#{LAUNCHD_LABEL}",
+               out: File::NULL, err: File::NULL)
+      else
+        run_cmd!("launchctl", "load", path)
+      end
+    end
+
+    def run_cmd!(*argv)
+      ok = system(*argv)
+      return if ok
+
+      status = $?.nil? ? "unknown" : $?.exitstatus
+      warn "hive: command failed (exit #{status}): #{argv.join(" ")}"
+      raise Hive::Error, "service install command failed: #{argv.join(" ")}"
+    end
+
+    def template_binding(enable:)
+      OpenStructBinding.new(
+        binary_path: @binary_path,
+        binary_dir: File.dirname(@binary_path),
+        home: File.expand_path("~"),
+        launchd_label: LAUNCHD_LABEL,
+        run_at_load: enable,
+        enable: enable
+      )
+    end
+
+    # Minimal ERB binding without requiring ostruct.
+    class OpenStructBinding
+      def initialize(vars)
+        @vars = vars
+      end
+
+      def method_missing(name, *args)
+        return @vars[name] if args.empty? && @vars.key?(name)
+
+        super
+      end
+
+      def respond_to_missing?(name, include_private = false)
+        @vars.key?(name) || super
+      end
+
+      def get_binding
+        binding
+      end
+    end
+
+    def render_from_template(relative_erb, enable:)
+      root = Paths.services_root
+      candidates = [
+        File.join(root, relative_erb),
+        File.join(Paths.source_root, "share", "hive", "services", relative_erb)
+      ]
+      path = candidates.find { |p| File.file?(p) }
+      return nil unless path
+
+      erb = ERB.new(File.read(path), trim_mode: "-")
+      ctx = template_binding(enable: enable)
+      erb.result(ctx.get_binding)
+    end
+
+    def render_systemd(enable: true)
+      rendered = render_from_template(File.join("systemd", "hive-daemon.service.erb"), enable: enable)
+      return rendered if rendered
+
+      # Fallback if templates are missing from the install tree.
+      bin = @binary_path
+      <<~UNIT
+        [Unit]
+        Description=Hive auto-advancing dispatcher (ADR-024)
+        After=default.target
+        StartLimitBurst=3
+        StartLimitIntervalSec=300
+
+        [Service]
+        Type=simple
+        ExecStart=#{bin} daemon start
+        Restart=on-failure
+        RestartSec=30s
+        KillMode=mixed
+        TimeoutStopSec=900
+
+        [Install]
+        WantedBy=default.target
+      UNIT
+    end
+
+    def render_launchd(enable: true)
+      rendered = render_from_template(File.join("launchd", "hive-daemon.plist.erb"), enable: enable)
+      return rendered if rendered
+
+      bin = @binary_path
+      home = File.expand_path("~")
+      run_at = enable ? "true" : "false"
+      disabled = enable ? "" : "  <key>Disabled</key>\n  <true/>\n"
+      <<~PLIST
+        <?xml version="1.0" encoding="UTF-8"?>
+        <!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
+          "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
+        <plist version="1.0">
+        <dict>
+          <key>Label</key>
+          <string>#{LAUNCHD_LABEL}</string>
+          <key>ProgramArguments</key>
+          <array>
+            <string>/bin/sh</string>
+            <string>-c</string>
+            <string>[ -x "$0" ] || exit 0; exec "$0" "$@"</string>
+            <string>#{bin}</string>
+            <string>daemon</string>
+            <string>start</string>
+          </array>
+          <key>RunAtLoad</key>
+          <#{run_at}/>
+        #{disabled}  <key>KeepAlive</key>
+          <dict>
+            <key>SuccessfulExit</key>
+            <false/>
+          </dict>
+          <key>ThrottleInterval</key>
+          <integer>30</integer>
+          <key>StandardOutPath</key>
+          <string>#{home}/Library/Logs/hive-daemon.out.log</string>
+          <key>StandardErrorPath</key>
+          <string>#{home}/Library/Logs/hive-daemon.err.log</string>
+          <key>EnvironmentVariables</key>
+          <dict>
+            <key>PATH</key>
+            <string>#{File.dirname(bin)}:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
+          </dict>
+        </dict>
+        </plist>
+      PLIST
+    end
+  end
+end
