+  def teardown
+    ENV["HOME"] = @prev_home
+    ENV["HIVE_HOME"] = @prev_hive_home
+    @prev_xdg.each { |k, v| v.nil? ? ENV.delete(k) : ENV[k] = v }
+  end
+
+  def with_stubbed_home
+    Dir.mktmpdir("hive-paths-home") do |home|
+      ENV["HOME"] = home
+      ENV.delete("HIVE_HOME")
+      %w[XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME XDG_CACHE_HOME HIVE_SHARE_ROOT HIVE_PREFIX].each { |k| ENV.delete(k) }
+      yield home
+    end
+  end
+
+  def test_default_config_path_is_xdg
+    with_stubbed_home do |home|
+      assert_equal File.join(home, ".config", "hive", "config.yml"), Hive::Paths.global_config_path
+      assert_equal File.join(home, ".config", "hive"), Hive::Paths.config_root
+      assert_equal File.join(home, ".local", "share", "hive"), Hive::Paths.data_root
+      assert_equal File.join(home, ".local", "state", "hive"), Hive::Paths.state_root
+      assert_equal File.join(home, ".cache", "hive"), Hive::Paths.cache_root
+      assert_equal File.join(home, ".local", "state", "hive", "logs"), Hive::Paths.log_root
+      assert_equal File.join(home, ".local", "bin"), Hive::Paths.bin_root
+    end
+  end
+
+  def test_xdg_env_overrides
+    with_stubbed_home do |_home|
+      ENV["XDG_CONFIG_HOME"] = "/tmp/xdg-config-#{Process.pid}"
+      ENV["XDG_DATA_HOME"] = "/tmp/xdg-data-#{Process.pid}"
+      ENV["XDG_STATE_HOME"] = "/tmp/xdg-state-#{Process.pid}"
+      ENV["XDG_CACHE_HOME"] = "/tmp/xdg-cache-#{Process.pid}"
+
+      assert_equal "/tmp/xdg-config-#{Process.pid}/hive", Hive::Paths.config_root
+      assert_equal "/tmp/xdg-data-#{Process.pid}/hive", Hive::Paths.data_root
+      assert_equal "/tmp/xdg-state-#{Process.pid}/hive", Hive::Paths.state_root
+      assert_equal "/tmp/xdg-cache-#{Process.pid}/hive", Hive::Paths.cache_root
+    end
+  end
+
+  def test_hive_home_uses_legacy_single_directory
+    Dir.mktmpdir("hive-legacy") do |dir|
+      ENV["HIVE_HOME"] = dir
+      assert Hive::Paths.legacy_home?
+      assert_equal dir, Hive::Paths.hive_home
+      assert_equal dir, Hive::Paths.config_root
+      assert_equal File.join(dir, "config.yml"), Hive::Paths.global_config_path
+      assert_equal File.join(dir, "logs"), Hive::Paths.log_root
+      assert_equal File.join(dir, ".daemon.pid"), Hive::Paths.daemon_pid_file
+      assert_equal File.join(dir, "logs", "daemon.log"), Hive::Paths.daemon_log_file
+      assert_equal File.join(dir, ".bot.pid"), Hive::Paths.bot_pid_file
+    end
+  end
+
+  def test_config_global_config_path_matches_paths
+    with_tmp_global_config do |home|
+      assert_equal File.join(home, "config.yml"), Hive::Config.global_config_path
+    end
+  end
+
+  def test_migration_copies_legacy_config_when_xdg_missing
+    with_stubbed_home do |home|
+      legacy_dir = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy_dir)
+      legacy = File.join(legacy_dir, "config.yml")
+      File.write(legacy, { "registered_projects" => [ { "name" => "demo", "path" => "/tmp/demo" } ] }.to_yaml)
+
+      assert_equal File.join(home, "Dev", "hive"), Hive::Paths.legacy_home_path
+
+      err = capture_io do
+        projects = Hive::Config.registered_projects
+        assert_equal 1, projects.size
+        assert_equal "demo", projects.first["name"]
+      end
+
+      xdg_cfg = File.join(home, ".config", "hive", "config.yml")
+      assert File.exist?(xdg_cfg), "expected migrated config at #{xdg_cfg}"
+      assert File.exist?(legacy), "migration must copy, not move"
+      assert_match(/migrated global config/, err.last)
+    end
+  end
+
+  def test_migration_prefers_existing_xdg_over_legacy
+    with_stubbed_home do |home|
+      legacy_dir = File.join(home, "Dev", "hive")
+      FileUtils.mkdir_p(legacy_dir)
+      File.write(File.join(legacy_dir, "config.yml"),
+                 { "registered_projects" => [ { "name" => "legacy", "path" => "/tmp/legacy" } ] }.to_yaml)
+
+      xdg_dir = File.join(home, ".config", "hive")
+      FileUtils.mkdir_p(xdg_dir)
+      File.write(File.join(xdg_dir, "config.yml"),
+                 { "registered_projects" => [ { "name" => "xdg", "path" => "/tmp/xdg" } ] }.to_yaml)
+
+      projects = Hive::Config.registered_projects
+      assert_equal 1, projects.size
+      assert_equal "xdg", projects.first["name"]
+    end
+  end
+
+  def test_bot_defaults_use_state_paths_under_xdg
+    with_stubbed_home do |home|
+      defaults = Hive::Config.global_bot_defaults
+      assert_equal File.join(home, ".local", "state", "hive", ".bot.pid"), defaults["pid_file"]
+      assert_equal File.join(home, ".local", "state", "hive", "logs", "bot.log"), defaults["log_file"]
+      assert_equal File.join(home, ".local", "state", "hive", ".bot.last_seen_update_id"),
+                   defaults["last_seen_state_file"]
+    end
+  end
+
+  def test_templates_root_prefers_packaged_share
+    with_stubbed_home do |home|
+      share = File.join(home, "share-pack")
+      templates = File.join(share, "templates")
+      FileUtils.mkdir_p(templates)
+      File.write(File.join(templates, "idea.md.erb"), "packaged\n")
+      ENV["HIVE_SHARE_ROOT"] = share
+
+      assert_equal templates, Hive::Paths.templates_root
+      assert_equal File.join(templates, "idea.md.erb"), Hive::Paths.resolve_template("idea.md.erb")
+      assert_equal "packaged\n", File.read(Hive::Paths.resolve_template("idea.md.erb"))
+    end
+  end
+
+  def test_templates_root_falls_back_to_source_tree
+    with_stubbed_home do
+      ENV.delete("HIVE_SHARE_ROOT")
