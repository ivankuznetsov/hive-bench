+    @prev_hive_home = ENV["HIVE_HOME"]
+    @prev_xdg = %w[XDG_CONFIG_HOME XDG_DATA_HOME XDG_STATE_HOME XDG_CACHE_HOME HIVE_SHARE_ROOT HIVE_PREFIX].to_h { |k| [ k, ENV[k] ] }
