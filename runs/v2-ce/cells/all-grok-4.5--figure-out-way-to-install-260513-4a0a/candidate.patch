+      assert File.directory?(root)
+      assert File.exist?(File.join(root, "project_config.yml.erb"))
+    end
+  end
+
+  def test_register_project_writes_under_xdg_when_no_hive_home
+    with_stubbed_home do |home|
+      Dir.mktmpdir("proj") do |proj|
+        entry = Hive::Config.register_project(name: "p1", path: proj)
+        assert_equal "p1", entry["name"]
+        cfg = File.join(home, ".config", "hive", "config.yml")
