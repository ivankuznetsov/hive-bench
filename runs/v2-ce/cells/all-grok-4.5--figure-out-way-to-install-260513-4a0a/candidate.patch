@@ -0,0 +1,72 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/install_channel"
+
+class InstallChannelTest < Minitest::Test
+  include HiveTestHelper
+
+  def setup
+    @prev = ENV["HIVE_INSTALL_CHANNEL"]
+  end
+
+  def teardown
+    @prev.nil? ? ENV.delete("HIVE_INSTALL_CHANNEL") : ENV["HIVE_INSTALL_CHANNEL"] = @prev
+  end
+
+  def test_env_override_wins
+    ENV["HIVE_INSTALL_CHANNEL"] = "brew"
+    assert_equal "brew", Hive::InstallChannel.detect
+  end
+
+  def test_marker_file_detection
+    with_tmp_global_config do |home|
+      ENV.delete("HIVE_INSTALL_CHANNEL")
+      # data_root under HIVE_HOME legacy layout is hive_home itself
+      path = File.join(home, "install-channel")
+      File.write(path, "channel=bash\nversion=v0.1.0\n")
+      assert_equal "bash", Hive::InstallChannel.detect
+      marker = Hive::InstallChannel.read_marker
+      assert_equal "bash", marker["channel"]
+      assert_equal "v0.1.0", marker["version"]
+    end
+  end
+
+  def test_write_marker
+    with_tmp_global_config do |home|
+      path = Hive::InstallChannel.write_marker!(channel: "aur", version: "v0.1.0", platform: "linux-x86_64")
+      assert File.exist?(path)
+      assert_equal "aur", Hive::InstallChannel.read_marker["channel"]
+      assert_equal File.join(home, "install-channel"), path
+    end
+  end
+
+  def test_invalid_channel_rejected
+    with_tmp_global_config do
+      assert_raises(ArgumentError) { Hive::InstallChannel.write_marker!(channel: "nope") }
+    end
+  end
+
+  def test_brew_detects_cellar_path
+    ENV.delete("HIVE_INSTALL_CHANNEL")
+    path = "/opt/homebrew/Cellar/hive/0.1.0/bin/hive"
+    assert Hive::InstallChannel.brew_install?(path)
+  end
+
+  def test_brew_detects_opt_hive_path
+    ENV.delete("HIVE_INSTALL_CHANNEL")
+    path = "/opt/homebrew/opt/hive/bin/hive"
+    assert Hive::InstallChannel.brew_install?(path)
+  end
+
+  def test_brew_rejects_bare_prefix_path
+    ENV.delete("HIVE_INSTALL_CHANNEL")
+    # Manual install under /usr/local (common brew --prefix on Intel) must not
+    # be treated as Homebrew formula ownership.
+    path = "/usr/local/bin/hive"
+    refute Hive::InstallChannel.brew_install?(path)
+
+    path = "/usr/local/share/hive/bin/hive"
+    refute Hive::InstallChannel.brew_install?(path)
+  end
+end
