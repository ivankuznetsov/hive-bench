index 00000000..dd23d53d
--- /dev/null
+++ b/test/packaging/install_lib_test.sh
@@ -0,0 +1,49 @@
+#!/usr/bin/env bash
+# Lightweight shell tests for packaging/install_lib.sh (no bats required).
+set -euo pipefail
+ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+# shellcheck source=../../packaging/install_lib.sh
+. "$ROOT/packaging/install_lib.sh"
+
+fail() { echo "FAIL: $*" >&2; exit 1; }
+pass() { echo "ok: $*"; }
+
+# Platform mapping should return something or unsupported on this host
+plat="$(hive_map_platform || true)"
+if [[ -n "$plat" && "$plat" != "unsupported" ]]; then
+  pass "hive_map_platform → $plat"
+else
+  # Alpine etc.
+  pass "hive_map_platform unsupported on this host (ok for non-tier-1)"
+fi
+
+# choose command name with clean PATH-ish: no hive → hive
+BIN="$(mktemp -d)"
+export PATH="$BIN:/usr/bin:/bin"
+# Ensure no hive in BIN
+cmd="$(hive_choose_command_name "$BIN")"
+[[ "$cmd" == "hive" ]] || fail "expected hive, got $cmd"
+pass "clean path chooses hive"
+
+# Collision: fake apache hive
+cat >"$BIN/hive" <<'EOF'
+#!/bin/sh
+echo "Apache Hive 3.1.3"
+EOF
+chmod +x "$BIN/hive"
+cmd="$(hive_choose_command_name "$HOME/.local/bin")"
+[[ "$cmd" == "hv" ]] || fail "expected hv on apache collision, got $cmd"
+pass "apache hive collision → hv"
+
+# Our hive version pattern
+cat >"$BIN/hive" <<'EOF'
+#!/bin/sh
+echo "0.1.0"
+EOF
+chmod +x "$BIN/hive"
+cmd="$(hive_choose_command_name "$BIN")"
+[[ "$cmd" == "hive" ]] || fail "expected hive when ours, got $cmd"
+pass "our hive keeps name hive"
+
+rm -rf "$BIN"
+echo "all install_lib tests passed"
