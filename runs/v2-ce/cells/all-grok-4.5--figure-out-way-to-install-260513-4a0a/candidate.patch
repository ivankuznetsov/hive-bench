@@ -0,0 +1,191 @@
+name: Release
+
+on:
+  push:
+    tags:
+      - "v*"
+
+permissions:
+  contents: write
+
+jobs:
+  test:
+    name: rake test before package
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - run: bundle exec rake test
+
+  package-linux:
+    name: package linux-x86_64
+    needs: test
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Build tarball
+        run: |
+          chmod +x packaging/scripts/build_tarball.sh
+          packaging/scripts/build_tarball.sh \
+            --platform linux-x86_64 \
+            --version "${GITHUB_REF_NAME}" \
+            --out dist \
+            --sums
+      - name: Stage install scripts
+        run: |
+          cp packaging/install.sh dist/install.sh
+          cp packaging/install_lib.sh dist/install_lib.sh
+          chmod +x dist/install.sh
+      - name: Clean-PATH smoke (no system Ruby)
+        run: |
+          set -euo pipefail
+          EXTRACT="$(mktemp -d)"
+          HOME_SMOKE="$(mktemp -d)"
+          tar -xzf dist/hive-*-linux-x86_64.tar.gz -C "$EXTRACT"
+          # Confirm embed is present and PATH has no ruby
+          test -x "$EXTRACT/hive/runtime/bin/ruby"
+          env -i PATH="/usr/bin:/bin" HOME="$HOME_SMOKE" HIVE_PREFIX="$EXTRACT/hive" \
+            "$EXTRACT/hive/bin/hive" --version | grep -E '^[0-9]+\.[0-9]+\.[0-9]+'
+          env -i PATH="/usr/bin:/bin" HOME="$HOME_SMOKE" \
+            HIVE_PREFIX="$EXTRACT/hive" HIVE_SHARE_ROOT="$EXTRACT/hive/share/hive" \
+            "$EXTRACT/hive/runtime/bin/ruby" -I"$EXTRACT/hive/lib" -e '
+              require "hive/paths"
+              path = Hive::Paths.resolve_template("project_config.yml.erb")
+              abort "missing #{path}" unless File.file?(path)
+              puts "template ok: #{path}"
+            '
+          rm -rf "$EXTRACT" "$HOME_SMOKE"
+      - uses: actions/upload-artifact@v4
+        with:
+          name: dist-linux-x86_64
+          path: dist/*
+
+  package-darwin-arm64:
+    name: package darwin-arm64
+    needs: test
+    runs-on: macos-14
+    steps:
+      - uses: actions/checkout@v6
+      - uses: ruby/setup-ruby@v1
+        with:
+          ruby-version: "3.4"
+          bundler-cache: true
+      - name: Build tarball
+        run: |
+          chmod +x packaging/scripts/build_tarball.sh
+          packaging/scripts/build_tarball.sh \
+            --platform darwin-arm64 \
+            --version "${GITHUB_REF_NAME}" \
+            --out dist \
+            --sums
+      - name: Clean-PATH smoke (no system Ruby)
+        run: |
+          set -euo pipefail
+          EXTRACT="$(mktemp -d)"
+          HOME_SMOKE="$(mktemp -d)"
+          tar -xzf dist/hive-*-darwin-arm64.tar.gz -C "$EXTRACT"
+          test -x "$EXTRACT/hive/runtime/bin/ruby"
+          env -i PATH="/usr/bin:/bin" HOME="$HOME_SMOKE" HIVE_PREFIX="$EXTRACT/hive" \
+            "$EXTRACT/hive/bin/hive" --version | grep -E '^[0-9]+\.[0-9]+\.[0-9]+'
+          env -i PATH="/usr/bin:/bin" HOME="$HOME_SMOKE" \
+            HIVE_PREFIX="$EXTRACT/hive" HIVE_SHARE_ROOT="$EXTRACT/hive/share/hive" \
+            "$EXTRACT/hive/runtime/bin/ruby" -I"$EXTRACT/hive/lib" -e '
+              require "hive/paths"
+              path = Hive::Paths.resolve_template("project_config.yml.erb")
+              abort "missing #{path}" unless File.file?(path)
+              puts "template ok: #{path}"
+            '
+          rm -rf "$EXTRACT" "$HOME_SMOKE"
+      - uses: actions/upload-artifact@v4
+        with:
+          name: dist-darwin-arm64
+          path: dist/*
+
+  publish:
+    name: GitHub Release
+    needs: [package-linux, package-darwin-arm64]
+    runs-on: ubuntu-22.04
+    steps:
+      - uses: actions/checkout@v6
+      - uses: actions/download-artifact@v4
+        with:
+          path: artifacts
+      - name: Assemble dist
+        run: |
+          mkdir -p dist
+          cp -a artifacts/dist-linux-x86_64/* dist/
+          cp -a artifacts/dist-darwin-arm64/* dist/
+          # Merge SHA256SUMS
+          cat artifacts/dist-linux-x86_64/SHA256SUMS artifacts/dist-darwin-arm64/SHA256SUMS > dist/SHA256SUMS
+          cp packaging/install.sh dist/install.sh
+          cp packaging/install_lib.sh dist/install_lib.sh
+          chmod +x dist/install.sh packaging/scripts/bump_package_metadata.sh
+          ls -la dist
+      - name: Bump Homebrew formula + AUR PKGBUILD with real checksums
+        run: |
+          packaging/scripts/bump_package_metadata.sh \
+            --dist dist \
+            --version "${GITHUB_REF_NAME}" \
+            --out-dir dist/packaging
+          # Also refresh in-tree staging copies attached to the release for maintainers
+          cp dist/packaging/homebrew/hive.rb dist/hive.rb
+          cp dist/packaging/aur/hive-bin/PKGBUILD dist/PKGBUILD
+          test -f dist/packaging/aur/hive-bin/hive-bin.install && \
+            cp dist/packaging/aur/hive-bin/hive-bin.install dist/hive-bin.install || true
+          # Placeholders must be gone
+          ! grep -q REPLACE_WITH_RELEASE dist/hive.rb
+          ! grep -q REPLACE_WITH_RELEASE dist/PKGBUILD
+          ! grep -q SKIP dist/PKGBUILD
+      - name: Push Homebrew tap (optional)
+        env:
+          HOMEBREW_TAP_TOKEN: ${{ secrets.HOMEBREW_TAP_TOKEN }}
+        run: |
+          set -euo pipefail
+          if [[ -z "${HOMEBREW_TAP_TOKEN:-}" ]]; then
+            echo "HOMEBREW_TAP_TOKEN not set — formula with real sha256 is attached to the release as hive.rb"
+            echo "Manual: copy dist/hive.rb → ivankuznetsov/homebrew-hive Formula/hive.rb"
+            exit 0
+          fi
+          TAP_DIR="$(mktemp -d)"
+          git clone --depth 1 \
+            "https://x-access-token:${HOMEBREW_TAP_TOKEN}@github.com/ivankuznetsov/homebrew-hive.git" \
+            "$TAP_DIR"
+          mkdir -p "$TAP_DIR/Formula"
+          cp dist/hive.rb "$TAP_DIR/Formula/hive.rb"
+          cd "$TAP_DIR"
+          git config user.name "hive-release-bot"
+          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
+          git add Formula/hive.rb
+          if git diff --cached --quiet; then
+            echo "tap formula unchanged"
+          else
+            git commit -m "hive ${GITHUB_REF_NAME}"
+            git push origin HEAD:main
+            echo "pushed Formula/hive.rb to ivankuznetsov/homebrew-hive"
+          fi
+      - name: AUR package note
+        run: |
+          cat <<'EOF'
+          AUR hive-bin is not auto-pushed (requires AUR SSH credentials).
+          Release assets include PKGBUILD with real sha256sums — publish with:
+            # from a checkout of the AUR hive-bin package
+            cp dist/PKGBUILD dist/hive-bin.install .
+            makepkg --printsrcinfo > .SRCINFO
+            git commit -am "hive ${GITHUB_REF_NAME}" && git push
+          EOF
+      - name: Create GitHub Release
+        uses: softprops/action-gh-release@v2
+        with:
+          files: |
+            dist/*
+            dist/packaging/homebrew/hive.rb
+            dist/packaging/aur/hive-bin/**
+          generate_release_notes: true
+          fail_on_unmatched_files: true
