+# Maintainer: Ivan Kuznetsov <ivan@ikuznetsov.com>
+# AUR package name is always hive-bin (prebuilt). Source package hive-git is out of scope for v1.
+# On each release, packaging/scripts/bump_package_metadata.sh rewrites pkgver + sha256sums
+# from the published SHA256SUMS file. Staging placeholders must be replaced before AUR push.
+pkgname=hive-bin
+pkgver=0.1.0
+pkgrel=1
+pkgdesc="Multi-agent software pipeline from idea to merge-ready PR (prebuilt)"
+arch=('x86_64')
+url="https://github.com/ivankuznetsov/hive"
+license=('MIT')
+depends=()
+optdepends=(
+  'git: required for project workflows'
+  'github-cli: PR and GitHub integration (gh)'
+  'jq: JSON tooling for agent/scripted use'
+  'bash: shell scripts and install helpers'
+)
+provides=('hive')
+conflicts=('hive')
+options=('!strip')
+# Single source: tarball only. sha256sums comes from release SHA256SUMS (not SKIP).
+source=(
+  "hive-v${pkgver}-linux-x86_64.tar.gz::https://github.com/ivankuznetsov/hive/releases/download/v${pkgver}/hive-v${pkgver}-linux-x86_64.tar.gz"
+)
+# Placeholder until release rewrite: packaging/scripts/bump_package_metadata.sh
+sha256sums=(
+  'REPLACE_WITH_RELEASE_SHA256_LINUX_X86_64'
+)
+
+package() {
+  cd "${srcdir}/hive"
+  install -d "${pkgdir}/usr/lib/hive"
+  cp -a . "${pkgdir}/usr/lib/hive/"
+  install -d "${pkgdir}/usr/bin"
+  # Always install the user-facing command as `hive`. Package name remains hive-bin.
+  ln -s /usr/lib/hive/bin/hive "${pkgdir}/usr/bin/hive"
+  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
+
+  # Channel marker for `hive update` (system-wide data dir)
+  install -d "${pkgdir}/usr/lib/hive"
+  printf 'channel=aur\nversion=v%s\nplatform=linux-x86_64\n' "$pkgver" \
+    >"${pkgdir}/usr/lib/hive/install-channel"
+}
+
+# post_install message is in hive-bin.install when present
