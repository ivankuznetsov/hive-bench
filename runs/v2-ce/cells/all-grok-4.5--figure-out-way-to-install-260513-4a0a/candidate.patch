@@ -0,0 +1,82 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/service_installer"
+require "stringio"
+
+class ServiceInstallerTest < Minitest::Test
+  def test_render_systemd_uses_absolute_binary
+    installer = Hive::ServiceInstaller.new(binary_path: "/opt/hive/bin/hive", dry_run: true, output: StringIO.new)
+    unit = installer.send(:render_systemd)
+    assert_match(%r{ExecStart=/opt/hive/bin/hive daemon start}, unit)
+    refute_match(/ExecStart=hive /, unit)
+  end
+
+  def test_render_launchd_uses_absolute_binary
+    installer = Hive::ServiceInstaller.new(binary_path: "/Users/me/.local/bin/hive", dry_run: true, output: StringIO.new)
+    plist = installer.send(:render_launchd, enable: true)
+    assert_includes plist, "/Users/me/.local/bin/hive"
+    assert_includes plist, "local.hive-daemon"
+    assert_match(%r{<key>RunAtLoad</key>\s*<true/>}, plist)
+    refute_match(%r{<key>Disabled</key>}, plist)
+  end
+
+  def test_render_launchd_register_only_stays_stopped
+    installer = Hive::ServiceInstaller.new(binary_path: "/Users/me/.local/bin/hive", dry_run: true, output: StringIO.new)
+    plist = installer.send(:render_launchd, enable: false)
+    assert_match(%r{<key>RunAtLoad</key>\s*<false/>}, plist)
+    assert_match(%r{<key>Disabled</key>\s*<true/>}, plist)
+  end
+
+  def test_render_uses_share_templates_when_present
+    installer = Hive::ServiceInstaller.new(binary_path: "/opt/hive/bin/hive", dry_run: true, output: StringIO.new)
+    unit = installer.send(:render_systemd)
+    # Template body (no long sample comment header from examples/)
+    assert_match(/Description=Hive auto-advancing dispatcher/, unit)
+    assert_match(%r{ExecStart=/opt/hive/bin/hive daemon start}, unit)
+  end
+
+  def test_prompt_mode_skip_on_non_tty
+    input = StringIO.new("1\n")
+    def input.tty? = false
+    assert_equal :skip, Hive::ServiceInstaller.prompt_mode(input: input, output: StringIO.new)
+  end
+
+  def test_prompt_mode_maps_answers
+    {
+      "1\n" => :enable_start,
+      "\n" => :enable_start,
+      "2\n" => :register_only,
+      "3\n" => :skip,
+      "nope\n" => :skip
+    }.each do |stdin, expected|
+      input = StringIO.new(stdin)
+      def input.tty? = true
+      assert_equal expected, Hive::ServiceInstaller.prompt_mode(input: input, output: StringIO.new),
+                   "stdin=#{stdin.inspect}"
+    end
+  end
+
+  def test_dry_run_install_does_not_write
+    Dir.mktmpdir do |dir|
+      # Point home at tmp so we don't touch the real systemd dir if code paths write
+      prev = ENV["HOME"]
+      ENV["HOME"] = dir
+      out = StringIO.new
+      installer = Hive::ServiceInstaller.new(binary_path: "#{dir}/bin/hive", dry_run: true, output: out)
+      FileUtils.mkdir_p(File.join(dir, "bin"))
+      File.write(File.join(dir, "bin", "hive"), "#!/bin/sh\n")
+      FileUtils.chmod(0o755, File.join(dir, "bin", "hive"))
+      result = installer.install(mode: :register_only)
+      assert_equal false, result.removed
+      # dry_run should not create the unit file
+      unit = File.join(dir, ".config", "systemd", "user", "hive-daemon.service")
+      plist = File.join(dir, "Library", "LaunchAgents", "local.hive-daemon.plist")
+      refute File.exist?(unit)
+      refute File.exist?(plist)
+      assert_match(/dry-run/, out.string)
+    ensure
+      ENV["HOME"] = prev
+    end
+  end
+end
