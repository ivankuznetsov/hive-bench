index 00000000..29e2c4d0
--- /dev/null
+++ b/packaging/scripts/bump_package_metadata.sh
@@ -0,0 +1,172 @@
+#!/usr/bin/env bash
+# Rewrite Homebrew formula + AUR PKGBUILD with real version/sha256 from a
+# release dist/ tree (expects SHA256SUMS + hive-v*-*.tar.gz assets).
+#
+# Usage:
+#   packaging/scripts/bump_package_metadata.sh --dist dist [--version v0.1.0]
+#                                              [--out-dir dist/packaging]
+#
+# Writes:
+#   <out-dir>/homebrew/hive.rb
+#   <out-dir>/aur/hive-bin/PKGBUILD
+#   <out-dir>/aur/hive-bin/hive-bin.install  (copied when present)
+set -euo pipefail
+
+ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+DIST=""
+VERSION=""
+OUT_DIR=""
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --dist) DIST="$2"; shift 2 ;;
+    --version) VERSION="$2"; shift 2 ;;
+    --out-dir) OUT_DIR="$2"; shift 2 ;;
+    -h|--help)
+      sed -n '2,16p' "$0"
+      exit 0
+      ;;
+    *) echo "unknown arg: $1" >&2; exit 2 ;;
+  esac
+done
+
+[[ -n "$DIST" ]] || { echo "usage: $0 --dist DIR" >&2; exit 2; }
+DIST="$(cd "$DIST" && pwd)"
+SUMS="$DIST/SHA256SUMS"
+[[ -f "$SUMS" ]] || { echo "missing $SUMS" >&2; exit 1; }
+
+if [[ -z "$VERSION" ]]; then
+  # Infer from first hive-v* tarball name
+  sample="$(grep -E 'hive-v[0-9].*\.tar\.gz$' "$SUMS" | head -1 | awk '{print $2}')"
+  [[ -n "$sample" ]] || { echo "no hive-v* entries in SHA256SUMS" >&2; exit 1; }
+  VERSION="$(echo "$sample" | sed -E 's/^hive-(v[0-9][^-]*)-.*/\1/')"
+fi
+VERSION="${VERSION#v}"
+TAG="v${VERSION}"
+
+sum_for() {
+  local asset="$1"
+  local line
+  line="$(grep -F "$asset" "$SUMS" | head -1 || true)"
+  [[ -n "$line" ]] || { echo "no SHA256SUMS entry for $asset" >&2; exit 1; }
+  echo "$line" | awk '{print $1}'
+}
+
+DARWIN_ARM64_ASSET="hive-${TAG}-darwin-arm64.tar.gz"
+LINUX_X86_ASSET="hive-${TAG}-linux-x86_64.tar.gz"
+
+SHA_DARWIN_ARM64="$(sum_for "$DARWIN_ARM64_ASSET")"
+SHA_LINUX_X86="$(sum_for "$LINUX_X86_ASSET")"
+
+OUT_DIR="${OUT_DIR:-$DIST/packaging}"
+mkdir -p "$OUT_DIR/homebrew" "$OUT_DIR/aur/hive-bin"
+
+# --- Homebrew formula (tier-1: darwin-arm64 + linux-x86_64 only) ---
+cat >"$OUT_DIR/homebrew/hive.rb" <<RUBY
+# frozen_string_literal: true
+
+# Generated by packaging/scripts/bump_package_metadata.sh for ${TAG}.
+# Publish to https://github.com/ivankuznetsov/homebrew-hive as Formula/hive.rb
+class Hive < Formula
+  desc "Multi-agent software pipeline from idea to merge-ready PR"
+  homepage "https://github.com/ivankuznetsov/hive"
+  version "${VERSION}"
+  license "MIT"
+
+  on_macos do
+    on_arm do
+      url "https://github.com/ivankuznetsov/hive/releases/download/${TAG}/${DARWIN_ARM64_ASSET}"
+      sha256 "${SHA_DARWIN_ARM64}"
+    end
+  end
+
+  on_linux do
+    on_intel do
+      url "https://github.com/ivankuznetsov/hive/releases/download/${TAG}/${LINUX_X86_ASSET}"
+      sha256 "${SHA_LINUX_X86}"
+    end
+  end
+
+  def install
+    # Tarball root is \`hive/\` with bin/, lib/, share/, etc.
+    prefix.install Dir["*"]
+  end
+
+  def caveats
+    <<~EOS
+      Hive was installed from the ivankuznetsov/hive tap (not homebrew-core).
+
+      Next steps:
+        hive doctor
+        cd your-project && hive init
+
+      \`hive init\` can register a user-level launchd service for the daemon
+      (you will be prompted). Skills for Claude Code / Codex / Pi are a
+      separate marketplace package and are not installed by this formula.
+
+      If \`hive\` on PATH is Apache Hive instead of this tool, reorder PATH
+      or use the bash installer which falls back to the \`hv\` command name.
+
+      Update with:  brew upgrade ivankuznetsov/hive/hive
+      Or:           hive update
+    EOS
+  end
+
+  test do
+    assert_match version.to_s, shell_output("#{bin}/hive --version")
+  end
+end
+RUBY
+
+# --- AUR PKGBUILD (single source + real sha256) ---
+cat >"$OUT_DIR/aur/hive-bin/PKGBUILD" <<PKG
+# Maintainer: Ivan Kuznetsov <ivan@ikuznetsov.com>
+# AUR package name is always hive-bin (prebuilt). Source package hive-git is out of scope for v1.
+# Generated by packaging/scripts/bump_package_metadata.sh for ${TAG}.
+pkgname=hive-bin
+pkgver=${VERSION}
+pkgrel=1
+pkgdesc="Multi-agent software pipeline from idea to merge-ready PR (prebuilt)"
+arch=('x86_64')
+url="https://github.com/ivankuznetsov/hive"
+license=('MIT')
+depends=()
+optdepends=(
+  'git: required for project workflows'
+  'github-cli: PR and GitHub integration (gh)'
+  'jq: JSON tooling for agent/scripted use'
+  'bash: shell scripts and install helpers'
+)
+provides=('hive')
+conflicts=('hive')
+options=('!strip')
+source=(
+  "hive-v\${pkgver}-linux-x86_64.tar.gz::https://github.com/ivankuznetsov/hive/releases/download/v\${pkgver}/hive-v\${pkgver}-linux-x86_64.tar.gz"
+)
+sha256sums=(
+  '${SHA_LINUX_X86}'
+)
+
+package() {
+  cd "\${srcdir}/hive"
+  install -d "\${pkgdir}/usr/lib/hive"
+  cp -a . "\${pkgdir}/usr/lib/hive/"
+  install -d "\${pkgdir}/usr/bin"
+  # Always install the user-facing command as \`hive\`. Package name remains hive-bin.
+  ln -s /usr/lib/hive/bin/hive "\${pkgdir}/usr/bin/hive"
+  install -Dm644 LICENSE "\${pkgdir}/usr/share/licenses/\${pkgname}/LICENSE"
+
+  # Channel marker for \`hive update\` (system-wide data dir)
+  install -d "\${pkgdir}/usr/lib/hive"
+  printf 'channel=aur\\nversion=v%s\\nplatform=linux-x86_64\\n' "\$pkgver" \\
+    >"\${pkgdir}/usr/lib/hive/install-channel"
+}
+PKG
+
+if [[ -f "$ROOT/packaging/aur/hive-bin/hive-bin.install" ]]; then
+  cp "$ROOT/packaging/aur/hive-bin/hive-bin.install" "$OUT_DIR/aur/hive-bin/hive-bin.install"
+fi
+
+echo "hive: wrote $OUT_DIR/homebrew/hive.rb"
+echo "hive: wrote $OUT_DIR/aur/hive-bin/PKGBUILD"
+echo "hive: version=${VERSION} darwin-arm64=${SHA_DARWIN_ARM64:0:12}… linux-x86_64=${SHA_LINUX_X86:0:12}…"
diff --git a/share/hive/services/launchd/hive-daemon.plist b/share/hive/services/launchd/hive-daemon.plist
