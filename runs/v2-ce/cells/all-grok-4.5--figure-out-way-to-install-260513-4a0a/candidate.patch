index 00000000..abe93918
--- /dev/null
+++ b/test/unit/commands/uninstall_test.rb
@@ -0,0 +1,60 @@
+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/commands/uninstall"
+require "hive/install_channel"
+require "stringio"
+
+class UninstallCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  def setup
+    @prev = ENV["HIVE_INSTALL_CHANNEL"]
+  end
+
+  def teardown
+    @prev.nil? ? ENV.delete("HIVE_INSTALL_CHANNEL") : ENV["HIVE_INSTALL_CHANNEL"] = @prev
+  end
+
+  def test_default_keeps_state_and_config
+    with_tmp_global_config do |home|
+      ENV["HIVE_INSTALL_CHANNEL"] = "bash"
+      state = File.join(home, "logs")
+      FileUtils.mkdir_p(state)
+      File.write(File.join(state, "daemon.log"), "keep-me\n")
+      File.write(File.join(home, "install-channel"), "channel=bash\nversion=v0.1.0\ncommand=hive\n")
+
+      # Fake bash binary install under bin_root — stub Paths.bin_root via HOME
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(yes: true, output: out, stderr: StringIO.new, input: StringIO.new).call
+
+      assert File.exist?(File.join(home, "config.yml")), "config must be preserved"
+      assert File.exist?(File.join(state, "daemon.log")), "state/logs must be preserved"
+      refute File.exist?(File.join(home, "install-channel")), "marker should be removed"
+      assert_match(/Preserved by default/, out.string)
+    end
+  end
+
+  def test_brew_refuses_to_delete_binary
+    ENV["HIVE_INSTALL_CHANNEL"] = "brew"
+    out = StringIO.new
+    with_tmp_global_config do
+      Hive::Commands::Uninstall.new(yes: true, output: out, stderr: StringIO.new, input: StringIO.new).call
+      assert_match(/brew uninstall/, out.string)
+      assert_match(/refusing to delete/, out.string)
+    end
+  end
+
+  def test_purge_still_keeps_state
+    with_tmp_global_config do |home|
+      ENV["HIVE_INSTALL_CHANNEL"] = "bash"
+      FileUtils.mkdir_p(File.join(home, "logs"))
+      File.write(File.join(home, "logs", "keep.log"), "x\n")
+      File.write(File.join(home, "install-channel"), "channel=bash\n")
+      out = StringIO.new
+      Hive::Commands::Uninstall.new(purge: true, yes: true, output: out, stderr: StringIO.new, input: StringIO.new).call
+      assert File.exist?(File.join(home, "logs", "keep.log"))
+      assert File.exist?(File.join(home, "config.yml"))
+    end
+  end
+end
