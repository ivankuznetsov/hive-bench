diff --git a/lib/hive/install_channel.rb b/lib/hive/install_channel.rb
new file mode 100644
index 00000000..c2861cd8
--- /dev/null
+++ b/lib/hive/install_channel.rb
@@ -0,0 +1,167 @@
+# frozen_string_literal: true
+
+require "fileutils"
+require "hive/paths"
+
+module Hive
+  # Detect how this Hive binary was installed so `hive update` / `uninstall`
+  # can shell out to the right channel tool instead of self-mutating.
+  #
+  # Detection order:
+  #   1. ENV["HIVE_INSTALL_CHANNEL"]
+  #   2. Marker file (share/data install-channel)
+  #   3. Heuristics: Homebrew Cellar/opt ownership, pacman ownership, source tree
+  #   4. unknown
+  module InstallChannel
+    CHANNELS = %w[brew aur bash dev unknown].freeze
+    MARKER_KEYS = %w[channel version platform command installed_at].freeze
+
+    module_function
+
+    def detect(binary_path: nil)
+      env = ENV["HIVE_INSTALL_CHANNEL"].to_s.strip
+      return env if CHANNELS.include?(env)
+
+      from_marker = read_marker
+      return from_marker["channel"] if from_marker && CHANNELS.include?(from_marker["channel"])
+
+      binary_path ||= resolve_binary_path
+      return "brew" if brew_install?(binary_path)
+      return "aur" if aur_install?(binary_path)
+      return "bash" if bash_install?(binary_path)
+      return "dev" if dev_checkout?(binary_path)
+
+      "unknown"
+    end
+
+    def marker_path
+      candidates = [
+        Paths.install_channel_path,
+        File.join(Paths.data_root, "install-channel"),
+        File.join(Paths.source_root, "install-channel")
+      ]
+      prefix = ENV["HIVE_PREFIX"]
+      candidates.unshift(File.join(File.expand_path(prefix), "install-channel")) if prefix && !prefix.empty?
+      candidates.find { |p| File.file?(p) } || Paths.install_channel_path
+    end
+
+    def read_marker
+      path = marker_path
+      return nil unless File.file?(path)
+
+      data = {}
+      File.foreach(path) do |line|
+        line = line.strip
+        next if line.empty? || line.start_with?("#")
+        next unless line.include?("=")
+
+        k, v = line.split("=", 2)
+        data[k.strip] = v.strip
+      end
+      data
+    rescue StandardError
+      nil
+    end
+
+    def write_marker!(channel:, version: Hive::VERSION, platform: nil, command: "hive")
+      raise ArgumentError, "invalid channel #{channel.inspect}" unless CHANNELS.include?(channel.to_s)
+
+      path = Paths.install_channel_path
+      FileUtils.mkdir_p(File.dirname(path))
+      File.write(path, <<~MARKER)
+        channel=#{channel}
+        version=#{version}
+        platform=#{platform}
+        command=#{command}
+        installed_at=#{Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ")}
+      MARKER
+      path
+    end
+
+    def resolve_binary_path
+      # Prefer the running script path (packaged bin/hive or bin/hive from checkout)
+      if defined?($PROGRAM_NAME) && $PROGRAM_NAME && !$PROGRAM_NAME.empty?
+        prog = File.expand_path($PROGRAM_NAME)
+        return prog if File.exist?(prog)
+      end
+
+      found = `command -v hive 2>/dev/null`.to_s.strip
+      return found unless found.empty?
+
+      found = `command -v hv 2>/dev/null`.to_s.strip
+      return found unless found.empty?
+
+      nil
+    end
+
+    def brew_install?(binary_path)
+      return false if binary_path.nil? || binary_path.empty?
+
+      real = begin
+        File.realpath(binary_path)
+      rescue StandardError
+        binary_path
+      end
+
+      # Require Cellar formula ownership or the stable opt/hive symlink tree.
+      # Do NOT treat a bare `brew --prefix` match as brew — on Intel Mac that
+      # prefix is often /usr/local, which hosts many non-brew installs.
+      return true if real.include?("/Cellar/hive/")
+      return true if real.match?(%r{/(?:opt|homebrew|linuxbrew)/hive(?:/|$)})
+      return true if real.include?("/opt/homebrew/opt/hive/")
+      return true if real.include?("/homebrew/opt/hive/")
+      return true if real.include?("/linuxbrew/opt/hive/")
+
+      brew_prefix = `brew --prefix 2>/dev/null`.to_s.strip
+      return false if brew_prefix.empty?
+
+      prefix = File.expand_path(brew_prefix)
+      # Only opt/hive or Cellar/hive under the brew prefix — not arbitrary paths.
+      real == File.join(prefix, "opt", "hive", "bin", "hive") ||
+        real.start_with?(File.join(prefix, "opt", "hive", "")) ||
+        real.start_with?(File.join(prefix, "Cellar", "hive", ""))
+    end
+
+    def aur_install?(binary_path)
+      return false if binary_path.nil? || binary_path.empty?
+      return false unless File.exist?("/usr/bin/pacman")
+
+      out = `pacman -Qo #{shell_escape(binary_path)} 2>/dev/null`.to_s
+      out.include?("hive-bin") || out.include?(" is owned by hive-bin")
+    end
+
+    def bash_install?(binary_path)
+      marker = read_marker
+      return true if marker && marker["channel"] == "bash"
+      return false if binary_path.nil?
+
+      real = begin
+        File.realpath(binary_path)
+      rescue StandardError
+        binary_path
+      end
+      real.include?("/.local/share/hive/") || real.start_with?(File.join(Paths.data_root, ""))
+    end
+
+    def dev_checkout?(binary_path)
+      # Running from a git checkout of this repo (bundle exec / bin/hive)
+      root = Paths.source_root
+      return true if File.directory?(File.join(root, ".git")) && File.file?(File.join(root, "Gemfile"))
+
+      return false if binary_path.nil?
+
+      real = begin
+        File.realpath(binary_path)
+      rescue StandardError
+        binary_path
+      end
+      real.include?("/libexec/hive") == false && real.end_with?("/bin/hive") &&
+        File.file?(File.expand_path("../Gemfile", File.dirname(real)))
+    end
+
+    def shell_escape(str)
+      "'" + str.to_s.gsub("'", "'\\\\''") + "'"
+    end
+    private_class_method :shell_escape
+  end
+end
diff --git a/lib/hive/paths.rb b/lib/hive/paths.rb
new file mode 100644
index 00000000..cd11a800
--- /dev/null
+++ b/lib/hive/paths.rb
@@ -0,0 +1,209 @@
+# frozen_string_literal: true
+
+module Hive
+  # XDG-aware global path helpers for packaged and source installs.
+  #
+  # Resolution order for global roots:
+  #   1. If ENV["HIVE_HOME"] is set → legacy single-directory layout
+  #      (config at $HIVE_HOME/config.yml, logs under $HIVE_HOME/logs/).
+  #   2. Else use XDG base dirs under ~/.config, ~/.local/share,
+  #      ~/.local/state, ~/.cache (with standard XDG_* overrides).
+  #
+  # Project pipeline state stays at <project>/.hive-state/ — this module
+  # only covers the global control plane.
+  module Paths
+    INSTALL_CHANNEL_FILENAME = "install-channel".freeze
+
+    module_function
+
+    # Pre-XDG default install path. Expanded at call time so tests that
+    # stub ENV["HOME"] see the stubbed value.
+    def legacy_home_path
+      File.expand_path("~/Dev/hive")
+    end
+
+    # True when the operator (or tests) force the single-directory layout.
+    def legacy_home?
+      env = ENV["HIVE_HOME"]
+      !(env.nil? || env.empty?)
+    end
+
+    # Legacy single-directory home, or nil when using XDG.
+    def hive_home
+      return File.expand_path(ENV["HIVE_HOME"]) if legacy_home?
+
+      nil
+    end
+
+    # Directory that holds config.yml (and is created by register_project).
+    def config_root
+      if legacy_home?
+        hive_home
+      else
+        File.join(xdg_config_home, "hive")
+      end
+    end
+
+    def global_config_path
+      File.join(config_root, "config.yml")
+    end
+
+    # Packaged share assets (templates, service units, install metadata).
+    def data_root
+      if legacy_home?
+        hive_home
+      else
+        File.join(xdg_data_home, "hive")
+      end
+    end
+
+    # Runtime state: pid files, last-seen ids, structured logs.
+    def state_root
+      if legacy_home?
+        hive_home
+      else
+        File.join(xdg_state_home, "hive")
+      end
+    end
+
+    def cache_root
+      if legacy_home?
+        File.join(hive_home, "cache")
+      else
+        File.join(xdg_cache_home, "hive")
+      end
+    end
+
+    def log_root
+      if legacy_home?
+        File.join(hive_home, "logs")
+      else
+        File.join(state_root, "logs")
+      end
+    end
+
+    def bin_root
+      File.expand_path("~/.local/bin")
+    end
+
+    def daemon_pid_file
+      File.join(state_root, ".daemon.pid")
+    end
+
+    def daemon_log_file
+      File.join(log_root, "daemon.log")
+    end
+
+    def bot_pid_file
+      File.join(state_root, ".bot.pid")
+    end
+
+    def bot_log_file
+      File.join(log_root, "bot.log")
+    end
+
+    def bot_last_seen_file
+      File.join(state_root, ".bot.last_seen_update_id")
+    end
+
+    def install_channel_path
+      File.join(data_root, INSTALL_CHANNEL_FILENAME)
+    end
+
+    # Source-tree root for a development checkout (parent of lib/).
+    def source_root
+      File.expand_path("../..", __dir__)
+    end
+
+    # Packaged share dir shipped inside release tarballs (share/hive), or
+    # the env override used by installers / tests.
+    def packaged_share_root
+      env = ENV["HIVE_SHARE_ROOT"]
+      return File.expand_path(env) if env && !env.empty?
+
+      candidate = File.join(data_root, "share")
+      return candidate if File.directory?(candidate)
+
+      # When installed from a prefix tarball, share lives next to bin via
+      # HIVE_PREFIX or relative to the running binary's install prefix.
+      prefix = ENV["HIVE_PREFIX"]
+      if prefix && !prefix.empty?
+        share = File.join(File.expand_path(prefix), "share", "hive")
+        return share if File.directory?(share)
+      end
+
+      nil
+    end
+
+    # Built-in ERB templates: packaged share first, then source checkout.
+    def templates_root
+      packaged = packaged_share_root
+      if packaged
+        t = File.join(packaged, "templates")
+        return t if File.directory?(t)
+      end
+
+      # share/hive/templates under data_root (bash installer layout)
+      data_templates = File.join(data_root, "templates")
+      return data_templates if File.directory?(data_templates)
+
+      File.join(source_root, "templates")
+    end
+
+    # Service unit templates for systemd / launchd registration.
+    def services_root
+      packaged = packaged_share_root
+      if packaged
+        s = File.join(packaged, "services")
+        return s if File.directory?(s)
+      end
+
+      data_services = File.join(data_root, "services")
+      return data_services if File.directory?(data_services)
+
+      # Dev checkout: examples/ holds the hand-edited samples; share/services
+      # is the packaged copy (promoted by the packager).
+      share_services = File.join(source_root, "share", "hive", "services")
+      return share_services if File.directory?(share_services)
+
+      File.join(source_root, "examples")
+    end
+
+    def resolve_template(name)
+      path = File.join(templates_root, name)
+      return path if File.exist?(path)
+
+      # Fallback to source tree even when a partial share dir exists.
+      fallback = File.join(source_root, "templates", name)
+      return fallback if File.exist?(fallback)
+
+      path
+    end
+
+    def xdg_config_home
+      xdg("XDG_CONFIG_HOME", "~/.config")
+    end
+
+    def xdg_data_home
+      xdg("XDG_DATA_HOME", "~/.local/share")
+    end
+
+    def xdg_state_home
+      xdg("XDG_STATE_HOME", "~/.local/state")
+    end
+
+    def xdg_cache_home
+      xdg("XDG_CACHE_HOME", "~/.cache")
+    end
+
+    def xdg(env_key, default)
+      val = ENV[env_key]
+      if val && !val.empty?
+        File.expand_path(val)
+      else
+        File.expand_path(default)
+      end
+    end
+    private_class_method :xdg
+  end
+end
