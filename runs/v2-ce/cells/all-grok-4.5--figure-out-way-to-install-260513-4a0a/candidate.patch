+# frozen_string_literal: true
+
+require "test_helper"
+require "hive/commands/update"
+require "stringio"
+
+class UpdateCommandTest < Minitest::Test
+  include HiveTestHelper
+
+  def setup
+    @prev = ENV["HIVE_INSTALL_CHANNEL"]
+  end
+
+  def teardown
+    @prev.nil? ? ENV.delete("HIVE_INSTALL_CHANNEL") : ENV["HIVE_INSTALL_CHANNEL"] = @prev
+  end
+
+  def test_brew_dry_run_prints_brew_upgrade
+    ENV["HIVE_INSTALL_CHANNEL"] = "brew"
+    out = StringIO.new
+    Hive::Commands::Update.new(dry_run: true, output: out, stderr: StringIO.new).call
+    assert_match(/brew upgrade/, out.string)
+    assert_match(/channel=brew/, out.string)
+  end
+
+  def test_bash_dry_run_prints_install_script
+    ENV["HIVE_INSTALL_CHANNEL"] = "bash"
+    out = StringIO.new
+    Hive::Commands::Update.new(dry_run: true, output: out, stderr: StringIO.new).call
+    assert_match(/install\.sh/, out.string)
+  end
+
+  def test_unknown_raises_config_error
+    ENV["HIVE_INSTALL_CHANNEL"] = "unknown"
+    err = assert_raises(Hive::ConfigError) do
+      Hive::Commands::Update.new(output: StringIO.new, stderr: StringIO.new).call
+    end
+    assert_match(/unknown/i, err.message)
+  end
+
+  def test_check_does_not_mutate
+    ENV["HIVE_INSTALL_CHANNEL"] = "brew"
+    out = StringIO.new
+    Hive::Commands::Update.new(check: true, output: out, stderr: StringIO.new).call
+    assert_match(/--check/, out.string)
+    refute_match(/would run: brew upgrade/, out.string)
+  end
+
+  def test_dev_raises
+    ENV["HIVE_INSTALL_CHANNEL"] = "dev"
+    assert_raises(Hive::Error) do
+      Hive::Commands::Update.new(output: StringIO.new, stderr: StringIO.new).call
+    end
+  end
+end
