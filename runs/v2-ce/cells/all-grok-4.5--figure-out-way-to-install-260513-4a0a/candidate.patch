+# frozen_string_literal: true
+
+# Formula staging for the ivankuznetsov/hive tap (own tap; not homebrew-core).
+# Publish to https://github.com/ivankuznetsov/homebrew-hive as Formula/hive.rb
+# Release workflow rewrites sha256/version via
+# packaging/scripts/bump_package_metadata.sh and pushes the tap when
+# HOMEBREW_TAP_TOKEN is configured.
+#
+# Install:
+#   brew tap ivankuznetsov/hive
+#   brew install hive
+#
+# Class name Hive collides with nothing in Homebrew core today; the formula
+# name is `hive`. Apache Hive is a different project — if both are needed,
+# put this tap earlier on PATH or use the bash installer `hv` fallback.
+#
+# Tier-1 platforms only: darwin-arm64 + linux-x86_64. darwin-x86_64 is tier-2
+# and intentionally omitted until CI builds that asset.
+class Hive < Formula
+  desc "Multi-agent software pipeline from idea to merge-ready PR"
+  homepage "https://github.com/ivankuznetsov/hive"
+  version "0.1.0"
+  license "MIT"
+
+  on_macos do
+    on_arm do
+      url "https://github.com/ivankuznetsov/hive/releases/download/v#{version}/hive-v#{version}-darwin-arm64.tar.gz"
+      # Updated on each release by packaging/scripts/bump_package_metadata.sh
+      sha256 "REPLACE_WITH_RELEASE_SHA256_DARWIN_ARM64"
+    end
+  end
+
+  on_linux do
+    on_intel do
+      url "https://github.com/ivankuznetsov/hive/releases/download/v#{version}/hive-v#{version}-linux-x86_64.tar.gz"
+      sha256 "REPLACE_WITH_RELEASE_SHA256_LINUX_X86_64"
+    end
+  end
+
+  def install
+    # Tarball root is `hive/` with bin/, lib/, share/, etc.
+    prefix.install Dir["*"]
+  end
+
+  def caveats
+    <<~EOS
+      Hive was installed from the ivankuznetsov/hive tap (not homebrew-core).
+
+      Next steps:
+        hive doctor
+        cd your-project && hive init
+
+      `hive init` can register a user-level launchd service for the daemon
+      (you will be prompted). Skills for Claude Code / Codex / Pi are a
+      separate marketplace package and are not installed by this formula.
+
+      If `hive` on PATH is Apache Hive instead of this tool, reorder PATH
+      or use the bash installer which falls back to the `hv` command name.
+
+      Update with:  brew upgrade ivankuznetsov/hive/hive
+      Or:           hive update
+    EOS
+  end
+
+  test do
+    assert_match version.to_s, shell_output("#{bin}/hive --version")
+  end
+end
diff --git a/packaging/install.sh b/packaging/install.sh
new file mode 100755
index 00000000..3a3d9505
--- /dev/null
+++ b/packaging/install.sh
@@ -0,0 +1,269 @@
+#!/usr/bin/env bash
+# Hive one-liner installer.
+#
+#   curl -fsSL https://github.com/ivankuznetsov/hive/releases/latest/download/install.sh | bash
+#
+# Env:
+#   HIVE_VERSION     pin to vX.Y.Z (default: latest)
+#   HIVE_BIN_DIR     default ~/.local/bin
+#   HIVE_INSTALL_DIR default ~/.local/share/hive (prefix root)
+#   HIVE_REPO        default ivankuznetsov/hive
+#   HIVE_BASE_URL    override release download base (tests)
+set -euo pipefail
+
+REPO="${HIVE_REPO:-ivankuznetsov/hive}"
+BASE_URL="${HIVE_BASE_URL:-https://github.com/${REPO}/releases}"
+VERSION="${HIVE_VERSION:-latest}"
+BIN_DIR="${HIVE_BIN_DIR:-${HOME}/.local/bin}"
+INSTALL_DIR="${HIVE_INSTALL_DIR:-${HOME}/.local/share/hive}"
+TMPDIR_ROOT="${TMPDIR:-/tmp}"
+
+# Resolve library (same dir when checked out; embedded when published alone)
+_LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd || true)"
+if [[ -n "${_LIB_DIR}" && -f "${_LIB_DIR}/install_lib.sh" ]]; then
+  # shellcheck source=install_lib.sh
+  . "${_LIB_DIR}/install_lib.sh"
+else
+  # Minimal inline fallbacks when install.sh is the only downloaded asset.
+  # Keep hive_map_platform aligned with packaging/install_lib.sh (tier-1 only).
+  hive_map_platform() {
+    local os arch
+    os="$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')"
+    arch="$(uname -m 2>/dev/null)"
+    case "$os" in
+      linux) os="linux" ;;
+      darwin) os="darwin" ;;
+      *) echo "unsupported"; return 1 ;;
+    esac
+    case "$arch" in
+      x86_64|amd64) arch="x86_64" ;;
+      arm64|aarch64) arch="arm64" ;;
+      *) echo "unsupported"; return 1 ;;
+    esac
+    # Tier-1: darwin-arm64, linux-x86_64. darwin-x86_64 maps but is tier-2.
+    if [[ "$os" == "linux" && "$arch" != "x86_64" ]]; then
+      echo "unsupported"
+      return 1
+    fi
+    if [[ "$os" == "darwin" && "$arch" != "arm64" && "$arch" != "x86_64" ]]; then
+      echo "unsupported"
+      return 1
+    fi
+    if [[ "$os" == "linux" && -f /etc/alpine-release ]]; then
+      echo "unsupported"
+      return 1
+    fi
+    echo "${os}-${arch}"
+  }
+  hive_looks_like_our_hive() {
+    local out
+    out="$("$1" --version 2>/dev/null || true)"
+    [[ "$out" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-].*)?$ ]]
+  }
+  hive_choose_command_name() {
+    local bin_dir="$1" existing
+    existing="$(command -v hive 2>/dev/null || true)"
+    [[ -z "$existing" ]] && { echo hive; return; }
+    if [[ "$(dirname "$existing")" == "$bin_dir" ]] || hive_looks_like_our_hive "$existing"; then
+      echo hive
+    else
+      echo hv
+    fi
+  }
+  hive_dep_hint() {
+    case "$1" in
+      git) echo "install git via your package manager" ;;
+      claude) echo "install Claude Code CLI" ;;
+      gh) echo "install GitHub CLI (gh)" ;;
+      jq) echo "install jq" ;;
+      *) echo "install $1" ;;
+    esac
+  }
+fi
+
+log() { printf 'hive-install: %s\n' "$*"; }
+die() { printf 'hive-install: error: %s\n' "$*" >&2; exit 1; }
+
+# Hard deps for the install step itself
+for need in curl tar; do
+  command -v "$need" >/dev/null 2>&1 || die "missing required tool: $need ($(hive_dep_hint "$need"))"
+done
+
+# Soft deps — warn only
+for soft in git bash claude gh jq; do
+  if ! command -v "$soft" >/dev/null 2>&1; then
+    log "warning: optional tool not on PATH: $soft — $(hive_dep_hint "$soft")"
+  fi
+done
+
+PLATFORM="$(hive_map_platform)" || die "unsupported OS/arch (tier-1: macOS arm64, Ubuntu 22.04+ x86_64, Arch x86_64)"
+log "platform=$PLATFORM"
+
+if [[ "$VERSION" == "latest" ]]; then
+  ASSET_BASE="${BASE_URL}/latest/download"
+  # Resolve concrete version from GitHub API when possible (for install-channel)
+  RESOLVED_VERSION="$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null \
+    | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -1 || true)"
+  RESOLVED_VERSION="${RESOLVED_VERSION:-latest}"
+else
+  # Accept v0.1.0 or 0.1.0
+  case "$VERSION" in
+    v*) TAG="$VERSION" ;;
+    *) TAG="v$VERSION" ;;
+  esac
+  ASSET_BASE="${BASE_URL}/download/${TAG}"
+  RESOLVED_VERSION="$TAG"
+fi
+
+# Normalize version for asset name (strip leading v for filename? plan uses hive-v0.1.0-...)
+case "$RESOLVED_VERSION" in
+  latest) FILE_VER="latest" ;;
+  v*) FILE_VER="$RESOLVED_VERSION" ;;
+  *) FILE_VER="v$RESOLVED_VERSION" ;;
+esac
+
+if [[ "$FILE_VER" == "latest" ]]; then
+  # When we couldn't resolve the tag, try common pattern via redirect — download
+  # still uses latest/download which GitHub resolves.
+  TARBALL_NAME="hive-${FILE_VER}-${PLATFORM}.tar.gz"
+  # Prefer resolving real asset name from release API
+  if [[ -n "${RESOLVED_VERSION}" && "$RESOLVED_VERSION" != "latest" ]]; then
+    case "$RESOLVED_VERSION" in
+      v*) TARBALL_NAME="hive-${RESOLVED_VERSION}-${PLATFORM}.tar.gz" ;;
+      *) TARBALL_NAME="hive-v${RESOLVED_VERSION}-${PLATFORM}.tar.gz" ;;
+    esac
+  else
+    # Fallback: probe using the latest/download redirect without hardcoding a version.
+    # GitHub serves /releases/latest/download/<name> only when <name> exists on the
+    # latest release — try the conventional hive-v*-PLATFORM pattern via API asset list.
+    TARBALL_NAME=""
+    asset_list="$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null || true)"
+    if [[ -n "$asset_list" ]]; then
+      # Prefer an asset whose name matches our platform tarball convention.
+      probed="$(printf '%s\n' "$asset_list" \
+        | sed -n 's/.*"name": *"\(hive-v[^"]*'"${PLATFORM}"'\.tar\.gz\)".*/\1/p' \
+        | head -1 || true)"
+      if [[ -n "$probed" ]]; then
+        TARBALL_NAME="$probed"
+        # Also recover tag_name if sed earlier failed
+        if [[ "$RESOLVED_VERSION" == "latest" ]]; then
+          tag_probe="$(printf '%s\n' "$asset_list" \
+            | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -1 || true)"
+          [[ -n "$tag_probe" ]] && RESOLVED_VERSION="$tag_probe"
+        fi
+      fi
+    fi
+    # Last resort: construct from RESOLVED if we got tag
+    if [[ -z "$TARBALL_NAME" && -n "$RESOLVED_VERSION" && "$RESOLVED_VERSION" != "latest" ]]; then
+      case "$RESOLVED_VERSION" in
+        v*) TARBALL_NAME="hive-${RESOLVED_VERSION}-${PLATFORM}.tar.gz" ;;
+        *) TARBALL_NAME="hive-v${RESOLVED_VERSION}-${PLATFORM}.tar.gz" ;;
+      esac
+    fi
+    [[ -n "$TARBALL_NAME" ]] || die "could not determine release asset name for platform $PLATFORM (GitHub API unavailable and no tag resolved)"
+  fi
+else
+  case "$FILE_VER" in
+    v*) TARBALL_NAME="hive-${FILE_VER}-${PLATFORM}.tar.gz" ;;
+    *) TARBALL_NAME="hive-v${FILE_VER}-${PLATFORM}.tar.gz" ;;
+  esac
+fi
+
+WORKDIR="$(mktemp -d "${TMPDIR_ROOT}/hive-install.XXXXXX")"
+cleanup() { rm -rf "$WORKDIR"; }
+trap cleanup EXIT
+
+log "downloading ${TARBALL_NAME}"
+curl -fsSL "${ASSET_BASE}/${TARBALL_NAME}" -o "${WORKDIR}/${TARBALL_NAME}" \
+  || die "download failed: ${ASSET_BASE}/${TARBALL_NAME}"
+
+# SHA256SUMS verification is mandatory (release always publishes sums).
+if ! curl -fsSL "${ASSET_BASE}/SHA256SUMS" -o "${WORKDIR}/SHA256SUMS"; then
+  die "SHA256SUMS download failed (required for supply-chain verify): ${ASSET_BASE}/SHA256SUMS"
+fi
+log "verifying checksum"
+if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
+  die "neither sha256sum nor shasum is available; cannot verify SHA256SUMS"
+fi
+(
+  cd "$WORKDIR"
+  if ! grep -Fq "$TARBALL_NAME" SHA256SUMS; then
+    die "SHA256SUMS has no entry for $TARBALL_NAME"
+  fi
+  if command -v sha256sum >/dev/null 2>&1; then
+    grep -F "$TARBALL_NAME" SHA256SUMS | sha256sum -c - \
+      || die "checksum mismatch for $TARBALL_NAME"
+  else
+    expected="$(grep -F "$TARBALL_NAME" SHA256SUMS | awk '{print $1}')"
+    actual="$(shasum -a 256 "$TARBALL_NAME" | awk '{print $1}')"
+    [[ "$expected" == "$actual" ]] || die "checksum mismatch for $TARBALL_NAME"
+  fi
+)
+
+tar -xzf "${WORKDIR}/${TARBALL_NAME}" -C "$WORKDIR"
+# Tarball root is "hive/"
+SRC="${WORKDIR}/hive"
+[[ -d "$SRC" ]] || die "unexpected tarball layout (missing hive/ root)"
+
+mkdir -p "$INSTALL_DIR" "$BIN_DIR"
+# Replace install tree carefully
+rm -rf "${INSTALL_DIR}.new"
+mkdir -p "${INSTALL_DIR}.new"
+cp -a "$SRC"/. "${INSTALL_DIR}.new/"
+# Atomic-ish swap for the share/prefix tree
+if [[ -d "$INSTALL_DIR" ]]; then
+  rm -rf "${INSTALL_DIR}.old"
+  mv "$INSTALL_DIR" "${INSTALL_DIR}.old" 2>/dev/null || true
+fi
+mv "${INSTALL_DIR}.new" "$INSTALL_DIR"
+rm -rf "${INSTALL_DIR}.old" 2>/dev/null || true
+
+CMD_NAME="$(hive_choose_command_name "$BIN_DIR")"
+TARGET_BIN="${BIN_DIR}/${CMD_NAME}"
+ln -sfn "${INSTALL_DIR}/bin/hive" "$TARGET_BIN"
+# Ensure executable
+chmod +x "${INSTALL_DIR}/bin/hive" 2>/dev/null || true
+
+# Install-channel marker (read by hive update)
+mkdir -p "$INSTALL_DIR"
+{
+  echo "channel=bash"
+  echo "version=${RESOLVED_VERSION}"
+  echo "platform=${PLATFORM}"
+  echo "command=${CMD_NAME}"
+  echo "installed_at=$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date)"
+} >"${INSTALL_DIR}/install-channel"
+
+# Also write under XDG data path if INSTALL_DIR differs
+XDG_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/hive"
+if [[ "$(cd "$INSTALL_DIR" && pwd)" != "$(mkdir -p "$XDG_DATA" && cd "$XDG_DATA" && pwd)" ]]; then
+  cp "${INSTALL_DIR}/install-channel" "${XDG_DATA}/install-channel" 2>/dev/null || true
+fi
+
+log "installed ${CMD_NAME} → ${TARGET_BIN}"
+log "prefix → ${INSTALL_DIR}"
+
+if ! echo ":$PATH:" | grep -q ":${BIN_DIR}:"; then
+  log "warning: ${BIN_DIR} is not on PATH"
+  log "  add to your shell rc, e.g.:"
+  log "    export PATH=\"${BIN_DIR}:\$PATH\""
+fi
+
+if command -v "$CMD_NAME" >/dev/null 2>&1 || [[ -x "$TARGET_BIN" ]]; then
+  ver="$("$TARGET_BIN" --version 2>/dev/null || echo unknown)"
+  log "ok: ${CMD_NAME} --version → ${ver}"
+fi
+
+cat <<EOF
+
+Next steps:
+  1. ${CMD_NAME} doctor          # check runtime CLI deps (git, gh, claude, jq, …)
+  2. cd your-project && ${CMD_NAME} init
+  3. ${CMD_NAME} tui             # open the dashboard
+
+Skills for Claude Code / Codex / Pi are a separate package — install them from
+your agent's marketplace when available (not bundled with this binary).
+
+Update later with:  ${CMD_NAME} update
+Uninstall with:     ${CMD_NAME} uninstall
+EOF
diff --git a/packaging/install_lib.sh b/packaging/install_lib.sh
