diff --git a/lib/hive/commands/uninstall.rb b/lib/hive/commands/uninstall.rb
new file mode 100644
index 00000000..e35b9fc2
--- /dev/null
+++ b/lib/hive/commands/uninstall.rb
@@ -0,0 +1,154 @@
+# frozen_string_literal: true
+
+require "fileutils"
+require "hive/install_channel"
+require "hive/paths"
+require "hive/service_installer"
+
+module Hive
+  module Commands
+    # `hive uninstall` — remove install hooks / service units; preserve
+    # work and state by default. Never deletes project .hive-state trees
+    # unless the operator explicitly confirms.
+    class Uninstall
+      def initialize(purge: false, yes: false, output: $stdout, stderr: $stderr, input: $stdin)
+        @purge = purge
+        @yes = yes
+        @output = output
+        @stderr = stderr
+        @input = input
+      end
+
+      def call
+        channel = InstallChannel.detect
+        @output.puts "hive uninstall: channel=#{channel}"
+
+        unregister_service
+
+        case channel
+        when "brew"
+          @output.puts "hive uninstall: brew-managed install — run: brew uninstall hive"
+          @output.puts "  (refusing to delete the Homebrew binary)"
+          cleanup_hive_owned_files(remove_binary: false)
+        when "aur"
+          @output.puts "hive uninstall: AUR-managed install — run: yay -R hive-bin  (or pacman -R hive-bin)"
+          @output.puts "  (refusing to delete the package binary)"
+          cleanup_hive_owned_files(remove_binary: false)
+        when "bash", "unknown", "dev"
+          cleanup_hive_owned_files(remove_binary: channel == "bash")
+        end
+
+        maybe_prompt_project_cleanup
+        print_skills_note
+        print_preserved
+      end
+
+      private
+
+      def unregister_service
+        result = ServiceInstaller.new(dry_run: false).uninstall
+        if result[:removed]
+          @output.puts "hive uninstall: removed user service (#{result[:kind]})"
+        else
+          @output.puts "hive uninstall: no user service unit found (ok)"
+        end
+      rescue StandardError => e
+        @stderr.puts "hive uninstall: service cleanup skipped: #{e.message}"
+      end
+
+      def cleanup_hive_owned_files(remove_binary:)
+        marker = InstallChannel.read_marker
+        cmd_name = (marker && marker["command"]) || "hive"
+
+        if remove_binary
+          [ cmd_name, "hive", "hv" ].uniq.each do |name|
+            path = File.join(Paths.bin_root, name)
+            next unless File.exist?(path) || File.symlink?(path)
+
+            FileUtils.rm_f(path)
+            @output.puts "hive uninstall: removed #{path}"
+          end
+
+          # Bash channel prefix under data_root (may hold bin/share)
+          prefix = ENV["HIVE_INSTALL_DIR"] || Paths.data_root
+          if File.directory?(prefix) && File.file?(File.join(prefix, "bin", "hive"))
+            if @purge
+              # Remove package payload but keep state_root / config_root
+              %w[bin lib libexec runtime vendor templates share].each do |sub|
+                path = File.join(prefix, sub)
+                FileUtils.rm_rf(path) if File.exist?(path)
+              end
+              @output.puts "hive uninstall: removed package payload under #{prefix}"
+            else
+              @output.puts "hive uninstall: left package files under #{prefix} (pass --purge to remove share payload)"
+            end
+          end
+        end
+
+        # Always safe to drop install-channel marker
+        [ InstallChannel.marker_path, File.join(Paths.data_root, "install-channel") ].uniq.each do |m|
+          next unless File.file?(m)
+
+          FileUtils.rm_f(m)
+          @output.puts "hive uninstall: removed #{m}"
+        end
+      end
+
+      def maybe_prompt_project_cleanup
+        projects = begin
+          Config.registered_projects
+        rescue StandardError
+          []
+        end
+        return if projects.empty?
+
+        if @yes || @purge || !interactive?
+          @output.puts "hive uninstall: keeping #{projects.size} registered project(s) and all .hive-state trees"
+          return
+        end
+
+        @output.puts "Registered projects (#{projects.size}):"
+        projects.each { |p| @output.puts "  - #{p["name"]}: #{p["path"]}" }
+        @output.print "Remove registry entries (not project files)? [y/N] "
+        ans = @input.gets.to_s.strip.downcase
+        if %w[y yes].include?(ans)
+          projects.each do |p|
+            Config.unregister_project(name: p["name"])
+            @output.puts "hive uninstall: unregistered #{p["name"]}"
+          end
+        else
+          @output.puts "hive uninstall: keeping registry entries"
+        end
+
+        @output.print "Delete any project .hive-state directories? [y/N] "
+        ans2 = @input.gets.to_s.strip.downcase
+        if %w[y yes].include?(ans2)
+          projects.each do |p|
+            state = p["hive_state_path"] || File.join(p["path"], ".hive-state")
+            next unless File.directory?(state)
+
+            FileUtils.rm_rf(state)
+            @output.puts "hive uninstall: removed #{state}"
+          end
+        else
+          @output.puts "hive uninstall: keeping project .hive-state directories"
+        end
+      end
+
+      def interactive?
+        @input.respond_to?(:tty?) && @input.tty?
+      end
+
+      def print_skills_note
+        @output.puts "hive uninstall: remove agent skills via your marketplace (not managed by hive uninstall)"
+      end
+
+      def print_preserved
+        @output.puts "Preserved by default:"
+        @output.puts "  config: #{Paths.global_config_path}"
+        @output.puts "  state:  #{Paths.state_root}"
+        @output.puts "  project pipeline trees under each project's .hive-state/"
+      end
+    end
+  end
+end
diff --git a/lib/hive/commands/update.rb b/lib/hive/commands/update.rb
new file mode 100644
index 00000000..ce2be423
--- /dev/null
+++ b/lib/hive/commands/update.rb
@@ -0,0 +1,103 @@
+# frozen_string_literal: true
+
+require "shellwords"
+require "hive/install_channel"
+require "hive/paths"
+require "hive/preflight"
+
+module Hive
+  module Commands
+    # `hive update` — channel-native upgrade only. Never downloads and
+    # overwrites a brew/AUR-managed binary in place.
+    class Update
+      REPO = "ivankuznetsov/hive"
+      INSTALL_SH_URL = "https://github.com/#{REPO}/releases/latest/download/install.sh"
+
+      def initialize(check: false, dry_run: false, output: $stdout, stderr: $stderr)
+        @check = check
+        @dry_run = dry_run
+        @output = output
+        @stderr = stderr
+      end
+
+      def call
+        channel = InstallChannel.detect
+        @output.puts "hive update: channel=#{channel} version=#{Hive::VERSION}"
+
+        if @check
+          report_latest
+          return
+        end
+
+        case channel
+        when "brew"
+          run_or_print(%w[brew upgrade ivankuznetsov/hive/hive])
+        when "aur"
+          if command_on_path?("yay")
+            run_or_print(%w[yay -Syu hive-bin])
+          elsif command_on_path?("paru")
+            run_or_print(%w[paru -Syu hive-bin])
+          else
+            @output.puts "hive update: install yay/paru or run: sudo pacman -Syu hive-bin"
+            raise Hive::Error, "aur channel requires yay, paru, or manual pacman upgrade"
+          end
+        when "bash"
+          cmd = ["bash", "-c", "curl -fsSL #{INSTALL_SH_URL} | bash"]
+          if @dry_run
+            @output.puts "hive update: would run: curl -fsSL #{INSTALL_SH_URL} | bash"
+          else
+            @output.puts "hive update: re-running bash installer for latest release"
+            exec("bash", "-c", "curl -fsSL #{INSTALL_SH_URL} | bash")
+          end
+        when "dev"
+          @stderr.puts "hive update: development checkout detected"
+          @stderr.puts "  pull and reinstall gems yourself:"
+          @stderr.puts "    git -C #{Paths.source_root} pull && bundle install"
+          raise Hive::Error, "no channel updater for development checkouts"
+        else
+          @stderr.puts "hive update: unknown install channel"
+          @stderr.puts "  set HIVE_INSTALL_CHANNEL=brew|aur|bash or reinstall via brew/AUR/install.sh"
+          raise Hive::ConfigError, "cannot update: install channel is unknown"
+        end
+      end
+
+      private
+
+      def report_latest
+        latest = fetch_latest_tag
+        if latest
+          @output.puts "hive update --check: current=#{Hive::VERSION} latest=#{latest}"
+        else
+          @output.puts "hive update --check: current=#{Hive::VERSION} latest=(unavailable; install gh or curl)"
+        end
+      end
+
+      def fetch_latest_tag
+        if command_on_path?("gh")
+          out = `gh api repos/#{REPO}/releases/latest --jq .tag_name 2>/dev/null`.to_s.strip
+          return out unless out.empty?
+        end
+        if command_on_path?("curl")
+          body = `curl -fsSL https://api.github.com/repos/#{REPO}/releases/latest 2>/dev/null`.to_s
+          if body =~ /"tag_name"\s*:\s*"([^"]+)"/
+            return ::Regexp.last_match(1)
+          end
+        end
+        nil
+      end
+
+      def run_or_print(argv)
+        if @dry_run
+          @output.puts "hive update: would run: #{argv.shelljoin}"
+          return
+        end
+        @output.puts "hive update: running #{argv.shelljoin}"
+        system(*argv) || raise(Hive::Error, "update command failed: #{argv.shelljoin}")
+      end
+
+      def command_on_path?(name)
+        Hive::Preflight.present?(name)
+      end
+    end
+  end
+end
