+++ b/packaging/install_lib.sh
@@ -0,0 +1,76 @@
+#!/usr/bin/env bash
+# Pure helpers for packaging/install.sh — sourced by the installer and by tests.
+# shellcheck shell=bash
+
+hive_map_platform() {
+  local os arch
+  os="$(uname -s 2>/dev/null | tr '[:upper:]' '[:lower:]')"
+  arch="$(uname -m 2>/dev/null)"
+  case "$os" in
+    linux) os="linux" ;;
+    darwin) os="darwin" ;;
+    *) echo "unsupported" ; return 1 ;;
+  esac
+  case "$arch" in
+    x86_64|amd64) arch="x86_64" ;;
+    arm64|aarch64) arch="arm64" ;;
+    *) echo "unsupported" ; return 1 ;;
+  esac
+  # Tier-1: darwin-arm64, linux-x86_64. darwin-x86_64 is tier-2 but map it.
+  if [[ "$os" == "linux" && "$arch" != "x86_64" ]]; then
+    # linux-arm64 not tier-1 yet
+    echo "unsupported"
+    return 1
+  fi
+  if [[ "$os" == "darwin" && "$arch" != "arm64" && "$arch" != "x86_64" ]]; then
+    echo "unsupported"
+    return 1
+  fi
+  # Detect Alpine (musl) — not supported
+  if [[ "$os" == "linux" && -f /etc/alpine-release ]]; then
+    echo "unsupported"
+    return 1
+  fi
+  echo "${os}-${arch}"
+}
+
+hive_looks_like_our_hive() {
+  local bin="$1"
+  local out
+  out="$("$bin" --version 2>/dev/null || true)"
+  # Our version is a bare semver (e.g. 0.1.0). Apache Hive prints a multi-line banner.
+  if [[ "$out" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-].*)?$ ]]; then
+    return 0
+  fi
+  return 1
+}
+
+hive_choose_command_name() {
+  local bin_dir="$1"
+  local existing
+  existing="$(command -v hive 2>/dev/null || true)"
+  if [[ -z "$existing" ]]; then
+    echo "hive"
+    return 0
+  fi
+  # If the existing hive is already ours (or lives in our bin_dir), keep hive.
+  if [[ "$(dirname "$existing")" == "$bin_dir" ]] || hive_looks_like_our_hive "$existing"; then
+    echo "hive"
+    return 0
+  fi
+  echo "hv"
+}
+
+hive_dep_hint() {
+  local tool="$1"
+  case "$tool" in
+    git) echo "install git via your package manager (apt install git / brew install git / pacman -S git)" ;;
+    bash) echo "install bash (required)" ;;
+    claude) echo "install Claude Code: https://docs.anthropic.com/en/docs/claude-code" ;;
+    gh) echo "install GitHub CLI: https://cli.github.com/ (then gh auth login)" ;;
+    jq) echo "install jq via your package manager (apt install jq / brew install jq / pacman -S jq)" ;;
+    curl) echo "install curl via your package manager" ;;
+    tar) echo "install tar via your package manager" ;;
+    *) echo "install $tool" ;;
+  esac
+}
diff --git a/packaging/scripts/build_tarball.sh b/packaging/scripts/build_tarball.sh
new file mode 100755
index 00000000..9a460940
--- /dev/null
+++ b/packaging/scripts/build_tarball.sh
@@ -0,0 +1,345 @@
+#!/usr/bin/env bash
+# Build a platform release tarball for Hive (relocatable prefix).
+#
+# Strategy (v1): relocatable prefix with vendored gems + optional embedded
+# Ruby runtime. A single-file Tebako pack was evaluated; bubbletea/lipgloss
+# FFI makes a reliable single ELF non-trivial, so the prefix layout is the
+# supported delivery form. End users still need no *system* Ruby when
+# HIVE_EMBED_RUBY=1 (default on release CI).
+#
+# Usage:
+#   packaging/scripts/build_tarball.sh [--platform PLATFORM] [--version VERSION]
+#                                      [--out DIR] [--no-embed-ruby]
+#
+# Artifact: hive-vVERSION-PLATFORM.tar.gz (+ line in SHA256SUMS when --sums)
+set -euo pipefail
+
+ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
+VERSION="${HIVE_VERSION:-}"
+PLATFORM="${HIVE_PLATFORM:-}"
+OUT_DIR="${HIVE_OUT_DIR:-$ROOT/dist}"
+EMBED_RUBY="${HIVE_EMBED_RUBY:-1}"
+WRITE_SUMS=0
+
+while [[ $# -gt 0 ]]; do
+  case "$1" in
+    --platform) PLATFORM="$2"; shift 2 ;;
+    --version) VERSION="$2"; shift 2 ;;
+    --out) OUT_DIR="$2"; shift 2 ;;
+    --no-embed-ruby) EMBED_RUBY=0; shift ;;
+    --sums) WRITE_SUMS=1; shift ;;
+    -h|--help)
+      sed -n '2,20p' "$0"
+      exit 0
+      ;;
+    *) echo "unknown arg: $1" >&2; exit 2 ;;
+  esac
+done
+
+if [[ -z "$VERSION" ]]; then
+  VERSION="$(ruby -I"$ROOT/lib" -rhive -e 'print Hive::VERSION' 2>/dev/null || true)"
+fi
+if [[ -z "$VERSION" ]]; then
+  VERSION="$(grep -E 'VERSION\s*=' "$ROOT/lib/hive.rb" | head -1 | sed -E 's/.*"([^"]+)".*/\1/')"
+fi
+[[ -n "$VERSION" ]] || { echo "could not determine version" >&2; exit 1; }
+# Normalize: accept v0.1.0 or 0.1.0; artifact names always use v-prefix once.
+VERSION="${VERSION#v}"
+TAG_VERSION="v${VERSION}"
+
+if [[ -z "$PLATFORM" ]]; then
+  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
+  arch="$(uname -m)"
+  case "$os" in
+    linux) os=linux ;;
+    darwin) os=darwin ;;
+    *) echo "unsupported os: $os" >&2; exit 1 ;;
+  esac
+  case "$arch" in
+    x86_64|amd64) arch=x86_64 ;;
+    arm64|aarch64) arch=arm64 ;;
+    *) echo "unsupported arch: $arch" >&2; exit 1 ;;
+  esac
+  PLATFORM="${os}-${arch}"
+fi
+
+STAGE="$(mktemp -d "${TMPDIR:-/tmp}/hive-pkg.XXXXXX")"
+cleanup() { rm -rf "$STAGE"; }
+trap cleanup EXIT
+
+PREFIX_NAME="hive"
+PREFIX="$STAGE/$PREFIX_NAME"
+mkdir -p "$PREFIX"/{bin,libexec,lib,templates,share/hive,vendor}
+
+# Resolve OUT_DIR to absolute before we cd into the staging tree.
+mkdir -p "$OUT_DIR"
+OUT_DIR="$(cd "$OUT_DIR" && pwd)"
+echo "hive: packaging ${TAG_VERSION} for ${PLATFORM} → ${OUT_DIR}"
+
+# Application payload
+cp -a "$ROOT/lib/." "$PREFIX/lib/"
+cp -a "$ROOT/templates/." "$PREFIX/templates/"
+# Ship templates under share/hive as well (packaged_share_root resolution)
+mkdir -p "$PREFIX/share/hive/templates"
+cp -a "$ROOT/templates/." "$PREFIX/share/hive/templates/"
+if [[ -d "$ROOT/share/hive" ]]; then
+  cp -a "$ROOT/share/hive/." "$PREFIX/share/hive/"
+fi
+# Also ship examples as services source of truth for older layouts
+mkdir -p "$PREFIX/share/hive/services"
+if [[ -d "$ROOT/examples/systemd" ]]; then
+  mkdir -p "$PREFIX/share/hive/services/systemd"
+  cp -a "$ROOT/examples/systemd/." "$PREFIX/share/hive/services/systemd/"
+fi
+if [[ -d "$ROOT/examples/launchd" ]]; then
+  mkdir -p "$PREFIX/share/hive/services/launchd"
+  cp -a "$ROOT/examples/launchd/." "$PREFIX/share/hive/services/launchd/"
+fi
+
+cp "$ROOT/LICENSE" "$PREFIX/LICENSE"
+printf '%s\n' "Hive ${TAG_VERSION} (${PLATFORM})" "https://github.com/ivankuznetsov/hive" >"$PREFIX/README"
+
+# Thin entry that production launcher execs
+cat >"$PREFIX/libexec/hive.rb" <<'RUBY'
+#!/usr/bin/env ruby
+# frozen_string_literal: true
+root = File.expand_path("..", __dir__)
+$LOAD_PATH.unshift(File.join(root, "lib"))
+# Prefer packaged gems when present
+vendor = File.join(root, "vendor", "bundle")
+if File.directory?(vendor)
+  Dir.glob(File.join(vendor, "ruby", "*", "gems", "*", "lib")).each do |p|
+    $LOAD_PATH.unshift(p)
+  end
+  Dir.glob(File.join(vendor, "ruby", "*", "specifications")).each do |spec_dir|
+    # no-op: path gems already on LOAD_PATH via gems/*/lib
+  end
+end
+require "hive"
+require "hive/cli"
+
+if ARGV == ["--version"] || ARGV == ["-v"]
+  puts Hive::VERSION
+  exit 0
+end
+
+def rewrite_help_flag!(argv)
+  return if argv.empty?
+  cmd_idx = argv.index { |a| !a.start_with?("-") }
+  return unless cmd_idx
+  help_idx = argv[(cmd_idx + 1)..]&.index { |a| a == "--help" || a == "-h" }
+  return unless help_idx
+  cmd = argv.delete_at(cmd_idx)
+  argv.delete_at(cmd_idx + help_idx)
+  argv.unshift("help", cmd)
+end
+
+rewrite_help_flag!(ARGV)
+
+begin
+  Hive::CLI.start(ARGV)
+rescue Hive::Error => e
+  warn "hive: #{e.message}"
+  exit(e.respond_to?(:exit_code) ? e.exit_code : 1)
+end
+RUBY
+chmod +x "$PREFIX/libexec/hive.rb"
+
+# Vendor gems (runtime only). Use env overrides so we never mutate the
+# developer's .bundle/config. Hard-fail: tier-1 artifacts must ship gems.
+# Isolate bundler app config so CI global BUNDLE_PATH=vendor/bundle cannot
+# redirect installs into the source tree.
+if ! command -v bundle >/dev/null 2>&1; then
+  echo "hive: error: bundle is required to vendor runtime gems" >&2
+  exit 1
+fi
+BUNDLE_APP_TMP="$(mktemp -d "${TMPDIR:-/tmp}/hive-bundle-cfg.XXXXXX")"
+(
+  cd "$ROOT"
+  BUNDLE_APP_CONFIG="$BUNDLE_APP_TMP" \
+    BUNDLE_PATH="$PREFIX/vendor/bundle" \
+    BUNDLE_WITHOUT="development:test" \
+    BUNDLE_DEPLOYMENT=false \
+    BUNDLE_SILENCE_ROOT_WARNING=1 \
+    bundle install --quiet
+)
+rm -rf "$BUNDLE_APP_TMP"
+# Confirm at least one gem platform dir landed
+if ! compgen -G "$PREFIX/vendor/bundle/ruby/*/gems/*" >/dev/null; then
+  echo "hive: error: vendor/bundle has no gems after bundle install (looked under $PREFIX/vendor/bundle)" >&2
+  find "$PREFIX/vendor" -maxdepth 4 -type d 2>/dev/null | head -20 >&2 || true
+  exit 1
+fi
+
+# Optional embedded Ruby: copy the build-host interpreter tree when possible.
+EMBEDDED_OK=0
+if [[ "$EMBED_RUBY" == "1" ]]; then
+  RUBY_BIN="$(command -v ruby || true)"
+  if [[ -z "$RUBY_BIN" ]]; then
+    echo "hive: error: HIVE_EMBED_RUBY=1 but no ruby on PATH to embed" >&2
+    exit 1
+  fi
+  RUBY_PREFIX="$(ruby -e 'print RbConfig::CONFIG["prefix"]' 2>/dev/null || true)"
+  if [[ -z "$RUBY_PREFIX" || ! -d "$RUBY_PREFIX" ]]; then
+    echo "hive: error: could not locate Ruby prefix for embed from ${RUBY_BIN}" >&2
+    exit 1
+  fi
+  echo "hive: embedding Ruby from ${RUBY_PREFIX}"
+  mkdir -p "$PREFIX/runtime"
+  # Copy bin + lib for the interpreter. Shared libs may still resolve from the host;
+  # release CI builds on the oldest supported glibc (Ubuntu 22.04) for Linux.
+  if [[ -d "$RUBY_PREFIX/bin" ]]; then
+    mkdir -p "$PREFIX/runtime/bin"
+    # Copy ruby + common companions; ignore missing optional tools
+    for b in ruby gem bundle irb; do
+      if [[ -x "$RUBY_PREFIX/bin/$b" ]]; then
+        cp -a "$RUBY_PREFIX/bin/$b" "$PREFIX/runtime/bin/"
+      fi
+    done
+  fi
+  for sub in lib libexec share; do
+    if [[ -d "$RUBY_PREFIX/$sub" ]]; then
+      cp -a "$RUBY_PREFIX/$sub" "$PREFIX/runtime/"
+    fi
+  done
+  if [[ ! -x "$PREFIX/runtime/bin/ruby" ]]; then
+    echo "hive: error: embed incomplete — runtime/bin/ruby missing after copy" >&2
+    exit 1
+  fi
+  EMBEDDED_OK=1
+fi
+
+# Launcher
+cat >"$PREFIX/bin/hive" <<'LAUNCH'
+#!/usr/bin/env bash
+set -euo pipefail
+ROOT="$(cd "$(dirname "$0")/.." && pwd)"
+export HIVE_PREFIX="${HIVE_PREFIX:-$ROOT}"
+export HIVE_SHARE_ROOT="${HIVE_SHARE_ROOT:-$ROOT/share/hive}"
+
+# Prefer embedded runtime, then PATH ruby.
+if [[ -x "$ROOT/runtime/bin/ruby" ]]; then
+  RUBY="$ROOT/runtime/bin/ruby"
+elif command -v ruby >/dev/null 2>&1; then
+  RUBY="$(command -v ruby)"
+else
+  echo "hive: no Ruby runtime found (embedded or on PATH)" >&2
+  exit 1
+fi
+
+# Point Bundler/RubyGems at vendored gems when present.
+# Expand the platform dir (do not leave an unexpanded ruby/* glob in GEM_PATH).
+if [[ -d "$ROOT/vendor/bundle" ]]; then
+  gem_paths=()
+  for rbdir in "$ROOT"/vendor/bundle/ruby/*; do
+    [[ -d "$rbdir" ]] || continue
+    gem_paths+=("$rbdir")
+  done
+  if [[ ${#gem_paths[@]} -gt 0 ]]; then
+    joined="$(IFS=:; echo "${gem_paths[*]}")"
+    export GEM_PATH="${joined}${GEM_PATH:+:$GEM_PATH}"
+  fi
+  # Also put each gem's lib on RUBYLIB (proven LOAD_PATH strategy for relocatable prefixes)
+  for gdir in "$ROOT"/vendor/bundle/ruby/*/gems/*/lib; do
+    [[ -d "$gdir" ]] && RUBYLIB="${gdir}${RUBYLIB:+:$RUBYLIB}"
+  done
+  export RUBYLIB="${RUBYLIB:-}"
+fi
+
+exec "$RUBY" -I"$ROOT/lib" "$ROOT/libexec/hive.rb" "$@"
+LAUNCH
+chmod +x "$PREFIX/bin/hive"
+
+TARBALL="hive-${TAG_VERSION}-${PLATFORM}.tar.gz"
+(
+  cd "$STAGE"
+  tar -czf "$OUT_DIR/$TARBALL" "$PREFIX_NAME"
+)
+
+echo "hive: wrote $OUT_DIR/$TARBALL"
+if [[ "$WRITE_SUMS" == "1" ]]; then
+  (
+    cd "$OUT_DIR"
+    if command -v sha256sum >/dev/null 2>&1; then
+      sha256sum "$TARBALL" >> SHA256SUMS
+    else
+      shasum -a 256 "$TARBALL" >> SHA256SUMS
+    fi
+  )
+  echo "hive: updated $OUT_DIR/SHA256SUMS"
+fi
+
+# Smoke: version must print. When embed is required, run under a Ruby-free
+# PATH so system ruby (e.g. ruby/setup-ruby on CI) cannot mask embed bugs.
+EXTRACT="$(mktemp -d "${TMPDIR:-/tmp}/hive-smoke.XXXXXX")"
+SMOKE_HOME="$(mktemp -d "${TMPDIR:-/tmp}/hive-smoke-home.XXXXXX")"
+tar -xzf "$OUT_DIR/$TARBALL" -C "$EXTRACT"
+
+run_smoke() {
+  local bin="$EXTRACT/hive/bin/hive"
+  if [[ "$EMBEDDED_OK" == "1" ]]; then
+    # No system ruby on PATH; only bare essentials for the shell launcher.
+    env -i \
+      PATH="/usr/bin:/bin" \
+      HOME="$SMOKE_HOME" \
+      HIVE_PREFIX="$EXTRACT/hive" \
+      "$bin" --version
+  else
+    # Dev package without embed may use host ruby; still strip extra env noise.
+    env -i \
+      PATH="${PATH:-/usr/bin:/bin}" \
+      HOME="$SMOKE_HOME" \
+      HIVE_PREFIX="$EXTRACT/hive" \
+      "$bin" --version
+  fi
+}
+
+if ! run_smoke | grep -q "$VERSION"; then
+  echo "hive: smoke failed: --version did not print $VERSION" >&2
+  rm -rf "$EXTRACT" "$SMOKE_HOME"
+  exit 1
+fi
+
+# Template resolution must work from the package tree (no git checkout).
+if [[ "$EMBEDDED_OK" == "1" ]]; then
+  template_check="$(
+    env -i \
+      PATH="/usr/bin:/bin" \
+      HOME="$SMOKE_HOME" \
+      HIVE_PREFIX="$EXTRACT/hive" \
+      HIVE_SHARE_ROOT="$EXTRACT/hive/share/hive" \
+      "$EXTRACT/hive/runtime/bin/ruby" -I"$EXTRACT/hive/lib" -e '
+        require "hive/paths"
+        path = Hive::Paths.resolve_template("project_config.yml.erb")
+        abort "missing template: #{path}" unless File.file?(path)
+        puts path
+      '
+  )" || {
+    echo "hive: smoke failed: Paths.resolve_template for project_config.yml.erb" >&2
+    rm -rf "$EXTRACT" "$SMOKE_HOME"
+    exit 1
+  }
+  echo "hive: smoke template → $template_check"
+else
+  template_check="$(
+    env -i \
+      PATH="${PATH:-/usr/bin:/bin}" \
+      HOME="$SMOKE_HOME" \
+      HIVE_PREFIX="$EXTRACT/hive" \
+      HIVE_SHARE_ROOT="$EXTRACT/hive/share/hive" \
+      ruby -I"$EXTRACT/hive/lib" -e '
+        require "hive/paths"
+        path = Hive::Paths.resolve_template("project_config.yml.erb")
+        abort "missing template: #{path}" unless File.file?(path)
+        puts path
+      '
+  )" || {
+    echo "hive: smoke failed: Paths.resolve_template for project_config.yml.erb" >&2
+    rm -rf "$EXTRACT" "$SMOKE_HOME"
+    exit 1
+  }
+  echo "hive: smoke template → $template_check"
+fi
+
+rm -rf "$EXTRACT" "$SMOKE_HOME"
+echo "hive: smoke ok (hive --version → $VERSION; no-system-Ruby=${EMBEDDED_OK})"
