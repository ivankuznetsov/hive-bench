+    tracker = AttemptTracker.new
+    key = [ "p", "s", "4-execute", "implementer_failed" ]
+
+    tracker.record_retry(key: key, fingerprint: "fp1", now: T0)
+    tracker.record_retry(key: key, fingerprint: "fp2", now: T0 + (30 * 60))
+
+    exhausted = tracker.decision(key: key, fingerprint: "fp3", now: T0 + (60 * 60))
+
+    assert_equal :exhausted, exhausted.action
+    assert_equal 2, exhausted.attempts
