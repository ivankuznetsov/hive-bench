+    with_marker_file do |state_file|
+      stale = make_row(
+        state_file,
+        pid_alive: nil,
+        stage: "4-execute",
+        marker: "error",
+        marker_attrs: { "reason" => "implementer_failed", "message" => "401 Unauthorized", "marker_id" => "old" },
+        action: "error",
+        live_task_lock: false
+      )
+
+      File.write(state_file, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=new -->\n")
+      heal([ stale ])
+      assert_match(/ERROR reason=implementer_failed marker_id=new/, File.read(state_file))
+      refute @logger.events.any? { |name, _| name == :auto_retry_attempted }
+      assert_equal 0, tracker.attempts_for([ "p", "s", "4-execute", "implementer_failed" ])
+
+      File.write(state_file, "# task\n\n<!-- ERROR reason=implementer_failed marker_id=old -->\n")
+      heal([ stale ])
+      assert Hive::Markers.current(state_file).none?,
+             "the marker-id race must not consume the single retry budget"
+      assert_equal 1, @logger.events.count { |name, _| name == :auto_retry_attempted }
+    end
