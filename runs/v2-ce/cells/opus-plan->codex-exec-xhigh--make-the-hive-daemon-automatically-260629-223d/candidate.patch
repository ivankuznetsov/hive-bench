--- /dev/null
+++ b/test/unit/daemon/auto_retry/classifier_test.rb
@@ -0,0 +1,103 @@
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/auto_retry/classifier"
+
+class HiveDaemonAutoRetryClassifierTest < Minitest::Test
+  Row = Struct.new(:folder, :marker_attrs, keyword_init: true)
+
+  def setup
+    @classifier = Hive::Daemon::AutoRetry::Classifier.new
+  end
+
+  def row(folder:, attrs:)
+    Row.new(folder: folder, marker_attrs: attrs)
+  end
+
+  def test_classifies_implementer_failed_from_marker_401_signature
+    Dir.mktmpdir do |dir|
+      classification = @classifier.classify(row(
+        folder: dir,
+        attrs: {
+          "reason" => "implementer_failed",
+          "message" => "Codex request failed: 401 Unauthorized; missing bearer token"
+        }
+      ))
+
+      refute_nil classification
+      assert_equal "implementer_failed", classification.reason
+      assert_equal "codex_auth_401", classification.subreason
+      assert_equal :codex_auth, classification.probe
+      assert_equal [ :marker_message ], classification.evidence_sources
+    end
+  end
+
+  def test_classifies_implementer_failed_from_daemon_visible_log_tail
+    Dir.mktmpdir do |root|
+      folder = File.join(root, ".hive-state", "stages", "4-execute", "task-260701-abcd")
+      log_dir = File.join(root, ".hive-state", "logs", "task-260701-abcd")
+      FileUtils.mkdir_p([ folder, log_dir ])
+      File.write(File.join(log_dir, "execute-impl-20260701T000000Z.log"),
+                 "[stream] request failed with 401 Unauthorized\n")
+
+      classification = @classifier.classify(row(
+        folder: folder,
+        attrs: { "reason" => "implementer_failed", "message" => "exit_code=1" }
+      ))
+
+      refute_nil classification
+      assert_equal "codex_auth_401", classification.subreason
+      assert_equal [ :agent_log ], classification.evidence_sources
+    end
+  end
+
+  def test_bare_exit_code_implementer_failure_is_not_classified
+    Dir.mktmpdir do |dir|
+      classification = @classifier.classify(row(
+        folder: dir,
+        attrs: { "reason" => "implementer_failed", "message" => "exit_code=1" }
+      ))
+
+      assert_nil classification
+    end
+  end
+
+  def test_classifies_claude_launch_failed_by_marker_reason
+    Dir.mktmpdir do |dir|
+      classification = @classifier.classify(row(
+        folder: dir,
+        attrs: { "reason" => "claude_launch_failed", "message" => "prompt did not become ready" }
+      ))
+
+      refute_nil classification
+      assert_equal "claude_launch_failed", classification.reason
+      assert_equal "claude_launcher", classification.subreason
+      assert_equal :claude_launcher, classification.probe
+      assert_equal [ :marker_reason ], classification.evidence_sources
+    end
+  end
+
+  def test_dirty_worktree_and_unknown_reasons_are_not_classified
+    Dir.mktmpdir do |dir|
+      assert_nil @classifier.classify(row(folder: dir, attrs: { "reason" => "dirty_worktree" }))
+      assert_nil @classifier.classify(row(folder: dir, attrs: { "reason" => "unknown" }))
+    end
+  end
+
+  def test_classification_payload_does_not_emit_secret_material
+    Dir.mktmpdir do |dir|
+      token = "Authorization: Basic abcdefghijklmnopqrstuvwxyz"
+      classification = @classifier.classify(row(
+        folder: dir,
+        attrs: {
+          "reason" => "implementer_failed",
+          "message" => "Codex failed after #{token}"
+        }
+      ))
+
+      refute_nil classification
+      refute_includes classification.to_h.inspect, "abcdefghijklmnopqrstuvwxyz"
+      refute_includes classification.to_h.inspect, "Authorization"
+    end
+  end
+end
diff --git a/test/unit/daemon/auto_retry/probes_test.rb b/test/unit/daemon/auto_retry/probes_test.rb
new file mode 100644
index 00000000..ecc3a1b5
--- /dev/null
+++ b/test/unit/daemon/auto_retry/probes_test.rb
@@ -0,0 +1,222 @@
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/auto_retry/probes"
+
+class HiveDaemonAutoRetryProbesTest < Minitest::Test
+  Row = Struct.new(:project, :folder, keyword_init: true)
+
+  Probes = Hive::Daemon::AutoRetry::Probes
+
+  T0 = Time.utc(2026, 7, 1, 12, 0, 0)
+
+  class FakeRunner
+    attr_reader :calls
+
+    def initialize(&block)
+      @block = block
+      @calls = []
+    end
+
+    def call(argv, env:, timeout:, chdir:, stdin_data: nil)
+      @calls << { argv: argv, env: env, timeout: timeout, chdir: chdir, stdin_data: stdin_data }
+      @block.call(argv, env: env, timeout: timeout, chdir: chdir, stdin_data: stdin_data)
+    end
+  end
+
+  def project_row
+    Dir.mktmpdir do |root|
+      folder = File.join(root, ".hive-state", "stages", "4-execute", "task-260701-abcd")
+      FileUtils.mkdir_p(folder)
+      yield Row.new(project: "p", folder: folder), root
+    end
+  end
+
+  def healthy_doctor
+    ->(project_root:, cfg:) { Probes::Check.new(name: "hive_doctor", healthy: true, detail: "ok") }
+  end
+
+  def cfg_loader
+    ->(_project_root) { Hive::Config.merge_defaults({}) }
+  end
+
+  def result(argv:, exitstatus: 0, stdout: "", stderr: "", timed_out: false, error: nil)
+    Probes::CommandResult.new(
+      argv: argv,
+      exitstatus: exitstatus,
+      stdout: stdout,
+      stderr: stderr,
+      timed_out: timed_out,
+      error: error
+    )
+  end
+
+  def test_codex_probe_passes_after_login_and_smoke_succeed
+    project_row do |row, _root|
+      runner = FakeRunner.new do |argv, **kwargs|
+        if argv == [ "codex", "login", "status" ]
+          result(argv: argv, stdout: "Logged in as user@example.com")
+        else
+          assert_equal "Reply with hive-auto-retry-smoke.\n", kwargs.fetch(:stdin_data)
+          result(argv: argv, stdout: "{\"type\":\"message\"}\n")
+        end
+      end
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      probe = probes.probe(:codex_auth, row: row, now: T0)
+
+      assert_equal true, probe.healthy
+      assert_equal :codex_auth, probe.probe
+      assert_equal %w[hive_doctor codex_profile codex_login_status codex_exec_smoke],
+                   probe.checks.map(&:name)
+      assert_equal [ "codex", "exec" ], runner.calls.last.fetch(:argv).first(2)
+      assert_includes runner.calls.last.fetch(:argv), "--json"
+    end
+  end
+
+  def test_codex_probe_fails_when_login_status_is_not_logged_in
+    project_row do |row, _root|
+      runner = FakeRunner.new do |argv, **|
+        result(argv: argv, exitstatus: 0, stdout: "Not logged in")
+      end
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      probe = probes.probe(:codex_auth, row: row, now: T0)
+
+      assert_equal false, probe.healthy
+      assert_equal "codex_login_status", probe.checks.find { |check| !check.healthy }.name
+      assert_equal 1, runner.calls.size, "failed login must skip the smoke command"
+    end
+  end
+
+  def test_codex_probe_treats_timeout_as_unhealthy
+    project_row do |row, _root|
+      runner = FakeRunner.new do |argv, **|
+        result(argv: argv, timed_out: true)
+      end
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      probe = probes.probe(:codex_auth, row: row, now: T0)
+
+      assert_equal false, probe.healthy
+      failed = probe.checks.find { |check| !check.healthy }
+      assert_equal "codex_login_status", failed.name
+      assert_equal true, failed.timed_out
+    end
+  end
+
+  def test_codex_probe_treats_runner_exception_as_unhealthy
+    project_row do |row, _root|
+      runner = FakeRunner.new { |_argv, **| raise IOError, "boom" }
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      probe = probes.probe(:codex_auth, row: row, now: T0)
+
+      assert_equal false, probe.healthy
+      failed = probe.checks.find { |check| !check.healthy }
+      assert_equal "codex_login_status", failed.name
+      assert_match(/IOError: boom/, failed.error)
+    end
+  end
+
+  def test_probe_results_are_cached_per_tick_and_reason
+    project_row do |row, _root|
+      runner = FakeRunner.new do |argv, **|
+        stdout = argv.include?("status") ? "Logged in" : ""
+        result(argv: argv, stdout: stdout)
+      end
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      first = probes.probe(:codex_auth, row: row, now: T0)
+      second = probes.probe(:codex_auth, row: row, now: T0)
+
+      assert_same first, second
+      assert_equal 2, runner.calls.size, "login + smoke should run once for the tick, not once per row"
+    end
+  end
+
+  def test_probe_output_is_scrubbed_for_audit_payloads
+    project_row do |row, _root|
+      runner = FakeRunner.new do |argv, **|
+        result(argv: argv, exitstatus: 1,
+               stderr: "Authorization: Bearer abcdefghijklmnop")
+      end
+      probes = Probes.new(command_runner: runner, doctor_runner: healthy_doctor, cfg_loader: cfg_loader)
+
+      payload = probes.probe(:codex_auth, row: row, now: T0).to_h.inspect
+
+      refute_includes payload, "abcdefghijklmnop"
+      assert_includes payload, "[REDACTED:bearer_token]"
+    end
+  end
+
+  def test_claude_launcher_probe_passes_with_wrapper_detector_versions_and_doctor
+    project_row do |row, _root|
+      Dir.mktmpdir do |dir|
+        wrapper = File.join(dir, "interactive_claude_wrapper.sh")
+        File.write(wrapper, "#!/usr/bin/env bash\n")
+        runner = FakeRunner.new do |argv, **|
+          assert_equal [ "/tmp/hive", "--version" ], argv
+          result(argv: argv, stdout: "#{Hive::VERSION}\n")
+        end
+        probes = Probes.new(
+          command_runner: runner,
+          doctor_runner: healthy_doctor,
+          cfg_loader: cfg_loader,
+          version_checker: ->(_profile) { "2.1.999" },
+          hive_binary_resolver: -> { "/tmp/hive" },
+          wrapper_path: wrapper
+        )
+
+        probe = probes.probe(:claude_launcher, row: row, now: T0)
+
+        assert_equal true, probe.healthy
+        assert_equal %w[
+          hive_doctor claude_wrapper claude_ready_detector claude_profile
+          claude_version hive_cli_version
+        ], probe.checks.map(&:name)
+      end
+    end
+  end
+
+  def test_claude_launcher_probe_fails_when_wrapper_is_missing
+    project_row do |row, _root|
+      probes = Probes.new(
+        command_runner: FakeRunner.new { |argv, **| result(argv: argv) },
+        doctor_runner: healthy_doctor,
+        cfg_loader: cfg_loader,
+        wrapper_path: "/no/such/wrapper"
+      )
+
+      probe = probes.probe(:claude_launcher, row: row, now: T0)
+
+      assert_equal false, probe.healthy
+      assert_equal "claude_wrapper", probe.checks.find { |check| !check.healthy }.name
+    end
+  end
+
+  def test_claude_launcher_probe_fails_when_hive_cli_version_mismatches
+    project_row do |row, _root|
+      Dir.mktmpdir do |dir|
+        wrapper = File.join(dir, "interactive_claude_wrapper.sh")
+        File.write(wrapper, "#!/usr/bin/env bash\n")
+        runner = FakeRunner.new { |argv, **| result(argv: argv, stdout: "9.9.9\n") }
+        probes = Probes.new(
+          command_runner: runner,
+          doctor_runner: healthy_doctor,
+          cfg_loader: cfg_loader,
+          version_checker: ->(_profile) { "2.1.999" },
+          hive_binary_resolver: -> { "/tmp/hive" },
+          wrapper_path: wrapper
+        )
+
+        probe = probes.probe(:claude_launcher, row: row, now: T0)
+
+        assert_equal false, probe.healthy
+        failed = probe.checks.find { |check| !check.healthy }
+        assert_equal "hive_cli_version", failed.name
+        assert_match(/mismatch/, failed.detail)
+      end
+    end
+  end
+end
