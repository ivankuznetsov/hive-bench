@@ -0,0 +1,98 @@
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/auto_retry/classifier"
+require "hive/daemon/auto_retry/safety_guard"
+
+class HiveDaemonAutoRetrySafetyGuardTest < Minitest::Test
+  Row = Struct.new(:folder, :state_file, :stage, keyword_init: true)
+
+  Classification = Hive::Daemon::AutoRetry::Classifier::Classification
+
+  def classification
+    Classification.new(reason: "implementer_failed", subreason: "codex_auth_401", probe: :codex_auth)
+  end
+
+  def test_execute_worktree_is_safe_when_clean
+    Dir.mktmpdir do |dir|
+      worktree = File.join(dir, "worktree")
+      FileUtils.mkdir_p(worktree)
+      folder = File.join(dir, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "task.md")
+      File.write(state_file, "# task\n<!-- ERROR reason=implementer_failed -->\n")
+      File.write(File.join(folder, "worktree.yml"), { "path" => worktree }.to_yaml)
+      guard = Hive::Daemon::AutoRetry::SafetyGuard.new(git_status_reader: ->(_path) { "" })
+
+      result = guard.safe?(Row.new(folder: folder, state_file: state_file, stage: "4-execute"),
+                           classification: classification)
+
+      assert_equal true, result.safe?
+      assert_equal "clean_worktree", result.rationale
+    end
+  end
+
+  def test_execute_worktree_is_unsafe_when_dirty
+    Dir.mktmpdir do |dir|
+      worktree = File.join(dir, "worktree")
+      FileUtils.mkdir_p(worktree)
+      folder = File.join(dir, "task")
+      FileUtils.mkdir_p(folder)
+      state_file = File.join(folder, "task.md")
+      File.write(state_file, "# task\n<!-- ERROR reason=implementer_failed -->\n")
+      File.write(File.join(folder, "worktree.yml"), { "path" => worktree }.to_yaml)
+      guard = Hive::Daemon::AutoRetry::SafetyGuard.new(git_status_reader: ->(_path) { " M app.rb\n" })
+
+      result = guard.safe?(Row.new(folder: folder, state_file: state_file, stage: "4-execute"),
+                           classification: classification)
+
+      assert_equal false, result.safe?
+      assert_equal "dirty_worktree", result.rationale
+      assert_equal " M app.rb\n", result.details.fetch(:status_short)
+    end
+  end
+
+  def test_terminal_success_marker_blocks_retry
+    Dir.mktmpdir do |dir|
+      state_file = File.join(dir, "task.md")
+      File.write(state_file, "# task\n<!-- EXECUTE_COMPLETE -->\n<!-- ERROR reason=implementer_failed -->\n")
+      guard = Hive::Daemon::AutoRetry::SafetyGuard.new
+
+      result = guard.safe?(Row.new(folder: dir, state_file: state_file, stage: "4-execute"),
+                           classification: classification)
+
+      assert_equal false, result.safe?
+      assert_equal "terminal_success_present", result.rationale
+    end
+  end
+
+  def test_brainstorm_or_plan_answered_content_blocks_launcher_retry
+    %w[2-brainstorm 3-plan].each do |stage|
+      Dir.mktmpdir do |dir|
+        state_file = File.join(dir, "state.md")
+        File.write(state_file, "# #{stage}\n\nUser answer that should not be overwritten\n<!-- ERROR reason=claude_launch_failed -->\n")
+        guard = Hive::Daemon::AutoRetry::SafetyGuard.new
+
+        result = guard.safe?(Row.new(folder: dir, state_file: state_file, stage: stage),
+                             classification: classification)
+
+        assert_equal false, result.safe?, "#{stage} content should block retry"
+        assert_equal "answered_content_present", result.rationale
+      end
+    end
+  end
+
+  def test_missing_worktree_pointer_is_unsafe
+    Dir.mktmpdir do |dir|
+      state_file = File.join(dir, "task.md")
+      File.write(state_file, "# task\n<!-- ERROR reason=implementer_failed -->\n")
+      guard = Hive::Daemon::AutoRetry::SafetyGuard.new
+
+      result = guard.safe?(Row.new(folder: dir, state_file: state_file, stage: "4-execute"),
+                           classification: classification)
+
+      assert_equal false, result.safe?
+      assert_equal "worktree_pointer_missing", result.rationale
+    end
+  end
+end
diff --git a/test/unit/daemon/auto_retry/signal_test.rb b/test/unit/daemon/auto_retry/signal_test.rb
new file mode 100644
index 00000000..707eeb24
--- /dev/null
+++ b/test/unit/daemon/auto_retry/signal_test.rb
@@ -0,0 +1,142 @@
+require "test_helper"
+require "tmpdir"
+require "fileutils"
+require "hive/daemon/auto_retry/classifier"
+require "hive/daemon/auto_retry/signal"
+
+class HiveDaemonAutoRetrySignalTest < Minitest::Test
+  Row = Struct.new(:project, :folder, keyword_init: true)
+
+  Signal = Hive::Daemon::AutoRetry::Signal
+  AttemptTracker = Hive::Daemon::AutoRetry::AttemptTracker
+  Classification = Hive::Daemon::AutoRetry::Classifier::Classification
+
+  T0 = Time.utc(2026, 7, 1, 12, 0, 0)
+
+  def project_fixture
+    Dir.mktmpdir do |root|
+      folder = File.join(root, ".hive-state", "stages", "4-execute", "task-260701-abcd")
+      FileUtils.mkdir_p(folder)
+      yield root, Row.new(project: "p", folder: folder)
+    end
+  end
+
+  def cfg_loader
+    ->(_root) { Hive::Config.merge_defaults({ "execute" => { "agent" => "codex" } }) }
+  end
+
+  def codex_classification
+    Classification.new(reason: "implementer_failed", subreason: "codex_auth_401", probe: :codex_auth)
+  end
+
+  def claude_classification
+    Classification.new(reason: "claude_launch_failed", subreason: "claude_launcher", probe: :claude_launcher)
+  end
+
+  def test_fingerprint_is_stable_for_unchanged_inputs
+    project_fixture do |root, row|
+      home = File.join(root, "home")
+      FileUtils.mkdir_p(home)
+      signal = Signal.new(cfg_loader: cfg_loader, home: home, hive_binary_resolver: -> { nil })
+
+      first = signal.fingerprint(row: row, classification: codex_classification)
+      second = signal.fingerprint(row: row, classification: codex_classification)
+
+      assert_equal first.value, second.value
+      assert_equal first.components, second.components
+    end
+  end
+
+  def test_fingerprint_changes_when_codex_auth_artifact_changes
+    project_fixture do |root, row|
+      home = File.join(root, "home")
+      auth = File.join(home, ".codex", "auth.json")
+      FileUtils.mkdir_p(File.dirname(auth))
+      signal = Signal.new(cfg_loader: cfg_loader, home: home, hive_binary_resolver: -> { nil })
+
+      before = signal.fingerprint(row: row, classification: codex_classification).value
+      File.write(auth, "{\"token\":\"present\"}")
+      File.utime(Time.now + 2, Time.now + 2, auth)
+      after = signal.fingerprint(row: row, classification: codex_classification).value
+
+      refute_equal before, after
+    end
+  end
+
+  def test_claude_fingerprint_includes_wrapper_mtime
+    project_fixture do |root, row|
+      home = File.join(root, "home")
+      wrapper = File.join(root, "wrapper.sh")
+      File.write(wrapper, "one")
+      signal = Signal.new(cfg_loader: cfg_loader, home: home, wrapper_path: wrapper, hive_binary_resolver: -> { nil })
+
+      before = signal.fingerprint(row: row, classification: claude_classification).value
+      File.write(wrapper, "two")
+      File.utime(Time.now + 2, Time.now + 2, wrapper)
+      after = signal.fingerprint(row: row, classification: claude_classification).value
+
+      refute_equal before, after
+    end
+  end
+
+  def test_fingerprint_components_redact_secret_like_values
+    project_fixture do |root, row|
+      env = {
+        "HIVE_CODEX_BIN" => "api_key=abcdefghijklmnopqrstuvwxyz",
+        "HIVE_CLAUDE_BIN" => "claude"
+      }
+      signal = Signal.new(cfg_loader: cfg_loader, env: env, home: File.join(root, "home"),
+                          hive_binary_resolver: -> { nil })
+
+      payload = signal.fingerprint(row: row, classification: codex_classification).components.inspect
+
+      refute_includes payload, "abcdefghijklmnopqrstuvwxyz"
+      assert_includes payload, "[REDACTED:generic_api_key]"
+    end
+  end
+
+  def test_attempt_tracker_blocks_unchanged_signal_without_spending_budget
+    tracker = AttemptTracker.new
+    key = [ "p", "s", "4-execute", "implementer_failed" ]
+
+    first = tracker.decision(key: key, fingerprint: "fp1", now: T0)
+    assert_equal :probe, first.action
+    assert_equal true, first.retry_allowed?
+    tracker.record_probe(key: key, fingerprint: "fp1", now: T0)
+
+    unchanged = tracker.decision(key: key, fingerprint: "fp1", now: T0 + 60)
+
+    assert_equal :unchanged_signal, unchanged.action
+    assert_equal 0, tracker.attempts_for(key)
+  end
+
+  def test_attempt_tracker_enforces_immediate_then_thirty_minute_backoff
+    tracker = AttemptTracker.new
+    key = [ "p", "s", "4-execute", "implementer_failed" ]
+
+    tracker.record_retry(key: key, fingerprint: "fp1", now: T0)
+
+    early = tracker.decision(key: key, fingerprint: "fp2", now: T0 + 60)
+    assert_equal :backoff, early.action
+    assert_equal T0 + (30 * 60), early.next_eligible_at
+
+    later = tracker.decision(key: key, fingerprint: "fp2", now: T0 + (30 * 60))
+    assert_equal :probe, later.action
+    assert_equal true, later.retry_allowed?
+    assert_equal 2, later.next_attempt
+  end
