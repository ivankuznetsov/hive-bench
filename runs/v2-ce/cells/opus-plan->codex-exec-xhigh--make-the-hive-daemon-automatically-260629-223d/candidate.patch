+      File.write(state_file, "# task\n\n<!-- ERROR reason=implementer_failed message=\"401 Unauthorized\" -->\n")
+      @healer.heal([ row ], now: NOW + (60 * 60))
+
+      assert_match(/ERROR reason=implementer_failed/, File.read(state_file),
+                   "third auto-retry should stay red after the two retry budget")
+      exhausted = @logger.events.select { |name, _| name == :auto_retry_exhausted }
