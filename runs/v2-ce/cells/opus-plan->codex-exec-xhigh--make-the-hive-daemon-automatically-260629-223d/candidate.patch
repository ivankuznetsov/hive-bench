diff --git a/lib/hive/daemon/auto_retry/classifier.rb b/lib/hive/daemon/auto_retry/classifier.rb
new file mode 100644
index 00000000..1bf5c95a
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/classifier.rb
@@ -0,0 +1,136 @@
+require "hive/task"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Read-only classifier for terminal ERROR markers that the daemon may
+      # probe-gate and retry. It returns diagnostic labels only; raw marker/log
+      # text never leaves this class.
+      class Classifier
+        LOG_TAIL_BYTES = 32 * 1024
+        LOG_GLOB_CAP = 10
+
+        AUTH_PATTERNS = {
+          codex_auth_401: /\b401\b/i,
+          codex_auth_unauthorized: /\bunauthori[sz]ed\b/i,
+          codex_auth_missing_bearer: /\bmissing\s+bearer\b/i,
+          codex_auth_missing_basic: /\bmissing\s+(?:bearer|basic)\b/i,
+          codex_auth_basic: /(?:\bauthori[sz]ation\b|\bauth\b).{0,80}\bBasic\b|\bBasic\b.{0,80}(?:\bauthori[sz]ation\b|\bauth\b)/i
+        }.freeze
+
+        Classification = Struct.new(
+          :reason,
+          :subreason,
+          :probe,
+          :evidence_sources,
+          keyword_init: true
+        ) do
+          def to_h
+            {
+              reason: reason,
+              subreason: subreason,
+              probe: probe,
+              evidence_sources: Array(evidence_sources)
+            }
+          end
+        end
+
+        def classify(row)
+          reason = marker_reason(row)
+          return claude_launch_classification if reason == "claude_launch_failed"
+          return nil unless reason == "implementer_failed"
+
+          sources = codex_auth_evidence_sources(row)
+          return nil if sources.empty?
+
+          Classification.new(
+            reason: reason,
+            subreason: "codex_auth_401",
+            probe: :codex_auth,
+            evidence_sources: sources
+          )
+        end
+
+        private
+
+        def claude_launch_classification
+          Classification.new(
+            reason: "claude_launch_failed",
+            subreason: "claude_launcher",
+            probe: :claude_launcher,
+            evidence_sources: [ :marker_reason ]
+          )
+        end
+
+        def codex_auth_evidence_sources(row)
+          sources = []
+          attrs = marker_attrs(row)
+          explicit = attrs["diagnostic"].to_s
+          sources << :marker_diagnostic if explicit == "codex_auth_401"
+
+          message = attrs["message"].to_s
+          sources << :marker_message if codex_auth_signature?(message)
+          sources << :agent_log if newest_log_tails(row).any? { |tail| codex_auth_signature?(tail) }
+          sources.uniq
+        end
+
+        def codex_auth_signature?(text)
+          AUTH_PATTERNS.values.any? { |pattern| text.to_s.match?(pattern) }
+        end
+
+        def newest_log_tails(row)
+          log_candidates(row).map { |path| read_tail(path) }.reject(&:empty?)
+        end
+
+        def log_candidates(row)
+          dirs = log_dirs(row)
+          candidates = dirs.flat_map { |dir| Dir[File.join(dir, "*.log")] }
+          candidates.sort_by { |path| safe_mtime(path) || Time.at(0) }
+                    .last(LOG_GLOB_CAP)
+                    .reverse
+        rescue SystemCallError
+          []
+        end
+
+        def log_dirs(row)
+          dirs = []
+          folder = row.respond_to?(:folder) ? row.folder.to_s : ""
+          dirs << File.join(folder, "logs") unless folder.empty?
+
+          match = Hive::Task::PATH_RE.match(folder)
+          if match
+            dirs << File.join(match[:root], match[:state_dir], "logs", match[:slug])
+          end
+          dirs.uniq
+        end
+
+        def read_tail(path)
+          File.open(path, "rb") do |file|
+            size = file.size
+            file.seek([ size - LOG_TAIL_BYTES, 0 ].max)
+            file.read.to_s
+          end
+        rescue SystemCallError
+          ""
+        end
+
+        def safe_mtime(path)
+          File.mtime(path)
+        rescue SystemCallError
+          nil
+        end
+
+        def marker_reason(row)
+          marker_attrs(row)["reason"].to_s
+        end
+
+        def marker_attrs(row)
+          return {} unless row.respond_to?(:marker_attrs)
+          return row.marker_attrs if row.marker_attrs.is_a?(Hash)
+
+          {}
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/probes.rb b/lib/hive/daemon/auto_retry/probes.rb
new file mode 100644
index 00000000..58d529c9
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/probes.rb
@@ -0,0 +1,379 @@
+require "open3"
+require "stringio"
+require "time"
+
+require "hive"
+require "hive/agent"
+require "hive/agent_profiles"
+require "hive/commands/doctor"
+require "hive/config"
+require "hive/claude_launcher"
+require "hive/invoked_binary"
+require "hive/secret_patterns"
+require "hive/task"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Probe suite for daemon auto-retry. All expensive/external checks are
+      # injectable and cached per tick so one parked reason triggers at most one
+      # probe run in a dispatcher tick.
+      class Probes
+        MAX_OUTPUT_BYTES = 2 * 1024
+        CODEX_LOGIN_TIMEOUT_SEC = 10
+        CODEX_SMOKE_TIMEOUT_SEC = 30
+        HIVE_VERSION_TIMEOUT_SEC = 10
+
+        CommandResult = Struct.new(
+          :argv,
+          :exitstatus,
+          :stdout,
+          :stderr,
+          :timed_out,
+          :error,
+          keyword_init: true
+        ) do
+          def success?
+            !timed_out && error.to_s.empty? && exitstatus == 0
+          end
+        end
+
+        Check = Struct.new(
+          :name,
+          :healthy,
+          :detail,
+          :stdout,
+          :stderr,
+          :exitstatus,
+          :timed_out,
+          :error,
+          keyword_init: true
+        ) do
+          def to_h
+            {
+              name: name,
+              healthy: healthy,
+              detail: detail,
+              stdout: stdout,
+              stderr: stderr,
+              exitstatus: exitstatus,
+              timed_out: timed_out,
+              error: error
+            }.compact
+          end
+        end
+
+        Result = Struct.new(:probe, :healthy, :checks, :summary, keyword_init: true) do
+          def to_h
+            {
+              probe: probe,
+              healthy: healthy,
+              summary: summary,
+              checks: Array(checks).map(&:to_h)
+            }
+          end
+        end
+
+        class CommandRunner
+          def call(argv, env:, timeout:, chdir:, stdin_data: nil)
+            out = +""
+            err = +""
+            status = nil
+            timed_out = false
+            Open3.popen3(env, *argv, chdir: chdir) do |stdin, stdout, stderr, wait_thr|
+              stdin.write(stdin_data.to_s) unless stdin_data.nil?
+              stdin.close
+              out_reader = Thread.new { stdout.read.to_s }
+              err_reader = Thread.new { stderr.read.to_s }
+              unless wait_thr.join(timeout)
+                timed_out = true
+                terminate_process(wait_thr.pid)
+                wait_thr.join(1)
+              end
+              status = wait_thr.value if wait_thr.stop?
+              out = out_reader.value
+              err = err_reader.value
+            end
+            CommandResult.new(
+              argv: argv,
+              exitstatus: status&.exitstatus,
+              stdout: out,
+              stderr: err,
+              timed_out: timed_out
+            )
+          rescue StandardError => e
+            CommandResult.new(argv: argv, exitstatus: nil, stdout: out, stderr: err,
+                              timed_out: timed_out, error: "#{e.class}: #{e.message}")
+          end
+
+          private
+
+          def terminate_process(pid)
+            Process.kill("TERM", pid)
+            sleep 0.1
+            Process.kill("KILL", pid)
+          rescue Errno::ESRCH, Errno::EPERM
+            nil
+          end
+        end
+
+        def initialize(command_runner: CommandRunner.new,
+                       doctor_runner: nil,
+                       cfg_loader: nil,
+                       version_checker: nil,
+                       hive_binary_resolver: nil,
+                       wrapper_path: nil)
+          @command_runner = command_runner
+          @doctor_runner = doctor_runner || method(:run_doctor)
+          @cfg_loader = cfg_loader || ->(project_root) { Hive::Config.load(project_root) }
+          @version_checker = version_checker || ->(profile) { profile.check_version! }
+          @hive_binary_resolver = hive_binary_resolver || -> { Hive::InvokedBinary.path }
+          @wrapper_path = wrapper_path || File.expand_path("../../scripts/interactive_claude_wrapper.sh", __dir__)
+          @cache_tick = nil
+          @cache = {}
+        end
+
+        def probe(probe, row:, now:)
+          reset_cache_for(now)
+          key = probe.to_sym
+          @cache[key] ||= run_probe(key, row: row)
+        end
+
+        private
+
+        def reset_cache_for(now)
+          return if @cache_tick == now
+
+          @cache_tick = now
+          @cache = {}
+        end
+
+        def run_probe(probe, row:)
+          case probe
+          when :codex_auth then probe_codex_auth(row)
+          when :claude_launcher then probe_claude_launcher(row)
+          else
+            Result.new(probe: probe, healthy: false, checks: [
+              failed_check("probe", "unknown probe #{probe.inspect}")
+            ], summary: "unknown probe")
+          end
+        rescue StandardError => e
+          Result.new(probe: probe, healthy: false, checks: [
+            failed_check("probe_exception", "#{e.class}: #{e.message}")
+          ], summary: "#{probe} probe raised")
+        end
+
+        def probe_codex_auth(row)
+          context = load_context(row)
+          checks = [ doctor_check(context) ]
+          return result(:codex_auth, checks) unless checks.last.healthy
+
+          profile = lookup_profile(:codex, context)
+          checks << profile
+          return result(:codex_auth, checks) unless profile.healthy
+
+          bin = profile.detail
+          login = run_command(
+            [ bin, "login", "status" ],
+            timeout: CODEX_LOGIN_TIMEOUT_SEC,
+            chdir: context.fetch(:project_root)
+          )
+          checks << command_check(
+            "codex_login_status",
+            login,
+            healthy: login.success? && logged_in_output?(login),
+            detail: login.success? ? "codex login status checked" : "codex login status failed"
+          )
+          return result(:codex_auth, checks) unless checks.last.healthy
+
+          smoke = run_command(
+            codex_smoke_argv(bin, profile: context.fetch(:profiles).fetch(:codex)),
+            timeout: CODEX_SMOKE_TIMEOUT_SEC,
+            chdir: context.fetch(:project_root),
+            stdin_data: "Reply with hive-auto-retry-smoke.\n"
+          )
+          checks << command_check(
+            "codex_exec_smoke",
+            smoke,
+            healthy: smoke.success?,
+            detail: smoke.success? ? "codex exec smoke passed" : "codex exec smoke failed"
+          )
+          result(:codex_auth, checks)
+        end
+
+        def probe_claude_launcher(row)
+          context = load_context(row)
+          checks = [ doctor_check(context) ]
+          return result(:claude_launcher, checks) unless checks.last.healthy
+
+          checks << wrapper_check
+          return result(:claude_launcher, checks) unless checks.last.healthy
+
+          checks << ready_detector_check
+          return result(:claude_launcher, checks) unless checks.last.healthy
+
+          profile = lookup_profile(:claude, context)
+          checks << profile
+          return result(:claude_launcher, checks) unless profile.healthy
+
+          checks << claude_version_check(context.fetch(:profiles).fetch(:claude))
+          return result(:claude_launcher, checks) unless checks.last.healthy
+
+          checks << hive_cli_version_check
+          result(:claude_launcher, checks)
+        end
+
+        def load_context(row)
+          project_root = project_root_for(row)
+          unless project_root && File.directory?(project_root)
+            raise Hive::ConfigError, "project root unavailable for #{row.respond_to?(:folder) ? row.folder : row.inspect}"
+          end
+
+          cfg = @cfg_loader.call(project_root)
+          { project_root: project_root, cfg: cfg, profiles: {} }
+        end
+
+        def project_root_for(row)
+          folder = row.respond_to?(:folder) ? row.folder.to_s : ""
+          match = Hive::Task::PATH_RE.match(folder)
+          return match[:root] if match
+
+          project = row.respond_to?(:project) ? row.project.to_s : ""
+          record = Hive::Config.find_project(project) unless project.empty?
+          record && record["path"]
+        rescue StandardError
+          nil
+        end
+
+        def doctor_check(context)
+          @doctor_runner.call(project_root: context.fetch(:project_root), cfg: context.fetch(:cfg))
+        rescue StandardError => e
+          failed_check("hive_doctor", "#{e.class}: #{e.message}")
+        end
+
+        def run_doctor(project_root:, cfg:)
+          output = StringIO.new
+          doctor = Hive::Commands::Doctor.new(config: cfg, project_root: project_root, json: false, output: output)
+          exit_code = doctor.call
+          unhealthy_rows = Array(doctor.rows).select { |row| %w[missing version_too_old].include?(row[:status].to_s) }
+          Check.new(
+            name: "hive_doctor",
+            healthy: exit_code == Hive::Commands::Doctor::EXIT_SUCCESS && unhealthy_rows.empty?,
+            detail: unhealthy_rows.empty? ? "hive doctor passed" : "hive doctor reported missing or stale dependencies",
+            stdout: scrub(output.string),
+            exitstatus: exit_code
+          )
+        end
+
+        def lookup_profile(name, context)
+          profile = Hive::AgentProfiles.lookup(name, cfg: context.fetch(:cfg))
+          context.fetch(:profiles)[name] = profile
+          Check.new(name: "#{name}_profile", healthy: true, detail: profile.bin)
+        rescue StandardError => e
+          failed_check("#{name}_profile", "#{e.class}: #{e.message}")
+        end
+
+        def claude_version_check(profile)
+          version = @version_checker.call(profile)
+          Check.new(name: "claude_version", healthy: true, detail: "claude #{version}")
+        rescue StandardError => e
+          failed_check("claude_version", "#{e.class}: #{e.message}")
+        end
+
+        def hive_cli_version_check
+          hive_bin = @hive_binary_resolver.call
+          return failed_check("hive_cli_version", "hive binary unavailable") if hive_bin.to_s.empty?
+
+          command = run_command([ hive_bin, "--version" ], timeout: HIVE_VERSION_TIMEOUT_SEC, chdir: Dir.pwd)
+          healthy = command.success? && command.stdout.to_s.strip == Hive::VERSION
+          command_check(
+            "hive_cli_version",
+            command,
+            healthy: healthy,
+            detail: healthy ? "hive CLI version matches daemon #{Hive::VERSION}" : "hive CLI version mismatch"
+          )
+        end
+
+        def wrapper_check
+          if File.file?(@wrapper_path) && File.readable?(@wrapper_path)
+            Check.new(name: "claude_wrapper", healthy: true, detail: @wrapper_path)
+          else
+            failed_check("claude_wrapper", "wrapper missing or unreadable: #{@wrapper_path}")
+          end
+        end
+
+        def ready_detector_check
+          pane = "Claude Code\n\n/work/repo main ?  ❯\n⏵⏵ bypass permissions mode enabled for agents\n"
+          if Hive::ClaudeLauncher.claude_ready_prompt?(pane)
+            Check.new(name: "claude_ready_detector", healthy: true, detail: "ready fixture accepted")
+          else
+            failed_check("claude_ready_detector", "ready fixture was not accepted")
+          end
+        end
+
+        def codex_smoke_argv(bin, profile:)
+          argv = [ bin ]
+          argv << profile.headless_flag if profile.headless_flag
+          argv.concat(profile.permission_flags("bypassPermissions"))
+          argv.concat(profile.output_format_flags)
+          argv << "-"
+          argv
+        end
+
+        def logged_in_output?(command)
+          text = [ command.stdout, command.stderr ].join("\n")
+          return false if text.match?(/not\s+logged\s+in|unauthenticated|unauthori[sz]ed|failed/i)
+
+          text.match?(/logged\s+in|authenticated|signed\s+in/i)
+        end
+
+        def run_command(argv, timeout:, chdir:, stdin_data: nil)
+          @command_runner.call(
+            argv,
+            env: Hive::Agent::SCRUBBED_CHILD_ENV,
+            timeout: timeout,
+            chdir: chdir,
+            stdin_data: stdin_data
+          )
+        rescue StandardError => e
+          CommandResult.new(argv: argv, exitstatus: nil, stdout: "", stderr: "",
+                            timed_out: false, error: "#{e.class}: #{e.message}")
+        end
+
+        def command_check(name, command, healthy:, detail:)
+          Check.new(
+            name: name,
+            healthy: healthy,
+            detail: detail,
+            stdout: scrub(command.stdout),
+            stderr: scrub(command.stderr),
+            exitstatus: command.exitstatus,
+            timed_out: command.timed_out,
+            error: scrub(command.error)
+          )
+        end
+
+        def failed_check(name, detail)
+          Check.new(name: name, healthy: false, detail: scrub(detail))
+        end
+
+        def result(probe, checks)
+          healthy = checks.all?(&:healthy)
+          Result.new(
+            probe: probe,
+            healthy: healthy,
+            checks: checks,
+            summary: healthy ? "healthy" : checks.find { |check| !check.healthy }&.detail
+          )
+        end
+
+        def scrub(text)
+          redacted = Hive::SecretPatterns.redact(text.to_s)
+          return redacted if redacted.bytesize <= MAX_OUTPUT_BYTES
+
+          "#{redacted.byteslice(0, MAX_OUTPUT_BYTES).to_s.scrub}...[truncated]"
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/safety_guard.rb b/lib/hive/daemon/auto_retry/safety_guard.rb
new file mode 100644
index 00000000..8e096e6e
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/safety_guard.rb
@@ -0,0 +1,83 @@
+require "yaml"
+
+require "hive/git_ops"
+require "hive/worktree"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Default-deny safety checks before clearing a terminal ERROR marker for
+      # auto-retry. Ambiguous residue is unsafe by design.
+      class SafetyGuard
+        SUCCESS_MARKER_RE = /<!--\s*(?:COMPLETE|EXECUTE_COMPLETE|REVIEW_COMPLETE)\b/.freeze
+        MARKER_RE = /<!--.*?-->/m.freeze
+
+        Result = Struct.new(:safe, :rationale, :details, keyword_init: true) do
+          def safe?
+            safe == true
+          end
+
+          def to_h
+            { safe: safe, rationale: rationale, details: details }.compact
+          end
+        end
+
+        def initialize(git_status_reader: nil)
+          @git_status_reader = git_status_reader || ->(path) { Hive::GitOps.new(path).status_short }
+        end
+
+        def safe?(row, classification:)
+          content = File.read(row.state_file.to_s)
+          return unsafe("terminal_success_present") if content.match?(SUCCESS_MARKER_RE)
+
+          stage = row.stage.to_s
+          if stage == "4-execute"
+            return execute_worktree_safe?(row)
+          end
+
+          if %w[2-brainstorm 3-plan].include?(stage)
+            return unsafe("answered_content_present") if answered_content?(content)
+          end
+
+          Result.new(safe: true, rationale: "safe_to_retry")
+        rescue StandardError => e
+          unsafe("inspection_failed", error: "#{e.class}: #{e.message}")
+        end
+
+        private
+
+        def execute_worktree_safe?(row)
+          pointer = Hive::Worktree.read_pointer(row.folder.to_s)
+          return unsafe("worktree_pointer_missing") unless pointer.is_a?(Hash)
+
+          path = pointer["path"].to_s
+          return unsafe("worktree_path_missing") if path.empty?
+          return unsafe("worktree_missing", worktree_path: path) unless File.directory?(path)
+
+          status = @git_status_reader.call(path).to_s
+          if status.strip.empty?
+            Result.new(safe: true, rationale: "clean_worktree", details: { worktree_path: path })
+          else
+            unsafe("dirty_worktree", worktree_path: path, status_short: status)
+          end
+        end
+
+        def answered_content?(content)
+          body = content.gsub(MARKER_RE, "")
+          body.lines.any? do |line|
+            stripped = line.strip
+            next false if stripped.empty?
+            next false if stripped.start_with?("#")
+            next false if stripped == "---"
+
+            true
+          end
+        end
+
+        def unsafe(rationale, **details)
+          Result.new(safe: false, rationale: rationale, details: details.empty? ? nil : details)
+        end
+      end
+    end
+  end
+end
diff --git a/lib/hive/daemon/auto_retry/signal.rb b/lib/hive/daemon/auto_retry/signal.rb
new file mode 100644
index 00000000..43461aa8
--- /dev/null
+++ b/lib/hive/daemon/auto_retry/signal.rb
@@ -0,0 +1,309 @@
+require "digest"
+require "json"
+require "time"
+
+require "hive"
+require "hive/agent_profiles"
+require "hive/config"
+require "hive/invoked_binary"
+require "hive/secret_patterns"
+require "hive/task"
+
+module Hive
+  module Daemon
+    module AutoRetry
+      # Stable, audit-safe health-signal fingerprint for probe-gated daemon
+      # retries. The digest changes when the local CLI/config/auth/wrapper
+      # signals that matter to the allowlisted reason change.
+      class Signal
+        Fingerprint = Struct.new(:value, :components, keyword_init: true) do
+          def to_h
+            { value: value, components: components }
+          end
+        end
+
+        def initialize(cfg_loader: nil, hive_binary_resolver: nil, env: ENV, home: Dir.home,
+                       wrapper_path: nil)
+          @cfg_loader = cfg_loader || ->(project_root) { Hive::Config.load(project_root) }
+          @hive_binary_resolver = hive_binary_resolver || -> { Hive::InvokedBinary.path }
+          @env = env
+          @home = home
+          @wrapper_path = wrapper_path || File.expand_path("../../scripts/interactive_claude_wrapper.sh", __dir__)
+        end
+
+        def fingerprint(row:, classification:)
+          components = base_components(row)
+          case classification.probe
+          when :codex_auth
+            components["codex"] = codex_components
+          when :claude_launcher
+            components["claude"] = claude_components
+          end
+          safe = scrub_components(components)
+          Fingerprint.new(value: Digest::SHA256.hexdigest(JSON.generate(safe)), components: safe)
+        end
+
+        private
+
+        def base_components(row)
+          root = project_root_for(row)
+          cfg = root ? safe_load_cfg(root) : {}
+          {
+            "hive" => {
+              "version" => Hive::VERSION,
+              "binary" => file_component(@hive_binary_resolver.call)
+            },
+            "project" => {
+              "root" => root,
+              "execute_agent" => cfg.dig("execute", "agent"),
+              "claude_mode" => cfg.dig("claude", "mode"),
+              "claude_permission_mode" => cfg.dig("claude", "permission_mode"),
+              "agents" => agent_config_components(cfg)
+            },
+            "env" => selected_env,
+            "skills" => skill_inventory_components(root)
+          }
+        end
+
+        def codex_components
+          auth_path = File.join(@home.to_s, ".codex", "auth.json")
+          {
+            "logged_in" => Hive::AgentProfiles.logged_in?(:codex, home: @home.to_s),
+            "auth_file" => file_component(auth_path)
+          }
+        end
+
+        def claude_components
+          {
+            "wrapper" => file_component(@wrapper_path),
+            "credentials" => file_component(File.join(@home.to_s, ".claude", ".credentials.json"))
+          }
+        end
+
+        def agent_config_components(cfg)
+          %w[codex claude].to_h do |name|
+            [
+              name,
+              {
+                "bin" => cfg.dig("agents", name, "bin"),
+                "env_override" => cfg.dig("agents", name, "env_override"),
+                "min_version" => cfg.dig("agents", name, "min_version")
+              }
+            ]
+          end
+        end
+
+        def selected_env
+          %w[
+            HIVE_CODEX_BIN
+            HIVE_CLAUDE_BIN
+            HIVE_TMUX_BIN
+            HIVE_INVOKED_BIN
+          ].to_h { |key| [ key, @env[key].to_s ] }
+        end
+
+        def skill_inventory_components(project_root)
+          roots = [
+            File.join(@home.to_s, ".codex", "skills"),
+            File.join(@home.to_s, ".claude", "skills")
+          ]
+          roots << File.join(project_root, ".codex", "skills") if project_root
+          roots << File.join(project_root, ".claude", "skills") if project_root
+
+          roots.uniq.to_h do |root|
+            [ root, directory_inventory(root) ]
+          end
+        end
+
+        def directory_inventory(root)
+          return { "present" => false } unless File.directory?(root)
+
+          entries = Dir.children(root).sort.first(100).map do |entry|
+            path = File.join(root, entry)
+            stat = File.stat(path)
+            {
+              "name" => entry,
+              "type" => stat.directory? ? "directory" : "file",
+              "mtime" => stat.mtime.to_i,
+              "size" => stat.size
+            }
+          rescue SystemCallError
+            { "name" => entry, "unreadable" => true }
+          end
+          { "present" => true, "entries" => entries }
+        rescue SystemCallError
+          { "present" => false }
+        end
+
+        def file_component(path)
+          expanded = path.to_s.empty? ? nil : File.expand_path(path.to_s)
+          return { "path" => expanded, "present" => false } if expanded.nil?
+
+          stat = File.stat(expanded)
+          {
+            "path" => expanded,
+            "present" => true,
+            "mtime" => stat.mtime.to_i,
+            "size" => stat.size
+          }
+        rescue SystemCallError
+          { "path" => expanded, "present" => false }
+        end
+
+        def scrub_components(components)
+          case components
+          when Hash
+            components.to_h { |key, value| [ key, scrub_components(value) ] }
+          when Array
+            components.map { |value| scrub_components(value) }
+          when String
+            Hive::SecretPatterns.redact(components)
+          else
+            components
+          end
+        end
+
+        def safe_load_cfg(project_root)
+          @cfg_loader.call(project_root)
+        rescue StandardError
+          {}
+        end
+
+        def project_root_for(row)
+          folder = row.respond_to?(:folder) ? row.folder.to_s : ""
+          match = Hive::Task::PATH_RE.match(folder)
+          return match[:root] if match
+
+          project = row.respond_to?(:project) ? row.project.to_s : ""
+          record = Hive::Config.find_project(project) unless project.empty?
+          record && record["path"]
+        rescue StandardError
+          nil
+        end
+      end
+
+      # In-memory per-process budget/backoff gate for auto-retry attempts.
+      class AttemptTracker
+        AUTO_RETRY_LIMIT = 2
+        BACKOFF_SECONDS = 30 * 60
+        PERIODIC_REPROBE_SECONDS = 60 * 60
+
+        State = Struct.new(
+          :attempts,
+          :last_fingerprint,
+          :last_probe_at,
+          :next_eligible_at,
+          :exhausted_logged,
+          keyword_init: true
+        )
+
+        Decision = Struct.new(
+          :action,
+          :attempts,
+          :max_attempts,
+          :next_attempt,
+          :next_eligible_at,
+          :changed_signal,
+          :periodic_probe,
+          :rationale,
+          keyword_init: true
+        ) do
+          def probe?
+            action == :probe
+          end
+
+          def retry_allowed?
+            probe? && changed_signal
+          end
+        end
+
+        def initialize(limit: AUTO_RETRY_LIMIT, backoff_seconds: BACKOFF_SECONDS,
+                       periodic_reprobe_seconds: PERIODIC_REPROBE_SECONDS)
+          @limit = limit
+          @backoff_seconds = backoff_seconds
+          @periodic_reprobe_seconds = periodic_reprobe_seconds
+          @states = {}
+        end
+
+        def decision(key:, fingerprint:, now:)
+          state = state_for(key)
+          if state.attempts >= @limit
+            return decision_for(:exhausted, state,
+                                changed_signal: state.last_fingerprint != fingerprint,
+                                rationale: "retry budget exhausted")
+          end
+
+          if state.next_eligible_at && now < state.next_eligible_at
+            return decision_for(:backoff, state,
+                                changed_signal: state.last_fingerprint != fingerprint,
+                                rationale: "waiting for retry backoff")
+          end
+
+          changed = state.last_fingerprint != fingerprint
+          periodic = !changed && periodic_reprobe_due?(state, now)
+          unless changed || periodic
+            return decision_for(:unchanged_signal, state,
+                                changed_signal: false,
+                                rationale: "health signal unchanged")
+          end
+
+          decision_for(:probe, state,
+                       changed_signal: changed,
+                       periodic_probe: periodic,
+                       rationale: changed ? "health signal changed" : "periodic reprobe")
+        end
+
+        def record_probe(key:, fingerprint:, now:)
+          state = state_for(key)
+          state.last_fingerprint = fingerprint
+          state.last_probe_at = now
+          state
+        end
+
+        def record_retry(key:, fingerprint:, now:)
+          state = record_probe(key: key, fingerprint: fingerprint, now: now)
+          state.attempts += 1
+          state.next_eligible_at = state.attempts == 1 ? now + @backoff_seconds : nil
+          state
+        end
+
+        def exhausted_logged?(key)
+          state_for(key).exhausted_logged == true
+        end
+
+        def mark_exhausted_logged(key)
+          state_for(key).exhausted_logged = true
+        end
+
+        def attempts_for(key)
+          state_for(key).attempts
+        end
+
+        private
+
+        def state_for(key)
+          @states[key] ||= State.new(attempts: 0, exhausted_logged: false)
+        end
+
+        def periodic_reprobe_due?(state, now)
+          return false if state.last_probe_at.nil?
+
+          (now - state.last_probe_at) >= @periodic_reprobe_seconds
+        end
+
+        def decision_for(action, state, changed_signal:, rationale:, periodic_probe: false)
+          Decision.new(
+            action: action,
+            attempts: state.attempts,
+            max_attempts: @limit,
+            next_attempt: state.attempts + 1,
+            next_eligible_at: state.next_eligible_at,
+            changed_signal: changed_signal,
+            periodic_probe: periodic_probe,
+            rationale: rationale
+          )
+        end
+      end
+    end
+  end
+end
