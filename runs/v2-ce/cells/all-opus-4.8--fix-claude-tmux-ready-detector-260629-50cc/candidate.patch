+    assert_includes pane, "❯\u00A0", "the caret must be followed by an NBSP, not a plain space"
+    assert Hive::ClaudeLauncher.claude_ready_prompt?(pane),
+           "the 2.1.179 boxed idle prompt (NBSP caret, separator/footer below) must read as ready"
+  end
+
