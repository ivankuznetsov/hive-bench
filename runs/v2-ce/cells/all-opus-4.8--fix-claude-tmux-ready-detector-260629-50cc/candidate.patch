index c4cd96dd..0b03320f 100644
--- a/test/unit/gemspec_test.rb
+++ b/test/unit/gemspec_test.rb
@@ -1,7 +1,11 @@
 require "test_helper"
+require "rubygems/package"
+require "tmpdir"
+require "fileutils"
 
 class GemspecTest < Minitest::Test
   GEMSPEC_PATH = File.expand_path("../../hive.gemspec", __dir__)
+  ROOT = File.expand_path("../..", __dir__)
 
   def test_gem_package_includes_babysitter_dry_run_stubs
     spec = Gem::Specification.load(GEMSPEC_PATH)
@@ -29,4 +33,94 @@ class GemspecTest < Minitest::Test
     refute spec.files.any? { |f| f.start_with?("public/") },
            "no Sinatra-era static assets should be packaged"
   end
+
+  # The `lib/**/*.rb` glob excludes the shell wrappers under
+  # lib/hive/scripts/. Without the scripts-specific glob a clean gem install
+  # launches `bash <missing-file>`, the tmux session dies before Hive can
+  # inspect it, and `hive run` fails with claude_launch_failed. Pin both
+  # known scripts so a future glob edit that drops them is caught here.
+  def test_gem_package_includes_the_interactive_claude_wrapper_script
+    spec = Gem::Specification.load(GEMSPEC_PATH)
+
+    assert_includes spec.files, "lib/hive/scripts/interactive_claude_wrapper.sh"
+  end
+
+  def test_gem_package_includes_the_stop_hook_script
+    spec = Gem::Specification.load(GEMSPEC_PATH)
+
+    assert_includes spec.files, "lib/hive/scripts/stop_hook.sh"
+  end
+
+  # Enumeration-driven guard: any `scripts/<name>.sh` referenced from lib/
+  # (ClaudeLauncher#wrapper_command, StopHookInstaller::HOOK_PATH, and any
+  # future reference) must resolve to a real file that the gemspec packages.
+  # A hardcoded list drifts; scanning the source keeps new scripts covered.
+  def test_every_script_referenced_from_lib_is_packaged
+    referenced = referenced_script_paths
+    spec = Gem::Specification.load(GEMSPEC_PATH)
+
+    refute_empty referenced,
+                 "expected to discover at least one scripts/*.sh reference in lib/ " \
+                 "(a broken regex would make this test vacuously pass)"
+
+    referenced.each do |rel_path|
+      assert File.exist?(File.join(ROOT, rel_path)),
+             "#{rel_path} is referenced from lib/ but does not exist on disk"
+      assert_includes spec.files, rel_path,
+                      "#{rel_path} is referenced from lib/ but the gemspec does not package it"
+    end
+  end
+
+  # The heaviest guard: build the actual .gem artifact and read its packaged
+  # file list back, so a spec.files entry that silently fails to match a file
+  # on disk still fails here. Gated behind HIVE_GEM_BUILD_TEST so the default
+  # unit run stays fast; the lighter spec.files checks above always run.
+  def test_built_gem_artifact_contains_every_referenced_script
+    skip "set HIVE_GEM_BUILD_TEST=1 to build the real .gem artifact" unless ENV["HIVE_GEM_BUILD_TEST"]
+
+    referenced = referenced_script_paths
+    refute_empty referenced, "expected at least one scripts/*.sh reference in lib/"
+
+    packaged = built_gem_file_list
+    referenced.each do |rel_path|
+      assert_includes packaged, rel_path,
+                      "#{rel_path} is missing from the built .gem artifact"
+    end
+  end
+
+  private
+
+  # Scan lib/**/*.rb for string literals of the form `scripts/<name>.sh` and
+  # resolve each to its path under lib/hive/scripts/.
+  def referenced_script_paths
+    Dir[File.join(ROOT, "lib/**/*.rb")].flat_map do |file|
+      File.read(file).scan(%r{scripts/(\S+?\.sh)}).flatten
+    end.uniq.map { |name| "lib/hive/scripts/#{name}" }
+  end
+
+  # Build the real .gem artifact in a temp dir and return its packaged file
+  # list. The gemspec's relative globs resolve against ROOT, so evaluate the
+  # spec there while writing the artifact into the temp dir.
+  def built_gem_file_list
+    Dir.mktmpdir do |dir|
+      gem_path = Dir.chdir(ROOT) do
+        spec = Gem::Specification.load(GEMSPEC_PATH)
+        # Gem::Package.build emits Name/Version/File lines to stdout; route it
+        # through SilentUI so the gated build test stays quiet.
+        built = Gem::DefaultUserInteraction.use_ui(Gem::SilentUI.new) do
+          Gem::Package.build(spec)
+        end
+        # Gem::Package.build writes the .gem into cwd (ROOT); move it into the
+        # tempdir and guarantee no stray artifact survives in the working tree
+        # even if the move (or anything after the build) raises.
+        begin
+          FileUtils.mv(built, dir)
+        ensure
+          FileUtils.rm_f(File.join(ROOT, built))
+        end
+        File.join(dir, built)
+      end
+      Gem::Package.new(gem_path).spec.files
+    end
+  end
 end
