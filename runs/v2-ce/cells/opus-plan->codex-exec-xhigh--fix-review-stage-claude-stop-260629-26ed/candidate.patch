+require_relative "../../../test_helper"
+require "hive/stages/review"
+
+class ReviewFixCompletionFallbackTest < Minitest::Test
+  include HiveTestHelper
+
+  FakeTask = Struct.new(:folder, :slug, keyword_init: true) do
+    def state_file = File.join(folder, "task.md")
+  end
+
+  def test_accepts_dirty_worktree_as_auto_commit_evidence
+    evidence = Hive::Stages::Review.send(
+      :fix_completion_fallback_evidence,
+      fix_result: { status: :ok },
+      post_fix_status: :dirty,
+      before_fix_head: "abc",
+      after_fix_head: "abc"
+    )
+
+    assert evidence.accepted
+    assert_equal "dirty", evidence.evidence
+  end
+
+  def test_accepts_new_commit_as_evidence
+    evidence = Hive::Stages::Review.send(
+      :fix_completion_fallback_evidence,
+      fix_result: { status: :ok },
+      post_fix_status: :clean,
+      before_fix_head: "abc",
+      after_fix_head: "def"
+    )
+
+    assert evidence.accepted
+    assert_equal "commit:def", evidence.evidence
+  end
+
+  def test_accepts_clean_no_commit_only_with_explicit_no_change_evidence
+    evidence = Hive::Stages::Review.send(
+      :fix_completion_fallback_evidence,
+      fix_result: { status: :ok, final_message: "No code changes were needed." },
+      post_fix_status: :clean,
+      before_fix_head: "abc",
+      after_fix_head: "abc"
+    )
+
+    assert evidence.accepted
+    assert_equal "no_change", evidence.evidence
+  end
+
+  def test_rejects_clean_no_commit_without_explicit_evidence
+    evidence = Hive::Stages::Review.send(
+      :fix_completion_fallback_evidence,
+      fix_result: { status: :ok, final_message: "Done." },
+      post_fix_status: :clean,
+      before_fix_head: "abc",
+      after_fix_head: "abc"
+    )
+
+    refute evidence.accepted
+    assert_equal "missing", evidence.evidence
+    assert_match(/without a new commit/, evidence.message)
+  end
+
+  def test_missing_heads_do_not_count_as_no_change_evidence
+    evidence = Hive::Stages::Review.send(
+      :fix_completion_fallback_evidence,
+      fix_result: { status: :ok, final_message: "No fix needed." },
+      post_fix_status: :clean,
+      before_fix_head: nil,
+      after_fix_head: nil
+    )
+
+    refute evidence.accepted
+  end
+
+  def test_emit_claude_completion_fallback_writes_warn_payload
+    with_tmp_dir do |dir|
+      task = FakeTask.new(folder: dir, slug: "demo-260629-abcd")
+      File.write(task.state_file, "# task\n")
+
+      record = Hive::Stages::Review.send(
+        :emit_claude_completion_fallback,
+        task,
+        pass: 1,
+        fix_result: {
+          completion_reason: "idle_prompt_no_sentinel",
+          log_label: "review fix"
+        },
+        evidence: "dirty"
+      )
+
+      assert_equal "claude_completion_fallback", record.fetch("event_type")
+      assert_equal "claude", record.fetch("agent")
+      message = record.fetch("message")
+      assert_includes message, "level=warn"
+      assert_includes message, "phase=fix"
+      assert_includes message, "pass=01"
+      assert_includes message, "sentinel=#{File.join(dir, '.done')}"
+      assert_includes message, "reason=idle_prompt_no_sentinel"
+      assert_includes message, "session=review_fix"
+      assert_includes message, "evidence=dirty"
+      assert_includes message, "slug=demo-260629-abcd"
+    end
+  end
+
+  def test_emit_claude_completion_fallback_is_best_effort
+    with_tmp_dir do |dir|
+      task = FakeTask.new(folder: dir, slug: "demo-260629-abcd")
+
+      with_replaced_singleton_method(Hive::Events, :emit, ->(**_kwargs) { raise IOError, "blocked" }) do
+        result = Hive::Stages::Review.send(
+          :emit_claude_completion_fallback,
+          task,
+          pass: 1,
+          fix_result: { completion_reason: "idle_prompt_no_sentinel" },
+          evidence: "dirty"
+        )
+
+        assert_nil result
+      end
+    end
+  end
+end
