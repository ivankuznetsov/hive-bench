+      def fix_completion_accepted?(fix_result:, post_fix_status:, before_fix_head:, after_fix_head:)
+        fix_completion_fallback_evidence(
+          fix_result: fix_result,
+          post_fix_status: post_fix_status,
+          before_fix_head: before_fix_head,
+          after_fix_head: after_fix_head
+        ).accepted
