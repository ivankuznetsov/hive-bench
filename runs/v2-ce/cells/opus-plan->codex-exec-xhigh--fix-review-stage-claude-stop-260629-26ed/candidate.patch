+
+      def fix_completion_fallback_evidence(fix_result:, post_fix_status:, before_fix_head:, after_fix_head:)
+        if post_fix_status == :dirty
+          return FixCompletionEvidence.new(
+            accepted: true,
+            evidence: "dirty",
+            message: "post-fix worktree is dirty and will be auto-committed"
+          )
+        end
+
+        if head_present?(before_fix_head) && head_present?(after_fix_head) && after_fix_head != before_fix_head
+          return FixCompletionEvidence.new(
+            accepted: true,
+            evidence: "commit:#{after_fix_head}",
+            message: "fix agent already created commit #{after_fix_head}"
+          )
+        end
+
+        if post_fix_status == :clean &&
+           head_present?(before_fix_head) &&
+           after_fix_head == before_fix_head &&
+           explicit_no_change_evidence?(fix_result)
+          return FixCompletionEvidence.new(
+            accepted: true,
+            evidence: "no_change",
+            message: "fix agent explicitly reported that no code change was required"
+          )
+        end
+
+        FixCompletionEvidence.new(
+          accepted: false,
+          evidence: "missing",
+          message: "clean worktree without a new commit or explicit no-change evidence"
+        )
+      end
+
+      def head_present?(head)
+        !head.to_s.strip.empty?
+      end
+
+      def explicit_no_change_evidence?(fix_result)
+        text = [
+          fix_result && fix_result[:final_message],
+          fix_result && fix_result[:message]
+        ].compact.join("\n")
+        return false if text.strip.empty?
+
+        NO_CHANGE_EVIDENCE_PATTERNS.any? { |pattern| text.match?(pattern) }
+      end
+
+      def emit_claude_completion_fallback(task, pass:, fix_result:, evidence:)
+        reason = fix_result[:completion_reason] || "unknown"
+        session = fallback_session_label(fix_result)
+        message = [
+          "level=warn",
+          "phase=fix",
+          "pass=#{format('%02d', pass)}",
+          "sentinel=#{Hive::ClaudeLauncher.done_path(task)}",
+          "reason=#{reason}",
+          "session=#{session}",
+          "evidence=#{evidence}",
+          "slug=#{task.slug}"
+        ].join(" ")
+        Hive::Events.emit(
+          task_folder: task.folder,
+          slug: task.slug,
+          stage: "6-review", # coding-scoped: coding review stage event
+          agent: "claude",
+          event_type: :claude_completion_fallback,
+          message: message.gsub(/\s+/, " ")
+        )
+      rescue StandardError
+        nil
+      end
+
+      def fallback_session_label(fix_result)
+        value = fix_result[:session] ||
+                fix_result[:session_name] ||
+                fix_result[:pid] ||
+                fix_result[:log_label] ||
+                "unknown"
+        value.to_s.gsub(/\s+/, "_")
+      end
